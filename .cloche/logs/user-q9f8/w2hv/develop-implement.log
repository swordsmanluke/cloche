inish.\n\tgo func() {\n\t\ttime.Sleep(100 * time.Millisecond)\n\t\tbroadcaster.Publish(\"step-live-1\", logstream.LogLine{\n\t\t\tTimestamp: \"2026-03-12T10:00:03Z\",\n\t\t\tType:      \"llm\",\n\t\t\tContent:   \"Making changes now.\",\n\t\t\tStepName:  \"implement\",\n\t\t})\n\t\ttime.Sleep(50 * time.Millisecond)\n\t\tr, _ := store.GetRun(ctx, \"step-live-1\")\n\t\tr.Complete(domain.RunStateSucceeded)\n\t\t_ = store.UpdateRun(ctx, r)\n\t\tbroadcaster.Finish(\"step-live-1\")\n\t}()\n\n\terr = srv.StreamLogs(&pb.StreamLogsRequest{\n\t\tRunId:    \"step-live-1\",\n\t\tStepName: \"implement\",\n\t}, mock)\n\trequire.NoError(t, err)\n\n\t// Should have received only implement-step entries (history + live) + run_completed.\n\tvar logEntries []*pb.LogEntry\n\tvar foundRunCompleted bool\n\tfor _, e := range mock.entries {\n\t\tswitch e.Type {\n\t\tcase \"log\":\n\t\t\tlogEntries = append(logEntries, e)\n\t\tcase \"run_completed\":\n\t\t\tfoundRunCompleted = true\n\t\t}\n\t}\n\n\trequire.Len(t, logEntries, 3, \"should have 3 log entries for implement step\")\n\tassert.Equal(t, \"step_started: implement\", logEntries[0].Message)\n\tassert.Equal(t, \"implement\", logEntries[0].StepName)\n\tassert.Equal(t, \"Reading the codebase...\", logEntries[1].Message)\n\tassert.Equal(t, \"Making changes now.\", logEntries[2].Message)\n\tassert.True(t, foundRunCompleted, \"should receive run_completed\")\n\n\t// None of the log entries should be for the \"test\" step.\n\tfor _, e := range logEntries {\n\t\tassert.NotEqual(t, \"test\", e.StepName, \"should not contain test step entries\")\n\t}\n}"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":207,"cache_read_input_tokens":99094,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":207},"output_tokens":24,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"f92ec9ed-6