{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018TVEiXKsY56mRuA4mioKAx","type":"tool_result","content":"     1→package web\n     2→\n     3→import (\n     4→\t\"bufio\"\n     5→\t\"context\"\n     6→\t\"embed\"\n     7→\t\"encoding/json\"\n     8→\t\"fmt\"\n     9→\t\"html/template\"\n    10→\t\"io/fs\"\n    11→\t\"net/http\"\n    12→\t\"net/url\"\n    13→\t\"os\"\n    14→\t\"os/exec\"\n    15→\t\"path/filepath\"\n    16→\t\"regexp\"\n    17→\t\"sort\"\n    18→\t\"strconv\"\n    19→\t\"strings\"\n    20→\t\"time\"\n    21→\n    22→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    23→\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    24→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    25→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    26→)\n    27→\n    28→// HandlerOption configures optional Handler dependencies.\n    29→type HandlerOption func(*Handler)\n    30→\n    31→// WithContainerLogger sets the container runtime for fetching live logs.\n    32→func WithContainerLogger(c ContainerLogger) HandlerOption {\n    33→\treturn func(h *Handler) { h.container = c }\n    34→}\n    35→\n    36→// WithContainerManager sets a full container manager (logs, inspect, remove).\n    37→func WithContainerManager(c ContainerManager) HandlerOption {\n    38→\treturn func(h *Handler) { h.container = c }\n    39→}\n    40→\n    41→// WithLogBroadcaster sets the log broadcaster for SSE streaming.\n    42→func WithLogBroadcaster(b *logstream.Broadcaster) HandlerOption {\n    43→\treturn func(h *Handler) { h.logBroadcast = b }\n    44→}\n    45→\n    46→// WithLogStore sets the log store for indexed log file lookups.\n    47→func WithLogStore(ls ports.LogStore) HandlerOption {\n    48→\treturn func(h *Handler) { h.logStore = ls }\n    49→}\n    50→\n    51→// WithTaskProvider sets the task provider for querying orchestration loop task state.\n    52→func WithTaskProvider(tp TaskProvider) HandlerOption {\n    53→\treturn func(h *Handler) { h.taskProvider = tp }\n    54→}\n    55→\n    56→//go:embed templates/*.html static/*\n    57→var content embed.FS\n    58→\n    59→// Handler serves the web dashboard.\n    60→// ContainerLogger can retrieve logs from a container by ID.\n    61→type ContainerLogger interface {\n    62→\tLogs(ctx context.Context, containerID string) (string, error)\n    63→}\n    64→\n    65→// ContainerManager extends ContainerLogger with container lifecycle operations.\n    66→type ContainerManager interface {\n    67→\tContainerLogger\n    68→\tStop(ctx context.Context, containerID string) error\n    69→\tRemove(ctx context.Context, containerID string) error\n    70→\tInspect(ctx context.Context, containerID string) (*ports.ContainerStatus, error)\n    71→}\n    72→\n    73→// TaskEntry represents a task with its assignment state for external consumers.\n    74→type TaskEntry struct {\n    75→\tID          string            `json:\"id\"`\n    76→\tStatus      string            `json:\"status\"`\n    77→\tTitle       string            `json:\"title\"`\n    78→\tDescription string            `json:\"description,omitempty\"`\n    79→\tMetadata    map[string]string `json:\"metadata,omitempty\"`\n    80→\tAssigned    bool              `json:\"assigned\"`\n    81→\tAssignedAt  string            `json:\"assigned_at,omitempty\"`\n    82→\tRunID       string            `json:\"run_id,omitempty\"`\n    83→}\n    84→\n    85→// TaskProvider retrieves task pipeline state for a project's orchestration loop.\n    86→type TaskProvider interface {\n    87→\tGetLoopTasks(projectDir string) []TaskEntry\n    88→}\n    89→\n    90→type Handler struct {\n    91→\tstore        ports.RunStore\n    92→\tcaptures     ports.CaptureStore\n    93→\tlogStore     ports.LogStore\n    94→\tcontainer    ContainerLogger\n    95→\tlogBroadcast *logstream.Broadcaster\n    96→\ttaskProvider TaskProvider\n    97→\tpages        map[string]*template.Template\n    98→\tmux          *http.ServeMux\n    99→}\n   100→\n   101→// NewHandler creates a web dashboard handler.\n   102→func NewHandler(store ports.RunStore, captures ports.CaptureStore, opts ...HandlerOption) (*Handler, error) {\n   103→\tfuncMap := template.FuncMap{\n   104→\t\t\"stateColor\":       stateColor,\n   105→\t\t\"healthColor\":      healthColor,\n   106→\t\t\"formatTime\":       formatTime,\n   107→\t\t\"formatDuration\":   formatDuration,\n   108→\t\t\"formatRunTiming\":  formatRunTiming,\n   109→\t\t\"truncate\":         truncate,\n   110→\t\t\"shortContainerID\": shortContainerID,\n   111→\t}\n   112→\n   113→\tbase, err := template.New(\"\").Funcs(funcMap).ParseFS(content, \"templates/layout.html\")\n   114→\tif err != nil {\n   115→\t\treturn nil, fmt.Errorf(\"parse layout: %w\", err)\n   116→\t}\n   117→\n   118→\tpages := map[string]*template.Template{}\n   119→\tfor _, page := range []string{\"projects\", \"runs\", \"run_detail\", \"project_detail\"} {\n   120→\t\tclone, err := base.Clone()\n   121→\t\tif err != nil {\n   122→\t\t\treturn nil, fmt.Errorf(\"clone layout for %s: %w\", page, err)\n   123→\t\t}\n   124→\t\t_, err = clone.ParseFS(content, \"templates/\"+page+\".html\")\n   125→\t\tif err != nil {\n   126→\t\t\treturn nil, fmt.Errorf(\"parse %s: %w\", page, err)\n   127→\t\t}\n   128→\t\tpages[page] = clone\n   129→\t}\n   130→\n   131→\th := &Handler{\n   132→\t\tstore:    store,\n   133→\t\tcaptures: captures,\n   134→\t\tpages:    pages,\n   135→\t\tmux:      http.NewServeMux(),\n   136→\t}\n   137→\tfor _, opt := range opts {\n   138→\t\topt(h)\n   139→\t}\n   140→\n   141→\tstaticFS, err := fs.Sub(content, \"static\")\n   142→\tif err != nil {\n   143→\t\treturn nil, fmt.Errorf(\"static sub-fs: %w\", err)\n   144→\t}\n   145→\n   146→\th.mux.HandleFunc(\"GET /{$}\", h.handleProjectOverview)\n   147→\th.mux.HandleFunc(\"GET /projects/{name}/runs\", h.handleProjectRuns)\n   148→\th.mux.HandleFunc(\"GET /runs\", h.handleRunsList)\n   149→\th.mux.HandleFunc(\"GET /runs/{id}\", h.handleRunDetail)\n   150→\th.mux.HandleFunc(\"GET /projects/{name}\", h.handleProjectDetail)\n   151→\th.mux.HandleFunc(\"GET /api/projects\", h.handleAPIProjects)\n   152→\th.mux.HandleFunc(\"GET /api/runs\", h.handleAPIRuns)\n   153→\th.mux.HandleFunc(\"GET /api/runs/{id}\", h.handleAPIRunDetail)\n   154→\th.mux.HandleFunc(\"GET /api/runs/{id}/steps/{step}/output\", h.handleAPIStepOutput)\n   155→\th.mux.HandleFunc(\"POST /api/runs/{id}/stop\", h.handleAPIStopRun)\n   156→\th.mux.HandleFunc(\"DELETE /api/runs/{id}/container\", h.handleAPIDeleteContainer)\n   157→\th.mux.HandleFunc(\"DELETE /api/projects/{name}/containers\", h.handleAPIDeleteProjectContainers)\n   158→\th.mux.HandleFunc(\"GET /api/projects/{name}/info\", h.handleAPIProjectInfo)\n   159→\th.mux.HandleFunc(\"GET /api/projects/{name}/info/prompt-diff\", h.handleAPIPromptDiff)\n   160→\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows\", h.handleAPIWorkflows)\n   161→\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows/{workflow}/steps/{step}/content\", h.handleAPIStepContent)\n   162→\th.mux.HandleFunc(\"GET /api/projects/{name}/tasks\", h.handleAPITasks)\n   163→\th.mux.HandleFunc(\"GET /api/runs/{id}/stream\", h.handleAPIStream)\n   164→\th.mux.Handle(\"GET /static/\", http.StripPrefix(\"/static/\", http.FileServerFS(staticFS)))\n   165→\n   166→\treturn h, nil\n   167→}\n   168→\n   169→func (h *Handler) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n   170→\th.mux.ServeHTTP(w, r)\n   171→}\n   172→\n   173→// --- HTML handlers ---\n   174→\n   175→// projectOverviewEntry holds data for a single project card on the landing page.\n   176→type projectOverviewEntry struct {\n   177→\tDir         string\n   178→\tLabel       string\n   179→\tHealth      domain.HealthResult\n   180→\tRecentRuns  []recentRunDot\n   181→\tActiveCount int\n   182→}\n   183→\n   184→// recentRunDot is a minimal representation of a run for the mini history display.\n   185→type recentRunDot struct {\n   186→\tID    string\n   187→\tState string\n   188→}\n   189→\n   190→const healthWindowSize = 10\n   191→\n   192→func (h *Handler) handleProjectOverview(w http.ResponseWriter, r *http.Request) {\n   193→\tprojects, _ := h.store.ListProjects(r.Context())\n   194→\tlabels := projectLabels(projects)\n   195→\n   196→\tvar entries []projectOverviewEntry\n   197→\tfor _, dir := range projects {\n   198→\t\truns, err := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   199→\t\tif err != nil {\n   200→\t\t\tcontinue\n   201→\t\t}\n   202→\n   203→\t\t// Convert []*domain.Run to []domain.Run for CalculateHealth.\n   204→\t\trunValues := make([]domain.Run, len(runs))\n   205→\t\tfor i, rr := range runs {\n   206→\t\t\trunValues[i] = *rr\n   207→\t\t}\n   208→\n   209→\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n   210→\n   211→\t\t// Take the last N runs for the mini history (most recent first).\n   212→\t\tn := healthWindowSize\n   213→\t\tif n > len(runs) {\n   214→\t\t\tn = len(runs)\n   215→\t\t}\n   216→\t\tdots := make([]recentRunDot, n)\n   217→\t\tfor i := 0; i < n; i++ {\n   218→\t\t\tdots[i] = recentRunDot{\n   219→\t\t\t\tID:    runs[i].ID,\n   220→\t\t\t\tState: string(runs[i].State),\n   221→\t\t\t}\n   222→\t\t}\n   223→\n   224→\t\tvar activeCount int\n   225→\t\tfor _, rr := range runs {\n   226→\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n   227→\t\t\t\tactiveCount++\n   228→\t\t\t}\n   229→\t\t}\n   230→\n   231→\t\tentries = append(entries, projectOverviewEntry{\n   232→\t\t\tDir:         dir,\n   233→\t\t\tLabel:       labels[dir],\n   234→\t\t\tHealth:      health,\n   235→\t\t\tRecentRuns:  dots,\n   236→\t\t\tActiveCount: activeCount,\n   237→\t\t})\n   238→\t}\n   239→\n   240→\tsort.Slice(entries, func(i, j int) bool {\n   241→\t\treturn entries[i].Label < entries[j].Label\n   242→\t})\n   243→\n   244→\tdata := map[string]any{\n   245→\t\t\"Title\":    \"Projects\",\n   246→\t\t\"Projects\": entries,\n   247→\t}\n   248→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   249→\tif err := h.pages[\"projects\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   250→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)"}]},"parent_tool_use_id":"toolu_01GWWMA1CrXYCFuDSqMwPuU1","session_id":"f92ec9ed-6750-474b-9b04-f794ca7ab54a","uuid":"50243c12-763c-4a5c-905b-b406c426edcd"}
