{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SYpNwbPJyTL2yyEpM9uGep","type":"tool_result","content":"diff --git a/internal/adapters/grpc/server.go b/internal/adapters/grpc/server.go\nindex f7bd363..7fc8e4f 100644\n--- a/internal/adapters/grpc/server.go\n+++ b/internal/adapters/grpc/server.go\n@@ -473,7 +473,12 @@ func (s *ClocheServer) StreamLogs(req *pb.StreamLogsRequest, stream rpcgrpc.Serv\n \t}\n \n \t// If step_name or log_type filter is set, serve content directly from the log index\n+\t// For active runs, fall through to live streaming filtered by step.\n \tif req.StepName != \"\" || req.LogType != \"\" {\n+\t\tisActive := run.State == domain.RunStateRunning || run.State == domain.RunStatePending\n+\t\tif isActive && s.logBroadcast != nil {\n+\t\t\treturn s.streamFilteredLive(req.RunId, req.StepName, req.LogType, stream)\n+\t\t}\n \t\treturn s.streamFilteredLogs(ctx, req, run, stream)\n \t}\n \n@@ -564,6 +569,72 @@ func (s *ClocheServer) StreamLogs(req *pb.StreamLogsRequest, stream rpcgrpc.Serv\n \treturn nil\n }\n \n+// streamFilteredLive serves step-filtered log history followed by live streaming\n+// for active runs. It uses SubscribeWithHistory to avoid gaps.\n+func (s *ClocheServer) streamFilteredLive(runID, stepName, logType string, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n+\tsub, history := s.logBroadcast.SubscribeWithHistory(runID)\n+\tdefer s.logBroadcast.Unsubscribe(runID, sub)\n+\n+\tmatchesFilter := func(line logstream.LogLine) bool {\n+\t\tif stepName != \"\" && line.StepName != stepName {\n+\t\t\treturn false\n+\t\t}\n+\t\tif logType != \"\" && line.Type != logType {\n+\t\t\treturn false\n+\t\t}\n+\t\treturn true\n+\t}\n+\n+\t// Send historical lines first.\n+\tfor _, line := range history {\n+\t\tif !matchesFilter(line) {\n+\t\t\tcontinue\n+\t\t}\n+\t\tif err := stream.Send(&pb.LogEntry{\n+\t\t\tType:      \"log\",\n+\t\t\tStepName:  line.StepName,\n+\t\t\tMessage:   line.Content,\n+\t\t\tTimestamp: line.Timestamp,\n+\t\t}); err != nil {\n+\t\t\treturn err\n+\t\t}\n+\t}\n+\n+\t// Stream live lines filtered by step/type.\n+\tctx := stream.Context()\n+\tfor {\n+\t\tselect {\n+\t\tcase <-ctx.Done():\n+\t\t\treturn ctx.Err()\n+\t\tcase line, ok := <-sub.C:\n+\t\t\tif !ok {\n+\t\t\t\t// Run completed — send terminal entry.\n+\t\t\t\trun, err := s.store.GetRun(context.Background(), runID)\n+\t\t\t\tif err == nil && run.State != domain.RunStateRunning && run.State != domain.RunStatePending {\n+\t\t\t\t\t_ = stream.Send(&pb.LogEntry{\n+\t\t\t\t\t\tType:      \"run_completed\",\n+\t\t\t\t\t\tResult:    string(run.State),\n+\t\t\t\t\t\tTimestamp: run.CompletedAt.String(),\n+\t\t\t\t\t\tMessage:   run.ErrorMessage,\n+\t\t\t\t\t})\n+\t\t\t\t}\n+\t\t\t\treturn nil\n+\t\t\t}\n+\t\t\tif !matchesFilter(line) {\n+\t\t\t\tcontinue\n+\t\t\t}\n+\t\t\tif err := stream.Send(&pb.LogEntry{\n+\t\t\t\tType:      \"log\",\n+\t\t\t\tStepName:  line.StepName,\n+\t\t\t\tMessage:   line.Content,\n+\t\t\t\tTimestamp: line.Timestamp,\n+\t\t\t}); err != nil {\n+\t\t\t\treturn err\n+\t\t\t}\n+\t\t}\n+\t}\n+}\n+\n // streamFilteredLogs serves log content filtered by step name and/or log type.\n // It uses the log index when available, falling back to file path conventions.\n func (s *ClocheServer) streamFilteredLogs(ctx context.Context, req *pb.StreamLogsRequest, run *domain.Run, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\ndiff --git a/internal/logstream/broadcaster.go b/internal/logstream/broadcaster.go\nindex c02adfe..ff7e333 100644\n--- a/internal/logstream/broadcaster.go\n+++ b/internal/logstream/broadcaster.go\n@@ -37,6 +37,7 @@ type Broadcaster struct {\n \n type runBroadcast struct {\n \tsubscribers []*Subscriber\n+\thistory     []LogLine\n \tdone        bool\n }\n \n@@ -91,15 +92,19 @@ func (b *Broadcaster) Unsubscribe(runID string, sub *Subscriber) {\n \n // Publish sends a log line to all subscribers of the given run.\n // Non-blocking: if a subscriber's buffer is full, the line is dropped for that subscriber.\n+// The line is also appended to the run's history buffer for late joiners.\n func (b *Broadcaster) Publish(runID string, line LogLine) {\n \tb.mu.Lock()\n \tdefer b.mu.Unlock()\n \n \trb, ok := b.runs[runID]\n \tif !ok {\n-\t\treturn\n+\t\trb = &runBroadcast{}\n+\t\tb.runs[runID] = rb\n \t}\n \n+\trb.history = append(rb.history, line)\n+\n \tfor _, sub := range rb.subscribers {\n \t\tselect {\n \t\tcase sub.ch <- line:\n@@ -138,3 +143,46 @@ func (b *Broadcaster) IsActive(runID string) bool {\n \t}\n \treturn !rb.done\n }\n+\n+// History returns a copy of all log lines published for the given run so far.\n+// Returns nil if the run is unknown.\n+func (b *Broadcaster) History(runID string) []LogLine {\n+\tb.mu.Lock()\n+\tdefer b.mu.Unlock()\n+\n+\trb, ok := b.runs[runID]\n+\tif !ok {\n+\t\treturn nil\n+\t}\n+\tout := make([]LogLine, len(rb.history))\n+\tcopy(out, rb.history)\n+\treturn out\n+}\n+\n+// SubscribeWithHistory atomically returns the accumulated history and a\n+// subscriber for future lines. This avoids the gap that would exist if\n+// History and Subscribe were called separately.\n+// If the run is already finished the subscriber channel is closed and the\n+// full history is still returned.\n+func (b *Broadcaster) SubscribeWithHistory(runID string) (*Subscriber, []LogLine) {\n+\tb.mu.Lock()\n+\tdefer b.mu.Unlock()\n+\n+\trb, ok := b.runs[runID]\n+\tif !ok {\n+\t\tsub := newSubscriber(256)\n+\t\tsub.close()\n+\t\treturn sub, nil\n+\t}\n+\n+\thist := make([]LogLine, len(rb.history))\n+\tcopy(hist, rb.history)\n+\n+\tsub := newSubscriber(256)\n+\tif rb.done {\n+\t\tsub.close()\n+\t\treturn sub, hist\n+\t}\n+\trb.subscribers = append(rb.subscribers, sub)\n+\treturn sub, hist\n+}","is_error":false}]},"parent_tool_use_id":null,"session_id":"32a9924e-c776-408c-8085-162da40f446c","uuid":"6a084e19-b8c0-45c1-b434-30806fc6a9a2","tool_use_result":{"stdout":"diff --git a/internal/adapters/grpc/server.go b/internal/adapte