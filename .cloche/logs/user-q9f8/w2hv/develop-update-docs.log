unID string) {\n   120→\tb.mu.Lock()\n   121→\tdefer b.mu.Unlock()\n   122→\n   123→\trb, ok := b.runs[runID]\n   124→\tif !ok {\n   125→\t\treturn\n   126→\t}\n   127→\n   128→\trb.done = true\n   129→\tfor _, sub := range rb.subscribers {\n   130→\t\tsub.close()\n   131→\t}\n   132→\trb.subscribers = nil\n   133→}\n   134→\n   135→// IsActive reports whether the given run has an active broadcast (not finished).\n   136→func (b *Broadcaster) IsActive(runID string) bool {\n   137→\tb.mu.Lock()\n   138→\tdefer b.mu.Unlock()\n   139→\n   140→\trb, ok := b.runs[runID]\n   141→\tif !ok {\n   142→\t\treturn false\n   143→\t}\n   144→\treturn !rb.done\n   145→}\n   146→\n   147→// History returns a copy of all log lines published for the given run so far.\n   148→// Returns nil if the run is unknown.\n   149→func (b *Broadcaster) History(runID string) []LogLine {\n   150→\tb.mu.Lock()\n   151→\tdefer b.mu.Unlock()\n   152→\n   153→\trb, ok := b.runs[runID]\n   154→\tif !ok {\n   155→\t\treturn nil\n   156→\t}\n   157→\tout := make([]LogLine, len(rb.history))\n   158→\tcopy(out, rb.history)\n   159→\treturn out\n   160→}\n   161→\n   162→// SubscribeWithHistory atomically returns the accumulated history and a\n   163→// subscriber for future lines. This avoids the gap that would exist if\n   164→// History and Subscribe were called separately.\n   165→// If the run is already finished the subscriber channel is closed and the\n   166→// full history is still returned.\n   167→func (b *Broadcaster) SubscribeWithHistory(runID string) (*Subscriber, []LogLine) {\n   168→\tb.mu.Lock()\n   169→\tdefer b.mu.Unlock()\n   170→\n   171→\trb, ok := b.runs[runID]\n   172→\tif !ok {\n   173→\t\tsub := newSubscriber(256)\n   174→\t\tsub.close()\n   175→\t\treturn sub, nil\n   176→\t}\n   177→\n   178→\thist := make([]LogLine, len(rb.history))\n   179→\tcopy(hist, rb.history)\n   180→\n   181→\tsub := newSubscriber(256)\n   182→\tif rb.done {\n   183→\t\tsub.close()\n   184→\t\treturn sub