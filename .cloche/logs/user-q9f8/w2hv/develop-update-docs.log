{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012ARWBzneceUihGUrSWhXEx","type":"tool_result","content":"     1→package grpc\n     2→\n     3→import (\n     4→\t\"bufio\"\n     5→\t\"context\"\n     6→\t\"encoding/json\"\n     7→\t\"fmt\"\n     8→\t\"log\"\n     9→\t\"os\"\n    10→\t\"os/exec\"\n    11→\t\"path/filepath\"\n    12→\t\"strings\"\n    13→\t\"sync\"\n    14→\t\"time\"\n    15→\n    16→\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    17→\t\"github.com/cloche-dev/cloche/internal/adapters/docker\"\n    18→\t\"github.com/cloche-dev/cloche/internal/adapters/web\"\n    19→\t\"github.com/cloche-dev/cloche/internal/config\"\n    20→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    21→\t\"github.com/cloche-dev/cloche/internal/evolution\"\n    22→\t\"github.com/cloche-dev/cloche/internal/host\"\n    23→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    24→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    25→\t\"github.com/cloche-dev/cloche/internal/protocol\"\n    26→\trpcgrpc \"google.golang.org/grpc\"\n    27→)\n    28→\n    29→type ClocheServer struct {\n    30→\tpb.UnimplementedClocheServiceServer\n    31→\tstore        ports.RunStore\n    32→\tcaptures     ports.CaptureStore\n    33→\tlogStore     ports.LogStore\n    34→\tcontainer    ports.ContainerRuntime\n    35→\tdefaultImage string\n    36→\tevolution    *evolution.Trigger\n    37→\tlogBroadcast *logstream.Broadcaster\n    38→\tshutdownFn   func()\n    39→\tmu           sync.Mutex\n    40→\trunIDs       map[string]string      // run_id -> container_id\n    41→\tloops        map[string]*host.Loop  // project_dir -> orchestration loop\n    42→}\n    43→\n    44→func NewClocheServer(store ports.RunStore, container ports.ContainerRuntime) *ClocheServer {\n    45→\treturn &ClocheServer{\n    46→\t\tstore:     store,\n    47→\t\tcontainer: container,\n    48→\t\trunIDs:    make(map[string]string),\n    49→\t\tloops:     make(map[string]*host.Loop),\n    50→\t}\n    51→}\n    52→\n    53→func NewClocheServerWithCaptures(store ports.RunStore, captures ports.CaptureStore, container ports.ContainerRuntime, defaultImage string) *ClocheServer {\n    54→\treturn &ClocheServer{\n    55→\t\tstore:        store,\n    56→\t\tcaptures:     captures,\n    57→\t\tcontainer:    container,\n    58→\t\tdefaultImage: defaultImage,\n    59→\t\trunIDs:       make(map[string]string),\n    60→\t\tloops:        make(map[string]*host.Loop),\n    61→\t}\n    62→}\n    63→\n    64→// SetLogStore attaches a log store to the server for indexing extracted log files.\n    65→func (s *ClocheServer) SetLogStore(ls ports.LogStore) {\n    66→\ts.logStore = ls\n    67→}\n    68→\n    69→\n    70→// SetEvolution attaches an evolution trigger to the server.\n    71→func (s *ClocheServer) SetEvolution(trigger *evolution.Trigger) {\n    72→\ts.evolution = trigger\n    73→}\n    74→\n    75→// SetLogBroadcaster attaches a log broadcaster for live-streaming LLM output.\n    76→func (s *ClocheServer) SetLogBroadcaster(b *logstream.Broadcaster) {\n    77→\ts.logBroadcast = b\n    78→}\n    79→\n    80→// SetShutdownFunc sets the callback invoked when the Shutdown RPC is called.\n    81→func (s *ClocheServer) SetShutdownFunc(fn func()) {\n    82→\ts.shutdownFn = fn\n    83→}\n    84→\n    85→func (s *ClocheServer) RunWorkflow(ctx context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error) {\n    86→\tif s.container == nil {\n    87→\t\treturn nil, fmt.Errorf(\"no container runtime configured\")\n    88→\t}\n    89→\n    90→\t// Generate a unique run ID, retrying on collision\n    91→\tvar runID string\n    92→\tfor attempts := 0; attempts < 10; attempts++ {\n    93→\t\trunID = domain.GenerateRunID(req.WorkflowName)\n    94→\t\texisting, err := s.store.GetRun(ctx, runID)\n    95→\t\tif err != nil {\n    96→\t\t\tbreak // ID is free\n    97→\t\t}\n    98→\t\t// Reuse if completed more than 1 hour ago\n    99→\t\tif !existing.CompletedAt.IsZero() && time.Since(existing.CompletedAt) > time.Hour {\n   100→\t\t\t_ = s.store.DeleteRun(ctx, runID)\n   101→\t\t\tbreak\n   102→\t\t}\n   103→\t}\n   104→\n   105→\t// Write prompt to .cloche/<run-id>/prompt.txt (run-specific to avoid conflicts)\n   106→\tif req.Prompt != \"\" {\n   107→\t\tclocheDir := filepath.Join(req.ProjectDir, \".cloche\", runID)\n   108→\t\tif err := os.MkdirAll(clocheDir, 0755); err != nil {\n   109→\t\t\treturn nil, fmt.Errorf(\"creating .cloche dir: %w\", err)\n   110→\t\t}\n   111→\t\tif err := os.WriteFile(filepath.Join(clocheDir, \"prompt.txt\"), []byte(req.Prompt), 0644); err != nil {\n   112→\t\t\treturn nil, fmt.Errorf(\"writing prompt: %w\", err)\n   113→\t\t}\n   114→\t}\n   115→\trun := domain.NewRun(runID, req.WorkflowName)\n   116→\trun.ProjectDir = req.ProjectDir\n   117→\trun.Title = req.Title\n   118→\tif err := s.store.CreateRun(ctx, run); err != nil {\n   119→\t\treturn nil, fmt.Errorf(\"creating run: %w\", err)\n   120→\t}\n   121→\n   122→\t// Resolve image: request-level override, then server default\n   123→\timage := req.Image\n   124→\tif image == \"\" {\n   125→\t\timage = s.defaultImage\n   126→\t}\n   127→\n   128→\t// Launch container start + tracking in background so the RPC returns immediately.\n   129→\t// The run stays in \"pending\" state until the container is up.\n   130→\tgo s.launchAndTrack(runID, image, req.KeepContainer, req)\n   131→\n   132→\treturn &pb.RunWorkflowResponse{RunId: runID}, nil\n   133→}\n   134→\n   135→// launchAndTrack starts the container and then tracks it to completion.\n   136→// It runs in a background goroutine with its own context, independent of the\n   137→// RPC context which may be cancelled after RunWorkflow returns.\n   138→func (s *ClocheServer) launchAndTrack(runID, image string, keepContainer bool, req *pb.RunWorkflowRequest) {\n   139→\tctx := context.Background()\n   140→\n   141→\t// Auto-rebuild image if the project Dockerfile has changed since last build.\n   142→\tif ensurer, ok := s.container.(ports.ImageEnsurer); ok {\n   143→\t\tif err := ensurer.EnsureImage(ctx, req.ProjectDir, image); err != nil {\n   144→\t\t\trun, _ := s.store.GetRun(ctx, runID)\n   145→\t\t\tif run != nil {\n   146→\t\t\t\trun.Fail(fmt.Sprintf(\"failed to ensure image: %v\", err))\n   147→\t\t\t\t_ = s.store.UpdateRun(ctx, run)\n   148→\t\t\t}\n   149→\t\t\tlog.Printf(\"run %s: failed to ensure image: %v\", runID, err)\n   150→\t\t\t\treturn\n   151→\t\t}\n   152→\t}\n   153→\n   154→\tbaseSHA := gitHEAD(req.ProjectDir)\n   155→\n   156→\tcontainerID, err := s.container.Start(ctx, ports.ContainerConfig{\n   157→\t\tImage:        image,\n   158→\t\tWorkflowName: req.WorkflowName,\n   159→\t\tProjectDir:   req.ProjectDir,\n   160→\t\tRunID:        runID,\n   161→\t\tNetworkAllow: []string{\"*\"},\n   162→\t})\n   163→\tif err != nil {\n   164→\t\trun, _ := s.store.GetRun(ctx, runID)\n   165→\t\tif run != nil {\n   166→\t\t\trun.Fail(fmt.Sprintf(\"failed to start container: %v\", err))\n   167→\t\t\t_ = s.store.UpdateRun(ctx, run)\n   168→\t\t}\n   169→\t\tlog.Printf(\"run %s: failed to start container: %v\", runID, err)\n   170→\t\treturn\n   171→\t}\n   172→\n   173→\ts.mu.Lock()\n   174→\ts.runIDs[runID] = containerID\n   175→\ts.mu.Unlock()\n   176→\n   177→\trun, _ := s.store.GetRun(ctx, runID)\n   178→\tif run != nil {\n   179→\t\trun.Start()\n   180→\t\trun.ContainerID = containerID\n   181→\t\trun.BaseSHA = baseSHA\n   182→\t\t_ = s.store.UpdateRun(ctx, run)\n   183→\t}\n   184→\n   185→\ts.trackRun(runID, containerID, req.ProjectDir, req.WorkflowName, keepContainer)\n   186→}\n   187→\n   188→func (s *ClocheServer) trackRun(runID, containerID, projectDir, workflowName string, keepContainer bool) {\n   189→\tctx := context.Background()\n   190→\n   191→\t// Attach to agent output\n   192→\treader, err := s.container.AttachOutput(ctx, containerID)\n   193→\tif err != nil {\n   194→\t\tlog.Printf(\"failed to attach to output for run %s: %v\", runID, err)\n   195→\t\t\treturn\n   196→\t}\n   197→\n   198→\t// Parse JSON-lines status messages\n   199→\tvar reportedResult string // captured from MsgRunCompleted, persisted after branch extraction\n   200→\tscanner := bufio.NewScanner(reader)\n   201→\tscanner.Buffer(make([]byte, 0, 256*1024), 1024*1024) // 1MB max to handle large log messages\n   202→\tfor scanner.Scan() {\n   203→\t\tvar msg protocol.StatusMessage\n   204→\t\tif err := json.Unmarshal(scanner.Bytes(), &msg); err != nil {\n   205→\t\t\tcontinue\n   206→\t\t}\n   207→\n   208→\t\t// Fast path: log messages don't need store interaction.\n   209→\t\tif msg.Type == protocol.MsgLog {\n   210→\t\t\tif s.logBroadcast != nil {\n   211→\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n   212→\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n   213→\t\t\t\t\tType:      \"llm\",\n   214→\t\t\t\t\tContent:   msg.Message,\n   215→\t\t\t\t\tStepName:  msg.StepName,\n   216→\t\t\t\t})\n   217→\t\t\t}\n   218→\t\t\tcontinue\n   219→\t\t}\n   220→\n   221→\t\trun, err := s.store.GetRun(ctx, runID)\n   222→\t\tif err != nil {\n   223→\t\t\tcontinue\n   224→\t\t}\n   225→\n   226→\t\tswitch msg.Type {\n   227→\t\tcase protocol.MsgStepStarted:\n   228→\t\t\trun.RecordStepStart(msg.StepName)\n   229→\t\t\tif s.captures != nil {\n   230→\t\t\t\t_ = s.captures.SaveCapture(ctx, runID, &domain.StepExecution{\n   231→\t\t\t\t\tStepName:  msg.StepName,\n   232→\t\t\t\t\tStartedAt: msg.Timestamp,\n   233→\t\t\t\t})\n   234→\t\t\t}\n   235→\t\t\tif s.logBroadcast != nil {\n   236→\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n   237→\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n   238→\t\t\t\t\tType:      \"status\",\n   239→\t\t\t\t\tContent:   \"step_started: \" + msg.StepName,\n   240→\t\t\t\t\tStepName:  msg.StepName,\n   241→\t\t\t\t})\n   242→\t\t\t}\n   243→\t\tcase protocol.MsgStepCompleted:\n   244→\t\t\trun.RecordStepComplete(msg.StepName, msg.Result)\n   245→\t\t\tif s.captures != nil {\n   246→\t\t\t\t_ = s.captures.SaveCapture(ctx, runID, &domain.StepExecution{\n   247→\t\t\t\t\tStepName:    msg.StepName,\n   248→\t\t\t\t\tResult:      msg.Result,\n   249→\t\t\t\t\tCompletedAt: msg.Timestamp,\n   250→\t\t\t\t})\n   251→\t\t\t}\n   252→\t\t\tif s.logBroadcast != nil {\n   253→\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n   254→\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n   255→\t\t\t\t\tType:      \"status\",\n   256→\t\t\t\t\tContent:   \"step_completed: \" + msg.StepName + \" -> \" + msg.Result,\n   257→\t\t\t\t\tStepName:  msg.StepName,\n   258→\t\t\t\t})\n   259→\t\t\t}\n   260→\t\tcase protocol.MsgRunTitle:\n   261→\t\t\tif run.Title == \"\" {\n   262→\t\t\t\trun.Title = msg.Message\n   263→\t\t\t}\n   264→\t\tcase protocol.MsgRunCompleted:\n   265→\t\t\treportedResult = msg.Result\n   266→\t\t\tcontinue // Don't persist terminal state yet; branch extraction must finish first\n   267→\t\t}\n   268→\n   269→\t\t_ = s.store.UpdateRun(ctx, run)\n   270→\t}\n   271→\treader.Close()\n   272→\n   273→\t// Signal live-stream subscribers that this run is done.\n   274→\tif s.logBroadcast != nil {\n   275→\t\ts.logBroadcast.Finish(runID)\n   276→\t}\n   277→\n   278→\t// Wait for process exit\n   279→\texitCode, err := s.container.Wait(ctx, containerID)\n   280→\tif err != nil {\n   281→\t\tlog.Printf(\"error waiting for run %s: %v\", runID, err)\n   282→\t}\n   283→\n   284→\t// Extract step output files from container before it's removed\n   285→\toutputDst := filepath.Join(projectDir, \".cloche\", runID, \"output\")\n   286→\tif err := os.MkdirAll(outputDst, 0755); err == nil {\n   287→\t\tif cpErr := s.container.CopyFrom(ctx, containerID, \"/workspace/.cloche/output/.\", outputDst); cpErr != nil {\n   288→\t\t\tlog.Printf(\"run %s: failed to extract output: %v\", runID, cpErr)\n   289→\t\t}\n   290→\t}\n   291→\n   292→\t// Capture full container stdout/stderr before the container is removed\n   293→\tif logs, logErr := s.container.Logs(ctx, containerID); logErr == nil && logs != \"\" {\n   294→\t\tcontainerLogPath := filepath.Join(outputDst, \"container.log\")\n   295→\t\tif writeErr := os.WriteFile(containerLogPath, []byte(logs), 0644); writeErr != nil {\n   296→\t\t\tlog.Printf(\"run %s: failed to write container.log: %v\", runID, writeErr)\n   297→\t\t}\n   298→\t}\n   299→\n   300→\t// Index extracted log files in the log store\n   301→\tif s.logStore != nil {\n   302→\t\ts.indexLogFiles(ctx, runID, outputDst)\n   303→\t}\n   304→\n   305→\t// Extract results to git branch BEFORE finalizing state, so that\n   306→\t// WaitRun callers (e.g. host workflow merge step) see branches exist\n   307→\t// before the run is marked complete.\n   308→\tresultLabel := reportedResult\n   309→\tif resultLabel == \"\" {\n   310→\t\tif exitCode == 0 {\n   311→\t\t\tresultLabel = \"succeeded\"\n   312→\t\t} else {\n   313→\t\t\tresultLabel = \"failed\"\n   314→\t\t}\n   315→\t}\n   316→\t{\n   317→\t\textractRun, _ := s.store.GetRun(ctx, runID)\n   318→\t\tif extractRun != nil && extractRun.BaseSHA != \"\" {\n   319→\t\t\tlog.Printf(\"run %s: extracting results to branch cloche/%s (baseSHA=%s)\", runID, runID, extractRun.BaseSHA)\n   320→\t\t\tif err := docker.ExtractResults(ctx, containerID, extractRun.ProjectDir, runID, extractRun.BaseSHA, workflowName, resultLabel); err != nil {\n   321→\t\t\t\tlog.Printf(\"run %s: failed to extract results to branch: %v\", runID, err)\n   322→\t\t\t} else {\n   323→\t\t\t\tlog.Printf(\"run %s: branch cloche/%s created successfully\", runID, runID)\n   324→\t\t\t}\n   325→\t\t} else {\n   326→\t\t\tlog.Printf(\"run %s: skipping branch extraction (baseSHA empty or run not found)\", runID)\n   327→\t\t}\n   328→\t}\n   329→\n   330→\t// Now finalize run state\n   331→\trun, err := s.store.GetRun(ctx, runID)\n   332→\tif err != nil {\n   333→\t\treturn\n   334→\t}\n   335→\tif run.State == domain.RunStateRunning {\n   336→\t\tif reportedResult == \"succeeded\" {\n   337→\t\t\trun.Complete(domain.RunStateSucceeded)\n   338→\t\t} else if reportedResult != \"\" {\n   339→\t\t\trun.Complete(domain.RunStateFailed)\n   340→\t\t} else if exitCode == 0 {\n   341→\t\t\trun.Complete(domain.RunStateSucceeded)\n   342→\t\t} else {\n   343→\t\t\trun.Fail(fmt.Sprintf(\"container exited with code %d\", exitCode))\n   344→\t\t}\n   345→\t\t_ = s.store.UpdateRun(ctx, run)\n   346→\t}\n   347→\n   348→\t// Fire evolution trigger if configured\n   349→\tif s.evolution != nil {\n   350→\t\ts.evolution.Fire(projectDir, workflowName, runID)\n   351→\t}\n   352→\n   353→\t// Merge is handled as a workflow step in host.cloche, not here.\n   354→\n   355→\t// Container retention policy:\n   356→\t// - Failed runs: always keep the container for debugging\n   357→\t// - Successful runs + --keep-container: keep the container\n   358→\t// - Successful runs without --keep-container: remove the container\n   359→\trunFinal, _ := s.store.GetRun(ctx, runID)\n   360→\trunFailed := runFinal != nil && (runFinal.State == domain.RunStateFailed || runFinal.State == domain.RunStateCancelled)\n   361→\n   362→\tif keepContainer || runFailed {\n   363→\t\treason := \"--keep-container\"\n   364→\t\tif runFailed {\n   365→\t\t\treason = \"run failed\"\n   366→\t\t}\n   367→\t\tlog.Printf(\"run %s: keeping container %s (%s)\", runID, containerID, reason)\n   368→\t\tif runFinal != nil {\n   369→\t\t\trunFinal.ContainerKept = true\n   370→\t\t\t_ = s.store.UpdateRun(ctx, runFinal)\n   371→\t\t}\n   372→\t} else {\n   373→\t\tif err := s.container.Remove(ctx, containerID); err != nil {\n   374→\t\t\tlog.Printf(\"run %s: failed to remove container %s: %v\", runID, containerID, err)\n   375→\t\t} else {\n   376→\t\t\tlog.Printf(\"run %s: removed container %s\", runID, containerID)\n   377→\t\t}\n   378→\t}\n   379→\n   380→\t// Cleanup mapping\n   381→\ts.mu.Lock()\n   382→\tdelete(s.runIDs, runID)\n   383→\ts.mu.Unlock()\n   384→}\n   385→\n   386→func (s *ClocheServer) ListRuns(ctx context.Context, req *pb.ListRunsRequest) (*pb.ListRunsResponse, error) {\n   387→\tvar since time.Time\n   388→\tif !req.All {\n   389→\t\tsince = time.Now().Add(-1 * time.Hour)\n   390→\t}\n   391→\truns, err := s.store.ListRuns(ctx, since)\n   392→\tif err != nil {\n   393→\t\treturn nil, fmt.Errorf(\"listing runs: %w\", err)\n   394→\t}\n   395→\n   396→\tresp := &pb.ListRunsResponse{}\n   397→\tfor _, run := range runs {\n   398→\t\tresp.Runs = append(resp.Runs, &pb.RunSummary{\n   399→\t\t\tRunId:        run.ID,\n   400→\t\t\tWorkflowName: run.WorkflowName,\n   401→\t\t\tState:        string(run.State),\n   402→\t\t\tStartedAt:    run.StartedAt.String(),\n   403→\t\t\tErrorMessage: run.ErrorMessage,\n   404→\t\t\tContainerId:  run.ContainerID,\n   405→\t\t\tTitle:        run.Title,\n   406→\t\t\tIsHost:       run.IsHost,\n   407→\t\t})\n   408→\t}\n   409→\treturn resp, nil\n   410→}\n   411→\n   412→func (s *ClocheServer) GetStatus(ctx context.Context, req *pb.GetStatusRequest) (*pb.GetStatusResponse, error) {\n   413→\trun, err := s.store.GetRun(ctx, req.RunId)\n   414→\tif err != nil {\n   415→\t\treturn nil, fmt.Errorf(\"getting run: %w\", err)\n   416→\t}\n   417→\n   418→\tresp := &pb.GetStatusResponse{\n   419→\t\tRunId:        run.ID,\n   420→\t\tWorkflowName: run.WorkflowName,\n   421→\t\tState:        string(run.State),\n   422→\t\tCurrentStep:  strings.Join(run.ActiveSteps, \",\"),\n   423→\t\tErrorMessage: run.ErrorMessage,\n   424→\t\tContainerId:  run.ContainerID,\n   425→\t\tTitle:        run.Title,\n   426→\t\tIsHost:       run.IsHost,\n   427→\t}\n   428→\n   429→\t// Check container liveness\n   430→\tif run.ContainerID != \"\" && s.container != nil {\n   431→\t\tif cs, err := s.container.Inspect(ctx, run.ContainerID); err == nil {\n   432→\t\t\tresp.ContainerAlive = cs.Running\n   433→\t\t\tif !cs.Running && !cs.FinishedAt.IsZero() {\n   434→\t\t\t\tresp.ContainerDeadSince = cs.FinishedAt.Format(time.RFC3339Nano)\n   435→\t\t\t}\n   436→\t\t}\n   437→\t}\n   438→\n   439→\t// Load step executions from captures store if available\n   440→\tif s.captures != nil {\n   441→\t\tcaptures, err := s.captures.GetCaptures(ctx, req.RunId)\n   442→\t\tif err == nil {\n   443→\t\t\tfor _, exec := range captures {\n   444→\t\t\t\tresp.StepExecutions = append(resp.StepExecutions, &pb.StepExecutionStatus{\n   445→\t\t\t\t\tStepName:    exec.StepName,\n   446→\t\t\t\t\tResult:      exec.Result,\n   447→\t\t\t\t\tStartedAt:   exec.StartedAt.String(),\n   448→\t\t\t\t\tCompletedAt: exec.CompletedAt.String(),\n   449→\t\t\t\t})\n   450→\t\t\t}\n   451→\t\t}\n   452→\t} else {\n   453→\t\tfor _, exec := range run.StepExecutions {\n   454→\t\t\tresp.StepExecutions = append(resp.StepExecutions, &pb.StepExecutionStatus{\n   455→\t\t\t\tStepName:    exec.StepName,\n   456→\t\t\t\tResult:      exec.Result,\n   457→\t\t\t\tStartedAt:   exec.StartedAt.String(),\n   458→\t\t\t\tCompletedAt: exec.CompletedAt.String(),\n   459→\t\t\t})\n   460→\t\t}\n   461→\t}\n   462→\n   463→\treturn resp, nil\n   464→}\n   465→\n   466→func (s *ClocheServer) StreamLogs(req *pb.StreamLogsRequest, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n   467→\tctx := stream.Context()\n   468→\n   469→\t// Verify run exists\n   470→\trun, err := s.store.GetRun(ctx, req.RunId)\n   471→\tif err != nil {\n   472→\t\treturn fmt.Errorf(\"run %q not found: %w\", req.RunId, err)\n   473→\t}\n   474→\n   475→\t// If step_name or log_type filter is set, serve content directly from the log index\n   476→\t// For active runs, fall through to live streaming filtered by step.\n   477→\tif req.StepName != \"\" || req.LogType != \"\" {\n   478→\t\tisActive := run.State == domain.RunStateRunning || run.State == domain.RunStatePending\n   479→\t\tif isActive && s.logBroadcast != nil {\n   480→\t\t\treturn s.streamFilteredLive(req.RunId, req.StepName, req.LogType, stream)\n   481→\t\t}\n   482→\t\treturn s.streamFilteredLogs(ctx, req, run, stream)\n   483→\t}\n   484→\n   485→\t// For active runs, stream live from the broadcaster so callers can tail output.\n   486→\tif (run.State == domain.RunStateRunning || run.State == domain.RunStatePending) && s.logBroadcast != nil {\n   487→\t\treturn s.streamLiveLogs(req.RunId, stream)\n   488→\t}\n   489→\n   490→\tif s.captures == nil {\n   491→\t\treturn fmt.Errorf(\"captures store not configured\")\n   492→\t}\n   493→\n   494→\t// Check for full.log first — if it exists, serve it as the unified log\n   495→\tfullLogPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", \"full.log\")\n   496→\tif data, readErr := os.ReadFile(fullLogPath); readErr == nil && len(data) > 0 {\n   497→\t\tif err := stream.Send(&pb.LogEntry{\n   498→\t\t\tType:    \"full_log\",\n   499→\t\t\tMessage: string(data),\n   500→\t\t}); err != nil {\n   501→\t\t\treturn err\n   502→\t\t}\n   503→\t\t// Still send run completion entry\n   504→\t\tif run.State != domain.RunStateRunning && run.State != domain.RunStatePending {\n   505→\t\t\tif err := stream.Send(&pb.LogEntry{\n   506→\t\t\t\tType:      \"run_completed\",\n   507→\t\t\t\tResult:    string(run.State),\n   508→\t\t\t\tTimestamp: run.CompletedAt.String(),\n   509→\t\t\t\tMessage:   run.ErrorMessage,\n   510→\t\t\t}); err != nil {\n   511→\t\t\t\treturn err\n   512→\t\t\t}\n   513→\t\t}\n   514→\t\treturn nil\n   515→\t}\n   516→\n   517→\t// Fall back to capture-based streaming\n   518→\tcaptures, err := s.captures.GetCaptures(ctx, req.RunId)\n   519→\tif err != nil {\n   520→\t\treturn fmt.Errorf(\"getting captures: %w\", err)\n   521→\t}\n   522→\n   523→\tfor _, exec := range captures {\n   524→\t\t// Captures are stored as separate rows: one for step_started (no Result)\n   525→\t\t// and one for step_completed (has Result).\n   526→\t\tif exec.Result == \"\" {\n   527→\t\t\tentry := &pb.LogEntry{\n   528→\t\t\t\tType:      \"step_started\",\n   529→\t\t\t\tStepName:  exec.StepName,\n   530→\t\t\t\tTimestamp: exec.StartedAt.String(),\n   531→\t\t\t}\n   532→\t\t\tif err := stream.Send(entry); err != nil {\n   533→\t\t\t\treturn err\n   534→\t\t\t}\n   535→\t\t} else {\n   536→\t\t\t// Read step output from per-step log file.\n   537→\t\t\t// Do NOT fall back to container.log — it contains unfiltered output\n   538→\t\t\t// from ALL steps and would show wrong content for this step.\n   539→\t\t\tvar output string\n   540→\t\t\toutputPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", exec.StepName+\".log\")\n   541→\t\t\tif data, err := os.ReadFile(outputPath); err == nil && len(data) > 0 {\n   542→\t\t\t\toutput = string(data)\n   543→\t\t\t}\n   544→\t\t\tentry := &pb.LogEntry{\n   545→\t\t\t\tType:      \"step_completed\",\n   546→\t\t\t\tStepName:  exec.StepName,\n   547→\t\t\t\tResult:    exec.Result,\n   548→\t\t\t\tTimestamp: exec.CompletedAt.String(),\n   549→\t\t\t\tMessage:   output,\n   550→\t\t\t}\n   551→\t\t\tif err := stream.Send(entry); err != nil {\n   552→\t\t\t\treturn err\n   553→\t\t\t}\n   554→\t\t}\n   555→\t}\n   556→\n   557→\t// Send run completion entry\n   558→\tif run.State != domain.RunStateRunning && run.State != domain.RunStatePending {\n   559→\t\tif err := stream.Send(&pb.LogEntry{\n   560→\t\t\tType:      \"run_completed\",\n   561→\t\t\tResult:    string(run.State),\n   562→\t\t\tTimestamp: run.CompletedAt.String(),\n   563→\t\t\tMessage:   run.ErrorMessage,\n   564→\t\t}); err != nil {\n   565→\t\t\treturn err\n   566→\t\t}\n   567→\t}\n   568→\n   569→\treturn nil\n   570→}\n   571→\n   572→// streamFilteredLive serves step-filtered log history followed by live streaming\n   573→// for active runs. It uses SubscribeWithHistory to avoid gaps.\n   574→func (s *ClocheServer) streamFilteredLive(runID, stepName, logType string, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n   575→\tsub, history := s.logBroadcast.SubscribeWithHistory(runID)\n   576→\tdefer s.logBroadcast.Unsubscribe(runID, sub)\n   577→\n   578→\tmatchesFilter := func(line logstream.LogLine) bool {\n   579→\t\tif stepName != \"\" && line.StepName != stepName {\n   580→\t\t\treturn false\n   581→\t\t}\n   582→\t\tif logType != \"\" && line.Type != logType {\n   583→\t\t\treturn false\n   584→\t\t}\n   585→\t\treturn true\n   586→\t}\n   587→\n   588→\t// Send historical lines first.\n   589→\tfor _, line := range history {\n   590→\t\tif !matchesFilter(line) {\n   591→\t\t\tcontinue\n   592→\t\t}\n   593→\t\tif err := stream.Send(&pb.LogEntry{\n   594→\t\t\tType:      \"log\",\n   595→\t\t\tStepName:  line.StepName,\n   596→\t\t\tMessage:   line.Content,\n   597→\t\t\tTimestamp: line.Timestamp,\n   598→\t\t}); err != nil {\n   599→\t\t\treturn err\n   600→\t\t}\n   601→\t}\n   602→\n   603→\t// Stream live lines filtered by step/type.\n   604→\tctx := stream.Context()\n   605→\tfor {\n   606→\t\tselect {\n   607→\t\tcase <-ctx.Done():\n   608→\t\t\treturn ctx.Err()\n   609→\t\tcase line, ok := <-sub.C:\n   610→\t\t\tif !ok {\n   611→\t\t\t\t// Run completed — send terminal entry.\n   612→\t\t\t\trun, err := s.store.GetRun(context.Background(), runID)\n   613→\t\t\t\tif err == nil && run.State != domain.RunStateRunning && run.State != domain.RunStatePending {\n   614→\t\t\t\t\t_ = stream.Send(&pb.LogEntry{\n   615→\t\t\t\t\t\tType:      \"run_completed\",\n   616→\t\t\t\t\t\tResult:    string(run.State),\n   617→\t\t\t\t\t\tTimestamp: run.CompletedAt.String(),\n   618→\t\t\t\t\t\tMessage:   run.ErrorMessage,\n   619→\t\t\t\t\t})\n   620→\t\t\t\t}\n   621→\t\t\t\treturn nil\n   622→\t\t\t}\n   623→\t\t\tif !matchesFilter(line) {\n   624→\t\t\t\tcontinue\n   625→\t\t\t}\n   626→\t\t\tif err := stream.Send(&pb.LogEntry{\n   627→\t\t\t\tType:      \"log\",\n   628→\t\t\t\tStepName:  line.StepName,\n   629→\t\t\t\tMessage:   line.Content,\n   630→\t\t\t\tTimestamp: line.Timestamp,\n   631→\t\t\t}); err != nil {\n   632→\t\t\t\treturn err\n   633→\t\t\t}\n   634→\t\t}\n   635→\t}\n   636→}\n   637→\n   638→// streamFilteredLogs serves log content filtered by step name and/or log type.\n   639→// It uses the log index when available, falling back to file path conventions.\n   640→func (s *ClocheServer) streamFilteredLogs(ctx context.Context, req *pb.StreamLogsRequest, run *domain.Run, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n   641→\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\")\n   642→\n   643→\t// Try log index first\n   644→\tif s.logStore != nil {\n   645→\t\tvar logFiles []*ports.LogFileEntry\n   646→\t\tvar err error\n   647→\n   648→\t\tif req.StepName != \"\" && req.LogType != \"\" {\n   649→\t\t\t// Filter by both step and type\n   650→\t\t\tlogFiles, err = s.logStore.GetLogFilesByStep(ctx, req.RunId, req.StepName)\n   651→\t\t\tif err == nil {\n   652→\t\t\t\tfiltered := logFiles[:0]\n   653→\t\t\t\tfor _, lf := range logFiles {\n   654→\t\t\t\t\tif lf.FileType == req.LogType {\n   655→\t\t\t\t\t\tfiltered = append(filtered, lf)\n   656→\t\t\t\t\t}\n   657→\t\t\t\t}\n   658→\t\t\t\tlogFiles = filtered\n   659→\t\t\t}\n   660→\t\t} else if req.StepName != \"\" {\n   661→\t\t\tlogFiles, err = s.logStore.GetLogFilesByStep(ctx, req.RunId, req.StepName)\n   662→\t\t} else {\n   663→\t\t\tlogFiles, err = s.logStore.GetLogFileByType(ctx, req.RunId, req.LogType)\n   664→\t\t}\n   665→\n   666→\t\tif err == nil && len(logFiles) > 0 {\n   667→\t\t\tfor _, lf := range logFiles {\n   668→\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n   669→\t\t\t\tif readErr != nil {\n   670→\t\t\t\t\tcontinue\n   671→\t\t\t\t}\n   672→\t\t\t\tif err := stream.Send(&pb.LogEntry{\n   673→\t\t\t\t\tType:     lf.FileType + \"_log\",\n   674→\t\t\t\t\tStepName: lf.StepName,\n   675→\t\t\t\t\tMessage:  string(data),\n   676→\t\t\t\t}); err != nil {\n   677→\t\t\t\t\treturn err\n   678→\t\t\t\t}\n   679→\t\t\t}\n   680→\t\t\treturn nil\n   681→\t\t}\n   682→\t}\n   683→\n   684→\t// Fall back to file path conventions\n   685→\tif req.StepName != \"\" {\n   686→\t\tvar logPath string\n   687→\t\tswitch req.LogType {\n   688→\t\tcase \"llm\":\n   689→\t\t\tlogPath = filepath.Join(outputDir, \"llm-\"+req.StepName+\".log\")\n   690→\t\tdefault:\n   691→\t\t\tlogPath = filepath.Join(outputDir, req.StepName+\".log\")\n   692→\t\t}\n   693→\n   694→\t\tdata, err := os.ReadFile(logPath)\n   695→\t\tif err != nil {\n   696→\t\t\treturn fmt.Errorf(\"log file not found for step %q: %w\", req.StepName, err)\n   697→\t\t}\n   698→\t\treturn stream.Send(&pb.LogEntry{\n   699→\t\t\tType:     \"step_log\",\n   700→\t\t\tStepName: req.StepName,\n   701→\t\t\tMessage:  string(data),\n   702→\t\t})\n   703→\t}\n   704→\n   705→\treturn fmt.Errorf(\"no log files found matching filter\")\n   706→}\n   707→\n   708→// streamLiveLogs subscribes to the broadcaster and streams log lines in real\n   709→// time for an active run. The stream closes when the run completes or the\n   710→// client disconnects.\n   711→func (s *ClocheServer) streamLiveLogs(runID string, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n   712→\tsub := s.logBroadcast.Subscribe(runID)\n   713→\tdefer s.logBroadcast.Unsubscribe(runID, sub)\n   714→\n   715→\tctx := stream.Context()\n   716→\tfor {\n   717→\t\tselect {\n   718→\t\tcase <-ctx.Done():\n   719→\t\t\treturn ctx.Err()\n   720→\t\tcase line, ok := <-sub.C:\n   721→\t\t\tif !ok {\n   722→\t\t\t\t// Run completed — send terminal entry.\n   723→\t\t\t\trun, err := s.store.GetRun(context.Background(), runID)\n   724→\t\t\t\tif err == nil && run.State != domain.RunStateRunning && run.State != domain.RunStatePending {\n   725→\t\t\t\t\t_ = stream.Send(&pb.LogEntry{\n   726→\t\t\t\t\t\tType:      \"run_completed\",\n   727→\t\t\t\t\t\tResult:    string(run.State),\n   728→\t\t\t\t\t\tTimestamp: run.CompletedAt.String(),\n   729→\t\t\t\t\t\tMessage:   run.ErrorMessage,\n   730→\t\t\t\t\t})\n   731→\t\t\t\t}\n   732→\t\t\t\treturn nil\n   733→\t\t\t}\n   734→\t\t\tif err := stream.Send(&pb.LogEntry{\n   735→\t\t\t\tType:      \"log\",\n   736→\t\t\t\tStepName:  line.StepName,\n   737→\t\t\t\tMessage:   line.Content,\n   738→\t\t\t\tTimestamp: line.Timestamp,\n   739→\t\t\t}); err != nil {\n   740→\t\t\t\treturn err\n   741→\t\t\t}\n   742→\t\t}\n   743→\t}\n   744→}\n   745→\n   746→func (s *ClocheServer) StopRun(ctx context.Context, req *pb.StopRunRequest) (*pb.StopRunResponse, error) {\n   747→\ts.mu.Lock()\n   748→\tcontainerID, ok := s.runIDs[req.RunId]\n   749→\ts.mu.Unlock()\n   750→\n   751→\tif !ok {\n   752→\t\treturn nil, fmt.Errorf(\"run %q not found or already completed\", req.RunId)\n   753→\t}\n   754→\n   755→\tif err := s.container.Stop(ctx, containerID); err != nil {\n   756→\t\treturn nil, fmt.Errorf(\"stopping run: %w\", err)\n   757→\t}\n   758→\n   759→\t// Mark as cancelled in store\n   760→\trun, err := s.store.GetRun(ctx, req.RunId)\n   761→\tif err == nil {\n   762→\t\trun.Complete(domain.RunStateCancelled)\n   763→\t\t_ = s.store.UpdateRun(ctx, run)\n   764→\t}\n   765→\n   766→\treturn &pb.StopRunResponse{}, nil\n   767→}\n   768→\n   769→func (s *ClocheServer) DeleteContainer(ctx context.Context, req *pb.DeleteContainerRequest) (*pb.DeleteContainerResponse, error) {\n   770→\tif s.container == nil {\n   771→\t\treturn nil, fmt.Errorf(\"no container runtime configured\")\n   772→\t}\n   773→\n   774→\tid := req.Id\n   775→\tif id == \"\" {\n   776→\t\treturn nil, fmt.Errorf(\"id is required\")\n   777→\t}\n   778→\n   779→\t// Try to resolve as a run ID first\n   780→\tcontainerID := id\n   781→\trun, err := s.store.GetRun(ctx, id)\n   782→\tif err == nil {\n   783→\t\t// It's a run ID — use the container ID from the run record\n   784→\t\tif run.ContainerID == \"\" {\n   785→\t\t\treturn nil, fmt.Errorf(\"run %q has no associated container\", id)\n   786→\t\t}\n   787→\t\tcontainerID = run.ContainerID\n   788→\t}\n   789→\n   790→\t// Remove the container\n   791→\tif err := s.container.Remove(ctx, containerID); err != nil {\n   792→\t\treturn nil, fmt.Errorf(\"removing container: %w\", err)\n   793→\t}\n   794→\n   795→\t// If we resolved a run, clear the container_kept flag\n   796→\tif run != nil {\n   797→\t\trun.ContainerKept = false\n   798→\t\t_ = s.store.UpdateRun(ctx, run)\n   799→\t}\n   800→\n   801→\treturn &pb.DeleteContainerResponse{}, nil\n   802→}\n   803→\n   804→func (s *ClocheServer) EnableLoop(ctx context.Context, req *pb.EnableLoopRequest) (*pb.EnableLoopResponse, error) {\n   805→\tprojectDir := req.ProjectDir\n   806→\tif projectDir == \"\" {\n   807→\t\treturn nil, fmt.Errorf(\"project_dir is required\")\n   808→\t}\n   809→\n   810→\t// Verify host.cloche exists\n   811→\thostPath := filepath.Join(projectDir, \".cloche\", \"host.cloche\")\n   812→\tif _, err := os.Stat(hostPath); err != nil {\n   813→\t\treturn nil, fmt.Errorf(\"host.cloche not found in %s: %w\", projectDir, err)\n   814→\t}\n   815→\n   816→\t// Load project config for defaults.\n   817→\tprojCfg, _ := config.Load(projectDir)\n   818→\n   819→\tmaxConc := int(req.MaxConcurrent)\n   820→\tif maxConc <= 0 {\n   821→\t\tmaxConc = projCfg.Orchestration.Concurrency\n   822→\t}\n   823→\tif maxConc <= 0 {\n   824→\t\tmaxConc = 1\n   825→\t}\n   826→\n   827→\tstagger := time.Duration(float64(time.Second) * projCfg.Orchestration.StaggerSeconds)\n   828→\n   829→\t// Compute dedup timeout from config (default 5 minutes).\n   830→\tdedupTimeout := time.Duration(float64(time.Second) * projCfg.Orchestration.DedupSeconds)\n   831→\n   832→\tloopCfg := host.LoopConfig{\n   833→\t\tProjectDir:    projectDir,\n   834→\t\tMaxConcurrent: maxConc,\n   835→\t\tStaggerDelay:  stagger,\n   836→\t\tDedupTimeout:  dedupTimeout,\n   837→\t}\n   838→\n   839→\ts.mu.Lock()\n   840→\tdefer s.mu.Unlock()\n   841→\n   842→\t// Stop existing loop if running.\n   843→\tif existing, ok := s.loops[projectDir]; ok {\n   844→\t\texisting.Stop()\n   845→\t}\n   846→\n   847→\t// Check if host.cloche defines a list-tasks workflow for three-phase mode.\n   848→\tvar loop *host.Loop\n   849→\tif s.hasWorkflow(hostPath, \"list-tasks\") {\n   850→\t\tloop = s.createPhaseLoop(loopCfg, projectDir, hostPath, dedupTimeout)\n   851→\t} else {\n   852→\t\tloop = s.createLegacyLoop(loopCfg, projectDir, projCfg, dedupTimeout)\n   853→\t}\n   854→\n   855→\ts.loops[projectDir] = loop\n   856→\tloop.Start()\n   857→\n   858→\treturn &pb.EnableLoopResponse{}, nil\n   859→}\n   860→\n   861→// hasWorkflow checks if host.cloche contains a workflow with the given name.\n   862→func (s *ClocheServer) hasWorkflow(hostPath, workflowName string) bool {\n   863→\tdata, err := os.ReadFile(hostPath)\n   864→\tif err != nil {\n   865→\t\treturn false\n   866→\t}\n   867→\treturn strings.Contains(string(data), fmt.Sprintf(\"workflow %q\", workflowName))\n   868→}\n   869→\n   870→// createPhaseLoop creates a three-phase orchestration loop using list-tasks,\n   871→// main, and finalize workflows from host.cloche.\n   872→func (s *ClocheServer) createPhaseLoop(loopCfg host.LoopConfig, projectDir, hostPath string, dedupTimeout time.Duration) *host.Loop {\n   873→\t// Phase 1: list-tasks function\n   874→\tlistTasksFn := func(ctx context.Context, projDir string) ([]host.Task, error) {\n   875→\t\trunner := &host.Runner{\n   876→\t\t\tDispatcher: s,\n   877→\t\t\tStore:      s.store,\n   878→\t\t}\n   879→\t\tresult, err := runner.RunNamed(ctx, projDir, \"list-tasks\")\n   880→\t\tif err != nil {\n   881→\t\t\treturn nil, err\n   882→\t\t}\n   883→\t\tif result.State != domain.RunStateSucceeded {\n   884→\t\t\treturn nil, fmt.Errorf(\"list-tasks workflow failed with state %s\", result.State)\n   885→\t\t}\n   886→\t\treturn host.ReadListTasksOutput(result.OutputDir)\n   887→\t}\n   888→\n   889→\t// Phase 2: main function\n   890→\tmainFn := func(ctx context.Context, projDir string, taskID string) (*host.RunResult, error) {\n   891→\t\trunner := &host.Runner{\n   892→\t\t\tDispatcher: s,\n   893→\t\t\tStore:      s.store,\n   894→\t\t\tTaskID:     taskID,\n   895→\t\t}\n   896→\t\treturn runner.RunNamed(ctx, projDir, \"main\")\n   897→\t}\n   898→\n   899→\t// Phase 3: finalize function (optional — only if host.cloche has it)\n   900→\tvar finalizeFn host.FinalizeFunc\n   901→\tif s.hasWorkflow(hostPath, \"finalize\") {\n   902→\t\tfinalizeFn = func(ctx context.Context, projDir string, taskID string, mainResult *host.RunResult) (*host.RunResult, error) {\n   903→\t\t\tmainRunID := \"\"\n   904→\t\t\tmainOutcome := \"failed\"\n   905→\t\t\tif mainResult != nil {\n   906→\t\t\t\tmainRunID = mainResult.RunID\n   907→\t\t\t\tmainOutcome = string(mainResult.State)\n   908→\t\t\t}\n   909→\t\t\trunner := &host.Runner{\n   910→\t\t\t\tDispatcher: s,\n   911→\t\t\t\tStore:      s.store,\n   912→\t\t\t\tTaskID:     taskID,\n   913→\t\t\t\tExtraEnv: []string{\n   914→\t\t\t\t\t\"CLOCHE_MAIN_RUN_ID=\" + mainRunID,\n   915→\t\t\t\t\t\"CLOCHE_MAIN_OUTCOME=\" + mainOutcome,\n   916→\t\t\t\t},\n   917→\t\t\t}\n   918→\t\t\treturn runner.RunNamed(ctx, projDir, \"finalize\")\n   919→\t\t}\n   920→\t}\n   921→\n   922→\tlog.Printf(\"orchestration loop: three-phase mode enabled for %s (list-tasks + main + finalize, dedup=%s)\", projectDir, dedupTimeout)\n   923→\treturn host.NewPhaseLoop(loopCfg, s.store, listTasksFn, mainFn, finalizeFn)\n   924→}\n   925→\n   926→// createLegacyLoop creates a legacy single-function orchestration loop.\n   927→func (s *ClocheServer) createLegacyLoop(loopCfg host.LoopConfig, projectDir string, projCfg *config.Config, dedupTimeout time.Duration) *host.Loop {\n   928→\trunFn := func(ctx context.Context, projDir string, taskID string) (*host.RunResult, error) {\n   929→\t\trunner := &host.Runner{\n   930→\t\t\tDispatcher: s,\n   931→\t\t\tStore:      s.store,\n   932→\t\t\tTaskID:     taskID,\n   933→\t\t}\n   934→\t\treturn runner.Run(ctx, projDir)\n   935→\t}\n   936→\n   937→\tloop := host.NewLoop(loopCfg, s.store, runFn)\n   938→\n   939→\t// Configure daemon-managed task assignment if a list-tasks command is set.\n   940→\tif cmd := projCfg.Orchestration.ListTasksCommand; cmd != \"\" {\n   941→\t\tloop.SetTaskAssigner(&host.ScriptTaskAssigner{Command: cmd})\n   942→\t\tlog.Printf(\"orchestration loop: task assignment enabled for %s (command=%q, dedup=%s)\", projectDir, cmd, dedupTimeout)\n   943→\t}\n   944→\n   945→\treturn loop\n   946→}\n   947→\n   948→// GetLoopTasks returns the current task pipeline state for a project's\n   949→// orchestration loop, formatted as web.TaskEntry values. Returns nil if no\n   950→// loop is active for the project.\n   951→func (s *ClocheServer) GetLoopTasks(projectDir string) []web.TaskEntry {\n   952→\ts.mu.Lock()\n   953→\tloop, ok := s.loops[projectDir]\n   954→\ts.mu.Unlock()\n   955→\tif !ok {\n   956→\t\treturn nil\n   957→\t}\n   958→\tsnapshot := loop.GetTaskSnapshot()\n   959→\tentries := make([]web.TaskEntry, len(snapshot))\n   960→\tfor i, e := range snapshot {\n   961→\t\tentry := web.TaskEntry{\n   962→\t\t\tID:          e.Task.ID,\n   963→\t\t\tStatus:      e.Task.Status,\n   964→\t\t\tTitle:       e.Task.Title,\n   965→\t\t\tDescription: e.Task.Description,\n   966→\t\t\tMetadata:    e.Task.Metadata,\n   967→\t\t\tAssigned:    e.Assigned,\n   968→\t\t\tRunID:       e.RunID,\n   969→\t\t}\n   970→\t\tif !e.AssignedAt.IsZero() {\n   971→\t\t\tentry.AssignedAt = e.AssignedAt.Format(time.RFC3339)\n   972→\t\t}\n   973→\t\tentries[i] = entry\n   974→\t}\n   975→\treturn entries\n   976→}\n   977→\n   978→func (s *ClocheServer) DisableLoop(ctx context.Context, req *pb.DisableLoopRequest) (*pb.DisableLoopResponse, error) {\n   979→\tprojectDir := req.ProjectDir\n   980→\tif projectDir == \"\" {\n   981→\t\treturn nil, fmt.Errorf(\"project_dir is required\")\n   982→\t}\n   983→\n   984→\ts.mu.Lock()\n   985→\tdefer s.mu.Unlock()\n   986→\n   987→\tif loop, ok := s.loops[projectDir]; ok {\n   988→\t\tloop.Stop()\n   989→\t\tdelete(s.loops, projectDir)\n   990→\t}\n   991→\n   992→\treturn &pb.DisableLoopResponse{}, nil\n   993→}\n   994→\n   995→func (s *ClocheServer) Shutdown(ctx context.Context, req *pb.ShutdownRequest) (*pb.ShutdownResponse, error) {\n   996→\t// Stop all orchestration loops.\n   997→\ts.mu.Lock()\n   998→\tfor _, loop := range s.loops {\n   999→\t\tloop.Stop()\n  1000→\t}\n  1001→\ts.loops = make(map[string]*host.Loop)\n  1002→\ts.mu.Unlock()\n  1003→\n  1004→\tif s.shutdownFn == nil {\n  1005→\t\treturn nil, fmt.Errorf(\"shutdown not configured\")\n  1006→\t}\n  1007→\tgo s.shutdownFn()\n  1008→\treturn &pb.ShutdownResponse{}, nil\n  1009→}\n  1010→\n  1011→// indexLogFiles scans the extracted output directory and creates log_files index entries.\n  1012→func (s *ClocheServer) indexLogFiles(ctx context.Context, runID, outputDir string) {\n  1013→\tentries, err := os.ReadDir(outputDir)\n  1014→\tif err != nil {\n  1015→\t\tlog.Printf(\"run %s: failed to read output dir for indexing: %v\", runID, err)\n  1016→\t\treturn\n  1017→\t}\n  1018→\n  1019→\tnow := time.Now()\n  1020→\tfor _, entry := range entries {\n  1021→\t\tif entry.IsDir() {\n  1022→\t\t\tcontinue\n  1023→\t\t}\n  1024→\t\tname := entry.Name()\n  1025→\t\tif !strings.HasSuffix(name, \".log\") {\n  1026→\t\t\tcontinue\n  1027→\t\t}\n  1028→\n  1029→\t\tvar fileType, stepName string\n  1030→\t\tbase := strings.TrimSuffix(name, \".log\")\n  1031→\n  1032→\t\tswitch {\n  1033→\t\tcase name == \"full.log\":\n  1034→\t\t\tfileType = \"full\"\n  1035→\t\tcase name == \"container.log\":\n  1036→\t\t\t// container.log is internal, not indexed as a user-facing log type\n  1037→\t\t\tcontinue\n  1038→\t\tcase strings.HasPrefix(name, \"llm-\"):\n  1039→\t\t\tfileType = \"llm\"\n  1040→\t\t\tstepName = strings.TrimPrefix(base, \"llm-\")\n  1041→\t\tdefault:\n  1042→\t\t\tfileType = \"script\"\n  1043→\t\t\tstepName = base\n  1044→\t\t}\n  1045→\n  1046→\t\tinfo, _ := entry.Info()\n  1047→\t\tvar fileSize int64\n  1048→\t\tif info != nil {\n  1049→\t\t\tfileSize = info.Size()\n  1050→\t\t}\n  1051→\n  1052→\t\tlogEntry := &ports.LogFileEntry{\n  1053→\t\t\tRunID:     runID,\n  1054→\t\t\tStepName:  stepName,\n  1055→\t\t\tFileType:  fileType,\n  1056→\t\t\tFilePath:  filepath.Join(outputDir, name),\n  1057→\t\t\tFileSize:  fileSize,\n  1058→\t\t\tCreatedAt: now,\n  1059→\t\t}\n  1060→\t\tif err := s.logStore.SaveLogFile(ctx, logEntry); err != nil {\n  1061→\t\t\tlog.Printf(\"run %s: failed to index log file %s: %v\", runID, name, err)\n  1062→\t\t}\n  1063→\t}\n  1064→}\n  1065→\n  1066→func gitHEAD(dir string) string {\n  1067→\tcmd := exec.Command(\"git\", \"rev-parse\", \"HEAD\")\n  1068→\tcmd.Dir = dir\n  1069→\tout, err := cmd.Output()\n  1070→\tif err != nil {\n  1071→\t\treturn \"\"\n  1072→\t}\n  1073→\treturn strings.TrimSpace(string(out))\n  1074→}\n  1075→"}]},"parent_tool_use_id":null,"session_id":"32a9924e-c776-408c-8085-162da40f446c","uuid":"dfde98da-1eab-4ffd-a15a-5b1255d1977b","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/grpc/server.go","content":"package grpc\n\nimport (\n\t\"bufio\"\n\t\"context\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"log\"\n\t\"os\"\n\t\"os/exec\"\n\t\"path/filepath\"\n\t\"strings\"\n\t\"sync\"\n\t\"time\"\n\n\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n\t\"github.com/cloche-dev/cloche/internal/adapters/docker\"\n\t\"github.com/cloche-dev/cloche/internal/adapters/web\"\n\t\"github.com/cloche-dev/cloche/internal/config\"\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/evolution\"\n\t\"github.com/cloche-dev/cloche/internal/host\"\n\t\"github.com/cloche-dev/cloche/internal/logstream\"\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n\t\"github.com/cloche-dev/cloche/internal/protocol\"\n\trpcgrpc \"google.golang.org/grpc\"\n)\n\ntype ClocheServer struct {\n\tpb.UnimplementedClocheServiceServer\n\tstore        ports.RunStore\n\tcaptures     ports.CaptureStore\n\tlogStore     ports.LogStore\n\tcontainer    ports.ContainerRuntime\n\tdefaultImage string\n\tevolution    *evolution.Trigger\n\tlogBroadcast *logstream.Broadcaster\n\tshutdownFn   func()\n\tmu           sync.Mutex\n\trunIDs       map[string]string      // run_id -> container_id\n\tloops        map[string]*host.Loop  // project_dir -> orchestration loop\n}\n\nfunc NewClocheServer(store ports.RunStore, container ports.ContainerRuntime) *ClocheServer {\n\treturn &ClocheServer{\n\t\tstore:     store,\n\t\tcontainer: container,\n\t\trunIDs:    make(map[string]string),\n\t\tloops:     make(map[string]*host.Loop),\n\t}\n}\n\nfunc NewClocheServerWithCaptures(store ports.RunStore, captures ports.CaptureStore, container ports.ContainerRuntime, defaultImage string) *ClocheServer {\n\treturn &ClocheServer{\n\t\tstore:        store,\n\t\tcaptures:     captures,\n\t\tcontainer:    container,\n\t\tdefaultImage: defaultImage,\n\t\trunIDs:       make(map[string]string),\n\t\tloops:        make(map[string]*host.Loop),\n\t}\n}\n\n// SetLogStore attaches a log store to the server for indexing extracted log files.\nfunc (s *ClocheServer) SetLogStore(ls ports.LogStore) {\n\ts.logStore = ls\n}\n\n\n// SetEvolution attaches an evolution trigger to the server.\nfunc (s *ClocheServer) SetEvolution(trigger *evolution.Trigger) {\n\ts.evolution = trigger\n}\n\n// SetLogBroadcaster attaches a log broadcaster for live-streaming LLM output.\nfunc (s *ClocheServer) SetLogBroadcaster(b *logstream.Broadcaster) {\n\ts.logBroadcast = b\n}\n\n// SetShutdownFunc sets the callback invoked when the Shutdown RPC is called.\nfunc (s *ClocheServer) SetShutdownFunc(fn func()) {\n\ts.shutdownFn = fn\n}\n\nfunc (s *ClocheServer) RunWorkflow(ctx context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error) {\n\tif s.container == nil {\n\t\treturn nil, fmt.Errorf(\"no container runtime configured\")\n\t}\n\n\t// Generate a unique run ID, retrying on collision\n\tvar runID string\n\tfor attempts := 0; attempts < 10; attempts++ {\n\t\trunID = domain.GenerateRunID(req.WorkflowName)\n\t\texisting, err := s.store.GetRun(ctx, runID)\n\t\tif err != nil {\n\t\t\tbreak // ID is free\n\t\t}\n\t\t// Reuse if completed more than 1 hour ago\n\t\tif !existing.CompletedAt.IsZero() && time.Since(existing.CompletedAt) > time.Hour {\n\t\t\t_ = s.store.DeleteRun(ctx, runID)\n\t\t\tbreak\n\t\t}\n\t}\n\n\t// Write prompt to .cloche/<run-id>/prompt.txt (run-specific to avoid conflicts)\n\tif req.Prompt != \"\" {\n\t\tclocheDir := filepath.Join(req.ProjectDir, \".cloche\", runID)\n\t\tif err := os.MkdirAll(clocheDir, 0755); err != nil {\n\t\t\treturn nil, fmt.Errorf(\"creating .cloche dir: %w\", err)\n\t\t}\n\t\tif err := os.WriteFile(filepath.Join(clocheDir, \"prompt.txt\"), []byte(req.Prompt), 0644); err != nil {\n\t\t\treturn nil, fmt.Errorf(\"writing prompt: %w\", err)\n\t\t}\n\t}\n\trun := domain.NewRun(runID, req.WorkflowName)\n\trun.ProjectDir = req.ProjectDir\n\trun.Title = req.Title\n\tif err := s.store.CreateRun(ctx, run); err != nil {\n\t\treturn nil, fmt.Errorf(\"creating run: %w\", err)\n\t}\n\n\t// Resolve image: request-level override, then server default\n\timage := req.Image\n\tif image == \"\" {\n\t\timage = s.defaultImage\n\t}\n\n\t// Launch container start + tracking in background so the RPC returns immediately.\n\t// The run stays in \"pending\" state until the container is up.\n\tgo s.launchAndTrack(runID, image, req.KeepContainer, req)\n\n\treturn &pb.RunWorkflowResponse{RunId: runID}, nil\n}\n\n// launchAndTrack starts the container and then tracks it to completion.\n// It runs in a background goroutine with its own context, independent of the\n// RPC context which may be cancelled after RunWorkflow returns.\nfunc (s *ClocheServer) launchAndTrack(runID, image string, keepContainer bool, req *pb.RunWorkflowRequest) {\n\tctx := context.Background()\n\n\t// Auto-rebuild image if the project Dockerfile has changed since last build.\n\tif ensurer, ok := s.container.(ports.ImageEnsurer); ok {\n\t\tif err := ensurer.EnsureImage(ctx, req.ProjectDir, image); err != nil {\n\t\t\trun, _ := s.store.GetRun(ctx, runID)\n\t\t\tif run != nil {\n\t\t\t\trun.Fail(fmt.Sprintf(\"failed to ensure image: %v\", err))\n\t\t\t\t_ = s.store.UpdateRun(ctx, run)\n\t\t\t}\n\t\t\tlog.Printf(\"run %s: failed to ensure image: %v\", runID, err)\n\t\t\t\treturn\n\t\t}\n\t}\n\n\tbaseSHA := gitHEAD(req.ProjectDir)\n\n\tcontainerID, err := s.container.Start(ctx, ports.ContainerConfig{\n\t\tImage:        image,\n\t\tWorkflowName: req.WorkflowName,\n\t\tProjectDir:   req.ProjectDir,\n\t\tRunID:        runID,\n\t\tNetworkAllow: []string{\"*\"},\n\t})\n\tif err != nil {\n\t\trun, _ := s.store.GetRun(ctx, runID)\n\t\tif run != nil {\n\t\t\trun.Fail(fmt.Sprintf(\"failed to start container: %v\", err))\n\t\t\t_ = s.store.UpdateRun(ctx, run)\n\t\t}\n\t\tlog.Printf(\"run %s: failed to start container: %v\", runID, err)\n\t\treturn\n\t}\n\n\ts.mu.Lock()\n\ts.runIDs[runID] = containerID\n\ts.mu.Unlock()\n\n\trun, _ := s.store.GetRun(ctx, runID)\n\tif run != nil {\n\t\trun.Start()\n\t\trun.ContainerID = containerID\n\t\trun.BaseSHA = baseSHA\n\t\t_ = s.store.UpdateRun(ctx, run)\n\t}\n\n\ts.trackRun(runID, containerID, req.ProjectDir, req.WorkflowName, keepContainer)\n}\n\nfunc (s *ClocheServer) trackRun(runID, containerID, projectDir, workflowName string, keepContainer bool) {\n\tctx := context.Background()\n\n\t// Attach to agent output\n\treader, err := s.container.AttachOutput(ctx, containerID)\n\tif err != nil {\n\t\tlog.Printf(\"failed to attach to output for run %s: %v\", runID, err)\n\t\t\treturn\n\t}\n\n\t// Parse JSON-lines status messages\n\tvar reportedResult string // captured from MsgRunCompleted, persisted after branch extraction\n\tscanner := bufio.NewScanner(reader)\n\tscanner.Buffer(make([]byte, 0, 256*1024), 1024*1024) // 1MB max to handle large log messages\n\tfor scanner.Scan() {\n\t\tvar msg protocol.StatusMessage\n\t\tif err := json.Unmarshal(scanner.Bytes(), &msg); err != nil {\n\t\t\tcontinue\n\t\t}\n\n\t\t// Fast path: log messages don't need store interaction.\n\t\tif msg.Type == protocol.MsgLog {\n\t\t\tif s.logBroadcast != nil {\n\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n\t\t\t\t\tType:      \"llm\",\n\t\t\t\t\tContent:   msg.Message,\n\t\t\t\t\tStepName:  msg.StepName,\n\t\t\t\t})\n\t\t\t}\n\t\t\tcontinue\n\t\t}\n\n\t\trun, err := s.store.GetRun(ctx, runID)\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\n\t\tswitch msg.Type {\n\t\tcase protocol.MsgStepStarted:\n\t\t\trun.RecordStepStart(msg.StepName)\n\t\t\tif s.captures != nil {\n\t\t\t\t_ = s.captures.SaveCapture(ctx, runID, &domain.StepExecution{\n\t\t\t\t\tStepName:  msg.StepName,\n\t\t\t\t\tStartedAt: msg.Timestamp,\n\t\t\t\t})\n\t\t\t}\n\t\t\tif s.logBroadcast != nil {\n\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n\t\t\t\t\tType:      \"status\",\n\t\t\t\t\tContent:   \"step_started: \" + msg.StepName,\n\t\t\t\t\tStepName:  msg.StepName,\n\t\t\t\t})\n\t\t\t}\n\t\tcase protocol.MsgStepCompleted:\n\t\t\trun.RecordStepComplete(msg.StepName, msg.Result)\n\t\t\tif s.captures != nil {\n\t\t\t\t_ = s.captures.SaveCapture(ctx, runID, &domain.StepExecution{\n\t\t\t\t\tStepName:    msg.StepName,\n\t\t\t\t\tResult:      msg.Result,\n\t\t\t\t\tCompletedAt: msg.Timestamp,\n\t\t\t\t})\n\t\t\t}\n\t\t\tif s.logBroadcast != nil {\n\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n\t\t\t\t\tType:      \"status\",\n\t\t\t\t\tContent:   \"step_completed: \" + msg.StepName + \" -> \" + msg.Result,\n\t\t\t\t\tStepName:  msg.StepName,\n\t\t\t\t})\n\t\t\t}\n\t\tcase protocol.MsgRunTitle:\n\t\t\tif run.Title == \"\" {\n\t\t\t\trun.Title = msg.Message\n\t\t\t}\n\t\tcase protocol.MsgRunCompleted:\n\t\t\treportedResult = msg.Result\n\t\t\tcontinue // Don't persist terminal state yet; branch extraction must finish first\n\t\t}\n\n\t\t_ = s.store.UpdateRun(ctx, run)\n\t}\n\treader.Close()\n\n\t// Signal live-stream subscribers that this run is done.\n\tif s.logBroadcast != nil {\n\t\ts.logBroadcast.Finish(runID)\n\t}\n\n\t// Wait for process exit\n\texitCode, err := s.container.Wait(ctx, containerID)\n\tif err != nil {\n\t\tlog.Printf(\"error waiting for run %s: %v\", runID, err)\n\t}\n\n\t// Extract step output files from container before it's removed\n\toutputDst := filepath.Join(projectDir, \".cloche\", runID, \"output\")\n\tif err := os.MkdirAll(outputDst, 0755); err == nil {\n\t\tif cpErr := s.container.CopyFrom(ctx, containerID, \"/workspace/.cloche/output/.\", outputDst); cpErr != nil {\n\t\t\tlog.Printf(\"run %s: failed to extract output: %v\", runID, cpErr)\n\t\t}\n\t}\n\n\t// Capture full container stdout/stderr before the container is removed\n\tif logs, logErr := s.container.Logs(ctx, containerID); logErr == nil && logs != \"\" {\n\t\tcontainerLogPath := filepath.Join(outputDst, \"container.log\")\n\t\tif writeErr := os.WriteFile(containerLogPath, []byte(logs), 0644); writeErr != nil {\n\t\t\tlog.Printf(\"run %s: failed to write container.log: %v\", runID, writeErr)\n\t\t}\n\t}\n\n\t// Index extracted log files in the log store\n\tif s.logStore != nil {\n\t\ts.indexLogFiles(ctx, runID, outputDst)\n\t}\n\n\t// Extract results to git branch BEFORE finalizing state, so that\n\t// WaitRun callers (e.g. host workflow merge step) see branches exist\n\t// before the run is marked complete.\n\tresultLabel := reportedResult\n\tif resultLabel == \"\" {\n\t\tif exitCode == 0 {\n\t\t\tresultLabel = \"succeeded\"\n\t\t} else {\n\t\t\tresultLabel = \"failed\"\n\t\t}\n\t}\n\t{\n\t\textractRun, _ := s.store.GetRun(ctx, runID)\n\t\tif extractRun != nil && extractRun.BaseSHA != \"\" {\n\t\t\tlog.Printf(\"run %s: extracting results to branch cloche/%s (baseSHA=%s)\", runID, runID, extractRun.BaseSHA)\n\t\t\tif err := docker.ExtractResults(ctx, containerID, extractRun.ProjectDir, runID, extractRun.BaseSHA, workflowName, resultLabel); err != nil {\n\t\t\t\tlog.Printf(\"run %s: failed to extract results to branch: %v\", runID, err)\n\t\t\t} else {\n\t\t\t\tlog.Printf(\"run %s: branch cloche/%s created successfully\", runID, runID)\n\t\t\t}\n\t\t} else {\n\t\t\tlog.Printf(\"run %s: skipping branch extraction (baseSHA empty or run not found)\", runID)\n\t\t}\n\t}\n\n\t// Now finalize run state\n\trun, err := s.store.GetRun(ctx, runID)\n\tif err != nil {\n\t\treturn\n\t}\n\tif run.State == domain.RunStateRunning {\n\t\tif reportedResult == \"succeeded\" {\n\t\t\trun.Complete(domain.RunStateSucceeded)\n\t\t} else if reportedResult != \"\" {\n\t\t\trun.Complete(domain.RunStateFailed)\n\t\t} else if exitCode == 0 {\n\t\t\trun.Complete(domain.RunStateSucceeded)\n\t\t} else {\n\t\t\trun.Fail(fmt.Sprintf(\"container exited with code %d\", exitCode))\n\t\t}\n\t\t_ = s.store.UpdateRun(ctx, run)\n\t}\n\n\t// Fire evolution trigger if configured\n\tif s.evolution != nil {\n\t\ts.evolution.Fire(projectDir, workflowName, runID)\n\t}\n\n\t// Merge is handled as a workflow step in host.cloche, not here.\n\n\t// Container retention policy:\n\t// - Failed runs: always keep the container for debugging\n\t// - Successful runs + --keep-container: keep the container\n\t// - Successful runs without --keep-container: remove the container\n\trunFinal, _ := s.store.GetRun(ctx, runID)\n\trunFailed := runFinal != nil && (runFinal.State == domain.RunStateFailed || runFinal.State == domain.RunStateCancelled)\n\n\tif keepContainer || runFailed {\n\t\treason := \"--keep-container\"\n\t\tif runFailed {\n\t\t\treason = \"run failed\"\n\t\t}\n\t\tlog.Printf(\"run %s: keeping container %s (%s)\", runID, containerID, reason)\n\t\tif runFinal != nil {\n\t\t\trunFinal.ContainerKept = true\n\t\t\t_ = s.store.UpdateRun(ctx, runFinal)\n\t\t}\n\t} else {\n\t\tif err := s.container.Remove(ctx, containerID); err != nil {\n\t\t\tlog.Printf(\"run %s: failed to remove container %s: %v\", runID, containerID, err)\n\t\t} else {\n\t\t\tlog.Printf(\"run %s: removed container %s\", runID, containerID)\n\t\t}\n\t}\n\n\t// Cleanup mapping\n\ts.mu.Lock()\n\tdelete(s.runIDs, runID)\n\ts.mu.Unlock()\n}\n\nfunc (s *ClocheServer) ListRuns(ctx context.Context, req *pb.ListRunsRequest) (*pb.ListRunsResponse, error) {\n\tvar since time.Time\n\tif !req.All {\n\t\tsince = time.Now().Add(-1 * time.Hour)\n\t}\n\truns, err := s.store.ListRuns(ctx, since)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"listing runs: %w\", err)\n\t}\n\n\tresp := &pb.ListRunsResponse{}\n\tfor _, run := range runs {\n\t\tresp.Runs = append(resp.Runs, &pb.RunSummary{\n\t\t\tRunId:        run.ID,\n\t\t\tWorkflowName: run.WorkflowName,\n\t\t\tState:        string(run.State),\n\t\t\tStartedAt:    run.StartedAt.String(),\n\t\t\tErrorMessage: run.ErrorMessage,\n\t\t\tContainerId:  run.ContainerID,\n\t\t\tTitle:        run.Title,\n\t\t\tIsHost:       run.IsHost,\n\t\t})\n\t}\n\treturn resp, nil\n}\n\nfunc (s *ClocheServer) GetStatus(ctx context.Context, req *pb.GetStatusRequest) (*pb.GetStatusResponse, error) {\n\trun, err := s.store.GetRun(ctx, req.RunId)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"getting run: %w\", err)\n\t}\n\n\tresp := &pb.GetStatusResponse{\n\t\tRunId:        run.ID,\n\t\tWorkflowName: run.WorkflowName,\n\t\tState:        string(run.State),\n\t\tCurrentStep:  strings.Join(run.ActiveSteps, \",\"),\n\t\tErrorMessage: run.ErrorMessage,\n\t\tContainerId:  run.ContainerID,\n\t\tTitle:        run.Title,\n\t\tIsHost:       run.IsHost,\n\t}\n\n\t// Check container liveness\n\tif run.ContainerID != \"\" && s.container != nil {\n\t\tif cs, err := s.container.Inspect(ctx, run.ContainerID); err == nil {\n\t\t\tresp.ContainerAlive = cs.Running\n\t\t\tif !cs.Running && !cs.FinishedAt.IsZero() {\n\t\t\t\tresp.ContainerDeadSince = cs.FinishedAt.Format(time.RFC3339Nano)\n\t\t\t}\n\t\t}\n\t}\n\n\t// Load step executions from captures store if available\n\tif s.captures != nil {\n\t\tcaptures, err := s.captures.GetCaptures(ctx, req.RunId)\n\t\tif err == nil {\n\t\t\tfor _, exec := range captures {\n\t\t\t\tresp.StepExecutions = append(resp.StepExecutions, &pb.StepExecutionStatus{\n\t\t\t\t\tStepName:    exec.StepName,\n\t\t\t\t\tResult:      exec.Result,\n\t\t\t\t\tStartedAt:   exec.StartedAt.String(),\n\t\t\t\t\tCompletedAt: exec.CompletedAt.String(),\n\t\t\t\t})\n\t\t\t}\n\t\t}\n\t} else {\n\t\tfor _, exec := range run.StepExecutions {\n\t\t\tresp.StepExecutions = append(resp.StepExecutions, &pb.StepExecutionStatus{\n\t\t\t\tStepName:    exec.StepName,\n\t\t\t\tResult:      exec.Result,\n\t\t\t\tStartedAt:   exec.StartedAt.String(),\n\t\t\t\tCompletedAt: exec.CompletedAt.String(),\n\t\t\t})\n\t\t}\n\t}\n\n\treturn resp, nil\n}\n\nfunc (s *ClocheServer) StreamLogs(req *pb.StreamLogsRequest, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n\tctx := stream.Context()\n\n\t// Verify run exists\n\trun, err := s.store.GetRun(ctx, req.RunId)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"run %q not found: %w\", req.RunId, err)\n\t}\n\n\t// If step_name or log_type filter is set, serve content directly from the log index\n\t// For active runs, fall through to live streaming filtered by step.\n\tif req.StepName != \"\" || req.LogType != \"\" {\n\t\tisActive := run.State == domain.RunStateRunning || run.State == domain.RunStatePending\n\t\tif isActive && s.logBroadcast != nil {\n\t\t\treturn s.streamFilteredLive(req.RunId, req.StepName, req.LogType, stream)\n\t\t}\n\t\treturn s.streamFilteredLogs(ctx, req, run, stream)\n\t}\n\n\t// For active runs, stream live from the broadcaster so callers can tail output.\n\tif (run.State == domain.RunStateRunning || run.State == domain.RunStatePending) && s.logBroadcast != nil {\n\t\treturn s.streamLiveLogs(req.RunId, stream)\n\t}\n\n\tif s.captures == nil {\n\t\treturn fmt.Errorf(\"captures store not configured\")\n\t}\n\n\t// Check for full.log first — if it exists, serve it as the unified log\n\tfullLogPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", \"full.log\")\n\tif data, readErr := os.ReadFile(fullLogPath); readErr == nil && len(data) > 0 {\n\t\tif err := stream.Send(&pb.LogEntry{\n\t\t\tType:    \"full_log\",\n\t\t\tMessage: string(data),\n\t\t}); err != nil {\n\t\t\treturn err\n\t\t}\n\t\t// Still send run completion entry\n\t\tif run.State != domain.RunStateRunning && run.State != domain.RunStatePending {\n\t\t\tif err := stream.Send(&pb.LogEntry{\n\t\t\t\tType:      \"run_completed\",\n\t\t\t\tResult:    string(run.State),\n\t\t\t\tTimestamp: run.CompletedAt.String(),\n\t\t\t\tMessage:   run.ErrorMessage,\n\t\t\t}); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t}\n\t\treturn nil\n\t}\n\n\t// Fall back to capture-based streaming\n\tcaptures, err := s.captures.GetCaptures(ctx, req.RunId)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"getting captures: %w\", err)\n\t}\n\n\tfor _, exec := range captures {\n\t\t// Captures are stored as separate rows: one for step_started (no Result)\n\t\t// and one for step_completed (has Result).\n\t\tif exec.Result == \"\" {\n\t\t\tentry := &pb.LogEntry{\n\t\t\t\tType:      \"step_started\",\n\t\t\t\tStepName:  exec.StepName,\n\t\t\t\tTimestamp: exec.StartedAt.String(),\n\t\t\t}\n\t\t\tif err := stream.Send(entry); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t} else {\n\t\t\t// Read step output from per-step log file.\n\t\t\t// Do NOT fall back to container.log — it contains unfiltered output\n\t\t\t// from ALL steps and would show wrong content for this step.\n\t\t\tvar output string\n\t\t\toutputPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", exec.StepName+\".log\")\n\t\t\tif data, err := os.ReadFile(outputPath); err == nil && len(data) > 0 {\n\t\t\t\toutput = string(data)\n\t\t\t}\n\t\t\tentry := &pb.LogEntry{\n\t\t\t\tType:      \"step_completed\",\n\t\t\t\tStepName:  exec.StepName,\n\t\t\t\tResult:    exec.Result,\n\t\t\t\tTimestamp: exec.CompletedAt.String(),\n\t\t\t\tMessage:   output,\n\t\t\t}\n\t\t\tif err := stream.Send(entry); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t}\n\t}\n\n\t// Send run completion entry\n\tif run.State != domain.RunStateRunning && run.State != domain.RunStatePending {\n\t\tif err := stream.Send(&pb.LogEntry{\n\t\t\tType:      \"run_completed\",\n\t\t\tResult:    string(run.State),\n\t\t\tTimestamp: run.CompletedAt.String(),\n\t\t\tMessage:   run.ErrorMessage,\n\t\t}); err != nil {\n\t\t\treturn err\n\t\t}\n\t}\n\n\treturn nil\n}\n\n// streamFilteredLive serves step-filtered log history followed by live streaming\n// for active runs. It uses SubscribeWithHistory to avoid gaps.\nfunc (s *ClocheServer) streamFilteredLive(runID, stepName, logType string, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n\tsub, history := s.logBroadcast.SubscribeWithHistory(runID)\n\tdefer s.logBroadcast.Unsubscribe(runID, sub)\n\n\tmatchesFilter := func(line logstream.LogLine) bool {\n\t\tif stepName != \"\" && line.StepName != stepName {\n\t\t\treturn false\n\t\t}\n\t\tif logType != \"\" && line.Type != logType {\n\t\t\treturn false\n\t\t}\n\t\treturn true\n\t}\n\n\t// Send historical lines first.\n\tfor _, line := range history {\n\t\tif !matchesFilter(line) {\n\t\t\tcontinue\n\t\t}\n\t\tif err := stream.Send(&pb.LogEntry{\n\t\t\tType:      \"log\",\n\t\t\tStepName:  line.StepName,\n\t\t\tMessage:   line.Content,\n\t\t\tTimestamp: line.Timestamp,\n\t\t}); err != nil {\n\t\t\treturn err\n\t\t}\n\t}\n\n\t// Stream live lines filtered by step/type.\n\tctx := stream.Context()\n\tfor {\n\t\tselect {\n\t\tcase <-ctx.Done():\n\t\t\treturn ctx.Err()\n\t\tcase line, ok := <-sub.C:\n\t\t\tif !ok {\n\t\t\t\t// Run completed — send terminal entry.\n\t\t\t\trun, err := s.store.GetRun(context.Background(), runID)\n\t\t\t\tif err == nil && run.State != domain.RunStateRunning && run.State != domain.RunStatePending {\n\t\t\t\t\t_ = stream.Send(&pb.LogEntry{\n\t\t\t\t\t\tType:      \"run_completed\",\n\t\t\t\t\t\tResult:    string(run.State),\n\t\t\t\t\t\tTimestamp: run.CompletedAt.String(),\n\t\t\t\t\t\tMessage:   run.ErrorMessage,\n\t\t\t\t\t})\n\t\t\t\t}\n\t\t\t\treturn nil\n\t\t\t}\n\t\t\tif !matchesFilter(line) {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tif err := stream.Send(&pb.LogEntry{\n\t\t\t\tType:      \"log\",\n\t\t\t\tStepName:  line.StepName,\n\t\t\t\tMessage:   line.Content,\n\t\t\t\tTimestamp: line.Timestamp,\n\t\t\t}); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t}\n\t}\n}\n\n// streamFilteredLogs serves log content filtered by step name and/or log type.\n// It uses the log index when available, falling back to file path conventions.\nfunc (s *ClocheServer) streamFilteredLogs(ctx context.Context, req *pb.StreamLogsRequest, run *domain.Run, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\")\n\n\t// Try log index first\n\tif s.logStore != nil {\n\t\tvar logFiles []*ports.LogFileEntry\n\t\tvar err error\n\n\t\tif req.StepName != \"\" && req.LogType != \"\" {\n\t\t\t// Filter by both step and type\n\t\t\tlogFiles, err = s.logStore.GetLogFilesByStep(ctx, req.RunId, req.StepName)\n\t\t\tif err == nil {\n\t\t\t\tfiltered := logFiles[:0]\n\t\t\t\tfor _, lf := range logFiles {\n\t\t\t\t\tif lf.FileType == req.LogType {\n\t\t\t\t\t\tfiltered = append(filtered, lf)\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t\tlogFiles = filtered\n\t\t\t}\n\t\t} else if req.StepName != \"\" {\n\t\t\tlogFiles, err = s.logStore.GetLogFilesByStep(ctx, req.RunId, req.StepName)\n\t\t} else {\n\t\t\tlogFiles, err = s.logStore.GetLogFileByType(ctx, req.RunId, req.LogType)\n\t\t}\n\n\t\tif err == nil && len(logFiles) > 0 {\n\t\t\tfor _, lf := range logFiles {\n\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n\t\t\t\tif readErr != nil {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tif err := stream.Send(&pb.LogEntry{\n\t\t\t\t\tType:     lf.FileType + \"_log\",\n\t\t\t\t\tStepName: lf.StepName,\n\t\t\t\t\tMessage:  string(data),\n\t\t\t\t}); err != nil {\n\t\t\t\t\treturn err\n\t\t\t\t}\n\t\t\t}\n\t\t\treturn nil\n\t\t}\n\t}\n\n\t// Fall back to file path conventions\n\tif req.StepName != \"\" {\n\t\tvar logPath string\n\t\tswitch req.LogType {\n\t\tcase \"llm\":\n\t\t\tlogPath = filepath.Join(outputDir, \"llm-\"+req.StepName+\".log\")\n\t\tdefault:\n\t\t\tlogPath = filepath.Join(outputDir, req.StepName+\".log\")\n\t\t}\n\n\t\tdata, err := os.ReadFile(logPath)\n\t\tif err != nil {\n\t\t\treturn fmt.Errorf(\"log file not found for step %q: %w\", req.StepName, err)\n\t\t}\n\t\treturn stream.Send(&pb.LogEntry{\n\t\t\tType:     \"step_log\",\n\t\t\tStepName: req.StepName,\n\t\t\tMessage:  string(data),\n\t\t})\n\t}\n\n\treturn fmt.Errorf(\"no log files found matching filter\")\n}\n\n// streamLiveLogs subscribes to the broadcaster and streams log lines in real\n// time for an active run. The stream closes when the run completes or the\n// client disconnects.\nfunc (s *ClocheServer) streamLiveLogs(runID string, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n\tsub := s.logBroadcast.Subscribe(runID)\n\tdefer s.logBroadcast.Unsubscribe(runID, sub)\n\n\tctx := stream.Context()\n\tfor {\n\t\tselect {\n\t\tcase <-ctx.Done():\n\t\t\treturn ctx.Err()\n\t\tcase line, ok := <-sub.C:\n\t\t\tif !ok {\n\t\t\t\t// Run completed — send terminal entry.\n\t\t\t\trun, err := s.store.GetRun(context.Background(), runID)\n\t\t\t\tif err == nil && run.State != domain.RunStateRunning && run.State != domain.RunStatePending {\n\t\t\t\t\t_ = stream.Send(&pb.LogEntry{\n\t\t\t\t\t\tType:      \"run_completed\",\n\t\t\t\t\t\tResult:    string(run.State),\n\t\t\t\t\t\tTimestamp: run.CompletedAt.String(),\n\t\t\t\t\t\tMessage:   run.ErrorMessage,\n\t\t\t\t\t})\n\t\t\t\t}\n\t\t\t\treturn nil\n\t\t\t}\n\t\t\tif err := stream.Send(&pb.LogEntry{\n\t\t\t\tType:      \"log\",\n\t\t\t\tStepName:  line.StepName,\n\t\t\t\tMessage:   line.Content,\n\t\t\t\tTimestamp: line.Timestamp,\n\t\t\t}); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t}\n\t}\n}\n\nfunc (s *ClocheServer) StopRun(ctx context.Context, req *pb.StopRunRequest) (*pb.StopRunResponse, error) {\n\ts.mu.Lock()\n\tcontainerID, ok := s.runIDs[req.RunId]\n\ts.mu.Unlock()\n\n\tif !ok {\n\t\treturn nil, fmt.Errorf(\"run %q not found or already completed\", req.RunId)\n\t}\n\n\tif err := s.container.Stop(ctx, containerID); err != nil {\n\t\treturn nil, fmt.Errorf(\"stopping run: %w\", err)\n\t}\n\n\t// Mark as cancelled in store\n\trun, err := s.store.GetRun(ctx, req.RunId)\n\tif err == nil {\n\t\trun.Complete(domain.RunStateCancelled)\n\t\t_ = s.store.UpdateRun(ctx, run)\n\t}\n\n\treturn &pb.StopRunResponse{}, nil\n}\n\nfunc (s *ClocheServer) DeleteContainer(ctx context.Context, req *pb.DeleteContainerRequest) (*pb.DeleteContainerResponse, error) {\n\tif s.container == nil {\n\t\treturn nil, fmt.Errorf(\"no container runtime configured\")\n\t}\n\n\tid := req.Id\n\tif id == \"\" {\n\t\treturn nil, fmt.Errorf(\"id is required\")\n\t}\n\n\t// Try to resolve as a run ID first\n\tcontainerID := id\n\trun, err := s.store.GetRun(ctx, id)\n\tif err == nil {\n\t\t// It's a run ID — use the container ID from the run record\n\t\tif run.ContainerID == \"\" {\n\t\t\treturn nil, fmt.Errorf(\"run %q has no associated container\", id)\n\t\t}\n\t\tcontainerID = run.ContainerID\n\t}\n\n\t// Remove the container\n\tif err := s.container.Remove(ctx, containerID); err != nil {\n\t\treturn nil, fmt.Errorf(\"removing container: %w\", err)\n\t}\n\n\t// If we resolved a run, clear the container_kept flag\n\tif run != nil {\n\t\trun.ContainerKept = false\n\t\t_ = s.store.UpdateRun(ctx, run)\n\t}\n\n\treturn &pb.DeleteContainerResponse{}, nil\n}\n\nfunc (s *ClocheServer) EnableLoop(ctx context.Context, req *pb.EnableLoopRequest) (*pb.EnableLoopResponse, error) {\n\tprojectDir := req.ProjectDir\n\tif projectDir == \"\" {\n\t\treturn nil, fmt.Errorf(\"project_dir is required\")\n\t}\n\n\t// Verify host.cloche exists\n\thostPath := filepath.Join(projectDir, \".cloche\", \"host.cloche\")\n\tif _, err := os.Stat(hostPath); err != nil {\n\t\treturn nil, fmt.Errorf(\"host.cloche not found in %s: %w\", projectDir, err)\n\t}\n\n\t// Load project config for defaults.\n\tprojCfg, _ := config.Load(projectDir)\n\n\tmaxConc := int(req.MaxConcurrent)\n\tif maxConc <= 0 {\n\t\tmaxConc = projCfg.Orchestration.Concurrency\n\t}\n\tif maxConc <= 0 {\n\t\tmaxConc = 1\n\t}\n\n\tstagger := time.Duration(float64(time.Second) * projCfg.Orchestration.StaggerSeconds)\n\n\t// Compute dedup timeout from config (default 5 minutes).\n\tdedupTimeout := time.Duration(float64(time.Second) * projCfg.Orchestration.DedupSeconds)\n\n\tloopCfg := host.LoopConfig{\n\t\tProjectDir:    projectDir,\n\t\tMaxConcurrent: maxConc,\n\t\tStaggerDelay:  stagger,\n\t\tDedupTimeout:  dedupTimeout,\n\t}\n\n\ts.mu.Lock()\n\tdefer s.mu.Unlock()\n\n\t// Stop existing loop if running.\n\tif existing, ok := s.loops[projectDir]; ok {\n\t\texisting.Stop()\n\t}\n\n\t// Check if host.cloche defines a list-tasks workflow for three-phase mode.\n\tvar loop *host.Loop\n\tif s.hasWorkflow(hostPath, \"list-tasks\") {\n\t\tloop = s.createPhaseLoop(loopCfg, projectDir, hostPath, dedupTimeout)\n\t} else {\n\t\tloop = s.createLegacyLoop(loopCfg, projectDir, projCfg, dedupTimeout)\n\t}\n\n\ts.loops[projectDir] = loop\n\tloop.Start()\n\n\treturn &pb.EnableLoopResponse{}, nil\n}\n\n// hasWorkflow checks if host.cloche contains a workflow with the given name.\nfunc (s *ClocheServer) hasWorkflow(hostPath, workflowName string) bool {\n\tdata, err := os.ReadFile(hostPath)\n\tif err != nil {\n\t\treturn false\n\t}\n\treturn strings.Contains(string(data), fmt.Sprintf(\"workflow %q\", workflowName))\n}\n\n// createPhaseLoop creates a three-phase orchestration loop using list-tasks,\n// main, and finalize workflows from host.cloche.\nfunc (s *ClocheServer) createPhaseLoop(loopCfg host.LoopConfig, projectDir, hostPath string, dedupTimeout time.Duration) *host.Loop {\n\t// Phase 1: list-tasks function\n\tlistTasksFn := func(ctx context.Context, projDir string) ([]host.Task, error) {\n\t\trunner := &host.Runner{\n\t\t\tDispatcher: s,\n\t\t\tStore:      s.store,\n\t\t}\n\t\tresult, err := runner.RunNamed(ctx, projDir, \"list-tasks\")\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t\tif result.State != domain.RunStateSucceeded {\n\t\t\treturn nil, fmt.Errorf(\"list-tasks workflow failed with state %s\", result.State)\n\t\t}\n\t\treturn host.ReadListTasksOutput(result.OutputDir)\n\t}\n\n\t// Phase 2: main function\n\tmainFn := func(ctx context.Context, projDir string, taskID string) (*host.RunResult, error) {\n\t\trunner := &host.Runner{\n\t\t\tDispatcher: s,\n\t\t\tStore:      s.store,\n\t\t\tTaskID:     taskID,\n\t\t}\n\t\treturn runner.RunNamed(ctx, projDir, \"main\")\n\t}\n\n\t// Phase 3: finalize function (optional — only if host.cloche has it)\n\tvar finalizeFn host.FinalizeFunc\n\tif s.hasWorkflow(hostPath, \"finalize\") {\n\t\tfinalizeFn = func(ctx context.Context, projDir string, taskID string, mainResult *host.RunResult) (*host.RunResult, error) {\n\t\t\tmainRunID := \"\"\n\t\t\tmainOutcome := \"failed\"\n\t\t\tif mainResult != nil {\n\t\t\t\tmainRunID = mainResult.RunID\n\t\t\t\tmainOutcome = string(mainResult.State)\n\t\t\t}\n\t\t\trunner := &host.Runner{\n\t\t\t\tDispatcher: s,\n\t\t\t\tStore:      s.store,\n\t\t\t\tTaskID:     taskID,\n\t\t\t\tExtraEnv: []string{\n\t\t\t\t\t\"CLOCHE_MAIN_RUN_ID=\" + mainRunID,\n\t\t\t\t\t\"CLOCHE_MAIN_OUTCOME=\" + mainOutcome,\n\t\t\t\t},\n\t\t\t}\n\t\t\treturn runner.RunNamed(ctx, projDir, \"finalize\")\n\t\t}\n\t}\n\n\tlog.Printf(\"orchestration loop: three-phase mode enabled for %s (list-tasks + main + finalize, dedup=%s)\", projectDir, dedupTimeout)\n\treturn host.NewPhaseLoop(loopCfg, s.store, listTasksFn, mainFn, finalizeFn)\n}\n\n// createLegacyLoop creates a legacy single-function orchestration loop.\nfunc (s *ClocheServer) createLegacyLoop(loopCfg host.LoopConfig, projectDir string, projCfg *config.Config, dedupTimeout time.Duration) *host.Loop {\n\trunFn := func(ctx context.Context, projDir string, taskID string) (*host.RunResult, error) {\n\t\trunner := &host.Runner{\n\t\t\tDispatcher: s,\n\t\t\tStore:      s.store,\n\t\t\tTaskID:     taskID,\n\t\t}\n\t\treturn runner.Run(ctx, projDir)\n\t}\n\n\tloop := host.NewLoop(loopCfg, s.store, runFn)\n\n\t// Configure daemon-managed task assignment if a list-tasks command is set.\n\tif cmd := projCfg.Orchestration.ListTasksCommand; cmd != \"\" {\n\t\tloop.SetTaskAssigner(&host.ScriptTaskAssigner{Command: cmd})\n\t\tlog.Printf(\"orchestration loop: task assignment enabled for %s (command=%q, dedup=%s)\", projectDir, cmd, dedupTimeout)\n\t}\n\n\treturn loop\n}\n\n// GetLoopTasks returns the current task pipeline state for a project's\n// orchestration loop, formatted as web.TaskEntry values. Returns nil if no\n// loop is active for the project.\nfunc (s *ClocheServer) GetLoopTasks(projectDir string) []web.TaskEntry {\n\ts.mu.Lock()\n\tloop, ok := s.loops[projectDir]\n\ts.mu.Unlock()\n\tif !ok {\n\t\treturn nil\n\t}\n\tsnapshot := loop.GetTaskSnapshot()\n\tentries := make([]web.TaskEntry, len(snapshot))\n\tfor i, e := range snapshot {\n\t\tentry := web.TaskEntry{\n\t\t\tID:          e.Task.ID,\n\t\t\tStatus:      e.Task.Status,\n\t\t\tTitle:       e.Task.Title,\n\t\t\tDescription: e.Task.Description,\n\t\t\tMetadata:    e.Task.Metadata,\n\t\t\tAssigned:    e.Assigned,\n\t\t\tRunID:       e.RunID,\n\t\t}\n\t\tif !e.AssignedAt.IsZero() {\n\t\t\tentry.AssignedAt = e.AssignedAt.Format(time.RFC3339)\n\t\t}\n\t\tentries[i] = entry\n\t}\n\treturn entries\n}\n\nfunc (s *ClocheServer) DisableLoop(ctx context.Context, req *pb.DisableLoopRequest) (*pb.DisableLoopResponse, error) {\n\tprojectDir := req.ProjectDir\n\tif projectDir == \"\" {\n\t\treturn nil, fmt.Errorf(\"project_dir is required\")\n\t}\n\n\ts.mu.Lock()\n\tdefer s.mu.Unlock()\n\n\tif loop, ok := s.loops[projectDir]; ok {\n\t\tloop.Stop()\n\t\tdelete(s.loops, projectDir)\n\t}\n\n\treturn &pb.DisableLoopResponse{}, nil\n}\n\nfunc (s *ClocheServer) Shutdown(ctx context.Context, req *pb.ShutdownRequest) (*pb.ShutdownResponse, error) {\n\t// Stop all orchestration loops.\n\ts.mu.Lock()\n\tfor _, loop := range s.loops {\n\t\tloop.Stop()\n\t}\n\ts.loops = make(map[string]*host.Loop)\n\ts.mu.Unlock()\n\n\tif s.shutdownFn == nil {\n\t\treturn nil, fmt.Errorf(\"shutdown not configured\")\n\t}\n\tgo s.shutdownFn()\n\treturn &pb.ShutdownResponse{}, nil\n}\n\n// indexLogFiles scans the extracted output directory and creates log_files index entries.\nfunc (s *ClocheServer) indexLogFiles(ctx context.Context, runID, outputDir string) {\n\tentries, err := os.ReadDir(outputDir)\n\tif err != nil {\n\t\tlog.Printf(\"run %s: failed to read output dir for indexing: %v\", runID, err)\n\t\treturn\n\t}\n\n\tnow := time.Now()\n\tfor _, entry := range entries {\n\t\tif entry.IsDir() {\n\t\t\tcontinue\n\t\t}\n\t\tname := entry.Name()\n\t\tif !strings.HasSuffix(name, \".log\") {\n\t\t\tcontinue\n\t\t}\n\n\t\tvar fileType, stepName string\n\t\tbase := strings.TrimSuffix(name, \".log\")\n\n\t\tswitch {\n\t\tcase name == \"full.log\":\n\t\t\tfileType = \"full\"\n\t\tcase name == \"container.log\":\n\t\t\t// container.log is internal, not indexed as a user-facing log type\n\t\t\tcontinue\n\t\tcase strings.HasPrefix(name, \"llm-\"):\n\t\t\tfileType = \"llm\"\n\t\t\tstepName = strings.TrimPrefix(base, \"llm-\")\n\t\tdefault:\n\t\t\tfileType = \"script\"\n\t\t\tstepName = base\n\t\t}\n\n\t\tinfo, _ := entry.Info()\n\t\tvar fileSize int64\n\t\tif info != nil {\n\t\t\tfileSize = info.Size()\n\t\t}\n\n\t\tlogEntry := &ports.LogFileEntry{\n\t\t\tRunID:     runID,\n\t\t\tStepName:  stepName,\n\t\t\tFileType:  fileType,\n\t\t\tFilePath:  filepath.Join(outputDir, name),\n\t\t\tFileSize:  fileSize,\n\t\t\tCreatedAt: now,\n\t\t}\n\t\tif err := s.logStore.SaveLogFile(ctx, logEntry); err != nil {\n\t\t\tlog.Printf(\"run %s: failed to index log file %s: %v\", runID, name, err)\n\t\t}\n\t}\n}\n\nfunc gitHEAD(dir string) string {\n\tcmd := exec.Command(\"git\", \"rev-parse\", \"HEAD\")\n\tcmd.Dir = dir\n\tout, err := cmd.Output()\n\tif err != nil {\n\t\treturn \"\"\n\t}\n\treturn strings.TrimSpace(string(out))\n}\n","numLines":1075,"startLine":1,"totalLines":1075}}}
