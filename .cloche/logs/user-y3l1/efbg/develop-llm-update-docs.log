tassert.Equal(t, http.StatusBadRequest, w.Code)\n+}\n+\n+func TestRunsList_CleanupButton(t *testing.T) {\n+\th, store, mgr := setupHandlerWithContainerManager(t)\n+\tseedRunWithContainer(t, store, mgr, \"run-cb1\", \"develop\", \"/home/user/alpha\", \"cid-cb1\", true)\n+\tseedRunWithContainer(t, store, mgr, \"run-cb2\", \"develop\", \"/home/user/beta\", \"cid-cb2\", true)\n+\n+\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n+\tw := httptest.NewRecorder()\n+\th.ServeHTTP(w, req)\n+\n+\tassert.Equal(t, http.StatusOK, w.Code)\n+\tbody := w.Body.String()\n+\tassert.Contains(t, body, `id=\"cleanup-containers-btn\"`)\n+\tassert.Contains(t, body, \"Clean up 2 old containers\")\n+}\n+\n+func TestRunsList_NoCleanupButtonWhenNoContainers(t *testing.T) {\n+\th, store, mgr := setupHandlerWithContainerManager(t)\n+\tseedRunWithContainer(t, store, mgr, \"run-ncb1\", \"develop\", \"/home/user/alpha\", \"cid-ncb1\", false)\n+\n+\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n+\tw := httptest.NewRecorder()\n+\th.ServeHTTP(w, req)\n+\n+\tassert.Equal(t, http.StatusOK, w.Code)\n+\tbody := w.Body.String()\n+\tassert.NotContains(t, body, `id=\"cleanup-containers-btn\"`)\n+}\ndiff --git a/internal/adapters/web/templates/runs.html b/internal/adapters/web/templates/runs.html\nindex ac62f1f..248c9f3 100644\n--- a/internal/adapters/web/templates/runs.html\n+++ b/internal/adapters/web/templates/runs.html\n@@ -9,6 +9,9 @@\n         <option value=\"{{.Dir}}\"{{if eq .Dir $.ProjectFilter}} selected{{end}}>{{.Label}}{{if .ContainerCount}} ({{.ContainerCount}} container{{if gt .ContainerCount 1}}s{{end}}){{end}}</option>\n         {{end}}\n     </select>\n+    {{if .TotalContainerCount}}\n+    <button class=\"btn btn-danger btn-sm\" id=\"cleanup-containers-btn\" onclick=\"cleanupContainers()\" style=\"margin-left:0.5rem\">Clean up {{.TotalContainerCount}} old container{{if gt .TotalContainerCount 1}}s{{end}}</button>\n+    {{end}}\n </div>\n {{end}}\n <table class=\"runs-table\">\n@@ -61,6 +64,24 @@\n     }\n     window.filterByProject = filterByProject;\n \n+    window.cleanupContainers = function() {\n+        var btn = document.getElementById('cleanup-containers-btn');\n+        if (btn) btn.disabled = true;\n+        fetch('/api/containers', { method: 'DELETE' })\n+            .then(function(r) { return r.json(); })\n+            .then(function(data) {\n+                if (btn) {\n+                    btn.textContent = 'Cleaned up ' + data.deleted + ' container' + (data.deleted !== 1 ? 's' : '');\n+                }\n+            })\n+            .catch(function() {\n+                if (btn) {\n+                    btn.textContent = 'Cleanup failed';\n+                    btn.disabled = false;\n+                }\n+            });\n+    };\n+\n     // groupRuns arranges runs so children appear directly after their parent.\n     // Parents are de-emphasized; children (where active work happens) are prominent.\n     function groupRuns(runs) {","stderr":"","interrupted":false,"isImage":false,"noOutputExpected":false}}
