{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QKepUYQFM5oAQGv99CEuAE","type":"tool_result","content":"The file /workspace/internal/adapters/web/templates/runs.html has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"8e13d6e3-30e6-4db9-bdca-65dcaa963e36","uuid":"a45f77b0-6e8d-4f50-87c9-daba43078d60","tool_use_result":{"filePath":"/workspace/internal/adapters/web/templates/runs.html","oldString":"    window.filterByProject = filterByProject;","newString":"    window.filterByProject = filterByProject;\n\n    window.cleanupContainers = function() {\n        var btn = document.getElementById('cleanup-containers-btn');\n        if (btn) btn.disabled = true;\n        fetch('/api/containers', { method: 'DELETE' })\n            .then(function(r) { return r.json(); })\n            .then(function(data) {\n                if (btn) {\n                    btn.textContent = 'Cleaned up ' + data.deleted + ' container' + (data.deleted !== 1 ? 's' : '');\n                }\n            })\n            .catch(function() {\n                if (btn) {\n                    btn.textContent = 'Cleanup failed';\n                    btn.disabled = false;\n                }\n            });\n    };","originalFile":"{{define \"content\"}}\n<h1>Runs</h1>\n{{if .Projects}}\n<div class=\"project-filter\">\n    <label for=\"project-select\">Project:</label>\n    <select id=\"project-select\" onchange=\"filterByProject(this.value)\">\n        <option value=\"\">All projects</option>\n        {{range .Projects}}\n        <option value=\"{{.Dir}}\"{{if eq .Dir $.ProjectFilter}} selected{{end}}>{{.Label}}{{if .ContainerCount}} ({{.ContainerCount}} container{{if gt .ContainerCount 1}}s{{end}}){{end}}</option>\n        {{end}}\n    </select>\n    {{if .TotalContainerCount}}\n    <button class=\"btn btn-danger btn-sm\" id=\"cleanup-containers-btn\" onclick=\"cleanupContainers()\" style=\"margin-left:0.5rem\">Clean up {{.TotalContainerCount}} old container{{if gt .TotalContainerCount 1}}s{{end}}</button>\n    {{end}}\n</div>\n{{end}}\n<table class=\"runs-table\">\n    <thead>\n        <tr>\n            <th>Run ID</th>\n            <th>Title</th>\n            <th>Project</th>\n            <th>Workflow</th>\n            <th>Type</th>\n            <th>State</th>\n            <th>Timing</th>\n            <th>Container</th>\n            <th>Error</th>\n        </tr>\n    </thead>\n    <tbody id=\"runs-body\">\n    {{if .Runs}}\n        {{range .Runs}}\n        <tr class=\"{{if .ParentRunID}}run-child-row{{else if .IsHost}}run-parent-row{{end}}\">\n            <td><a href=\"/runs/{{.ID}}\">{{.ID}}</a></td>\n            <td>{{truncate .Title 50}}</td>\n            <td>{{index $.ProjectLabels .ProjectDir}}</td>\n            <td>{{.WorkflowName}}</td>\n            <td>{{if .IsHost}}host{{else}}container{{end}}</td>\n            <td><span class=\"badge badge-{{stateColor .State}}\">{{.State}}</span></td>\n            <td>{{formatRunTiming .State .StartedAt .CompletedAt}}</td>\n            <td class=\"mono\">{{shortContainerID .ContainerID}}</td>\n            <td class=\"error-cell\">{{truncate .ErrorMessage 80}}</td>\n        </tr>\n        {{end}}\n    {{else}}\n        <tr><td colspan=\"9\" class=\"empty\">No runs yet.</td></tr>\n    {{end}}\n    </tbody>\n</table>\n{{end}}\n\n{{define \"scripts\"}}\n<script>\n(function() {\n    var currentProject = '{{.ProjectFilter}}';\n\n    function filterByProject(dir) {\n        if (dir) {\n            window.location.href = '/runs?project=' + encodeURIComponent(dir);\n        } else {\n            window.location.href = '/runs';\n        }\n    }\n    window.filterByProject = filterByProject;\n\n    // groupRuns arranges runs so children appear directly after their parent.\n    // Parents are de-emphasized; children (where active work happens) are prominent.\n    function groupRuns(runs) {\n        var parentMap = {};  // parent_run_id -> [children]\n        var topLevel = [];\n        var byId = {};\n\n        for (var i = 0; i < runs.length; i++) {\n            byId[runs[i].id] = runs[i];\n        }\n\n        for (var i = 0; i < runs.length; i++) {\n            var r = runs[i];\n            if (r.parent_run_id && byId[r.parent_run_id]) {\n                if (!parentMap[r.parent_run_id]) parentMap[r.parent_run_id] = [];\n                parentMap[r.parent_run_id].push(r);\n            } else {\n                topLevel.push(r);\n            }\n        }\n\n        // Sort top-level: running first, then by started_at descending\n        topLevel.sort(function(a, b) {\n            var aRunning = a.state === 'running' ? 0 : 1;\n            var bRunning = b.state === 'running' ? 0 : 1;\n            if (aRunning !== bRunning) return aRunning - bRunning;\n            return (b.started_at || '').localeCompare(a.started_at || '');\n        });\n\n        var result = [];\n        for (var i = 0; i < topLevel.length; i++) {\n            var r = topLevel[i];\n            var children = parentMap[r.id];\n            var isParent = children && children.length > 0;\n            result.push({ run: r, isParent: isParent, isChild: false });\n            if (children) {\n                for (var j = 0; j < children.length; j++) {\n                    result.push({ run: children[j], isParent: false, isChild: true });\n                }\n            }\n        }\n\n        // Add orphaned children (parent not in current view)\n        for (var i = 0; i < runs.length; i++) {\n            var r = runs[i];\n            if (r.parent_run_id && !byId[r.parent_run_id]) {\n                result.push({ run: r, isParent: false, isChild: true });\n            }\n        }\n\n        return result;\n    }\n\n    function poll() {\n        var url = '/api/runs';\n        if (currentProject) {\n            url += '?project=' + encodeURIComponent(currentProject);\n        }\n        fetch(url)\n            .then(function(r) { return r.json(); })\n            .then(function(runs) {\n                var tbody = document.getElementById('runs-body');\n                if (!runs || runs.length === 0) {\n                    tbody.innerHTML = '<tr><td colspan=\"9\" class=\"empty\">No runs yet.</td></tr>';\n                    return;\n                }\n\n                var grouped = groupRuns(runs);\n                var html = '';\n                for (var i = 0; i < grouped.length; i++) {\n                    var entry = grouped[i];\n                    var r = entry.run;\n                    var cid = r.container_id || '';\n                    if (cid.length > 12) cid = cid.substring(0, 12);\n                    var err = r.error_message || '';\n                    if (err.length > 80) err = err.substring(0, 80) + '...';\n                    var proj = r.project_label || '';\n                    var title = r.title || '';\n                    if (title.length > 50) title = title.substring(0, 47) + '...';\n                    var runType = r.is_host ? 'host' : 'container';\n                    var rowClass = entry.isChild ? 'run-child-row' : (entry.isParent ? 'run-parent-row' : '');\n                    var timing = r.timing || '';\n                    html += '<tr class=\"' + rowClass + '\">' +\n                        '<td><a href=\"/runs/' + r.id + '\">' + r.id + '</a></td>' +\n                        '<td>' + escapeHtml(title) + '</td>' +\n                        '<td>' + escapeHtml(proj) + '</td>' +\n                        '<td>' + r.workflow_name + '</td>' +\n                        '<td>' + runType + '</td>' +\n                        '<td><span class=\"badge badge-' + r.state + '\">' + r.state + '</span></td>' +\n                        '<td>' + escapeHtml(timing) + '</td>' +\n                        '<td class=\"mono\">' + cid + '</td>' +\n                        '<td class=\"error-cell\">' + escapeHtml(err) + '</td>' +\n                        '</tr>';\n                }\n                tbody.innerHTML = html;\n            })\n            .catch(function() {});\n    }\n    function escapeHtml(s) {\n        var d = document.createElement('div');\n        d.appendChild(document.createTextNode(s));\n        return d.innerHTML;\n    }\n    setInterval(poll, 3000);\n})();\n</script>\n{{end}}\n","structuredPatch":[{"oldStart":64,"oldLines":6,"newStart":64,"newLines":24,"lines":["     }","     window.filterByProject = filterByProject;"," ","+    window.cleanupContainers = function() {","+        var btn = document.getElementById('cleanup-containers-btn');","+        if (btn) btn.disabled = true;","+        fetch('/api/containers', { method: 'DELETE' })","+            .then(function(r) { return r.json(); })","+            .then(function(data) {","+                if (btn) {","+                    btn.textContent = 'Cleaned up ' + data.deleted + ' container' + (data.deleted !== 1 ? 's' : '');","+                }","+            })","+            .catch(function() {","+                if (btn) {","+                    btn.textContent = 'Cleanup failed';","+                    btn.disabled = false;","+                }","+            });","+    };","+","     // groupRuns arranges runs so children appear directly after their parent.","     // Parents are de-emphasized; children (where active work happens) are prominent.","     function groupRuns(runs) {"]}],"userModified":false,"replaceAll":false}}
