{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015jVWT5Pufn16pscsHZisk1","type":"tool_result","content":"   482→func (h *Handler) handleAPIRuns(w http.ResponseWriter, r *http.Request) {\n   483→\tprojectFilter := r.URL.Query().Get(\"project\")\n   484→\n   485→\tvar runs []*domain.Run\n   486→\tvar err error\n   487→\tif projectFilter != \"\" {\n   488→\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n   489→\t} else {\n   490→\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n   491→\t}\n   492→\tif err != nil {\n   493→\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n   494→\t\treturn\n   495→\t}\n   496→\n   497→\tprojects, _ := h.store.ListProjects(r.Context())\n   498→\tlabels := projectLabels(projects)\n   499→\n   500→\tresult := make([]apiRun, len(runs))\n   501→\tfor i, run := range runs {\n   502→\t\tresult[i] = toAPIRun(run, labels)\n   503→\t}\n   504→\n   505→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   506→\tjson.NewEncoder(w).Encode(result)\n   507→}\n   508→\n   509→func (h *Handler) handleAPIProjects(w http.ResponseWriter, r *http.Request) {\n   510→\tprojects, err := h.store.ListProjects(r.Context())\n   511→\tif err != nil {\n   512→\t\thttp.Error(w, \"failed to list projects\", http.StatusInternalServerError)\n   513→\t\treturn\n   514→\t}\n   515→\tlabels := projectLabels(projects)\n   516→\n   517→\ttype apiHealth struct {\n   518→\t\tStatus string `json:\"status\"`\n   519→\t\tPassed int    `json:\"passed\"`\n   520→\t\tFailed int    `json:\"failed\"`\n   521→\t\tTotal  int    `json:\"total\"`\n   522→\t}\n   523→\ttype apiProject struct {\n   524→\t\tDir         string    `json:\"dir\"`\n   525→\t\tLabel       string    `json:\"label\"`\n   526→\t\tHealth      apiHealth `json:\"health\"`\n   527→\t\tActiveCount int       `json:\"active_count\"`\n   528→\t}\n   529→\tresult := make([]apiProject, len(projects))\n   530→\tfor i, dir := range projects {\n   531→\t\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   532→\t\trunValues := make([]domain.Run, len(runs))\n   533→\t\tfor j, rr := range runs {\n   534→\t\t\trunValues[j] = *rr\n   535→\t\t}\n   536→\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n   537→\t\tvar activeCount int\n   538→\t\tfor _, rr := range runs {\n   539→\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n   540→\t\t\t\tactiveCount++\n   541→\t\t\t}\n   542→\t\t}\n   543→\t\tresult[i] = apiProject{\n   544→\t\t\tDir:   dir,\n   545→\t\t\tLabel: labels[dir],\n   546→\t\t\tHealth: apiHealth{\n   547→\t\t\t\tStatus: string(health.Status),\n   548→\t\t\t\tPassed: health.Passed,\n   549→\t\t\t\tFailed: health.Failed,\n   550→\t\t\t\tTotal:  health.Total,\n   551→\t\t\t},\n   552→\t\t\tActiveCount: activeCount,\n   553→\t\t}\n   554→\t}\n   555→\n   556→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   557→\tjson.NewEncoder(w).Encode(result)\n   558→}\n   559→\n   560→func (h *Handler) handleAPIRunDetail(w http.ResponseWriter, r *http.Request) {\n   561→\tid := r.PathValue(\"id\")"}]},"parent_tool_use_id":"toolu_01M8hYjhcTo6x7NYVENZSdEY","session_id":"8e13d6e3-30e6-4db9-bdca-65dcaa963e36","uuid":"fa25f1d3-4958-476c-89e5-0fd380689d13"}
