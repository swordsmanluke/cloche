r(t, store, mgr, \"run-pdr2\", \"develop\", \"/home/user/alpha\", \"cid-pdr2\", true)\n  1257→\n  1258→\treq := httptest.NewRequest(\"DELETE\", \"/api/projects/alpha/containers\", nil)\n  1259→\tw := httptest.NewRecorder()\n  1260→\th.ServeHTTP(w, req)\n  1261→\n  1262→\tassert.Equal(t, http.StatusOK, w.Code)\n  1263→\n  1264→\tvar resp map[string]any\n  1265→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n  1266→\tassert.Equal(t, float64(1), resp[\"deleted\"])\n  1267→\n  1268→\t// Running container not removed\n  1269→\tassert.NotContains(t, mgr.removed, \"cid-pdr1\")\n  1270→\tassert.Contains(t, mgr.removed, \"cid-pdr2\")\n  1271→}\n  1272→\n  1273→func TestAPIDeleteProjectContainers_SkipsNonKept(t *testing.T) {\n  1274→\th, store, mgr := setupHandlerWithContainerManager(t)\n  1275→\tseedRunWithContainer(t, store, mgr, \"run-pdk1\", \"develop\", \"/home/user/alpha\", \"cid-pdk1\", false) // not kept\n  1276→\n  1277→\treq := httptest.NewRequest(\"DELETE\", \"/api/projects/alpha/containers\", nil)\n  1278→\tw := httptest.NewRecorder()\n  1279→\th.ServeHTTP(w, req)\n  1280→\n  1281→\tassert.Equal(t, http.StatusOK, w.Code)\n  1282→\n  1283→\tvar resp map[string]any\n  1284→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n  1285→\tassert.Equal(t, float64(0), resp[\"deleted\"])\n  1286→}\n  1287→\n  1288→func TestAPIDeleteProjectContainers_NoManager(t *testing.T) {\n  1289→\th, store := setupHandler(t)\n  1290→\tseedRunWithProject(t, store, \"run-pdnm\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n  1291→\n  1292→\treq := httptest.NewRequest(\"DELETE\", \"/api/projects/alpha/containers\", nil)\n  1293→\tw := httptest.NewRecorder()\n  1294→\th.ServeHTTP(w, req)\n  1295→\n  1296→\tassert.Equal(t, http.StatusBadRequest, w.Code)\n  1297→}\n  1298→\n  1299→func TestAPIDeleteProjectContainers_ProjectNotFound(t *testing.T) {\n  1300→\th, _, _ := setupHandlerWithContainerManager(t)\n  1301→\n  1302→\treq := httptest.NewRequest(\"DELETE\", \"/api/projects/nonexistent/containers\", nil)\n  1303→\tw := httptest.NewRecorder()\n  1304→\th.ServeHTTP(w, req)\n  1305→\n  1306→\tassert.Equal(t, http.StatusNotFound, w.Code)\n  1307→}\n  1308→\n  1309→func TestProjectDetail_ContainerDeleteButton(t *testing.T) {\n  1310→\th, store, mgr := setupHandlerWithContainerManager(t)\n  1311→\tseedRunWithContainer(t, store, mgr, \"run-pdb1\", \"develop\", \"/home/user/alpha\", \"cid-pdb1\", true)\n  1312→\tseedRunWithContainer(t, store, mgr, \"run-pdb2\", \"develop\", \"/home/user/alpha\", \"cid-pdb2\", true)\n  1313→\n  1314→\treq := httptest.NewRequest(\"GET\", \"/projects/alpha\", nil)\n  1315→\tw := httptest.NewRecorder()\n  1316→\th.ServeHTTP(w, req)\n  1317→\n  1318→\tassert.Equal(t, http.StatusOK, w.Code)\n  1319→\tbody := w.Body.String()\n  1320→\tassert.Contains(t, body, `id=\"delete-containers-btn\"`)\n  1321→\tassert.Contains(t, body, \"Delete 2 containers\")\n  1322→}\n  1323→\n  1324→func TestProjectDetail_NoButtonWhenNoContainers(t *testing.T) {\n  1325→\th, store, mgr := setupHandlerWithContainerManager(t)\n  1326→\tseedRunWithContainer(t, store, mgr, \"run-pdnb1\", \"develop\", \"/home/user/alpha\", \"cid-pdnb1\", false)\n  1327→\n  1328→\treq := httptest.NewRequest(\"GET\", \"/projects/alpha\", nil)\n  1329→\tw := httptest.NewRecorder()\n  1330→\th.ServeHTTP(w, req)\n  1331→\n  1332→\tassert.Equal(t, http.StatusOK, w.Code)\n  1333→\tbody := w.Body.String()\n  1334→\tassert.NotContains(t, body, `id=\"delete-containers-btn\"`)\n  1335→}\n  1336→\n  1337→func TestAPIProjects_HealthNoRuns(t *testing.T) {\n  1338→\th, _ := setupHandler(t)\n  1339→\n  1340→\treq := httptest.NewRequest(\"GET\", \"/api/projects\", nil)\n  1341→\tw := httptest.NewRecorder()\n  1342→\th.ServeHTTP(w, req)\n  1343→\tassert.Equal(t, http.StatusOK, w.Code)\n  1344→\n  1345→\t// No projects means empty array\n  1346→\ttype project struct {\n  1347→\t\tDir   string `json:\"dir\"`\n  1348→\t\tLabel string `json:\"label\"`\n  1349→\t}"}]},"parent_tool_use_id":null,"session_id":"8e13d6e3-30e6-4db9-bdca-65dcaa963e36","uuid":"ef573a26-3f0e-419c-8222-9c6b77f86537","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/web/handler_test.go","content":"func TestAPIDeleteProjectContainers_Success(t *testing.T) {\n\th, store, mgr := setupHandlerWithContainerManager(t)\n\tseedRunWithContainer(t, store, mgr, \"run-pd1\", \"develop\", \"/home/user/alpha\", \"cid-pd1\", true)\n\tseedRunWithContainer(t, store, mgr, \"run-pd2\", \"develop\", \"/home/user/alpha\", \"cid-pd2\", true)\n\tseedRunWithContainer(t, store, mgr, \"run-pd3\", \"deploy\", \"/home/user/beta\", \"cid-pd3\", true)\n\n\treq := httptest.NewRequest(\"DELETE\", \"/api/projects/alpha/containers\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\n\tvar resp map[string]any\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n\tassert.Equal(t, float64(2), resp[\"deleted\"])\n\n\t// Verify containers were removed\n\tassert.Contains(t, mgr.removed, \"cid-pd1\")\n\tassert.Contains(t, mgr.removed, \"cid-pd2\")\n\tassert.NotContains(t, mgr.removed, \"cid-pd3\")\n\n\t// Verify runs updated\n\trun1, _ := store.GetRun(context.Background(), \"run-pd1\")\n\tassert.False(t, run1.ContainerKept)\n\trun2, _ := store.GetRun(context.Background(), \"run-pd2\")\n\tassert.False(t, run2.ContainerKept)\n\t// beta run unchanged\n\trun3, _ := store.GetRun(context.Background(), \"run-pd3\")\n\tassert.True(t, run3.ContainerKept)\n}\n\nfunc TestAPIDeleteProjectContainers_SkipsRunning(t *testing.T) {\n\th, store, mgr := setupHandlerWithContainerManager(t)\n\tseedRunWithContainer(t, store, mgr, \"run-pdr1\", \"develop\", \"/home/user/alpha\", \"cid-pdr1\", true)\n\tmgr.running[\"cid-pdr1\"] = true // mark as running\n\n\tseedRunWithContainer(t, store, mgr, \"run-pdr2\", \"develop\", \"/home/user/alpha\", \"cid-pdr2\", true)\n\n\treq := httptest.NewRequest(\"DELETE\", \"/api/projects/alpha/containers\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\n\tvar resp map[string]any\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n\tassert.Equal(t, float64(1), resp[\"deleted\"])\n\n\t// Running container not removed\n\tassert.NotContains(t, mgr.removed, \"cid-pdr1\")\n\tassert.Contains(t, mgr.removed, \"cid-pdr2\")\n}\n\nfunc TestAPIDeleteProjectContainers_SkipsNonKept(t *testing.T) {\n\th, store, mgr := setupHandlerWithContainerManager(t)\n\tseedRunWithContainer(t, store, mgr, \"run-pdk1\", \"develop\", \"/home/user/alpha\", \"cid-pdk1\", false) // not kept\n\n\treq := httptest.NewRequest(\"DELETE\", \"/api/projects/alpha/containers\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\n\tvar resp map[string]any\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n\tassert.Equal(t, float64(0), resp[\"deleted\"])\n}\n\nfunc TestAPIDeleteProjectContainers_NoManager(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRunWithProject(t, store, \"run-pdnm\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n\n\treq := httptest.NewRequest(\"DELETE\", \"/api/projects/alpha/containers\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusBadRequest, w.Code)\n}\n\nfunc TestAPIDeleteProjectContainers_ProjectNotFound(t *testing.T) {\n\th, _, _ := setupHandlerWithContainerManager(t)\n\n\treq := httptest.NewRequest(\"DELETE\", \"/api/projects/nonexistent/containers\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusNotFound, w.Code)\n}\n\nfunc TestProjectDetail_ContainerDeleteButton(t *testing.T) {\n\th, store, mgr := setupHandlerWithContainerManager(t)\n\tseedRunWithContainer(t, store, mgr, \"run-pdb1\", \"develop\", \"/home/user/alpha\", \"cid-pdb1\", true)\n\tseedRunWithContainer(t, store, mgr, \"run-pdb2\", \"develop\", \"/home/user/alpha\", \"cid-pdb2\", true)\n\n\treq := httptest.NewRequest(\"GET\", \"/projects/alpha\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody := w.Body.String()\n\tassert.Contains(t, body, `id=\"delete-containers-btn\"`)\n\tassert.Contains(t, body, \"Delete 2 containers\")\n}\n\nfunc TestProjectDetail_NoButtonWhenNoContainers(t *testing.T) {\n\th, store, mgr := setupHandlerWithContainerManager(t)\n\tseedRunWithContainer(t, store, mgr, \"run-pdnb1\", \"develop\", \"/home/user/alpha\", \"cid-pdnb1\", false)\n\n\treq := httptest.NewRequest(\"GET\", \"/projects/alpha\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody := w.Body.String()\n\tassert.NotContains(t, body, `id=\"delete-containers-btn\"`)\n}\n\nfunc TestAPIProjects_HealthNoRuns(t *testing.T) {\n\th, _ := setupHandler(t)\n\n\treq := httptest.NewRequest(\"GET\", \"/api/projects\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\tassert.Equal(t, http.StatusOK, w.Code)\n\n\t// No projects means empty array\n\ttype project struct {\n\t\tDir   string `json:\"dir\"`\n\t\tLabel string `json:\"label\"`\n\t}","numLines":130,"startLine":1220,"totalLines":1872}}}
