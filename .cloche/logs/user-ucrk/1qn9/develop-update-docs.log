{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01B52bi2eC6UUHfsy1V9ZEAc","type":"tool_result","content":"     1→{{define \"content\"}}\n     2→<h1><a href=\"/\">Projects</a> / {{.Label}}</h1>\n     3→\n     4→<div class=\"run-history\" style=\"margin-bottom:1rem\">\n     5→    {{range .RecentRuns}}\n     6→    <a href=\"/runs/{{.ID}}\"><span class=\"run-dot run-dot-{{.State}}\" title=\"{{.ID}}: {{.State}}\"></span></a>\n     7→    {{end}}\n     8→    <a href=\"/projects/{{.Label}}/runs\" class=\"btn btn-secondary btn-sm\" style=\"margin-left:0.5rem\">View all runs</a>\n     9→    {{if .ContainerCount}}\n    10→    <button class=\"btn btn-danger btn-sm\" id=\"delete-containers-btn\" onclick=\"deleteAllContainers()\" style=\"margin-left:0.5rem\">Delete {{.ContainerCount}} container{{if gt .ContainerCount 1}}s{{end}}</button>\n    11→    {{end}}\n    12→</div>\n    13→\n    14→<!-- Panel 1: Project Info -->\n    15→<div class=\"panel\" id=\"info-panel\">\n    16→    <div class=\"panel-header\">Project Info</div>\n    17→    <div class=\"panel-body\" id=\"project-info\">Loading...</div>\n    18→</div>\n    19→\n    20→<!-- Panel 3: Workflow View -->\n    21→<div class=\"panel\" id=\"workflow-panel\">\n    22→    <div class=\"panel-header\">Workflows</div>\n    23→    <div class=\"panel-body\">\n    24→        <div id=\"location-tabs\" class=\"tab-bar\"></div>\n    25→        <div id=\"workflow-tabs\" class=\"tab-bar\"></div>\n    26→        <div id=\"workflow-dag\"></div>\n    27→    </div>\n    28→</div>\n    29→\n    30→<!-- Step Drawer -->\n    31→<div class=\"drawer\" id=\"step-drawer\">\n    32→    <div class=\"drawer-header\">\n    33→        <span id=\"drawer-title\"></span>\n    34→        <button class=\"drawer-close\" onclick=\"closeDrawer()\">&times;</button>\n    35→    </div>\n    36→    <div class=\"drawer-body\" id=\"drawer-body\"></div>\n    37→</div>\n    38→{{end}}\n    39→\n    40→{{define \"scripts\"}}\n    41→<script>\n    42→var projectLabel = {{.Label}};\n    43→\n    44→function loadProjectInfo() {\n    45→    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/info')\n    46→        .then(function(r) { return r.json(); })\n    47→        .then(function(data) {\n    48→            var html = '<dl class=\"run-meta\" style=\"margin:0\">';\n    49→            html += '<dt>Docker Image</dt><dd class=\"mono\">' + (data.docker_image || 'N/A') + '</dd>';\n    50→            html += '<dt>Version</dt><dd>' + (data.version ? 'v' + data.version : 'N/A') + '</dd>';\n    51→            html += '</dl>';\n    52→\n    53→            if (data.prompt_files && data.prompt_files.length > 0) {\n    54→                html += '<h2 style=\"margin-top:1rem\">Prompt Files</h2>';\n    55→                data.prompt_files.forEach(function(pf) {\n    56→                    html += '<details><summary class=\"mono\">' + pf.path + '</summary>';\n    57→                    if (pf.content) {\n    58→                        html += '<pre class=\"diff-block\">' + pf.content.replace(/&/g,'&amp;').replace(/</g,'&lt;') + '</pre>';\n    59→                    } else {\n    60→                        html += '<p style=\"color:var(--text-muted);font-size:0.85rem\">Empty file</p>';\n    61→                    }\n    62→                    html += '</details>';\n    63→                });\n    64→            }\n    65→\n    66→            document.getElementById('project-info').innerHTML = html;\n    67→        });\n    68→}\n    69→\n    70→function toggleDiff(el) {\n    71→    var existing = el.nextElementSibling;\n    72→    if (existing && existing.classList.contains('diff-block')) {\n    73→        existing.remove();\n    74→        return;\n    75→    }\n    76→    var file = el.getAttribute('data-file');\n    77→    var sha = el.getAttribute('data-sha');\n    78→    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/info/prompt-diff?file=' + encodeURIComponent(file) + '&sha=' + encodeURIComponent(sha))\n    79→        .then(function(r) { return r.text(); })\n    80→        .then(function(text) {\n    81→            var pre = document.createElement('pre');\n    82→            pre.className = 'diff-block';\n    83→            pre.textContent = text || '(no diff available)';\n    84→            el.parentNode.insertBefore(pre, el.nextSibling);\n    85→        });\n    86→}\n    87→\n    88→var workflowsData = [];\n    89→var activeLocation = 'container';\n    90→\n    91→function loadWorkflows() {\n    92→    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/workflows')\n    93→        .then(function(r) { return r.json(); })\n    94→        .then(function(data) {\n    95→            workflowsData = data || [];\n    96→            if (workflowsData.length === 0) {\n    97→                document.getElementById('workflow-dag').innerHTML = '<p class=\"empty\">No workflows found</p>';\n    98→                return;\n    99→            }\n   100→\n   101→            // Check which locations exist\n   102→            var hasContainer = workflowsData.some(function(wf) { return wf.location === 'container'; });\n   103→            var hasHost = workflowsData.some(function(wf) { return wf.location === 'host'; });\n   104→\n   105→            // Render location tabs if both types exist\n   106→            var locationTabs = document.getElementById('location-tabs');\n   107→            if (hasContainer && hasHost) {\n   108→                var html = '';\n   109→                html += '<button class=\"tab-btn tab-active\" onclick=\"switchLocation(\\'container\\')\">Container</button>';\n   110→                html += '<button class=\"tab-btn\" onclick=\"switchLocation(\\'host\\')\">Host</button>';\n   111→                locationTabs.innerHTML = html;\n   112→            } else {\n   113→                locationTabs.innerHTML = '';\n   114→            }\n   115→\n   116→            // Default to whichever location exists\n   117→            activeLocation = hasContainer ? 'container' : 'host';\n   118→            renderWorkflowTabs();\n   119→        });\n   120→}\n   121→\n   122→function switchLocation(loc) {\n   123→    activeLocation = loc;\n   124→    var btns = document.querySelectorAll('#location-tabs .tab-btn');\n   125→    btns.forEach(function(b) {\n   126→        b.classList.toggle('tab-active', b.textContent === (loc === 'container' ? 'Container' : 'Host'));\n   127→    });\n   128→    renderWorkflowTabs();\n   129→}\n   130→\n   131→function renderWorkflowTabs() {\n   132→    var filtered = workflowsData.filter(function(wf) { return wf.location === activeLocation; });\n   133→    var tabs = document.getElementById('workflow-tabs');\n   134→\n   135→    if (filtered.length === 0) {\n   136→        tabs.innerHTML = '';\n   137→        document.getElementById('workflow-dag').innerHTML = '<p class=\"empty\">No ' + activeLocation + ' workflows found</p>';\n   138→        return;\n   139→    }\n   140→\n   141→    if (filtered.length > 1) {\n   142→        var html = '';\n   143→        filtered.forEach(function(wf, i) {\n   144→            html += '<button class=\"tab-btn' + (i === 0 ? ' tab-active' : '') + '\" onclick=\"showFilteredWorkflow(' + i + ')\">' + wf.name + '</button>';\n   145→        });\n   146→        tabs.innerHTML = html;\n   147→    } else {\n   148→        tabs.innerHTML = '';\n   149→    }\n   150→    showFilteredWorkflow(0);\n   151→}\n   152→\n   153→function showFilteredWorkflow(idx) {\n   154→    var filtered = workflowsData.filter(function(wf) { return wf.location === activeLocation; });\n   155→    var btns = document.querySelectorAll('#workflow-tabs .tab-btn');\n   156→    btns.forEach(function(b, i) { b.classList.toggle('tab-active', i === idx); });\n   157→    showWorkflow(filtered[idx]);\n   158→}\n   159→\n   160→function showWorkflow(wf) {\n   161→    var dagEl = document.getElementById('workflow-dag');\n   162→\n   163→    // Build step order via topological sort from entry\n   164→    var ordered = [];\n   165→    var visited = {};\n   166→    function visit(name) {\n   167→        if (visited[name] || name === 'done' || name === 'abort') return;\n   168→        visited[name] = true;\n   169→        ordered.push(name);\n   170→        wf.wires.forEach(function(wire) {\n   171→            if (wire.from === name) visit(wire.to);\n   172→        });\n   173→    }\n   174→    if (wf.entry_step) visit(wf.entry_step);\n   175→    // Add any unvisited steps\n   176→    wf.steps.forEach(function(s) { if (!visited[s.name]) { ordered.push(s.name); visited[s.name] = true; } });\n   177→\n   178→    // Collect terminal targets\n   179→    var terminals = {};\n   180→    wf.wires.forEach(function(wire) {\n   181→        if (wire.to === 'done' || wire.to === 'abort') terminals[wire.to] = true;\n   182→    });\n   183→\n   184→    var stepMap = {};\n   185→    wf.steps.forEach(function(s) { stepMap[s.name] = s; });\n   186→\n   187→    var nodeH = 48, nodeW = 180, gapY = 24, gapX = 40, padTop = 20, padLeft = 30;\n   188→\n   189→    // Assign positions\n   190→    var positions = {};\n   191→    ordered.forEach(function(name, i) {\n   192→        positions[name] = {x: padLeft, y: padTop + i * (nodeH + gapY)};\n   193→    });\n   194→    var termIdx = ordered.length;\n   195→    for (var t in terminals) {\n   196→        positions[t] = {x: padLeft, y: padTop + termIdx * (nodeH + gapY)};\n   197→        termIdx++;\n   198→    }\n   199→\n   200→    var totalH = padTop + termIdx * (nodeH + gapY) + 10;\n   201→    var totalW = padLeft + nodeW + gapX + 80;\n   202→\n   203→    var html = '<svg class=\"dag-svg\" width=\"' + totalW + '\" height=\"' + totalH + '\">';\n   204→    html += '<defs><marker id=\"arrowhead\" markerWidth=\"8\" markerHeight=\"6\" refX=\"8\" refY=\"3\" orient=\"auto\"><polygon points=\"0 0, 8 3, 0 6\" fill=\"var(--text-muted)\"/></marker></defs>';\n   205→\n   206→    // Draw wires\n   207→    wf.wires.forEach(function(wire) {\n   208→        var from = positions[wire.from];\n   209→        var to = positions[wire.to];\n   210→        if (!from || !to) return;\n   211→        var x1 = from.x + nodeW;\n   212→        var y1 = from.y + nodeH / 2;\n   213→        var x2 = to.x;\n   214→        var y2 = to.y + nodeH / 2;\n   215→        var cx = x1 + gapX / 2;\n   216→        html += '<path d=\"M' + x1 + ' ' + y1 + ' C' + cx + ' ' + y1 + ' ' + cx + ' ' + y2 + ' ' + x2 + ' ' + y2 + '\" class=\"dag-edge\" marker-end=\"url(#arrowhead)\"/>';\n   217→        var lx = (x1 + x2) / 2, ly = (y1 + y2) / 2 - 6;\n   218→        html += '<text x=\"' + lx + '\" y=\"' + ly + '\" class=\"dag-edge-label\">' + wire.result + '</text>';\n   219→    });\n   220→\n   221→    // Draw step nodes\n   222→    ordered.forEach(function(name) {\n   223→        var pos = positions[name];\n   224→        var s = stepMap[name];\n   225→        var icon = '\\u{1F4DC}';\n   226→        if (s) {\n   227→            if (s.type === 'agent') icon = '\\u{1F916}';\n   228→            else if (s.type === 'workflow') icon = '\\u{1F501}';\n   229→        }\n   230→        html += '<g class=\"dag-node\" onclick=\"openDrawer(\\'' + wf.name + '\\',\\'' + name + '\\')\" style=\"cursor:pointer\">';\n   231→        html += '<rect x=\"' + pos.x + '\" y=\"' + pos.y + '\" width=\"' + nodeW + '\" height=\"' + nodeH + '\" class=\"dag-node-rect\"/>';\n   232→        html += '<text x=\"' + (pos.x + 10) + '\" y=\"' + (pos.y + nodeH / 2 + 5) + '\" class=\"dag-node-text\">' + icon + ' ' + name + '</text>';\n   233→        html += '</g>';\n   234→    });\n   235→\n   236→    // Draw terminal nodes\n   237→    for (var t in terminals) {\n   238→        var pos = positions[t];\n   239→        var cls = t === 'done' ? 'dag-terminal-done' : 'dag-terminal-abort';\n   240→        html += '<rect x=\"' + pos.x + '\" y=\"' + pos.y + '\" width=\"' + nodeW + '\" height=\"' + nodeH + '\" class=\"dag-node-rect ' + cls + '\" rx=\"20\"/>';\n   241→        html += '<text x=\"' + (pos.x + nodeW / 2) + '\" y=\"' + (pos.y + nodeH / 2 + 5) + '\" class=\"dag-node-text\" text-anchor=\"middle\">' + t + '</text>';\n   242→    }\n   243→\n   244→    html += '</svg>';\n   245→    dagEl.innerHTML = html;\n   246→}\n   247→\n   248→function openDrawer(workflowName, stepName) {\n   249→    var wf = workflowsData.find(function(w) { return w.name === workflowName; });\n   250→    if (!wf) return;\n   251→    var step = wf.steps.find(function(s) { return s.name === stepName; });\n   252→    if (!step) return;\n   253→\n   254→    document.getElementById('drawer-title').textContent = stepName;\n   255→    var body = '<dl class=\"run-meta\">';\n   256→    body += '<dt>Type</dt><dd>' + step.type + '</dd>';\n   257→    body += '<dt>Results</dt><dd>' + (step.results ? step.results.join(', ') : 'none') + '</dd>';\n   258→    if (step.config) {\n   259→        for (var k in step.config) {\n   260→            if (k === 'max_attempts' || k === 'prompt' || k === 'command' || k === 'script' || k === 'run' || k === 'workflow_name') {\n   261→                body += '<dt>' + k + '</dt><dd class=\"mono\">' + step.config[k] + '</dd>';\n   262→            }\n   263→        }\n   264→    }\n   265→    body += '</dl>';\n   266→    body += '<div id=\"drawer-content\"><p style=\"color:var(--text-muted)\">Loading content...</p></div>';\n   267→\n   268→    document.getElementById('drawer-body').innerHTML = body;\n   269→    document.getElementById('step-drawer').classList.add('drawer-open');\n   270→\n   271→    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/workflows/' + encodeURIComponent(workflowName) + '/steps/' + encodeURIComponent(stepName) + '/content')\n   272→        .then(function(r) { if (r.ok) return r.text(); return ''; })\n   273→        .then(function(text) {\n   274→            var el = document.getElementById('drawer-content');\n   275→            if (text) {\n   276→                el.innerHTML = '<pre>' + text.replace(/&/g,'&amp;').replace(/</g,'&lt;') + '</pre>';\n   277→            } else {\n   278→                el.innerHTML = '<p style=\"color:var(--text-muted)\">No content available</p>';\n   279→            }\n   280→        });\n   281→}\n   282→\n   283→function closeDrawer() {\n   284→    document.getElementById('step-drawer').classList.remove('drawer-open');\n   285→}\n   286→\n   287→document.addEventListener('keydown', function(e) {\n   288→    if (e.key === 'Escape') closeDrawer();\n   289→});\n   290→\n   291→window.deleteAllContainers = function() {\n   292→    var btn = document.getElementById('delete-containers-btn');\n   293→    if (btn) btn.disabled = true;\n   294→    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/containers', { method: 'DELETE' })\n   295→        .then(function(r) { return r.json(); })\n   296→        .then(function(data) {\n   297→            if (btn) {\n   298→                btn.textContent = 'Deleted ' + (data.deleted || 0) + ' container' + (data.deleted !== 1 ? 's' : '');\n   299→                btn.classList.remove('btn-danger');\n   300→                btn.classList.add('btn-secondary');\n   301→            }\n   302→        })\n   303→        .catch(function() {\n   304→            if (btn) {\n   305→                btn.textContent = 'Delete failed';\n   306→                btn.disabled = false;\n   307→            }\n   308→        });\n   309→};\n   310→\n   311→// Load all panels\n   312→loadProjectInfo();\n   313→loadWorkflows();\n   314→</script>\n   315→{{end}}\n   316→"}]},"parent_tool_use_id":null,"session_id":"eb5b89a2-592e-4901-8f1a-c9ee80f3d68e","uuid":"7c1d9386-be40-4056-b5ba-446e3c7bfcb6","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/web/templates/project_detail.html","content":"{{define \"content\"}}\n<h1><a href=\"/\">Projects</a> / {{.Label}}</h1>\n\n<div class=\"run-history\" style=\"margin-bottom:1rem\">\n    {{range .RecentRuns}}\n    <a href=\"/runs/{{.ID}}\"><span class=\"run-dot run-dot-{{.State}}\" title=\"{{.ID}}: {{.State}}\"></span></a>\n    {{end}}\n    <a href=\"/projects/{{.Label}}/runs\" class=\"btn btn-secondary btn-sm\" style=\"margin-left:0.5rem\">View all runs</a>\n    {{if .ContainerCount}}\n    <button class=\"btn btn-danger btn-sm\" id=\"delete-containers-btn\" onclick=\"deleteAllContainers()\" style=\"margin-left:0.5rem\">Delete {{.ContainerCount}} container{{if gt .ContainerCount 1}}s{{end}}</button>\n    {{end}}\n</div>\n\n<!-- Panel 1: Project Info -->\n<div class=\"panel\" id=\"info-panel\">\n    <div class=\"panel-header\">Project Info</div>\n    <div class=\"panel-body\" id=\"project-info\">Loading...</div>\n</div>\n\n<!-- Panel 3: Workflow View -->\n<div class=\"panel\" id=\"workflow-panel\">\n    <div class=\"panel-header\">Workflows</div>\n    <div class=\"panel-body\">\n        <div id=\"location-tabs\" class=\"tab-bar\"></div>\n        <div id=\"workflow-tabs\" class=\"tab-bar\"></div>\n        <div id=\"workflow-dag\"></div>\n    </div>\n</div>\n\n<!-- Step Drawer -->\n<div class=\"drawer\" id=\"step-drawer\">\n    <div class=\"drawer-header\">\n        <span id=\"drawer-title\"></span>\n        <button class=\"drawer-close\" onclick=\"closeDrawer()\">&times;</button>\n    </div>\n    <div class=\"drawer-body\" id=\"drawer-body\"></div>\n</div>\n{{end}}\n\n{{define \"scripts\"}}\n<script>\nvar projectLabel = {{.Label}};\n\nfunction loadProjectInfo() {\n    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/info')\n        .then(function(r) { return r.json(); })\n        .then(function(data) {\n            var html = '<dl class=\"run-meta\" style=\"margin:0\">';\n            html += '<dt>Docker Image</dt><dd class=\"mono\">' + (data.docker_image || 'N/A') + '</dd>';\n            html += '<dt>Version</dt><dd>' + (data.version ? 'v' + data.version : 'N/A') + '</dd>';\n            html += '</dl>';\n\n            if (data.prompt_files && data.prompt_files.length > 0) {\n                html += '<h2 style=\"margin-top:1rem\">Prompt Files</h2>';\n                data.prompt_files.forEach(function(pf) {\n                    html += '<details><summary class=\"mono\">' + pf.path + '</summary>';\n                    if (pf.content) {\n                        html += '<pre class=\"diff-block\">' + pf.content.replace(/&/g,'&amp;').replace(/</g,'&lt;') + '</pre>';\n                    } else {\n                        html += '<p style=\"color:var(--text-muted);font-size:0.85rem\">Empty file</p>';\n                    }\n                    html += '</details>';\n                });\n            }\n\n            document.getElementById('project-info').innerHTML = html;\n        });\n}\n\nfunction toggleDiff(el) {\n    var existing = el.nextElementSibling;\n    if (existing && existing.classList.contains('diff-block')) {\n        existing.remove();\n        return;\n    }\n    var file = el.getAttribute('data-file');\n    var sha = el.getAttribute('data-sha');\n    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/info/prompt-diff?file=' + encodeURIComponent(file) + '&sha=' + encodeURIComponent(sha))\n        .then(function(r) { return r.text(); })\n        .then(function(text) {\n            var pre = document.createElement('pre');\n            pre.className = 'diff-block';\n            pre.textContent = text || '(no diff available)';\n            el.parentNode.insertBefore(pre, el.nextSibling);\n        });\n}\n\nvar workflowsData = [];\nvar activeLocation = 'container';\n\nfunction loadWorkflows() {\n    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/workflows')\n        .then(function(r) { return r.json(); })\n        .then(function(data) {\n            workflowsData = data || [];\n            if (workflowsData.length === 0) {\n                document.getElementById('workflow-dag').innerHTML = '<p class=\"empty\">No workflows found</p>';\n                return;\n            }\n\n            // Check which locations exist\n            var hasContainer = workflowsData.some(function(wf) { return wf.location === 'container'; });\n            var hasHost = workflowsData.some(function(wf) { return wf.location === 'host'; });\n\n            // Render location tabs if both types exist\n            var locationTabs = document.getElementById('location-tabs');\n            if (hasContainer && hasHost) {\n                var html = '';\n                html += '<button class=\"tab-btn tab-active\" onclick=\"switchLocation(\\'container\\')\">Container</button>';\n                html += '<button class=\"tab-btn\" onclick=\"switchLocation(\\'host\\')\">Host</button>';\n                locationTabs.innerHTML = html;\n            } else {\n                locationTabs.innerHTML = '';\n            }\n\n            // Default to whichever location exists\n            activeLocation = hasContainer ? 'container' : 'host';\n            renderWorkflowTabs();\n        });\n}\n\nfunction switchLocation(loc) {\n    activeLocation = loc;\n    var btns = document.querySelectorAll('#location-tabs .tab-btn');\n    btns.forEach(function(b) {\n        b.classList.toggle('tab-active', b.textContent === (loc === 'container' ? 'Container' : 'Host'));\n    });\n    renderWorkflowTabs();\n}\n\nfunction renderWorkflowTabs() {\n    var filtered = workflowsData.filter(function(wf) { return wf.location === activeLocation; });\n    var tabs = document.getElementById('workflow-tabs');\n\n    if (filtered.length === 0) {\n        tabs.innerHTML = '';\n        document.getElementById('workflow-dag').innerHTML = '<p class=\"empty\">No ' + activeLocation + ' workflows found</p>';\n        return;\n    }\n\n    if (filtered.length > 1) {\n        var html = '';\n        filtered.forEach(function(wf, i) {\n            html += '<button class=\"tab-btn' + (i === 0 ? ' tab-active' : '') + '\" onclick=\"showFilteredWorkflow(' + i + ')\">' + wf.name + '</button>';\n        });\n        tabs.innerHTML = html;\n    } else {\n        tabs.innerHTML = '';\n    }\n    showFilteredWorkflow(0);\n}\n\nfunction showFilteredWorkflow(idx) {\n    var filtered = workflowsData.filter(function(wf) { return wf.location === activeLocation; });\n    var btns = document.querySelectorAll('#workflow-tabs .tab-btn');\n    btns.forEach(function(b, i) { b.classList.toggle('tab-active', i === idx); });\n    showWorkflow(filtered[idx]);\n}\n\nfunction showWorkflow(wf) {\n    var dagEl = document.getElementById('workflow-dag');\n\n    // Build step order via topological sort from entry\n    var ordered = [];\n    var visited = {};\n    function visit(name) {\n        if (visited[name] || name === 'done' || name === 'abort') return;\n        visited[name] = true;\n        ordered.push(name);\n        wf.wires.forEach(function(wire) {\n            if (wire.from === name) visit(wire.to);\n        });\n    }\n    if (wf.entry_step) visit(wf.entry_step);\n    // Add any unvisited steps\n    wf.steps.forEach(function(s) { if (!visited[s.name]) { ordered.push(s.name); visited[s.name] = true; } });\n\n    // Collect terminal targets\n    var terminals = {};\n    wf.wires.forEach(function(wire) {\n        if (wire.to === 'done' || wire.to === 'abort') terminals[wire.to] = true;\n    });\n\n    var stepMap = {};\n    wf.steps.forEach(function(s) { stepMap[s.name] = s; });\n\n    var nodeH = 48, nodeW = 180, gapY = 24, gapX = 40, padTop = 20, padLeft = 30;\n\n    // Assign positions\n    var positions = {};\n    ordered.forEach(function(name, i) {\n        positions[name] = {x: padLeft, y: padTop + i * (nodeH + gapY)};\n    });\n    var termIdx = ordered.length;\n    for (var t in terminals) {\n        positions[t] = {x: padLeft, y: padTop + termIdx * (nodeH + gapY)};\n        termIdx++;\n    }\n\n    var totalH = padTop + termIdx * (nodeH + gapY) + 10;\n    var totalW = padLeft + nodeW + gapX + 80;\n\n    var html = '<svg class=\"dag-svg\" width=\"' + totalW + '\" height=\"' + totalH + '\">';\n    html += '<defs><marker id=\"arrowhead\" markerWidth=\"8\" markerHeight=\"6\" refX=\"8\" refY=\"3\" orient=\"auto\"><polygon points=\"0 0, 8 3, 0 6\" fill=\"var(--text-muted)\"/></marker></defs>';\n\n    // Draw wires\n    wf.wires.forEach(function(wire) {\n        var from = positions[wire.from];\n        var to = positions[wire.to];\n        if (!from || !to) return;\n        var x1 = from.x + nodeW;\n        var y1 = from.y + nodeH / 2;\n        var x2 = to.x;\n        var y2 = to.y + nodeH / 2;\n        var cx = x1 + gapX / 2;\n        html += '<path d=\"M' + x1 + ' ' + y1 + ' C' + cx + ' ' + y1 + ' ' + cx + ' ' + y2 + ' ' + x2 + ' ' + y2 + '\" class=\"dag-edge\" marker-end=\"url(#arrowhead)\"/>';\n        var lx = (x1 + x2) / 2, ly = (y1 + y2) / 2 - 6;\n        html += '<text x=\"' + lx + '\" y=\"' + ly + '\" class=\"dag-edge-label\">' + wire.result + '</text>';\n    });\n\n    // Draw step nodes\n    ordered.forEach(function(name) {\n        var pos = positions[name];\n        var s = stepMap[name];\n        var icon = '\\u{1F4DC}';\n        if (s) {\n            if (s.type === 'agent') icon = '\\u{1F916}';\n            else if (s.type === 'workflow') icon = '\\u{1F501}';\n        }\n        html += '<g class=\"dag-node\" onclick=\"openDrawer(\\'' + wf.name + '\\',\\'' + name + '\\')\" style=\"cursor:pointer\">';\n        html += '<rect x=\"' + pos.x + '\" y=\"' + pos.y + '\" width=\"' + nodeW + '\" height=\"' + nodeH + '\" class=\"dag-node-rect\"/>';\n        html += '<text x=\"' + (pos.x + 10) + '\" y=\"' + (pos.y + nodeH / 2 + 5) + '\" class=\"dag-node-text\">' + icon + ' ' + name + '</text>';\n        html += '</g>';\n    });\n\n    // Draw terminal nodes\n    for (var t in terminals) {\n        var pos = positions[t];\n        var cls = t === 'done' ? 'dag-terminal-done' : 'dag-terminal-abort';\n        html += '<rect x=\"' + pos.x + '\" y=\"' + pos.y + '\" width=\"' + nodeW + '\" height=\"' + nodeH + '\" class=\"dag-node-rect ' + cls + '\" rx=\"20\"/>';\n        html += '<text x=\"' + (pos.x + nodeW / 2) + '\" y=\"' + (pos.y + nodeH / 2 + 5) + '\" class=\"dag-node-text\" text-anchor=\"middle\">' + t + '</text>';\n    }\n\n    html += '</svg>';\n    dagEl.innerHTML = html;\n}\n\nfunction openDrawer(workflowName, stepName) {\n    var wf = workflowsData.find(function(w) { return w.name === workflowName; });\n    if (!wf) return;\n    var step = wf.steps.find(function(s) { return s.name === stepName; });\n    if (!step) return;\n\n    document.getElementById('drawer-title').textContent = stepName;\n    var body = '<dl class=\"run-meta\">';\n    body += '<dt>Type</dt><dd>' + step.type + '</dd>';\n    body += '<dt>Results</dt><dd>' + (step.results ? step.results.join(', ') : 'none') + '</dd>';\n    if (step.config) {\n        for (var k in step.config) {\n            if (k === 'max_attempts' || k === 'prompt' || k === 'command' || k === 'script' || k === 'run' || k === 'workflow_name') {\n                body += '<dt>' + k + '</dt><dd class=\"mono\">' + step.config[k] + '</dd>';\n            }\n        }\n    }\n    body += '</dl>';\n    body += '<div id=\"drawer-content\"><p style=\"color:var(--text-muted)\">Loading content...</p></div>';\n\n    document.getElementById('drawer-body').innerHTML = body;\n    document.getElementById('step-drawer').classList.add('drawer-open');\n\n    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/workflows/' + encodeURIComponent(workflowName) + '/steps/' + encodeURIComponent(stepName) + '/content')\n        .then(function(r) { if (r.ok) return r.text(); return ''; })\n        .then(function(text) {\n            var el = document.getElementById('drawer-content');\n            if (text) {\n                el.innerHTML = '<pre>' + text.replace(/&/g,'&amp;').replace(/</g,'&lt;') + '</pre>';\n            } else {\n                el.innerHTML = '<p style=\"color:var(--text-muted)\">No content available</p>';\n            }\n        });\n}\n\nfunction closeDrawer() {\n    document.getElementById('step-drawer').classList.remove('drawer-open');\n}\n\ndocument.addEventListener('keydown', function(e) {\n    if (e.key === 'Escape') closeDrawer();\n});\n\nwindow.deleteAllContainers = function() {\n    var btn = document.getElementById('delete-containers-btn');\n    if (btn) btn.disabled = true;\n    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/containers', { method: 'DELETE' })\n        .then(function(r) { return r.json(); })\n        .then(function(data) {\n            if (btn) {\n                btn.textContent = 'Deleted ' + (data.deleted || 0) + ' container' + (data.deleted !== 1 ? 's' : '');\n                btn.classList.remove('btn-danger');\n                btn.classList.add('btn-secondary');\n            }\n        })\n        .catch(function() {\n            if (btn) {\n                btn.textContent = 'Delete failed';\n                btn.disabled = false;\n            }\n        });\n};\n\n// Load all panels\nloadProjectInfo();\nloadWorkflows();\n</script>\n{{end}}\n","numLines":316,"startLine":1,"totalLines":316}}}
