leAPIWorkflows)\n   138→\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows/{workflow}/steps/{step}/content\", h.handleAPIStepContent)\n   139→\th.mux.HandleFunc(\"GET /api/runs/{id}/stream\", h.handleAPIStream)\n   140→\th.mux.Handle(\"GET /static/\", http.StripPrefix(\"/static/\", http.FileServerFS(staticFS)))\n   141→\n   142→\treturn h, nil\n   143→}\n   144→\n   145→func (h *Handler) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n   146→\th.mux.ServeHTTP(w, r)\n   147→}\n   148→\n   149→// --- HTML handlers ---\n   150→\n   151→// projectOverviewEntry holds data for a single project card on the landing page.\n   152→type projectOverviewEntry struct {\n   153→\tDir         string\n   154→\tLabel       string\n   155→\tHealth      domain.HealthResult\n   156→\tRecentRuns  []recentRunDot\n   157→\tActiveCount int\n   158→}\n   159→"}]},"parent_tool_use_id":"toolu_01BPmWkiCP2StYpJuZzrB4mc","session_id":"04c57cbe-a919-4819-8178-dae3046f6f43","uuid":"4988f61f-16e6-4101-90d7-79136eee2fa9"}
