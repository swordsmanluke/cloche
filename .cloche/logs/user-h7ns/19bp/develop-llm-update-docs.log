{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VMJA9futBnz2QtWuZ3xSos","type":"tool_result","content":"     1â†’{{define \"content\"}}\n     2â†’<h1><a href=\"/\">Projects</a> / {{.Label}}</h1>\n     3â†’\n     4â†’<div class=\"run-history\" style=\"margin-bottom:1rem\">\n     5â†’    {{range .RecentRuns}}\n     6â†’    <a href=\"/runs/{{.ID}}\"><span class=\"run-dot run-dot-{{.State}}\" title=\"{{.ID}}: {{.State}}\"></span></a>\n     7â†’    {{end}}\n     8â†’    <a href=\"/runs?project={{.Dir}}\" class=\"btn btn-secondary btn-sm\" style=\"margin-left:0.5rem\">View all runs</a>\n     9â†’</div>\n    10â†’\n    11â†’<!-- Panel 1: Orchestrator Control -->\n    12â†’<div class=\"panel\" id=\"orchestrator-panel\">\n    13â†’    <div class=\"panel-header\">Orchestrator Control</div>\n    14â†’    <div class=\"panel-body\">\n    15â†’        <div id=\"orch-status\" class=\"orch-status\">Loading...</div>\n    16â†’        <div class=\"orch-controls\" style=\"margin-top:0.75rem;display:flex;gap:0.5rem;align-items:center;flex-wrap:wrap\">\n    17â†’            <button id=\"orch-toggle\" class=\"btn btn-primary btn-sm\" onclick=\"toggleOrchestrator()\">Enable</button>\n    18â†’            <span style=\"margin-left:1rem;color:var(--text-muted);font-size:0.85rem\">Concurrency:</span>\n    19â†’            <input type=\"number\" id=\"orch-concurrency\" min=\"1\" max=\"20\" value=\"1\" style=\"width:60px;padding:0.2em 0.4em;border:1px solid var(--border);border-radius:var(--radius);background:var(--bg);color:var(--text);font-size:0.85rem\">\n    20â†’            <button class=\"btn btn-secondary btn-sm\" onclick=\"applyConcurrency()\">Apply</button>\n    21â†’        </div>\n    22â†’    </div>\n    23â†’</div>\n    24â†’\n    25â†’<!-- Panel 2: Project Info -->\n    26â†’<div class=\"panel\" id=\"info-panel\">\n    27â†’    <div class=\"panel-header\">Project Info</div>\n    28â†’    <div class=\"panel-body\" id=\"project-info\">Loading...</div>\n    29â†’</div>\n    30â†’\n    31â†’<!-- Panel 3: Workflow View -->\n    32â†’<div class=\"panel\" id=\"workflow-panel\">\n    33â†’    <div class=\"panel-header\">Workflows</div>\n    34â†’    <div class=\"panel-body\">\n    35â†’        <div id=\"workflow-tabs\" class=\"tab-bar\"></div>\n    36â†’        <div id=\"workflow-dag\"></div>\n    37â†’    </div>\n    38â†’</div>\n    39â†’\n    40â†’<!-- Step Drawer -->\n    41â†’<div class=\"drawer\" id=\"step-drawer\">\n    42â†’    <div class=\"drawer-header\">\n    43â†’        <span id=\"drawer-title\"></span>\n    44â†’        <button class=\"drawer-close\" onclick=\"closeDrawer()\">&times;</button>\n    45â†’    </div>\n    46â†’    <div class=\"drawer-body\" id=\"drawer-body\"></div>\n    47â†’</div>\n    48â†’{{end}}\n    49â†’\n    50â†’{{define \"scripts\"}}\n    51â†’<script>\n    52â†’var projectLabel = {{.Label}};\n    53â†’var orchEnabled = false;\n    54â†’\n    55â†’function loadOrchestratorStatus() {\n    56â†’    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/orchestrator')\n    57â†’        .then(function(r) { return r.json(); })\n    58â†’        .then(function(data) {\n    59â†’            orchEnabled = data.enabled;\n    60â†’            var statusEl = document.getElementById('orch-status');\n    61â†’            var toggleBtn = document.getElementById('orch-toggle');\n    62â†’            var concInput = document.getElementById('orch-concurrency');\n    63â†’            statusEl.innerHTML = '<span class=\"badge ' + (data.enabled ? 'badge-succeeded' : 'badge-stopped') + '\">' +\n    64â†’                (data.enabled ? 'Enabled' : 'Disabled') + '</span>' +\n    65â†’                '&nbsp; In-flight: <strong>' + data.in_flight + '</strong>' +\n    66â†’                '&nbsp; Concurrency: <strong>' + data.concurrency + '</strong>';\n    67â†’            toggleBtn.textContent = data.enabled ? 'Disable' : 'Enable';\n    68â†’            toggleBtn.className = 'btn btn-sm ' + (data.enabled ? 'btn-danger' : 'btn-primary');\n    69â†’            concInput.value = data.concurrency;\n    70â†’        });\n    71â†’}\n    72â†’\n    73â†’function toggleOrchestrator() {\n    74â†’    var action = orchEnabled ? 'stop' : 'start';\n    75â†’    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/orchestrator/' + action, {method: 'POST'})\n    76â†’        .then(function() { loadOrchestratorStatus(); });\n    77â†’}\n    78â†’\n    79â†’function applyConcurrency() {\n    80â†’    var val = parseInt(document.getElementById('orch-concurrency').value, 10);\n    81â†’    if (val < 1) return;\n    82â†’    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/orchestrator/concurrency', {\n    83â†’        method: 'POST',\n    84â†’        headers: {'Content-Type': 'application/json'},\n    85â†’        body: JSON.stringify({concurrency: val})\n    86â†’    }).then(function() { loadOrchestratorStatus(); });\n    87â†’}\n    88â†’\n    89â†’function loadProjectInfo() {\n    90â†’    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/info')\n    91â†’        .then(function(r) { return r.json(); })\n    92â†’        .then(function(data) {\n    93â†’            var html = '<dl class=\"run-meta\" style=\"margin:0\">';\n    94â†’            html += '<dt>Docker Image</dt><dd class=\"mono\">' + (data.docker_image || 'N/A') + '</dd>';\n    95â†’            html += '<dt>Version</dt><dd>' + (data.version ? 'v' + data.version : 'N/A') + '</dd>';\n    96â†’            html += '</dl>';\n    97â†’\n    98â†’            if (data.prompt_files && data.prompt_files.length > 0) {\n    99â†’                html += '<h2 style=\"margin-top:1rem\">Prompt Files</h2>';\n   100â†’                data.prompt_files.forEach(function(pf) {\n   101â†’                    html += '<details><summary class=\"mono\">' + pf.path + '</summary>';\n   102â†’                    if (pf.history && pf.history.length > 0) {\n   103â†’                        html += '<div style=\"margin:0.5rem 0\">';\n   104â†’                        pf.history.forEach(function(h) {\n   105â†’                            html += '<div class=\"prompt-commit\" data-file=\"' + pf.path + '\" data-sha=\"' + h.sha + '\" onclick=\"toggleDiff(this)\" style=\"cursor:pointer;padding:0.25rem 0;font-size:0.85rem\">';\n   106â†’                            html += '<span class=\"mono\" style=\"color:var(--link)\">' + h.sha + '</span> ';\n   107â†’                            html += '<span style=\"color:var(--text-muted)\">' + h.date + '</span> ';\n   108â†’                            html += h.message;\n   109â†’                            html += '</div>';\n   110â†’                        });\n   111â†’                        html += '</div>';\n   112â†’                    } else {\n   113â†’                        html += '<p style=\"color:var(--text-muted);font-size:0.85rem\">No history</p>';\n   114â†’                    }\n   115â†’                    html += '</details>';\n   116â†’                });\n   117â†’            }\n   118â†’\n   119â†’            document.getElementById('project-info').innerHTML = html;\n   120â†’        });\n   121â†’}\n   122â†’\n   123â†’function toggleDiff(el) {\n   124â†’    var existing = el.nextElementSibling;\n   125â†’    if (existing && existing.classList.contains('diff-block')) {\n   126â†’        existing.remove();\n   127â†’        return;\n   128â†’    }\n   129â†’    var file = el.getAttribute('data-file');\n   130â†’    var sha = el.getAttribute('data-sha');\n   131â†’    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/info/prompt-diff?file=' + encodeURIComponent(file) + '&sha=' + encodeURIComponent(sha))\n   132â†’        .then(function(r) { return r.text(); })\n   133â†’        .then(function(text) {\n   134â†’            var pre = document.createElement('pre');\n   135â†’            pre.className = 'diff-block';\n   136â†’            pre.textContent = text || '(no diff available)';\n   137â†’            el.parentNode.insertBefore(pre, el.nextSibling);\n   138â†’        });\n   139â†’}\n   140â†’\n   141â†’var workflowsData = [];\n   142â†’function loadWorkflows() {\n   143â†’    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/workflows')\n   144â†’        .then(function(r) { return r.json(); })\n   145â†’        .then(function(data) {\n   146â†’            workflowsData = data || [];\n   147â†’            if (workflowsData.length === 0) {\n   148â†’                document.getElementById('workflow-dag').innerHTML = '<p class=\"empty\">No workflows found</p>';\n   149â†’                return;\n   150â†’            }\n   151â†’            var tabs = document.getElementById('workflow-tabs');\n   152â†’            if (workflowsData.length > 1) {\n   153â†’                var html = '';\n   154â†’                workflowsData.forEach(function(wf, i) {\n   155â†’                    html += '<button class=\"tab-btn' + (i === 0 ? ' tab-active' : '') + '\" onclick=\"showWorkflow(' + i + ')\">' + wf.name + '</button>';\n   156â†’                });\n   157â†’                tabs.innerHTML = html;\n   158â†’            }\n   159â†’            showWorkflow(0);\n   160â†’        });\n   161â†’}\n   162â†’\n   163â†’function showWorkflow(idx) {\n   164â†’    var btns = document.querySelectorAll('.tab-btn');\n   165â†’    btns.forEach(function(b, i) { b.classList.toggle('tab-active', i === idx); });\n   166â†’\n   167â†’    var wf = workflowsData[idx];\n   168â†’    var dagEl = document.getElementById('workflow-dag');\n   169â†’\n   170â†’    // Build step order via topological sort from entry\n   171â†’    var ordered = [];\n   172â†’    var visited = {};\n   173â†’    function visit(name) {\n   174â†’        if (visited[name] || name === 'done' || name === 'abort') return;\n   175â†’        visited[name] = true;\n   176â†’        ordered.push(name);\n   177â†’        wf.wires.forEach(function(wire) {\n   178â†’            if (wire.from === name) visit(wire.to);\n   179â†’        });\n   180â†’    }\n   181â†’    if (wf.entry_step) visit(wf.entry_step);\n   182â†’    // Add any unvisited steps\n   183â†’    wf.steps.forEach(function(s) { if (!visited[s.name]) { ordered.push(s.name); visited[s.name] = true; } });\n   184â†’\n   185â†’    // Collect terminal targets\n   186â†’    var terminals = {};\n   187â†’    wf.wires.forEach(function(wire) {\n   188â†’        if (wire.to === 'done' || wire.to === 'abort') terminals[wire.to] = true;\n   189â†’    });\n   190â†’\n   191â†’    var stepMap = {};\n   192â†’    wf.steps.forEach(function(s) { stepMap[s.name] = s; });\n   193â†’\n   194â†’    var nodeH = 48, nodeW = 180, gapY = 24, gapX = 40, padTop = 20, padLeft = 30;\n   195â†’\n   196â†’    // Assign positions\n   197â†’    var positions = {};\n   198â†’    ordered.forEach(function(name, i) {\n   199â†’        positions[name] = {x: padLeft, y: padTop + i * (nodeH + gapY)};\n   200â†’    });\n   201â†’    var termIdx = ordered.length;\n   202â†’    for (var t in terminals) {\n   203â†’        positions[t] = {x: padLeft, y: padTop + termIdx * (nodeH + gapY)};\n   204â†’        termIdx++;\n   205â†’    }\n   206â†’\n   207â†’    var totalH = padTop + termIdx * (nodeH + gapY) + 10;\n   208â†’    var totalW = padLeft + nodeW + gapX + 80;\n   209â†’\n   210â†’    var html = '<svg class=\"dag-svg\" width=\"' + totalW + '\" height=\"' + totalH + '\">';\n   211â†’    html += '<defs><marker id=\"arrowhead\" markerWidth=\"8\" markerHeight=\"6\" refX=\"8\" refY=\"3\" orient=\"auto\"><polygon points=\"0 0, 8 3, 0 6\" fill=\"var(--text-muted)\"/></marker></defs>';\n   212â†’\n   213â†’    // Draw wires\n   214â†’    wf.wires.forEach(function(wire) {\n   215â†’        var from = positions[wire.from];\n   216â†’        var to = positions[wire.to];\n   217â†’        if (!from || !to) return;\n   218â†’        var x1 = from.x + nodeW;\n   219â†’        var y1 = from.y + nodeH / 2;\n   220â†’        var x2 = to.x;\n   221â†’        var y2 = to.y + nodeH / 2;\n   222â†’        var cx = x1 + gapX / 2;\n   223â†’        html += '<path d=\"M' + x1 + ' ' + y1 + ' C' + cx + ' ' + y1 + ' ' + cx + ' ' + y2 + ' ' + x2 + ' ' + y2 + '\" class=\"dag-edge\" marker-end=\"url(#arrowhead)\"/>';\n   224â†’        var lx = (x1 + x2) / 2, ly = (y1 + y2) / 2 - 6;\n   225â†’        html += '<text x=\"' + lx + '\" y=\"' + ly + '\" class=\"dag-edge-label\">' + wire.result + '</text>';\n   226â†’    });\n   227â†’\n   228â†’    // Draw step nodes\n   229â†’    ordered.forEach(function(name) {\n   230â†’        var pos = positions[name];\n   231â†’        var s = stepMap[name];\n   232â†’        var icon = s && s.type === 'agent' ? '\\u{1F916}' : '\\u{1F4DC}';\n   233â†’        html += '<g class=\"dag-node\" onclick=\"openDrawer(\\'' + wf.name + '\\',\\'' + name + '\\')\" style=\"cursor:pointer\">';\n   234â†’        html += '<rect x=\"' + pos.x + '\" y=\"' + pos.y + '\" width=\"' + nodeW + '\" height=\"' + nodeH + '\" class=\"dag-node-rect\"/>';\n   235â†’        html += '<text x=\"' + (pos.x + 10) + '\" y=\"' + (pos.y + nodeH / 2 + 5) + '\" class=\"dag-node-text\">' + icon + ' ' + name + '</text>';\n   236â†’        html += '</g>';\n   237â†’    });\n   238â†’\n   239â†’    // Draw terminal nodes\n   240â†’    for (var t in terminals) {\n   241â†’        var pos = positions[t];\n   242â†’        var cls = t === 'done' ? 'dag-terminal-done' : 'dag-terminal-abort';\n   243â†’        html += '<rect x=\"' + pos.x + '\" y=\"' + pos.y + '\" width=\"' + nodeW + '\" height=\"' + nodeH + '\" class=\"dag-node-rect ' + cls + '\" rx=\"20\"/>';\n   244â†’        html += '<text x=\"' + (pos.x + nodeW / 2) + '\" y=\"' + (pos.y + nodeH / 2 + 5) + '\" class=\"dag-node-text\" text-anchor=\"middle\">' + t + '</text>';\n   245â†’    }\n   246â†’\n   247â†’    html += '</svg>';\n   248â†’    dagEl.innerHTML = html;\n   249â†’}\n   250â†’\n   251â†’function openDrawer(workflowName, stepName) {\n   252â†’    var wf = workflowsData.find(function(w) { return w.name === workflowName; });\n   253â†’    if (!wf) return;\n   254â†’    var step = wf.steps.find(function(s) { return s.name === stepName; });\n   255â†’    if (!step) return;\n   256â†’\n   257â†’    document.getElementById('drawer-title').textContent = stepName;\n   258â†’    var body = '<dl class=\"run-meta\">';\n   259â†’    body += '<dt>Type</dt><dd>' + step.type + '</dd>';\n   260â†’    body += '<dt>Results</dt><dd>' + (step.results ? step.results.join(', ') : 'none') + '</dd>';\n   261â†’    if (step.config) {\n   262â†’        for (var k in step.config) {\n   263â†’            if (k === 'max_attempts' || k === 'prompt' || k === 'run') {\n   264â†’                body += '<dt>' + k + '</dt><dd class=\"mono\">' + step.config[k] + '</dd>';\n   265â†’            }\n   266â†’        }\n   267â†’    }\n   268â†’    body += '</dl>';\n   269â†’    body += '<div id=\"drawer-content\"><p style=\"color:var(--text-muted)\">Loading content...</p></div>';\n   270â†’\n   271â†’    document.getElementById('drawer-body').innerHTML = body;\n   272â†’    document.getElementById('step-drawer').classList.add('drawer-open');\n   273â†’\n   274â†’    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/workflows/' + encodeURIComponent(workflowName) + '/steps/' + encodeURIComponent(stepName) + '/content')\n   275â†’        .then(function(r) { if (r.ok) return r.text(); return ''; })\n   276â†’        .then(function(text) {\n   277â†’            var el = document.getElementById('drawer-content');\n   278â†’            if (text) {\n   279â†’                el.innerHTML = '<pre>' + text.replace(/&/g,'&amp;').replace(/</g,'&lt;') + '</pre>';\n   280â†’            } else {\n   281â†’                el.innerHTML = '<p style=\"color:var(--text-muted)\">No content available</p>';\n   282â†’            }\n   283â†’        });\n   284â†’}\n   285â†’\n   286â†’function closeDrawer() {\n   287â†’    document.getElementById('step-drawer').classList.remove('drawer-open');\n   288â†’}\n   289â†’\n   290â†’document.addEventListener('keydown', function(e) {\n   291â†’    if (e.key === 'Escape') closeDrawer();\n   292â†’});\n   293â†’\n   294â†’// Load all panels\n   295â†’loadOrchestratorStatus();\n   296â†’loadProjectInfo();\n   297â†’loadWorkflows();\n   298â†’</script>\n   299â†’{{end}}\n   300â†’"}]},"parent_tool_use_id":null,"session_id":"a37f3516-6a98-45b4-b440-44c340a4d486","uuid":"21fa9dba-348c-436d-8f3b-03d7ec40849e","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/web/templates/project_detail.html","content":"{{define \"content\"}}\n<h1><a href=\"/\">Projects</a> / {{.Label}}</h1>\n\n<div class=\"run-history\" style=\"margin-bottom:1rem\">\n    {{range .RecentRuns}}\n    <a href=\"/runs/{{.ID}}\"><span class=\"run-dot run-dot-{{.State}}\" title=\"{{.ID}}: {{.State}}\"></span></a>\n    {{end}}\n    <a href=\"/runs?project={{.Dir}}\" class=\"btn btn-secondary btn-sm\" style=\"margin-left:0.5rem\">View all runs</a>\n</div>\n\n<!-- Panel 1: Orchestrator Control -->\n<div class=\"panel\" id=\"orchestrator-panel\">\n    <div class=\"panel-header\">Orchestrator Control</div>\n    <div class=\"panel-body\">\n        <div id=\"orch-status\" class=\"orch-status\">Loading...</div>\n        <div class=\"orch-controls\" style=\"margin-top:0.75rem;display:flex;gap:0.5rem;align-items:center;flex-wrap:wrap\">\n            <button id=\"orch-toggle\" class=\"btn btn-primary btn-sm\" onclick=\"toggleOrchestrator()\">Enable</button>\n            <span style=\"margin-left:1rem;color:var(--text-muted);font-size:0.85rem\">Concurrency:</span>\n            <input type=\"number\" id=\"orch-concurrency\" min=\"1\" max=\"20\" value=\"1\" style=\"width:60px;padding:0.2em 0.4em;border:1px solid var(--border);border-radius:var(--radius);background:var(--bg);color:var(--text);font-size:0.85rem\">\n            <button class=\"btn btn-secondary btn-sm\" onclick=\"applyConcurrency()\">Apply</button>\n        </div>\n    </div>\n</div>\n\n<!-- Panel 2: Project Info -->\n<div class=\"panel\" id=\"info-panel\">\n    <div class=\"panel-header\">Project Info</div>\n    <div class=\"panel-body\" id=\"project-info\">Loading...</div>\n</div>\n\n<!-- Panel 3: Workflow View -->\n<div class=\"panel\" id=\"workflow-panel\">\n    <div class=\"panel-header\">Workflows</div>\n    <div class=\"panel-body\">\n        <div id=\"workflow-tabs\" class=\"tab-bar\"></div>\n        <div id=\"workflow-dag\"></div>\n    </div>\n</div>\n\n<!-- Step Drawer -->\n<div class=\"drawer\" id=\"step-drawer\">\n    <div class=\"drawer-header\">\n        <span id=\"drawer-title\"></span>\n        <button class=\"drawer-close\" onclick=\"closeDrawer()\">&times;</button>\n    </div>\n    <div class=\"drawer-body\" id=\"drawer-body\"></div>\n</div>\n{{end}}\n\n{{define \"scripts\"}}\n<script>\nvar projectLabel = {{.Label}};\nvar orchEnabled = false;\n\nfunction loadOrchestratorStatus() {\n    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/orchestrator')\n        .then(function(r) { return r.json(); })\n        .then(function(data) {\n            orchEnabled = data.enabled;\n            var statusEl = document.getElementById('orch-status');\n            var toggleBtn = document.getElementById('orch-toggle');\n            var concInput = document.getElementById('orch-concurrency');\n            statusEl.innerHTML = '<span class=\"badge ' + (data.enabled ? 'badge-succeeded' : 'badge-stopped') + '\">' +\n                (data.enabled ? 'Enabled' : 'Disabled') + '</span>' +\n                '&nbsp; In-flight: <strong>' + data.in_flight + '</strong>' +\n                '&nbsp; Concurrency: <strong>' + data.concurrency + '</strong>';\n            toggleBtn.textContent = data.enabled ? 'Disable' : 'Enable';\n            toggleBtn.className = 'btn btn-sm ' + (data.enabled ? 'btn-danger' : 'btn-primary');\n            concInput.value = data.concurrency;\n        });\n}\n\nfunction toggleOrchestrator() {\n    var action = orchEnabled ? 'stop' : 'start';\n    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/orchestrator/' + action, {method: 'POST'})\n        .then(function() { loadOrchestratorStatus(); });\n}\n\nfunction applyConcurrency() {\n    var val = parseInt(document.getElementById('orch-concurrency').value, 10);\n    if (val < 1) return;\n    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/orchestrator/concurrency', {\n        method: 'POST',\n        headers: {'Content-Type': 'application/json'},\n        body: JSON.stringify({concurrency: val})\n    }).then(function() { loadOrchestratorStatus(); });\n}\n\nfunction loadProjectInfo() {\n    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/info')\n        .then(function(r) { return r.json(); })\n        .then(function(data) {\n            var html = '<dl class=\"run-meta\" style=\"margin:0\">';\n            html += '<dt>Docker Image</dt><dd class=\"mono\">' + (data.docker_image || 'N/A') + '</dd>';\n            html += '<dt>Version</dt><dd>' + (data.version ? 'v' + data.version : 'N/A') + '</dd>';\n            html += '</dl>';\n\n            if (data.prompt_files && data.prompt_files.length > 0) {\n                html += '<h2 style=\"margin-top:1rem\">Prompt Files</h2>';\n                data.prompt_files.forEach(function(pf) {\n                    html += '<details><summary class=\"mono\">' + pf.path + '</summary>';\n                    if (pf.history && pf.history.length > 0) {\n                        html += '<div style=\"margin:0.5rem 0\">';\n                        pf.history.forEach(function(h) {\n                            html += '<div class=\"prompt-commit\" data-file=\"' + pf.path + '\" data-sha=\"' + h.sha + '\" onclick=\"toggleDiff(this)\" style=\"cursor:pointer;padding:0.25rem 0;font-size:0.85rem\">';\n                            html += '<span class=\"mono\" style=\"color:var(--link)\">' + h.sha + '</span> ';\n                            html += '<span style=\"color:var(--text-muted)\">' + h.date + '</span> ';\n                            html += h.message;\n                            html += '</div>';\n                        });\n                        html += '</div>';\n                    } else {\n                        html += '<p style=\"color:var(--text-muted);font-size:0.85rem\">No history</p>';\n                    }\n                    html += '</details>';\n                });\n            }\n\n            document.getElementById('project-info').innerHTML = html;\n        });\n}\n\nfunction toggleDiff(el) {\n    var existing = el.nextElementSibling;\n    if (existing && existing.classList.contains('diff-block')) {\n        existing.remove();\n        return;\n    }\n    var file = el.getAttribute('data-file');\n    var sha = el.getAttribute('data-sha');\n    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/info/prompt-diff?file=' + encodeURIComponent(file) + '&sha=' + encodeURIComponent(sha))\n        .then(function(r) { return r.text(); })\n        .then(function(text) {\n            var pre = document.createElement('pre');\n            pre.className = 'diff-block';\n            pre.textContent = text || '(no diff available)';\n            el.parentNode.insertBefore(pre, el.nextSibling);\n        });\n}\n\nvar workflowsData = [];\nfunction loadWorkflows() {\n    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/workflows')\n        .then(function(r) { return r.json(); })\n        .then(function(data) {\n            workflowsData = data || [];\n            if (workflowsData.length === 0) {\n                document.getElementById('workflow-dag').innerHTML = '<p class=\"empty\">No workflows found</p>';\n                return;\n            }\n            var tabs = document.getElementById('workflow-tabs');\n            if (workflowsData.length > 1) {\n                var html = '';\n                workflowsData.forEach(function(wf, i) {\n                    html += '<button class=\"tab-btn' + (i === 0 ? ' tab-active' : '') + '\" onclick=\"showWorkflow(' + i + ')\">' + wf.name + '</button>';\n                });\n                tabs.innerHTML = html;\n            }\n            showWorkflow(0);\n        });\n}\n\nfunction showWorkflow(idx) {\n    var btns = document.querySelectorAll('.tab-btn');\n    btns.forEach(function(b, i) { b.classList.toggle('tab-active', i === idx); });\n\n    var wf = workflowsData[idx];\n    var dagEl = document.getElementById('workflow-dag');\n\n    // Build step order via topological sort from entry\n    var ordered = [];\n    var visited = {};\n    function visit(name) {\n        if (visited[name] || name === 'done' || name === 'abort') return;\n        visited[name] = true;\n        ordered.push(name);\n        wf.wires.forEach(function(wire) {\n            if (wire.from === name) visit(wire.to);\n        });\n    }\n    if (wf.entry_step) visit(wf.entry_step);\n    // Add any unvisited steps\n    wf.steps.forEach(function(s) { if (!visited[s.name]) { ordered.push(s.name); visited[s.name] = true; } });\n\n    // Collect terminal targets\n    var terminals = {};\n    wf.wires.forEach(function(wire) {\n        if (wire.to === 'done' || wire.to === 'abort') terminals[wire.to] = true;\n    });\n\n    var stepMap = {};\n    wf.steps.forEach(function(s) { stepMap[s.name] = s; });\n\n    var nodeH = 48, nodeW = 180, gapY = 24, gapX = 40, padTop = 20, padLeft = 30;\n\n    // Assign positions\n    var positions = {};\n    ordered.forEach(function(name, i) {\n        positions[name] = {x: padLeft, y: padTop + i * (nodeH + gapY)};\n    });\n    var termIdx = ordered.length;\n    for (var t in terminals) {\n        positions[t] = {x: padLeft, y: padTop + termIdx * (nodeH + gapY)};\n        termIdx++;\n    }\n\n    var totalH = padTop + termIdx * (nodeH + gapY) + 10;\n    var totalW = padLeft + nodeW + gapX + 80;\n\n    var html = '<svg class=\"dag-svg\" width=\"' + totalW + '\" height=\"' + totalH + '\">';\n    html += '<defs><marker id=\"arrowhead\" markerWidth=\"8\" markerHeight=\"6\" refX=\"8\" refY=\"3\" orient=\"auto\"><polygon points=\"0 0, 8 3, 0 6\" fill=\"var(--text-muted)\"/></marker></defs>';\n\n    // Draw wires\n    wf.wires.forEach(function(wire) {\n        var from = positions[wire.from];\n        var to = positions[wire.to];\n        if (!from || !to) return;\n        var x1 = from.x + nodeW;\n        var y1 = from.y + nodeH / 2;\n        var x2 = to.x;\n        var y2 = to.y + nodeH / 2;\n        var cx = x1 + gapX / 2;\n        html += '<path d=\"M' + x1 + ' ' + y1 + ' C' + cx + ' ' + y1 + ' ' + cx + ' ' + y2 + ' ' + x2 + ' ' + y2 + '\" class=\"dag-edge\" marker-end=\"url(#arrowhead)\"/>';\n        var lx = (x1 + x2) / 2, ly = (y1 + y2) / 2 - 6;\n        html += '<text x=\"' + lx + '\" y=\"' + ly + '\" class=\"dag-edge-label\">' + wire.result + '</text>';\n    });\n\n    // Draw step nodes\n    ordered.forEach(function(name) {\n        var pos = positions[name];\n        var s = stepMap[name];\n        var icon = s && s.type === 'agent' ? '\\u{1F916}' : '\\u{1F4DC}';\n        html += '<g class=\"dag-node\" onclick=\"openDrawer(\\'' + wf.name + '\\',\\'' + name + '\\')\" style=\"cursor:pointer\">';\n        html += '<rect x=\"' + pos.x + '\" y=\"' + pos.y + '\" width=\"' + nodeW + '\" height=\"' + nodeH + '\" class=\"dag-node-rect\"/>';\n        html += '<text x=\"' + (pos.x + 10) + '\" y=\"' + (pos.y + nodeH / 2 + 5) + '\" class=\"dag-node-text\">' + icon + ' ' + name + '</text>';\n        html += '</g>';\n    });\n\n    // Draw terminal nodes\n    for (var t in terminals) {\n        var pos = positions[t];\n        var cls = t === 'done' ? 'dag-terminal-done' : 'dag-terminal-abort';\n        html += '<rect x=\"' + pos.x + '\" y=\"' + pos.y + '\" width=\"' + nodeW + '\" height=\"' + nodeH + '\" class=\"dag-node-rect ' + cls + '\" rx=\"20\"/>';\n        html += '<text x=\"' + (pos.x + nodeW / 2) + '\" y=\"' + (pos.y + nodeH / 2 + 5) + '\" class=\"dag-node-text\" text-anchor=\"middle\">' + t + '</text>';\n    }\n\n    html += '</svg>';\n    dagEl.innerHTML = html;\n}\n\nfunction openDrawer(workflowName, stepName) {\n    var wf = workflowsData.find(function(w) { return w.name === workflowName; });\n    if (!wf) return;\n    var step = wf.steps.find(function(s) { return s.name === stepName; });\n    if (!step) return;\n\n    document.getElementById('drawer-title').textContent = stepName;\n    var body = '<dl class=\"run-meta\">';\n    body += '<dt>Type</dt><dd>' + step.type + '</dd>';\n    body += '<dt>Results</dt><dd>' + (step.results ? step.results.join(', ') : 'none') + '</dd>';\n    if (step.config) {\n        for (var k in step.config) {\n            if (k === 'max_attempts' || k === 'prompt' || k === 'run') {\n                body += '<dt>' + k + '</dt><dd class=\"mono\">' + step.config[k] + '</dd>';\n            }\n        }\n    }\n    body += '</dl>';\n    body += '<div id=\"drawer-content\"><p style=\"color:var(--text-muted)\">Loading content...</p></div>';\n\n    document.getElementById('drawer-body').innerHTML = body;\n    document.getElementById('step-drawer').classList.add('drawer-open');\n\n    fetch('/api/projects/' + encodeURIComponent(projectLabel) + '/workflows/' + encodeURIComponent(workflowName) + '/steps/' + encodeURIComponent(stepName) + '/content')\n        .then(function(r) { if (r.ok) return r.text(); return ''; })\n        .then(function(text) {\n            var el = document.getElementById('drawer-content');\n            if (text) {\n                el.innerHTML = '<pre>' + text.replace(/&/g,'&amp;').replace(/</g,'&lt;') + '</pre>';\n            } else {\n                el.innerHTML = '<p style=\"color:var(--text-muted)\">No content available</p>';\n            }\n        });\n}\n\nfunction closeDrawer() {\n    document.getElementById('step-drawer').classList.remove('drawer-open');\n}\n\ndocument.addEventListener('keydown', function(e) {\n    if (e.key === 'Escape') closeDrawer();\n});\n\n// Load all panels\nloadOrchestratorStatus();\nloadProjectInfo();\nloadWorkflows();\n</script>\n{{end}}\n","numLines":300,"startLine":1,"totalLines":300}}}
