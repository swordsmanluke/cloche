{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CKdTyHCsJ8CuqK1tCmGpZy","type":"tool_result","content":"     1→package prompt\n     2→\n     3→import (\n     4→\t\"bufio\"\n     5→\t\"bytes\"\n     6→\t\"context\"\n     7→\t\"encoding/json\"\n     8→\t\"fmt\"\n     9→\t\"os\"\n    10→\t\"os/exec\"\n    11→\t\"path/filepath\"\n    12→\t\"strconv\"\n    13→\t\"strings\"\n    14→\n    15→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    16→\t\"github.com/cloche-dev/cloche/internal/protocol\"\n    17→)\n    18→\n    19→// defaultAgentArgs maps known agent commands to their default arguments.\n    20→// Commands not in this map receive no default arguments (prompt on stdin only).\n    21→var defaultAgentArgs = map[string][]string{\n    22→\t\"claude\":  {\"-p\", \"--output-format\", \"stream-json\", \"--verbose\", \"--dangerously-skip-permissions\"},\n    23→\t\"gemini\":  {},\n    24→\t\"codex\":   {},\n    25→\t\"aider\":   {\"--yes-always\", \"--message\"},\n    26→}\n    27→\n    28→type Adapter struct {\n    29→\tCommands     []string            // ordered fallback chain of agent commands\n    30→\tExplicitArgs []string            // if non-nil, overrides default args for all commands\n    31→\tAgentArgs    map[string][]string // per-agent arg overrides (e.g. \"gemini\" -> [\"--model\", \"...\"])\n    32→\tRunID        string\n    33→\tStatusWriter *protocol.StatusWriter // optional: streams live output lines\n    34→}\n    35→\n    36→func New() *Adapter {\n    37→\treturn &Adapter{\n    38→\t\tCommands: []string{\"claude\"},\n    39→\t}\n    40→}\n    41→\n    42→func (a *Adapter) Name() string {\n    43→\treturn \"prompt\"\n    44→}\n    45→\n    46→// argsFor returns the arguments for the given command. Priority:\n    47→//  1. ExplicitArgs (overrides everything, applies to all commands)\n    48→//  2. AgentArgs[command] exact match, then basename match\n    49→//  3. defaultAgentArgs[command] exact match, then basename match\n    50→func (a *Adapter) argsFor(command string) []string {\n    51→\tif a.ExplicitArgs != nil {\n    52→\t\treturn a.ExplicitArgs\n    53→\t}\n    54→\tbase := filepath.Base(command)\n    55→\tif a.AgentArgs != nil {\n    56→\t\tif args, ok := a.AgentArgs[command]; ok {\n    57→\t\t\treturn args\n    58→\t\t}\n    59→\t\tif args, ok := a.AgentArgs[base]; ok {\n    60→\t\t\treturn args\n    61→\t\t}\n    62→\t}\n    63→\tif args, ok := defaultAgentArgs[command]; ok {\n    64→\t\treturn args\n    65→\t}\n    66→\tif args, ok := defaultAgentArgs[base]; ok {\n    67→\t\treturn args\n    68→\t}\n    69→\treturn nil\n    70→}\n    71→\n    72→// KnownAgents returns the names of agents with built-in default arguments.\n    73→func KnownAgents() []string {\n    74→\tagents := make([]string, 0, len(defaultAgentArgs))\n    75→\tfor name := range defaultAgentArgs {\n    76→\t\tagents = append(agents, name)\n    77→\t}\n    78→\treturn agents\n    79→}\n    80→\n    81→// ParseCommands splits a comma-separated agent_command string into individual\n    82→// command names, trimming whitespace from each entry.\n    83→func ParseCommands(s string) []string {\n    84→\tparts := strings.Split(s, \",\")\n    85→\tvar cmds []string\n    86→\tfor _, p := range parts {\n    87→\t\tp = strings.TrimSpace(p)\n    88→\t\tif p != \"\" {\n    89→\t\t\tcmds = append(cmds, p)\n    90→\t\t}\n    91→\t}\n    92→\treturn cmds\n    93→}\n    94→\n    95→func (a *Adapter) Execute(ctx context.Context, step *domain.Step, workDir string) (string, error) {\n    96→\t// Check attempt count for retry limiting\n    97→\tif maxStr, ok := step.Config[\"max_attempts\"]; ok {\n    98→\t\tmax, err := strconv.Atoi(maxStr)\n    99→\t\tif err == nil {\n   100→\t\t\tcount := readAttemptCount(workDir, step.Name)\n   101→\t\t\tif count >= max {\n   102→\t\t\t\treturn \"give-up\", nil\n   103→\t\t\t}\n   104→\t\t}\n   105→\t}\n   106→\tincrementAttemptCount(workDir, step.Name)\n   107→\n   108→\t// Build the full prompt\n   109→\tfullPrompt, err := assemblePrompt(step, workDir, a.RunID)\n   110→\tif err != nil {\n   111→\t\treturn \"\", fmt.Errorf(\"assembling prompt: %w\", err)\n   112→\t}\n   113→\n   114→\t// Try each command in the fallback chain\n   115→\tvar lastResult string\n   116→\tvar lastStdout []byte\n   117→\tvar lastErr error\n   118→\tran := false\n   119→\n   120→\tfor i, command := range a.Commands {\n   121→\t\tif a.StatusWriter != nil && len(a.Commands) > 1 {\n   122→\t\t\tif i == 0 {\n   123→\t\t\t\ta.StatusWriter.Log(step.Name, fmt.Sprintf(\"[agent] trying %s\", command))\n   124→\t\t\t} else {\n   125→\t\t\t\ta.StatusWriter.Log(step.Name, fmt.Sprintf(\"[agent] falling back to %s\", command))\n   126→\t\t\t}\n   127→\t\t}\n   128→\n   129→\t\tresult, stdout, fallbackErr := a.tryCommand(ctx, command, fullPrompt, workDir, step.Name)\n   130→\t\tlastResult = result\n   131→\t\tlastStdout = stdout\n   132→\t\tlastErr = fallbackErr\n   133→\n   134→\t\tif fallbackErr == nil {\n   135→\t\t\t// Definitive result — agent completed (exit 0 or exit non-zero with marker)\n   136→\t\t\tbreak\n   137→\t\t}\n   138→\t\tif stdout != nil {\n   139→\t\t\tran = true\n   140→\t\t}\n   141→\t\tif a.StatusWriter != nil && len(a.Commands) > 1 && i < len(a.Commands)-1 {\n   142→\t\t\ta.StatusWriter.Log(step.Name, fmt.Sprintf(\"[agent] %s failed: %v\", command, fallbackErr))\n   143→\t\t}\n   144→\t\t// Fallback-eligible — try next command\n   145→\t}\n   146→\n   147→\tif lastErr != nil && !ran && lastStdout == nil {\n   148→\t\t// All commands failed to produce any output (e.g., all not found)\n   149→\t\treturn \"\", lastErr\n   150→\t}\n   151→\n   152→\tresult := lastResult\n   153→\tif lastErr != nil {\n   154→\t\t// Last command in chain crashed without a result marker\n   155→\t\tresult = \"fail\"\n   156→\t}\n   157→\n   158→\t// Write output file\n   159→\toutputDir := filepath.Join(workDir, \".cloche\", \"output\")\n   160→\tif mkErr := os.MkdirAll(outputDir, 0755); mkErr == nil {\n   161→\t\t_ = os.WriteFile(filepath.Join(outputDir, step.Name+\".log\"), lastStdout, 0644)\n   162→\t}\n   163→\tprotocol.AppendHistory(workDir, step.Name, result, true, nil)\n   164→\treturn result, nil\n   165→}\n   166→\n   167→// tryCommand executes a single agent command and returns:\n   168→//   - result: the step result name (e.g. \"success\", \"fail\")\n   169→//   - stdout: captured stdout bytes\n   170→//   - fallbackErr: nil if the result is definitive, non-nil if fallback-eligible\n   171→//\n   172→// Fallback-eligible conditions:\n   173→//   - Command not found or failed to start (stdout will be nil)\n   174→//   - Command exited non-zero without a CLOCHE_RESULT marker\n   175→//\n   176→// Definitive (non-fallback) conditions:\n   177→//   - Command exited 0\n   178→//   - Command exited non-zero but produced a CLOCHE_RESULT marker\n   179→func (a *Adapter) tryCommand(ctx context.Context, command string, prompt string, workDir string, stepName string) (result string, stdout []byte, fallbackErr error) {\n   180→\targs := a.argsFor(command)\n   181→\tcmd := exec.CommandContext(ctx, command, args...)\n   182→\tcmd.Dir = workDir\n   183→\tcmd.Stdin = strings.NewReader(prompt)\n   184→\n   185→\t// If we have a StatusWriter, stream stdout line-by-line; otherwise buffer.\n   186→\tif a.StatusWriter == nil {\n   187→\t\tvar stdoutBuf, stderrBuf bytes.Buffer\n   188→\t\tcmd.Stdout = &stdoutBuf\n   189→\t\tcmd.Stderr = &stderrBuf\n   190→\n   191→\t\trunErr := cmd.Run()\n   192→\t\tstdoutBytes := stdoutBuf.Bytes()\n   193→\t\treturn a.classifyResult(command, stdoutBytes, runErr)\n   194→\t}\n   195→\n   196→\t// Streaming path: pipe stdout through a scanner so we can emit lines live.\n   197→\tpipe, err := cmd.StdoutPipe()\n   198→\tif err != nil {\n   199→\t\treturn \"\", nil, fmt.Errorf(\"command %q stdout pipe: %w\", command, err)\n   200→\t}\n   201→\tcmd.Stderr = nil // discard stderr\n   202→\n   203→\tif err := cmd.Start(); err != nil {\n   204→\t\treturn \"\", nil, fmt.Errorf(\"command %q failed to start: %w\", command, err)\n   205→\t}\n   206→\n   207→\t// textBuf accumulates extracted text content for result extraction.\n   208→\t// rawBuf accumulates raw stdout for the output log file.\n   209→\tvar textBuf, rawBuf bytes.Buffer\n   210→\t// lineBuf accumulates text deltas into lines for streaming.\n   211→\tvar lineBuf strings.Builder\n   212→\n   213→\tscanner := bufio.NewScanner(pipe)\n   214→\tscanner.Buffer(make([]byte, 0, 256*1024), 1024*1024)\n   215→\tfor scanner.Scan() {\n   216→\t\traw := scanner.Bytes()\n   217→\t\trawBuf.Write(raw)\n   218→\t\trawBuf.WriteByte('\\n')\n   219→\n   220→\t\ttext := extractStreamText(raw)\n   221→\t\tif text == \"\" {\n   222→\t\t\tcontinue\n   223→\t\t}\n   224→\t\ttextBuf.WriteString(text)\n   225→\n   226→\t\t// Stream complete lines to StatusWriter as they form.\n   227→\t\tlineBuf.WriteString(text)\n   228→\t\tfor {\n   229→\t\t\ts := lineBuf.String()\n   230→\t\t\tidx := strings.IndexByte(s, '\\n')\n   231→\t\t\tif idx < 0 {\n   232→\t\t\t\tbreak\n   233→\t\t\t}\n   234→\t\t\ta.StatusWriter.Log(stepName, s[:idx])\n   235→\t\t\tlineBuf.Reset()\n   236→\t\t\tlineBuf.WriteString(s[idx+1:])\n   237→\t\t}\n   238→\t}\n   239→\t// Flush any remaining partial line.\n   240→\tif lineBuf.Len() > 0 {\n   241→\t\ta.StatusWriter.Log(stepName, lineBuf.String())\n   242→\t}\n   243→\tif scanErr := scanner.Err(); scanErr != nil {\n   244→\t\ta.StatusWriter.Log(stepName, fmt.Sprintf(\"[scan error: %v]\", scanErr))\n   245→\t}\n   246→\n   247→\twaitErr := cmd.Wait()\n   248→\t// Prefer extracted text (stream-json) for result classification; fall back\n   249→\t// to raw output for non-JSON commands (scripts, non-claude agents).\n   250→\tclassifyBuf := textBuf.Bytes()\n   251→\tif len(bytes.TrimSpace(classifyBuf)) == 0 {\n   252→\t\tclassifyBuf = rawBuf.Bytes()\n   253→\t}\n   254→\tresult, _, fallbackErr = a.classifyResult(command, classifyBuf, waitErr)\n   255→\treturn result, rawBuf.Bytes(), fallbackErr\n   256→}\n   257→\n   258→// classifyResult interprets the command's exit status and stdout to determine\n   259→// the step result.\n   260→func (a *Adapter) classifyResult(command string, stdoutBytes []byte, runErr error) (string, []byte, error) {\n   261→\tif runErr != nil {\n   262→\t\tif _, ok := runErr.(*exec.ExitError); !ok {\n   263→\t\t\t// Command failed to start (not found, permission denied, etc.)\n   264→\t\t\treturn \"\", nil, fmt.Errorf(\"command %q failed to start: %w\", command, runErr)\n   265→\t\t}\n   266→\t\t// Command ran but exited non-zero\n   267→\t\tmarkerResult, _, found := protocol.ExtractResult(stdoutBytes)\n   268→\t\tif found {\n   269→\t\t\treturn markerResult, stdoutBytes, nil\n   270→\t\t}\n   271→\t\treturn \"fail\", stdoutBytes, fmt.Errorf(\"command %q exited with error: %w\", command, runErr)\n   272→\t}\n   273→\n   274→\t// Command succeeded (exit 0)\n   275→\tif len(bytes.TrimSpace(stdoutBytes)) == 0 {\n   276→\t\treturn \"fail\", stdoutBytes, fmt.Errorf(\"command %q exited 0 but produced no output (auth/config issue?)\", command)\n   277→\t}\n   278→\tmarkerResult, _, found := protocol.ExtractResult(stdoutBytes)\n   279→\tresult := \"success\"\n   280→\tif found {\n   281→\t\tresult = markerResult\n   282→\t}\n   283→\treturn result, stdoutBytes, nil\n   284→}\n   285→\n   286→// extractStreamText parses a stream-json line and returns text content.\n   287→// It handles both content_block_delta (text_delta) events for streaming and\n   288→// result events for final output (which contains the CLOCHE_RESULT marker).\n   289→func extractStreamText(line []byte) string {\n   290→\t// Fast path: only parse lines that could contain text we care about.\n   291→\tif bytes.Contains(line, []byte(`\"text_delta\"`)) {\n   292→\t\tvar event struct {\n   293→\t\t\tType  string `json:\"type\"`\n   294→\t\t\tDelta struct {\n   295→\t\t\t\tType string `json:\"type\"`\n   296→\t\t\t\tText string `json:\"text\"`\n   297→\t\t\t} `json:\"delta\"`\n   298→\t\t}\n   299→\t\tif json.Unmarshal(line, &event) == nil &&\n   300→\t\t\tevent.Type == \"content_block_delta\" && event.Delta.Type == \"text_delta\" {\n   301→\t\t\treturn event.Delta.Text\n   302→\t\t}\n   303→\t}\n   304→\n   305→\t// Also extract the final result text (contains CLOCHE_RESULT marker).\n   306→\tif bytes.Contains(line, []byte(`\"result\"`)) && bytes.Contains(line, []byte(`\"subtype\"`)) {\n   307→\t\tvar event struct {\n   308→\t\t\tType   string `json:\"type\"`\n   309→\t\t\tResult string `json:\"result\"`\n   310→\t\t}\n   311→\t\tif json.Unmarshal(line, &event) == nil && event.Type == \"result\" {\n   312→\t\t\treturn event.Result\n   313→\t\t}\n   314→\t}\n   315→\n   316→\treturn \"\"\n   317→}\n   318→\n   319→func assemblePrompt(step *domain.Step, workDir, runID string) (string, error) {\n   320→\tvar parts []string\n   321→\n   322→\t// 1. Read system template from step config\n   323→\tif tmpl, ok := step.Config[\"prompt\"]; ok {\n   324→\t\tcontent, err := resolveContent(tmpl, workDir)\n   325→\t\tif err != nil {\n   326→\t\t\treturn \"\", fmt.Errorf(\"reading prompt template: %w\", err)\n   327→\t\t}\n   328→\t\tparts = append(parts, content)\n   329→\t}\n   330→\n   331→\t// 2. Read user prompt from .cloche/<run-id>/prompt.txt\n   332→\tuserPrompt := readUserPrompt(workDir, runID)\n   333→\tif userPrompt != \"\" {\n   334→\t\tparts = append(parts, \"## User Request\\n\"+userPrompt)\n   335→\t}\n   336→\n   337→\t// 3. Read feedback from .cloche/output/*.log (opt-in via step config)\n   338→\tif step.Config[\"feedback\"] == \"true\" {\n   339→\t\tfeedback := readFeedback(workDir)\n   340→\t\tif feedback != \"\" {\n   341→\t\t\tparts = append(parts, \"## Validation Output\\n\"+feedback)\n   342→\t\t}\n   343→\t}\n   344→\n   345→\t// 4. Result selection instructions\n   346→\tif len(step.Results) > 0 {\n   347→\t\tvar resultLines []string\n   348→\t\tresultLines = append(resultLines, \"## Result Selection\")\n   349→\t\tresultLines = append(resultLines, \"When you are finished, output exactly one of the following on its own line:\")\n   350→\t\tfor _, r := range step.Results {\n   351→\t\t\tresultLines = append(resultLines, protocol.ResultPrefix+r)\n   352→\t\t}\n   353→\t\tparts = append(parts, strings.Join(resultLines, \"\\n\"))\n   354→\t}\n   355→\n   356→\treturn strings.Join(parts, \"\\n\\n\"), nil\n   357→}\n   358→\n   359→// resolveContent handles file(\"path\") syntax or returns the string directly.\n   360→func resolveContent(value string, workDir string) (string, error) {\n   361→\t// Check for file(\"path\") syntax from DSL parser\n   362→\tif strings.HasPrefix(value, `file(\"`) && strings.HasSuffix(value, `\")`) {\n   363→\t\tpath := value[6 : len(value)-2]\n   364→\t\tdata, err := os.ReadFile(filepath.Join(workDir, path))\n   365→\t\tif err != nil {\n   366→\t\t\treturn \"\", fmt.Errorf(\"reading file %q: %w\", path, err)\n   367→\t\t}\n   368→\t\treturn string(data), nil\n   369→\t}\n   370→\treturn value, nil\n   371→}\n   372→\n   373→func readFeedback(workDir string) string {\n   374→\toutputDir := filepath.Join(workDir, \".cloche\", \"output\")\n   375→\tentries, err := os.ReadDir(outputDir)\n   376→\tif err != nil {\n   377→\t\treturn \"\"\n   378→\t}\n   379→\n   380→\tvar parts []string\n   381→\tfor _, entry := range entries {\n   382→\t\tif entry.IsDir() || !strings.HasSuffix(entry.Name(), \".log\") {\n   383→\t\t\tcontinue\n   384→\t\t}\n   385→\t\tdata, err := os.ReadFile(filepath.Join(outputDir, entry.Name()))\n   386→\t\tif err != nil {\n   387→\t\t\tcontinue\n   388→\t\t}\n   389→\t\tcontent := strings.TrimSpace(string(data))\n   390→\t\tif content != \"\" {\n   391→\t\t\tstepName := strings.TrimSuffix(entry.Name(), \".log\")\n   392→\t\t\tparts = append(parts, fmt.Sprintf(\"### %s\\n```\\n%s\\n```\", stepName, content))\n   393→\t\t}\n   394→\t}\n   395→\n   396→\treturn strings.Join(parts, \"\\n\\n\")\n   397→}\n   398→\n   399→func readAttemptCount(workDir, stepName string) int {\n   400→\tpath := filepath.Join(workDir, \".cloche\", \"attempt_count\", stepName)\n   401→\tdata, err := os.ReadFile(path)\n   402→\tif err != nil {\n   403→\t\treturn 0\n   404→\t}\n   405→\tn, _ := strconv.Atoi(strings.TrimSpace(string(data)))\n   406→\treturn n\n   407→}\n   408→\n   409→// readUserPrompt reads the user prompt from .cloche/<run-id>/prompt.txt.\n   410→func readUserPrompt(workDir, runID string) string {\n   411→\tif runID == \"\" {\n   412→\t\treturn \"\"\n   413→\t}\n   414→\tpath := filepath.Join(workDir, \".cloche\", runID, \"prompt.txt\")\n   415→\tif data, err := os.ReadFile(path); err == nil {\n   416→\t\treturn string(data)\n   417→\t}\n   418→\treturn \"\"\n   419→}\n   420→\n   421→func incrementAttemptCount(workDir, stepName string) {\n   422→\tdir := filepath.Join(workDir, \".cloche\", \"attempt_count\")\n   423→\t_ = os.MkdirAll(dir, 0755)\n   424→\tcount := readAttemptCount(workDir, stepName) + 1\n   425→\t_ = os.WriteFile(filepath.Join(dir, stepName), []byte(strconv.Itoa(count)), 0644)\n   426→}\n   427→"}]},"parent_tool_use_id":null,"session_id":"4f04c193-cbac-4c68-80c0-572ba4179c47","uuid":"de31f801-125c-4ed2-b602-8c2285295891","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/agents/prompt/prompt.go","content":"package prompt\n\nimport (\n\t\"bufio\"\n\t\"bytes\"\n\t\"context\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"os\"\n\t\"os/exec\"\n\t\"path/filepath\"\n\t\"strconv\"\n\t\"strings\"\n\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/protocol\"\n)\n\n// defaultAgentArgs maps known agent commands to their default arguments.\n// Commands not in this map receive no default arguments (prompt on stdin only).\nvar defaultAgentArgs = map[string][]string{\n\t\"claude\":  {\"-p\", \"--output-format\", \"stream-json\", \"--verbose\", \"--dangerously-skip-permissions\"},\n\t\"gemini\":  {},\n\t\"codex\":   {},\n\t\"aider\":   {\"--yes-always\", \"--message\"},\n}\n\ntype Adapter struct {\n\tCommands     []string            // ordered fallback chain of agent commands\n\tExplicitArgs []string            // if non-nil, overrides default args for all commands\n\tAgentArgs    map[string][]string // per-agent arg overrides (e.g. \"gemini\" -> [\"--model\", \"...\"])\n\tRunID        string\n\tStatusWriter *protocol.StatusWriter // optional: streams live output lines\n}\n\nfunc New() *Adapter {\n\treturn &Adapter{\n\t\tCommands: []string{\"claude\"},\n\t}\n}\n\nfunc (a *Adapter) Name() string {\n\treturn \"prompt\"\n}\n\n// argsFor returns the arguments for the given command. Priority:\n//  1. ExplicitArgs (overrides everything, applies to all commands)\n//  2. AgentArgs[command] exact match, then basename match\n//  3. defaultAgentArgs[command] exact match, then basename match\nfunc (a *Adapter) argsFor(command string) []string {\n\tif a.ExplicitArgs != nil {\n\t\treturn a.ExplicitArgs\n\t}\n\tbase := filepath.Base(command)\n\tif a.AgentArgs != nil {\n\t\tif args, ok := a.AgentArgs[command]; ok {\n\t\t\treturn args\n\t\t}\n\t\tif args, ok := a.AgentArgs[base]; ok {\n\t\t\treturn args\n\t\t}\n\t}\n\tif args, ok := defaultAgentArgs[command]; ok {\n\t\treturn args\n\t}\n\tif args, ok := defaultAgentArgs[base]; ok {\n\t\treturn args\n\t}\n\treturn nil\n}\n\n// KnownAgents returns the names of agents with built-in default arguments.\nfunc KnownAgents() []string {\n\tagents := make([]string, 0, len(defaultAgentArgs))\n\tfor name := range defaultAgentArgs {\n\t\tagents = append(agents, name)\n\t}\n\treturn agents\n}\n\n// ParseCommands splits a comma-separated agent_command string into individual\n// command names, trimming whitespace from each entry.\nfunc ParseCommands(s string) []string {\n\tparts := strings.Split(s, \",\")\n\tvar cmds []string\n\tfor _, p := range parts {\n\t\tp = strings.TrimSpace(p)\n\t\tif p != \"\" {\n\t\t\tcmds = append(cmds, p)\n\t\t}\n\t}\n\treturn cmds\n}\n\nfunc (a *Adapter) Execute(ctx context.Context, step *domain.Step, workDir string) (string, error) {\n\t// Check attempt count for retry limiting\n\tif maxStr, ok := step.Config[\"max_attempts\"]; ok {\n\t\tmax, err := strconv.Atoi(maxStr)\n\t\tif err == nil {\n\t\t\tcount := readAttemptCount(workDir, step.Name)\n\t\t\tif count >= max {\n\t\t\t\treturn \"give-up\", nil\n\t\t\t}\n\t\t}\n\t}\n\tincrementAttemptCount(workDir, step.Name)\n\n\t// Build the full prompt\n\tfullPrompt, err := assemblePrompt(step, workDir, a.RunID)\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"assembling prompt: %w\", err)\n\t}\n\n\t// Try each command in the fallback chain\n\tvar lastResult string\n\tvar lastStdout []byte\n\tvar lastErr error\n\tran := false\n\n\tfor i, command := range a.Commands {\n\t\tif a.StatusWriter != nil && len(a.Commands) > 1 {\n\t\t\tif i == 0 {\n\t\t\t\ta.StatusWriter.Log(step.Name, fmt.Sprintf(\"[agent] trying %s\", command))\n\t\t\t} else {\n\t\t\t\ta.StatusWriter.Log(step.Name, fmt.Sprintf(\"[agent] falling back to %s\", command))\n\t\t\t}\n\t\t}\n\n\t\tresult, stdout, fallbackErr := a.tryCommand(ctx, command, fullPrompt, workDir, step.Name)\n\t\tlastResult = result\n\t\tlastStdout = stdout\n\t\tlastErr = fallbackErr\n\n\t\tif fallbackErr == nil {\n\t\t\t// Definitive result — agent completed (exit 0 or exit non-zero with marker)\n\t\t\tbreak\n\t\t}\n\t\tif stdout != nil {\n\t\t\tran = true\n\t\t}\n\t\tif a.StatusWriter != nil && len(a.Commands) > 1 && i < len(a.Commands)-1 {\n\t\t\ta.StatusWriter.Log(step.Name, fmt.Sprintf(\"[agent] %s failed: %v\", command, fallbackErr))\n\t\t}\n\t\t// Fallback-eligible — try next command\n\t}\n\n\tif lastErr != nil && !ran && lastStdout == nil {\n\t\t// All commands failed to produce any output (e.g., all not found)\n\t\treturn \"\", lastErr\n\t}\n\n\tresult := lastResult\n\tif lastErr != nil {\n\t\t// Last command in chain crashed without a result marker\n\t\tresult = \"fail\"\n\t}\n\n\t// Write output file\n\toutputDir := filepath.Join(workDir, \".cloche\", \"output\")\n\tif mkErr := os.MkdirAll(outputDir, 0755); mkErr == nil {\n\t\t_ = os.WriteFile(filepath.Join(outputDir, step.Name+\".log\"), lastStdout, 0644)\n\t}\n\tprotocol.AppendHistory(workDir, step.Name, result, true, nil)\n\treturn result, nil\n}\n\n// tryCommand executes a single agent command and returns:\n//   - result: the step result name (e.g. \"success\", \"fail\")\n//   - stdout: captured stdout bytes\n//   - fallbackErr: nil if the result is definitive, non-nil if fallback-eligible\n//\n// Fallback-eligible conditions:\n//   - Command not found or failed to start (stdout will be nil)\n//   - Command exited non-zero without a CLOCHE_RESULT marker\n//\n// Definitive (non-fallback) conditions:\n//   - Command exited 0\n//   - Command exited non-zero but produced a CLOCHE_RESULT marker\nfunc (a *Adapter) tryCommand(ctx context.Context, command string, prompt string, workDir string, stepName string) (result string, stdout []byte, fallbackErr error) {\n\targs := a.argsFor(command)\n\tcmd := exec.CommandContext(ctx, command, args...)\n\tcmd.Dir = workDir\n\tcmd.Stdin = strings.NewReader(prompt)\n\n\t// If we have a StatusWriter, stream stdout line-by-line; otherwise buffer.\n\tif a.StatusWriter == nil {\n\t\tvar stdoutBuf, stderrBuf bytes.Buffer\n\t\tcmd.Stdout = &stdoutBuf\n\t\tcmd.Stderr = &stderrBuf\n\n\t\trunErr := cmd.Run()\n\t\tstdoutBytes := stdoutBuf.Bytes()\n\t\treturn a.classifyResult(command, stdoutBytes, runErr)\n\t}\n\n\t// Streaming path: pipe stdout through a scanner so we can emit lines live.\n\tpipe, err := cmd.StdoutPipe()\n\tif err != nil {\n\t\treturn \"\", nil, fmt.Errorf(\"command %q stdout pipe: %w\", command, err)\n\t}\n\tcmd.Stderr = nil // discard stderr\n\n\tif err := cmd.Start(); err != nil {\n\t\treturn \"\", nil, fmt.Errorf(\"command %q failed to start: %w\", command, err)\n\t}\n\n\t// textBuf accumulates extracted text content for result extraction.\n\t// rawBuf accumulates raw stdout for the output log file.\n\tvar textBuf, rawBuf bytes.Buffer\n\t// lineBuf accumulates text deltas into lines for streaming.\n\tvar lineBuf strings.Builder\n\n\tscanner := bufio.NewScanner(pipe)\n\tscanner.Buffer(make([]byte, 0, 256*1024), 1024*1024)\n\tfor scanner.Scan() {\n\t\traw := scanner.Bytes()\n\t\trawBuf.Write(raw)\n\t\trawBuf.WriteByte('\\n')\n\n\t\ttext := extractStreamText(raw)\n\t\tif text == \"\" {\n\t\t\tcontinue\n\t\t}\n\t\ttextBuf.WriteString(text)\n\n\t\t// Stream complete lines to StatusWriter as they form.\n\t\tlineBuf.WriteString(text)\n\t\tfor {\n\t\t\ts := lineBuf.String()\n\t\t\tidx := strings.IndexByte(s, '\\n')\n\t\t\tif idx < 0 {\n\t\t\t\tbreak\n\t\t\t}\n\t\t\ta.StatusWriter.Log(stepName, s[:idx])\n\t\t\tlineBuf.Reset()\n\t\t\tlineBuf.WriteString(s[idx+1:])\n\t\t}\n\t}\n\t// Flush any remaining partial line.\n\tif lineBuf.Len() > 0 {\n\t\ta.StatusWriter.Log(stepName, lineBuf.String())\n\t}\n\tif scanErr := scanner.Err(); scanErr != nil {\n\t\ta.StatusWriter.Log(stepName, fmt.Sprintf(\"[scan error: %v]\", scanErr))\n\t}\n\n\twaitErr := cmd.Wait()\n\t// Prefer extracted text (stream-json) for result classification; fall back\n\t// to raw output for non-JSON commands (scripts, non-claude agents).\n\tclassifyBuf := textBuf.Bytes()\n\tif len(bytes.TrimSpace(classifyBuf)) == 0 {\n\t\tclassifyBuf = rawBuf.Bytes()\n\t}\n\tresult, _, fallbackErr = a.classifyResult(command, classifyBuf, waitErr)\n\treturn result, rawBuf.Bytes(), fallbackErr\n}\n\n// classifyResult interprets the command's exit status and stdout to determine\n// the step result.\nfunc (a *Adapter) classifyResult(command string, stdoutBytes []byte, runErr error) (string, []byte, error) {\n\tif runErr != nil {\n\t\tif _, ok := runErr.(*exec.ExitError); !ok {\n\t\t\t// Command failed to start (not found, permission denied, etc.)\n\t\t\treturn \"\", nil, fmt.Errorf(\"command %q failed to start: %w\", command, runErr)\n\t\t}\n\t\t// Command ran but exited non-zero\n\t\tmarkerResult, _, found := protocol.ExtractResult(stdoutBytes)\n\t\tif found {\n\t\t\treturn markerResult, stdoutBytes, nil\n\t\t}\n\t\treturn \"fail\", stdoutBytes, fmt.Errorf(\"command %q exited with error: %w\", command, runErr)\n\t}\n\n\t// Command succeeded (exit 0)\n\tif len(bytes.TrimSpace(stdoutBytes)) == 0 {\n\t\treturn \"fail\", stdoutBytes, fmt.Errorf(\"command %q exited 0 but produced no output (auth/config issue?)\", command)\n\t}\n\tmarkerResult, _, found := protocol.ExtractResult(stdoutBytes)\n\tresult := \"success\"\n\tif found {\n\t\tresult = markerResult\n\t}\n\treturn result, stdoutBytes, nil\n}\n\n// extractStreamText parses a stream-json line and returns text content.\n// It handles both content_block_delta (text_delta) events for streaming and\n// result events for final output (which contains the CLOCHE_RESULT marker).\nfunc extractStreamText(line []byte) string {\n\t// Fast path: only parse lines that could contain text we care about.\n\tif bytes.Contains(line, []byte(`\"text_delta\"`)) {\n\t\tvar event struct {\n\t\t\tType  string `json:\"type\"`\n\t\t\tDelta struct {\n\t\t\t\tType string `json:\"type\"`\n\t\t\t\tText string `json:\"text\"`\n\t\t\t} `json:\"delta\"`\n\t\t}\n\t\tif json.Unmarshal(line, &event) == nil &&\n\t\t\tevent.Type == \"content_block_delta\" && event.Delta.Type == \"text_delta\" {\n\t\t\treturn event.Delta.Text\n\t\t}\n\t}\n\n\t// Also extract the final result text (contains CLOCHE_RESULT marker).\n\tif bytes.Contains(line, []byte(`\"result\"`)) && bytes.Contains(line, []byte(`\"subtype\"`)) {\n\t\tvar event struct {\n\t\t\tType   string `json:\"type\"`\n\t\t\tResult string `json:\"result\"`\n\t\t}\n\t\tif json.Unmarshal(line, &event) == nil && event.Type == \"result\" {\n\t\t\treturn event.Result\n\t\t}\n\t}\n\n\treturn \"\"\n}\n\nfunc assemblePrompt(step *domain.Step, workDir, runID string) (string, error) {\n\tvar parts []string\n\n\t// 1. Read system template from step config\n\tif tmpl, ok := step.Config[\"prompt\"]; ok {\n\t\tcontent, err := resolveContent(tmpl, workDir)\n\t\tif err != nil {\n\t\t\treturn \"\", fmt.Errorf(\"reading prompt template: %w\", err)\n\t\t}\n\t\tparts = append(parts, content)\n\t}\n\n\t// 2. Read user prompt from .cloche/<run-id>/prompt.txt\n\tuserPrompt := readUserPrompt(workDir, runID)\n\tif userPrompt != \"\" {\n\t\tparts = append(parts, \"## User Request\\n\"+userPrompt)\n\t}\n\n\t// 3. Read feedback from .cloche/output/*.log (opt-in via step config)\n\tif step.Config[\"feedback\"] == \"true\" {\n\t\tfeedback := readFeedback(workDir)\n\t\tif feedback != \"\" {\n\t\t\tparts = append(parts, \"## Validation Output\\n\"+feedback)\n\t\t}\n\t}\n\n\t// 4. Result selection instructions\n\tif len(step.Results) > 0 {\n\t\tvar resultLines []string\n\t\tresultLines = append(resultLines, \"## Result Selection\")\n\t\tresultLines = append(resultLines, \"When you are finished, output exactly one of the following on its own line:\")\n\t\tfor _, r := range step.Results {\n\t\t\tresultLines = append(resultLines, protocol.ResultPrefix+r)\n\t\t}\n\t\tparts = append(parts, strings.Join(resultLines, \"\\n\"))\n\t}\n\n\treturn strings.Join(parts, \"\\n\\n\"), nil\n}\n\n// resolveContent handles file(\"path\") syntax or returns the string directly.\nfunc resolveContent(value string, workDir string) (string, error) {\n\t// Check for file(\"path\") syntax from DSL parser\n\tif strings.HasPrefix(value, `file(\"`) && strings.HasSuffix(value, `\")`) {\n\t\tpath := value[6 : len(value)-2]\n\t\tdata, err := os.ReadFile(filepath.Join(workDir, path))\n\t\tif err != nil {\n\t\t\treturn \"\", fmt.Errorf(\"reading file %q: %w\", path, err)\n\t\t}\n\t\treturn string(data), nil\n\t}\n\treturn value, nil\n}\n\nfunc readFeedback(workDir string) string {\n\toutputDir := filepath.Join(workDir, \".cloche\", \"output\")\n\tentries, err := os.ReadDir(outputDir)\n\tif err != nil {\n\t\treturn \"\"\n\t}\n\n\tvar parts []string\n\tfor _, entry := range entries {\n\t\tif entry.IsDir() || !strings.HasSuffix(entry.Name(), \".log\") {\n\t\t\tcontinue\n\t\t}\n\t\tdata, err := os.ReadFile(filepath.Join(outputDir, entry.Name()))\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tcontent := strings.TrimSpace(string(data))\n\t\tif content != \"\" {\n\t\t\tstepName := strings.TrimSuffix(entry.Name(), \".log\")\n\t\t\tparts = append(parts, fmt.Sprintf(\"### %s\\n```\\n%s\\n```\", stepName, content))\n\t\t}\n\t}\n\n\treturn strings.Join(parts, \"\\n\\n\")\n}\n\nfunc readAttemptCount(workDir, stepName string) int {\n\tpath := filepath.Join(workDir, \".cloche\", \"attempt_count\", stepName)\n\tdata, err := os.ReadFile(path)\n\tif err != nil {\n\t\treturn 0\n\t}\n\tn, _ := strconv.Atoi(strings.TrimSpace(string(data)))\n\treturn n\n}\n\n// readUserPrompt reads the user prompt from .cloche/<run-id>/prompt.txt.\nfunc readUserPrompt(workDir, runID string) string {\n\tif runID == \"\" {\n\t\treturn \"\"\n\t}\n\tpath := filepath.Join(workDir, \".cloche\", runID, \"prompt.txt\")\n\tif data, err := os.ReadFile(path); err == nil {\n\t\treturn string(data)\n\t}\n\treturn \"\"\n}\n\nfunc incrementAttemptCount(workDir, stepName string) {\n\tdir := filepath.Join(workDir, \".cloche\", \"attempt_count\")\n\t_ = os.MkdirAll(dir, 0755)\n\tcount := readAttemptCount(workDir, stepName) + 1\n\t_ = os.WriteFile(filepath.Join(dir, stepName), []byte(strconv.Itoa(count)), 0644)\n}\n","numLines":427,"startLine":1,"totalLines":427}}}
