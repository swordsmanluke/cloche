l, err\n    60→\t}\n    61→\n    62→\twf := &domain.Workflow{\n    63→\t\tName:   nameTok.Literal,\n    64→\t\tSteps:  make(map[string]*domain.Step),\n    65→\t\tConfig: make(map[string]string),\n    66→\t}\n    67→\n    68→\tfor p.current.Type != TokenRBrace && p.current.Type != TokenEOF {\n    69→\t\tif p.current.Type == TokenIdent && p.current.Literal == \"step\" {\n    70→\t\t\tstep, err := p.parseStep()\n    71→\t\t\tif err != nil {\n    72→\t\t\t\treturn nil, err\n    73→\t\t\t}\n    74→\t\t\twf.Steps[step.Name] = step\n    75→\t\t\tif wf.EntryStep == \"\" {\n    76→\t\t\t\twf.EntryStep = step.Name\n    77→\t\t\t}\n    78→\t\t} else if p.current.Type == TokenIdent && p.current.Literal == \"collect\" {\n    79→\t\t\tcollect, err := p.parseCollect()\n    80→\t\t\tif err != nil {\n    81→\t\t\t\treturn nil, err\n    82→\t\t\t}\n    83→\t\t\twf.Collects = append(wf.Collects, collect)\n    84→\t\t} else if p.current.Type == TokenIdent && p.peek.Type == TokenLBrace {\n    85→\t\t\tif err := p.parseWorkflowConfig(wf); err != nil {\n    86→\t\t\t\treturn nil, err\n    87→\t\t\t}\n    88→\t\t} else if p.current.Type == TokenIdent && p.peek.Type == TokenColon {\n    89→\t\t\twire, err := p.parseWire()\n    90→\t\t\tif err != nil {\n    91→\t\t\t\treturn nil, err\n    92→\t\t\t}\n    93→\t\t\twf.Wiring = append(wf.Wiring, wire)\n    94→\t\t} else {\n    95→\t\t\treturn nil, fmt.Errorf(\"line %d col %d: unexpected token %q\", p.current.Line, p.current.Col, p.current.Literal)\n    96→\t\t}\n    97→\t}\n    98→\n    99→\tif _, err := p.expect(TokenRBrace); err != nil {\n   100→\t\treturn nil, err\n   101→\t}\n   102→\n   103→\treturn wf, nil\n   104→}\n   105→\n   106→func (p *Parser) parseWorkflowConfig(wf *domain.Workflow) error {\n   107→\tprefix := p.current.Literal // e.g. \"container\"\n   108→\tp.advance()                 // consume prefix ident\n   109→\n   110→\tif _, err := p.expect(TokenLBrace); err != nil {\n   111→\t\treturn err\n   112→\t}\n   113→\n   114→\tif err := p.parseWorkflowConfigFields(wf, prefix); err != nil {\n   115→\t\treturn err\n   116→\t}\n   117→\n   118→\tif _, err := p.expect(TokenRBrace); err != nil {\n   119→\t\treturn err\n   120→\t}\n   121→\n   122→\treturn nil\n   123→}\n   124→\n   125→func (p *Parser) parseWorkflowConfigFields(wf *domain.Workflow, prefix string) error {\n   126→\tfor p.current.Type != TokenRBrace && p.current.Type != TokenEOF {\n   127→\t\tkeyTok, err := p.expect(TokenIdent)\n   128→\t\tif err != nil {\n   129→\t\t\treturn fmt.Errorf(\"expected field name: %w\", err)\n   130→\t\t}\n   131→\n   132→\t\tfullKey := prefix + \".\" + keyTok.Literal\n   133→\n   134→\t\t// Sub-block (e.g., agent_args { ... })\n   135→\t\tif p.current.Type == TokenLBrace {\n   136→\t\t\tp.advance() // consume {\n   137→\t\t\tif err := p.parseWorkflowConfigFields(wf, fullKey); err != nil {\n   138→\t\t\t\treturn err\n   139→\t\t\t}\n   140→\t\t\tif _, err := p.expect(TokenRBrace); err != nil {\n   141→\t\t\t\treturn err\n   142→\t\t\t}\n   143→\t\t\tcontinue\n   144→\t\t}\n   145→\n   146→\t\tif _, err := p.expect(TokenEquals); err != nil {\n   147→\t\t\treturn err\n   148→\t\t}\n   149→\n   150→\t\tval, err := p.parseValue()\n   151→\t\tif err != nil {\n   152→\t\t\treturn err\n   153→\t\t}\n   154→\n   155→\t\twf.Config[fullKey] = val\n   156→\t}\n   157→\treturn nil\n   158→}\n   159→\n   160→func (p *Parser) parseStep() (*domain.Step, error) {\n   161→\tp.advance() // consume \"step\"\n   162→\n   163→\tnameTok, err := p.expect(TokenIdent)\n   164→\tif err != nil {\n   165→\t\treturn nil, fmt.Errorf(\"expected step name: %w\", err)\n   166→\t}\n   167→\n   168→\tif _, err := p.expect(TokenLBrace); err != nil {\n   169→\t\treturn nil, err\n   170→\t}\n   171→\n   172→\tstep := &domain.Step{\n   173→\t\tName:   nameTok.Literal,\n   174→\t\tConfig: make(map[string]string),\n   175→\t}\n   176→\n   177→\tfor p.current.Type != TokenRBrace && p.current.Type != TokenEOF {\n   178→\t\tif err := p.parseStepField(step, \"\"); err != nil {\n   179→\t\t\treturn nil, err\n   180→\t\t}\n   181→\t}\n   182→\n   183→\tif _, err := p.expect(TokenRBrace); err != nil {\n   184→\t\treturn nil, err\n   185→\t}\n   186→\n   187→\t// Infer step type from content\n   188→\t_, hasPrompt := step.Config[\"prompt\"]\n   189→\t_, hasRun := step.Config[\"run\"]\n   190→\t_, hasWorkflowName := step.Config[\"workflow_name\"]\n   191→\n   192→\tcount := 0\n   193→\tif hasPrompt {\n   194→\t\tcount++\n   195→\t}\n   196→\tif hasRun {\n   197→\t\tcount++\n   198→\t}\n   199→\tif hasWorkflowName {\n   200→\t\tcount++\n   201→\t}\n   202→\n   203→\tif count > 1 {\n   204→\t\treturn nil, fmt.Errorf(\"step %q has multiple of 'prompt', 'run', 'workflow_name'; must have exactly one\", step.Name)\n   205→\t}\n   206→\n   207→\tswitch {\n   208→\tcase hasPrompt:\n   209→\t\tstep.Type = domain.StepTypeAgent\n   210→\tcase hasRun:\n   211→\t\tstep.Type = domain.StepTypeScript\n   212→\tcase hasWorkflowName:\n   213→\t\tstep.Type = domain.StepTypeWorkflow\n   214→\tdefault:\n   215→\t\treturn nil, fmt.Errorf(\"step %q has none of 'prompt', 'run', or 'workflow_name'; must have exactly one\", step.Name)\n   216→\t}\n   217→\n   218→\treturn step, nil\n   219→}\n   220→\n   221→func (p *Parser) parseStepField(step *domain.Step, prefix string) error {\n   222→\tkeyTok, err := p.expect(TokenIdent)\n   223→\tif err != nil {\n   224→\t\treturn fmt.Errorf(\"expected field name: %w\", err)\n   225→\t}\n   226→\n   227→\tkey := keyTok.Literal\n   228→\tif prefix != \"\" {\n   229→\t\tkey = prefix + \".\" + key\n   230→\t}\n   231→\n   232→\t// Sub-block (e.g., container { ... })\n   233→\tif p.current.Type == TokenLBrace {\n   234→\t\tp.advance() // consume {\n   235→\t\tfor p.current.Type != TokenRBrace && p.current.Type != TokenEOF {\n   236→\t\t\tif err := p.parseStepField(step, key); err != nil {\n   237→\t\t\t\treturn err\n   238→\t\t\t}\n   239→\t\t}\n   240→\t\tp.advance() // consume }\n   241→\t\treturn nil\n   242→\t}\n   243→\n   244→\tif _, err := p.expect(TokenEquals); err != nil {\n   245→\t\treturn err\n   246→\t}\n   247→\n   248→\tif key == \"results\" {\n   249→\t\tresults, err := p.parseIdentList()\n   250→\t\tif err != nil {\n   251→\t\t\treturn err\n   252→\t\t}\n   253→\t\tstep.Results = results\n   254→\t} else if p.current.Type == TokenLBracket {\n   255→\t\tvalues, err := p.parseStringList()\n   256→\t\tif err != nil {\n   257→\t\t\treturn err\n   258→\t\t}\n   259→\t\tstep.Config[key] = strings.Join(values, \",\")\n   260→\t} else {\n   261→\t\tval, err := p.parseValue()\n   262→\t\tif err != nil {\n   263→\t\t\treturn err\n   264→\t\t}\n   265→\t\tstep.Config[key] = val\n   266→\t}\n   267→\n   268→\treturn nil\n   269→}\n   270→\n   271→func (p *Parser) parseIdentList() ([]string, error) {\n   272→\tif _, err := p.expect(TokenLBracket); err != nil {\n   273→\t\treturn nil, err\n   274→\t}\n   275→\n   276→\tvar items []string\n   277→\tfor p.current.Type != TokenRBracket && p.current.Type != TokenEOF {\n   278→\t\ttok, err := p.expect(TokenIdent)\n   279→\t\tif err != nil {\n   280→\t\t\treturn nil, err\n   281→\t\t}\n   282→\t\titems = append(items, tok.Literal)\n   283→\t\tif p.current.Type == TokenComma {\n   284→\t\t\tp.advance()\n   285→\t\t}\n   286→\t}\n   287→\n   288→\tif _, err := p.expect(TokenRBracket); err != nil {\n   289→\t\treturn nil, err\n   290→\t}\n   291→\n   292→\treturn items, nil\n   293→}\n   294→\n   295→func (p *Parser) parseStringList() ([]string, error) {\n   296→\tif _, err := p.expect(TokenLBracket); err != nil {\n   297→\t\treturn nil, err\n   298→\t}\n   299→\n   300→\tvar items []string\n   301→\tfor p.current.Type != TokenRBracket && p.current.Type != TokenEOF {\n   302→\t\ttok, err := p.expect(TokenString)\n   303→\t\tif err != nil {\n   304→\t\t\treturn nil, err\n   305→\t\t}\n   306→\t\titems = append(items, tok.Literal)\n   307→\t\tif p.current.Type == TokenComma {\n   308→\t\t\tp.advance()\n   309→\t\t}\n   310→\t}\n   311→\n   312→\tif _, err := p.expect(TokenRBracket); err != nil {\n   313→\t\treturn nil, err\n   314→\t}\n   315→\n   316→\treturn items, nil\n   317→}\n   318→\n   319→func (p *Parser) parseValue() (string, error) {\n   320→\tif p.current.Type == TokenString {\n   321→\t\ttok := p.current\n   322→\t\tp.advance()\n   323→\t\treturn tok.Literal, nil\n   324→\t}\n   325→\n   326→\tif p.current.Type == TokenIdent {\n   327→\t\tvar buf strings.Builder\n   328→\t\tbuf.WriteString(p.current.Literal)\n   329→\t\tp.advance()\n   330→\n   331→\t\t// Function call: file(\"...\")\n   332→\t\tif p.current.Type == TokenLParen {\n   333→\t\t\tbuf.WriteRune('(')\n   334→\t\t\tp.advance()\n   335→\t\t\tfor p.current.Type != TokenRParen && p.current.Type != TokenEOF {\n   336→\t\t\t\tif p.current.Type == TokenString {\n   337→\t\t\t\t\tbuf.WriteRune('\"')\n   338→\t\t\t\t\tbuf.WriteString(p.current.Literal)\n   339→\t\t\t\t\tbuf.WriteRune('\"')\n   340→\t\t\t\t} else {\n   341→\t\t\t\t\tbuf.WriteString(p.current.Literal)\n   342→\t\t\t\t}\n   343→\t\t\t\tp.advance()\n   344→\t\t\t}\n   345→\t\t\tbuf.WriteRune(')')\n   346→\t\t\tp.advance() // consume )\n   347→\t\t}\n   348→\n   349→\t\t// Dotted path: step.code.output\n   350→\t\tfor p.current.Type == TokenDot {\n   351→\t\t\tbuf.WriteRune('.')\n   352→\t\t\tp.advance()\n   353→\t\t\tif p.current.Type == TokenIdent {\n   354→\t\t\t\tbuf.WriteString(p.current.Literal)\n   355→\t\t\t\tp.advance()\n   356→\t\t\t}\n   357→\t\t}\n   358→\n   359→\t\treturn buf.String(), nil\n   360→\t}\n   361→\n   362→\treturn \"\", fmt.Errorf(\"line %d col %d: expected value, got %q\", p.current.Line, p.current.Col, p.current.Literal)\n   363→}\n   364→\n   365→func (p *Parser) parseWire() (domain.Wire, error) {\n   366→\tfromTok := p.current\n   367→\tp.advance()\n   368→\n   369→\tif _, err := p.expect(TokenColon); err != nil {\n   370→\t\treturn domain.Wire{}, err\n   371→\t}\n   372→\n   373→\tresultTok, err := p.expect(TokenIdent)\n   374→\tif err != nil {\n   375→\t\treturn domain.Wire{}, err\n   376→\t}\n   377→\n   378→\tif _, err := p.expect(TokenArrow); err != nil {\n   379→\t\treturn domain.Wire{}, err\n   380→\t}\n   381→\n   382→\ttoTok, err := p.expect(TokenIdent)\n   383→\tif err != nil {\n   384→\t\treturn domain.Wire{}, err\n   385→\t}\n   386→\n   387→\treturn domain.Wire{\n   388→\t\tFrom:   fromTok.Literal,\n   389→\t\tResult: resultTok.Literal,\n   390→\t\tTo:     toTok.Literal,\n   391→\t}, nil\n   392→}\n   393→\n   394→func (p *Parser) parseCollect() (domain.Collect, error) {\n   395→\tp.advance() // consume \"collect\"\n   396→\n   397→\tmodeTok, err := p.expect(TokenIdent)\n   398→\tif err != nil {\n   399→\t\treturn domain.Collect{}, fmt.Errorf(\"expected 'all' or 'any': %w\", err)\n   400→\t}\n   401→\n   402→\tvar mode domain.CollectMode\n   403→\tswitch modeTok.Literal {\n   404→\tcase \"all\":\n   405→\t\tmode = domain.CollectAll\n   406→\tcase \"any\":\n   407→\t\tmode = domain.CollectAny\n   408→\tdefault:\n   409→\t\treturn domain.Collect{}, fmt.Errorf(\"line %d col %d: expected 'all' or 'any', got %q\",\n   410→\t\t\tmodeTok.Line, modeTok.Col, modeTok.Literal)\n   411→\t}\n   412→\n   413→\tif _, err := p.expect(TokenLParen); err != nil {\n   414→\t\treturn domain.Collect{}, err\n   415→\t}\n   416→\n   417→\tvar conditions []domain.WireCondition\n   418→\tfor p.current.Type != TokenRParen && p.current.Type != TokenEOF {\n   419→\t\tstepTok, err := p.expect(TokenIdent)\n   420→\t\tif err != nil {\n   421→\t\t\treturn domain.Collect{}, fmt.Errorf(\"expected step name in collect: %w\", err)\n   422→\t\t}\n   423→\t\tif _, err := p.expect(TokenColon); err != nil {\n   424→\t\t\treturn domain.Collect{}, err\n   425→\t\t}\n   426→\t\tresultTok, err := p.expect(TokenIdent)\n   427→\t\tif err != nil {\n   428→\t\t\treturn domain.Collect{}, fmt.Errorf(\"expected result name in collect: %w\", err)\n   429→\t\t}\n   430→\t\tconditions = append(conditions, domain.WireCondition{Step: stepTok.Literal, Result: resultTok.Literal})\n   431→\t\tif p.current.Type == TokenComma {\n   432→\t\t\tp.advance()\n   433→\t\t}\n   434→\t}\n   435→\n   436→\tif _, err := p.expect(TokenRParen); err != nil {\n   437→\t\treturn domain.Collect{}, err\n   438→\t}\n   439→\tif _, err := p.expect(TokenArrow); err != nil {\n   440→\t\treturn domain.Collect{}, err\n   441→\t}\n   442→\n   443→\ttoTok, err := p.expect(TokenIdent)\n   444→\tif err != nil {\n   445→\t\treturn domain.Collect{}, fmt.Errorf(\"expected target step: %w\", err)\n   446→\t}\n   447→\n   448→\treturn domain.Collect{\n   449→\t\tMode:       mode,\n   450→\t\tConditions: conditions,\n   451→\t\tTo:         toTok.Literal,\n   452→\t}, nil\n   453→}\n   454→"}]},"parent_tool_use_id":null,"session_id":"4f04c193-cbac-4c68-80c0-572ba4179c47","uuid":"d40a06c9-17f6-4322-ad7b-ef51bb0359e3","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/dsl/parser.go","content":"package dsl\n\nimport (\n\t\"fmt\"\n\t\"strings\"\n\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n)\n\ntype Parser struct {\n\tlexer   *Lexer\n\tcurrent Token\n\tpeek    Token\n}\n\nfunc Parse(input string) (*domain.Workflow, error) {\n\tp := &Parser{lexer: NewLexer(input)}\n\tp.advance() // load current\n\tp.advance() // load peek\n\treturn p.parseWorkflow()\n}\n\nfunc (p *Parser) advance() {\n\tp.current = p.peek\n\tp.peek = p.lexer.NextToken()\n}\n\nfunc (p *Parser) expect(typ TokenType) (Token, error) {\n\tif p.current.Type != typ {\n\t\treturn p.current, fmt.Errorf(\"line %d col %d: expected %v, got %v (%q)\",\n\t\t\tp.current.Line, p.current.Col, typ, p.current.Type, p.current.Literal)\n\t}\n\ttok := p.current\n\tp.advance()\n\treturn tok, nil\n}\n\nfunc (p *Parser) expectIdent(value string) (Token, error) {\n\tif p.current.Type != TokenIdent || p.current.Literal != value {\n\t\treturn p.current, fmt.Errorf(\"line %d col %d: expected %q, got %q\",\n\t\t\tp.current.Line, p.current.Col, value, p.current.Literal)\n\t}\n\ttok := p.current\n\tp.advance()\n\treturn tok, nil\n}\n\nfunc (p *Parser) parseWorkflow() (*domain.Workflow, error) {\n\tif _, err := p.expectIdent(\"workflow\"); err != nil {\n\t\treturn nil, err\n\t}\n\n\tnameTok, err := p.expect(TokenString)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"expected workflow name string: %w\", err)\n\t}\n\n\tif _, err := p.expect(TokenLBrace); err != nil {\n\t\treturn nil, err\n\t}\n\n\twf := &domain.Workflow{\n\t\tName:   nameTok.Literal,\n\t\tSteps:  make(map[string]*domain.Step),\n\t\tConfig: make(map[string]string),\n\t}\n\n\tfor p.current.Type != TokenRBrace && p.current.Type != TokenEOF {\n\t\tif p.current.Type == TokenIdent && p.current.Literal == \"step\" {\n\t\t\tstep, err := p.parseStep()\n\t\t\tif err != nil {\n\t\t\t\treturn nil, err\n\t\t\t}\n\t\t\twf.Steps[step.Name] = step\n\t\t\tif wf.EntryStep == \"\" {\n\t\t\t\twf.EntryStep = step.Name\n\t\t\t}\n\t\t} else if p.current.Type == TokenIdent && p.current.Literal == \"collect\" {\n\t\t\tcollect, err := p.parseCollect()\n\t\t\tif err != nil {\n\t\t\t\treturn nil, err\n\t\t\t}\n\t\t\twf.Collects = append(wf.Collects, collect)\n\t\t} else if p.current.Type == TokenIdent && p.peek.Type == TokenLBrace {\n\t\t\tif err := p.parseWorkflowConfig(wf); err != nil {\n\t\t\t\treturn nil, err\n\t\t\t}\n\t\t} else if p.current.Type == TokenIdent && p.peek.Type == TokenColon {\n\t\t\twire, err := p.parseWire()\n\t\t\tif err != nil {\n\t\t\t\treturn nil, err\n\t\t\t}\n\t\t\twf.Wiring = append(wf.Wiring, wire)\n\t\t} else {\n\t\t\treturn nil, fmt.Errorf(\"line %d col %d: unexpected token %q\", p.current.Line, p.current.Col, p.current.Literal)\n\t\t}\n\t}\n\n\tif _, err := p.expect(TokenRBrace); err != nil {\n\t\treturn nil, err\n\t}\n\n\treturn wf, nil\n}\n\nfunc (p *Parser) parseWorkflowConfig(wf *domain.Workflow) error {\n\tprefix := p.current.Literal // e.g. \"container\"\n\tp.advance()                 // consume prefix ident\n\n\tif _, err := p.expect(TokenLBrace); err != nil {\n\t\treturn err\n\t}\n\n\tif err := p.parseWorkflowConfigFields(wf, prefix); err != nil {\n\t\treturn err\n\t}\n\n\tif _, err := p.expect(TokenRBrace); err != nil {\n\t\treturn err\n\t}\n\n\treturn nil\n}\n\nfunc (p *Parser) parseWorkflowConfigFields(wf *domain.Workflow, prefix string) error {\n\tfor p.current.Type != TokenRBrace && p.current.Type != TokenEOF {\n\t\tkeyTok, err := p.expect(TokenIdent)\n\t\tif err != nil {\n\t\t\treturn fmt.Errorf(\"expected field name: %w\", err)\n\t\t}\n\n\t\tfullKey := prefix + \".\" + keyTok.Literal\n\n\t\t// Sub-block (e.g., agent_args { ... })\n\t\tif p.current.Type == TokenLBrace {\n\t\t\tp.advance() // consume {\n\t\t\tif err := p.parseWorkflowConfigFields(wf, fullKey); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t\tif _, err := p.expect(TokenRBrace); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t\tcontinue\n\t\t}\n\n\t\tif _, err := p.expect(TokenEquals); err != nil {\n\t\t\treturn err\n\t\t}\n\n\t\tval, err := p.parseValue()\n\t\tif err != nil {\n\t\t\treturn err\n\t\t}\n\n\t\twf.Config[fullKey] = val\n\t}\n\treturn nil\n}\n\nfunc (p *Parser) parseStep() (*domain.Step, error) {\n\tp.advance() // consume \"step\"\n\n\tnameTok, err := p.expect(TokenIdent)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"expected step name: %w\", err)\n\t}\n\n\tif _, err := p.expect(TokenLBrace); err != nil {\n\t\treturn nil, err\n\t}\n\n\tstep := &domain.Step{\n\t\tName:   nameTok.Literal,\n\t\tConfig: make(map[string]string),\n\t}\n\n\tfor p.current.Type != TokenRBrace && p.current.Type != TokenEOF {\n\t\tif err := p.parseStepField(step, \"\"); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t}\n\n\tif _, err := p.expect(TokenRBrace); err != nil {\n\t\treturn nil, err\n\t}\n\n\t// Infer step type from content\n\t_, hasPrompt := step.Config[\"prompt\"]\n\t_, hasRun := step.Config[\"run\"]\n\t_, hasWorkflowName := step.Config[\"workflow_name\"]\n\n\tcount := 0\n\tif hasPrompt {\n\t\tcount++\n\t}\n\tif hasRun {\n\t\tcount++\n\t}\n\tif hasWorkflowName {\n\t\tcount++\n\t}\n\n\tif count > 1 {\n\t\treturn nil, fmt.Errorf(\"step %q has multiple of 'prompt', 'run', 'workflow_name'; must have exactly one\", step.Name)\n\t}\n\n\tswitch {\n\tcase hasPrompt:\n\t\tstep.Type = domain.StepTypeAgent\n\tcase hasRun:\n\t\tstep.Type = domain.StepTypeScript\n\tcase hasWorkflowName:\n\t\tstep.Type = domain.StepTypeWorkflow\n\tdefault:\n\t\treturn nil, fmt.Errorf(\"step %q has none of 'prompt', 'run', or 'workflow_name'; must have exactly one\", step.Name)\n\t}\n\n\treturn step, nil\n}\n\nfunc (p *Parser) parseStepField(step *domain.Step, prefix string) error {\n\tkeyTok, err := p.expect(TokenIdent)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"expected field name: %w\", err)\n\t}\n\n\tkey := keyTok.Literal\n\tif prefix != \"\" {\n\t\tkey = prefix + \".\" + key\n\t}\n\n\t// Sub-block (e.g., container { ... })\n\tif p.current.Type == TokenLBrace {\n\t\tp.advance() // consume {\n\t\tfor p.current.Type != TokenRBrace && p.current.Type != TokenEOF {\n\t\t\tif err := p.parseStepField(step, key); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t}\n\t\tp.advance() // consume }\n\t\treturn nil\n\t}\n\n\tif _, err := p.expect(TokenEquals); err != nil {\n\t\treturn err\n\t}\n\n\tif key == \"results\" {\n\t\tresults, err := p.parseIdentList()\n\t\tif err != nil {\n\t\t\treturn err\n\t\t}\n\t\tstep.Results = results\n\t} else if p.current.Type == TokenLBracket {\n\t\tvalues, err := p.parseStringList()\n\t\tif err != nil {\n\t\t\treturn err\n\t\t}\n\t\tstep.Config[key] = strings.Join(values, \",\")\n\t} else {\n\t\tval, err := p.parseValue()\n\t\tif err != nil {\n\t\t\treturn err\n\t\t}\n\t\tstep.Config[key] = val\n\t}\n\n\treturn nil\n}\n\nfunc (p *Parser) parseIdentList() ([]string, error) {\n\tif _, err := p.expect(TokenLBracket); err != nil {\n\t\treturn nil, err\n\t}\n\n\tvar items []string\n\tfor p.current.Type != TokenRBracket && p.current.Type != TokenEOF {\n\t\ttok, err := p.expect(TokenIdent)\n\t\tif err != nil {\n\t\t\