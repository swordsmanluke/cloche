[2026-03-13T19:58:53Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014FoaENZuSdN7niUx51gxAb","type":"tool_result","content":"     1→package main\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"fmt\"\n     6→\t\"net\"\n     7→\t\"net/http\"\n     8→\t\"os\"\n     9→\t\"os/signal\"\n    10→\t\"path/filepath\"\n    11→\t\"syscall\"\n    12→\n    13→\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    14→\t\"github.com/cloche-dev/cloche/internal/adapters/docker\"\n    15→\t\"github.com/cloche-dev/cloche/internal/version\"\n    16→\tadaptgrpc \"github.com/cloche-dev/cloche/internal/adapters/grpc\"\n    17→\t\"github.com/cloche-dev/cloche/internal/adapters/local\"\n    18→\t\"github.com/cloche-dev/cloche/internal/adapters/sqlite\"\n    19→\t\"github.com/cloche-dev/cloche/internal/adapters/web\"\n    20→\t\"github.com/cloche-dev/cloche/internal/config\"\n    21→\t\"github.com/cloche-dev/cloche/internal/evolution\"\n    22→\thostpkg \"github.com/cloche-dev/cloche/internal/host\"\n    23→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    24→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    25→\t\"google.golang.org/grpc\"\n    26→)\n    27→\n    28→func main() {\n    29→\tif len(os.Args) >= 2 && (os.Args[1] == \"-v\" || os.Args[1] == \"--version\") {\n    30→\t\tfmt.Printf(\"cloched %s\\n\", version.Version())\n    31→\t\treturn\n    32→\t}\n    33→\n    34→\t// Load global config file (~/.config/cloche/config)\n    35→\tglobalCfg, err := config.LoadGlobal()\n    36→\tif err != nil {\n    37→\t\tfmt.Fprintf(os.Stderr, \"warning: failed to load global config: %v\\n\", err)\n    38→\t\tdefaults := config.Config{}\n    39→\t\tglobalCfg = &defaults\n    40→\t}\n    41→\n    42→\tdbPath := envOrConfig(\"CLOCHE_DB\", globalCfg.Daemon.DB, \"cloche.db\")\n    43→\tlistenAddr := envOrConfig(\"CLOCHE_LISTEN\", globalCfg.Daemon.Listen, \"unix:///tmp/cloche.sock\")\n    44→\n    45→\tstore, err := sqlite.NewStore(dbPath)\n    46→\tif err != nil {\n    47→\t\tfmt.Fprintf(os.Stderr, \"failed to open store: %v\\n\", err)\n    48→\t\tos.Exit(1)\n    49→\t}\n    50→\tdefer store.Close()\n    51→\n    52→\t// Sweep stale runs from a previous daemon crash (pending or running with no live goroutine).\n    53→\tif n, err := store.FailStaleRuns(context.Background()); err != nil {\n    54→\t\tfmt.Fprintf(os.Stderr, \"warning: failed to sweep stale runs: %v\\n\", err)\n    55→\t} else if n > 0 {\n    56→\t\tfmt.Fprintf(os.Stderr, \"startup: marked %d stale run(s) as failed\\n\", n)\n    57→\t}\n    58→\n    59→\truntime, err := initRuntime(globalCfg)\n    60→\tif err != nil {\n    61→\t\tfmt.Fprintf(os.Stderr, \"failed to init runtime: %v\\n\", err)\n    62→\t\tos.Exit(1)\n    63→\t}\n    64→\n    65→\tdefaultImage := envOrConfig(\"CLOCHE_IMAGE\", globalCfg.Daemon.Image, \"cloche-agent:latest\")\n    66→\n    67→\tbroadcaster := logstream.NewBroadcaster()\n    68→\n    69→\tsrv := adaptgrpc.NewClocheServerWithCaptures(store, store, runtime, defaultImage)\n    70→\tsrv.SetLogStore(store)\n    71→\tsrv.SetLogBroadcaster(broadcaster)\n    72→\n    73→\t// Set up evolution trigger\n    74→\tevoTrigger := initEvolution(globalCfg, store, store)\n    75→\tif evoTrigger != nil {\n    76→\t\tsrv.SetEvolution(evoTrigger)\n    77→\t}\n    78→\n    79→\tgrpcServer := grpc.NewServer()\n    80→\tpb.RegisterClocheServiceServer(grpcServer, srv)\n    81→\n    82→\tsrv.SetShutdownFunc(func() { grpcServer.GracefulStop() })\n    83→\n    84→\tlis, err := listen(listenAddr)\n    85→\tif err != nil {\n    86→\t\tfmt.Fprintf(os.Stderr, \"failed to listen on %s: %v\\n\", listenAddr, err)\n    87→\t\tos.Exit(1)\n    88→\t}\n    89→\n    90→\tvar httpServer *http.Server\n    91→\tif httpAddr := envOrConfig(\"CLOCHE_HTTP\", globalCfg.Daemon.HTTP, \"\"); httpAddr != \"\" {\n    92→\t\twebOpts := []web.HandlerOption{\n    93→\t\t\tweb.WithContainerLogger(runtime),\n    94→\t\t\tweb.WithLogStore(store),\n    95→\t\t\tweb.WithLogBroadcaster(broadcaster),\n    96→\t\t\tweb.WithTaskProvider(srv),\n    97→\t\t}\n    98→\t\twebHandler, err := web.NewHandler(store, store, webOpts...)\n    99→\t\tif err != nil {\n   100→\t\t\tfmt.Fprintf(os.Stderr, \"failed to create web handler: %v\\n\", err)\n   101→\t\t\tos.Exit(1)\n   102→\t\t}\n   103→\t\thttpServer = &http.Server{Addr: httpAddr, Handler: webHandler}\n   104→\t\tgo func() {\n   105→\t\t\tfmt.Fprintf(os.Stderr, \"cloched web dashboard on http://%s\\n\", httpAddr)\n   106→\t\t\tif err := httpServer.ListenAndServe(); err != nil && err != http.ErrServerClosed {\n   107→\t\t\t\tfmt.Fprintf(os.Stderr, \"http server error: %v\\n\", err)\n   108→\t\t\t}\n   109→\t\t}()\n   110→\t}\n   111→\n   112→\t// Auto-execute main workflow for active projects\n   113→\tautoRunActiveProjects(store, srv)\n   114→\n   115→\tsigCh := make(chan os.Signal, 1)\n   116→\tsignal.Notify(sigCh, syscall.SIGTERM, syscall.SIGINT)\n   117→\tgo func() {\n   118→\t\t<-sigCh\n   119→\t\tif httpServer != nil {\n   120→\t\t\thttpServer.Close()\n   121→\t\t}\n   122→\t\tgrpcServer.GracefulStop()\n   123→\t}()\n   124→\n   125→\tfmt.Fprintf(os.Stderr, \"cloched listening on %s\\n\", listenAddr)\n   126→\tif err := grpcServer.Serve(lis); err != nil {\n   127→\t\tfmt.Fprintf(os.Stderr, \"server error: %v\\n\", err)\n   128→\t\tos.Exit(1)\n   129→\t}\n   130→}\n   131→\n   132→func initRuntime(cfg *config.Config) (ports.ContainerRuntime, error) {\n   133→\truntimeType := envOrConfig(\"CLOCHE_RUNTIME\", cfg.Daemon.Runtime, \"docker\")\n   134→\n   135→\tswitch runtimeType {\n   136→\tcase \"local\":\n   137→\t\tagentPath := envOrConfig(\"CLOCHE_AGENT_PATH\", cfg.Daemon.AgentPath, \"\")\n   138→\t\tif agentPath == \"\" {\n   139→\t\t\t// Look for cloche-agent next to this binary\n   140→\t\t\texe, err := os.Executable()\n   141→\t\t\tif err == nil {\n   142→\t\t\t\tagentPath = filepath.Join(filepath.Dir(exe), \"cloche-agent\")\n   143→\t\t\t} else {\n   144→\t\t\t\tagentPath = \"cloche-agent\"\n   145→\t\t\t}\n   146→\t\t}\n   147→\t\treturn local.NewRuntime(agentPath), nil\n   148→\tcase \"docker\":\n   149→\t\treturn docker.NewRuntime()\n   150→\tdefault:"}]},"parent_tool_use_id":"toolu_013Y5EJhPZgAJrRFK4ZZsW2U","session_id":"96f32727-3069-4902-8837-5bfcf44ab35e","uuid":"8d93949f-145a-419d-9883-e3baf17a7433"}
