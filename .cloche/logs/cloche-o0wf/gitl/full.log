Add(5 * time.Second)\n  1259→\tfor time.Now().Before(deadline) {\n  1260→\t\tstatus, err := srv.GetStatus(context.Background(), &pb.GetStatusRequest{RunId: resp.RunId})\n  1261→\t\trequire.NoError(t, err)\n  1262→\t\tif status.State == \"succeeded\" {\n  1263→\t\t\tbreak\n  1264→\t\t}\n  1265→\t\ttime.Sleep(50 * time.Millisecond)\n  1266→\t}\n  1267→\ttime.Sleep(500 * time.Millisecond)\n  1268→\n  1269→\t// StreamLogs with step filter should return only that step's logs\n  1270→\tmock := &mockLogStream{ctx: context.Background()}\n  1271→\terr = srv.StreamLogs(&pb.StreamLogsRequest{\n  1272→\t\tRunId:    resp.RunId,\n  1273→\t\tStepName: \"build\",\n  1274→\t}, mock)\n  1275→\trequire.NoError(t, err)\n  1276→\tassert.GreaterOrEqual(t, len(mock.entries), 1, \"should have at least one entry for build step\")\n  1277→\n  1278→\t// All entries should be about the build step\n  1279→\tfor _, e := range mock.entries {\n  1280→\t\tif e.StepName != \"\" {\n  1281→\t\t\tassert.Equal(t, \"build\", e.StepName, \"filtered output should only contain build step\")\n  1282→\t\t}\n  1283→\t}\n  1284→\n  1285→\t// StreamLogs with type filter\n  1286→\tmock2 := &mockLogStream{ctx: context.Background()}\n  1287→\terr = srv.StreamLogs(&pb.StreamLogsRequest{\n  1288→\t\tRunId:    resp.RunId,\n  1289→\t\tStepName: \"build\",\n  1290→\t\tLogType:  \"llm\",\n  1291→\t}, mock2)\n  1292→\trequire.NoError(t, err)\n  1293→\tassert.GreaterOrEqual(t, len(mock2.entries), 1, \"should have at least one LLM log entry\")\n  1294→\n  1295→\tfor _, e := range mock2.entries {\n  1296→\t\tif e.Message != \"\" {\n  1297→\t\t\tassert.Contains(t, e.Message, \"llm conversation\", \"should contain LLM output\")\n  1298→\t\t}\n  1299→\t}"}]},"parent_tool_use_id":null,"session_id":"96f32727-3069-4902-8837-5bfcf44ab35e","uuid":"cda749ae-59d8-42e4-b0cd-7d80e6ac1478","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/grpc/server_test.go","content":"func TestServer_StreamLogs_StepFilte