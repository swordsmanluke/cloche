[2026-03-13T19:58:53Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01MijccK3dhBCXfxygz6Kbbf","type":"tool_result","content":"     1→package grpc\n     2→\n     3→import (\n     4→\t\"bufio\"\n     5→\t\"context\"\n     6→\t\"encoding/json\"\n     7→\t\"fmt\"\n     8→\t\"log\"\n     9→\t\"os\"\n    10→\t\"os/exec\"\n    11→\t\"path/filepath\"\n    12→\t\"sort\"\n    13→\t\"strings\"\n    14→\t\"sync\"\n    15→\t\"time\"\n    16→\n    17→\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    18→\t\"github.com/cloche-dev/cloche/internal/adapters/docker\"\n    19→\t\"github.com/cloche-dev/cloche/internal/adapters/web\"\n    20→\t\"github.com/cloche-dev/cloche/internal/config\"\n    21→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    22→\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    23→\t\"github.com/cloche-dev/cloche/internal/evolution\"\n    24→\t\"github.com/cloche-dev/cloche/internal/host\"\n    25→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    26→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    27→\t\"github.com/cloche-dev/cloche/internal/protocol\"\n    28→\t\"github.com/cloche-dev/cloche/internal/version\"\n    29→\trpcgrpc \"google.golang.org/grpc\"\n    30→\t\"google.golang.org/grpc/metadata\"\n    31→)\n    32→\n    33→type ClocheServer struct {\n    34→\tpb.UnimplementedClocheServiceServer\n    35→\tstore        ports.RunStore\n    36→\tcaptures     ports.CaptureStore\n    37→\tlogStore     ports.LogStore\n    38→\tcontainer    ports.ContainerRuntime\n    39→\tdefaultImage string\n    40→\tevolution    *evolution.Trigger\n    41→\tlogBroadcast *logstream.Broadcaster\n    42→\tshutdownFn   func()\n    43→\tmu           sync.Mutex\n    44→\trunIDs       map[string]string      // run_id -> container_id\n    45→\tloops        map[string]*host.Loop  // project_dir -> orchestration loop\n    46→}\n    47→\n    48→func NewClocheServer(store ports.RunStore, container ports.ContainerRuntime) *ClocheServer {\n    49→\treturn &ClocheServer{\n    50→\t\tstore:     store,\n    51→\t\tcontainer: container,\n    52→\t\trunIDs:    make(map[string]string),\n    53→\t\tloops:     make(map[string]*host.Loop),\n    54→\t}\n    55→}\n    56→\n    57→func NewClocheServerWithCaptures(store ports.RunStore, captures ports.CaptureStore, container ports.ContainerRuntime, defaultImage string) *ClocheServer {\n    58→\treturn &ClocheServer{\n    59→\t\tstore:        store,\n    60→\t\tcaptures:     captures,\n    61→\t\tcontainer:    container,\n    62→\t\tdefaultImage: defaultImage,\n    63→\t\trunIDs:       make(map[string]string),\n    64→\t\tloops:        make(map[string]*host.Loop),\n    65→\t}\n    66→}\n    67→\n    68→// SetLogStore attaches a log store to the server for indexing extracted log files.\n    69→func (s *ClocheServer) SetLogStore(ls ports.LogStore) {\n    70→\ts.logStore = ls\n    71→}\n    72→\n    73→\n    74→// SetEvolution attaches an evolution trigger to the server.\n    75→func (s *ClocheServer) SetEvolution(trigger *evolution.Trigger) {\n    76→\ts.evolution = trigger\n    77→}\n    78→\n    79→// SetLogBroadcaster attaches a log broadcaster for live-streaming LLM output.\n    80→func (s *ClocheServer) SetLogBroadcaster(b *logstream.Broadcaster) {\n    81→\ts.logBroadcast = b\n    82→}\n    83→\n    84→// SetShutdownFunc sets the callback invoked when the Shutdown RPC is called.\n    85→func (s *ClocheServer) SetShutdownFunc(fn func()) {\n    86→\ts.shutdownFn = fn\n    87→}\n    88→\n    89→func (s *ClocheServer) RunWorkflow(ctx context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error) {\n    90→\tif s.container == nil {\n    91→\t\treturn nil, fmt.Errorf(\"no container runtime configured\")\n    92→\t}\n    93→\n    94→\t// Generate a unique run ID, retrying on collision\n    95→\tvar runID string\n    96→\tfor attempts := 0; attempts < 10; attempts++ {\n    97→\t\trunID = domain.GenerateRunID(req.WorkflowName)\n    98→\t\texisting, err := s.store.GetRun(ctx, runID)\n    99→\t\tif err != nil {\n   100→\t\t\tbreak // ID is free\n   101→\t\t}\n   102→\t\t// Reuse if completed more than 1 hour ago\n   103→\t\tif !existing.CompletedAt.IsZero() && time.Since(existing.CompletedAt) > time.Hour {\n   104→\t\t\t_ = s.store.DeleteRun(ctx, runID)\n   105→\t\t\tbreak\n   106→\t\t}\n   107→\t}\n   108→\n   109→\t// Write prompt to .cloche/<run-id>/prompt.txt (run-specific to avoid conflicts)\n   110→\tif req.Prompt != \"\" {\n   111→\t\tclocheDir := filepath.Join(req.ProjectDir, \".cloche\", runID)\n   112→\t\tif err := os.MkdirAll(clocheDir, 0755); err != nil {\n   113→\t\t\treturn nil, fmt.Errorf(\"creating .cloche dir: %w\", err)\n   114→\t\t}\n   115→\t\tif err := os.WriteFile(filepath.Join(clocheDir, \"prompt.txt\"), []byte(req.Prompt), 0644); err != nil {\n   116→\t\t\treturn nil, fmt.Errorf(\"writing prompt: %w\", err)\n   117→\t\t}\n   118→\t}\n   119→\trun := domain.NewRun(runID, req.WorkflowName)\n   120→\trun.ProjectDir = req.ProjectDir\n   121→\trun.Title = req.Title\n   122→\tif err := s.store.CreateRun(ctx, run); err != nil {\n   123→\t\treturn nil, fmt.Errorf(\"creating run: %w\", err)\n   124→\t}\n   125→\n   126→\t// Resolve image: request-level override, then server default\n   127→\timage := req.Image\n   128→\tif image == \"\" {\n   129→\t\timage = s.defaultImage\n   130→\t}\n   131→\n   132→\t// Launch container start + tracking in background so the RPC returns immediately.\n   133→\t// The run stays in \"pending\" state until the container is up.\n   134→\tgo s.launchAndTrack(runID, image, req.KeepContainer, req)\n   135→\n   136→\treturn &pb.RunWorkflowResponse{RunId: runID}, nil\n   137→}\n   138→\n   139→// launchAndTrack starts the container and then tracks it to completion.\n   140→// It runs in a background goroutine with its own context, independent of the\n   141→// RPC context which may be cancelled after RunWorkflow returns.\n   142→func (s *ClocheServer) launchAndTrack(runID, image string, keepContainer bool, req *pb.RunWorkflowRequest) {\n   143→\tctx := context.Background()\n   144→\n   145→\t// Auto-rebuild image if the project Dockerfile has changed since last build.\n   146→\tif ensurer, ok := s.container.(ports.ImageEnsurer); ok {\n   147→\t\tif err := ensurer.EnsureImage(ctx, req.ProjectDir, image); err != nil {\n   148→\t\t\trun, _ := s.store.GetRun(ctx, runID)\n   149→\t\t\tif run != nil {\n   150→\t\t\t\trun.Fail(fmt.Sprintf(\"failed to ensure image: %v\", err))\n   151→\t\t\t\t_ = s.store.UpdateRun(ctx, run)\n   152→\t\t\t}\n   153→\t\t\tlog.Printf(\"run %s: failed to ensure image: %v\", runID, err)\n   154→\t\t\t\treturn\n   155→\t\t}\n   156→\t}\n   157→\n   158→\tbaseSHA := gitHEAD(req.ProjectDir)\n   159→\n   160→\tcontainerID, err := s.container.Start(ctx, ports.ContainerConfig{\n   161→\t\tImage:        image,\n   162→\t\tWorkflowName: req.WorkflowName,\n   163→\t\tProjectDir:   req.ProjectDir,\n   164→\t\tRunID:        runID,\n   165→\t\tNetworkAllow: []string{\"*\"},\n   166→\t})\n   167→\tif err != nil {\n   168→\t\trun, _ := s.store.GetRun(ctx, runID)\n   169→\t\tif run != nil {\n   170→\t\t\trun.Fail(fmt.Sprintf(\"failed to start container: %v\", err))\n   171→\t\t\t_ = s.store.UpdateRun(ctx, run)\n   172→\t\t}\n   173→\t\tlog.Printf(\"run %s: failed to start container: %v\", runID, err)\n   174→\t\treturn\n   175→\t}\n   176→\n   177→\ts.mu.Lock()\n   178→\ts.runIDs[runID] = containerID\n   179→\ts.mu.Unlock()\n   180→\n   181→\trun, _ := s.store.GetRun(ctx, runID)\n   182→\tif run != nil {\n   183→\t\trun.Start()\n   184→\t\trun.ContainerID = containerID\n   185→\t\trun.BaseSHA = baseSHA\n   186→\t\t_ = s.store.UpdateRun(ctx, run)\n   187→\t}\n   188→\n   189→\ts.trackRun(runID, containerID, req.ProjectDir, req.WorkflowName, keepContainer)\n   190→}\n   191→\n   192→func (s *ClocheServer) trackRun(runID, containerID, projectDir, workflowName string, keepContainer bool) {\n   193→\tctx := context.Background()\n   194→\n   195→\t// Attach to agent output\n   196→\treader, err := s.container.AttachOutput(ctx, containerID)\n   197→\tif err != nil {\n   198→\t\tlog.Printf(\"failed to attach to output for run %s: %v\", runID, err)\n   199→\t\t\treturn\n   200→\t}\n   201→\n   202→\t// Parse JSON-lines status messages\n   203→\tvar reportedResult string // captured from MsgRunCompleted, persisted after branch extraction\n   204→\tvar reportedError string  // captured from MsgError, used to set ErrorMessage on failed runs\n   205→\tscanner := bufio.NewScanner(reader)\n   206→\tscanner.Buffer(make([]byte, 0, 256*1024), 1024*1024) // 1MB max to handle large log messages\n   207→\tfor scanner.Scan() {\n   208→\t\tvar msg protocol.StatusMessage\n   209→\t\tif err := json.Unmarshal(scanner.Bytes(), &msg); err != nil {\n   210→\t\t\tcontinue\n   211→\t\t}\n   212→\n   213→\t\t// Fast path: log messages don't need store interaction.\n   214→\t\tif msg.Type == protocol.MsgLog {\n   215→\t\t\tif s.logBroadcast != nil {\n   216→\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n   217→\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n   218→\t\t\t\t\tType:      \"llm\",\n   219→\t\t\t\t\tContent:   msg.Message,\n   220→\t\t\t\t\tStepName:  msg.StepName,\n   221→\t\t\t\t})\n   222→\t\t\t}\n   223→\t\t\tcontinue\n   224→\t\t}\n   225→\n   226→\t\trun, err := s.store.GetRun(ctx, runID)\n   227→\t\tif err != nil {\n   228→\t\t\tcontinue\n   229→\t\t}\n   230→\n   231→\t\tswitch msg.Type {\n   232→\t\tcase protocol.MsgStepStarted:\n   233→\t\t\trun.RecordStepStart(msg.StepName)\n   234→\t\t\tif s.captures != nil {\n   235→\t\t\t\t_ = s.captures.SaveCapture(ctx, runID, &domain.StepExecution{\n   236→\t\t\t\t\tStepName:  msg.StepName,\n   237→\t\t\t\t\tStartedAt: msg.Timestamp,\n   238→\t\t\t\t})\n   239→\t\t\t}\n   240→\t\t\tif s.logBroadcast != nil {\n   241→\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n   242→\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n   243→\t\t\t\t\tType:      \"status\",\n   244→\t\t\t\t\tContent:   \"step_started: \" + msg.StepName,\n   245→\t\t\t\t\tStepName:  msg.StepName,\n   246→\t\t\t\t})\n   247→\t\t\t}\n   248→\t\tcase protocol.MsgStepCompleted:\n   249→\t\t\trun.RecordStepComplete(msg.StepName, msg.Result)\n   250→\t\t\tif s.captures != nil {\n   251→\t\t\t\t_ = s.captures.SaveCapture(ctx, runID, &domain.StepExecution{\n   252→\t\t\t\t\tStepName:    msg.StepName,\n   253→\t\t\t\t\tResult:      msg.Result,\n   254→\t\t\t\t\tCompletedAt: msg.Timestamp,\n   255→\t\t\t\t})\n   256→\t\t\t}\n   257→\t\t\tif s.logBroadcast != nil {\n   258→\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n   259→\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n   260→\t\t\t\t\tType:      \"status\",\n   261→\t\t\t\t\tContent:   \"step_completed: \" + msg.StepName + \" -> \" + msg.Result,\n   262→\t\t\t\t\tStepName:  msg.StepName,\n   263→\t\t\t\t})\n   264→\t\t\t}\n   265→\t\tcase protocol.MsgRunTitle:\n   266→\t\t\tif run.Title == \"\" {\n   267→\t\t\t\trun.Title = msg.Message\n   268→\t\t\t}\n   269→\t\tcase protocol.MsgError:\n   270→\t\t\treportedError = msg.Message\n   271→\t\t\tcontinue // Don't persist; used during finalization\n   272→\t\tcase protocol.MsgRunCompleted:\n   273→\t\t\treportedResult = msg.Result\n   274→\t\t\tcontinue // Don't persist terminal state yet; branch extraction must finish first\n   275→\t\t}\n   276→\n   277→\t\t_ = s.store.UpdateRun(ctx, run)\n   278→\t}\n   279→\treader.Close()\n   280→\n   281→\t// Signal live-stream subscribers that this run is done.\n   282→\tif s.logBroadcast != nil {\n   283→\t\ts.logBroadcast.Finish(runID)\n   284→\t}\n   285→\n   286→\t// Wait for process exit\n   287→\texitCode, err := s.container.Wait(ctx, containerID)\n   288→\tif err != nil {\n   289→\t\tlog.Printf(\"error waiting for run %s: %v\", runID, err)\n   290→\t}\n   291→\n   292→\t// Extract step output files from container before it's removed\n   293→\toutputDst := filepath.Join(projectDir, \".cloche\", runID, \"output\")\n   294→\tif err := os.MkdirAll(outputDst, 0755); err == nil {\n   295→\t\tif cpErr := s.container.CopyFrom(ctx, containerID, \"/workspace/.cloche/output/.\", outputDst); cpErr != nil {\n   296→\t\t\tlog.Printf(\"run %s: failed to extract output: %v\", runID, cpErr)\n   297→\t\t}\n   298→\t}\n   299→\n   300→\t// Capture full container stdout/stderr before the container is removed\n   301→\tif logs, logErr := s.container.Logs(ctx, containerID); logErr == nil && logs != \"\" {\n   302→\t\tcontainerLogPath := filepath.Join(outputDst, \"container.log\")\n   303→\t\tif writeErr := os.WriteFile(containerLogPath, []byte(logs), 0644); writeErr != nil {\n   304→\t\t\tlog.Printf(\"run %s: failed to write container.log: %v\", runID, writeErr)\n   305→\t\t}\n   306→\t}\n   307→\n   308→\t// Index extracted log files in the log store\n   309→\tif s.logStore != nil {\n   310→\t\ts.indexLogFiles(ctx, runID, outputDst)\n   311→\t}\n   312→\n   313→\t// Extract results to git branch BEFORE finalizing state, so that\n   314→\t// WaitRun callers (e.g. host workflow merge step) see branches exist\n   315→\t// before the run is marked complete.\n   316→\tresultLabel := reportedResult\n   317→\tif resultLabel == \"\" {\n   318→\t\tif exitCode == 0 {\n   319→\t\t\tresultLabel = \"succeeded\"\n   320→\t\t} else {\n   321→\t\t\tresultLabel = \"failed\"\n   322→\t\t}\n   323→\t}\n   324→\t{\n   325→\t\textractRun, _ := s.store.GetRun(ctx, runID)\n   326→\t\tif extractRun != nil && extractRun.BaseSHA != \"\" {\n   327→\t\t\tlog.Printf(\"run %s: extracting results to branch cloche/%s (baseSHA=%s)\", runID, runID, extractRun.BaseSHA)\n   328→\t\t\tif err := docker.ExtractResults(ctx, containerID, extractRun.ProjectDir, runID, extractRun.BaseSHA, workflowName, resultLabel); err != nil {\n   329→\t\t\t\tlog.Printf(\"run %s: failed to extract results to branch: %v\", runID, err)\n   330→\t\t\t} else {\n   331→\t\t\t\tlog.Printf(\"run %s: branch cloche/%s created successfully\", runID, runID)\n   332→\t\t\t}\n   333→\t\t} else {\n   334→\t\t\tlog.Printf(\"run %s: skipping branch extraction (baseSHA empty or run not found)\", runID)\n   335→\t\t}\n   336→\t}\n   337→\n   338→\t// Now finalize run state\n   339→\trun, err := s.store.GetRun(ctx, runID)\n   340→\tif err != nil {\n   341→\t\treturn\n   342→\t}\n   343→\tif run.State == domain.RunStateRunning {\n   344→\t\tif reportedResult == \"succeeded\" {\n   345→\t\t\trun.Complete(domain.RunStateSucceeded)\n   346→\t\t} else if reportedResult != \"\" {\n   347→\t\t\tif reportedError != \"\" {\n   348→\t\t\t\trun.Fail(reportedError)\n   349→\t\t\t} else {\n   350→\t\t\t\trun.Complete(domain.RunStateFailed)\n   351→\t\t\t}\n   352→\t\t} else if exitCode == 0 {\n   353→\t\t\trun.Complete(domain.RunStateSucceeded)\n   354→\t\t} else {\n   355→\t\t\trun.Fail(fmt.Sprintf(\"container exited with code %d\", exitCode))\n   356→\t\t}\n   357→\t\t_ = s.store.UpdateRun(ctx, run)\n   358→\t}\n   359→\n   360→\t// Fire evolution trigger if configured\n   361→\tif s.evolution != nil {\n   362→\t\ts.evolution.Fire(projectDir, workflowName, runID)\n   363→\t}\n   364→\n   365→\t// Merge is handled as a workflow step in host.cloche, not here.\n   366→\n   367→\t// Container retention policy:\n   368→\t// - Failed runs: always keep the container for debugging\n   369→\t// - Successful runs + --keep-container: keep the container\n   370→\t// - Successful runs without --keep-container: remove the container\n   371→\trunFinal, _ := s.store.GetRun(ctx, runID)\n   372→\trunFailed := runFinal != nil && (runFinal.State == domain.RunStateFailed || runFinal.State == domain.RunStateCancelled)\n   373→\n   374→\tif keepContainer || runFailed {\n   375→\t\treason := \"--keep-container\"\n   376→\t\tif runFailed {\n   377→\t\t\treason = \"run failed\"\n   378→\t\t}\n   379→\t\tlog.Printf(\"run %s: keeping container %s (%s)\", runID, containerID, reason)\n   380→\t\tif runFinal != nil {\n   381→\t\t\trunFinal.ContainerKept = true\n   382→\t\t\t_ = s.store.UpdateRun(ctx, runFinal)\n   383→\t\t}\n   384→\t} else {\n   385→\t\tif err := s.container.Remove(ctx, containerID); err != nil {\n   386→\t\t\tlog.Printf(\"run %s: failed to remove container %s: %v\", runID, containerID, err)\n   387→\t\t} else {\n   388→\t\t\tlog.Printf(\"run %s: removed container %s\", runID, containerID)\n   389→\t\t}\n   390→\t}\n   391→\n   392→\t// Cleanup mapping\n   393→\ts.mu.Lock()\n   394→\tdelete(s.runIDs, runID)\n   395→\ts.mu.Unlock()\n   396→}\n   397→\n   398→func (s *ClocheServer) ListRuns(ctx context.Context, req *pb.ListRunsRequest) (*pb.ListRunsResponse, error) {\n   399→\tfilter := domain.RunListFilter{\n   400→\t\tProjectDir: req.ProjectDir,\n   401→\t\tState:      domain.RunState(req.State),\n   402→\t\tTaskID:     req.TaskId,\n   403→\t\tLimit:      int(req.Limit),\n   404→\t}\n   405→\n   406→\t// When no project filter and not --all, default to last hour\n   407→\tif filter.ProjectDir == \"\" && !req.All {\n   408→\t\tfilter.Since = time.Now().Add(-1 * time.Hour)\n   409→\t}\n   410→\n   411→\truns, err := s.store.ListRunsFiltered(ctx, filter)\n   412→\tif err != nil {\n   413→\t\treturn nil, fmt.Errorf(\"listing runs: %w\", err)\n   414→\t}\n   415→\n   416→\tresp := &pb.ListRunsResponse{}\n   417→\tfor _, run := range runs {\n   418→\t\tresp.Runs = append(resp.Runs, &pb.RunSummary{\n   419→\t\t\tRunId:        run.ID,\n   420→\t\t\tWorkflowName: run.WorkflowName,\n   421→\t\t\tState:        string(run.State),\n   422→\t\t\tStartedAt:    run.StartedAt.String(),\n   423→\t\t\tErrorMessage: run.ErrorMessage,\n   424→\t\t\tContainerId:  run.ContainerID,\n   425→\t\t\tTitle:        run.Title,\n   426→\t\t\tIsHost:       run.IsHost,\n   427→\t\t\tProjectDir:   run.ProjectDir,\n   428→\t\t})\n   429→\t}\n   430→\treturn resp, nil\n   431→}\n   432→\n   433→func (s *ClocheServer) GetStatus(ctx context.Context, req *pb.GetStatusRequest) (*pb.GetStatusResponse, error) {\n   434→\trun, err := s.store.GetRun(ctx, req.RunId)\n   435→\tif err != nil {\n   436→\t\treturn nil, fmt.Errorf(\"getting run: %w\", err)\n   437→\t}\n   438→\n   439→\tresp := &pb.GetStatusResponse{\n   440→\t\tRunId:        run.ID,\n   441→\t\tWorkflowName: run.WorkflowName,\n   442→\t\tState:        string(run.State),\n   443→\t\tCurrentStep:  strings.Join(run.ActiveSteps, \",\"),\n   444→\t\tErrorMessage: run.ErrorMessage,\n   445→\t\tContainerId:  run.ContainerID,\n   446→\t\tTitle:        run.Title,\n   447→\t\tIsHost:       run.IsHost,\n   448→\t}\n   449→\n   450→\t// Check container liveness\n   451→\tif run.ContainerID != \"\" && s.container != nil {\n   452→\t\tif cs, err := s.container.Inspect(ctx, run.ContainerID); err == nil {\n   453→\t\t\tresp.ContainerAlive = cs.Running\n   454→\t\t\tif !cs.Running && !cs.FinishedAt.IsZero() {\n   455→\t\t\t\tresp.ContainerDeadSince = cs.FinishedAt.Format(time.RFC3339Nano)\n   456→\t\t\t}\n   457→\t\t}\n   458→\t}\n   459→\n   460→\t// Load step executions from captures store if available\n   461→\tif s.captures != nil {\n   462→\t\tcaptures, err := s.captures.GetCaptures(ctx, req.RunId)\n   463→\t\tif err == nil {\n   464→\t\t\tfor _, exec := range captures {\n   465→\t\t\t\tresp.StepExecutions = append(resp.StepExecutions, &pb.StepExecutionStatus{\n   466→\t\t\t\t\tStepName:    exec.StepName,\n   467→\t\t\t\t\tResult:      exec.Result,\n   468→\t\t\t\t\tStartedAt:   exec.StartedAt.String(),\n   469→\t\t\t\t\tCompletedAt: exec.CompletedAt.String(),\n   470→\t\t\t\t})\n   471→\t\t\t}\n   472→\t\t}\n   473→\t} else {\n   474→\t\tfor _, exec := range run.StepExecutions {\n   475→\t\t\tresp.StepExecutions = append(resp.StepExecutions, &pb.StepExecutionStatus{\n   476→\t\t\t\tStepName:    exec.StepName,\n   477→\t\t\t\tResult:      exec.Result,\n   478→\t\t\t\tStartedAt:   exec.StartedAt.String(),\n   479→\t\t\t\tCompletedAt: exec.CompletedAt.String(),\n   480→\t\t\t})\n   481→\t\t}\n   482→\t}\n   483→\n   484→\treturn resp, nil\n   485→}\n   486→\n   487→func (s *ClocheServer) StreamLogs(req *pb.StreamLogsRequest, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n   488→\tctx := stream.Context()\n   489→\n   490→\t// Check for follow mode via gRPC metadata.\n   491→\tfollow := followFromContext(ctx)\n   492→\n   493→\t// Verify run exists\n   494→\trun, err := s.store.GetRun(ctx, req.RunId)\n   495→\tif err != nil {\n   496→\t\treturn fmt.Errorf(\"run %q not found: %w\", req.RunId, err)\n   497→\t}\n   498→\n   499→\t// If step_name or log_type filter is set, serve content directly from the log index\n   500→\tif req.StepName != \"\" || req.LogType != \"\" {\n   501→\t\treturn s.streamFilteredLogs(ctx, req, run, stream)\n   502→\t}\n   503→\n   504→\tisActive := run.State == domain.RunStateRunning || run.State == domain.RunStatePending\n   505→\n   506→\t// With -f on an active run: send existing logs then tail live output.\n   507→\tif follow && isActive && s.logBroadcast != nil {\n   508→\t\treturn s.streamFollowLogs(req.RunId, run, stream)\n   509→\t}\n   510→\n   511→\t// Without -f on an active run: snapshot existing logs and return.\n   512→\t// (Legacy callers that relied on implicit live streaming should use -f.)\n   513→\t// With -f on a completed run: same as without -f — no new lines will arrive.\n   514→\n   515→\t// Check for full.log first — if it exists, serve it as the unified log\n   516→\tfullLogPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", \"full.log\")\n   517→\tif data, readErr := os.ReadFile(fullLogPath); readErr == nil && len(data) > 0 {\n   518→\t\tif err := stream.Send(&pb.LogEntry{\n   519→\t\t\tType:    \"full_log\",\n   520→\t\t\tMessage: string(data),\n   521→\t\t}); err != nil {\n   522→\t\t\treturn err\n   523→\t\t}\n   524→\t\tif !isActive {\n   525→\t\t\tif err := stream.Send(&pb.LogEntry{\n   526→\t\t\t\tType:      \"run_completed\",\n   527→\t\t\t\tResult:    string(run.State),\n   528→\t\t\t\tTimestamp: run.CompletedAt.String(),\n   529→\t\t\t\tMessage:   run.ErrorMessage,\n   530→\t\t\t}); err != nil {\n   531→\t\t\t\treturn err\n   532→\t\t\t}\n   533→\t\t}\n   534→\t\treturn nil\n   535→\t}\n   536→\n   537→\tif s.captures == nil {\n   538→\t\treturn fmt.Errorf(\"captures store not configured\")\n   539→\t}\n   540→\n   541→\t// Fall back to capture-based streaming\n   542→\tcaptures, err := s.captures.GetCaptures(ctx, req.RunId)\n   543→\tif err != nil {\n   544→\t\treturn fmt.Errorf(\"getting captures: %w\", err)\n   545→\t}\n   546→\n   547→\tfor _, exec := range captures {\n   548→\t\t// Captures are stored as separate rows: one for step_started (no Result)\n   549→\t\t// and one for step_completed (has Result).\n   550→\t\tif exec.Result == \"\" {\n   551→\t\t\tentry := &pb.LogEntry{\n   552→\t\t\t\tType:      \"step_started\",\n   553→\t\t\t\tStepName:  exec.StepName,\n   554→\t\t\t\tTimestamp: exec.StartedAt.String(),\n   555→\t\t\t}\n   556→\t\t\tif err := stream.Send(entry); err != nil {\n   557→\t\t\t\treturn err\n   558→\t\t\t}\n   559→\t\t} else {\n   560→\t\t\t// Read step output from per-step output file.\n   561→\t\t\t// Container runs write .log, host runs write .out — try both.\n   562→\t\t\tvar output string\n   563→\t\t\tfor _, ext := range []string{\".log\", \".out\"} {\n   564→\t\t\t\toutputPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", exec.StepName+ext)\n   565→\t\t\t\tif data, err := os.ReadFile(outputPath); err == nil && len(data) > 0 {\n   566→\t\t\t\t\toutput = string(data)\n   567→\t\t\t\t\tbreak\n   568→\t\t\t\t}\n   569→\t\t\t}\n   570→\t\t\tentry := &pb.LogEntry{\n   571→\t\t\t\tType:      \"step_completed\",\n   572→\t\t\t\tStepName:  exec.StepName,\n   573→\t\t\t\tResult:    exec.Result,\n   574→\t\t\t\tTimestamp: exec.CompletedAt.String(),\n   575→\t\t\t\tMessage:   output,\n   576→\t\t\t}\n   577→\t\t\tif err := stream.Send(entry); err != nil {\n   578→\t\t\t\treturn err\n   579→\t\t\t}\n   580→\t\t}\n   581→\t}\n   582→\n   583→\t// Send run completion entry\n   584→\tif !isActive {\n   585→\t\tif err := stream.Send(&pb.LogEntry{\n   586→\t\t\tType:      \"run_completed\",\n   587→\t\t\tResult:    string(run.State),\n   588→\t\t\tTimestamp: run.CompletedAt.String(),\n   589→\t\t\tMessage:   run.ErrorMessage,\n   590→\t\t}); err != nil {\n   591→\t\t\treturn err\n   592→\t\t}\n   593→\t}\n   594→\n   595→\treturn nil\n   596→}\n   597→\n   598→// followFromContext checks for the follow flag in gRPC metadata.\n   599→func followFromContext(ctx context.Context) bool {\n   600→\tmd, ok := metadata.FromIncomingContext(ctx)\n   601→\tif !ok {\n   602→\t\treturn false\n   603→\t}\n   604→\tvals := md.Get(\"x-cloche-follow\")\n   605→\treturn len(vals) > 0 && vals[0] == \"true\"\n   606→}\n   607→\n   608→// streamFollowLogs sends existing log content then tails live output from the\n   609→// broadcaster. It combines snapshot + live streaming (like tail -f).\n   610→func (s *ClocheServer) streamFollowLogs(runID string, run *domain.Run, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n   611→\t// Subscribe first so we don't miss lines written between read and subscribe.\n   612→\tsub := s.logBroadcast.Subscribe(runID)\n   613→\tdefer s.logBroadcast.Unsubscribe(runID, sub)\n   614→\n   615→\t// Send existing full.log content if available.\n   616→\tfullLogPath := filepath.Join(run.ProjectDir, \".cloche\", runID, \"output\", \"full.log\")\n   617→\tif data, err := os.ReadFile(fullLogPath); err == nil && len(data) > 0 {\n   618→\t\tif err := stream.Send(&pb.LogEntry{\n   619→\t\t\tType:    \"full_log\",\n   620→\t\t\tMessage: string(data),\n   621→\t\t}); err != nil {\n   622→\t\t\treturn err\n   623→\t\t}\n   624→\t}\n   625→\n   626→\t// Now tail live output from the broadcaster.\n   627→\tctx := stream.Context()\n   628→\tfor {\n   629→\t\tselect {\n   630→\t\tcase <-ctx.Done():\n   631→\t\t\treturn ctx.Err()\n   632→\t\tcase line, ok := <-sub.C:\n   633→\t\t\tif !ok {\n   634→\t\t\t\t// Run completed — send terminal entry.\n   635→\t\t\t\tr, err := s.store.GetRun(context.Background(), runID)\n   636→\t\t\t\tif err == nil && r.State != domain.RunStateRunning && r.State != domain.RunStatePending {\n   637→\t\t\t\t\t_ = stream.Send(&pb.LogEntry{\n   638→\t\t\t\t\t\tType:      \"run_completed\",\n   639→\t\t\t\t\t\tResult:    string(r.State),\n   640→\t\t\t\t\t\tTimestamp: r.CompletedAt.String(),\n   641→\t\t\t\t\t\tMessage:   r.ErrorMessage,\n   642→\t\t\t\t\t})\n   643→\t\t\t\t}\n   644→\t\t\t\treturn nil\n   645→\t\t\t}\n   646→\t\t\tif err := stream.Send(&pb.LogEntry{\n   647→\t\t\t\tType:      \"log\",\n   648→\t\t\t\tStepName:  line.StepName,\n   649→\t\t\t\tMessage:   line.Content,\n   650→\t\t\t\tTimestamp: line.Timestamp,\n   651→\t\t\t}); err != nil {\n   652→\t\t\t\treturn err\n   653→\t\t\t}\n   654→\t\t}\n   655→\t}\n   656→}\n   657→\n   658→// streamFilteredLogs serves log content filtered by step name and/or log type.\n   659→// It uses the log index when available, falling back to file path conventions.\n   660→func (s *ClocheServer) streamFilteredLogs(ctx context.Context, req *pb.StreamLogsRequest, run *domain.Run, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n   661→\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\")\n   662→\n   663→\t// Try log index first\n   664→\tif s.logStore != nil {\n   665→\t\tvar logFiles []*ports.LogFileEntry\n   666→\t\tvar err error\n   667→\n   668→\t\tif req.StepName != \"\" && req.LogType != \"\" {\n   669→\t\t\t// Filter by both step and type\n   670→\t\t\tlogFiles, err = s.logStore.GetLogFilesByStep(ctx, req.RunId, req.StepName)\n   671→\t\t\tif err == nil {\n   672→\t\t\t\tfiltered := logFiles[:0]\n   673→\t\t\t\tfor _, lf := range logFiles {\n   674→\t\t\t\t\tif lf.FileType == req.LogType {\n   675→\t\t\t\t\t\tfiltered = append(filtered, lf)\n   676→\t\t\t\t\t}\n   677→\t\t\t\t}\n   678→\t\t\t\tlogFiles = filtered\n   679→\t\t\t}\n   680→\t\t} else if req.StepName != \"\" {\n   681→\t\t\tlogFiles, err = s.logStore.GetLogFilesByStep(ctx, req.RunId, req.StepName)\n   682→\t\t} else {\n   683→\t\t\tlogFiles, err = s.logStore.GetLogFileByType(ctx, req.RunId, req.LogType)\n   684→\t\t}\n   685→\n   686→\t\tif err == nil && len(logFiles) > 0 {\n   687→\t\t\tfor _, lf := range logFiles {\n   688→\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n   689→\t\t\t\tif readErr != nil {\n   690→\t\t\t\t\tcontinue\n   691→\t\t\t\t}\n   692→\t\t\t\tif err := stream.Send(&pb.LogEntry{\n   693→\t\t\t\t\tType:     lf.FileType + \"_log\",\n   694→\t\t\t\t\tStepName: lf.StepName,\n   695→\t\t\t\t\tMessage:  string(data),\n   696→\t\t\t\t}); err != nil {\n   697→\t\t\t\t\treturn err\n   698→\t\t\t\t}\n   699→\t\t\t}\n   700→\t\t\treturn nil\n   701→\t\t}\n   702→\t}\n   703→\n   704→\t// Fall back to file path conventions\n   705→\tif req.StepName != \"\" {\n   706→\t\tvar logPath string\n   707→\t\tswitch req.LogType {\n   708→\t\tcase \"llm\":\n   709→\t\t\tlogPath = filepath.Join(outputDir, \"llm-\"+req.StepName+\".log\")\n   710→\t\tdefault:\n   711→\t\t\tlogPath = filepath.Join(outputDir, req.StepName+\".log\")\n   712→\t\t}\n   713→\n   714→\t\tdata, err := os.ReadFile(logPath)\n   715→\t\tif err != nil {\n   716→\t\t\treturn fmt.Errorf(\"log file not found for step %q: %w\", req.StepName, err)\n   717→\t\t}\n   718→\t\treturn stream.Send(&pb.LogEntry{\n   719→\t\t\tType:     \"step_log\",\n   720→\t\t\tStepName: req.StepName,\n   721→\t\t\tMessage:  string(data),\n   722→\t\t})\n   723→\t}\n   724→\n   725→\treturn fmt.Errorf(\"no log files found matching filter\")\n   726→}\n   727→\n   728→// streamLiveLogs subscribes to the broadcaster and streams log lines in real\n   729→// time for an active run. The stream closes when the run completes or the\n   730→// client disconnects.\n   731→func (s *ClocheServer) streamLiveLogs(runID string, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n   732→\tsub := s.logBroadcast.Subscribe(runID)\n   733→\tdefer s.logBroadcast.Unsubscribe(runID, sub)\n   734→\n   735→\tctx := stream.Context()\n   736→\tfor {\n   737→\t\tselect {\n   738→\t\tcase <-ctx.Done():\n   739→\t\t\treturn ctx.Err()\n   740→\t\tcase line, ok := <-sub.C:\n   741→\t\t\tif !ok {\n   742→\t\t\t\t// Run completed — send terminal entry.\n   743→\t\t\t\trun, err := s.store.GetRun(context.Background(), runID)\n   744→\t\t\t\tif err == nil && run.State != domain.RunStateRunning && run.State != domain.RunStatePending {\n   745→\t\t\t\t\t_ = stream.Send(&pb.LogEntry{\n   746→\t\t\t\t\t\tType:      \"run_completed\",\n   747→\t\t\t\t\t\tResult:    string(run.State),\n   748→\t\t\t\t\t\tTimestamp: run.CompletedAt.String(),\n   749→\t\t\t\t\t\tMessage:   run.ErrorMessage,\n   750→\t\t\t\t\t})\n   751→\t\t\t\t}\n   752→\t\t\t\treturn nil\n   753→\t\t\t}\n   754→\t\t\tif err := stream.Send(&pb.LogEntry{\n   755→\t\t\t\tType:      \"log\",\n   756→\t\t\t\tStepName:  line.StepName,\n   757→\t\t\t\tMessage:   line.Content,\n   758→\t\t\t\tTimestamp: line.Timestamp,\n   759→\t\t\t}); err != nil {\n   760→\t\t\t\treturn err\n   761→\t\t\t}\n   762→\t\t}\n   763→\t}\n   764→}\n   765→\n   766→func (s *ClocheServer) StopRun(ctx context.Context, req *pb.StopRunRequest) (*pb.StopRunResponse, error) {\n   767→\ts.mu.Lock()\n   768→\tcontainerID, ok := s.runIDs[req.RunId]\n   769→\ts.mu.Unlock()\n   770→\n   771→\tif !ok {\n   772→\t\treturn nil, fmt.Errorf(\"run %q not found or already completed\", req.RunId)\n   773→\t}\n   774→\n   775→\tif err := s.container.Stop(ctx, containerID); err != nil {\n   776→\t\treturn nil, fmt.Errorf(\"stopping run: %w\", err)\n   777→\t}\n   778→\n   779→\t// Mark as cancelled in store\n   780→\trun, err := s.store.GetRun(ctx, req.RunId)\n   781→\tif err == nil {\n   782→\t\trun.Complete(domain.RunStateCancelled)\n   783→\t\t_ = s.store.UpdateRun(ctx, run)\n   784→\t}\n   785→\n   786→\treturn &pb.StopRunResponse{}, nil\n   787→}\n   788→\n   789→func (s *ClocheServer) DeleteContainer(ctx context.Context, req *pb.DeleteContainerRequest) (*pb.DeleteContainerResponse, error) {\n   790→\tif s.container == nil {\n   791→\t\treturn nil, fmt.Errorf(\"no container runtime configured\")\n   792→\t}\n   793→\n   794→\tid := req.Id\n   795→\tif id == \"\" {\n   796→\t\treturn nil, fmt.Errorf(\"id is required\")\n   797→\t}\n   798→\n   799→\t// Try to resolve as a run ID first\n   800→\tcontainerID := id\n   801→\trun, err := s.store.GetRun(ctx, id)\n   802→\tif err == nil {\n   803→\t\t// It's a run ID — use the container ID from the run record\n   804→\t\tif run.ContainerID == \"\" {\n   805→\t\t\treturn nil, fmt.Errorf(\"run %q has no associated container\", id)\n   806→\t\t}\n   807→\t\tcontainerID = run.ContainerID\n   808→\t}\n   809→\n   810→\t// Remove the container\n   811→\tif err := s.container.Remove(ctx, containerID); err != nil {\n   812→\t\treturn nil, fmt.Errorf(\"removing container: %w\", err)\n   813→\t}\n   814→\n   815→\t// If we resolved a run, clear the container_kept flag\n   816→\tif run != nil {\n   817→\t\trun.ContainerKept = false\n   818→\t\t_ = s.store.UpdateRun(ctx, run)\n   819→\t}\n   820→\n   821→\treturn &pb.DeleteContainerResponse{}, nil\n   822→}\n   823→\n   824→func (s *ClocheServer) EnableLoop(ctx context.Context, req *pb.EnableLoopRequest) (*pb.EnableLoopResponse, error) {\n   825→\tprojectDir := req.ProjectDir\n   826→\tif projectDir == \"\" {\n   827→\t\treturn nil, fmt.Errorf(\"project_dir is required\")\n   828→\t}\n   829→\n   830→\t// Verify host.cloche exists\n   831→\thostPath := filepath.Join(projectDir, \".cloche\", \"host.cloche\")\n   832→\tif _, err := os.Stat(hostPath); err != nil {\n   833→\t\treturn nil, fmt.Errorf(\"host.cloche not found in %s: %w\", projectDir, err)\n   834→\t}\n   835→\n   836→\t// Load project config for defaults.\n   837→\tprojCfg, _ := config.Load(projectDir)\n   838→\n   839→\tmaxConc := int(req.MaxConcurrent)\n   840→\tif maxConc <= 0 {\n   841→\t\tmaxConc = projCfg.Orchestration.Concurrency\n   842→\t}\n   843→\tif maxConc <= 0 {\n   844→\t\tmaxConc = 1\n   845→\t}\n   846→\n   847→\tstagger := time.Duration(float64(time.Second) * projCfg.Orchestration.StaggerSeconds)\n   848→\n   849→\t// Compute dedup timeout from config (default 5 minutes).\n   850→\tdedupTimeout := time.Duration(float64(time.Second) * projCfg.Orchestration.DedupSeconds)\n   851→\n   852→\tloopCfg := host.LoopConfig{\n   853→\t\tProjectDir:    projectDir,\n   854→\t\tMaxConcurrent: maxConc,\n   855→\t\tStaggerDelay:  stagger,\n   856→\t\tDedupTimeout:  dedupTimeout,\n   857→\t}\n   858→\n   859→\ts.mu.Lock()\n   860→\tdefer s.mu.Unlock()\n   861→\n   862→\t// Stop existing loop if running.\n   863→\tif existing, ok := s.loops[projectDir]; ok {\n   864→\t\texisting.Stop()\n   865→\t}\n   866→\n   867→\t// Check if host.cloche defines a list-tasks workflow for three-phase mode.\n   868→\tvar loop *host.Loop\n   869→\tif s.hasWorkflow(hostPath, \"list-tasks\") {\n   870→\t\tloop = s.createPhaseLoop(loopCfg, projectDir, hostPath, dedupTimeout)\n   871→\t} else {\n   872→\t\tloop = s.createLegacyLoop(loopCfg, projectDir, projCfg, dedupTimeout)\n   873→\t}\n   874→\n   875→\ts.loops[projectDir] = loop\n   876→\tloop.Start()\n   877→\n   878→\treturn &pb.EnableLoopResponse{}, nil\n   879→}\n   880→\n   881→// hasWorkflow checks if host.cloche contains a workflow with the given name.\n   882→func (s *ClocheServer) hasWorkflow(hostPath, workflowName string) bool {\n   883→\tdata, err := os.ReadFile(hostPath)\n   884→\tif err != nil {\n   885→\t\treturn false\n   886→\t}\n   887→\treturn strings.Contains(string(data), fmt.Sprintf(\"workflow %q\", workflowName))\n   888→}\n   889→\n   890→// createPhaseLoop creates a three-phase orchestration loop using list-tasks,\n   891→// main, and finalize workflows from host.cloche.\n   892→func (s *ClocheServer) createPhaseLoop(loopCfg host.LoopConfig, projectDir, hostPath string, dedupTimeout time.Duration) *host.Loop {\n   893→\t// Phase 1: list-tasks function\n   894→\tlistTasksFn := func(ctx context.Context, projDir string) ([]host.Task, error) {\n   895→\t\trunner := &host.Runner{\n   896→\t\t\tDispatcher: s,\n   897→\t\t\tStore:      s.store,\n   898→\t\t}\n   899→\t\ttasks, _, err := host.RunListTasksWorkflow(ctx, runner, projDir)\n   900→\t\treturn tasks, err\n   901→\t}\n   902→\n   903→\t// Phase 2: main function\n   904→\tmainFn := func(ctx context.Context, projDir string, taskID string) (*host.RunResult, error) {\n   905→\t\trunner := &host.Runner{\n   906→\t\t\tDispatcher:   s,\n   907→\t\t\tStore:        s.store,\n   908→\t\t\tCaptures:     s.captures,\n   909→\t\t\tLogBroadcast: s.logBroadcast,\n   910→\t\t\tTaskID:       taskID,\n   911→\t\t}\n   912→\t\treturn runner.RunNamed(ctx, projDir, \"main\")\n   913→\t}\n   914→\n   915→\t// Phase 3: finalize function (optional — only if host.cloche has it)\n   916→\tvar finalizeFn host.FinalizeFunc\n   917→\tif s.hasWorkflow(hostPath, \"finalize\") {\n   918→\t\tfinalizeFn = func(ctx context.Context, projDir string, taskID string, mainResult *host.RunResult) (*host.RunResult, error) {\n   919→\t\t\tmainRunID := \"\"\n   920→\t\t\tmainOutcome := \"failed\"\n   921→\t\t\tif mainResult != nil {\n   922→\t\t\t\tmainRunID = mainResult.RunID\n   923→\t\t\t\tmainOutcome = string(mainResult.State)\n   924→\t\t\t}\n   925→\t\t\trunner := &host.Runner{\n   926→\t\t\t\tDispatcher:   s,\n   927→\t\t\t\tStore:        s.store,\n   928→\t\t\t\tCaptures:     s.captures,\n   929→\t\t\t\tLogBroadcast: s.logBroadcast,\n   930→\t\t\t\tTaskID:       taskID,\n   931→\t\t\t\tExtraEnv: []string{\n   932→\t\t\t\t\t\"CLOCHE_MAIN_RUN_ID=\" + mainRunID,\n   933→\t\t\t\t\t\"CLOCHE_MAIN_OUTCOME=\" + mainOutcome,\n   934→\t\t\t\t},\n   935→\t\t\t}\n   936→\t\t\treturn runner.RunNamed(ctx, projDir, \"finalize\")\n   937→\t\t}\n   938→\t}\n   939→\n   940→\tlog.Printf(\"orchestration loop: three-phase mode enabled for %s (list-tasks + main + finalize, dedup=%s)\", projectDir, dedupTimeout)\n   941→\treturn host.NewPhaseLoop(loopCfg, s.store, listTasksFn, mainFn, finalizeFn)\n   942→}\n   943→\n   944→// createLegacyLoop creates a legacy single-function orchestration loop.\n   945→func (s *ClocheServer) createLegacyLoop(loopCfg host.LoopConfig, projectDir string, projCfg *config.Config, dedupTimeout time.Duration) *host.Loop {\n   946→\trunFn := func(ctx context.Context, projDir string, taskID string) (*host.RunResult, error) {\n   947→\t\trunner := &host.Runner{\n   948→\t\t\tDispatcher:   s,\n   949→\t\t\tStore:        s.store,\n   950→\t\t\tCaptures:     s.captures,\n   951→\t\t\tLogBroadcast: s.logBroadcast,\n   952→\t\t\tTaskID:       taskID,\n   953→\t\t}\n   954→\t\treturn runner.Run(ctx, projDir)\n   955→\t}\n   956→\n   957→\tloop := host.NewLoop(loopCfg, s.store, runFn)\n   958→\n   959→\t// Configure daemon-managed task assignment if a list-tasks command is set.\n   960→\tif cmd := projCfg.Orchestration.ListTasksCommand; cmd != \"\" {\n   961→\t\tloop.SetTaskAssigner(&host.ScriptTaskAssigner{Command: cmd})\n   962→\t\tlog.Printf(\"orchestration loop: task assignment enabled for %s (command=%q, dedup=%s)\", projectDir, cmd, dedupTimeout)\n   963→\t}\n   964→\n   965→\treturn loop\n   966→}\n   967→\n   968→// GetLoopTasks returns the current task pipeline state for a project's\n   969→// orchestration loop, formatted as web.TaskEntry values. Returns nil if no\n   970→// loop is active for the project.\n   971→func (s *ClocheServer) GetLoopTasks(projectDir string) []web.TaskEntry {\n   972→\ts.mu.Lock()\n   973→\tloop, ok := s.loops[projectDir]\n   974→\ts.mu.Unlock()\n   975→\tif !ok {\n   976→\t\treturn nil\n   977→\t}\n   978→\tsnapshot := loop.GetTaskSnapshot()\n   979→\n   980→\t// Build a set of task IDs that have active (pending/running) runs.\n   981→\tactiveTaskIDs := make(map[string]bool)\n   982→\tctx := context.Background()\n   983→\tallRuns, _ := s.store.ListRunsByProject(ctx, projectDir, time.Time{})\n   984→\tfor _, r := range allRuns {\n   985→\t\tif r.TaskID != \"\" && (r.State == domain.RunStatePending || r.State == domain.RunStateRunning) {\n   986→\t\t\tactiveTaskIDs[r.TaskID] = true\n   987→\t\t}\n   988→\t}\n   989→\n   990→\tentries := make([]web.TaskEntry, len(snapshot))\n   991→\tfor i, e := range snapshot {\n   992→\t\tentry := web.TaskEntry{\n   993→\t\t\tID:          e.Task.ID,\n   994→\t\t\tStatus:      e.Task.Status,\n   995→\t\t\tTitle:       e.Task.Title,\n   996→\t\t\tDescription: e.Task.Description,\n   997→\t\t\tMetadata:    e.Task.Metadata,\n   998→\t\t\tAssigned:    e.Assigned,\n   999→\t\t\tRunID:       e.RunID,\n  1000→\t\t}\n  1001→\t\tif !e.AssignedAt.IsZero() {\n  1002→\t\t\tentry.AssignedAt = e.AssignedAt.Format(time.RFC3339)\n  1003→\t\t}\n  1004→\t\t// Stale: task is in_progress but has no active worker.\n  1005→\t\tif host.TaskStatus(e.Task.Status) == host.TaskStatusInProgress && !activeTaskIDs[e.Task.ID] {\n  1006→\t\t\tentry.Stale = true\n  1007→\t\t}\n  1008→\t\tentries[i] = entry\n  1009→\t}\n  1010→\treturn entries\n  1011→}\n  1012→\n  1013→// ReleaseTask runs the release-task host workflow for a specific task,\n  1014→// returning it to open status.\n  1015→func (s *ClocheServer) ReleaseTask(ctx context.Context, projectDir string, taskID string) error {\n  1016→\trunner := &host.Runner{\n  1017→\t\tDispatcher:   s,\n  1018→\t\tStore:        s.store,\n  1019→\t\tCaptures:     s.captures,\n  1020→\t\tLogBroadcast: s.logBroadcast,\n  1021→\t\tTaskID:       taskID,\n  1022→\t}\n  1023→\tresult, err := runner.RunNamed(ctx, projectDir, \"release-task\")\n  1024→\tif err != nil {\n  1025→\t\treturn fmt.Errorf(\"release-task workflow failed: %w\", err)\n  1026→\t}\n  1027→\tif result.State != domain.RunStateSucceeded {\n  1028→\t\treturn fmt.Errorf(\"release-task workflow finished with state %s\", result.State)\n  1029→\t}\n  1030→\treturn nil\n  1031→}\n  1032→\n  1033→func (s *ClocheServer) DisableLoop(ctx context.Context, req *pb.DisableLoopRequest) (*pb.DisableLoopResponse, error) {\n  1034→\tprojectDir := req.ProjectDir\n  1035→\tif projectDir == \"\" {\n  1036→\t\treturn nil, fmt.Errorf(\"project_dir is required\")\n  1037→\t}\n  1038→\n  1039→\ts.mu.Lock()\n  1040→\tdefer s.mu.Unlock()\n  1041→\n  1042→\tif loop, ok := s.loops[projectDir]; ok {\n  1043→\t\tloop.Stop()\n  1044→\t\tdelete(s.loops, projectDir)\n  1045→\t}\n  1046→\n  1047→\treturn &pb.DisableLoopResponse{}, nil\n  1048→}\n  1049→\n  1050→func (s *ClocheServer) GetProjectInfo(ctx context.Context, req *pb.GetProjectInfoRequest) (*pb.GetProjectInfoResponse, error) {\n  1051→\tprojectDir := req.ProjectDir\n  1052→\n  1053→\t// Resolve by name if provided.\n  1054→\tif req.Name != \"\" && projectDir == \"\" {\n  1055→\t\tprojects, err := s.store.ListProjects(ctx)\n  1056→\t\tif err != nil {\n  1057→\t\t\treturn nil, fmt.Errorf(\"listing projects: %w\", err)\n  1058→\t\t}\n  1059→\t\tlabels := projectLabels(projects)\n  1060→\t\tfound := false\n  1061→\t\tfor dir, label := range labels {\n  1062→\t\t\tif label == req.Name {\n  1063→\t\t\t\tprojectDir = dir\n  1064→\t\t\t\tfound = true\n  1065→\t\t\t\tbreak\n  1066→\t\t\t}\n  1067→\t\t}\n  1068→\t\tif !found {\n  1069→\t\t\treturn nil, fmt.Errorf(\"project %q not found\", req.Name)\n  1070→\t\t}\n  1071→\t}\n  1072→\n  1073→\tif projectDir == \"\" {\n  1074→\t\treturn nil, fmt.Errorf(\"project_dir or name is required\")\n  1075→\t}\n  1076→\n  1077→\t// Derive project label.\n  1078→\tprojects, _ := s.store.ListProjects(ctx)\n  1079→\tlabels := projectLabels(projects)\n  1080→\tlabel := labels[projectDir]\n  1081→\tif label == \"\" {\n  1082→\t\tlabel = filepath.Base(projectDir)\n  1083→\t}\n  1084→\n  1085→\t// Load config.\n  1086→\tcfg, _ := config.Load(projectDir)\n  1087→\n  1088→\t// Check loop state.\n  1089→\ts.mu.Lock()\n  1090→\tloop, loopExists := s.loops[projectDir]\n  1091→\ts.mu.Unlock()\n  1092→\tloopRunning := loopExists && loop != nil && loop.Running()\n  1093→\n  1094→\t// Get active runs.\n  1095→\tallRuns, _ := s.store.ListRunsByProject(ctx, projectDir, time.Time{})\n  1096→\tvar activeRuns []*pb.RunSummary\n  1097→\tfor _, run := range allRuns {\n  1098→\t\tif run.State == domain.RunStatePending || run.State == domain.RunStateRunning {\n  1099→\t\t\tactiveRuns = append(activeRuns, &pb.RunSummary{\n  1100→\t\t\t\tRunId:        run.ID,\n  1101→\t\t\t\tWorkflowName: run.WorkflowName,\n  1102→\t\t\t\tState:        string(run.State),\n  1103→\t\t\t\tStartedAt:    run.StartedAt.String(),\n  1104→\t\t\t\tTitle:        run.Title,\n  1105→\t\t\t\tIsHost:       run.IsHost,\n  1106→\t\t\t\tContainerId:  run.ContainerID,\n  1107→\t\t\t})\n  1108→\t\t}\n  1109→\t}\n  1110→\n  1111→\t// Discover workflows.\n  1112→\tvar containerWorkflows, hostWorkflows []string\n  1113→\tclocheDir := filepath.Join(projectDir, \".cloche\")\n  1114→\tentries, _ := filepath.Glob(filepath.Join(clocheDir, \"*.cloche\"))\n  1115→\tfor _, path := range entries {\n  1116→\t\tbase := filepath.Base(path)\n  1117→\t\tdata, err := os.ReadFile(path)\n  1118→\t\tif err != nil {\n  1119→\t\t\tcontinue\n  1120→\t\t}\n  1121→\t\tif base == \"host.cloche\" {\n  1122→\t\t\twfs, err := dsl.ParseAllForHost(string(data))\n  1123→\t\t\tif err != nil {\n  1124→\t\t\t\tcontinue\n  1125→\t\t\t}\n  1126→\t\t\tfor name := range wfs {\n  1127→\t\t\t\thostWorkflows = append(hostWorkflows, name)\n  1128→\t\t\t}\n  1129→\t\t} else {\n  1130→\t\t\twf, err := dsl.ParseForContainer(string(data))\n  1131→\t\t\tif err != nil {\n  1132→\t\t\t\tcontinue\n  1133→\t\t\t}\n  1134→\t\t\tcontainerWorkflows = append(containerWorkflows, wf.Name)\n  1135→\t\t}\n  1136→\t}\n  1137→\n  1138→\tsort.Strings(containerWorkflows)\n  1139→\tsort.Strings(hostWorkflows)\n  1140→\n  1141→\treturn &pb.GetProjectInfoResponse{\n  1142→\t\tProjectDir:         projectDir,\n  1143→\t\tName:               label,\n  1144→\t\tActive:             cfg.Active,\n  1145→\t\tConcurrency:        int32(cfg.Orchestration.Concurrency),\n  1146→\t\tStaggerSeconds:     cfg.Orchestration.StaggerSeconds,\n  1147→\t\tDedupSeconds:       cfg.Orchestration.DedupSeconds,\n  1148→\t\tEvolutionEnabled:   cfg.Evolution.Enabled,\n  1149→\t\tLoopRunning:        loopRunning,\n  1150→\t\tActiveRuns:         activeRuns,\n  1151→\t\tContainerWorkflows: containerWorkflows,\n  1152→\t\tHostWorkflows:      hostWorkflows,\n  1153→\t}, nil\n  1154→}\n  1155→\n  1156→// projectLabels maps each project directory to a short display label.\n  1157→// Uses basename unless there are conflicts, in which case parent/basename is used.\n  1158→func projectLabels(dirs []string) map[string]string {\n  1159→\tlabels := make(map[string]string, len(dirs))\n  1160→\tbyBase := map[string][]string{}\n  1161→\tfor _, d := range dirs {\n  1162→\t\tbase := filepath.Base(d)\n  1163→\t\tbyBase[base] = append(byBase[base], d)\n  1164→\t}\n  1165→\tfor base, paths := range byBase {\n  1166→\t\tif len(paths) == 1 {\n  1167→\t\t\tlabels[paths[0]] = base\n  1168→\t\t} else {\n  1169→\t\t\tfor _, p := range paths {\n  1170→\t\t\t\tparent := filepath.Base(filepath.Dir(p))\n  1171→\t\t\t\tlabels[p] = parent + \"/\" + base\n  1172→\t\t\t}\n  1173→\t\t}\n  1174→\t}\n  1175→\treturn labels\n  1176→}\n  1177→\n  1178→func (s *ClocheServer) GetVersion(ctx context.Context, req *pb.GetVersionRequest) (*pb.GetVersionResponse, error) {\n  1179→\treturn &pb.GetVersionResponse{Version: version.Version()}, nil\n  1180→}\n  1181→\n  1182→func (s *ClocheServer) Shutdown(ctx context.Context, req *pb.ShutdownRequest) (*pb.ShutdownResponse, error) {\n  1183→\t// Stop all orchestration loops.\n  1184→\ts.mu.Lock()\n  1185→\tfor _, loop := range s.loops {\n  1186→\t\tloop.Stop()\n  1187→\t}\n  1188→\ts.loops = make(map[string]*host.Loop)\n  1189→\ts.mu.Unlock()\n  1190→\n  1191→\tif s.shutdownFn == nil {\n  1192→\t\treturn nil, fmt.Errorf(\"shutdown not configured\")\n  1193→\t}\n  1194→\tgo s.shutdownFn()\n  1195→\treturn &pb.ShutdownResponse{}, nil\n  1196→}\n  1197→\n  1198→// indexLogFiles scans the extracted output directory and creates log_files index entries.\n  1199→func (s *ClocheServer) indexLogFiles(ctx context.Context, runID, outputDir string) {\n  1200→\tentries, err := os.ReadDir(outputDir)\n  1201→\tif err != nil {\n  1202→\t\tlog.Printf(\"run %s: failed to read output dir for indexing: %v\", runID, err)\n  1203→\t\treturn\n  1204→\t}\n  1205→\n  1206→\tnow := time.Now()\n  1207→\tfor _, entry := range entries {\n  1208→\t\tif entry.IsDir() {\n  1209→\t\t\tcontinue\n  1210→\t\t}\n  1211→\t\tname := entry.Name()\n  1212→\t\tif !strings.HasSuffix(name, \".log\") {\n  1213→\t\t\tcontinue\n  1214→\t\t}\n  1215→\n  1216→\t\tvar fileType, stepName string\n  1217→\t\tbase := strings.TrimSuffix(name, \".log\")\n  1218→\n  1219→\t\tswitch {\n  1220→\t\tcase name == \"full.log\":\n  1221→\t\t\tfileType = \"full\"\n  1222→\t\tcase name == \"container.log\":\n  1223→\t\t\t// container.log is internal, not indexed as a user-facing log type\n  1224→\t\t\tcontinue\n  1225→\t\tcase strings.HasPrefix(name, \"llm-\"):\n  1226→\t\t\tfileType = \"llm\"\n  1227→\t\t\tstepName = strings.TrimPrefix(base, \"llm-\")\n  1228→\t\tdefault:\n  1229→\t\t\tfileType = \"script\"\n  1230→\t\t\tstepName = base\n  1231→\t\t}\n  1232→\n  1233→\t\tinfo, _ := entry.Info()\n  1234→\t\tvar fileSize int64\n  1235→\t\tif info != nil {\n  1236→\t\t\tfileSize = info.Size()\n  1237→\t\t}\n  1238→\n  1239→\t\tlogEntry := &ports.LogFileEntry{\n  1240→\t\t\tRunID:     runID,\n  1241→\t\t\tStepName:  stepName,\n  1242→\t\t\tFileType:  fileType,\n  1243→\t\t\tFilePath:  filepath.Join(outputDir, name),\n  1244→\t\t\tFileSize:  fileSize,\n  1245→\t\t\tCreatedAt: now,\n  1246→\t\t}\n  1247→\t\tif err := s.logStore.SaveLogFile(ctx, logEntry); err != nil {\n  1248→\t\t\tlog.Printf(\"run %s: failed to index log file %s: %v\", runID, name, err)\n  1249→\t\t}\n  1250→\t}\n  1251→}\n  1252→\n  1253→func gitHEAD(dir string) string {\n  1254→\tcmd := exec.Command(\"git\", \"rev-parse\", \"HEAD\")\n  1255→\tcmd.Dir = dir\n  1256→\tout, err := cmd.Output()\n  1257→\tif err != nil {\n  1258→\t\treturn \"\"\n  1259→\t}\n  1260→\treturn strings.TrimSpace(string(out))\n  1261→}\n  1262→"}]},"parent_tool_use_id":"toolu_013Y5EJhPZgAJrRFK4ZZsW2U","session_id":"96f32727-3069-4902-8837-5bfcf44ab35e","uuid":"bfb2ff6f-fb44-475c-b286-e7926f4142e7"}
