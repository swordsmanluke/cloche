[2026-03-13T20:00:03Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QR3fgKSiCJxgptc6kFBSkn","type":"tool_result","content":"     1→package grpc\n     2→\n     3→import (\n     4→\t\"bufio\"\n     5→\t\"context\"\n     6→\t\"encoding/json\"\n     7→\t\"fmt\"\n     8→\t\"log\"\n     9→\t\"os\"\n    10→\t\"os/exec\"\n    11→\t\"path/filepath\"\n    12→\t\"sort\"\n    13→\t\"strconv\"\n    14→\t\"strings\"\n    15→\t\"sync\"\n    16→\t\"time\"\n    17→\n    18→\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    19→\t\"github.com/cloche-dev/cloche/internal/adapters/docker\"\n    20→\t\"github.com/cloche-dev/cloche/internal/adapters/web\"\n    21→\t\"github.com/cloche-dev/cloche/internal/config\"\n    22→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    23→\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    24→\t\"github.com/cloche-dev/cloche/internal/evolution\"\n    25→\t\"github.com/cloche-dev/cloche/internal/host\"\n    26→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    27→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    28→\t\"github.com/cloche-dev/cloche/internal/protocol\"\n    29→\t\"github.com/cloche-dev/cloche/internal/version\"\n    30→\trpcgrpc \"google.golang.org/grpc\"\n    31→\t\"google.golang.org/grpc/metadata\"\n    32→)\n    33→\n    34→type ClocheServer struct {\n    35→\tpb.UnimplementedClocheServiceServer\n    36→\tstore        ports.RunStore\n    37→\tcaptures     ports.CaptureStore\n    38→\tlogStore     ports.LogStore\n    39→\tcontainer    ports.ContainerRuntime\n    40→\tdefaultImage string\n    41→\tevolution    *evolution.Trigger\n    42→\tlogBroadcast *logstream.Broadcaster\n    43→\tshutdownFn   func()\n    44→\tmu           sync.Mutex\n    45→\trunIDs       map[string]string      // run_id -> container_id\n    46→\tloops        map[string]*host.Loop  // project_dir -> orchestration loop\n    47→}\n    48→\n    49→func NewClocheServer(store ports.RunStore, container ports.ContainerRuntime) *ClocheServer {\n    50→\treturn &ClocheServer{\n    51→\t\tstore:     store,\n    52→\t\tcontainer: container,\n    53→\t\trunIDs:    make(map[string]string),\n    54→\t\tloops:     make(map[string]*host.Loop),\n    55→\t}\n    56→}\n    57→\n    58→func NewClocheServerWithCaptures(store ports.RunStore, captures ports.CaptureStore, container ports.ContainerRuntime, defaultImage string) *ClocheServer {\n    59→\treturn &ClocheServer{\n    60→\t\tstore:        store,\n    61→\t\tcaptures:     captures,\n    62→\t\tcontainer:    container,\n    63→\t\tdefaultImage: defaultImage,\n    64→\t\trunIDs:       make(map[string]string),\n    65→\t\tloops:        make(map[string]*host.Loop),\n    66→\t}\n    67→}\n    68→\n    69→// SetLogStore attaches a log store to the server for indexing extracted log files.\n    70→func (s *ClocheServer) SetLogStore(ls ports.LogStore) {\n    71→\ts.logStore = ls\n    72→}\n    73→\n    74→\n    75→// SetEvolution attaches an evolution trigger to the server.\n    76→func (s *ClocheServer) SetEvolution(trigger *evolution.Trigger) {\n    77→\ts.evolution = trigger\n    78→}\n    79→\n    80→// SetLogBroadcaster attaches a log broadcaster for live-streaming LLM output.\n    81→func (s *ClocheServer) SetLogBroadcaster(b *logstream.Broadcaster) {\n    82→\ts.logBroadcast = b\n    83→}\n    84→\n    85→// SetShutdownFunc sets the callback invoked when the Shutdown RPC is called.\n    86→func (s *ClocheServer) SetShutdownFunc(fn func()) {\n    87→\ts.shutdownFn = fn\n    88→}\n    89→\n    90→func (s *ClocheServer) RunWorkflow(ctx context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error) {\n    91→\tif s.container == nil {\n    92→\t\treturn nil, fmt.Errorf(\"no container runtime configured\")\n    93→\t}\n    94→\n    95→\t// Generate a unique run ID, retrying on collision\n    96→\tvar runID string\n    97→\tfor attempts := 0; attempts < 10; attempts++ {\n    98→\t\trunID = domain.GenerateRunID(req.WorkflowName)\n    99→\t\texisting, err := s.store.GetRun(ctx, runID)\n   100→\t\tif err != nil {\n   101→\t\t\tbreak // ID is free\n   102→\t\t}\n   103→\t\t// Reuse if completed more than 1 hour ago\n   104→\t\tif !existing.CompletedAt.IsZero() && time.Since(existing.CompletedAt) > time.Hour {\n   105→\t\t\t_ = s.store.DeleteRun(ctx, runID)\n   106→\t\t\tbreak\n   107→\t\t}\n   108→\t}\n   109→\n   110→\t// Write prompt to .cloche/<run-id>/prompt.txt (run-specific to avoid conflicts)\n   111→\tif req.Prompt != \"\" {\n   112→\t\tclocheDir := filepath.Join(req.ProjectDir, \".cloche\", runID)\n   113→\t\tif err := os.MkdirAll(clocheDir, 0755); err != nil {\n   114→\t\t\treturn nil, fmt.Errorf(\"creating .cloche dir: %w\", err)\n   115→\t\t}\n   116→\t\tif err := os.WriteFile(filepath.Join(clocheDir, \"prompt.txt\"), []byte(req.Prompt), 0644); err != nil {\n   117→\t\t\treturn nil, fmt.Errorf(\"writing prompt: %w\", err)\n   118→\t\t}\n   119→\t}\n   120→\trun := domain.NewRun(runID, req.WorkflowName)\n   121→\trun.ProjectDir = req.ProjectDir\n   122→\trun.Title = req.Title\n   123→\tif err := s.store.CreateRun(ctx, run); err != nil {\n   124→\t\treturn nil, fmt.Errorf(\"creating run: %w\", err)\n   125→\t}\n   126→\n   127→\t// Resolve image: request-level override, then server default\n   128→\timage := req.Image\n   129→\tif image == \"\" {\n   130→\t\timage = s.defaultImage\n   131→\t}\n   132→\n   133→\t// Launch container start + tracking in background so the RPC returns immediately.\n   134→\t// The run stays in \"pending\" state until the container is up.\n   135→\tgo s.launchAndTrack(runID, image, req.KeepContainer, req)\n   136→\n   137→\treturn &pb.RunWorkflowResponse{RunId: runID}, nil\n   138→}\n   139→\n   140→// launchAndTrack starts the container and then tracks it to completion.\n   141→// It runs in a background goroutine with its own context, independent of the\n   142→// RPC context which may be cancelled after RunWorkflow returns.\n   143→func (s *ClocheServer) launchAndTrack(runID, image string, keepContainer bool, req *pb.RunWorkflowRequest) {\n   144→\tctx := context.Background()\n   145→\n   146→\t// Auto-rebuild image if the project Dockerfile has changed since last build.\n   147→\tif ensurer, ok := s.container.(ports.ImageEnsurer); ok {\n   148→\t\tif err := ensurer.EnsureImage(ctx, req.ProjectDir, image); err != nil {\n   149→\t\t\trun, _ := s.store.GetRun(ctx, runID)\n   150→\t\t\tif run != nil {\n   151→\t\t\t\trun.Fail(fmt.Sprintf(\"failed to ensure image: %v\", err))\n   152→\t\t\t\t_ = s.store.UpdateRun(ctx, run)\n   153→\t\t\t}\n   154→\t\t\tlog.Printf(\"run %s: failed to ensure image: %v\", runID, err)\n   155→\t\t\t\treturn\n   156→\t\t}\n   157→\t}\n   158→\n   159→\tbaseSHA := gitHEAD(req.ProjectDir)\n   160→\n   161→\tcontainerID, err := s.container.Start(ctx, ports.ContainerConfig{\n   162→\t\tImage:        image,\n   163→\t\tWorkflowName: req.WorkflowName,\n   164→\t\tProjectDir:   req.ProjectDir,\n   165→\t\tRunID:        runID,\n   166→\t\tNetworkAllow: []string{\"*\"},\n   167→\t})\n   168→\tif err != nil {\n   169→\t\trun, _ := s.store.GetRun(ctx, runID)\n   170→\t\tif run != nil {\n   171→\t\t\trun.Fail(fmt.Sprintf(\"failed to start container: %v\", err))\n   172→\t\t\t_ = s.store.UpdateRun(ctx, run)\n   173→\t\t}\n   174→\t\tlog.Printf(\"run %s: failed to start container: %v\", runID, err)\n   175→\t\treturn\n   176→\t}\n   177→\n   178→\ts.mu.Lock()\n   179→\ts.runIDs[runID] = containerID\n   180→\ts.mu.Unlock()\n   181→\n   182→\trun, _ := s.store.GetRun(ctx, runID)\n   183→\tif run != nil {\n   184→\t\trun.Start()\n   185→\t\trun.ContainerID = containerID\n   186→\t\trun.BaseSHA = baseSHA\n   187→\t\t_ = s.store.UpdateRun(ctx, run)\n   188→\t}\n   189→\n   190→\ts.trackRun(runID, containerID, req.ProjectDir, req.WorkflowName, keepContainer)\n   191→}\n   192→\n   193→func (s *ClocheServer) trackRun(runID, containerID, projectDir, workflowName string, keepContainer bool) {\n   194→\tctx := context.Background()\n   195→\n   196→\t// Attach to agent output\n   197→\treader, err := s.container.AttachOutput(ctx, containerID)\n   198→\tif err != nil {\n   199→\t\tlog.Printf(\"failed to attach to output for run %s: %v\", runID, err)\n   200→\t\t\treturn\n   201→\t}\n   202→\n   203→\t// Parse JSON-lines status messages\n   204→\tvar reportedResult string // captured from MsgRunCompleted, persisted after branch extraction\n   205→\tvar reportedError string  // captured from MsgError, used to set ErrorMessage on failed runs\n   206→\tscanner := bufio.NewScanner(reader)\n   207→\tscanner.Buffer(make([]byte, 0, 256*1024), 1024*1024) // 1MB max to handle large log messages\n   208→\tfor scanner.Scan() {\n   209→\t\tvar msg protocol.StatusMessage\n   210→\t\tif err := json.Unmarshal(scanner.Bytes(), &msg); err != nil {\n   211→\t\t\tcontinue\n   212→\t\t}\n   213→\n   214→\t\t// Fast path: log messages don't need store interaction.\n   215→\t\tif msg.Type == protocol.MsgLog {\n   216→\t\t\tif s.logBroadcast != nil {\n   217→\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n   218→\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n   219→\t\t\t\t\tType:      \"llm\",\n   220→\t\t\t\t\tContent:   msg.Message,\n   221→\t\t\t\t\tStepName:  msg.StepName,\n   222→\t\t\t\t})\n   223→\t\t\t}\n   224→\t\t\tcontinue\n   225→\t\t}\n   226→\n   227→\t\trun, err := s.store.GetRun(ctx, runID)\n   228→\t\tif err != nil {\n   229→\t\t\tcontinue\n   230→\t\t}\n   231→\n   232→\t\tswitch msg.Type {\n   233→\t\tcase protocol.MsgStepStarted:\n   234→\t\t\trun.RecordStepStart(msg.StepName)\n   235→\t\t\tif s.captures != nil {\n   236→\t\t\t\t_ = s.captures.SaveCapture(ctx, runID, &domain.StepExecution{\n   237→\t\t\t\t\tStepName:  msg.StepName,\n   238→\t\t\t\t\tStartedAt: msg.Timestamp,\n   239→\t\t\t\t})\n   240→\t\t\t}\n   241→\t\t\tif s.logBroadcast != nil {\n   242→\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n   243→\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n   244→\t\t\t\t\tType:      \"status\",\n   245→\t\t\t\t\tContent:   \"step_started: \" + msg.StepName,\n   246→\t\t\t\t\tStepName:  msg.StepName,\n   247→\t\t\t\t})\n   248→\t\t\t}\n   249→\t\tcase protocol.MsgStepCompleted:\n   250→\t\t\trun.RecordStepComplete(msg.StepName, msg.Result)\n   251→\t\t\tif s.captures != nil {\n   252→\t\t\t\t_ = s.captures.SaveCapture(ctx, runID, &domain.StepExecution{\n   253→\t\t\t\t\tStepName:    msg.StepName,\n   254→\t\t\t\t\tResult:      msg.Result,\n   255→\t\t\t\t\tCompletedAt: msg.Timestamp,\n   256→\t\t\t\t})\n   257→\t\t\t}\n   258→\t\t\tif s.logBroadcast != nil {\n   259→\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n   260→\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n   261→\t\t\t\t\tType:      \"status\",\n   262→\t\t\t\t\tContent:   \"step_completed: \" + msg.StepName + \" -> \" + msg.Result,\n   263→\t\t\t\t\tStepName:  msg.StepName,\n   264→\t\t\t\t})\n   265→\t\t\t}\n   266→\t\tcase protocol.MsgRunTitle:\n   267→\t\t\tif run.Title == \"\" {\n   268→\t\t\t\trun.Title = msg.Message\n   269→\t\t\t}\n   270→\t\tcase protocol.MsgError:\n   271→\t\t\treportedError = msg.Message\n   272→\t\t\tcontinue // Don't persist; used during finalization\n   273→\t\tcase protocol.MsgRunCompleted:\n   274→\t\t\treportedResult = msg.Result\n   275→\t\t\tcontinue // Don't persist terminal state yet; branch extraction must finish first\n   276→\t\t}\n   277→\n   278→\t\t_ = s.store.UpdateRun(ctx, run)\n   279→\t}\n   280→\treader.Close()\n   281→\n   282→\t// Signal live-stream subscribers that this run is done.\n   283→\tif s.logBroadcast != nil {\n   284→\t\ts.logBroadcast.Finish(runID)\n   285→\t}\n   286→\n   287→\t// Wait for process exit\n   288→\texitCode, err := s.container.Wait(ctx, containerID)\n   289→\tif err != nil {\n   290→\t\tlog.Printf(\"error waiting for run %s: %v\", runID, err)\n   291→\t}\n   292→\n   293→\t// Extract step output files from container before it's removed\n   294→\toutputDst := filepath.Join(projectDir, \".cloche\", runID, \"output\")\n   295→\tif err := os.MkdirAll(outputDst, 0755); err == nil {\n   296→\t\tif cpErr := s.container.CopyFrom(ctx, containerID, \"/workspace/.cloche/output/.\", outputDst); cpErr != nil {\n   297→\t\t\tlog.Printf(\"run %s: failed to extract output: %v\", runID, cpErr)\n   298→\t\t}\n   299→\t}\n   300→\n   301→\t// Capture full container stdout/stderr before the container is removed\n   302→\tif logs, logErr := s.container.Logs(ctx, containerID); logErr == nil && logs != \"\" {\n   303→\t\tcontainerLogPath := filepath.Join(outputDst, \"container.log\")\n   304→\t\tif writeErr := os.WriteFile(containerLogPath, []byte(logs), 0644); writeErr != nil {\n   305→\t\t\tlog.Printf(\"run %s: failed to write container.log: %v\", runID, writeErr)\n   306→\t\t}\n   307→\t}\n   308→\n   309→\t// Index extracted log files in the log store\n   310→\tif s.logStore != nil {\n   311→\t\ts.indexLogFiles(ctx, runID, outputDst)\n   312→\t}\n   313→\n   314→\t// Extract results to git branch BEFORE finalizing state, so that\n   315→\t// WaitRun callers (e.g. host workflow merge step) see branches exist\n   316→\t// before the run is marked complete.\n   317→\tresultLabel := reportedResult\n   318→\tif resultLabel == \"\" {\n   319→\t\tif exitCode == 0 {\n   320→\t\t\tresultLabel = \"succeeded\"\n   321→\t\t} else {\n   322→\t\t\tresultLabel = \"failed\"\n   323→\t\t}\n   324→\t}\n   325→\t{\n   326→\t\textractRun, _ := s.store.GetRun(ctx, runID)\n   327→\t\tif extractRun != nil && extractRun.BaseSHA != \"\" {\n   328→\t\t\tlog.Printf(\"run %s: extracting results to branch cloche/%s (baseSHA=%s)\", runID, runID, extractRun.BaseSHA)\n   329→\t\t\tif err := docker.ExtractResults(ctx, containerID, extractRun.ProjectDir, runID, extractRun.BaseSHA, workflowName, resultLabel); err != nil {\n   330→\t\t\t\tlog.Printf(\"run %s: failed to extract results to branch: %v\", runID, err)\n   331→\t\t\t} else {\n   332→\t\t\t\tlog.Printf(\"run %s: branch cloche/%s created successfully\", runID, runID)\n   333→\t\t\t}\n   334→\t\t} else {\n   335→\t\t\tlog.Printf(\"run %s: skipping branch extraction (baseSHA empty or run not found)\", runID)\n   336→\t\t}\n   337→\t}\n   338→\n   339→\t// Now finalize run state\n   340→\trun, err := s.store.GetRun(ctx, runID)\n   341→\tif err != nil {\n   342→\t\treturn\n   343→\t}\n   344→\tif run.State == domain.RunStateRunning {\n   345→\t\tif reportedResult == \"succeeded\" {\n   346→\t\t\trun.Complete(domain.RunStateSucceeded)\n   347→\t\t} else if reportedResult != \"\" {\n   348→\t\t\tif reportedError != \"\" {\n   349→\t\t\t\trun.Fail(reportedError)\n   350→\t\t\t} else {\n   351→\t\t\t\trun.Complete(domain.RunStateFailed)\n   352→\t\t\t}\n   353→\t\t} else if exitCode == 0 {\n   354→\t\t\trun.Complete(domain.RunStateSucceeded)\n   355→\t\t} else {\n   356→\t\t\trun.Fail(fmt.Sprintf(\"container exited with code %d\", exitCode))\n   357→\t\t}\n   358→\t\t_ = s.store.UpdateRun(ctx, run)\n   359→\t}\n   360→\n   361→\t// Fire evolution trigger if configured\n   362→\tif s.evolution != nil {\n   363→\t\ts.evolution.Fire(projectDir, workflowName, runID)\n   364→\t}\n   365→\n   366→\t// Merge is handled as a workflow step in host.cloche, not here.\n   367→\n   368→\t// Container retention policy:\n   369→\t// - Failed runs: always keep the container for debugging\n   370→\t// - Successful runs + --keep-container: keep the container\n   371→\t// - Successful runs without --keep-container: remove the container\n   372→\trunFinal, _ := s.store.GetRun(ctx, runID)\n   373→\trunFailed := runFinal != nil && (runFinal.State == domain.RunStateFailed || runFinal.State == domain.RunStateCancelled)\n   374→\n   375→\tif keepContainer || runFailed {\n   376→\t\treason := \"--keep-container\"\n   377→\t\tif runFailed {\n   378→\t\t\treason = \"run failed\"\n   379→\t\t}\n   380→\t\tlog.Printf(\"run %s: keeping container %s (%s)\", runID, containerID, reason)\n   381→\t\tif runFinal != nil {\n   382→\t\t\trunFinal.ContainerKept = true\n   383→\t\t\t_ = s.store.UpdateRun(ctx, runFinal)\n   384→\t\t}\n   385→\t} else {\n   386→\t\tif err := s.container.Remove(ctx, containerID); err != nil {\n   387→\t\t\tlog.Printf(\"run %s: failed to remove container %s: %v\", runID, containerID, err)\n   388→\t\t} else {\n   389→\t\t\tlog.Printf(\"run %s: removed container %s\", runID, containerID)\n   390→\t\t}\n   391→\t}\n   392→\n   393→\t// Cleanup mapping\n   394→\ts.mu.Lock()\n   395→\tdelete(s.runIDs, runID)\n   396→\ts.mu.Unlock()\n   397→}\n   398→\n   399→func (s *ClocheServer) ListRuns(ctx context.Context, req *pb.ListRunsRequest) (*pb.ListRunsResponse, error) {\n   400→\tfilter := domain.RunListFilter{\n   401→\t\tProjectDir: req.ProjectDir,\n   402→\t\tState:      domain.RunState(req.State),\n   403→\t\tTaskID:     req.TaskId,\n   404→\t\tLimit:      int(req.Limit),\n   405→\t}\n   406→\n   407→\t// When no project filter and not --all, default to last hour\n   408→\tif filter.ProjectDir == \"\" && !req.All {\n   409→\t\tfilter.Since = time.Now().Add(-1 * time.Hour)\n   410→\t}\n   411→\n   412→\truns, err := s.store.ListRunsFiltered(ctx, filter)\n   413→\tif err != nil {\n   414→\t\treturn nil, fmt.Errorf(\"listing runs: %w\", err)\n   415→\t}\n   416→\n   417→\tresp := &pb.ListRunsResponse{}\n   418→\tfor _, run := range runs {\n   419→\t\tresp.Runs = append(resp.Runs, &pb.RunSummary{\n   420→\t\t\tRunId:        run.ID,\n   421→\t\t\tWorkflowName: run.WorkflowName,\n   422→\t\t\tState:        string(run.State),\n   423→\t\t\tStartedAt:    run.StartedAt.String(),\n   424→\t\t\tErrorMessage: run.ErrorMessage,\n   425→\t\t\tContainerId:  run.ContainerID,\n   426→\t\t\tTitle:        run.Title,\n   427→\t\t\tIsHost:       run.IsHost,\n   428→\t\t\tProjectDir:   run.ProjectDir,\n   429→\t\t})\n   430→\t}\n   431→\treturn resp, nil\n   432→}\n   433→\n   434→func (s *ClocheServer) GetStatus(ctx context.Context, req *pb.GetStatusRequest) (*pb.GetStatusResponse, error) {\n   435→\trun, err := s.store.GetRun(ctx, req.RunId)\n   436→\tif err != nil {\n   437→\t\treturn nil, fmt.Errorf(\"getting run: %w\", err)\n   438→\t}\n   439→\n   440→\tresp := &pb.GetStatusResponse{\n   441→\t\tRunId:        run.ID,\n   442→\t\tWorkflowName: run.WorkflowName,\n   443→\t\tState:        string(run.State),\n   444→\t\tCurrentStep:  strings.Join(run.ActiveSteps, \",\"),\n   445→\t\tErrorMessage: run.ErrorMessage,\n   446→\t\tContainerId:  run.ContainerID,\n   447→\t\tTitle:        run.Title,\n   448→\t\tIsHost:       run.IsHost,\n   449→\t}\n   450→\n   451→\t// Check container liveness\n   452→\tif run.ContainerID != \"\" && s.container != nil {\n   453→\t\tif cs, err := s.container.Inspect(ctx, run.ContainerID); err == nil {\n   454→\t\t\tresp.ContainerAlive = cs.Running\n   455→\t\t\tif !cs.Running && !cs.FinishedAt.IsZero() {\n   456→\t\t\t\tresp.ContainerDeadSince = cs.FinishedAt.Format(time.RFC3339Nano)\n   457→\t\t\t}\n   458→\t\t}\n   459→\t}\n   460→\n   461→\t// Load step executions from captures store if available\n   462→\tif s.captures != nil {\n   463→\t\tcaptures, err := s.captures.GetCaptures(ctx, req.RunId)\n   464→\t\tif err == nil {\n   465→\t\t\tfor _, exec := range captures {\n   466→\t\t\t\tresp.StepExecutions = append(resp.StepExecutions, &pb.StepExecutionStatus{\n   467→\t\t\t\t\tStepName:    exec.StepName,\n   468→\t\t\t\t\tResult:      exec.Result,\n   469→\t\t\t\t\tStartedAt:   exec.StartedAt.String(),\n   470→\t\t\t\t\tCompletedAt: exec.CompletedAt.String(),\n   471→\t\t\t\t})\n   472→\t\t\t}\n   473→\t\t}\n   474→\t} else {\n   475→\t\tfor _, exec := range run.StepExecutions {\n   476→\t\t\tresp.StepExecutions = append(resp.StepExecutions, &pb.StepExecutionStatus{\n   477→\t\t\t\tStepName:    exec.StepName,\n   478→\t\t\t\tResult:      exec.Result,\n   479→\t\t\t\tStartedAt:   exec.StartedAt.String(),\n   480→\t\t\t\tCompletedAt: exec.CompletedAt.String(),\n   481→\t\t\t})\n   482→\t\t}\n   483→\t}\n   484→\n   485→\treturn resp, nil\n   486→}\n   487→\n   488→func (s *ClocheServer) StreamLogs(req *pb.StreamLogsRequest, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n   489→\tctx := stream.Context()\n   490→\n   491→\t// Check for follow mode via gRPC metadata.\n   492→\tfollow := followFromContext(ctx)\n   493→\tlimit := limitFromContext(ctx)\n   494→\n   495→\t// Verify run exists\n   496→\trun, err := s.store.GetRun(ctx, req.RunId)\n   497→\tif err != nil {\n   498→\t\treturn fmt.Errorf(\"run %q not found: %w\", req.RunId, err)\n   499→\t}\n   500→\n   501→\t// If step_name or log_type filter is set, serve content directly from the log index\n   502→\tif req.StepName != \"\" || req.LogType != \"\" {\n   503→\t\treturn s.streamFilteredLogs(ctx, req, run, stream, limit)\n   504→\t}\n   505→\n   506→\tisActive := run.State == domain.RunStateRunning || run.State == domain.RunStatePending\n   507→\n   508→\t// With -f on an active run: send existing logs then tail live output.\n   509→\tif follow && isActive && s.logBroadcast != nil {\n   510→\t\treturn s.streamFollowLogs(req.RunId, run, stream, limit)\n   511→\t}\n   512→\n   513→\t// Without -f on an active run: snapshot existing logs and return.\n   514→\t// (Legacy callers that relied on implicit live streaming should use -f.)\n   515→\t// With -f on a completed run: same as without -f — no new lines will arrive.\n   516→\n   517→\t// Check for full.log first — if it exists, serve it as the unified log\n   518→\tfullLogPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", \"full.log\")\n   519→\tif data, readErr := os.ReadFile(fullLogPath); readErr == nil && len(data) > 0 {\n   520→\t\tmsg := applyLimit(string(data), limit)\n   521→\t\tif err := stream.Send(&pb.LogEntry{\n   522→\t\t\tType:    \"full_log\",\n   523→\t\t\tMessage: msg,\n   524→\t\t}); err != nil {\n   525→\t\t\treturn err\n   526→\t\t}\n   527→\t\tif !isActive {\n   528→\t\t\tif err := stream.Send(&pb.LogEntry{\n   529→\t\t\t\tType:      \"run_completed\",\n   530→\t\t\t\tResult:    string(run.State),\n   531→\t\t\t\tTimestamp: run.CompletedAt.String(),\n   532→\t\t\t\tMessage:   run.ErrorMessage,\n   533→\t\t\t}); err != nil {\n   534→\t\t\t\treturn err\n   535→\t\t\t}\n   536→\t\t}\n   537→\t\treturn nil\n   538→\t}\n   539→\n   540→\tif s.captures == nil {\n   541→\t\treturn fmt.Errorf(\"captures store not configured\")\n   542→\t}\n   543→\n   544→\t// Fall back to capture-based streaming\n   545→\tcaptures, err := s.captures.GetCaptures(ctx, req.RunId)\n   546→\tif err != nil {\n   547→\t\treturn fmt.Errorf(\"getting captures: %w\", err)\n   548→\t}\n   549→\n   550→\tfor _, exec := range captures {\n   551→\t\t// Captures are stored as separate rows: one for step_started (no Result)\n   552→\t\t// and one for step_completed (has Result).\n   553→\t\tif exec.Result == \"\" {\n   554→\t\t\tentry := &pb.LogEntry{\n   555→\t\t\t\tType:      \"step_started\",\n   556→\t\t\t\tStepName:  exec.StepName,\n   557→\t\t\t\tTimestamp: exec.StartedAt.String(),\n   558→\t\t\t}\n   559→\t\t\tif err := stream.Send(entry); err != nil {\n   560→\t\t\t\treturn err\n   561→\t\t\t}\n   562→\t\t} else {\n   563→\t\t\t// Read step output from per-step output file.\n   564→\t\t\t// Container runs write .log, host runs write .out — try both.\n   565→\t\t\tvar output string\n   566→\t\t\tfor _, ext := range []string{\".log\", \".out\"} {\n   567→\t\t\t\toutputPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", exec.StepName+ext)\n   568→\t\t\t\tif data, err := os.ReadFile(outputPath); err == nil && len(data) > 0 {\n   569→\t\t\t\t\toutput = string(data)\n   570→\t\t\t\t\tbreak\n   571→\t\t\t\t}\n   572→\t\t\t}\n   573→\t\t\tentry := &pb.LogEntry{\n   574→\t\t\t\tType:      \"step_completed\",\n   575→\t\t\t\tStepName:  exec.StepName,\n   576→\t\t\t\tResult:    exec.Result,\n   577→\t\t\t\tTimestamp: exec.CompletedAt.String(),\n   578→\t\t\t\tMessage:   applyLimit(output, limit),\n   579→\t\t\t}\n   580→\t\t\tif err := stream.Send(entry); err != nil {\n   581→\t\t\t\treturn err\n   582→\t\t\t}\n   583→\t\t}\n   584→\t}\n   585→\n   586→\t// Send run completion entry\n   587→\tif !isActive {\n   588→\t\tif err := stream.Send(&pb.LogEntry{\n   589→\t\t\tType:      \"run_completed\",\n   590→\t\t\tResult:    string(run.State),\n   591→\t\t\tTimestamp: run.CompletedAt.String(),\n   592→\t\t\tMessage:   run.ErrorMessage,\n   593→\t\t}); err != nil {\n   594→\t\t\treturn err\n   595→\t\t}\n   596→\t}\n   597→\n   598→\treturn nil\n   599→}\n   600→\n   601→// followFromContext checks for the follow flag in gRPC metadata.\n   602→func followFromContext(ctx context.Context) bool {\n   603→\tmd, ok := metadata.FromIncomingContext(ctx)\n   604→\tif !ok {\n   605→\t\treturn false\n   606→\t}\n   607→\tvals := md.Get(\"x-cloche-follow\")\n   608→\treturn len(vals) > 0 && vals[0] == \"true\"\n   609→}\n   610→\n   611→// limitFromContext reads the line limit from gRPC metadata.\n   612→// Returns 0 when no limit is set.\n   613→func limitFromContext(ctx context.Context) int {\n   614→\tmd, ok := metadata.FromIncomingContext(ctx)\n   615→\tif !ok {\n   616→\t\treturn 0\n   617→\t}\n   618→\tvals := md.Get(\"x-cloche-limit\")\n   619→\tif len(vals) == 0 {\n   620→\t\treturn 0\n   621→\t}\n   622→\tn, err := strconv.Atoi(vals[0])\n   623→\tif err != nil || n <= 0 {\n   624→\t\treturn 0\n   625→\t}\n   626→\treturn n\n   627→}\n   628→\n   629→// applyLimit returns the last n lines of content. If n <= 0, returns content unchanged.\n   630→func applyLimit(content string, n int) string {\n   631→\tif n <= 0 {\n   632→\t\treturn content\n   633→\t}\n   634→\tlines := strings.Split(content, \"\\n\")\n   635→\t// Remove trailing empty line from final newline\n   636→\tif len(lines) > 0 && lines[len(lines)-1] == \"\" {\n   637→\t\tlines = lines[:len(lines)-1]\n   638→\t}\n   639→\tif len(lines) <= n {\n   640→\t\treturn content\n   641→\t}\n   642→\treturn strings.Join(lines[len(lines)-n:], \"\\n\") + \"\\n\"\n   643→}\n   644→\n   645→// streamFollowLogs sends existing log content then tails live output from the\n   646→// broadcaster. It combines snapshot + live streaming (like tail -f).\n   647→func (s *ClocheServer) streamFollowLogs(runID string, run *domain.Run, stream rpcgrpc.ServerStreamingServer[pb.LogEntry], limit int) error {\n   648→\t// Subscribe first so we don't miss lines written between read and subscribe.\n   649→\tsub := s.logBroadcast.Subscribe(runID)\n   650→\tdefer s.logBroadcast.Unsubscribe(runID, sub)\n   651→\n   652→\t// Send existing full.log content if available.\n   653→\tfullLogPath := filepath.Join(run.ProjectDir, \".cloche\", runID, \"output\", \"full.log\")\n   654→\tif data, err := os.ReadFile(fullLogPath); err == nil && len(data) > 0 {\n   655→\t\tmsg := applyLimit(string(data), limit)\n   656→\t\tif err := stream.Send(&pb.LogEntry{\n   657→\t\t\tType:    \"full_log\",\n   658→\t\t\tMessage: msg,\n   659→\t\t}); err != nil {\n   660→\t\t\treturn err\n   661→\t\t}\n   662→\t}\n   663→\n   664→\t// Now tail live output from the broadcaster.\n   665→\tctx := stream.Context()\n   666→\tfor {\n   667→\t\tselect {\n   668→\t\tcase <-ctx.Done():\n   669→\t\t\treturn ctx.Err()\n   670→\t\tcase line, ok := <-sub.C:\n   671→\t\t\tif !ok {\n   672→\t\t\t\t// Run completed — send terminal entry.\n   673→\t\t\t\tr, err := s.store.GetRun(context.Background(), runID)\n   674→\t\t\t\tif err == nil && r.State != domain.RunStateRunning && r.State != domain.RunStatePending {\n   675→\t\t\t\t\t_ = stream.Send(&pb.LogEntry{\n   676→\t\t\t\t\t\tType:      \"run_completed\",\n   677→\t\t\t\t\t\tResult:    string(r.State),\n   678→\t\t\t\t\t\tTimestamp: r.CompletedAt.String(),\n   679→\t\t\t\t\t\tMessage:   r.ErrorMessage,\n   680→\t\t\t\t\t})\n   681→\t\t\t\t}\n   682→\t\t\t\treturn nil\n   683→\t\t\t}\n   684→\t\t\tif err := stream.Send(&pb.LogEntry{\n   685→\t\t\t\tType:      \"log\",\n   686→\t\t\t\tStepName:  line.StepName,\n   687→\t\t\t\tMessage:   line.Content,\n   688→\t\t\t\tTimestamp: line.Timestamp,\n   689→\t\t\t}); err != nil {\n   690→\t\t\t\treturn err\n   691→\t\t\t}\n   692→\t\t}\n   693→\t}\n   694→}\n   695→\n   696→// streamFilteredLogs serves log content filtered by step name and/or log type.\n   697→// It uses the log index when available, falling back to file path conventions.\n   698→func (s *ClocheServer) streamFilteredLogs(ctx context.Context, req *pb.StreamLogsRequest, run *domain.Run, stream rpcgrpc.ServerStreamingServer[pb.LogEntry], limit int) error {\n   699→\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\")\n   700→\n   701→\t// Try log index first\n   702→\tif s.logStore != nil {\n   703→\t\tvar logFiles []*ports.LogFileEntry\n   704→\t\tvar err error\n   705→\n   706→\t\tif req.StepName != \"\" && req.LogType != \"\" {\n   707→\t\t\t// Filter by both step and type\n   708→\t\t\tlogFiles, err = s.logStore.GetLogFilesByStep(ctx, req.RunId, req.StepName)\n   709→\t\t\tif err == nil {\n   710→\t\t\t\tfiltered := logFiles[:0]\n   711→\t\t\t\tfor _, lf := range logFiles {\n   712→\t\t\t\t\tif lf.FileType == req.LogType {\n   713→\t\t\t\t\t\tfiltered = append(filtered, lf)\n   714→\t\t\t\t\t}\n   715→\t\t\t\t}\n   716→\t\t\t\tlogFiles = filtered\n   717→\t\t\t}\n   718→\t\t} else if req.StepName != \"\" {\n   719→\t\t\tlogFiles, err = s.logStore.GetLogFilesByStep(ctx, req.RunId, req.StepName)\n   720→\t\t} else {\n   721→\t\t\tlogFiles, err = s.logStore.GetLogFileByType(ctx, req.RunId, req.LogType)\n   722→\t\t}\n   723→\n   724→\t\tif err == nil && len(logFiles) > 0 {\n   725→\t\t\tfor _, lf := range logFiles {\n   726→\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n   727→\t\t\t\tif readErr != nil {\n   728→\t\t\t\t\tcontinue\n   729→\t\t\t\t}\n   730→\t\t\t\tif err := stream.Send(&pb.LogEntry{\n   731→\t\t\t\t\tType:     lf.FileType + \"_log\",\n   732→\t\t\t\t\tStepName: lf.StepName,\n   733→\t\t\t\t\tMessage:  applyLimit(string(data), limit),\n   734→\t\t\t\t}); err != nil {\n   735→\t\t\t\t\treturn err\n   736→\t\t\t\t}\n   737→\t\t\t}\n   738→\t\t\treturn nil\n   739→\t\t}\n   740→\t}\n   741→\n   742→\t// Fall back to file path conventions\n   743→\tif req.StepName != \"\" {\n   744→\t\tvar logPath string\n   745→\t\tswitch req.LogType {\n   746→\t\tcase \"llm\":\n   747→\t\t\tlogPath = filepath.Join(outputDir, \"llm-\"+req.StepName+\".log\")\n   748→\t\tdefault:\n   749→\t\t\tlogPath = filepath.Join(outputDir, req.StepName+\".log\")\n   750→\t\t}\n   751→\n   752→\t\tdata, err := os.ReadFile(logPath)\n   753→\t\tif err != nil {\n   754→\t\t\treturn fmt.Errorf(\"log file not found for step %q: %w\", req.StepName, err)\n   755→\t\t}\n   756→\t\treturn stream.Send(&pb.LogEntry{\n   757→\t\t\tType:     \"step_log\",\n   758→\t\t\tStepName: req.StepName,\n   759→\t\t\tMessage:  applyLimit(string(data), limit),\n   760→\t\t})\n   761→\t}\n   762→\n   763→\treturn fmt.Errorf(\"no log files found matching filter\")\n   764→}\n   765→\n   766→// streamLiveLogs subscribes to the broadcaster and streams log lines in real\n   767→// time for an active run. The stream closes when the run completes or the\n   768→// client disconnects.\n   769→func (s *ClocheServer) streamLiveLogs(runID string, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n   770→\tsub := s.logBroadcast.Subscribe(runID)\n   771→\tdefer s.logBroadcast.Unsubscribe(runID, sub)\n   772→\n   773→\tctx := stream.Context()\n   774→\tfor {\n   775→\t\tselect {\n   776→\t\tcase <-ctx.Done():\n   777→\t\t\treturn ctx.Err()\n   778→\t\tcase line, ok := <-sub.C:\n   779→\t\t\tif !ok {\n   780→\t\t\t\t// Run completed — send terminal entry.\n   781→\t\t\t\trun, err := s.store.GetRun(context.Background(), runID)\n   782→\t\t\t\tif err == nil && run.State != domain.RunStateRunning && run.State != domain.RunStatePending {\n   783→\t\t\t\t\t_ = stream.Send(&pb.LogEntry{\n   784→\t\t\t\t\t\tType:      \"run_completed\",\n   785→\t\t\t\t\t\tResult:    string(run.State),\n   786→\t\t\t\t\t\tTimestamp: run.CompletedAt.String(),\n   787→\t\t\t\t\t\tMessage:   run.ErrorMessage,\n   788→\t\t\t\t\t})\n   789→\t\t\t\t}\n   790→\t\t\t\treturn nil\n   791→\t\t\t}\n   792→\t\t\tif err := stream.Send(&pb.LogEntry{\n   793→\t\t\t\tType:      \"log\",\n   794→\t\t\t\tStepName:  line.StepName,\n   795→\t\t\t\tMessage:   line.Content,\n   796→\t\t\t\tTimestamp: line.Timestamp,\n   797→\t\t\t}); err != nil {\n   798→\t\t\t\treturn err\n   799→\t\t\t}\n   800→\t\t}\n   801→\t}\n   802→}\n   803→\n   804→func (s *ClocheServer) StopRun(ctx context.Context, req *pb.StopRunRequest) (*pb.StopRunResponse, error) {\n   805→\ts.mu.Lock()\n   806→\tcontainerID, ok := s.runIDs[req.RunId]\n   807→\ts.mu.Unlock()\n   808→\n   809→\tif !ok {\n   810→\t\treturn nil, fmt.Errorf(\"run %q not found or already completed\", req.RunId)\n   811→\t}\n   812→\n   813→\tif err := s.container.Stop(ctx, containerID); err != nil {\n   814→\t\treturn nil, fmt.Errorf(\"stopping run: %w\", err)\n   815→\t}\n   816→\n   817→\t// Mark as cancelled in store\n   818→\trun, err := s.store.GetRun(ctx, req.RunId)\n   819→\tif err == nil {\n   820→\t\trun.Complete(domain.RunStateCancelled)\n   821→\t\t_ = s.store.UpdateRun(ctx, run)\n   822→\t}\n   823→\n   824→\treturn &pb.StopRunResponse{}, nil\n   825→}\n   826→\n   827→func (s *ClocheServer) DeleteContainer(ctx context.Context, req *pb.DeleteContainerRequest) (*pb.DeleteContainerResponse, error) {\n   828→\tif s.container == nil {\n   829→\t\treturn nil, fmt.Errorf(\"no container runtime configured\")\n   830→\t}\n   831→\n   832→\tid := req.Id\n   833→\tif id == \"\" {\n   834→\t\treturn nil, fmt.Errorf(\"id is required\")\n   835→\t}\n   836→\n   837→\t// Try to resolve as a run ID first\n   838→\tcontainerID := id\n   839→\trun, err := s.store.GetRun(ctx, id)\n   840→\tif err == nil {\n   841→\t\t// It's a run ID — use the container ID from the run record\n   842→\t\tif run.ContainerID == \"\" {\n   843→\t\t\treturn nil, fmt.Errorf(\"run %q has no associated container\", id)\n   844→\t\t}\n   845→\t\tcontainerID = run.ContainerID\n   846→\t}\n   847→\n   848→\t// Remove the container\n   849→\tif err := s.container.Remove(ctx, containerID); err != nil {\n   850→\t\treturn nil, fmt.Errorf(\"removing container: %w\", err)\n   851→\t}\n   852→\n   853→\t// If we resolved a run, clear the container_kept flag\n   854→\tif run != nil {\n   855→\t\trun.ContainerKept = false\n   856→\t\t_ = s.store.UpdateRun(ctx, run)\n   857→\t}\n   858→\n   859→\treturn &pb.DeleteContainerResponse{}, nil\n   860→}\n   861→\n   862→func (s *ClocheServer) EnableLoop(ctx context.Context, req *pb.EnableLoopRequest) (*pb.EnableLoopResponse, error) {\n   863→\tprojectDir := req.ProjectDir\n   864→\tif projectDir == \"\" {\n   865→\t\treturn nil, fmt.Errorf(\"project_dir is required\")\n   866→\t}\n   867→\n   868→\t// Verify host.cloche exists\n   869→\thostPath := filepath.Join(projectDir, \".cloche\", \"host.cloche\")\n   870→\tif _, err := os.Stat(hostPath); err != nil {\n   871→\t\treturn nil, fmt.Errorf(\"host.cloche not found in %s: %w\", projectDir, err)\n   872→\t}\n   873→\n   874→\t// Load project config for defaults.\n   875→\tprojCfg, _ := config.Load(projectDir)\n   876→\n   877→\tmaxConc := int(req.MaxConcurrent)\n   878→\tif maxConc <= 0 {\n   879→\t\tmaxConc = projCfg.Orchestration.Concurrency\n   880→\t}\n   881→\tif maxConc <= 0 {\n   882→\t\tmaxConc = 1\n   883→\t}\n   884→\n   885→\tstagger := time.Duration(float64(time.Second) * projCfg.Orchestration.StaggerSeconds)\n   886→\n   887→\t// Compute dedup timeout from config (default 5 minutes).\n   888→\tdedupTimeout := time.Duration(float64(time.Second) * projCfg.Orchestration.DedupSeconds)\n   889→\n   890→\tloopCfg := host.LoopConfig{\n   891→\t\tProjectDir:    projectDir,\n   892→\t\tMaxConcurrent: maxConc,\n   893→\t\tStaggerDelay:  stagger,\n   894→\t\tDedupTimeout:  dedupTimeout,\n   895→\t}\n   896→\n   897→\ts.mu.Lock()\n   898→\tdefer s.mu.Unlock()\n   899→\n   900→\t// Stop existing loop if running.\n   901→\tif existing, ok := s.loops[projectDir]; ok {\n   902→\t\texisting.Stop()\n   903→\t}\n   904→\n   905→\t// Check if host.cloche defines a list-tasks workflow for three-phase mode.\n   906→\tvar loop *host.Loop\n   907→\tif s.hasWorkflow(hostPath, \"list-tasks\") {\n   908→\t\tloop = s.createPhaseLoop(loopCfg, projectDir, hostPath, dedupTimeout)\n   909→\t} else {\n   910→\t\tloop = s.createLegacyLoop(loopCfg, projectDir, projCfg, dedupTimeout)\n   911→\t}\n   912→\n   913→\ts.loops[projectDir] = loop\n   914→\tloop.Start()\n   915→\n   916→\treturn &pb.EnableLoopResponse{}, nil\n   917→}\n   918→\n   919→// hasWorkflow checks if host.cloche contains a workflow with the given name.\n   920→func (s *ClocheServer) hasWorkflow(hostPath, workflowName string) bool {\n   921→\tdata, err := os.ReadFile(hostPath)\n   922→\tif err != nil {\n   923→\t\treturn false\n   924→\t}\n   925→\treturn strings.Contains(string(data), fmt.Sprintf(\"workflow %q\", workflowName))\n   926→}\n   927→\n   928→// createPhaseLoop creates a three-phase orchestration loop using list-tasks,\n   929→// main, and finalize workflows from host.cloche.\n   930→func (s *ClocheServer) createPhaseLoop(loopCfg host.LoopConfig, projectDir, hostPath string, dedupTimeout time.Duration) *host.Loop {\n   931→\t// Phase 1: list-tasks function\n   932→\tlistTasksFn := func(ctx context.Context, projDir string) ([]host.Task, error) {\n   933→\t\trunner := &host.Runner{\n   934→\t\t\tDispatcher: s,\n   935→\t\t\tStore:      s.store,\n   936→\t\t}\n   937→\t\ttasks, _, err := host.RunListTasksWorkflow(ctx, runner, projDir)\n   938→\t\treturn tasks, err\n   939→\t}\n   940→\n   941→\t// Phase 2: main function\n   942→\tmainFn := func(ctx context.Context, projDir string, taskID string) (*host.RunResult, error) {\n   943→\t\trunner := &host.Runner{\n   944→\t\t\tDispatcher:   s,\n   945→\t\t\tStore:        s.store,\n   946→\t\t\tCaptures:     s.captures,\n   947→\t\t\tLogBroadcast: s.logBroadcast,\n   948→\t\t\tTaskID:       taskID,\n   949→\t\t}\n   950→\t\treturn runner.RunNamed(ctx, projDir, \"main\")\n   951→\t}\n   952→\n   953→\t// Phase 3: finalize function (optional — only if host.cloche has it)\n   954→\tvar finalizeFn host.FinalizeFunc\n   955→\tif s.hasWorkflow(hostPath, \"finalize\") {\n   956→\t\tfinalizeFn = func(ctx context.Context, projDir string, taskID string, mainResult *host.RunResult) (*host.RunResult, error) {\n   957→\t\t\tmainRunID := \"\"\n   958→\t\t\tmainOutcome := \"failed\"\n   959→\t\t\tif mainResult != nil {\n   960→\t\t\t\tmainRunID = mainResult.RunID\n   961→\t\t\t\tmainOutcome = string(mainResult.State)\n   962→\t\t\t}\n   963→\t\t\trunner := &host.Runner{\n   964→\t\t\t\tDispatcher:   s,\n   965→\t\t\t\tStore:        s.store,\n   966→\t\t\t\tCaptures:     s.captures,\n   967→\t\t\t\tLogBroadcast: s.logBroadcast,\n   968→\t\t\t\tTaskID:       taskID,\n   969→\t\t\t\tExtraEnv: []string{\n   970→\t\t\t\t\t\"CLOCHE_MAIN_RUN_ID=\" + mainRunID,\n   971→\t\t\t\t\t\"CLOCHE_MAIN_OUTCOME=\" + mainOutcome,\n   972→\t\t\t\t},\n   973→\t\t\t}\n   974→\t\t\treturn runner.RunNamed(ctx, projDir, \"finalize\")\n   975→\t\t}\n   976→\t}\n   977→\n   978→\tlog.Printf(\"orchestration loop: three-phase mode enabled for %s (list-tasks + main + finalize, dedup=%s)\", projectDir, dedupTimeout)\n   979→\treturn host.NewPhaseLoop(loopCfg, s.store, listTasksFn, mainFn, finalizeFn)\n   980→}\n   981→\n   982→// createLegacyLoop creates a legacy single-function orchestration loop.\n   983→func (s *ClocheServer) createLegacyLoop(loopCfg host.LoopConfig, projectDir string, projCfg *config.Config, dedupTimeout time.Duration) *host.Loop {\n   984→\trunFn := func(ctx context.Context, projDir string, taskID string) (*host.RunResult, error) {\n   985→\t\trunner := &host.Runner{\n   986→\t\t\tDispatcher:   s,\n   987→\t\t\tStore:        s.store,\n   988→\t\t\tCaptures:     s.captures,\n   989→\t\t\tLogBroadcast: s.logBroadcast,\n   990→\t\t\tTaskID:       taskID,\n   991→\t\t}\n   992→\t\treturn runner.Run(ctx, projDir)\n   993→\t}\n   994→\n   995→\tloop := host.NewLoop(loopCfg, s.store, runFn)\n   996→\n   997→\t// Configure daemon-managed task assignment if a list-tasks command is set.\n   998→\tif cmd := projCfg.Orchestration.ListTasksCommand; cmd != \"\" {\n   999→\t\tloop.SetTaskAssigner(&host.ScriptTaskAssigner{Command: cmd})\n  1000→\t\tlog.Printf(\"orchestration loop: task assignment enabled for %s (command=%q, dedup=%s)\", projectDir, cmd, dedupTimeout)\n  1001→\t}\n  1002→\n  1003→\treturn loop\n  1004→}\n  1005→\n  1006→// GetLoopTasks returns the current task pipeline state for a project's\n  1007→// orchestration loop, formatted as web.TaskEntry values. Returns nil if no\n  1008→// loop is active for the project.\n  1009→func (s *ClocheServer) GetLoopTasks(projectDir string) []web.TaskEntry {\n  1010→\ts.mu.Lock()\n  1011→\tloop, ok := s.loops[projectDir]\n  1012→\ts.mu.Unlock()\n  1013→\tif !ok {\n  1014→\t\treturn nil\n  1015→\t}\n  1016→\tsnapshot := loop.GetTaskSnapshot()\n  1017→\n  1018→\t// Build a set of task IDs that have active (pending/running) runs.\n  1019→\tactiveTaskIDs := make(map[string]bool)\n  1020→\tctx := context.Background()\n  1021→\tallRuns, _ := s.store.ListRunsByProject(ctx, projectDir, time.Time{})\n  1022→\tfor _, r := range allRuns {\n  1023→\t\tif r.TaskID != \"\" && (r.State == domain.RunStatePending || r.State == domain.RunStateRunning) {\n  1024→\t\t\tactiveTaskIDs[r.TaskID] = true\n  1025→\t\t}\n  1026→\t}\n  1027→\n  1028→\tentries := make([]web.TaskEntry, len(snapshot))\n  1029→\tfor i, e := range snapshot {\n  1030→\t\tentry := web.TaskEntry{\n  1031→\t\t\tID:          e.Task.ID,\n  1032→\t\t\tStatus:      e.Task.Status,\n  1033→\t\t\tTitle:       e.Task.Title,\n  1034→\t\t\tDescription: e.Task.Description,\n  1035→\t\t\tMetadata:    e.Task.Metadata,\n  1036→\t\t\tAssigned:    e.Assigned,\n  1037→\t\t\tRunID:       e.RunID,\n  1038→\t\t}\n  1039→\t\tif !e.AssignedAt.IsZero() {\n  1040→\t\t\tentry.AssignedAt = e.AssignedAt.Format(time.RFC3339)\n  1041→\t\t}\n  1042→\t\t// Stale: task is in_progress but has no active worker.\n  1043→\t\tif host.TaskStatus(e.Task.Status) == host.TaskStatusInProgress && !activeTaskIDs[e.Task.ID] {\n  1044→\t\t\tentry.Stale = true\n  1045→\t\t}\n  1046→\t\tentries[i] = entry\n  1047→\t}\n  1048→\treturn entries\n  1049→}\n  1050→\n  1051→// ReleaseTask runs the release-task host workflow for a specific task,\n  1052→// returning it to open status.\n  1053→func (s *ClocheServer) ReleaseTask(ctx context.Context, projectDir string, taskID string) error {\n  1054→\trunner := &host.Runner{\n  1055→\t\tDispatcher:   s,\n  1056→\t\tStore:        s.store,\n  1057→\t\tCaptures:     s.captures,\n  1058→\t\tLogBroadcast: s.logBroadcast,\n  1059→\t\tTaskID:       taskID,\n  1060→\t}\n  1061→\tresult, err := runner.RunNamed(ctx, projectDir, \"release-task\")\n  1062→\tif err != nil {\n  1063→\t\treturn fmt.Errorf(\"release-task workflow failed: %w\", err)\n  1064→\t}\n  1065→\tif result.State != domain.RunStateSucceeded {\n  1066→\t\treturn fmt.Errorf(\"release-task workflow finished with state %s\", result.State)\n  1067→\t}\n  1068→\treturn nil\n  1069→}\n  1070→\n  1071→func (s *ClocheServer) DisableLoop(ctx context.Context, req *pb.DisableLoopRequest) (*pb.DisableLoopResponse, error) {\n  1072→\tprojectDir := req.ProjectDir\n  1073→\tif projectDir == \"\" {\n  1074→\t\treturn nil, fmt.Errorf(\"project_dir is required\")\n  1075→\t}\n  1076→\n  1077→\ts.mu.Lock()\n  1078→\tdefer s.mu.Unlock()\n  1079→\n  1080→\tif loop, ok := s.loops[projectDir]; ok {\n  1081→\t\tloop.Stop()\n  1082→\t\tdelete(s.loops, projectDir)\n  1083→\t}\n  1084→\n  1085→\treturn &pb.DisableLoopResponse{}, nil\n  1086→}\n  1087→\n  1088→func (s *ClocheServer) GetProjectInfo(ctx context.Context, req *pb.GetProjectInfoRequest) (*pb.GetProjectInfoResponse, error) {\n  1089→\tprojectDir := req.ProjectDir\n  1090→\n  1091→\t// Resolve by name if provided.\n  1092→\tif req.Name != \"\" && projectDir == \"\" {\n  1093→\t\tprojects, err := s.store.ListProjects(ctx)\n  1094→\t\tif err != nil {\n  1095→\t\t\treturn nil, fmt.Errorf(\"listing projects: %w\", err)\n  1096→\t\t}\n  1097→\t\tlabels := projectLabels(projects)\n  1098→\t\tfound := false\n  1099→\t\tfor dir, label := range labels {\n  1100→\t\t\tif label == req.Name {\n  1101→\t\t\t\tprojectDir = dir\n  1102→\t\t\t\tfound = true\n  1103→\t\t\t\tbreak\n  1104→\t\t\t}\n  1105→\t\t}\n  1106→\t\tif !found {\n  1107→\t\t\treturn nil, fmt.Errorf(\"project %q not found\", req.Name)\n  1108→\t\t}\n  1109→\t}\n  1110→\n  1111→\tif projectDir == \"\" {\n  1112→\t\treturn nil, fmt.Errorf(\"project_dir or name is required\")\n  1113→\t}\n  1114→\n  1115→\t// Derive project label.\n  1116→\tprojects, _ := s.store.ListProjects(ctx)\n  1117→\tlabels := projectLabels(projects)\n  1118→\tlabel := labels[projectDir]\n  1119→\tif label == \"\" {\n  1120→\t\tlabel = filepath.Base(projectDir)\n  1121→\t}\n  1122→\n  1123→\t// Load config.\n  1124→\tcfg, _ := config.Load(projectDir)\n  1125→\n  1126→\t// Check loop state.\n  1127→\ts.mu.Lock()\n  1128→\tloop, loopExists := s.loops[projectDir]\n  1129→\ts.mu.Unlock()\n  1130→\tloopRunning := loopExists && loop != nil && loop.Running()\n  1131→\n  1132→\t// Get active runs.\n  1133→\tallRuns, _ := s.store.ListRunsByProject(ctx, projectDir, time.Time{})\n  1134→\tvar activeRuns []*pb.RunSummary\n  1135→\tfor _, run := range allRuns {\n  1136→\t\tif run.State == domain.RunStatePending || run.State == domain.RunStateRunning {\n  1137→\t\t\tactiveRuns = append(activeRuns, &pb.RunSummary{\n  1138→\t\t\t\tRunId:        run.ID,\n  1139→\t\t\t\tWorkflowName: run.WorkflowName,\n  1140→\t\t\t\tState:        string(run.State),\n  1141→\t\t\t\tStartedAt:    run.StartedAt.String(),\n  1142→\t\t\t\tTitle:        run.Title,\n  1143→\t\t\t\tIsHost:       run.IsHost,\n  1144→\t\t\t\tContainerId:  run.ContainerID,\n  1145→\t\t\t})\n  1146→\t\t}\n  1147→\t}\n  1148→\n  1149→\t// Discover workflows.\n  1150→\tvar containerWorkflows, hostWorkflows []string\n  1151→\tclocheDir := filepath.Join(projectDir, \".cloche\")\n  1152→\tentries, _ := filepath.Glob(filepath.Join(clocheDir, \"*.cloche\"))\n  1153→\tfor _, path := range entries {\n  1154→\t\tbase := filepath.Base(path)\n  1155→\t\tdata, err := os.ReadFile(path)\n  1156→\t\tif err != nil {\n  1157→\t\t\tcontinue\n  1158→\t\t}\n  1159→\t\tif base == \"host.cloche\" {\n  1160→\t\t\twfs, err := dsl.ParseAllForHost(string(data))\n  1161→\t\t\tif err != nil {\n  1162→\t\t\t\tcontinue\n  1163→\t\t\t}\n  1164→\t\t\tfor name := range wfs {\n  1165→\t\t\t\thostWorkflows = append(hostWorkflows, name)\n  1166→\t\t\t}\n  1167→\t\t} else {\n  1168→\t\t\twf, err := dsl.ParseForContainer(string(data))\n  1169→\t\t\tif err != nil {\n  1170→\t\t\t\tcontinue\n  1171→\t\t\t}\n  1172→\t\t\tcontainerWorkflows = append(containerWorkflows, wf.Name)\n  1173→\t\t}\n  1174→\t}\n  1175→\n  1176→\tsort.Strings(containerWorkflows)\n  1177→\tsort.Strings(hostWorkflows)\n  1178→\n  1179→\treturn &pb.GetProjectInfoResponse{\n  1180→\t\tProjectDir:         projectDir,\n  1181→\t\tName:               label,\n  1182→\t\tActive:             cfg.Active,\n  1183→\t\tConcurrency:        int32(cfg.Orchestration.Concurrency),\n  1184→\t\tStaggerSeconds:     cfg.Orchestration.StaggerSeconds,\n  1185→\t\tDedupSeconds:       cfg.Orchestration.DedupSeconds,\n  1186→\t\tEvolutionEnabled:   cfg.Evolution.Enabled,\n  1187→\t\tLoopRunning:        loopRunning,\n  1188→\t\tActiveRuns:         activeRuns,\n  1189→\t\tContainerWorkflows: containerWorkflows,\n  1190→\t\tHostWorkflows:      hostWorkflows,\n  1191→\t}, nil\n  1192→}\n  1193→\n  1194→// projectLabels maps each project directory to a short display label.\n  1195→// Uses basename unless there are conflicts, in which case parent/basename is used.\n  1196→func projectLabels(dirs []string) map[string]string {\n  1197→\tlabels := make(map[string]string, len(dirs))\n  1198→\tbyBase := map[string][]string{}\n  1199→\tfor _, d := range dirs {\n  1200→\t\tbase := filepath.Base(d)\n  1201→\t\tbyBase[base] = append(byBase[base], d)\n  1202→\t}\n  1203→\tfor base, paths := range byBase {\n  1204→\t\tif len(paths) == 1 {\n  1205→\t\t\tlabels[paths[0]] = base\n  1206→\t\t} else {\n  1207→\t\t\tfor _, p := range paths {\n  1208→\t\t\t\tparent := filepath.Base(filepath.Dir(p))\n  1209→\t\t\t\tlabels[p] = parent + \"/\" + base\n  1210→\t\t\t}\n  1211→\t\t}\n  1212→\t}\n  1213→\treturn labels\n  1214→}\n  1215→\n  1216→func (s *ClocheServer) GetVersion(ctx context.Context, req *pb.GetVersionRequest) (*pb.GetVersionResponse, error) {\n  1217→\treturn &pb.GetVersionResponse{Version: version.Version()}, nil\n  1218→}\n  1219→\n  1220→func (s *ClocheServer) Shutdown(ctx context.Context, req *pb.ShutdownRequest) (*pb.ShutdownResponse, error) {\n  1221→\t// Stop all orchestration loops.\n  1222→\ts.mu.Lock()\n  1223→\tfor _, loop := range s.loops {\n  1224→\t\tloop.Stop()\n  1225→\t}\n  1226→\ts.loops = make(map[string]*host.Loop)\n  1227→\ts.mu.Unlock()\n  1228→\n  1229→\tif s.shutdownFn == nil {\n  1230→\t\treturn nil, fmt.Errorf(\"shutdown not configured\")\n  1231→\t}\n  1232→\tgo s.shutdownFn()\n  1233→\treturn &pb.ShutdownResponse{}, nil\n  1234→}\n  1235→\n  1236→// indexLogFiles scans the extracted output directory and creates log_files index entries.\n  1237→func (s *ClocheServer) indexLogFiles(ctx context.Context, runID, outputDir string) {\n  1238→\tentries, err := os.ReadDir(outputDir)\n  1239→\tif err != nil {\n  1240→\t\tlog.Printf(\"run %s: failed to read output dir for indexing: %v\", runID, err)\n  1241→\t\treturn\n  1242→\t}\n  1243→\n  1244→\tnow := time.Now()\n  1245→\tfor _, entry := range entries {\n  1246→\t\tif entry.IsDir() {\n  1247→\t\t\tcontinue\n  1248→\t\t}\n  1249→\t\tname := entry.Name()\n  1250→\t\tif !strings.HasSuffix(name, \".log\") {\n  1251→\t\t\tcontinue\n  1252→\t\t}\n  1253→\n  1254→\t\tvar fileType, stepName string\n  1255→\t\tbase := strings.TrimSuffix(name, \".log\")\n  1256→\n  1257→\t\tswitch {\n  1258→\t\tcase name == \"full.log\":\n  1259→\t\t\tfileType = \"full\"\n  1260→\t\tcase name == \"container.log\":\n  1261→\t\t\t// container.log is internal, not indexed as a user-facing log type\n  1262→\t\t\tcontinue\n  1263→\t\tcase strings.HasPrefix(name, \"llm-\"):\n  1264→\t\t\tfileType = \"llm\"\n  1265→\t\t\tstepName = strings.TrimPrefix(base, \"llm-\")\n  1266→\t\tdefault:\n  1267→\t\t\tfileType = \"script\"\n  1268→\t\t\tstepName = base\n  1269→\t\t}\n  1270→\n  1271→\t\tinfo, _ := entry.Info()\n  1272→\t\tvar fileSize int64\n  1273→\t\tif info != nil {\n  1274→\t\t\tfileSize = info.Size()\n  1275→\t\t}\n  1276→\n  1277→\t\tlogEntry := &ports.LogFileEntry{\n  1278→\t\t\tRunID:     runID,\n  1279→\t\t\tStepName:  stepName,\n  1280→\t\t\tFileType:  fileType,\n  1281→\t\t\tFilePath:  filepath.Join(outputDir, name),\n  1282→\t\t\tFileSize:  fileSize,\n  1283→\t\t\tCreatedAt: now,\n  1284→\t\t}\n  1285→\t\tif err := s.logStore.SaveLogFile(ctx, logEntry); err != nil {\n  1286→\t\t\tlog.Printf(\"run %s: failed to index log file %s: %v\", runID, name, err)\n  1287→\t\t}\n  1288→\t}\n  1289→}\n  1290→\n  1291→func gitHEAD(dir string) string {\n  1292→\tcmd := exec.Command(\"git\", \"rev-parse\", \"HEAD\")\n  1293→\tcmd.Dir = dir\n  1294→\tout, err := cmd.Output()\n  1295→\tif err != nil {\n  1296→\t\treturn \"\"\n  1297→\t}\n  1298→\treturn strings.TrimSpace(string(out))\n  1299→}\n  1300→"}]},"parent_tool_use_id":"toolu_01SisYs2mGvpsHnZNXYBn119","session_id":"80e1ce2e-a764-409e-b43f-733763e5218d","uuid":"7e203e6b-decb-42ce-9d4f-b898bcdd0490"}
