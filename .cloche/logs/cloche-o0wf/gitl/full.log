[2026-03-13T19:58:53Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TiQyGrUHk8au46ihGsnuKt","type":"tool_result","content":"   487→func (s *ClocheServer) StreamLogs(req *pb.StreamLogsRequest, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n   488→\tctx := stream.Context()\n   489→\n   490→\t// Check for follow mode via gRPC metadata.\n   491→\tfollow := followFromContext(ctx)\n   492→\n   493→\t// Verify run exists\n   494→\trun, err := s.store.GetRun(ctx, req.RunId)\n   495→\tif err != nil {\n   496→\t\treturn fmt.Errorf(\"run %q not found: %w\", req.RunId, err)\n   497→\t}\n   498→\n   499→\t// If step_name or log_type filter is set, serve content directly from the log index\n   500→\tif req.StepName != \"\" || req.LogType != \"\" {\n   501→\t\treturn s.streamFilteredLogs(ctx, req, run, stream)\n   502→\t}\n   503→\n   504→\tisActive := run.State == domain.RunStateRunning || run.State == domain.RunStatePending\n   505→\n   506→\t// With -f on an active run: send existing logs then tail live output.\n   507→\tif follow && isActive && s.logBroadcast != nil {\n   508→\t\treturn s.streamFollowLogs(req.RunId, run, stream)\n   509→\t}\n   510→\n   511→\t// Without -f on an active run: snapshot existing logs and return.\n   512→\t// (Legacy callers that relied on implicit live streaming should use -f.)\n   513→\t// With -f on a completed run: same as without -f — no new lines will arrive.\n   514→\n   515→\t// Check for full.log first — if it exists, serve it as the unified log\n   516→\tfullLogPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", \"full.log\")\n   517→\tif data, readErr := os.ReadFile(fullLogPath); readErr == nil && len(data) > 0 {\n   518→\t\tif err := stream.Send(&pb.LogEntry{\n   519→\t\t\tType:    \"full_log\",\n   520→\t\t\tMessage: string(data),\n   521→\t\t}); err != nil {\n   522→\t\t\treturn err\n   523→\t\t}\n   524→\t\tif !isActive {\n   525→\t\t\tif err := stream.Send(&pb.LogEntry{\n   526→\t\t\t\tType:      \"run_completed\",\n   527→\t\t\t\tResult:    string(run.State),\n   528→\t\t\t\tTimestamp: run.CompletedAt.String(),\n   529→\t\t\t\tMessage:   run.ErrorMessage,\n   530→\t\t\t}); err != nil {\n   531→\t\t\t\treturn err\n   532→\t\t\t}\n   533→\t\t}\n   534→\t\treturn nil\n   535→\t}\n   536→\n   537→\tif s.captures == nil {\n   538→\t\treturn fmt.Errorf(\"captures store not configured\")\n   539→\t}\n   540→\n   541→\t// Fall back to capture-based streaming\n   542→\tcaptures, err := s.captures.GetCaptures(ctx, req.RunId)\n   543→\tif err != nil {\n   544→\t\treturn fmt.Errorf(\"getting captures: %w\", err)\n   545→\t}\n   546→\n   547→\tfor _, exec := range captures {\n   548→\t\t// Captures are stored as separate rows: one for step_started (no Result)\n   549→\t\t// and one for step_completed (has Result).\n   550→\t\tif exec.Result == \"\" {\n   551→\t\t\tentry := &pb.LogEntry{\n   552→\t\t\t\tType:      \"step_started\",\n   553→\t\t\t\tStepName:  exec.StepName,\n   554→\t\t\t\tTimestamp: exec.StartedAt.String(),\n   555→\t\t\t}\n   556→\t\t\tif err := stream.Send(entry); err != nil {\n   557→\t\t\t\treturn err\n   558→\t\t\t}\n   559→\t\t} else {\n   560→\t\t\t// Read step output from per-step output file.\n   561→\t\t\t// Container runs write .log, host runs write .out — try both.\n   562→\t\t\tvar output string\n   563→\t\t\tfor _, ext := range []string{\".log\", \".out\"} {\n   564→\t\t\t\toutputPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", exec.StepName+ext)\n   565→\t\t\t\tif data, err := os.ReadFile(outputPath); err == nil && len(data) > 0 {\n   566→\t\t\t\t\toutput = string(data)\n   567→\t\t\t\t\tbreak\n   568→\t\t\t\t}\n   569→\t\t\t}\n   570→\t\t\tentry := &pb.LogEntry{\n   571→\t\t\t\tType:      \"step_completed\",\n   572→\t\t\t\tStepName:  exec.StepName,\n   573→\t\t\t\tResult:    exec.Result,\n   574→\t\t\t\tTimestamp: exec.CompletedAt.String(),\n   575→\t\t\t\tMessage:   output,\n   576→\t\t\t}\n   577→\t\t\tif err := stream.Send(entry); err != nil {\n   578→\t\t\t\treturn err\n   579→\t\t\t}\n   580→\t\t}\n   581→\t}\n   582→\n   583→\t// Send run completion entry\n   584→\tif !isActive {\n   585→\t\tif err := stream.Send(&pb.LogEntry{\n   586→\t\t\tType:      \"run_completed\",\n   587→\t\t\tResult:    string(run.State),\n   588→\t\t\tTimestamp: run.CompletedAt.String(),\n   589→\t\t\tMessage:   run.ErrorMessage,\n   590→\t\t}); err != nil {\n   591→\t\t\treturn err\n   592→\t\t}\n   593→\t}\n   594→\n   595→\treturn nil\n   596→}\n   597→\n   598→// followFromContext checks for the follow flag in gRPC metadata.\n   599→func followFromContext(ctx context.Context) bool {\n   600→\tmd, ok := metadata.FromIncomingContext(ctx)\n   601→\tif !ok {\n   602→\t\treturn false\n   603→\t}\n   604→\tvals := md.Get(\"x-cloche-follow\")\n   605→\treturn len(vals) > 0 && vals[0] == \"true\"\n   606→}\n   607→\n   608→// streamFollowLogs sends existing log content then tails live output from the\n   609→// broadcaster. It combines snapshot + live streaming (like tail -f).\n   610→func (s *ClocheServer) streamFollowLogs(runID string, run *domain.Run, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n   611→\t// Subscribe first so we don't miss lines written between read and subscribe.\n   612→\tsub := s.logBroadcast.Subscribe(runID)\n   613→\tdefer s.logBroadcast.Unsubscribe(runID, sub)\n   614→\n   615→\t// Send existing full.log content if available.\n   616→\tfullLogPath := filepath.Join(run.ProjectDir, \".cloche\", runID, \"output\", \"full.log\")\n   617→\tif data, err := os.ReadFile(fullLogPath); err == nil && len(data) > 0 {\n   618→\t\tif err := stream.Send(&pb.LogEntry{\n   619→\t\t\tType:    \"full_log\",\n   620→\t\t\tMessage: string(data),\n   621→\t\t}); err != nil {\n   622→\t\t\treturn err\n   623→\t\t}\n   624→\t}\n   625→\n   626→\t// Now tail live output from the broadcaster.\n   627→\tctx := stream.Context()\n   628→\tfor {\n   629→\t\tselect {\n   630→\t\tcase <-ctx.Done():\n   631→\t\t\treturn ctx.Err()\n   632→\t\tcase line, ok := <-sub.C:\n   633→\t\t\tif !ok {\n   634→\t\t\t\t// Run completed — send terminal entry.\n   635→\t\t\t\tr, err := s.store.GetRun(context.Background(), runID)\n   636→\t\t\t\tif err == nil && r.State != domain.RunStateRunning && r.State != domain.RunStatePending {\n   637→\t\t\t\t\t_ = stream.Send(&pb.LogEntry{\n   638→\t\t\t\t\t\tType:      \"run_completed\",\n   639→\t\t\t\t\t\tResult:    string(r.State),\n   640→\t\t\t\t\t\tTimestamp: r.CompletedAt.String(),\n   641→\t\t\t\t\t\tMessage:   r.ErrorMessage,\n   642→\t\t\t\t\t})\n   643→\t\t\t\t}\n   644→\t\t\t\treturn nil\n   645→\t\t\t}\n   646→\t\t\tif err := stream.Send(&pb.LogEntry{\n   647→\t\t\t\tType:      \"log\",\n   648→\t\t\t\tStepName:  line.StepName,\n   649→\t\t\t\tMessage:   line.Content,\n   650→\t\t\t\tTimestamp: line.Timestamp,\n   651→\t\t\t}); err != nil {\n   652→\t\t\t\treturn err\n   653→\t\t\t}\n   654→\t\t}\n   655→\t}\n   656→}\n   657→\n   658→// streamFilteredLogs serves log content filtered by step name and/or log type.\n   659→// It uses the log index when available, falling back to file path conventions.\n   660→func (s *ClocheServer) streamFilteredLogs(ctx context.Context, req *pb.StreamLogsRequest, run *domain.Run, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n   661→\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\")\n   662→\n   663→\t// Try log index first\n   664→\tif s.logStore != nil {\n   665→\t\tvar logFiles []*ports.LogFileEntry\n   666→\t\tvar err error\n   667→\n   668→\t\tif req.StepName != \"\" && req.LogType != \"\" {\n   669→\t\t\t// Filter by both step and type\n   670→\t\t\tlogFiles, err = s.logStore.GetLogFilesByStep(ctx, req.RunId, req.StepName)\n   671→\t\t\tif err == nil {\n   672→\t\t\t\tfiltered := logFiles[:0]\n   673→\t\t\t\tfor _, lf := range logFiles {\n   674→\t\t\t\t\tif lf.FileType == req.LogType {\n   675→\t\t\t\t\t\tfiltered = append(filtered, lf)\n   676→\t\t\t\t\t}\n   677→\t\t\t\t}\n   678→\t\t\t\tlogFiles = filtered\n   679→\t\t\t}\n   680→\t\t} else if req.StepName != \"\" {\n   681→\t\t\tlogFiles, err = s.logStore.GetLogFilesByStep(ctx, req.RunId, req.StepName)\n   682→\t\t} else {\n   683→\t\t\tlogFiles, err = s.logStore.GetLogFileByType(ctx, req.RunId, req.LogType)\n   684→\t\t}\n   685→\n   686→\t\tif err == nil && len(logFiles) > 0 {\n   687→\t\t\tfor _, lf := range logFiles {\n   688→\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n   689→\t\t\t\tif readErr != nil {\n   690→\t\t\t\t\tcontinue\n   691→\t\t\t\t}\n   692→\t\t\t\tif err := stream.Send(&pb.LogEntry{\n   693→\t\t\t\t\tType:     lf.FileType + \"_log\",\n   694→\t\t\t\t\tStepName: lf.StepName,\n   695→\t\t\t\t\tMessage:  string(data),\n   696→\t\t\t\t}); err != nil {\n   697→\t\t\t\t\treturn err\n   698→\t\t\t\t}\n   699→\t\t\t}\n   700→\t\t\treturn nil\n   701→\t\t}\n   702→\t}\n   703→\n   704→\t// Fall back to file path conventions\n   705→\tif req.StepName != \"\" {\n   706→\t\tvar logPath string\n   707→\t\tswitch req.LogType {\n   708→\t\tcase \"llm\":\n   709→\t\t\tlogPath = filepath.Join(outputDir, \"llm-\"+req.StepName+\".log\")\n   710→\t\tdefault:\n   711→\t\t\tlogPath = filepath.Join(outputDir, req.StepName+\".log\")\n   712→\t\t}\n   713→\n   714→\t\tdata, err := os.ReadFile(logPath)\n   715→\t\tif err != nil {\n   716→\t\t\treturn fmt.Errorf(\"log file not found for step %q: %w\", req.StepName, err)\n   717→\t\t}\n   718→\t\treturn stream.Send(&pb.LogEntry{\n   719→\t\t\tType:     \"step_log\",\n   720→\t\t\tStepName: req.StepName,\n   721→\t\t\tMessage:  string(data),\n   722→\t\t})\n   723→\t}\n   724→\n   725→\treturn fmt.Errorf(\"no log files found matching filter\")\n   726→}"}]},"parent_tool_use_id":null,"session_id":"96f32727-3069-4902-8837-5bfcf44ab35e","uuid":"5f3bc33b-7f92-4e36-b6a0-b9f84c707645","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/grpc/server.go","content":"func (s *ClocheServer) StreamLogs(req *pb.StreamLogsRequest, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n\tctx := stream.Context()\n\n\t// Check for follow mode via gRPC metadata.\n\tfollow := followFromContext(ctx)\n\n\t// Verify run exists\n\trun, err := s.store.GetRun(ctx, req.RunId)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"run %q not found: %w\", req.RunId, err)\n\t}\n\n\t// If step_name or log_type filter is set, serve content directly from the log index\n\tif req.StepName != \"\" || req.LogType != \"\" {\n\t\treturn s.streamFilteredLogs(ctx, req, run, stream)\n\t}\n\n\tisActive := run.State == domain.RunStateRunning || run.State == domain.RunStatePending\n\n\t// With -f on an active run: send existing logs then tail live output.\n\tif follow && isActive && s.logBroadcast != nil {\n\t\treturn s.streamFollowLogs(req.RunId, run, stream)\n\t}\n\n\t// Without -f on an active run: snapshot existing logs and return.\n\t// (Legacy callers that relied on implicit live streaming should use -f.)\n\t// With -f on a completed run: same as without -f — no new lines will arrive.\n\n\t// Check for full.log first — if it exists, serve it as the unified log\n\tfullLogPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", \"full.log\")\n\tif data, readErr := os.ReadFile(fullLogPath); readErr == nil && len(data) > 0 {\n\t\tif err := stream.Send(&pb.LogEntry{\n\t\t\tType:    \"full_log\",\n\t\t\tMessage: string(data),\n\t\t}); err != nil {\n\t\t\treturn err\n\t\t}\n\t\tif !isActive {\n\t\t\tif err := stream.Send(&pb.LogEntry{\n\t\t\t\tType:      \"run_completed\",\n\t\t\t\tResult:    string(run.State),\n\t\t\t\tTimestamp: run.CompletedAt.String(),\n\t\t\t\tMessage:   run.ErrorMessage,\n\t\t\t}); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t}\n\t\treturn nil\n\t}\n\n\tif s.captures == nil {\n\t\treturn fmt.Errorf(\"captures store not configured\")\n\t}\n\n\t// Fall back to capture-based streaming\n\tcaptures, err := s.captures.GetCaptures(ctx, req.RunId)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"getting captures: %w\", err)\n\t}\n\n\tfor _, exec := range captures {\n\t\t// Captures are stored as separate rows: one for step_started (no Result)\n\t\t// and one for step_completed (has Result).\n\t\tif exec.Result == \"\" {\n\t\t\tentry := &pb.LogEntry{\n\t\t\t\tType:      \"step_started\",\n\t\t\t\tStepName:  exec.StepName,\n\t\t\t\tTimestamp: exec.StartedAt.String(),\n\t\t\t}\n\t\t\tif err := stream.Send(entry); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t} else {\n\t\t\t// Read step output from per-step output file.\n\t\t\t// Container runs write .log, host runs write .out — try both.\n\t\t\tvar output string\n\t\t\tfor _, ext := range []string{\".log\", \".out\"} {\n\t\t\t\toutputPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", exec.StepName+ext)\n\t\t\t\tif data, err := os.ReadFile(outputPath); err == nil && len(data) > 0 {\n\t\t\t\t\toutput = string(data)\n\t\t\t\t\tbreak\n\t\t\t\t}\n\t\t\t}\n\t\t\tentry := &pb.LogEntry{\n\t\t\t\tType:      \"step_completed\",\n\t\t\t\tStepName:  exec.StepName,\n\t\t\t\tResult:    exec.Result,\n\t\t\t\tTimestamp: exec.CompletedAt.String(),\n\t\t\t\tMessage:   output,\n\t\t\t}\n\t\t\tif err := stream.Send(entry); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t}\n\t}\n\n\t// Send run completion entry\n\tif !isActive {\n\t\tif err := stream.Send(&pb.LogEntry{\n\t\t\tType:      \"run_completed\",\n\t\t\tResult:    string(run.State),\n\t\t\tTimestamp: run.CompletedAt.String(),\n\t\t\tMessage:   run.ErrorMessage,\n\t\t}); err != nil {\n\t\t\treturn err\n\t\t}\n\t}\n\n\treturn nil\n}\n\n// followFromContext checks for the follow flag in gRPC metadata.\nfunc followFromContext(ctx context.Context) bool {\n\tmd, ok := metadata.FromIncomingContext(ctx)\n\tif !ok {\n\t\treturn false\n\t}\n\tvals := md.Get(\"x-cloche-follow\")\n\treturn len(vals) > 0 && vals[0] == \"true\"\n}\n\n// streamFollowLogs sends existing log content then tails live output from the\n// broadcaster. It combines snapshot + live streaming (like tail -f).\nfunc (s *ClocheServer) streamFollowLogs(runID string, run *domain.Run, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n\t// Subscribe first so we don't miss lines written between read and subscribe.\n\tsub := s.logBroadcast.Subscribe(runID)\n\tdefer s.logBroadcast.Unsubscribe(runID, sub)\n\n\t// Send existing full.log content if available.\n\tfullLogPath := filepath.Join(run.ProjectDir, \".cloche\", runID, \"output\", \"full.log\")\n\tif data, err := os.ReadFile(fullLogPath); err == nil && len(data) > 0 {\n\t\tif err := stream.Send(&pb.LogEntry{\n\t\t\tType:    \"full_log\",\n\t\t\tMessage: string(data),\n\t\t}); err != nil {\n\t\t\treturn err\n\t\t}\n\t}\n\n\t// Now tail live output from the broadcaster.\n\tctx := stream.Context()\n\tfor {\n\t\tselect {\n\t\tcase <-ctx.Done():\n\t\t\treturn ctx.Err()\n\t\tcase line, ok := <-sub.C:\n\t\t\tif !ok {\n\t\t\t\t// Run completed — send terminal entry.\n\t\t\t\tr, err := s.store.GetRun(context.Background(), runID)\n\t\t\t\tif err == nil && r.State != domain.RunStateRunning && r.State != domain.RunStatePending {\n\t\t\t\t\t_ = stream.Send(&pb.LogEntry{\n\t\t\t\t\t\tType:      \"run_completed\",\n\t\t\t\t\t\tResult:    string(r.State),\n\t\t\t\t\t\tTimestamp: r.CompletedAt.String(),\n\t\t\t\t\t\tMessage:   r.ErrorMessage,\n\t\t\t\t\t})\n\t\t\t\t}\n\t\t\t\treturn nil\n\t\t\t}\n\t\t\tif err := stream.Send(&pb.LogEntry{\n\t\t\t\tType:      \"log\",\n\t\t\t\tStepName:  line.StepName,\n\t\t\t\tMessage:   line.Content,\n\t\t\t\tTimestamp: line.Timestamp,\n\t\t\t}); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t}\n\t}\n}\n\n// streamFilteredLogs serves log content filtered by step name and/or log type.\n// It uses the log index when available, falling back to file path conventions.\nfunc (s *ClocheServer) streamFilteredLogs(ctx context.Context, req *pb.StreamLogsRequest, run *domain.Run, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\")\n\n\t// Try log index first\n\tif s.logStore != nil {\n\t\tvar logFiles []*ports.LogFileEntry\n\t\tvar err error\n\n\t\tif req.StepName != \"\" && req.LogType != \"\" {\n\t\t\t// Filter by both step and type\n\t\t\tlogFiles, err = s.logStore.GetLogFilesByStep(ctx, req.RunId, req.StepName)\n\t\t\tif err == nil {\n\t\t\t\tfiltered := logFiles[:0]\n\t\t\t\tfor _, lf := range logFiles {\n\t\t\t\t\tif lf.FileType == req.LogType {\n\t\t\t\t\t\tfiltered = append(filtered, lf)\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t\tlogFiles = filtered\n\t\t\t}\n\t\t} else if req.StepName != \"\" {\n\t\t\tlogFiles, err = s.logStore.GetLogFilesByStep(ctx, req.RunId, req.StepName)\n\t\t} else {\n\t\t\tlogFiles, err = s.logStore.GetLogFileByType(ctx, req.RunId, req.LogType)\n\t\t}\n\n\t\tif err == nil && len(logFiles) > 0 {\n\t\t\tfor _, lf := range logFiles {\n\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n\t\t\t\tif readErr != nil {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tif err := stream.Send(&pb.LogEntry{\n\t\t\t\t\tType:     lf.FileType + \"_log\",\n\t\t\t\t\tStepName: lf.StepName,\n\t\t\t\t\tMessage:  string(data),\n\t\t\t\t}); err != nil {\n\t\t\t\t\treturn err\n\t\t\t\t}\n\t\t\t}\n\t\t\treturn nil\n\t\t}\n\t}\n\n\t// Fall back to file path conventions\n\tif req.StepName != \"\" {\n\t\tvar logPath string\n\t\tswitch req.LogType {\n\t\tcase \"llm\":\n\t\t\tlogPath = filepath.Join(outputDir, \"llm-\"+req.StepName+\".log\")\n\t\tdefault:\n\t\t\tlogPath = filepath.Join(outputDir, req.StepName+\".log\")\n\t\t}\n\n\t\tdata, err := os.ReadFile(logPath)\n\t\tif err != nil {\n\t\t\treturn fmt.Errorf(\"log file not found for step %q: %w\", req.StepName, err)\n\t\t}\n\t\treturn stream.Send(&pb.LogEntry{\n\t\t\tType:     \"step_log\",\n\t\t\tStepName: req.StepName,\n\t\t\tMessage:  string(data),\n\t\t})\n\t}\n\n\treturn fmt.Errorf(\"no log files found matching filter\")\n}","numLines":240,"startLine":487,"totalLines":1262}}}
