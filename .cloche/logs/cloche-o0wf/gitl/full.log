[2026-03-13T19:58:53Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BMs9xyrs3uEzuvdj5dqpGR","type":"tool_result","content":"     1→package prompt\n     2→\n     3→import (\n     4→\t\"bufio\"\n     5→\t\"bytes\"\n     6→\t\"context\"\n     7→\t\"encoding/json\"\n     8→\t\"fmt\"\n     9→\t\"os\"\n    10→\t\"os/exec\"\n    11→\t\"path/filepath\"\n    12→\t\"strconv\"\n    13→\t\"strings\"\n    14→\n    15→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    16→\t\"github.com/cloche-dev/cloche/internal/protocol\"\n    17→)\n    18→\n    19→// defaultAgentArgs maps known agent commands to their default arguments.\n    20→// Commands not in this map receive no default arguments (prompt on stdin only).\n    21→var defaultAgentArgs = map[string][]string{\n    22→\t\"claude\": {\"-p\", \"--output-format\", \"stream-json\", \"--verbose\", \"--dangerously-skip-permissions\"},\n    23→}\n    24→\n    25→type Adapter struct {\n    26→\tCommands     []string // ordered fallback chain of agent commands\n    27→\tExplicitArgs []string // if non-nil, overrides default args for all commands\n    28→\tRunID        string\n    29→\tStatusWriter *protocol.StatusWriter // optional: streams live output lines\n    30→}\n    31→\n    32→func New() *Adapter {\n    33→\treturn &Adapter{\n    34→\t\tCommands: []string{\"claude\"},\n    35→\t}\n    36→}\n    37→\n    38→func (a *Adapter) Name() string {\n    39→\treturn \"prompt\"\n    40→}\n    41→\n    42→// argsFor returns the arguments for the given command. If ExplicitArgs is set,\n    43→// it is used for all commands. Otherwise, known agents get their default args.\n    44→func (a *Adapter) argsFor(command string) []string {\n    45→\tif a.ExplicitArgs != nil {\n    46→\t\treturn a.ExplicitArgs\n    47→\t}\n    48→\tif args, ok := defaultAgentArgs[command]; ok {\n    49→\t\treturn args\n    50→\t}\n    51→\treturn nil\n    52→}\n    53→\n    54→// ParseCommands splits a comma-separated agent_command string into individual\n    55→// command names, trimming whitespace from each entry.\n    56→func ParseCommands(s string) []string {\n    57→\tparts := strings.Split(s, \",\")\n    58→\tvar cmds []string\n    59→\tfor _, p := range parts {\n    60→\t\tp = strings.TrimSpace(p)\n    61→\t\tif p != \"\" {\n    62→\t\t\tcmds = append(cmds, p)\n    63→\t\t}\n    64→\t}\n    65→\treturn cmds\n    66→}\n    67→\n    68→func (a *Adapter) Execute(ctx context.Context, step *domain.Step, workDir string) (string, error) {\n    69→\t// Check attempt count for retry limiting\n    70→\tif maxStr, ok := step.Config[\"max_attempts\"]; ok {\n    71→\t\tmax, err := strconv.Atoi(maxStr)\n    72→\t\tif err == nil {\n    73→\t\t\tcount := readAttemptCount(workDir, step.Name)\n    74→\t\t\tif count >= max {\n    75→\t\t\t\treturn \"give-up\", nil\n    76→\t\t\t}\n    77→\t\t}\n    78→\t}\n    79→\tincrementAttemptCount(workDir, step.Name)\n    80→\n    81→\t// Build the full prompt\n    82→\tfullPrompt, err := assemblePrompt(step, workDir, a.RunID)\n    83→\tif err != nil {\n    84→\t\treturn \"\", fmt.Errorf(\"assembling prompt: %w\", err)\n    85→\t}\n    86→\n    87→\t// Try each command in the fallback chain\n    88→\tvar lastResult string\n    89→\tvar lastStdout []byte\n    90→\tvar lastErr error\n    91→\tran := false\n    92→\n    93→\tfor _, command := range a.Commands {\n    94→\t\tresult, stdout, fallbackErr := a.tryCommand(ctx, command, fullPrompt, workDir, step.Name)\n    95→\t\tlastResult = result\n    96→\t\tlastStdout = stdout\n    97→\t\tlastErr = fallbackErr\n    98→\n    99→\t\tif fallbackErr == nil {\n   100→\t\t\t// Definitive result — agent completed (exit 0 or exit non-zero with marker)\n   101→\t\t\tbreak\n   102→\t\t}\n   103→\t\tif stdout != nil {\n   104→\t\t\tran = true\n   105→\t\t}\n   106→\t\t// Fallback-eligible — try next command\n   107→\t}\n   108→\n   109→\tif lastErr != nil && !ran && lastStdout == nil {\n   110→\t\t// All commands failed to produce any output (e.g., all not found)\n   111→\t\treturn \"\", lastErr\n   112→\t}\n   113→\n   114→\tresult := lastResult\n   115→\tif lastErr != nil {\n   116→\t\t// Last command in chain crashed without a result marker\n   117→\t\tresult = \"fail\"\n   118→\t}\n   119→\n   120→\t// Reset attempt counter on success so give-up only triggers after\n   121→\t// consecutive failures, not after successful fixes whose downstream\n   122→\t// tests fail for unrelated reasons.\n   123→\tif result == \"success\" {\n   124→\t\tresetAttemptCount(workDir, step.Name)\n   125→\t}\n   126→\n   127→\t// Write output file\n   128→\toutputDir := filepath.Join(workDir, \".cloche\", \"output\")\n   129→\tif mkErr := os.MkdirAll(outputDir, 0755); mkErr == nil {\n   130→\t\t_ = os.WriteFile(filepath.Join(outputDir, step.Name+\".log\"), lastStdout, 0644)\n   131→\t}\n   132→\tprotocol.AppendHistory(workDir, step.Name, result, true, nil)\n   133→\treturn result, nil\n   134→}\n   135→\n   136→// tryCommand executes a single agent command and returns:\n   137→//   - result: the step result name (e.g. \"success\", \"fail\")\n   138→//   - stdout: captured stdout bytes\n   139→//   - fallbackErr: nil if the result is definitive, non-nil if fallback-eligible\n   140→//\n   141→// Fallback-eligible conditions:\n   142→//   - Command not found or failed to start (stdout will be nil)\n   143→//   - Command exited non-zero without a CLOCHE_RESULT marker\n   144→//\n   145→// Definitive (non-fallback) conditions:\n   146→//   - Command exited 0\n   147→//   - Command exited non-zero but produced a CLOCHE_RESULT marker\n   148→func (a *Adapter) tryCommand(ctx context.Context, command string, prompt string, workDir string, stepName string) (result string, stdout []byte, fallbackErr error) {\n   149→\targs := a.argsFor(command)\n   150→\tcmd := exec.CommandContext(ctx, command, args...)\n   151→\tcmd.Dir = workDir\n   152→\tcmd.Stdin = strings.NewReader(prompt)\n   153→\n   154→\t// If we have a StatusWriter, stream stdout line-by-line; otherwise buffer.\n   155→\tif a.StatusWriter == nil {\n   156→\t\tvar stdoutBuf, stderrBuf bytes.Buffer\n   157→\t\tcmd.Stdout = &stdoutBuf\n   158→\t\tcmd.Stderr = &stderrBuf\n   159→\n   160→\t\trunErr := cmd.Run()\n   161→\t\tstdoutBytes := stdoutBuf.Bytes()\n   162→\t\treturn a.classifyResult(command, stdoutBytes, runErr)\n   163→\t}\n   164→\n   165→\t// Streaming path: pipe stdout through a scanner so we can emit lines live.\n   166→\tpipe, err := cmd.StdoutPipe()\n   167→\tif err != nil {\n   168→\t\treturn \"\", nil, fmt.Errorf(\"command %q stdout pipe: %w\", command, err)\n   169→\t}\n   170→\tcmd.Stderr = nil // discard stderr\n   171→\n   172→\tif err := cmd.Start(); err != nil {\n   173→\t\treturn \"\", nil, fmt.Errorf(\"command %q failed to start: %w\", command, err)\n   174→\t}\n   175→\n   176→\t// textBuf accumulates extracted text content for result extraction.\n   177→\t// rawBuf accumulates raw stdout for the output log file.\n   178→\tvar textBuf, rawBuf bytes.Buffer\n   179→\t// lineBuf accumulates text deltas into lines for streaming.\n   180→\tvar lineBuf strings.Builder\n   181→\n   182→\tscanner := bufio.NewScanner(pipe)\n   183→\tscanner.Buffer(make([]byte, 0, 256*1024), 1024*1024)\n   184→\tfor scanner.Scan() {\n   185→\t\traw := scanner.Bytes()\n   186→\t\trawBuf.Write(raw)\n   187→\t\trawBuf.WriteByte('\\n')\n   188→\n   189→\t\ttext := extractStreamText(raw)\n   190→\t\tif text == \"\" {\n   191→\t\t\tcontinue\n   192→\t\t}\n   193→\t\ttextBuf.WriteString(text)\n   194→\n   195→\t\t// Stream complete lines to StatusWriter as they form.\n   196→\t\tlineBuf.WriteString(text)\n   197→\t\tfor {\n   198→\t\t\ts := lineBuf.String()\n   199→\t\t\tidx := strings.IndexByte(s, '\\n')\n   200→\t\t\tif idx < 0 {"}]},"parent_tool_use_id":"toolu_013Y5EJhPZgAJrRFK4ZZsW2U","session_id":"96f32727-3069-4902-8837-5bfcf44ab35e","uuid":"5feebfa4-ae99-49ed-8d43-ef1b833912bc"}
