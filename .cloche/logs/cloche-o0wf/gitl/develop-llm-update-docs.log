64→\t\treturn\n    65→\tcase \"get\":\n    66→\t\tif hasHelpFlag(os.Args[2:]) {\n    67→\t\t\tprintSubcommandHelp(\"get\")\n    68→\t\t\treturn\n    69→\t\t}\n    70→\t\tcmdGet(os.Args[2:])\n    71→\t\treturn\n    72→\tcase \"set\":\n    73→\t\tif hasHelpFlag(os.Args[2:]) {\n    74→\t\t\tprintSubcommandHelp(\"set\")\n    75→\t\t\treturn\n    76→\t\t}\n    77→\t\tcmdSet(os.Args[2:])\n    78→\t\treturn\n    79→\tcase \"tasks\":\n    80→\t\tif hasHelpFlag(os.Args[2:]) {\n    81→\t\t\tprintSubcommandHelp(\"tasks\")\n    82→\t\t\treturn\n    83→\t\t}\n    84→\t\tcmdTasks(os.Args[2:])\n    85→\t\treturn\n    86→\tcase \"workflow\":\n    87→\t\tif hasHelpFlag(os.Args[2:]) {\n    88→\t\t\tprintSubcommandHelp(\"workflow\")\n    89→\t\t\treturn\n    90→\t\t}\n    91→\t\tcmdWorkflow(os.Args[2:])\n    92→\t\treturn\n    93→\tcase \"project\":\n    94→\t\tif hasHelpFlag(os.Args[2:]) {\n    95→\t\t\tprintSubcommandHelp(\"project\")\n    96→\t\t\treturn\n    97→\t\t}\n    98→\t\tcmdProject(os.Args[2:])\n    99→\t\treturn\n   100→\t}\n   101→\n   102→\t// Handle --help for daemon commands before connecting\n   103→\tdaemonCmds := map[string]bool{\n   104→\t\t\"run\": true, \"status\": true, \"logs\": true, \"poll\": true,\n   105→\t\t\"list\": true, \"stop\": true, \"delete\": true, \"loop\": true, \"shutdown\": true,\n   106→\t}\n   107→\tif daemonCmds[os.Args[1]] && hasHelpFlag(os.Args[2:]) {\n   108→\t\tprintSubcommandHelp(os.Args[1])\n   109→\t\treturn\n   110→\t}\n   111→\n   112→\t// Commands that need a daemon connection\n   113→\taddr := os.Getenv(\"CLOCHE_ADDR\")\n   114→\tif addr == \"\" {\n   115→\t\taddr = \"unix:///tmp/cloche.sock\"\n   116→\t}\n   117→\n   118→\tconn, err := grpc.NewClient(addr, grpc.WithTransportCredentials(insecure.NewCredentials()))\n   119→\tif err != nil {\n   120→\t\tfmt.Fprintf(os.Stderr, \"failed to connect: %v\\n\", err)\n   121→\t\tos.Exit(1)\n   122→\t}\n   123→\tdefer conn.Close()\n   124→\n   125→\tclient := pb.NewClocheServiceClient(conn)\n   126→\tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n   127→\tdefer cancel()\n   128→\n   129→\tswitch os.Args[1] {\n   130→\tcase \"run\":\n   131→\t\tcmdRun(ctx, client, os.Args[2:])\n   132→\tcase \"status\":\n   133→\t\tcmdStatus(ctx, client, os.Args[2:])\n   134→\tcase \"logs\":\n   135→\t\tcmdLogs(client, os.Args[2:])\n   136→\tcase \"poll\":\n   137→\t\tcmdPoll(client, os.Args[2:])\n   138→\tcase \"list\":\n   139→\t\tcmdList(ctx, client, os.Args[2:])\n   140→\tcase \"stop\":\n   141→\t\tcmdStop(ctx, client, os.Args[2:])\n   142→\tcase \"delete\":\n   143→\t\tcmdDelete(ctx, client, os.Args[2:])\n   144→\tcase \"loop\":\n   145→\t\tcmdLoop(ctx, client, os.Args[2:])\n   146→\tcase \"shutdown\":\n   147→\t\tcmdShutdown(ctx, client)\n   148→\tdefault:\n   149→\t\tfmt.Fprintf(os.Stderr, \"unknown command: %s\\n\\n\", os.Args[1])\n   150→\t\tprintTopLevelHelp()\n   151→\t\tos.Exit(1)\n   152→\t}\n   153→}\n   154→\n   155→\n   156→func cmdRun(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   157→\tvar workflow, prompt, title string\n   158→\tvar keepContainer bool\n   159→\n   160→\tfor i := 0; i < len(args); i++ {\n   161→\t\tswitch args[i] {\n   162→\t\tcase \"--workflow\":\n   163→\t\t\tif i+1 < len(args) {\n   164→\t\t\t\ti++\n   165→\t\t\t\tworkflow = args[i]\n   166→\t\t\t}\n   167→\t\tcase \"--prompt\", \"-p\":\n   168→\t\t\tif i+1 < len(args) {\n   169→\t\t\t\ti++\n   170→\t\t\t\tprompt = args[i]\n   171→\t\t\t}\n   172→\t\tcase \"--title\":\n   173→\t\t\tif i+1 < len(args) {\n   174→\t\t\t\ti++\n   175→\t\t\t\ttitle = args[i]\n   176→\t\t\t}\n   177→\t\tcase \"--keep-container\":\n   178→\t\t\tkeepContainer = true\n   179→\t\tdefault:\n   180→\t\t\t// Support bare positional arg as workflow name for backwards compat\n   181→\t\t\tif workflow == \"\" && !strings.HasPrefix(args[i], \"-\") {\n   182→\t\t\t\tworkflow = args[i]\n   183→\t\t\t}\n   184→\t\t}\n   185→\t}\n   186→\n   187→\tif workflow == \"\" {\n   188→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche run --workflow <name> [--prompt \\\"...\\\"] [--title \\\"...\\\"]\\n\")\n   189→\t\tos.Exit(1)\n   190→\t}\n   191→\n   192→\tcwd, _ := os.Getwd()\n   193→\n   194→\t// Resolve image from workflow file (soft failure — fall back to daemon default)\n   195→\tvar image string\n   196→\twfPath := filepath.Join(cwd, \".cloche\", workflow+\".cloche\")\n   197→\tif data, err := os.ReadFile(wfPath); err == nil {\n   198→\t\tif wf, err := dsl.ParseForContainer(string(data)); err == nil {\n   199→\t\t\timage = wf.Config[\"container.image\"]\n   200→\t\t}\n   201→\t}\n   202→\n   203→\tresp, err := client.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n   204→\t\tWorkflowName:  workflow,\n   205→\t\tProjectDir:    cwd,\n   206→\t\tImage:         image,\n   207→\t\tPrompt:        prompt,\n   208→\t\tKeepContainer: keepContainer,\n   209→\t\tTitle:         title,\n   210→\t})\n   211→\tif err != nil {\n   212→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   213→\t\tos.Exit(1)\n   214→\t}\n   215→\tfmt.Printf(\"Started run: %s\\n\", resp.RunId)\n   216→}\n   217→\n   218→func cmdStatus(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   219→\tif len(args) < 1 {\n   220→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche status <run-id>\\n\")\n   221→\t\tos.Exit(1)\n   222→\t}\n   223→\n   224→\tresp, err := client.GetStatus(ctx, &pb.GetStatusRequest{RunId: args[0]})\n   225→\tif err != nil {\n   226→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   227→\t\tos.Exit(1)\n   228→\t}\n   229→\n   230→\tfmt.Printf(\"Run:       %s\\n\", resp.RunId)\n   231→\tif resp.Title != \"\" {\n   232→\t\tfmt.Printf(\"Title:     %s\\n\", resp.Title)\n   233→\t}\n   234→\tfmt.Printf(\"Workflow:  %s\\n\", resp.WorkflowName)\n   235→\tif resp.IsHost {\n   236→\t\tfmt.Printf(\"Type:      host\\n\")\n   237→\t} else {\n   238→\t\tfmt.Printf(\"Type:      container\\n\")\n   239→\t}\n   240→\tfmt.Printf(\"State:     %s\\n\", resp.State)\n   241→\tif resp.ContainerId != \"\" {\n   242→\t\tcid := resp.ContainerId\n   243→\t\tif len(cid) > 12 {\n   244→\t\t\tcid = cid[:12]\n   245→\t\t}\n   246→\t\tfmt.Printf(\"Container: %s\\n\", cid)\n   247→\t}\n   248→\tif resp.ErrorMessage != \"\" {\n   249→\t\tfmt.Printf(\"Error:     %s\\n\", resp.ErrorMessage)\n   250→\t}\n   251→\tfmt.Printf(\"Active:    %s\\n\", resp.CurrentStep)\n   252→\tfor _, exec := range resp.StepExecutions {\n   253→\t\tfmt.Printf(\"  %s: %s (%s -> %s)\\n\", exec.StepName, exec.Result, exec.StartedAt, exec.CompletedAt)\n   254→\t}\n   255→}\n   256→\n   257→func cmdList(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   258→\tvar all bool\n   259→\tvar projectDir, stateFilter, issueFilter string\n   260→\tvar limit int32\n   261→\n   262→\tfor i := 0; i < len(args); i++ {\n   263→\t\tswitch args[i] {\n   264→\t\tcase \"--all\":\n   265→\t\t\tall = true\n   266→\t\tcase \"--project\", \"-p\":\n   267→\t\t\tif i+1 < len(args) {\n   268→\t\t\t\ti++\n   269→\t\t\t\tprojectDir = args[i]\n   270→\t\t\t}\n   271→\t\tcase \"--state\", \"-s\":\n   272→\t\t\tif i+1 < len(args) {\n   273→\t\t\t\ti++\n   274→\t\t\t\tstateFilter = args[i]\n   275→\t\t\t}\n   276→\t\tcase \"--limit\", \"-n\":\n   277→\t\t\tif i+1 < len(args) {\n   278→\t\t\t\ti++\n   279→\t\t\t\tn, err := strconv.Atoi(args[i])\n   280→\t\t\t\tif err != nil {\n   281→\t\t\t\t\tfmt.Fprintf(os.Stderr, \"error: invalid --limit value: %s\\n\", args[i])\n   282→\t\t\t\t\tos.Exit(1)\n   283→\t\t\t\t}\n   284→\t\t\t\tlimit = int32(n)\n   285→\t\t\t}\n   286→\t\tcase \"--issue\", \"-i\":\n   287→\t\t\tif i+1 < len(args) {\n   288→\t\t\t\ti++\n   289→\t\t\t\tissueFilter = args[i]\n   290→\t\t\t}\n   291→\t\t}\n   292→\t}\n   293→\n   294→\treq := &pb.ListRunsRequest{\n   295→\t\tState:  stateFilter,\n   296→\t\tLimit:  limit,\n   297→\t\tTaskId: issueFilter,\n   298→\t}\n   299→\tif projectDir != \"\" {\n   300→\t\treq.ProjectDir = projectDir\n   301→\t} else if all {\n   302→\t\treq.All = true\n   303→\t} else {\n   304→\t\t// Default: filter to current project\n   305→\t\tcwd, _ := os.Getwd()\n   306→\t\treq.ProjectDir = cwd\n   307→\t}\n   308→\n   309→\tresp, err := client.ListRuns(ctx, req)\n   310→\tif err != nil {\n   311→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   312→\t\tos.Exit(1)\n   313→\t}\n   314→\n   315→\tif len(resp.Runs) == 0 {\n   316→\t\tfmt.Println(\"No runs found.\")\n   317→\t\treturn\n   318→\t}\n   319→\n   320→\tfor _, run := range resp.Runs {\n   321→\t\trunType := \"container\"\n   322→\t\tif run.IsHost {\n   323→\t\t\trunType = \"host\"\n   324→\t\t}\n   325→\t\tline := fmt.Sprintf(\"%s  %-20s  %-10s  %-9s\", run.RunId, run.WorkflowName, run.State, runType)\n   326→\t\tif run.Title != \"\" {\n   327→\t\t\tt := run.Title\n   328→\t\t\tif len(t) > 40 {\n   329→\t\t\t\tt = t[:37] + \"...\"\n   330→\t\t\t}\n   331→\t\t\tline += \"  \" + t\n   332→\t\t}\n   333→\t\tif run.ContainerId != \"\" {\n   334→\t\t\tline += \"  \" + run.ContainerId\n   335→\t\t}\n   336→\t\tif run.ErrorMessage != \"\" {\n   337→\t\t\terrMsg := run.ErrorMessage\n   338→\t\t\tif len(errMsg) > 60 {\n   339→\t\t\t\terrMsg = errMsg[:57] + \"...\"\n   340→\t\t\t}\n   341→\t\t\tline += \"  \" + errMsg\n   342→\t\t}\n   343→\t\tfmt.Println(line)\n   344→\t}\n   345→}\n   346→\n   347→func cmdLogs(client pb.ClocheServiceClient, args []string) {\n   348→\tif len(args) < 1 {\n   349→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche logs <run-id> [-s <name>] [--type <full|script|llm>] [-f] [-l <n>]\\n\")\n   350→\t\tos.Exit(1)\n   351→\t}\n   352→\n   353→\tvar stepFilter, typeFilter string\n   354→\tvar follow bool\n   355→\tvar limit int\n   356→\trunID := args[0]\n   357→\n   358→\tfor i := 1; i < len(args); i++ {\n   359→\t\tswitch args[i] {\n   360→\t\tcase \"--step\", \"-s\":\n   361→\t\t\tif i+1 < len(args) {\n   362→\t\t\t\ti++\n   363→\t\t\t\tstepFilter = args[i]\n   364→\t\t\t}\n   365→\t\tcase \"--type\":\n   366→\t\t\tif i+1 < len(args) {\n   367→\t\t\t\ti++\n   368→\t\t\t\ttypeFilter = args[i]\n   369→\t\t\t}\n   370→\t\tcase \"--follow\", \"-f\":\n   371→\t\t\tfollow = true\n   372→\t\tcase \"--limit\", \"-l\":\n   373→\t\t\tif i+1 < len(args) {\n   374→\t\t\t\ti++\n   375→\t\t\t\tn, err := strconv.Atoi(args[i])\n   376→\t\t\t\tif err != nil || n < 0 {\n   377→\t\t\t\t\tfmt.Fprintf(os.Stderr, \"error: --limit requires a positive integer\\n\")\n   378→\t\t\t\t\tos.Exit(1)\n   379→\t\t\t\t}\n   380→\t\t\t\tlimit = n\n   381→\t\t\t}\n   382→\t\t}\n   383→\t}\n   384→\n   385→\t// Use background context — log output can be large and follow mode blocks.\n   386→\tctx := context.Background()\n   387→\tvar mdPairs []string\n   388→\tif follow {\n   389→\t\tmdPairs = append(mdPairs, \"x-cloche-follow\", \"true\")\n   390→\t}\n   391→\tif limit > 0 {\n   392→\t\tmdPairs = append(mdPairs, \"x-cloche-limit\", strconv.Itoa(limit))\n   393→\t}\n   394→\tif len(mdPairs) > 0 {\n   395→\t\tmd := metadata.Pairs(mdPairs...)\n   396→\t\tctx = metadata.NewOutgoingContext(ctx, md)\n   397→\t}\n   398→\n   399→\tstream, err := client.StreamLogs(ctx, &pb.StreamLogsRequest{\n   400→\t\tRunId:    runID,\n   401→\t\tStepName: stepFilter,\n   402→\t\tLogType:  typeFilter,\n   403→\t})\n   404→\tif err != nil {\n   405→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   406→\t\tos.Exit(1)\n   407→\t}\n   408→\n   409→\tfor {\n   410→\t\tentry, err := stream.Recv()\n   411→\t\tif err != nil {\n   412→\t\t\tif errors.Is(err, io.EOF) {\n   413→\t\t\t\tbreak\n   414→\t\t\t}\n   415→\t\t\tfmt.Fprintf(os.Stderr, \"error reading logs: %v\\n\", err)\n   416→\t\t\tos.Exit(1)\n   417→\t\t}\n   418→\n   419→\t\tswitch entry.Type {\n   420→\t\tcase \"step_started\":\n   421→\t\t\tfmt.Printf(\"--- %s started ---\\n\", entry.StepName)\n   422→\t\t\tif entry.Message != \"\" {\n   423→\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n   424→\t\t\t}\n   425→\t\tcase \"step_completed\":\n   426→\t\t\tfmt.Printf(\"--- %s: %s ---\\n\", entry.StepName, entry.Result)\n   427→\t\t\tif entry.Message != \"\" {\n   428→\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n   429→\t\t\t}\n   430→\t\tcase \"run_completed\":\n   431→\t\t\tfmt.Printf(\"\\nRun result: %s\\n\", entry.Result)\n   432→\t\t\tif entry.Message != \"\" {\n   433→\t\t\t\tfmt.Printf(\"Error:      %s\\n\", entry.Message)\n   434→\t\t\t}\n   435→\t\tcase \"full_log\":\n   436→\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n   437→\t\tcase \"log\":\n   438→\t\t\t// Live-streamed log line from an active run.\n   439→\t\t\tfmt.Println(entry.Message)\n   440→\t\tdefault:\n   441→\t\t\t// Handles filtered log entries like \"script_log\", \"llm_log\", \"step_log\"\n   442→\t\t\tif entry.StepName != \"\" {\n   443→\t\t\t\tfmt.Printf(\"--- %s ---\\n\", entry.StepName)\n   444→\t\t\t}\n   445→\t\t\tif entry.Message != \"\" {\n   446→\t\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n   447→\t\t\t}\n   448→\t\t}\n   449→\t}\n   450→}\n   451→\n   452→func cmdStop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   453→\tif len(args) < 1 {\n   454→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche stop <run-id>\\n\")\n   455→\t\tos.Exit(1)\n   456→\t}\n   457→\n   458→\t_, err := client.StopRun(ctx, &pb.StopRunRequest{RunId: args[0]})\n   459→\tif err != nil {\n   460→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   461→\t\tos.Exit(1)\n   462→\t}\n   463→\tfmt.Printf(\"Stopped run: %s\\n\", args[0])\n   464→}\n   465→\n   466→func cmdDelete(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   467→\tif len(args) < 1 {\n   468→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche delete <container-or-run-id>\\n\")\n   469→\t\tos.Exit(1)\n   470→\t}\n   471→\n   472→\t_, err := client.DeleteContainer(ctx, &pb.DeleteContainerRequest{Id: args[0]})\n   473→\tif err != nil {\n   474→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   475→\t\tos.Exit(1)\n   476→\t}\n   477→\tfmt.Printf(\"Deleted container: %s\\n\", args[0])\n   478→}\n   479→\n   480→func cmdLoop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   481→\tcwd, _ := os.Getwd()\n   482→\n   483→\t// Check for \"stop\" subcommand\n   484→\tif len(args) > 0 && args[0] == \"stop\" {\n   485→\t\t_, err := client.DisableLoop(ctx, &pb.DisableLoopRequest{ProjectDir: cwd})\n   486→\t\tif err != nil {\n   487→\t\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   488→\t\t\tos.Exit(1)\n   489→\t\t}\n   490→\t\tfmt.Println(\"Orchestration loop stopped.\")\n   491→\t\treturn\n   492→\t}\n   493→\n   494→\t// Default: 0 means \"use config value\" (server reads .cloche/config.toml).\n   495→\tvar maxConcurrent int32\n   496→\tfor i := 0; i < len(args); i++ {\n   497→\t\tswitch args[i] {\n   498→\t\tcase \"--max\":\n   499→\t\t\tif i+1 < len(args) {\n   500→\t\t\t\ti++\n   501→\t\t\t\tn, err := fmt.Sscanf(args[i], \"%d\", &maxConcurrent)\n   502→\t\t\t\tif n != 1 || err != nil {\n   503→\t\t\t\t\tfmt.Fprintf(os.Stderr, \"invalid --max value: %s\\n\", args[i])\n   504→\t\t\t\t\tos.Exit(1)\n   505→\t\t\t\t}\n   506→\t\t\t}\n   507→\t\t}\n   508→\t}\n   509→\n   510→\t_, err := client.EnableLoop(ctx, &pb.EnableLoopRequest{\n   511→\t\tProjectDir:    cwd,\n   512→\t\tMaxConcurrent: maxConcurrent,\n   513→\t})\n   514→\tif err != nil {\n   515→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   516→\t\tos.Exit(1)\n   517→\t}\n   518→\tif maxConcurrent > 0 {\n   519→\t\tfmt.Printf(\"Orchestration loop started (max_concurrent=%d).\\n\", maxConcurrent)\n   520→\t} else {\n   521→\t\tfmt.Println(\"Orchestration loop started (using config defaults).\")\n   522→\t}\n   523→}\n   524→\n   525→func cmdTasks(args []string) {\n   526→\t// Determine HTTP address from env\n   527→\thttpAddr := os.Getenv(\"CLOCHE_HTTP\")\n   528→\tif httpAddr == \"\" {\n   529→\t\thttpAddr = \"localhost:8080\"\n   530→\t}\n   531→\thttpAddr = strings.TrimPrefix(httpAddr, \"http://\")\n   532→\n   533→\t// Determine project label from --project flag or current directory\n   534→\tprojectDir := \"\"\n   535→\tfor i := 0; i < len(args); i++ {\n   536→\t\tswitch args[i] {\n   537→\t\tcase \"--project\":\n   538→\t\t\tif i+1 < len(args) {\n   539→\t\t\t\ti++\n   540→\t\t\t\tprojectDir = args[i]\n   541→\t\t\t}\n   542→\t\t}\n   543→\t}\n   544→\n   545→\tif projectDir == \"\" {\n   546→\t\tcwd, _ := os.Getwd()\n   547→\t\tprojectDir = filepath.Base(cwd)\n   548→\t}\n   549→\n   550→\ttasksURL := fmt.Sprintf(\"http://%s/api/projects/%s/tasks\", httpAddr, projectDir)\n   551→\tresp, err := http.Get(tasksURL)\n   552→\tif err != nil {\n   553→\t\tfmt.Fprintf(os.Stderr, \"error connecting to daemon web API: %v\\n\", err)\n   554→\t\tfmt.Fprintf(os.Stderr, \"hint: ensure CLOCHE_HTTP is set and the daemon is running with --http\\n\")\n   555→\t\tos.Exit(1)\n   556→\t}\n   557→\tdefer resp.Body.Close()\n   558→\n   559→\tif resp.StatusCode != 200 {\n   560→\t\tbody, _ := io.ReadAll(resp.Body)\n   561→\t\tfmt.Fprintf(os.Stderr, \"error: HTTP %d: %s\\n\", resp.StatusCode, strings.TrimSpace(string(body)))\n   562→\t\tos.Exit(1)\n   563→\t}\n   564→\n   565→\ttype taskEntry struct {\n   566→\t\tID          string `json:\"id\"`\n   567→\t\tStatus      string `json:\"status\"`\n   568→\t\tTitle       string `json:\"title\"`\n   569→\t\tDescription string `json:\"description\"`\n   570→\t\tAssigned    bool   `json:\"assigned\"`\n   571→\t\tAssignedAt  string `json:\"assigned_at\"`\n   572→\t\tRunID       string `json:\"run_id\"`\n   573→\t}\n   574→\n   575→\tvar tasks []taskEntry\n   576→\tif err := json.NewDecoder(resp.Body).Decode(&tasks); err != nil {\n   577→\t\tfmt.Fprintf(os.Stderr, \"error parsing response: %v\\n\", err)\n   578→\t\tos.Exit(1)\n   579→\t}\n   580→\n   581→\tif len(tasks) == 0 {\n   582→\t\tfmt.Println(\"No tasks found. (Is the orchestration loop running?)\")\n   583→\t\treturn\n   584→\t}\n   585→\n   586→\tfmt.Printf(\"%-20s  %-12s  %-10s  %-30s  %s\\n\", \"ID\", \"STATUS\", \"ASSIGNED\", \"RUN\", \"TITLE\")\n   587→\tfor _, t := range tasks {\n   588→\t\tstatus := t.Status\n   589→\t\tif status == \"\" {\n   590→\t\t\tstatus = \"open\"\n   591→\t\t}\n   592→\t\tassigned := \"-\"\n   593→\t\tif t.Assigned {\n   594→\t\t\tassigned = \"yes\"\n   595→\t\t}\n   596→\t\trunID := \"\"\n   597→\t\tif t.RunID != \"\" {\n   598→\t\t\trunID = t.RunID\n   599→\t\t\tif len(runID) > 30 {\n   600→\t\t\t\trunID = runID[:27] + \"...\"\n   601→\t\t\t}\n   602→\t\t}\n   603→\t\ttitle := t.Title\n   604→\t\tif len(title) > 40 {\n   605→\t\t\ttitle = title[:37] + \"...\"\n   606→\t\t}\n   607→\t\tfmt.Printf(\"%-20s  %-12s  %-10s  %-30s  %s\\n\", t.ID, status, assigned, runID, title)\n   608→\t}\n   609→}\n   610→\n   611→func cmdShutdown(ctx context.Context, client pb.ClocheServiceClient) {\n   612→\t_, err := client.Shutdown(ctx, &pb.ShutdownRequest{})\n   613→\tif err != nil {\n   614→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   615→\t\tos.Exit(1)\n   616→\t}\n   617→\tfmt.Println(\"Daemon shutting down.\")\n   618→}\n   619→\n   620→// resolveRunContext returns the project directory and run ID for context\n   621→// commands. The run ID comes from CLOCHE_RUN_ID and the project directory\n   622→// from CLOCHE_PROJECT_DIR (falling back to cwd).\n   623→func resolveRunContext() (projectDir, runID string, err error) {\n   624→\trunID = os.Getenv(\"CLOCHE_RUN_ID\")\n   625→\tif runID == \"\" {\n   626→\t\treturn \"\", \"\", fmt.Errorf(\"CLOCHE_RUN_ID environment variable is not set\")\n   627→\t}\n   628→\tprojectDir = os.Getenv(\"CLOCHE_PROJECT_DIR\")\n   629→\tif projectDir == \"\" {\n   630→\t\tprojectDir, err = os.Getwd()\n   631→\t\tif err != nil {\n   632→\t\t\treturn \"\", \"\", fmt.Errorf(\"getting working directory: %w\", err)\n   633→\t\t}\n   634→\t}\n   635→\treturn projectDir, runID, nil\n   636→}\n   637→\n   638→func cmdGet(args []string) {\n   639→\tif len(args) < 1 {\n   640→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche get <key>\\n\")\n   641→\t\tos.Exit(1)\n   642→\t}\n   643→\n   644→\tprojectDir, runID, err := resolveRunContext()\n   645→\tif err != nil {\n   646→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   647→\t\tos.Exit(1)\n   648→\t}\n   649→\n   650→\tval, ok, err := runcontext.Get(projectDir, runID, args[0])\n   651→\tif err != nil {\n   652→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   653→\t\tos.Exit(1)\n   654→\t}\n   655→\tif !ok {\n   656→\t\tos.Exit(1)\n   657→\t}\n   658→\tfmt.Println(val)\n   659→}\n   660→\n   661→func cmdSet(args []string) {\n   662→\tif len(args) < 2 {\n   663→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche set <key> <value>\\n\")\n   664→\t\tfmt.Fprintf(os.Stderr, \"       cloche set <key> -     (read value from stdin)\\n\")\n   665→\t\tos.Exit(1)\n   666→\t}\n   667→\n   668→\tprojectDir, runID, err := resolveRunContext()\n   669→\tif err != nil {\n   670→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   671→\t\tos.Exit(1)\n   672→\t}\n   673→\n   674→\tvalue := args[1]\n   675→\tif value == \"-\" {\n   676→\t\tdata, err := io.ReadAll(os.Stdin)\n   677→\t\tif err != nil {\n   678→\t\t\tfmt.Fprintf(os.Stderr, \"error reading stdin: %v\\n\", err)\n   679→\t\t\tos.Exit(1)\n   680→\t\t}\n   681→\t\tvalue = strings.TrimRight(string(data), \"\\n\")\n   682→\t}\n   683→\n   684→\tif err := runcontext.Set(projectDir, runID, args[0], value); err != nil {\n   685→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   686→\t\tos.Exit(1)\n   687→\t}\n   688→}\n   689→\n   690→func cmdVersion() {\n   691→\tcliVersion := version.Version()\n   692→\tfmt.Printf(\"cloche %s\\n\", cliVersion)\n   693→\n   694→\t// Try to get daemon version via gRPC\n   695→\tdaemonVersion := \"<unavailable>\"\n   696→\taddr := os.Getenv(\"CLOCHE_ADDR\")\n   697→\tif addr == \"\" {\n   698→\t\taddr = \"unix:///tmp/cloche.sock\"\n   699→\t}\n   700→\tconn, err := grpc.NewClient(addr, grpc.WithTransportCredentials(insecure.NewCredentials()))\n   701→\tif err == nil {\n   702→\t\tdefer conn.Close()\n   703→\t\tclient := pb.NewClocheServiceClient(conn)\n   704→\t\tctx, cancel := context.WithTimeout(context.Background(), 3*time.Second)\n   705→\t\tdefer cancel()\n   706→\t\tresp, err := client.GetVersion(ctx, &pb.GetVersionRequest{})\n   707→\t\tif err == nil {\n   708→\t\t\tdaemonVersion = resp.Version\n   709→\t\t}\n   710→\t}\n   711→\tfmt.Printf(\"cloched %s\\n\", daemonVersion)\n   712→\n   713→\t// Try to get agent version by running: docker run --rm <image> cloche-agent -v\n   714→\tagentVersion := \"<unavailable>\"\n   715→\timage := os.Getenv(\"CLOCHE_IMAGE\")\n   716→\tif image == \"\" {\n   717→\t\timage = \"cloche-agent:latest\"\n   718→\t}\n   719→\tout, err := exec.CommandContext(\n   720→\t\tcontext.Background(),\n   721→\t\t\"docker\", \"run\", \"--rm\", \"--entrypoint\", \"cloche-agent\", image, \"-v\",\n   722→\t).Output()\n   723→\tif err == nil {\n   724→\t\tagentVersion = strings.TrimSpace(string(out))\n   725→\t\t// Strip \"cloche-agent \" prefix if present\n   726→\t\tagentVersion = strings.TrimPrefix(agentVersion, \"cloche-agent \")\n   727→\t}\n   728→\tfmt.Printf(\"cloche-agent %s\\n\", agentVersion)\n   729→\n   730→\t// Warn about version mismatches\n   731→\tif daemonVersion != \"<unavailable>\" && daemonVersion != cliVersion {\n   732→\t\tfmt.Fprintf(os.Stderr, \"warning: CLI version (%s) differs from daemon version (%s)\\n\", cliVersion, daemonVersion)\n   733→\t}\n   734→\tif agentVersion != \"<unavailable>\" && agentVersion != cliVersion {\n   735→\t\tfmt.Fprintf(os.Stderr, \"warning: CLI version (%s) differs from agent version (%s)\\n\", cliVersion, agentVersion)\n   736→\t}\n   737→}\n   738→"}]},"parent_tool_use_id":"toolu_01SisYs2mGvpsHnZNXYBn119","session_id":"80e1ce2e-a764-409e-b43f-733763e5218d","uuid":"c191411a-e769-470a-995e-6a262fcf526c"}
