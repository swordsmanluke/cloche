{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Xg2pMGuNH3nA6ZxLGxuDeZ","type":"tool_result","content":"  1302→func TestServer_StreamLogs_FullLog(t *testing.T) {\n  1303→\tstore, err := sqlite.NewStore(\":memory:\")\n  1304→\trequire.NoError(t, err)\n  1305→\tdefer store.Close()\n  1306→\n  1307→\tdir := t.TempDir()\n  1308→\n  1309→\tmsgs := []protocol.StatusMessage{\n  1310→\t\t{Type: protocol.MsgStepStarted, StepName: \"build\"},\n  1311→\t\t{Type: protocol.MsgStepCompleted, StepName: \"build\", Result: \"success\"},\n  1312→\t\t{Type: protocol.MsgRunCompleted, Result: \"succeeded\"},\n  1313→\t}\n  1314→\tscript := \"#!/bin/sh\\n\"\n  1315→\tscript += \"mkdir -p .cloche/output\\n\"\n  1316→\tscript += \"echo 'unified log content here' > .cloche/output/full.log\\n\"\n  1317→\tfor _, msg := range msgs {\n  1318→\t\tdata, _ := json.Marshal(msg)\n  1319→\t\tscript += \"echo '\" + string(data) + \"'\\n\"\n  1320→\t}\n  1321→\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \".cloche\"), 0755))\n  1322→\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"test.cloche\"), []byte(script), 0755))\n  1323→\n  1324→\trt := local.NewRuntime(\"sh\")\n  1325→\tsrv := server.NewClocheServerWithCaptures(store, store, rt, \"\")\n  1326→\n  1327→\tresp, err := srv.RunWorkflow(context.Background(), &pb.RunWorkflowRequest{\n  1328→\t\tWorkflowName: \"test\",\n  1329→\t\tProjectDir:   dir,\n  1330→\t})\n  1331→\trequire.NoError(t, err)\n  1332→\n  1333→\t// Poll until complete\n  1334→\tdeadline := time.Now().Add(5 * time.Second)\n  1335→\tfor time.Now().Before(deadline) {\n  1336→\t\tstatus, err := srv.GetStatus(context.Background(), &pb.GetStatusRequest{RunId: resp.RunId})\n  1337→\t\trequire.NoError(t, err)\n  1338→\t\tif status.State == \"succeeded\" {\n  1339→\t\t\tbreak\n  1340→\t\t}\n  1341→\t\ttime.Sleep(50 * time.Millisecond)\n  1342→\t}\n  1343→\ttime.Sleep(500 * time.Millisecond)\n  1344→\n  1345→\t// StreamLogs with no filters should serve full.log content\n  1346→\tmock := &mockLogStream{ctx: context.Background()}\n  1347→\terr = srv.StreamLogs(&pb.StreamLogsRequest{RunId: resp.RunId}, mock)\n  1348→\trequire.NoError(t, err)\n  1349→\n  1350→\t// Should have a full_log entry\n  1351→\tvar foundFullLog bool\n  1352→\tfor _, e := range mock.entries {\n  1353→\t\tif e.Type == \"full_log\" {\n  1354→\t\t\tfoundFullLog = true\n  1355→\t\t\tassert.Contains(t, e.Message, \"unified log content here\")\n  1356→\t\t}\n  1357→\t}\n  1358→\tassert.True(t, foundFullLog, \"should serve full.log as unified log when available\")\n  1359→}\n  1360→\n  1361→func TestServer_StreamLogs_LiveStreaming(t *testing.T) {\n  1362→\tstore, err := sqlite.NewStore(\":memory:\")\n  1363→\trequire.NoError(t, err)\n  1364→\tdefer store.Close()\n  1365→\n  1366→\t// Create a running run (no container needed — we test the broadcaster path directly).\n  1367→\tctx := context.Background()\n  1368→\trun := domain.NewRun(\"live-test-1\", \"develop\")\n  1369→\trun.ProjectDir = t.TempDir()\n  1370→\trun.Start()\n  1371→\trun.ContainerID = \"fake\"\n  1372→\trequire.NoError(t, store.CreateRun(ctx, run))\n  1373→\n  1374→\tbroadcaster := logstream.NewBroadcaster()\n  1375→\tsrv := server.NewClocheServerWithCaptures(store, store, nil, \"\")\n  1376→\tsrv.SetLogBroadcaster(broadcaster)\n  1377→\n  1378→\t// Use a cancellable context with follow metadata for the mock stream.\n  1379→\tstreamCtx, streamCancel := context.WithTimeout(ctx, 5*time.Second)\n  1380→\tdefer streamCancel()\n  1381→\tstreamCtx = metadata.NewIncomingContext(streamCtx, metadata.Pairs(\"x-cloche-follow\", \"true\"))\n  1382→\tmock := &mockLogStream{ctx: streamCtx}\n  1383→\n  1384→\t// Publish log lines in a goroutine, then finish the broadcast.\n  1385→\tgo func() {\n  1386→\t\ttime.Sleep(50 * time.Millisecond)\n  1387→\t\tbroadcaster.Publish(\"live-test-1\", logstream.LogLine{\n  1388→\t\t\tTimestamp: \"2026-03-10T10:00:00Z\",\n  1389→\t\t\tType:      \"status\",\n  1390→\t\t\tContent:   \"step_started: implement\",\n  1391→\t\t\tStepName:  \"implement\",\n  1392→\t\t})\n  1393→\t\ttime.Sleep(50 * time.Millisecond)\n  1394→\t\tbroadcaster.Publish(\"live-test-1\", logstream.LogLine{\n  1395→\t\t\tTimestamp: \"2026-03-10T10:00:01Z\",\n  1396→\t\t\tType:      \"llm\",\n  1397→\t\t\tContent:   \"Reading the codebase...\",\n  1398→\t\t\tStepName:  \"implement\",\n  1399→\t\t})\n  1400→\t\ttime.Sleep(50 * time.Millisecond)\n  1401→\t\tbroadcaster.Publish(\"live-test-1\", logstream.LogLine{\n  1402→\t\t\tTimestamp: \"2026-03-10T10:00:02Z\",\n  1403→\t\t\tType:      \"llm\",\n  1404→\t\t\tContent:   \"Making changes now.\",\n  1405→\t\t\tStepName:  \"implement\",\n  1406→\t\t})\n  1407→\t\ttime.Sleep(50 * time.Millisecond)\n  1408→\n  1409→\t\t// Mark run as completed before finishing broadcast.\n  1410→\t\tr, _ := store.GetRun(ctx, \"live-test-1\")\n  1411→\t\tr.Complete(domain.RunStateSucceeded)\n  1412→\t\t_ = store.UpdateRun(ctx, r)\n  1413→\n  1414→\t\tbroadcaster.Finish(\"live-test-1\")\n  1415→\t}()\n  1416→\n  1417→\terr = srv.StreamLogs(&pb.StreamLogsRequest{RunId: \"live-test-1\"}, mock)\n  1418→\trequire.NoError(t, err)\n  1419→\n  1420→\t// Should have received live log entries plus a run_completed entry.\n  1421→\tvar logEntries []*pb.LogEntry\n  1422→\tvar foundRunCompleted bool\n  1423→\tfor _, e := range mock.entries {\n  1424→\t\tswitch e.Type {\n  1425→\t\tcase \"log\":\n  1426→\t\t\tlogEntries = append(logEntries, e)\n  1427→\t\tcase \"run_completed\":\n  1428→\t\t\tfoundRunCompleted = true\n  1429→\t\t\tassert.Equal(t, \"succeeded\", e.Result)\n  1430→\t\t}\n  1431→\t}\n  1432→\n  1433→\trequire.Len(t, logEntries, 3, \"should receive 3 live log entries\")\n  1434→\tassert.Equal(t, \"step_started: implement\", logEntries[0].Message)\n  1435→\tassert.Equal(t, \"implement\", logEntries[0].StepName)\n  1436→\tassert.Equal(t, \"Reading the codebase...\", logEntries[1].Message)\n  1437→\tassert.Equal(t, \"Making changes now.\", logEntries[2].Message)\n  1438→\tassert.True(t, foundRunCompleted, \"should receive run_completed after broadcast finishes\")\n  1439→}\n  1440→\n  1441→func TestServer_StreamLogs_LiveStreamingClientDisconnect(t *testing.T) {\n  1442→\tstore, err := sqlite.NewStore(\":memory:\")\n  1443→\trequire.NoError(t, err)\n  1444→\tdefer store.Close()\n  1445→\n  1446→\tctx := context.Background()\n  1447→\trun := domain.NewRun(\"live-cancel-1\", \"develop\")\n  1448→\trun.ProjectDir = t.TempDir()\n  1449→\trun.Start()\n  1450→\trun.ContainerID = \"fake\"\n  1451→\trequire.NoError(t, store.CreateRun(ctx, run))\n  1452→\n  1453→\tbroadcaster := logstream.NewBroadcaster()\n  1454→\tsrv := server.NewClocheServerWithCaptures(store, store, nil, \"\")\n  1455→\tsrv.SetLogBroadcaster(broadcaster)\n  1456→\n  1457→\t// Cancel the stream context immediately to simulate client disconnect.\n  1458→\tstreamCtx, streamCancel := context.WithCancel(ctx)\n  1459→\tstreamCtx = metadata.NewIncomingContext(streamCtx, metadata.Pairs(\"x-cloche-follow\", \"true\"))\n  1460→\tmock := &mockLogStream{ctx: streamCtx}\n  1461→\n  1462→\t// Ensure broadcaster has an active entry for the run.\n  1463→\tbroadcaster.Subscribe(\"live-cancel-1\")\n  1464→\n  1465→\tgo func() {\n  1466→\t\ttime.Sleep(50 * time.Millisecond)\n  1467→\t\tstreamCancel()\n  1468→\t}()\n  1469→\n  1470→\terr = srv.StreamLogs(&pb.StreamLogsRequest{RunId: \"live-cancel-1\"}, mock)\n  1471→\tassert.ErrorIs(t, err, context.Canceled)\n  1472→}\n  1473→\n  1474→// TestServer_StreamLogs_NoFollowActiveRun verifies that without -f, logs for\n  1475→// an active run return existing content and exit (snapshot mode).\n  1476→func TestServer_StreamLogs_NoFollowActiveRun(t *testing.T) {\n  1477→\tstore, err := sqlite.NewStore(\":memory:\")\n  1478→\trequire.NoError(t, err)\n  1479→\tdefer store.Close()\n  1480→\n  1481→\tctx := context.Background()\n  1482→\tdir := t.TempDir()\n  1483→\trun := domain.NewRun(\"snapshot-test-1\", \"develop\")\n  1484→\trun.ProjectDir = dir\n  1485→\trun.Start()\n  1486→\trun.ContainerID = \"fake\"\n  1487→\trequire.NoError(t, store.CreateRun(ctx, run))\n  1488→\n  1489→\t// Write some existing log content.\n  1490→\toutputDir := filepath.Join(dir, \".cloche\", \"snapshot-test-1\", \"output\")\n  1491→\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n  1492→\trequire.NoError(t, os.WriteFile(filepath.Join(outputDir, \"full.log\"),\n  1493→\t\t[]byte(\"[2026-03-10T10:00:00Z] [status] step_started: build\\n\"), 0644))\n  1494→\n  1495→\tbroadcaster := logstream.NewBroadcaster()\n  1496→\tsrv := server.NewClocheServerWithCaptures(store, store, nil, \"\")\n  1497→\tsrv.SetLogBroadcaster(broadcaster)\n  1498→\n  1499→\t// Ensure broadcaster has an active entry so the run appears \"live\".\n  1500→\tbroadcaster.Subscribe(\"snapshot-test-1\")\n  1501→\n  1502→\t// No follow metadata — should return snapshot and exit immediately.\n  1503→\tmock := &mockLogStream{ctx: context.Background()}\n  1504→\terr = srv.StreamLogs(&pb.StreamLogsRequest{RunId: \"snapshot-test-1\"}, mock)\n  1505→\trequire.NoError(t, err)\n  1506→\n  1507→\t// Should have received the full_log entry but NOT blocked waiting for live lines.\n  1508→\trequire.Len(t, mock.entries, 1, \"should return exactly one entry (full_log snapshot)\")\n  1509→\tassert.Equal(t, \"full_log\", mock.entries[0].Type)\n  1510→\tassert.Contains(t, mock.entries[0].Message, \"step_started: build\")\n  1511→}\n  1512→\n  1513→// TestServer_StreamLogs_FollowWithExistingLogs verifies that -f sends existing\n  1514→// full.log content first, then streams live output.\n  1515→func TestServer_StreamLogs_FollowWithExistingLogs(t *testing.T) {\n  1516→\tstore, err := sqlite.NewStore(\":memory:\")\n  1517→\trequire.NoError(t, err)\n  1518→\tdefer store.Close()\n  1519→\n  1520→\tctx := context.Background()\n  1521→\tdir := t.TempDir()"}]},"parent_tool_use_id":null,"session_id":"96f32727-3069-4902-8837-5bfcf44ab35e","uuid":"ec82619f-de6a-4593-93f3-cb99dd110f80","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/grpc/server_test.go","content":"func TestServer_StreamLogs_FullLog(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tdir := t.TempDir()\n\n\tmsgs := []protocol.StatusMessage{\n\t\t{Type: protocol.MsgStepStarted, StepName: \"build\"},\n\t\t{Type: protocol.MsgStepCompleted, StepName: \"build\", Result: \"success\"},\n\t\t{Type: protocol.MsgRunCompleted, Result: \"succeeded\"},\n\t}\n\tscript := \"#!/bin/sh\\n\"\n\tscript += \"mkdir -p .cloche/output\\n\"\n\tscript += \"echo 'unified log content here' > .cloche/output/full.log\\n\"\n\tfor _, msg := range msgs {\n\t\tdata, _ := json.Marshal(msg)\n\t\tscript += \"echo '\" + string(data) + \"'\\n\"\n\t}\n\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \".cloche\"), 0755))\n\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"test.cloche\"), []byte(script), 0755))\n\n\trt := local.NewRuntime(\"sh\")\n\tsrv := server.NewClocheServerWithCaptures(store, store, rt, \"\")\n\n\tresp, err := srv.RunWorkflow(context.Background(), &pb.RunWorkflowRequest{\n\t\tWorkflowName: \"test\",\n\t\tProjectDir:   dir,\n\t})\n\trequire.NoError(t, err)\n\n\t// Poll until complete\n\tdeadline := time.Now().Add(5 * time.Second)\n\tfor time.Now().Before(deadline) {\n\t\tstatus, err := srv.GetStatus(context.Background(), &pb.GetStatusRequest{RunId: resp.RunId})\n\t\trequire.NoError(t, err)\n\t\tif status.State == \"succeeded\" {\n\t\t\tbreak\n\t\t}\n\t\ttime.Sleep(50 * time.Millisecond)\n\t}\n\ttime.Sleep(500 * time.Millisecond)\n\n\t// StreamLogs with no filters should serve full.log content\n\tmock := &mockLogStream{ctx: context.Background()}\n\terr = srv.StreamLogs(&pb.StreamLogsRequest{RunId: resp.RunId}, mock)\n\trequire.NoError(t, err)\n\n\t// Should have a full_log entry\n\tvar foundFullLog bool\n\tfor _, e := range mock.entries {\n\t\tif e.Type == \"full_log\" {\n\t\t\tfoundFullLog = true\n\t\t\tassert.Contains(t, e.Message, \"unified log content here\")\n\t\t}\n\t}\n\tassert.True(t, foundFullLog, \"should serve full.log as unified log when available\")\n}\n\nfunc TestServer_StreamLogs_LiveStreaming(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\t// Create a running run (no container needed — we test the broadcaster path directly).\n\tctx := context.Background()\n\trun := domain.NewRun(\"live-test-1\", \"develop\")\n\trun.ProjectDir = t.TempDir()\n\trun.Start()\n\trun.ContainerID = \"fake\"\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\n\tbroadcaster := logstream.NewBroadcaster()\n\tsrv := server.NewClocheServerWithCaptures(store, store, nil, \"\")\n\tsrv.SetLogBroadcaster(broadcaster)\n\n\t// Use a cancellable context with follow metadata for the mock stream.\n\tstreamCtx, streamCancel := context.WithTimeout(ctx, 5*time.Second)\n\tdefer streamCancel()\n\tstreamCtx = metadata.NewIncomingContext(streamCtx, metadata.Pairs(\"x-cloche-follow\", \"true\"))\n\tmock := &mockLogStream{ctx: streamCtx}\n\n\t// Publish log lines in a goroutine, then finish the broadcast.\n\tgo func() {\n\t\ttime.Sleep(50 * time.Millisecond)\n\t\tbroadcaster.Publish(\"live-test-1\", logstream.LogLine{\n\t\t\tTimestamp: \"2026-03-10T10:00:00Z\",\n\t\t\tType:      \"status\",\n\t\t\tContent:   \"step_started: implement\",\n\t\t\tStepName:  \"implement\",\n\t\t})\n\t\ttime.Sleep(50 * time.Millisecond)\n\t\tbroadcaster.Publish(\"live-test-1\", logstream.LogLine{\n\t\t\tTimestamp: \"2026-03-10T10:00:01Z\",\n\t\t\tType:      \"llm\",\n\t\t\tContent:   \"Reading the codebase...\",\n\t\t\tStepName:  \"implement\",\n\t\t})\n\t\ttime.Sleep(50 * time.Millisecond)\n\t\tbroadcaster.Publish(\"live-test-1\", logstream.LogLine{\n\t\t\tTimestamp: \"2026-03-10T10:00:02Z\",\n\t\t\tType:      \"llm\",\n\t\t\tContent:   \"Making changes now.\",\n\t\t\tStepName:  \"implement\",\n\t\t})\n\t\ttime.Sleep(50 * time.Millisecond)\n\n\t\t// Mark run as completed before finishing broadcast.\n\t\tr, _ := store.GetRun(ctx, \"live-test-1\")\n\t\tr.Complete(domain.RunStateSucceeded)\n\t\t_ = store.UpdateRun(ctx, r)\n\n\t\tbroadcaster.Finish(\"live-test-1\")\n\t}()\n\n\terr = srv.StreamLogs(&pb.StreamLogsRequest{RunId: \"live-test-1\"}, mock)\n\trequire.NoError(t, err)\n\n\t// Should have received live log entries plus a run_completed entry.\n\tvar logEntries []*pb.LogEntry\n\tvar foundRunCompleted bool\n\tfor _, e := range mock.entries {\n\t\tswitch e.Type {\n\t\tcase \"log\":\n\t\t\tlogEntries = append(logEntries, e)\n\t\tcase \"run_completed\":\n\t\t\tfoundRunCompleted = true\n\t\t\tassert.Equal(t, \"succeeded\", e.Result)\n\t\t}\n\t}\n\n\trequire.Len(t, logEntries, 3, \"should receive 3 live log entries\")\n\tassert.Equal(t, \"step_started: implement\", logEntries[0].Message)\n\tassert.Equal(t, \"implement\", logEntries[0].StepName)\n\tassert.Equal(t, \"Reading the codebase...\", logEntries[1].Message)\n\tassert.Equal(t, \"Making changes now.\", logEntries[2].Message)\n\tassert.True(t, foundRunCompleted, \"should receive run_completed after broadcast finishes\")\n}\n\nfunc TestServer_StreamLogs_LiveStreamingClientDisconnect(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\trun := domain.NewRun(\"live-cancel-1\", \"develop\")\n\trun.ProjectDir = t.TempDir()\n\trun.Start()\n\trun.ContainerID = \"fake\"\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\n\tbroadcaster := logstream.NewBroadcaster()\n\tsrv := server.NewClocheServerWithCaptures(store, store, nil, \"\")\n\tsrv.SetLogBroadcaster(broadcaster)\n\n\t// Cancel the stream context immediately to simulate client disconnect.\n\tstreamCtx, streamCancel := context.WithCancel(ctx)\n\tstreamCtx = metadata.NewIncomingContext(streamCtx, metadata.Pairs(\"x-cloche-follow\", \"true\"))\n\tmock := &mockLogStream{ctx: streamCtx}\n\n\t// Ensure broadcaster has an active entry for the run.\n\tbroadcaster.Subscribe(\"live-cancel-1\")\n\n\tgo func() {\n\t\ttime.Sleep(50 * time.Millisecond)\n\t\tstreamCancel()\n\t}()\n\n\terr = srv.StreamLogs(&pb.StreamLogsRequest{RunId: \"live-cancel-1\"}, mock)\n\tassert.ErrorIs(t, err, context.Canceled)\n}\n\n// TestServer_StreamLogs_NoFollowActiveRun verifies that without -f, logs for\n// an active run return existing content and exit (snapshot mode).\nfunc TestServer_StreamLogs_NoFollowActiveRun(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\tdir := t.TempDir()\n\trun := domain.NewRun(\"snapshot-test-1\", \"develop\")\n\trun.ProjectDir = dir\n\trun.Start()\n\trun.ContainerID = \"fake\"\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\n\t// Write some existing log content.\n\toutputDir := filepath.Join(dir, \".cloche\", \"snapshot-test-1\", \"output\")\n\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n\trequire.NoError(t, os.WriteFile(filepath.Join(outputDir, \"full.log\"),\n\t\t[]byte(\"[2026-03-10T10:00:00Z] [status] step_started: build\\n\"), 0644))\n\n\tbroadcaster := logstream.NewBroadcaster()\n\tsrv := server.NewClocheServerWithCaptures(store, store, nil, \"\")\n\tsrv.SetLogBroadcaster(broadcaster)\n\n\t// Ensure broadcaster has an active entry so the run appears \"live\".\n\tbroadcaster.Subscribe(\"snapshot-test-1\")\n\n\t// No follow metadata — should return snapshot and exit immediately.\n\tmock := &mockLogStream{ctx: context.Background()}\n\terr = srv.StreamLogs(&pb.StreamLogsRequest{RunId: \"snapshot-test-1\"}, mock)\n\trequire.NoError(t, err)\n\n\t// Should have received the full_log entry but NOT blocked waiting for live lines.\n\trequire.Len(t, mock.entries, 1, \"should return exactly one entry (full_log snapshot)\")\n\tassert.Equal(t, \"full_log\", mock.entries[0].Type)\n\tassert.Contains(t, mock.entries[0].Message, \"step_started: build\")\n}\n\n// TestServer_StreamLogs_FollowWithExistingLogs verifies that -f sends existing\n// full.log content first, then streams live output.\nfunc TestServer_StreamLogs_FollowWithExistingLogs(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\tdir := t.TempDir()","numLines":220,"startLine":1302,"totalLines":1749}}}
