ct {\n    45→\tID             string\n    46→\tProjectDir     string\n    47→\tWorkflowName   string\n    48→\tTriggerRunID   string\n    49→\tCreatedAt      time.Time\n    50→\tClassification string\n    51→\tChangesJSON    string\n    52→\tKnowledgeDelta string\n    53→}\n    54→\n    55→type EvolutionStore interface {\n    56→\tSaveEvolution(ctx context.Context, entry *EvolutionEntry) error\n    57→\tGetLastEvolution(ctx context.Context, projectDir, workflowName string) (*EvolutionEntry, error)\n    58→\tListRunsSince(ctx context.Context, projectDir, workflowName, sinceRunID string) ([]*domain.Run, error)\n    59→}\n    60→"}]},"parent_tool_use_id":"toolu_013Y5EJhPZgAJrRFK4ZZsW2U","session_id":"96f32727-3069-4902-8837-5bfcf44ab35e","uuid":"bb4cad49-5419-4259-af8e-5a1f159e71ac"}
