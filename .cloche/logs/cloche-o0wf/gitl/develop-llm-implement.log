t\t}\n\t\t\t\tif err := stream.Send(&pb.LogEntry{\n\t\t\t\t\tType:     lf.FileType + \"_log\",\n\t\t\t\t\tStepName: lf.StepName,\n\t\t\t\t\tMessage:  string(data),\n\t\t\t\t}); err != nil {\n\t\t\t\t\treturn err\n\t\t\t\t}\n\t\t\t}\n\t\t\treturn nil\n\t\t}\n\t}\n\n\t// Fall back to file path conventions","numLines":55,"startLine":688,"totalLines":1300}}}
