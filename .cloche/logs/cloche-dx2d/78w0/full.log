utputPath\n    69→}\n    70→\n    71→// Evaluate navigates the raw output bytes using the path segments.\n    72→// With no segments, it returns the raw output as a string.\n    73→// With segments, it parses the raw bytes as JSON and navigates using\n    74→// field access (SegmentField) and array indexing (SegmentIndex).\n    75→func (p OutputPath) Evaluate(raw []byte) (string, error) {\n    76→\tif len(p.Segments) == 0 {\n    77→\t\treturn string(raw), nil\n    78→\t}\n    79→\n    80→\tvar val any\n    81→\tif err := json.Unmarshal(raw, &val); err != nil {\n    82→\t\treturn \"\", fmt.Errorf(\"output is not valid JSON\")\n    83→\t}\n    84→\n    85→\tfor _, seg := range p.Segments {\n    86→\t\tswitch seg.Kind {\n    87→\t\tcase SegmentField:\n    88→\t\t\tm, ok := val.(map[string]any)\n    89→\t\t\tif !ok {\n    90→\t\t\t\treturn \"\", fmt.Errorf(\"expected object for .%s\", seg.Field)\n    91→\t\t\t}\n    92→\t\t\tval, ok = m[seg.Field]\n    93→\t\t\tif !ok {\n    94→\t\t\t\treturn \"\", fmt.Errorf(\"field %q not found\", seg.Field)\n    95→\t\t\t}\n    96→\t\tcase SegmentIndex:\n    97→\t\t\tarr, ok := val.([]any)\n    98→\t\t\tif !ok {\n    99→\t\t\t\treturn \"\", fmt.Errorf(\"expected array for [%d]\", seg.Index)\n   100→\t\t\t}\n   101→\t\t\tif seg.Index < 0 || seg.Index >= len(arr) {\n   102→\t\t\t\treturn \"\", fmt.Errorf(\"index %d out of range (len %d)\", seg.Index, len(arr))\n   103→\t\t\t}\n   104→\t\t\tval = arr[seg.Index]\n   105→\t\t}\n   106→\t}\n   107→\n   108→\tswitch v := val.(type) {\n   109→\tcase string:\n   110→\t\treturn v, nil\n   111→\tdefault:\n   112→\t\tb, _ := json.Marshal(v)\n   113→\t\treturn string(b), nil\n   114→\t}\n   115→}\n   116→\n   117→type CollectMode string\n   118→\n   119→const (\n   120→\tCollectAll CollectMode = \"all\"\n   121→\tCollectAny CollectMode = \"any\"\n   122→)\n   123→\n   124→type WireCondition struct {\n   125→\tStep   string\n   126→\tResult string\n   127→}\n   128→\n   129→type Collect struct {\n   130→\tMode       CollectMode\n   131→\tConditions []WireCondition\n   132→\tTo         string\n   133→}\n   134→\n   135→// Agent declares a named agent with a command and arguments.\n   136→// Steps reference agents by identifier via the \"agent\" config key.\n   137→type Agent struct {\n   138→\tName    string\n   139→\tCommand string\n   140→\tArgs    string\n   141→}\n   142→\n   143→type Workflow struct {\n   144→\tName      string\n   145→\tLocation  WorkflowLocation  // host or container\n   146→\tSteps     map[string]*Step\n   147→\tAgents    map[string]*Agent // declared agents, keyed by identifier\n   148→\tWiring    []Wire\n   149→\tCollects  []Collect\n   150→\tEntryStep string\n   151→\tConfig    map[string]string // workflow-level config (e.g. \"container.image\")\n   152→}\n   153→\n   154→func (w *Workflow) Validate() error {\n   155→\tif w.EntryStep == \"\" {\n   156→\t\treturn fmt.Errorf(\"workflow %q: no entry step defined\", w.Name)\n   157→\t}\n   158→\tif _, ok := w.Steps[w.EntryStep]; !ok {\n   159→\t\treturn fmt.Errorf(\"workflow %q: entry step %q not found\", w.Name, w.EntryStep)\n   160→\t}\n   161→\n   162→\twired := make(map[string]map[string]bool)\n   163→\treachable := map[string]bool{w.EntryStep: true}\n   164→\tfor _, wire := range w.Wiring {\n   165→\t\tif wired[wire.From] == nil {\n   166→\t\t\twired[wire.From] = make(map[string]bool)\n   167→\t\t}\n   168→\t\twired[wire.From][wire.Result] = true\n   169→\t\tif wire.To != StepDone && wire.To != StepAbort {\n   170→\t\t\treachable[wire.To] = true\n   171→\t\t}\n   172→\t}\n   173→\n   174→\t// Validate collects and count their results as wired\n   175→\tfor _, c := range w.Collects {\n   176→\t\t// Validate target step exists\n   177→\t\tif c.To != StepDone && c.To != StepAbort {\n   178→\t\t\tif _, ok := w.Steps[c.To]; !ok {\n   179→\t\t\t\treturn fmt.Errorf(\"workflow %q: collect target step %q not found\", w.Name, c.To)\n   180→\t\t\t}\n   181→\t\t\treachable[c.To] = true\n   182→\t\t}\n   183→\n   184→\t\tfor _, cond := range c.Conditions {\n   185→\t\t\t// Validate condition step exists\n   186→\t\t\tstep, ok := w.Steps[cond.Step]\n   187→\t\t\tif !ok {\n   188→\t\t\t\treturn fmt.Errorf(\"workflow %q: collect references unknown step %q\", w.Name, cond.Step)\n   189→\t\t\t}\n   190→\t\t\t// Validate condition result is declared\n   191→\t\t\tfound := false\n   192→\t\t\tfor _, r := range step.Results {\n   193→\t\t\t\tif r == cond.Result {\n   194→\t\t\t\t\tfound = true\n   195→\t\t\t\t\tbreak\n   196→\t\t\t\t}\n   197→\t\t\t}\n   198→\t\t\tif !found {\n   199→\t\t\t\treturn fmt.Errorf(\"workflow %q: collect references undeclared result %q on step %q\", w.Name, cond.Result, cond.Step)\n   200→\t\t\t}\n   201→\t\t\t// Mark as wired so the \"every result must be wired\" check passes\n   202→\t\t\tif wired[cond.Step] == nil {\n   203→\t\t\t\twired[cond.Step] = make(map[string]bool)\n   204→\t\t\t}\n   205→\t\t\twired[cond.Step][cond.Result] = true\n   206→\t\t}\n   207→\t}\n   208→\n   209→\tfor name, step := range w.Steps {\n   210→\t\tfor _, result := range step.Results {\n   211→\t\t\tif !wired[name][result] {\n   212→\t\t\t\treturn fmt.Errorf(\"workflow %q: step %q result %q is not wired\", w.Name, name, result)\n   213→\t\t\t}\n   214→\t\t}\n   215→\t}\n   216→\n   217→\tfor name := range w.Steps {\n   218→\t\tif !reachable[name] {\n   219→\t\t\treturn fmt.Errorf(\"workflow %q: step %q is orphaned (unreachable)\", w.Name, name)\n   220→\t\t}\n   221→\t}\n   222→\n   223→\t// Check for duplicate output mapping env vars targeting the same step\n   224→\ttargetEnvVars := make(map[string]map[string]bool) // step -> env var -> seen\n   225→\tfor _, wire := range w.Wiring {\n   226→\t\tfor _, om := range wire.OutputMap {\n   227→\t\t\tif targetEnvVars[wire.To] == nil {\n   228→\t\t\t\ttargetEnvVars[wire.To] = make(map[string]bool)\n   229→\t\t\t}\n   230→\t\t\tif targetEnvVars[wire.To][om.EnvVar] {\n   231→\t\t\t\treturn fmt.Errorf(\"duplicate output mapping for env var %q targeting step %q\", om.EnvVar, wire.To)\n   232→\t\t\t}\n   233→\t\t\ttargetEnvVars[wire.To][om.EnvVar] = true\n   234→\t\t}\n   235→\t}\n   236→\n   237→\t// Validate agent references\n   238→\tfor name, step := range w.Steps {\n   239→\t\tif agentRef, ok := step.Config[\"agent\"]; ok {\n   240→\t\t\tif len(w.Agents) == 0 || w.Agents[agentRef] == nil {\n   241→\t\t\t\treturn fmt.Errorf(\"workflow %q: step %q references undeclared agent %q\", w.Name, name, agentRef)\n   242→\t\t\t}\n   243→\t\t\tif step.Type != StepTypeAgent {\n   244→\t\t\t\treturn fmt.Errorf(\"workflow %q: step %q references agent %q but is not a prompt step\", w.Name, name, agentRef)\n   245→\t\t\t}\n   246→\t\t}\n   247→\t}\n   248→\n   249→\treturn nil\n   250→}\n   251→\n   252→// ResolveAgents expands agent references in steps to agent_command/agent_args config.\n   253→// Must be called after Validate to ensure references are valid.\n   254→func (w *Workflow) ResolveAgents() {\n   255→\tfor _, step := range w.Steps {\n   256→\t\tagentRef, ok := step.Config[\"agent\"]\n   257→\t\tif !ok {\n   258→\t\t\tcontinue\n   259→\t\t}\n   260→\t\tagent := w.Agents[agentRef]\n   261→\t\tif agent == nil {\n   262→\t\t\tcontinue\n   263→\t\t}\n   264→\t\t// Only set if not already explicitly overridden at step level\n   265→\t\tif _, has := step.Config[\"agent_command\"]; !has && agent.Command != \"\" {\n   266→\t\t\tstep.Config[\"agent_command\"] = agent.Command\n   267→\t\t}\n   268→\t\tif _, has := step.Config[\"agent_args\"]; !has && agent.Args != \"\" {\n   269→\t\t\tstep.Config[\"agent_args\"] = agent.Args\n   270→\t\t}\n   271→\t}\n   272→}\n   273→\n   274→// ValidateLocation checks that step types are compatible with the workflow location.\n   275→// workflow_name steps are only allowed in host workflows.\n   276→func (w *Workflow) ValidateLocation() error {\n   277→\tif w.Location == LocationContainer {\n   278→\t\tfor name, step := range w.Steps {\n   279→\t\t\tif step.Type == StepTypeWorkflow {\n   280→\t\t\t\treturn fmt.Errorf(\"workflow %q: step %q uses workflow_name, which is only allowed in host workflows (host.cloche)\", w.Name, name)\n   281→\t\t\t}\n   282→\t\t}\n   283→\t}\n   284→\treturn nil\n   285→}\n   286→\n   287→// knownStepConfigKeys lists recognized step-level config keys.\n   288→// Keys with a \"container.\" prefix are also allowed.\n   289→var knownStepConfigKeys = map[string]bool{\n   290→\t\"prompt\":        true,\n   291→\t\"run\":           true,\n   292→\t\"max_attempts\":  true,\n   293→\t\"timeout\":       true,\n   294→\t\"agent_command\": true,\n   295→\t\"agent_args\":    true,\n   296→\t\"agent\":         true,\n   297→\t\"results\":       true,\n   298→\t\"feedback\":      true,\n   299→\t\"workflow_name\": true,\n   300→\t\"prompt_step\":   true,\n   301→}\n   302→\n   303→// ValidateConfig checks step config keys against known keys and returns\n   304→// warnings for any unrecognized keys (likely typos).\n   305→func (w *Workflow) ValidateConfig() []string {\n   306→\tvar warnings []string\n   307→\tfor name, step := range w.Steps {\n   308→\t\tfor key := range step.Config {\n   309→\t\t\tif knownStepConfigKeys[key] {\n   310→\t\t\t\tcontinue\n   311→\t\t\t}\n   312→\t\t\tif strings.HasPrefix(key, \"container.\") || strings.HasPrefix(key, \"host.\") {\n   313→\t\t\t\tcontinue\n   314→\t\t\t}\n   315→\t\t\twarnings = append(warnings, fmt.Sprintf(\n   316→\t\t\t\t\"workflow %q: step %q has unrecognized config key %q\", w.Name, name, key))\n   317→\t\t}\n   318→\t}\n   319→\treturn warnings\n   320→}\n   321→\n   322→// NextSteps returns all target step names wired from the given (stepName, result) pair.\n   323→// Multiple targets indicate fanout — parallel branches launched by the engine.\n   324→func (w *Workflow) NextSteps(stepName, result string) ([]string, error) {\n   325→\tvar targets []string\n   326→\tfor _, wire := range w.Wiring {\n   327→\t\tif wire.From == stepName && wire.Result == result {\n   328→\t\t\ttargets = append(targets, wire.To)\n   329→\t\t}\n   330→\t}\n   331→\tif len(targets) == 0 {\n   332→\t\treturn nil, fmt.Errorf(\"workflow %q: no wiring for step %q result %q\", w.Name, stepName, result)\n   333→\t}\n   334→\treturn targets, nil\n   335→}\n   336→\n   337→// Deprecated: NextStep returns the first target only. Use NextSteps for fanout support.\n   338→func (w *Workflow) NextStep(stepName, result string) (string, error) {\n   339→\ttargets, err := w.NextSteps(stepName, result)\n   340→\tif err != nil {\n   341→\t\treturn \"\", err\n   342→\t}\n   343→\treturn targets[0], nil\n   344→}\n   345→"}]},"parent_tool_use_id":null,"session_id":"f0dfea91-15c3-4f3d-9b43-9ce6c721a7fa","uuid":"ade6c48c-b24d-4d10-8cbf-ba40d79688a8","timestamp":"2026-03-18T16:10:32.504Z","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/domain/workflow.go","content":"package domain\n\nimport (\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"strings\"\n)\n\nconst (\n\tStepDone  = \"done\"\n\tStepAbort = \"abort\"\n)\n\ntype StepType string\n\nconst (\n\tStepTypeAgent    StepType = \"agent\"\n\tStepTypeScript   StepType = \"script\"\n\tStepTypeWorkflow StepType = \"workflow\"\n)\n\n// WorkflowLocation indicates where a workflow is intended to run.\ntype WorkflowLocation string\n\nconst (\n\t// LocationContainer is for workflows that run inside a Docker container.\n\t// This is the default for workflows without a \"host { }\" block.\n\tLocationContainer WorkflowLocation = \"container\"\n\n\t// LocationHost is for workflows that run on the host machine.\n\t// A workflow declares itself as host by including a \"host { }\" block.\n\tLocationHost WorkflowLocation = \"host\"\n)\n\ntype Step struct {\n\tName    string\n\tType    StepType\n\tResults []string\n\tConfig  map[string]string\n}\n\ntype Wire struct {\n\tFrom      string\n\tResult    string\n\tTo        string\n\tOutputMap []OutputMapping\n}\n\ntype SegmentKind int\n\nconst (\n\tSegmentField SegmentKind = iota\n\tSegmentIndex\n)\n\ntype PathSegment struct {\n\tKind  SegmentKind\n\tField string // for SegmentField\n\tIndex int    // for SegmentIndex\n}\n\ntype OutputPath struct {\n\tSegments []PathSegment\n}\n\ntype OutputMapping struct {\n\tEnvVar string\n\tPath   OutputPath\n}\n\n// Evaluate navigates the raw output bytes using the path segments.\n// With no segments, it returns the raw output as a string.\n// With segments, it parses the raw bytes as JSON and navigates using\n// field access (SegmentField) and array indexing (SegmentIndex).\nfunc (p OutputPath) Evaluate(raw []byte) (string, error) {\n\tif len(p.Segments) == 0 {\n\t\treturn string(raw), nil\n\t}\n\n\tvar val any\n\tif err := json.Unmarshal(raw, &val); err != nil {\n\t\treturn \"\", fmt.Errorf(\"output is not valid JSON\")\n\t}\n\n\tfor _, seg := range p.Segments {\n\t\tswitch seg.Kind {\n\t\tcase SegmentField:\n\t\t\tm, ok := val.(map[string]any)\n\t\t\tif !ok {\n\t\t\t\treturn \"\", fmt.Errorf(\"expected object for .%s\", seg.Field)\n\t\t\t}\n\t\t\tval, ok = m[seg.Field]\n\t\t\tif !ok {\n\t\t\t\treturn \"\", fmt.Errorf(\"field %q not found\", seg.Field)\n\t\t\t}\n\t\tcase SegmentIndex:\n\t\t\tarr, ok := val.([]any)\n\t\t\tif !ok {\n\t\t\t\treturn \"\", fmt.Errorf(\"expected array for [%d]\", seg.Index)\n\t\t\t}\n\t\t\tif seg.Index < 0 || seg.Index >= len(arr) {\n\t\t\t\treturn \"\", fmt.Errorf(\"index %d out of range (len %d)\", seg.Index, len(arr))\n\t\t\t}\n\t\t\tval = arr[seg.Index]\n\t\t}\n\t}\n\n\tswitch v := val.(type) {\n\tcase string:\n\t\treturn v, nil\n\tdefault:\n\t\tb, _ := json.Marshal(v)\n\t\treturn string(b), nil\n\t}\n}\n\ntype CollectMode string\n\nconst (\n\tCollectAll CollectMode = \"all\"\n\tCollectAny CollectMode = \"any\"\n)\n\ntype WireCondition struct {\n\tStep   string\n\tResult string\n}\n\ntype Collect struct {\n\tMode       CollectMode\n\tConditions []WireCondition\n\tTo         string\n}\n\n// Agent declares a named agent with a command and arguments.\n// Steps reference agents by identifier via the \"agent\" config key.\ntype Agent struct {\n\tName    string\n\tCommand string\n\tArgs    string\n}\n\ntype Workflow struct {\n\tName      string\n\tLocation  WorkflowLocation  // host or container\n\tSteps     map[string]*Step\n\tAgents    map[string]*Agent // declared agents, keyed by identifier\n\tWiring    []Wire\n\tCollects  []Collect\n\tEntryStep string\n\tConfig    map[string]string // workflow-level config (e.g. \"container.image\")\n}\n\nfunc (w *Workflow) Validate() error {\n\tif w.EntryStep == \"\" {\n\t\treturn fmt.Errorf(\"workflow %q: no entry step defined\", w.Name)\n\t}\n\tif _, ok := w.Steps[w.EntryStep]; !ok {\n\t\treturn fmt.Errorf(\"workflow %q: entry step %q not found\", w.Name, w.EntryStep)\n\t}\n\n\twired := make(map[string]map[string]bool)\n\treachable := map[string]bool{w.EntryStep: true}\n\tfor _, wire := range w.Wiring {\n\t\tif wired[wire.From] == nil {\n\t\t\twired[wire.From] = make(map[string]bool)\n\t\t}\n\t\twired[wire.From][wire.Result] = true\n\t\tif wire.To != StepDone && wire.To != StepAbort {\n\t\t\treachable[wire.To] = true\n\t\t}\n\t}\n\n\t// Validate collects and count their results as wired\n\tfor _, c := range w.Collects {\n\t\t// Validate target step exists\n\t\tif c.To != StepDone && c.To != StepAbort {\n\t\t\tif _, ok := w.Steps[c.To]; !ok {\n\t\t\t\treturn fmt.Errorf(\"workflow %q: collect target step %q not found\", w.Name, c.To)\n\t\t\t}\n\t\t\treachable[c.To] = true\n\t\t}\n\n\t\tfor _, cond := range c.Conditions {\n\t\t\t// Validate condition step exists\n\t\t\tstep, ok := w.Steps[cond.Step]\n\t\t\tif !ok {\n\t\t\t\treturn fmt.Errorf(\"workflow %q: collect references unknown step %q\", w.Name, cond.Step)\n\t\t\t}\n\t\t\t// Validate condition result is declared\n\t\t\tfound := false\n\t\t\tfor _, r := range step.Results {\n\t\t\t\tif r == cond.Result {\n\t\t\t\t\tfound = true\n\t\t\t\t\tbreak\n\t\t\t\t}\n\t\t\t}\n\t\t\tif !found {\n\t\t\t\treturn fmt.Errorf(\"workflow %q: collect references undeclared result %q on step %q\", w.Name, cond.Result, cond.Step)\n\t\t\t}\n\t\t\t// Mark as wired so the \"every result must be wired\" check passes\n\t\t\tif wired[cond.Step] == nil {\n\t\t\t\twired[cond.Step] = make(map[string]bool)\n\t\t\t}\n\t\t\twired[cond.Step][cond.Result] = true\n\t\t}\n\t}\n\n\tfor name, step := range w.Steps {\n\t\tfor _, result := range step.Results {\n\t\t\tif !wired[name][result] {\n\t\t\t\treturn fmt.Errorf(\"workflow %q: step %q result %q is not wired\", w.Name, name, result)\n\t\t\t}\n\t\t}\n\t}\n\n\tfor name := range w.Steps {\n\t\tif !reachable[name] {\n\t\t\treturn fmt.Errorf(\"workflow %q: step %q is orphaned (unreachable)\", w.Name, name)\n\t\t}\n\t}\n\n\t// Check for duplicate output mapping env vars targeting the same step\n\ttargetEnvVars := make(map[string]map[string]bool) // step -> env var -> seen\n\tfor _, wire := range w.Wiring {\n\t\tfor _, om := range wire.OutputMap {\n\t\t\tif targetEnvVars[wire.To] == nil {\n\t\t\t\ttargetEnvVars[wire.To] = make(map[string]bool)\n\t\t\t}\n\t\t\tif targetEnvVars[wire.To][om.EnvVar] {\n\t\t\t\treturn fmt.Errorf(\"duplicate output mapping for env var %q targeting step %q\", om.EnvVar, wire.To)\n\t\t\t}\n\t\t\ttargetEnvVars[wire.To][om.EnvVar] = true\n\t\t}\n\t}\n\n\t// Validate agent references\n\tfor name, step := range w.Steps {\n\t\tif agentRef, ok := step.Config[\"agent\"]; ok {\n\t\t\tif len(w.Agents) == 0 || w.Agents[agentRef] == nil {\n\t\t\t\treturn fmt.Errorf(\"workflow %q: step %q references undeclared agent %q\", w.Name, name, agentRef)\n\t\t\t}\n\t\t\tif step.Type != StepTypeAgent {\n\t\t\t\treturn fmt.Errorf(\"workflow %q: step %q references agent %q but is not a prompt step\", w.Name, name, agentRef)\n\t\t\t}\n\t\t}\n\t}\n\n\treturn nil\n}\n\n// ResolveAgents expands agent references in steps to agent_command/agent_args config.\n// Must be called after Validate to ensure references are valid.\nfunc (w *Workflow) ResolveAgents() {\n\tfor _, step := range w.Steps {\n\t\tagentRef, ok := step.Config[\"agent\"]\n\t\tif !ok {\n\t\t\tcontinue\n\t\t}\n\t\tagent := w.Agents[agentRef]\n\t\tif agent == nil {\n\t\t\tcontinue\n\t\t}\n\t\t// Only set if not already explicitly overridden at step level\n\t\tif _, has := step.Config[\"agent_command\"]; !has && agent.Command != \"\" {\n\t\t\tstep.Config[\"agent_command\"] = agent.Command\n\t\t}\n\t\tif _, has := step.Config[\"agent_args\"]; !has && agent.Args != \"\" {\n\t\t\tstep.Config[\"agent_args\"] = agent.Args\n\t\t}\n\t}\n}\n\n// ValidateLocation checks that step types are compatible with the workflow location.\n// workflow_name steps are only allowed in host workflows.\nfunc (w *Workflow) ValidateLocation() error {\n\tif w.Location == LocationContainer {\n\t\tfor name, step := range w.Steps {\n\t\t\tif step.Type == StepTypeWorkflow {\n\t\t\t\treturn fmt.Errorf(\"workflow %q: step %q uses workflow_name, which is only allowed in host workflows (host.cloche)\", w.Name, name)\n\t\t\t}\n\t\t}\n\t}\n\treturn nil\n}\n\n// knownStepConfigKeys lists recognized step-level config keys.\n// Keys with a \"container.\" prefix are also allowed.\nvar knownStepConfigKeys = map[string]bool{\n\t\"prompt\":        true,\n\t\"run\":           true,\n\t\"max_attempts\":  true,\n\t\"timeout\":       true,\n\t\"agent_command\": true,\n\t\"agent_args\":    true,\n\t\"agent\":         true,\n\t\"results\":       true,\n\t\"feedback\":      true,\n\t\"workflow_name\": true,\n\t\"prompt_step\":   true,\n}\n\n// ValidateConfig checks step config keys against known keys and returns\n// warnings for any unrecognized keys (likely typos).\nfunc (w *Workflow) ValidateConfig() []string {\n\tvar warnings []string\n\tfor name, step := range w.Steps {\n\t\tfor key := range step.Config {\n\t\t\tif knownStepConfigKeys[key] {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tif strings.HasPrefix(key, \"container.\") || strings.HasPrefix(key, \"host.\") {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\twarnings = append(warnings, fmt.Sprintf(\n\t\t\t\t\"workflow %q: step %q has unrecognized config key %q\", w.Name, name, key))\n\t\t}\n\t}\n\treturn warnings\n}\n\n// NextSteps returns all target step names wired from the given (stepName, result) pair.\n// Multiple targets indicate fanout — parallel branches launched by the engine.\nfunc (w *Workflow) NextSteps(stepName, result string) ([]string, error) {\n\tvar targets []string\n\tfor _, wire := range w.Wiring {\n\t\tif wire.From == stepName && wire.Result == result {\n\t\t\ttargets = append(targets, wire.To)\n\t\t}\n\t}\n\tif len(targets) == 0 {\n\t\treturn nil, fmt.Errorf(\"workflow %q: no wiring for step %q result %q\", w.Name, stepName, result)\n\t}\n\treturn targets, nil\n}\n\n// Deprecated: NextStep returns the first target only. Use NextSteps for fanout support.\nfunc (w *Workflow) NextStep(stepName, result string) (string, error) {\n\ttargets, err := w.NextSteps(stepName, result)\n\tif err != nil {\n\t\treturn \"\", err\n\t}\n\treturn targets[0], nil\n}\n","numLines":345,"startLine":1,"totalLines":345}}}
