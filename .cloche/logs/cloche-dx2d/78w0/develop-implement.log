{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LAbuAirQTDn6tFSGpTiqAK","type":"tool_result","content":"     1→package agent\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"fmt\"\n     6→\t\"io\"\n     7→\t\"os\"\n     8→\t\"path/filepath\"\n     9→\t\"strings\"\n    10→\n    11→\t\"github.com/cloche-dev/cloche/internal/adapters/agents/generic\"\n    12→\t\"github.com/cloche-dev/cloche/internal/adapters/agents/prompt\"\n    13→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    14→\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    15→\t\"github.com/cloche-dev/cloche/internal/engine\"\n    16→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    17→\t\"github.com/cloche-dev/cloche/internal/protocol\"\n    18→)\n    19→\n    20→type RunnerConfig struct {\n    21→\tWorkflowPath   string\n    22→\tWorkDir        string\n    23→\tStatusOutput   io.Writer\n    24→\tRunID          string\n    25→\tResumeFromStep string // when non-empty, resume the workflow from this step\n    26→}\n    27→\n    28→type Runner struct {\n    29→\tcfg RunnerConfig\n    30→}\n    31→\n    32→func NewRunner(cfg RunnerConfig) *Runner {\n    33→\treturn &Runner{\n    34→\t\tcfg: cfg,\n    35→\t}\n    36→}\n    37→\n    38→func (r *Runner) Run(ctx context.Context) error {\n    39→\tdata, err := os.ReadFile(r.cfg.WorkflowPath)\n    40→\tif err != nil {\n    41→\t\treturn fmt.Errorf(\"reading workflow file: %w\", err)\n    42→\t}\n    43→\n    44→\twf, err := dsl.ParseForContainer(string(data))\n    45→\tif err != nil {\n    46→\t\treturn fmt.Errorf(\"parsing workflow: %w\", err)\n    47→\t}\n    48→\twf.ResolveAgents()\n    49→\n    50→\tstatusWriter := protocol.NewStatusWriter(r.cfg.StatusOutput)\n    51→\tgenericAdapter := generic.New()\n    52→\tgenericAdapter.RunID = r.cfg.RunID\n    53→\tpromptAdapter := prompt.New()\n    54→\tpromptAdapter.RunID = r.cfg.RunID\n    55→\tpromptAdapter.StatusWriter = statusWriter\n    56→\tif cmd, ok := os.LookupEnv(\"CLOCHE_AGENT_COMMAND\"); ok {\n    57→\t\tpromptAdapter.Commands = prompt.ParseCommands(cmd)\n    58→\t}\n    59→\tif cmd := wf.Config[\"container.agent_command\"]; cmd != \"\" {\n    60→\t\tpromptAdapter.Commands = prompt.ParseCommands(cmd)\n    61→\t}\n    62→\tif args := wf.Config[\"container.agent_args\"]; args != \"\" {\n    63→\t\tpromptAdapter.ExplicitArgs = strings.Fields(args)\n    64→\t}\n    65→\n    66→\t// Reset per-run state from any previous run — but preserve outputs when resuming\n    67→\t_ = os.RemoveAll(filepath.Join(r.cfg.WorkDir, \".cloche\", \"attempt_count\"))\n    68→\tif r.cfg.ResumeFromStep == \"\" {\n    69→\t\t_ = os.RemoveAll(filepath.Join(r.cfg.WorkDir, \".cloche\", \"output\"))\n    70→\t}\n    71→\n    72→\t// Create unified log writer\n    73→\tulog, err := logstream.New(r.cfg.WorkDir)\n    74→\tif err != nil {\n    75→\t\treturn fmt.Errorf(\"creating unified log: %w\", err)\n    76→\t}\n    77→\tdefer ulog.Close()\n    78→\n    79→\tgenericAdapter.StatusWriter = statusWriter\n    80→\n    81→\texecutor := &stepExecutor{\n    82→\t\tworkDir:        r.cfg.WorkDir,\n    83→\t\tgeneric:        genericAdapter,\n    84→\t\tprompt:         promptAdapter,\n    85→\t\tlogStream:      ulog,\n    86→\t\tstatusWriter:   statusWriter,\n    87→\t\tresumeFromStep: r.cfg.ResumeFromStep,\n    88→\t}\n    89→\n    90→\teng := engine.New(executor)\n    91→\teng.SetStatusHandler(&statusReporter{writer: statusWriter, logStream: ulog})\n    92→\n    93→\t// Resume mode: load completed step results and configure engine\n    94→\tif r.cfg.ResumeFromStep != \"\" {\n    95→\t\tpreloaded, err := loadCompletedStepResults(r.cfg.WorkDir, wf, r.cfg.ResumeFromStep)\n    96→\t\tif err != nil {\n    97→\t\t\treturn fmt.Errorf(\"loading completed step results for resume: %w\", err)\n    98→\t\t}\n    99→\t\teng.SetPreloadedResults(preloaded)\n   100→\t}\n   101→\n   102→\t// Generate a run title from the prompt if one was not provided by the caller.\n   103→\t// The daemon sets title from --title; if empty, the agent extracts from prompt.\n   104→\tif title := extractTitle(r.cfg.WorkDir, r.cfg.RunID); title != \"\" {\n   105→\t\tstatusWriter.RunTitle(title)\n   106→\t}\n   107→\n   108→\tprotocol.AppendHistoryMarker(r.cfg.WorkDir, \"workflow:start \"+wf.Name)\n   109→\n   110→\trun, runErr := eng.Run(ctx, wf)\n   111→\tif runErr != nil {\n   112→\t\tprotocol.AppendHistoryMarker(r.cfg.WorkDir, \"workflow:end \"+wf.Name+\" result:failed\")\n   113→\t\tulog.Log(logstream.TypeStatus, \"error: \"+runErr.Error())\n   114→\t\tulog.Log(logstream.TypeStatus, \"run_completed: failed\")\n   115→\t\t// Extract the failed step name from step executions so the daemon\n   116→\t\t// can display which step caused the failure.\n   117→\t\tfailedStep := \"\"\n   118→\t\tif run != nil {\n   119→\t\t\tfor _, se := range run.StepExecutions {\n   120→\t\t\t\tif se.Result == \"error\" || se.Result == \"fail\" {\n   121→\t\t\t\t\tfailedStep = se.StepName\n   122→\t\t\t\t}\n   123→\t\t\t}\n   124→\t\t}\n   125→\t\tstatusWriter.Error(failedStep, runErr.Error())\n   126→\t\tstatusWriter.RunCompleted(\"failed\")\n   127→\t\treturn runErr\n   128→\t}\n   129→\n   130→\tprotocol.AppendHistoryMarker(r.cfg.WorkDir, \"workflow:end \"+wf.Name+\" result:\"+string(run.State))\n   131→\n   132→\tulog.Log(logstream.TypeStatus, \"run_completed: \"+string(run.State))\n   133→\tstatusWriter.RunCompleted(string(run.State))\n   134→\treturn nil\n   135→}\n   136→\n   137→type stepExecutor struct {\n   138→\tworkDir        string\n   139→\tgeneric        *generic.Adapter\n   140→\tprompt         *prompt.Adapter\n   141→\tlogStream      *logstream.Writer\n   142→\tstatusWriter   *protocol.StatusWriter\n   143→\tresumeFromStep string // the step being resumed (for prompt resume mode)\n   144→}\n   145→\n   146→func (e *stepExecutor) Execute(ctx context.Context, step *domain.Step) (string, error) {\n   147→\tswitch step.Type {\n   148→\tcase domain.StepTypeScript:\n   149→\t\tresult, err := e.generic.Execute(ctx, step, e.workDir)\n   150→\t\te.logStepOutput(step.Name, logstream.TypeScript)\n   151→\t\treturn result, err\n   152→\tcase domain.StepTypeAgent:\n   153→\t\tif _, ok := step.Config[\"run\"]; ok {\n   154→\t\t\tresult, err := e.generic.Execute(ctx, step, e.workDir)\n   155→\t\t\te.logStepOutput(step.Name, logstream.TypeScript)\n   156→\t\t\treturn result, err\n   157→\t\t}\n   158→\t\tif _, ok := step.Config[\"prompt\"]; ok {\n   159→\t\t\tif cmd := step.Config[\"agent_command\"]; cmd != \"\" {\n   160→\t\t\t\te.prompt.Commands = prompt.ParseCommands(cmd)\n   161→\t\t\t}\n   162→\t\t\tif args := step.Config[\"agent_args\"]; args != \"\" {\n   163→\t\t\t\te.prompt.ExplicitArgs = strings.Fields(args)\n   164→\t\t\t}\n   165→\t\t\t// Resume mode: if this is the step being resumed, use conversation resume\n   166→\t\t\tif e.resumeFromStep == step.Name {\n   167→\t\t\t\te.prompt.ResumeConversation = true\n   168→\t\t\t\tdefer func() { e.prompt.ResumeConversation = false }()\n   169→\t\t\t}\n   170→\t\t\tresult, err := e.prompt.Execute(ctx, step, e.workDir)\n   171→\t\t\te.copyToLLMLog(step.Name)\n   172→\t\t\te.logStepOutput(step.Name, logstream.TypeLLM)\n   173→\t\t\treturn result, err\n   174→\t\t}\n   175→\t\treturn \"\", fmt.Errorf(\"agent step %q requires either 'run' or 'prompt' config\", step.Name)\n   176→\tdefault:\n   177→\t\treturn \"\", fmt.Errorf(\"unknown step type: %s\", step.Type)\n   178→\t}\n   179→}\n   180→\n   181→// logStepOutput reads the per-step log file and writes its contents to the unified log.\n   182→func (e *stepExecutor) logStepOutput(stepName string, typ logstream.EntryType) {\n   183→\tpath := filepath.Join(e.workDir, \".cloche\", \"output\", stepName+\".log\")\n   184→\tdata, err := os.ReadFile(path)\n   185→\tif err != nil || len(data) == 0 {\n   186→\t\treturn\n   187→\t}\n   188→\te.logStream.Log(typ, string(data))\n   189→}\n   190→\n   191→// copyToLLMLog copies <step>.log to llm-<step>.log for agent prompt steps.\n   192→func (e *stepExecutor) copyToLLMLog(stepName string) {\n   193→\tsrc := filepath.Join(e.workDir, \".cloche\", \"output\", stepName+\".log\")\n   194→\tdst := filepath.Join(e.workDir, \".cloche\", \"output\", \"llm-\"+stepName+\".log\")\n   195→\tdata, err := os.ReadFile(src)\n   196→\tif err != nil {\n   197→\t\treturn\n   198→\t}\n   199→\t_ = os.WriteFile(dst, data, 0644)\n   200→}\n   201→\n   202→type statusReporter struct {\n   203→\twriter    *protocol.StatusWriter\n   204→\tlogStream *logstream.Writer\n   205→}\n   206→\n   207→func (s *statusReporter) OnStepStart(_ *domain.Run, step *domain.Step) {\n   208→\ts.writer.StepStarted(step.Name)\n   209→\ts.logStream.Log(logstream.TypeStatus, \"step_started: \"+step.Name)\n   210→}\n   211→\n   212→func (s *statusReporter) OnStepComplete(_ *domain.Run, step *domain.Step, result string) {\n   213→\ts.writer.StepCompleted(step.Name, result)\n   214→\ts.logStream.Log(logstream.TypeStatus, \"step_completed: \"+step.Name+\" -> \"+result)\n   215→}\n   216→\n   217→func (s *statusReporter) OnRunComplete(_ *domain.Run) {}\n   218→\n   219→// loadCompletedStepResults builds a map of step_name -> result for all steps\n   220→// that completed successfully before the resume point. It walks the workflow\n   221→// graph from the entry step, following wires, collecting results from the\n   222→// history log. Steps at or after the resumeFrom step are excluded.\n   223→func loadCompletedStepResults(workDir string, wf *domain.Workflow, resumeFrom string) (map[string]string, error) {\n   224→\tpreloaded := make(map[string]string)\n   225→\n   226→\t// Parse step results from history.log\n   227→\thistoryPath := filepath.Join(workDir, \".cloche\", \"history.log\")\n   228→\tdata, err := os.ReadFile(historyPath)\n   229→\tif err != nil {\n   230→\t\treturn nil, fmt.Errorf(\"reading history log: %w\", err)\n   231→\t}\n   232→\n   233→\t// Extract step:result pairs from history entries\n   234→\tstepResults := make(map[string]string)\n   235→\tfor _, line := range strings.Split(string(data), \"\\n\") {\n   236→\t\t// History format: [timestamp] step:<name> result:<result> ...\n   237→\t\tif !strings.Contains(line, \"step:\") || !strings.Contains(line, \"result:\") {\n   238→\t\t\tcontinue\n   239→\t\t}\n   240→\t\tvar stepName, result string\n   241→\t\tfor _, field := range strings.Fields(line) {\n   242→\t\t\tif strings.HasPrefix(field, \"step:\") {\n   243→\t\t\t\tstepName = strings.TrimPrefix(field, \"step:\")\n   244→\t\t\t}\n   245→\t\t\tif strings.HasPrefix(field, \"result:\") {\n   246→\t\t\t\tresult = strings.TrimPrefix(field, \"result:\")\n   247→\t\t\t}\n   248→\t\t}\n   249→\t\tif stepName != \"\" && result != \"\" {\n   250→\t\t\tstepResults[stepName] = result\n   251→\t\t}\n   252→\t}\n   253→\n   254→\t// Walk the workflow graph from entry step, collecting completed steps\n   255→\t// until we reach the resume step\n   256→\tvisited := make(map[string]bool)\n   257→\tvar walk func(stepName string)\n   258→\twalk = func(stepName string) {\n   259→\t\tif visited[stepName] || stepName == resumeFrom {\n   260→\t\t\treturn\n   261→\t\t}\n   262→\t\tvisited[stepName] = true\n   263→\n   264→\t\tresult, ok := stepResults[stepName]\n   265→\t\tif !ok {\n   266→\t\t\treturn\n   267→\t\t}\n   268→\t\tpreloaded[stepName] = result\n   269→\n   270→\t\t// Follow wires from this step's result\n   271→\t\tnextSteps, err := wf.NextSteps(stepName, result)\n   272→\t\tif err != nil {\n   273→\t\t\treturn\n   274→\t\t}\n   275→\t\tfor _, next := range nextSteps {\n   276→\t\t\tif next != domain.StepDone && next != domain.StepAbort {\n   277→\t\t\t\twalk(next)\n   278→\t\t\t}\n   279→\t\t}\n   280→\t}\n   281→\n   282→\twalk(wf.EntryStep)\n   283→\treturn preloaded, nil\n   284→}\n   285→\n   286→// extractTitle tries to derive a one-line summary from the run's prompt content.\n   287→// It reads the per-run prompt.txt file (written by the daemon before container start),\n   288→// then returns the first non-empty line, truncated to 100 characters.\n   289→func extractTitle(workDir string, runID string) string {\n   290→\t// Try the per-run prompt file\n   291→\tpromptPath := filepath.Join(workDir, \".cloche\", runID, \"prompt.txt\")\n   292→\tif _, err := os.Stat(promptPath); err != nil {\n   293→\t\t// Fall back to legacy path\n   294→\t\tpromptPath = filepath.Join(workDir, \".cloche\", \"prompt.txt\")\n   295→\t}\n   296→\tdata, err := os.ReadFile(promptPath)\n   297→\tif err != nil || len(data) == 0 {\n   298→\t\treturn \"\"\n   299→\t}\n   300→\n   301→\ttext := strings.TrimSpace(string(data))\n   302→\tif text == \"\" {\n   303→\t\treturn \"\"\n   304→\t}\n   305→\n   306→\t// Take first non-empty line as the title\n   307→\tfor _, line := range strings.Split(text, \"\\n\") {\n   308→\t\tline = strings.TrimSpace(line)\n   309→\t\t// Skip markdown headers, comment markers, and blank lines\n   310→\t\tif line == \"\" || line == \"---\" || line == \"```\" {\n   311→\t\t\tcontinue\n   312→\t\t}\n   313→\t\t// Strip leading markdown header markers\n   314→\t\tline = strings.TrimLeft(line, \"# \")\n   315→\t\tline = strings.TrimSpace(line)\n   316→\t\tif line == \"\" {\n   317→\t\t\tcontinue\n   318→\t\t}\n   319→\t\tif len(line) > 100 {\n   320→\t\t\tline = line[:97] + \"...\"\n   321→\t\t}\n   322→\t\treturn line\n   323→\t}\n   324→\treturn \"\"\n   325→}\n   326→"}]},"parent_tool_use_id":null,"session_id":"f0dfea91-15c3-4f3d-9b43-9ce6c721a7fa","uuid":"b7529216-cb55-4c40-a5f6-ebab2e8ddac9","timestamp":"2026-03-18T16:10:32.937Z","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/agent/runner.go","content":"package agent\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"io\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"strings\"\n\n\t\"github.com/cloche-dev/cloche/internal/adapters/agents/generic\"\n\t\"github.com/cloche-dev/cloche/internal/adapters/agents/prompt\"\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/dsl\"\n\t\"github.com/cloche-dev/cloche/internal/engine\"\n\t\"github.com/cloche-dev/cloche/internal/logstream\"\n\t\"github.com/cloche-dev/cloche/internal/protocol\"\n)\n\ntype RunnerConfig struct {\n\tWorkflowPath   string\n\tWorkDir        string\n\tStatusOutput   io.Writer\n\tRunID          string\n\tResumeFromStep string // when non-empty, resume the workflow from this step\n}\n\ntype Runner struct {\n\tcfg RunnerConfig\n}\n\nfunc NewRunner(cfg RunnerConfig) *Runner {\n\treturn &Runner{\n\t\tcfg: cfg,\n\t}\n}\n\nfunc (r *Runner) Run(ctx context.Context) error {\n\tdata, err := os.ReadFile(r.cfg.WorkflowPath)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"reading workflow file: %w\", err)\n\t}\n\n\twf, err := dsl.ParseForContainer(string(data))\n\tif err != nil {\n\t\treturn fmt.Errorf(\"parsing workflow: %w\", err)\n\t}\n\twf.ResolveAgents()\n\n\tstatusWriter := protocol.NewStatusWriter(r.cfg.StatusOutput)\n\tgenericAdapter := generic.New()\n\tgenericAdapter.RunID = r.cfg.RunID\n\tpromptAdapter := prompt.New()\n\tpromptAdapter.RunID = r.cfg.RunID\n\tpromptAdapter.StatusWriter = statusWriter\n\tif cmd, ok := os.LookupEnv(\"CLOCHE_AGENT_COMMAND\"); ok {\n\t\tpromptAdapter.Commands = prompt.ParseCommands(cmd)\n\t}\n\tif cmd := wf.Config[\"container.agent_command\"]; cmd != \"\" {\n\t\tpromptAdapter.Commands = prompt.ParseCommands(cmd)\n\t}\n\tif args := wf.Config[\"container.agent_args\"]; args != \"\" {\n\t\tpromptAdapter.ExplicitArgs = strings.Fields(args)\n\t}\n\n\t// Reset per-run state from any previous run — but preserve outputs when resuming\n\t_ = os.RemoveAll(filepath.Join(r.cfg.WorkDir, \".cloche\", \"attempt_count\"))\n\tif r.cfg.ResumeFromStep == \"\" {\n\t\t_ = os.RemoveAll(filepath.Join(r.cfg.WorkDir, \".cloche\", \"output\"))\n\t}\n\n\t// Create unified log writer\n\tulog, err := logstream.New(r.cfg.WorkDir)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"creating unified log: %w\", err)\n\t}\n\tdefer ulog.Close()\n\n\tgenericAdapter.StatusWriter = statusWriter\n\n\texecutor := &stepExecutor{\n\t\tworkDir:        r.cfg.WorkDir,\n\t\tgeneric:        genericAdapter,\n\t\tprompt:         promptAdapter,\n\t\tlogStream:      ulog,\n\t\tstatusWriter:   statusWriter,\n\t\tresumeFromStep: r.cfg.ResumeFromStep,\n\t}\n\n\teng := engine.New(executor)\n\teng.SetStatusHandler(&statusReporter{writer: statusWriter, logStream: ulog})\n\n\t// Resume mode: load completed step results and configure engine\n\tif r.cfg.ResumeFromStep != \"\" {\n\t\tpreloaded, err := loadCompletedStepResults(r.cfg.WorkDir, wf, r.cfg.ResumeFromStep)\n\t\tif err != nil {\n\t\t\treturn fmt.Errorf(\"loading completed step results for resume: %w\", err)\n\t\t}\n\t\teng.SetPreloadedResults(preloaded)\n\t}\n\n\t// Generate a run title from the prompt if one was not provided by the caller.\n\t// The daemon sets title from --title; if empty, the agent extracts from prompt.\n\tif title := extractTitle(r.cfg.WorkDir, r.cfg.RunID); title != \"\" {\n\t\tstatusWriter.RunTitle(title)\n\t}\n\n\tprotocol.AppendHistoryMarker(r.cfg.WorkDir, \"workflow:start \"+wf.Name)\n\n\trun, runErr := eng.Run(ctx, wf)\n\tif runErr != nil {\n\t\tprotocol.AppendHistoryMarker(r.cfg.WorkDir, \"workflow:end \"+wf.Name+\" result:failed\")\n\t\tulog.Log(logstream.TypeStatus, \"error: \"+runErr.Error())\n\t\tulog.Log(logstream.TypeStatus, \"run_completed: failed\")\n\t\t// Extract the failed step name from step executions so the daemon\n\t\t// can display which step caused the failure.\n\t\tfailedStep := \"\"\n\t\tif run != nil {\n\t\t\tfor _, se := range run.StepExecutions {\n\t\t\t\tif se.Result == \"error\" || se.Result == \"fail\" {\n\t\t\t\t\tfailedStep = se.StepName\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t\tstatusWriter.Error(failedStep, runErr.Error())\n\t\tstatusWriter.RunCompleted(\"failed\")\n\t\treturn runErr\n\t}\n\n\tprotocol.AppendHistoryMarker(r.cfg.WorkDir, \"workflow:end \"+wf.Name+\" result:\"+string(run.State))\n\n\tulog.Log(logstream.TypeStatus, \"run_completed: \"+string(run.State))\n\tstatusWriter.RunCompleted(string(run.State))\n\treturn nil\n}\n\ntype stepExecutor struct {\n\tworkDir        string\n\tgeneric        *generic.Adapter\n\tprompt         *prompt.Adapter\n\tlogStream      *logstream.Writer\n\tstatusWriter   *protocol.StatusWriter\n\tresumeFromStep string // the step being resumed (for prompt resume mode)\n}\n\nfunc (e *stepExecutor) Execute(ctx context.Context, step *domain.Step) (string, error) {\n\tswitch step.Type {\n\tcase domain.StepTypeScript:\n\t\tresult, err := e.generic.Execute(ctx, step, e.workDir)\n\t\te.logStepOutput(step.Name, logstream.TypeScript)\n\t\treturn result, err\n\tcase domain.StepTypeAgent:\n\t\tif _, ok := step.Config[\"run\"]; ok {\n\t\t\tresult, err := e.generic.Execute(ctx, step, e.workDir)\n\t\t\te.logStepOutput(step.Name, logstream.TypeScript)\n\t\t\treturn result, err\n\t\t}\n\t\tif _, ok := step.Config[\"prompt\"]; ok {\n\t\t\tif cmd := step.Config[\"agent_command\"]; cmd != \"\" {\n\t\t\t\te.prompt.Commands = prompt.ParseCommands(cmd)\n\t\t\t}\n\t\t\tif args := step.Config[\"agent_args\"]; args != \"\" {\n\t\t\t\te.prompt.ExplicitArgs = strings.Fields(args)\n\t\t\t}\n\t\t\t// Resume mode: if this is the step being resumed, use conversation resume\n\t\t\tif e.resumeFromStep == step.Name {\n\t\t\t\te.prompt.ResumeConversation = true\n\t\t\t\tdefer func() { e.prompt.ResumeConversation = false }()\n\t\t\t}\n\t\t\tresult, err := e.prompt.Execute(ctx, step, e.workDir)\n\t\t\te.copyToLLMLog(step.Name)\n\t\t\te.logStepOutput(step.Name, logstream.TypeLLM)\n\t\t\treturn result, err\n\t\t}\n\t\treturn \"\", fmt.Errorf(\"agent step %q requires either 'run' or 'prompt' config\", step.Name)\n\tdefault:\n\t\treturn \"\", fmt.Errorf(\"unknown step type: %s\", step.Type)\n\t}\n}\n\n// logStepOutput reads the per-step log file and writes its contents to the unified log.\nfunc (e *stepExecutor) logStepOutput(stepName string, typ logstream.EntryType) {\n\tpath := filepath.Join(e.workDir, \".cloche\", \"output\", stepName+\".log\")\n\tdata, err := os.ReadFile(path)\n\tif err != nil || len(data) == 0 {\n\t\treturn\n\t}\n\te.logStream.Log(typ, string(data))\n}\n\n// copyToLLMLog copies <step>.log to llm-<step>.log for agent prompt steps.\nfunc (e *stepExecutor) copyToLLMLog(stepName string) {\n\tsrc := filepath.Join(e.workDir, \".cloche\", \"output\", stepName+\".log\")\n\tdst := filepath.Join(e.workDir, \".cloche\", \"output\", \"llm-\"+stepName+\".log\")\n\tdata, err := os.ReadFile(src)\n\tif err != nil {\n\t\treturn\n\t}\n\t_ = os.WriteFile(dst, data, 0644)\n}\n\ntype statusReporter struct {\n\twriter    *protocol.StatusWriter\n\tlogStream *logstream.Writer\n}\n\nfunc (s *statusReporter) OnStepStart(_ *domain.Run, step *domain.Step) {\n\ts.writer.StepStarted(step.Name)\n\ts.logStream.Log(logstream.TypeStatus, \"step_started: \"+step.Name)\n}\n\nfunc (s *statusReporter) OnStepComplete(_ *domain.Run, step *domain.Step, result string) {\n\ts.writer.StepCompleted(step.Name, result)\n\ts.logStream.Log(logstream.TypeStatus, \"step_completed: \"+step.Name+\" -> \"+result)\n}\n\nfunc (s *statusReporter) OnRunComplete(_ *domain.Run) {}\n\n// loadCompletedStepResults builds a map of step_name -> result for all steps\n// that completed successfully before the resume point. It walks the workflow\n// graph from the entry step, following wires, collecting results from the\n// history log. Steps at or after the resumeFrom step are excluded.\nfunc loadCompletedStepResults(workDir string, wf *domain.Workflow, resumeFrom string) (map[string]string, error) {\n\tpreloaded := make(map[string]string)\n\n\t// Parse step results from history.log\n\thistoryPath := filepath.Join(workDir, \".cloche\", \"history.log\")\n\tdata, err := os.ReadFile(historyPath)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"reading history log: %w\", err)\n\t}\n\n\t// Extract step:result pairs from history entries\n\tstepResults := make(map[string]string)\n\tfor _, line := range strings.Split(string(data), \"\\n\") {\n\t\t// History format: [timestamp] step:<name> result:<result> ...\n\t\tif !strings.Contains(line, \"step:\") || !strings.Contains(line, \"result:\") {\n\t\t\tcontinue\n\t\t}\n\t\tvar stepName, result string\n\t\tfor _, field := range strings.Fields(line) {\n\t\t\tif strings.HasPrefix(field, \"step:\") {\n\t\t\t\tstepName = strings.TrimPrefix(field, \"step:\")\n\t\t\t}\n\t\t\tif strings.HasPrefix(field, \"result:\") {\n\t\t\t\tresult = strings.TrimPrefix(field, \"result:\")\n\t\t\t}\n\t\t}\n\t\tif stepName != \"\" && result != \"\" {\n\t\t\tstepResults[stepName] = result\n\t\t}\n\t}\n\n\t// Walk the workflow graph from entry step, collecting completed steps\n\t// until we reach the resume step\n\tvisited := make(map[string]bool)\n\tvar walk func(stepName string)\n\twalk = func(stepName string) {\n\t\tif visited[stepName] || stepName == resumeFrom {\n\t\t\treturn\n\t\t}\n\t\tvisited[stepName] = true\n\n\t\tresult, ok := stepResults[stepName]\n\t\tif !ok {\n\t\t\treturn\n\t\t}\n\t\tpreloaded[stepName] = result\n\n\t\t// Follow wires from this step's result\n\t\tnextSteps, err := wf.NextSteps(stepName, result)\n\t\tif err != nil {\n\t\t\treturn\n\t\t}\n\t\tfor _, next := range nextSteps {\n\t\t\tif next != domain.StepDone && next != domain.StepAbort {\n\t\t\t\twalk(next)\n\t\t\t}\n\t\t}\n\t}\n\n\twalk(wf.EntryStep)\n\treturn preloaded, nil\n}\n\n// extractTitle tries to derive a one-line summary from the run's prompt content.\n// It reads the per-run prompt.txt file (written by the daemon before container start),\n// then returns the first non-empty line, truncated to 100 characters.\nfunc extractTitle(workDir string, runID string) string {\n\t// Try the per-run prompt file\n\tpromptPath := filepath.Join(workDir, \".cloche\", runID, \"prompt.txt\")\n\tif _, err := os.Stat(promptPath); err != nil {\n\t\t// Fall back to legacy path\n\t\tpromptPath = filepath.Join(workDir, \".cloche\", \"prompt.txt\")\n\t}\n\tdata, err := os.ReadFile(promptPath)\n\tif err != nil || len(data) == 0 {\n\t\treturn \"\"\n\t}\n\n\ttext := strings.TrimSpace(string(data))\n\tif text == \"\" {\n\t\treturn \"\"\n\t}\n\n\t// Take first non-empty line as the title\n\tfor _, line := range strings.Split(text, \"\\n\") {\n\t\tline = strings.TrimSpace(line)\n\t\t// Skip markdown headers, comment markers, and blank lines\n\t\tif line == \"\" || line == \"---\" || line == \"```\" {\n\t\t\tcontinue\n\t\t}\n\t\t// Strip leading markdown header markers\n\t\tline = strings.TrimLeft(line, \"# \")\n\t\tline = strings.TrimSpace(line)\n\t\tif line == \"\" {\n\t\t\tcontinue\n\t\t}\n\t\tif len(line) > 100 {\n\t\t\tline = line[:97] + \"...\"\n\t\t}\n\t\treturn line\n\t}\n\treturn \"\"\n}\n","numLines":326,"startLine":1,"totalLines":326}}}
