{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01G2UtuNWiz3BF8KD2seXFff","type":"tool_result","content":"     1â†’package main\n     2â†’\n     3â†’import (\n     4â†’\t\"context\"\n     5â†’\t\"fmt\"\n     6â†’\t\"io\"\n     7â†’\t\"os\"\n     8â†’\t\"time\"\n     9â†’\n    10â†’\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    11â†’)\n    12â†’\n    13â†’func cmdPoll(client pb.ClocheServiceClient, args []string) {\n    14â†’\tif len(args) < 1 {\n    15â†’\t\tfmt.Fprintf(os.Stderr, \"usage: cloche poll <run-id> [run-id...]\\n\")\n    16â†’\t\tos.Exit(1)\n    17â†’\t}\n    18â†’\n    19â†’\tif len(args) == 1 {\n    20â†’\t\tcmdPollSingle(client, args[0])\n    21â†’\t} else {\n    22â†’\t\texitCode := cmdPollMulti(client, args, os.Stdout, os.Stderr)\n    23â†’\t\tos.Exit(exitCode)\n    24â†’\t}\n    25â†’}\n    26â†’\n    27â†’func cmdPollSingle(client pb.ClocheServiceClient, runID string) {\n    28â†’\tpollInterval := 2 * time.Second\n    29â†’\tcontainerDeadThreshold := 1 * time.Minute\n    30â†’\n    31â†’\tvar lastStepCount int\n    32â†’\tvar lastState string\n    33â†’\n    34â†’\tfor {\n    35â†’\t\tctx, cancel := context.WithTimeout(context.Background(), 10*time.Second)\n    36â†’\t\tresp, err := client.GetStatus(ctx, &pb.GetStatusRequest{RunId: runID})\n    37â†’\t\tcancel()\n    38â†’\n    39â†’\t\tif err != nil {\n    40â†’\t\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n    41â†’\t\t\tos.Exit(1)\n    42â†’\t\t}\n    43â†’\n    44â†’\t\t// Print new step events\n    45â†’\t\tfor i := lastStepCount; i < len(resp.StepExecutions); i++ {\n    46â†’\t\t\texec := resp.StepExecutions[i]\n    47â†’\t\t\tts := time.Now().Format(\"15:04:05\")\n    48â†’\t\t\tif exec.Result == \"\" {\n    49â†’\t\t\t\tfmt.Printf(\"[%s] Step %q started\\n\", ts, exec.StepName)\n    50â†’\t\t\t} else {\n    51â†’\t\t\t\tfmt.Printf(\"[%s] Step %q completed: %s\\n\", ts, exec.StepName, exec.Result)\n    52â†’\t\t\t}\n    53â†’\t\t}\n    54â†’\t\tlastStepCount = len(resp.StepExecutions)\n    55â†’\n    56â†’\t\t// Print state changes\n    57â†’\t\tif resp.State != lastState {\n    58â†’\t\t\tts := time.Now().Format(\"15:04:05\")\n    59â†’\t\t\tfmt.Printf(\"[%s] Run %s is %s\\n\", ts, runID, resp.State)\n    60â†’\t\t\tlastState = resp.State\n    61â†’\t\t}\n    62â†’\n    63â†’\t\t// Check terminal states\n    64â†’\t\tswitch resp.State {\n    65â†’\t\tcase \"succeeded\":\n    66â†’\t\t\tos.Exit(0)\n    67â†’\t\tcase \"failed\", \"cancelled\":\n    68â†’\t\t\tif resp.ErrorMessage != \"\" {\n    69â†’\t\t\t\tfmt.Fprintf(os.Stderr, \"Error: %s\\n\", resp.ErrorMessage)\n    70â†’\t\t\t}\n    71â†’\t\t\tos.Exit(1)\n    72â†’\t\t}\n    73â†’\n    74â†’\t\t// Check container death\n    75â†’\t\tif !resp.ContainerAlive && resp.ContainerDeadSince != \"\" {\n    76â†’\t\t\tdeadSince, err := time.Parse(time.RFC3339Nano, resp.ContainerDeadSince)\n    77â†’\t\t\tif err == nil && time.Since(deadSince) > containerDeadThreshold {\n    78â†’\t\t\t\tfmt.Fprintf(os.Stderr, \"[%s] Container has been dead for >1 minute (since %s)\\n\",\n    79â†’\t\t\t\t\ttime.Now().Format(\"15:04:05\"), deadSince.Format(\"15:04:05\"))\n    80â†’\t\t\t\tos.Exit(1)\n    81â†’\t\t\t}\n    82â†’\t\t}\n    83â†’\n    84â†’\t\ttime.Sleep(pollInterval)\n    85â†’\t}\n    86â†’}\n    87â†’\n    88â†’// isTerminalState returns true if the run state is a terminal state.\n    89â†’func isTerminalState(state string) bool {\n    90â†’\tswitch state {\n    91â†’\tcase \"succeeded\", \"failed\", \"cancelled\":\n    92â†’\t\treturn true\n    93â†’\t}\n    94â†’\treturn false\n    95â†’}\n    96â†’\n    97â†’// cmdPollMulti polls multiple runs and displays a compact status summary.\n    98â†’// Returns 0 if all runs succeeded, 1 if any failed or were cancelled.\n    99â†’func cmdPollMulti(client pb.ClocheServiceClient, runIDs []string, stdout, stderr io.Writer) int {\n   100â†’\tpollInterval := 2 * time.Second\n   101â†’\tstates := make(map[string]string, len(runIDs))\n   102â†’\n   103â†’\tfor {\n   104â†’\t\tchanged := false\n   105â†’\t\tfor _, id := range runIDs {\n   106â†’\t\t\tif isTerminalState(states[id]) {\n   107â†’\t\t\t\tcontinue\n   108â†’\t\t\t}\n   109â†’\n   110â†’\t\t\tctx, cancel := context.WithTimeout(context.Background(), 10*time.Second)\n   111â†’\t\t\tresp, err := client.GetStatus(ctx, &pb.GetStatusRequest{RunId: id})\n   112â†’\t\t\tcancel()\n   113â†’\n   114â†’\t\t\tif err != nil {\n   115â†’\t\t\t\tfmt.Fprintf(stderr, \"error polling %s: %v\\n\", id, err)\n   116â†’\t\t\t\tstates[id] = \"error\"\n   117â†’\t\t\t\tchanged = true\n   118â†’\t\t\t\tcontinue\n   119â†’\t\t\t}\n   120â†’\n   121â†’\t\t\tif resp.State != states[id] {\n   122â†’\t\t\t\tstates[id] = resp.State\n   123â†’\t\t\t\tchanged = true\n   124â†’\t\t\t}\n   125â†’\t\t}\n   126â†’\n   127â†’\t\tif changed {\n   128â†’\t\t\tfor _, id := range runIDs {\n   129â†’\t\t\t\tfmt.Fprintf(stdout, \"%s: %s\\n\", id, states[id])\n   130â†’\t\t\t}\n   131â†’\t\t\tfmt.Fprintln(stdout)\n   132â†’\t\t}\n   133â†’\n   134â†’\t\t// Check if all runs are in terminal states\n   135â†’\t\tallDone := true\n   136â†’\t\tfor _, id := range runIDs {\n   137â†’\t\t\tif !isTerminalState(states[id]) && states[id] != \"error\" {\n   138â†’\t\t\t\tallDone = false\n   139â†’\t\t\t\tbreak\n   140â†’\t\t\t}\n   141â†’\t\t}\n   142â†’\n   143â†’\t\tif allDone {\n   144â†’\t\t\tfor _, id := range runIDs {\n   145â†’\t\t\t\ts := states[id]\n   146â†’\t\t\t\tif s != \"succeeded\" {\n   147â†’\t\t\t\t\treturn 1\n   148â†’\t\t\t\t}\n   149â†’\t\t\t}\n   150â†’\t\t\treturn 0\n   151â†’\t\t}\n   152â†’\n   153â†’\t\ttime.Sleep(pollInterval)\n   154â†’\t}\n   155â†’}\n   156â†’"}]},"parent_tool_use_id":null,"session_id":"4f4a76a6-d5ff-4a04-aa47-bd20b66a7dff","uuid":"61a27b56-33b6-4c06-b6d7-6dd8bea616b7","tool_use_result":{"type":"text","file":{"filePath":"/workspace/cmd/cloche/poll.go","content":"package main\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"io\"\n\t\"os\"\n\t\"time\"\n\n\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n)\n\nfunc cmdPoll(client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche poll <run-id> [run-id...]\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tif len(args) == 1 {\n\t\tcmdPollSingle(client, args[0])\n\t} else {\n\t\texitCode := cmdPollMulti(client, args, os.Stdout, os.Stderr)\n\t\tos.Exit(exitCode)\n\t}\n}\n\nfunc cmdPollSingle(client pb.ClocheServiceClient, runID string) {\n\tpollInterval := 2 * time.Second\n\tcontainerDeadThreshold := 1 * time.Minute\n\n\tvar lastStepCount int\n\tvar lastState string\n\n\tfor {\n\t\tctx, cancel := context.WithTimeout(context.Background(), 10*time.Second)\n\t\tresp, err := client.GetStatus(ctx, &pb.GetStatusRequest{RunId: runID})\n\t\tcancel()\n\n\t\tif err != nil {\n\t\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\t\tos.Exit(1)\n\t\t}\n\n\t\t// Print new step events\n\t\tfor i := lastStepCount; i < len(resp.StepExecutions); i++ {\n\t\t\texec := resp.StepExecutions[i]\n\t\t\tts := time.Now().Format(\"15:04:05\")\n\t\t\tif exec.Result == \"\" {\n\t\t\t\tfmt.Printf(\"[%s] Step %q started\\n\", ts, exec.StepName)\n\t\t\t} else {\n\t\t\t\tfmt.Printf(\"[%s] Step %q completed: %s\\n\", ts, exec.StepName, exec.Result)\n\t\t\t}\n\t\t}\n\t\tlastStepCount = len(resp.StepExecutions)\n\n\t\t// Print state changes\n\t\tif resp.State != lastState {\n\t\t\tts := time.Now().Format(\"15:04:05\")\n\t\t\tfmt.Printf(\"[%s] Run %s is %s\\n\", ts, runID, resp.State)\n\t\t\tlastState = resp.State\n\t\t}\n\n\t\t// Check terminal states\n\t\tswitch resp.State {\n\t\tcase \"succeeded\":\n\t\t\tos.Exit(0)\n\t\tcase \"failed\", \"cancelled\":\n\t\t\tif resp.ErrorMessage != \"\" {\n\t\t\t\tfmt.Fprintf(os.Stderr, \"Error: %s\\n\", resp.ErrorMessage)\n\t\t\t}\n\t\t\tos.Exit(1)\n\t\t}\n\n\t\t// Check container death\n\t\tif !resp.ContainerAlive && resp.ContainerDeadSince != \"\" {\n\t\t\tdeadSince, err := time.Parse(time.RFC3339Nano, resp.ContainerDeadSince)\n\t\t\tif err == nil && time.Since(deadSince) > containerDeadThreshold {\n\t\t\t\tfmt.Fprintf(os.Stderr, \"[%s] Container has been dead for >1 minute (since %s)\\n\",\n\t\t\t\t\ttime.Now().Format(\"15:04:05\"), deadSince.Format(\"15:04:05\"))\n\t\t\t\tos.Exit(1)\n\t\t\t}\n\t\t}\n\n\t\ttime.Sleep(pollInterval)\n\t}\n}\n\n// isTerminalState returns true if the run state is a terminal state.\nfunc isTerminalState(state string) bool {\n\tswitch state {\n\tcase \"succeeded\", \"failed\", \"cancelled\":\n\t\treturn true\n\t}\n\treturn false\n}\n\n// cmdPollMulti polls multiple runs and displays a compact status summary.\n// Returns 0 if all runs succeeded, 1 if any failed or were cancelled.\nfunc cmdPollMulti(client pb.ClocheServiceClient, runIDs []string, stdout, stderr io.Writer) int {\n\tpollInterval := 2 * time.Second\n\tstates := make(map[string]string, len(runIDs))\n\n\tfor {\n\t\tchanged := false\n\t\tfor _, id := range runIDs {\n\t\t\tif isTerminalState(states[id]) {\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tctx, cancel := context.WithTimeout(context.Background(), 10*time.Second)\n\t\t\tresp, err := client.GetStatus(ctx, &pb.GetStatusRequest{RunId: id})\n\t\t\tcancel()\n\n\t\t\tif err != nil {\n\t\t\t\tfmt.Fprintf(stderr, \"error polling %s: %v\\n\", id, err)\n\t\t\t\tstates[id] = \"error\"\n\t\t\t\tchanged = true\n\t\t\t\tcontinue\n\t\t\t}\n\n\t\t\tif resp.State != states[id] {\n\t\t\t\tstates[id] = resp.State\n\t\t\t\tchanged = true\n\t\t\t}\n\t\t}\n\n\t\tif changed {\n\t\t\tfor _, id := range runIDs {\n\t\t\t\tfmt.Fprintf(stdout, \"%s: %s\\n\", id, states[id])\n\t\t\t}\n\t\t\tfmt.Fprintln(stdout)\n\t\t}\n\n\t\t// Check if all runs are in terminal states\n\t\tallDone := true\n\t\tfor _, id := range runIDs {\n\t\t\tif !isTerminalState(states[id]) && states[id] != \"error\" {\n\t\t\t\tallDone = false\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\n\t\tif allDone {\n\t\t\tfor _, id := range runIDs {\n\t\t\t\ts := states[id]\n\t\t\t\tif s != \"succeeded\" {\n\t\t\t\t\treturn 1\n\t\t\t\t}\n\t\t\t}\n\t\t\treturn 0\n\t\t}\n\n\t\ttime.Sleep(pollInterval)\n\t}\n}\n","numLines":156,"startLine":1,"totalLines":156}}}
