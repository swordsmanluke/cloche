{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WSAq7zNboN6BDWLVgJBC4F","type":"tool_result","content":"     1â†’package main\n     2â†’\n     3â†’import (\n     4â†’\t\"bytes\"\n     5â†’\t\"context\"\n     6â†’\t\"fmt\"\n     7â†’\t\"strings\"\n     8â†’\t\"sync\"\n     9â†’\t\"testing\"\n    10â†’\n    11â†’\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    12â†’\t\"google.golang.org/grpc\"\n    13â†’)\n    14â†’\n    15â†’// mockClocheClient implements pb.ClocheServiceClient for testing poll logic.\n    16â†’type mockClocheClient struct {\n    17â†’\tpb.ClocheServiceClient\n    18â†’\n    19â†’\tmu        sync.Mutex\n    20â†’\tstatuses  map[string][]*pb.GetStatusResponse\n    21â†’\tcallCount map[string]int\n    22â†’}\n    23â†’\n    24â†’func newMockClient() *mockClocheClient {\n    25â†’\treturn &mockClocheClient{\n    26â†’\t\tstatuses:  make(map[string][]*pb.GetStatusResponse),\n    27â†’\t\tcallCount: make(map[string]int),\n    28â†’\t}\n    29â†’}\n    30â†’\n    31â†’func (m *mockClocheClient) GetStatus(_ context.Context, req *pb.GetStatusRequest, _ ...grpc.CallOption) (*pb.GetStatusResponse, error) {\n    32â†’\tm.mu.Lock()\n    33â†’\tdefer m.mu.Unlock()\n    34â†’\n    35â†’\tresps, ok := m.statuses[req.RunId]\n    36â†’\tif !ok {\n    37â†’\t\treturn nil, fmt.Errorf(\"unknown run: %s\", req.RunId)\n    38â†’\t}\n    39â†’\n    40â†’\tidx := m.callCount[req.RunId]\n    41â†’\tif idx >= len(resps) {\n    42â†’\t\tidx = len(resps) - 1\n    43â†’\t}\n    44â†’\tm.callCount[req.RunId] = idx + 1\n    45â†’\n    46â†’\treturn resps[idx], nil\n    47â†’}\n    48â†’\n    49â†’func TestIsTerminalState(t *testing.T) {\n    50â†’\ttests := []struct {\n    51â†’\t\tstate string\n    52â†’\t\twant  bool\n    53â†’\t}{\n    54â†’\t\t{\"succeeded\", true},\n    55â†’\t\t{\"failed\", true},\n    56â†’\t\t{\"cancelled\", true},\n    57â†’\t\t{\"running\", false},\n    58â†’\t\t{\"pending\", false},\n    59â†’\t\t{\"\", false},\n    60â†’\t}\n    61â†’\n    62â†’\tfor _, tt := range tests {\n    63â†’\t\tgot := isTerminalState(tt.state)\n    64â†’\t\tif got != tt.want {\n    65â†’\t\t\tt.Errorf(\"isTerminalState(%q) = %v, want %v\", tt.state, got, tt.want)\n    66â†’\t\t}\n    67â†’\t}\n    68â†’}\n    69â†’\n    70â†’func TestCmdPollMulti_AllSucceeded(t *testing.T) {\n    71â†’\tclient := newMockClient()\n    72â†’\tclient.statuses[\"run1\"] = []*pb.GetStatusResponse{\n    73â†’\t\t{RunId: \"run1\", State: \"running\"},\n    74â†’\t\t{RunId: \"run1\", State: \"succeeded\"},\n    75â†’\t}\n    76â†’\tclient.statuses[\"run2\"] = []*pb.GetStatusResponse{\n    77â†’\t\t{RunId: \"run2\", State: \"running\"},\n    78â†’\t\t{RunId: \"run2\", State: \"running\"},\n    79â†’\t\t{RunId: \"run2\", State: \"succeeded\"},\n    80â†’\t}\n    81â†’\n    82â†’\tvar stdout, stderr bytes.Buffer\n    83â†’\texitCode := cmdPollMulti(client, []string{\"run1\", \"run2\"}, &stdout, &stderr)\n    84â†’\n    85â†’\tif exitCode != 0 {\n    86â†’\t\tt.Errorf(\"expected exit code 0, got %d\", exitCode)\n    87â†’\t}\n    88â†’\n    89â†’\toutput := stdout.String()\n    90â†’\tif !strings.Contains(output, \"run1: \") {\n    91â†’\t\tt.Error(\"output should contain status for run1\")\n    92â†’\t}\n    93â†’\tif !strings.Contains(output, \"run2: \") {\n    94â†’\t\tt.Error(\"output should contain status for run2\")\n    95â†’\t}\n    96â†’\tif !strings.Contains(output, \"succeeded\") {\n    97â†’\t\tt.Error(\"output should show succeeded state\")\n    98â†’\t}\n    99â†’}\n   100â†’\n   101â†’func TestCmdPollMulti_OneFailed(t *testing.T) {\n   102â†’\tclient := newMockClient()\n   103â†’\tclient.statuses[\"run1\"] = []*pb.GetStatusResponse{\n   104â†’\t\t{RunId: \"run1\", State: \"succeeded\"},\n   105â†’\t}\n   106â†’\tclient.statuses[\"run2\"] = []*pb.GetStatusResponse{\n   107â†’\t\t{RunId: \"run2\", State: \"failed\"},\n   108â†’\t}\n   109â†’\n   110â†’\tvar stdout, stderr bytes.Buffer\n   111â†’\texitCode := cmdPollMulti(client, []string{\"run1\", \"run2\"}, &stdout, &stderr)\n   112â†’\n   113â†’\tif exitCode != 1 {\n   114â†’\t\tt.Errorf(\"expected exit code 1 when a run failed, got %d\", exitCode)\n   115â†’\t}\n   116â†’}\n   117â†’\n   118â†’func TestCmdPollMulti_OneCancelled(t *testing.T) {\n   119â†’\tclient := newMockClient()\n   120â†’\tclient.statuses[\"run1\"] = []*pb.GetStatusResponse{\n   121â†’\t\t{RunId: \"run1\", State: \"succeeded\"},\n   122â†’\t}\n   123â†’\tclient.statuses[\"run2\"] = []*pb.GetStatusResponse{\n   124â†’\t\t{RunId: \"run2\", State: \"cancelled\"},\n   125â†’\t}\n   126â†’\n   127â†’\tvar stdout, stderr bytes.Buffer\n   128â†’\texitCode := cmdPollMulti(client, []string{\"run1\", \"run2\"}, &stdout, &stderr)\n   129â†’\n   130â†’\tif exitCode != 1 {\n   131â†’\t\tt.Errorf(\"expected exit code 1 when a run was cancelled, got %d\", exitCode)\n   132â†’\t}\n   133â†’}\n   134â†’\n   135â†’func TestCmdPollMulti_ErrorState(t *testing.T) {\n   136â†’\tclient := newMockClient()\n   137â†’\tclient.statuses[\"run1\"] = []*pb.GetStatusResponse{\n   138â†’\t\t{RunId: \"run1\", State: \"succeeded\"},\n   139â†’\t}\n   140â†’\t// run2 is not in the mock, so GetStatus returns an error\n   141â†’\n   142â†’\tvar stdout, stderr bytes.Buffer\n   143â†’\texitCode := cmdPollMulti(client, []string{\"run1\", \"run2\"}, &stdout, &stderr)\n   144â†’\n   145â†’\tif exitCode != 1 {\n   146â†’\t\tt.Errorf(\"expected exit code 1 when a run has error, got %d\", exitCode)\n   147â†’\t}\n   148â†’\terrOutput := stderr.String()\n   149â†’\tif !strings.Contains(errOutput, \"error polling run2\") {\n   150â†’\t\tt.Errorf(\"expected error message for run2, got: %s\", errOutput)\n   151â†’\t}\n   152â†’}\n   153â†’\n   154â†’func TestCmdPollMulti_OutputFormat(t *testing.T) {\n   155â†’\tclient := newMockClient()\n   156â†’\tclient.statuses[\"aaa\"] = []*pb.GetStatusResponse{\n   157â†’\t\t{RunId: \"aaa\", State: \"running\"},\n   158â†’\t\t{RunId: \"aaa\", State: \"succeeded\"},\n   159â†’\t}\n   160â†’\tclient.statuses[\"bbb\"] = []*pb.GetStatusResponse{\n   161â†’\t\t{RunId: \"bbb\", State: \"succeeded\"},\n   162â†’\t}\n   163â†’\n   164â†’\tvar stdout, stderr bytes.Buffer\n   165â†’\t_ = cmdPollMulti(client, []string{\"aaa\", \"bbb\"}, &stdout, &stderr)\n   166â†’\n   167â†’\toutput := stdout.String()\n   168â†’\tlines := strings.Split(strings.TrimSpace(output), \"\\n\")\n   169â†’\tfoundOrder := false\n   170â†’\tfor i, line := range lines {\n   171â†’\t\tif strings.HasPrefix(line, \"aaa: \") && i+1 < len(lines) && strings.HasPrefix(lines[i+1], \"bbb: \") {\n   172â†’\t\t\tfoundOrder = true\n   173â†’\t\t\tbreak\n   174â†’\t\t}\n   175â†’\t}\n   176â†’\tif !foundOrder {\n   177â†’\t\tt.Errorf(\"expected runs to be printed in argument order (aaa then bbb), got:\\n%s\", output)\n   178â†’\t}\n   179â†’}\n   180â†’\n   181â†’func TestCmdPollMulti_OnlyPrintsOnChange(t *testing.T) {\n   182â†’\tclient := newMockClient()\n   183â†’\t// Two polls with same state, then terminal\n   184â†’\tclient.statuses[\"run1\"] = []*pb.GetStatusResponse{\n   185â†’\t\t{RunId: \"run1\", State: \"running\"},\n   186â†’\t\t{RunId: \"run1\", State: \"running\"},\n   187â†’\t\t{RunId: \"run1\", State: \"succeeded\"},\n   188â†’\t}\n   189â†’\n   190â†’\tvar stdout, stderr bytes.Buffer\n   191â†’\t_ = cmdPollMulti(client, []string{\"run1\"}, &stdout, &stderr)\n   192â†’\n   193â†’\toutput := stdout.String()\n   194â†’\tcount := strings.Count(output, \"run1: running\")\n   195â†’\tif count != 1 {\n   196â†’\t\tt.Errorf(\"expected 'run1: running' to appear once (only on change), appeared %d times in:\\n%s\", count, output)\n   197â†’\t}\n   198â†’}\n   199â†’\n   200â†’func TestPollHelpText(t *testing.T) {\n   201â†’\ttext, ok := subcommandHelp[\"poll\"]\n   202â†’\tif !ok {\n   203â†’\t\tt.Fatal(\"missing help text for poll subcommand\")\n   204â†’\t}\n   205â†’\tif !strings.Contains(text, \"run-id...\") {\n   206â†’\t\tt.Error(\"poll help should mention multiple run IDs\")\n   207â†’\t}\n   208â†’\tif !strings.Contains(text, \"multiple\") {\n   209â†’\t\tt.Error(\"poll help should describe multiple ID behavior\")\n   210â†’\t}\n   211â†’}\n   212â†’"}]},"parent_tool_use_id":null,"session_id":"4f4a76a6-d5ff-4a04-aa47-bd20b66a7dff","uuid":"18f45f05-79e0-40a9-87c4-f802c9d3f711","tool_use_result":{"type":"text","file":{"filePath":"/workspace/cmd/cloche/poll_test.go","content":"package main\n\nimport (\n\t\"bytes\"\n\t\"context\"\n\t\"fmt\"\n\t\"strings\"\n\t\"sync\"\n\t\"testing\"\n\n\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n\t\"google.golang.org/grpc\"\n)\n\n// mockClocheClient implements pb.ClocheServiceClient for testing poll logic.\ntype mockClocheClient struct {\n\tpb.ClocheServiceClient\n\n\tmu        sync.Mutex\n\tstatuses  map[string][]*pb.GetStatusResponse\n\tcallCount map[string]int\n}\n\nfunc newMockClient() *mockClocheClient {\n\treturn &mockClocheClient{\n\t\tstatuses:  make(map[string][]*pb.GetStatusResponse),\n\t\tcallCount: make(map[string]int),\n\t}\n}\n\nfunc (m *mockClocheClient) GetStatus(_ context.Context, req *pb.GetStatusRequest, _ ...grpc.CallOption) (*pb.GetStatusResponse, error) {\n\tm.mu.Lock()\n\tdefer m.mu.Unlock()\n\n\tresps, ok := m.statuses[req.RunId]\n\tif !ok {\n\t\treturn nil, fmt.Errorf(\"unknown run: %s\", req.RunId)\n\t}\n\n\tidx := m.callCount[req.RunId]\n\tif idx >= len(resps) {\n\t\tidx = len(resps) - 1\n\t}\n\tm.callCount[req.RunId] = idx + 1\n\n\treturn resps[idx], nil\n}\n\nfunc TestIsTerminalState(t *testing.T) {\n\ttests := []struct {\n\t\tstate string\n\t\twant  bool\n\t}{\n\t\t{\"succeeded\", true},\n\t\t{\"failed\", true},\n\t\t{\"cancelled\", true},\n\t\t{\"running\", false},\n\t\t{\"pending\", false},\n\t\t{\"\", false},\n\t}\n\n\tfor _, tt := range tests {\n\t\tgot := isTerminalState(tt.state)\n\t\tif got != tt.want {\n\t\t\tt.Errorf(\"isTerminalState(%q) = %v, want %v\", tt.state, got, tt.want)\n\t\t}\n\t}\n}\n\nfunc TestCmdPollMulti_AllSucceeded(t *testing.T) {\n\tclient := newMockClient()\n\tclient.statuses[\"run1\"] = []*pb.GetStatusResponse{\n\t\t{RunId: \"run1\", State: \"running\"},\n\t\t{RunId: \"run1\", State: \"succeeded\"},\n\t}\n\tclient.statuses[\"run2\"] = []*pb.GetStatusResponse{\n\t\t{RunId: \"run2\", State: \"running\"},\n\t\t{RunId: \"run2\", State: \"running\"},\n\t\t{RunId: \"run2\", State: \"succeeded\"},\n\t}\n\n\tvar stdout, stderr bytes.Buffer\n\texitCode := cmdPollMulti(client, []string{\"run1\", \"run2\"}, &stdout, &stderr)\n\n\tif exitCode != 0 {\n\t\tt.Errorf(\"expected exit code 0, got %d\", exitCode)\n\t}\n\n\toutput := stdout.String()\n\tif !strings.Contains(output, \"run1: \") {\n\t\tt.Error(\"output should contain status for run1\")\n\t}\n\tif !strings.Contains(output, \"run2: \") {\n\t\tt.Error(\"output should contain status for run2\")\n\t}\n\tif !strings.Contains(output, \"succeeded\") {\n\t\tt.Error(\"output should show succeeded state\")\n\t}\n}\n\nfunc TestCmdPollMulti_OneFailed(t *testing.T) {\n\tclient := newMockClient()\n\tclient.statuses[\"run1\"] = []*pb.GetStatusResponse{\n\t\t{RunId: \"run1\", State: \"succeeded\"},\n\t}\n\tclient.statuses[\"run2\"] = []*pb.GetStatusResponse{\n\t\t{RunId: \"run2\", State: \"failed\"},\n\t}\n\n\tvar stdout, stderr bytes.Buffer\n\texitCode := cmdPollMulti(client, []string{\"run1\", \"run2\"}, &stdout, &stderr)\n\n\tif exitCode != 1 {\n\t\tt.Errorf(\"expected exit code 1 when a run failed, got %d\", exitCode)\n\t}\n}\n\nfunc TestCmdPollMulti_OneCancelled(t *testing.T) {\n\tclient := newMockClient()\n\tclient.statuses[\"run1\"] = []*pb.GetStatusResponse{\n\t\t{RunId: \"run1\", State: \"succeeded\"},\n\t}\n\tclient.statuses[\"run2\"] = []*pb.GetStatusResponse{\n\t\t{RunId: \"run2\", State: \"cancelled\"},\n\t}\n\n\tvar stdout, stderr bytes.Buffer\n\texitCode := cmdPollMulti(client, []string{\"run1\", \"run2\"}, &stdout, &stderr)\n\n\tif exitCode != 1 {\n\t\tt.Errorf(\"expected exit code 1 when a run was cancelled, got %d\", exitCode)\n\t}\n}\n\nfunc TestCmdPollMulti_ErrorState(t *testing.T) {\n\tclient := newMockClient()\n\tclient.statuses[\"run1\"] = []*pb.GetStatusResponse{\n\t\t{RunId: \"run1\", State: \"succeeded\"},\n\t}\n\t// run2 is not in the mock, so GetStatus returns an error\n\n\tvar stdout, stderr bytes.Buffer\n\texitCode := cmdPollMulti(client, []string{\"run1\", \"run2\"}, &stdout, &stderr)\n\n\tif exitCode != 1 {\n\t\tt.Errorf(\"expected exit code 1 when a run has error, got %d\", exitCode)\n\t}\n\terrOutput := stderr.String()\n\tif !strings.Contains(errOutput, \"error polling run2\") {\n\t\tt.Errorf(\"expected error message for run2, got: %s\", errOutput)\n\t}\n}\n\nfunc TestCmdPollMulti_OutputFormat(t *testing.T) {\n\tclient := newMockClient()\n\tclient.statuses[\"aaa\"] = []*pb.GetStatusResponse{\n\t\t{RunId: \"aaa\", State: \"running\"},\n\t\t{RunId: \"aaa\", State: \"succeeded\"},\n\t}\n\tclient.statuses[\"bbb\"] = []*pb.GetStatusResponse{\n\t\t{RunId: \"bbb\", State: \"succeeded\"},\n\t}\n\n\tvar stdout, stderr bytes.Buffer\n\t_ = cmdPollMulti(client, []string{\"aaa\", \"bbb\"}, &stdout, &stderr)\n\n\toutput := stdout.String()\n\tlines := strings.Split(strings.TrimSpace(output), \"\\n\")\n\tfoundOrder := false\n\tfor i, line := range lines {\n\t\tif strings.HasPrefix(line, \"aaa: \") && i+1 < len(lines) && strings.HasPrefix(lines[i+1], \"bbb: \") {\n\t\t\tfoundOrder = true\n\t\t\tbreak\n\t\t}\n\t}\n\tif !foundOrder {\n\t\tt.Errorf(\"expected runs to be printed in argument order (aaa then bbb), got:\\n%s\", output)\n\t}\n}\n\nfunc TestCmdPollMulti_OnlyPrintsOnChange(t *testing.T) {\n\tclient := newMockClient()\n\t// Two polls with same state, then terminal\n\tclient.statuses[\"run1\"] = []*pb.GetStatusResponse{\n\t\t{RunId: \"run1\", State: \"running\"},\n\t\t{RunId: \"run1\", State: \"running\"},\n\t\t{RunId: \"run1\", State: \"succeeded\"},\n\t}\n\n\tvar stdout, stderr bytes.Buffer\n\t_ = cmdPollMulti(client, []string{\"run1\"}, &stdout, &stderr)\n\n\toutput := stdout.String()\n\tcount := strings.Count(output, \"run1: running\")\n\tif count != 1 {\n\t\tt.Errorf(\"expected 'run1: running' to appear once (only on change), appeared %d times in:\\n%s\", count, output)\n\t}\n}\n\nfunc TestPollHelpText(t *testing.T) {\n\ttext, ok := subcommandHelp[\"poll\"]\n\tif !ok {\n\t\tt.Fatal(\"missing help text for poll subcommand\")\n\t}\n\tif !strings.Contains(text, \"run-id...\") {\n\t\tt.Error(\"poll help should mention multiple run IDs\")\n\t}\n\tif !strings.Contains(text, \"multiple\") {\n\t\tt.Error(\"poll help should describe multiple ID behavior\")\n\t}\n}\n","numLines":212,"startLine":1,"totalLines":212}}}
