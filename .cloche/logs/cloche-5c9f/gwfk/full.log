n    65→\n    66→\t\tif base == \"host.cloche\" {\n    67→\t\t\twfs, err := dsl.ParseAllForHost(string(data))\n    68→\t\t\tif err != nil {\n    69→\t\t\t\tcontinue\n    70→\t\t\t}\n    71→\t\t\tfor name := range wfs {\n    72→\t\t\t\tinfos = append(infos, workflowInfo{name: name, location: domain.LocationHost})\n    73→\t\t\t}\n    74→\t\t} else {\n    75→\t\t\twf, err := dsl.ParseForContainer(string(data))\n    76→\t\t\tif err != nil {\n    77→\t\t\t\tcontinue\n    78→\t\t\t}\n    79→\t\t\tinfos = append(infos, workflowInfo{name: wf.Name, location: domain.LocationContainer})\n    80→\t\t}\n    81→\t}\n    82→\n    83→\treturn infos, nil\n    84→}\n    85→\n    86→func listWorkflows(projectDir string) {\n    87→\tinfos, err := discoverWorkflows(projectDir)\n    88→\tif err != nil {\n    89→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n    90→\t\tos.Exit(1)\n    91→\t}\n    92→\n    93→\tif len(infos) == 0 {\n    94→\t\tfmt.Println(\"No workflows found.\")\n    95→\t\treturn\n    96→\t}\n    97→\n    98→\tvar container, host []string\n    99→\tfor _, info := range infos {\n   100→\t\tswitch info.location {"}]},"parent_tool_use_id":"toolu_01L7Q8736ghtGeweygdvyqX8","session_id":"ac30b052-9a54-423a-a143-d93519242f61","uuid":"ef9dd955-1809-43f7-a3d7-6c4f009bf9ab"}
