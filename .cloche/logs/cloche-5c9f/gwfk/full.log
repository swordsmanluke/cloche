ning\" appears - should be once (no duplicate on same state)\n\tcount := strings.Count(output, \"run1: running\")\n\tif count != 1 {\n\t\tt.Errorf(\"expected 'run1: running' to appear once (only on change), appeared %d times in:\\n%s\", count, output)\n\t}\n}\n\nfunc TestPollHelpText(t *testing.T) {\n\ttext, ok := subcommandHelp[\"poll\"]\n\tif !ok {\n\t\tt.Fatal(\"missing help text for poll subcommand\")\n\t}\n\tif !strings.Contains(text, \"run-id...\") {\n\t\tt.Error(\"poll help should mention multiple run IDs\")\n\t}\n\tif !strings.Contains(text, \"multiple\") {\n\t\tt.Error(\"poll help should describe multiple ID behavior\")\n\t}\n}\n\n// capturedOutput holds the original writer and captured buffer.\ntype capturedOutput struct {\n\tbuf     *bytes.Buffer\n\trestore func() string\n}\n\nfunc captureStdout(t *testing.T) *capturedOutput {\n\tt.Helper()\n\tr, w, err := pipePair()\n\tif err != nil {\n\t\tt.Fatal(err)\n\t}\n\torigStdout := osStdout\n\tosStdout = w\n\tbuf := &bytes.Buffer{}\n\treturn &capturedOutput{\n\t\tbuf: buf,\n\t\trestore: func() string {\n\t\t\tw.Close()\n\t\t\tbuf.ReadFrom(r)\n\t\t\tr.Close()\n\t\t\tosStdout = origStdout\n\t\t\treturn buf.String()\n\t\t},\n\t}\n}\n\nfunc captureStderr(t *testing.T) *capturedOutput {\n\tt.Helper()\n\tr, w, err := pipePair()\n\tif err != nil {\n\t\tt.Fatal(err)\n\t}\n\torigStderr := osStderr\n\tosStderr = w\n\tbuf := &bytes.Buffer{}\n\treturn &capturedOutput{\n\t\tbuf: buf,\n\t\trestore: func() string {\n\t\t\tw.Close()\n\t\t\tbuf.ReadFrom(r)\n\t\t\tr.Close()\n\t\t\tosStderr = origStderr\n\t\t\treturn buf.String()\n\t\t},\n\t}\n}\n","structuredPatch":[],"originalFile":null}}
