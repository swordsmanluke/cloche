ut := stdout.String()\n\tcount := strings.Count(output, \"run1: running\")\n\tif count != 1 {\n\t\tt.Errorf(\"expected 'run1: running' to appear once (only on change), appeared %d times in:\\n%s\", count, output)\n\t}\n}\n\nfunc TestPollHelpText(t *testing.T) {\n\ttext, ok := subcommandHelp[\"poll\"]\n\tif !ok {\n\t\tt.Fatal(\"missing help text for poll subcommand\")\n\t}\n\tif !strings.Contains(text, \"run-id...\") {\n\t\tt.Error(\"poll help should mention multiple run IDs\")\n\t}\n\tif !strings.Contains(text, \"multiple\") {\n\t\tt.Error(\"poll help should describe multiple ID behavior\")\n\t}\n}\n","structuredPatch":[{"oldStart":28,"oldLines":7,"newStart":28,"newLines":7,"lines":["   }"," }"," ","-func (m *mockClocheClient) GetStatus(ctx context.Context, req *pb.GetStatusRequest, opts ...grpc.CallOption) (*pb.GetStatusResponse, error) {","+func (m *mockClocheClient) GetStatus(_ context.Context, req *pb.GetStatusRequest, _ ...grpc.CallOption) (*pb.GetStatusResponse, error) {","   m.mu.Lock()","   defer m.mu.Unlock()"," "]},{"oldStart":79,"oldLines":16,"newStart":79,"newLines":14,"lines":["     {RunId: \"run2\", State: \"succeeded\"},","   }"," ","-  // Capture stdout","-  old := captureStdout(t)","-  exitCode := cmdPollMulti(client, []string{\"run1\", \"run2\"})","-  output := old.restore()","+  var stdout, stderr bytes.Buffer","+  exitCode := cmdPollMulti(client, []string{\"run1\", \"run2\"}, &stdout, &stderr)"," ","   if exitCode != 0 {","     t.Errorf(\"expected exit code 0, got %d\", exitCode)","   }"," ","-  // Should contain status lines for both runs","+  output := stdout.String()","   if !strings.Contains(output, \"run1: \") {","     t.Error(\"output should contain status for run1\")","   }"]},{"oldStart":109,"oldLines":8,"newStart":107,"newLines":8,"lines":["     {RunId: \"run2\", State: \"failed\"},","   }"," ","-  _ = captureStdout(t)","-  exitCode := cmdPollMulti(client, []string{\"run1\", \"run2\"})","+  var stdout, stderr bytes.Buffer","+  exitCode :