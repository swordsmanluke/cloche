tate)\n    64→\t\tif got != tt.want {\n    65→\t\t\tt.Errorf(\"isTerminalState(%q) = %v, want %v\", tt.state, got, tt.want)\n    66→\t\t}\n    67→\t}\n    68→}\n    69→\n    70→func TestCmdPollMulti_AllSucceeded(t *testing.T) {\n    71→\tclient := newMockClient()\n    72→\tclient.statuses[\"run1\"] = []*pb.GetStatusResponse{\n    73→\t\t{RunId: \"run1\", State: \"running\"},\n    74→\t\t{RunId: \"run1\", State: \"succeeded\"},\n    75→\t}\n    76→\tclient.statuses[\"run2\"] = []*pb.GetStatusResponse{\n    77→\t\t{RunId: \"run2\", State: \"running\"},\n    78→\t\t{RunId: \"run2\", State: \"running\"},\n    79→\t\t{RunId: \"run2\", State: \"succeeded\"},\n    80→\t}\n    81→\n    82→\tvar stdout, stderr bytes.Buffer\n    83→\texitCode := cmdPollMulti(client, []string{\"run1\", \"run2\"}, &stdout, &stderr)\n    84→\n    85→\tif exitCode != 0 {\n    86→\t\tt.Errorf(\"expected exit code 0, got %d\", exitCode)\n    87→\t}\n    88→\n    89→\toutput := stdout.String()\n    90→\tif !strings.Contains(output, \"run1: \") {\n    91→\t\tt.Error(\"output should contain status for run1\")\n    92→\t}\n    93→\tif !strings.Contains(output, \"run2: \") {\n    94→\t\tt.Error(\"output should contain status for run2\")\n    95→\t}\n    96→\tif !strings.Contains(output, \"succeeded\") {\n    97→\t\tt.Error(\"output should show succeeded state\")\n    98→\t}\n    99→}\n   100→\n   101→func TestCmdPollMulti_OneFailed(t *testing.T) {\n   102→\tclient := newMockClient()\n   103→\tclient.statuses[\"run1\"] = []*pb.GetStatusResponse{\n   104→\t\t{RunId: \"run1\", State: \"succeeded\"},\n   105→\t}\n   106→\tclient.statuses[\"run2\"] = []*pb.GetStatusResponse{\n   107→\t\t{RunId: \"run2\", State: \"failed\"},\n   108→\t}\n   109→\n   110→\tvar stdout, stderr bytes.Buffer\n   111→\texitCode := cmdPollMulti(client, []string{\"run1\", \"run2\"}, &stdout, &stderr)\n   112→\n   113→\tif exitCode != 1 {\n   114→\t\tt.Errorf(\"expected exit code 1 when a run failed, got %d\", exitCode)\n   115→\t}\n   116→}\n   117→\n   118→func TestCmdPollMulti_OneCancelled(t *testing.T) {\n   119→\tclient := newMockClient()\n   120→\tclient.statuses[\"run1\"] = []*pb.GetStatusResponse{\n   121→\t\t{RunId: \"run1\", State: \"succeeded\"},\n   122→\t}\n   123→\tclient.statuses[\"run2\"] = []*pb.GetStatusResponse{\n   124→\t\t{RunId: \"run2\", State: \"cancelled\"},\n   125→\t}\n   126→\n   127→\tvar stdout, stderr bytes.Buffer\n   128→\texitCode := cmdPollMulti(client, []string{\"run1\", \"run2\"}, &stdout, &stderr)\n   129→\n   130→\tif exitCode != 1 {\n   131→\t\tt.Errorf(\"expected exit code 1 when a run was cancelled, got %d\", exitCode)\n   132→\t}\n   133→}\n   134→\n   135→func TestCmdPollMulti_ErrorState(t *testing.T) {\n   136→\tclient := newMockClient()\n   137→\tclient.statuses[\"run1\"] = []*pb.GetStatusResponse{\n   138→\t\t{RunId: \"run1\", State: \"succeeded\"},\n   139→\t}\n   140→\t// run2 is not in the mock, so GetStatus returns an error\n   141→\n   142→\tvar stdout, stderr bytes.Buffer\n   143→\texitCode := cmdPollMulti(client, []string{\"run1\", \"run2\"}, &stdout, &stderr)\n   144→\n   145→\tif exitCode != 1 {\n   146→\t\tt.Errorf(\"expected exit code 1 when a run has error, got %d\", exitCode)\n   147→\t}\n   148→\terrOutput := stderr.String()\n   149→\tif !strings.Contains(errOutput, \"error polling run2\") {\n   150→\t\tt.Errorf(\"expected error message for run2, got: %s\", errOutput)\n   151→\t}\n   152→}\n   153→\n   154→func TestCmdPollMulti_OutputFormat(t *testing.T) {\n   155→\tclient := newMockClient()\n   156→\tclient.statuses[\"aaa\"] = []*pb.GetStatusResponse{\n   157→\t\t{RunId: \"aaa\", State: \"running\"},\n   158→\t\t{RunId: \"aaa\", State: \"succeeded\"},\n   159→\t}\n   160→\tclient.statuses[\"bbb\"] = []*pb.GetStatusResponse{\n   161→\t\t{RunId: \"bbb\", State: \"succeeded\"},\n   162→\t}\n   163→\n   164→\tvar stdout, stderr bytes.Buffer\n   165→\t_ = cmdPollMulti(client, []string{\"aaa\", \"bbb\"}, &stdout, &stderr)\n   166→\n   167→\toutput := stdout.String()\n   168→\tlines := strings.Split(strings.TrimSpace(output), \"\\n\")\n   169→\tfoundOrder := false\n   170→\tfor i, line := range lines {\n   171→\t\tif strings.HasPrefix(line, \"aaa: \") && i+1 < len(lines) && strings.HasPrefix(lines[i+1], \"bbb: \") {\n   172→\t\t\tfoundOrder = true\n   173→\t\t\tbreak\n   174→\t\t}\n   175→\t}\n   176→\tif !foundOrder {\n   177→\t\tt.Errorf(\"expected runs to be printed in argument order (aaa then bbb), got:\\n%s\", output)\n   178→\t}\n   179→}\n   180→\n   181→func TestCmdPollMulti_OnlyPrintsOnChange(t *testing.T) {\n   182→\tclient := newMockClient()\n   183→\t// Two polls with same state, then terminal\n   184→\tclient.statuses[\"run1\"] = []*pb.GetStatusResponse{\n   185→\t\t{RunId: \"run1\", State: \"running\"},\n   186→\t\t{RunId: \"run1\", State: \"running\"},\n   187→\t\t{RunId: \"run1\", State: \"succeeded\"},\n   188→\t}\n   189→\n   190→\tvar stdout, stderr bytes.Buffer\n   191→\t_ = cmdPollMulti(client, []string{\"run1\"}, &stdout, &stderr)\n   192→\n   193→\toutput := stdout.String()\n   194→\tcount := strings.Count(output, \"run1: running\")\n   195→\tif count != 1 {\n   196→\t\tt.Errorf(\"expected 'run1: running' to appear once (only on change), appeared %d times in:\\n%s\", count, output)\n   197→\t}\n   198→}\n   199→\n   200→func TestPollHelpText(t *testing.T) {\n   201→\ttext, ok := subcommandHelp[\"poll\"]\n   202→\tif !ok {\n   203→\t\tt.Fatal(\"missing help text for poll subcommand\")\n   204→\t}\n   205→\tif !strings.Contains(text, \"run-id...\") {\n   206→\t\tt.Error(\"poll help should mention multiple run IDs\")\n   207→\t}\n   208→\tif !strings.Contains(text, \"multiple\") {\n   209→\t\tt.Error(\"poll help should describe multiple ID behavior\")\n   210→\t}\n   211→}\n   212→"}]},"parent_tool_use_id":null,"session_id":"4f4a76a6-d5ff-4a04-aa47-bd20b66a7dff","uuid":"18f45f05-79e0-40a9-87c4-f802c9d3f711","tool_use_result":{"type":"text","file":{"filePath":"/workspace/cmd/cloche/poll_test.go","content":"package main\n\nimport (\n\t\"bytes\"\n\t\"context\"\n\t\"fmt\"\n\t\"strings\"\n\t\"sync\"\n\t\"testing\"\n\n\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n\t\"google.golang.org/grpc\"\n)\n\n// mockClocheClient implements pb.ClocheServiceClient for testing poll logic.\ntype mockClocheClient struct {\n\tpb.ClocheServiceClient\n\n\tmu        sync.Mutex\n\tstatuses  map[string][]*pb.GetStatusResponse\n\tcallCount map[string]int\n}\n\nfunc newMockClient() *mockClocheClient {\n\treturn &mockClocheClient{\n\t\tstatuses:  make(map[string][]*pb.GetStatusResponse),\n\t\tcallCount: make(map[string]int),\n\t}\n}\n\nfunc (m *mockClocheClient) GetStatus(_ context.Context, req *pb.GetStatusRequest, _ ...grpc.CallOption) (*pb.GetStatusResponse, error) {\n\tm.mu.Lock()\n\tdefer m.mu.Unlock()\n\n\tresps, ok := m.statuses[req.RunId]\n\tif !ok {\n\t\treturn nil, fmt.Errorf(\"unknown run: %s\", req.RunId)\n\t}\n\n\tidx := m.callCount[req.RunId]\n\tif idx >= len(resps) {\n\t\tidx = len(resps) - 1\n\t}\n\tm.callCount[req.RunId] = idx + 1\n\n\treturn resps[idx], nil\n}\n\nfunc TestIsTerminalState(t *testing.T) {\n\ttests := []struct {\n\t\tstate string\n\t\twant  bool\n\t}{\n\t\t{\"succeeded\", true},\n\t\t{\"failed\", true},\n\t\t{\"cancelled\", true},\n\t\t{\"running\", false},\n\t\t{\"pending\", false},\n\t\t{\"\", false},\n\t}\n\n\tfor _, tt := range tests {\n\t\tgot := isTerminalState(tt.state)\n\t\tif got != tt.want {\n\t\t\tt.Errorf(\"isTerminalState(%q) = %v, want %v\", tt.state, got, tt.want)\n\t\t}\n\t}\n}\n\nfunc TestCmdPollMulti_AllSucceeded(t *testing.T) {\n\tclient := newMockClient()\n\tclient.statuses[\"run1\"] = []*pb.GetStatusResponse{\n\t\t{RunId: \"run1\", State: \"running\"},\n\t\t{RunId: \"run1\", State: \"succeeded\"},\n\t}\n\tclient.statuses[\"run2\"] = []*pb.GetStatusResponse{\n\t\t{RunId: \"run2\", State: \"running\"},\n\t\t{RunId: \"run2\", State: \"running\"},\n\t\t{RunId: \"run2\", State: \"succeeded\"},\n\t}\n\n\tvar stdout, stderr bytes.Buffer\n\texitCode := cmdPollMulti(client, []string{\"run1\", \"run2\"}, &stdout, &stderr)\n\n\tif exitCode != 0 {\n\t\tt.Errorf(\"expected exit code 0, got %d\", exitCode)\n\t}\n\n\toutput := stdout.String()\n\tif !strings.Contains(output, \"run1: \") {\n\t\tt.Error(\"output should contain status for run1\")\n\t}\n\tif !strings.Contains(output, \"run2: \") {\n\t\tt.Error(\"output should contain status for run2\")\n\t}\n\tif !strings.Contains(output, \"succeeded\") {\n\t\tt.Error(\"output should show succeeded state\")\n\t}\n}\n\nfunc TestCmdPollMulti_OneFailed(t *testing.T) {\n\tclient := newMockClient()\n\tclient.statuses[\"run1\"] = []*pb.GetStatusResponse{\n\t\t{RunId: \"run1\", State: \"succeeded\"},\n\t}\n\tclient.statuses[\"run2\"] = []*pb.GetStatusResponse{\n\t\t{RunId: \"run2\", State: \"failed\"},\n\t}\n\n\tvar stdout, stderr bytes.Buffer\n\texitCode := cmdPollMulti(client, []string{\"run1\", \"run2\"}, &stdout, &stderr)\n\n\tif exitCode != 1 {\n\t\tt.Errorf(\"expected exit code 1 when a run failed, got %d\", exitCode)\n\t}\n}\n\nfunc TestCmdPollMulti_OneCancelled(t *testing.T) {\n\tclient := newMockClient()\n\tclient.statuses[\"run1\"] = []*pb.GetStatusResponse{\n\t\t{RunId: \"run1\", State: \"succeeded\"},\n\t}\n\tclient.statuses[\"run2\"] = []*pb.GetStatusResponse{\n\t\t{RunId: \"run2\", State: \"cancelled\"},\n\t}\n\n\tvar stdout, stderr bytes.Buffer\n\texitCode := cmdPollMulti(client, []string{\"run1\", \"run2\"}, &stdout, &stderr)\n\n\tif exitCode != 1 {\n\t\tt.Errorf(\"expected exit code 1 when a run was cancelled, got %d\", exitCode)\n\t}\n}\n\nfunc TestCmdPollMulti_ErrorState(t *testing.T) {\n\tclient := newMockClient()\n\tclient.statuses[\"run1\"] = []*pb.GetStatusResponse{\n\t\t{RunId: \"run1\", State: \"succeeded\"},\n\t}\n\t// run2 is not in the mock, so GetStatus returns an error\n\n\tvar stdout, stderr bytes.Buffer\n\texitCode := cmdPollMulti(client, []string{\"run1\", \"run2\"}, &stdout, &stderr)\n\n\tif exitCode != 1 {\n\t\tt.Errorf(\"expected exit code 1 when a run has error, got %d\", exitCode)\n\t}\n\terrOutput := stderr.String()\n\tif !strings.Contains(errOutput, \"error polling run2\") {\n\t\tt.Errorf(\"expected error message for run2, got: %s\", errOutput)\n\t}\n}\n\nfunc TestCmdPollMulti_OutputFormat(t *testing.T) {\n\tclient := newMockClient()\n\tclient.statuses[\"aaa\"] = []*pb.GetStatusResponse{\n\t\t{RunId: \"aaa\", State: \"running\"},\n\t\t{RunId: \"aaa\", State: \"succeeded\"},\n\t}\n\tclient.statuses[\"bbb\"] = []*pb.GetStatusResponse{\n\t\t{RunId: \"bbb\", State: \"succeeded\"},\n\t}\n\n\tvar stdout, stderr bytes.Buffer\n\t_ = cmdPollMulti(client, []string{\"aaa\", \"bbb\"}, &stdout, &stderr)\n\n\toutput := stdout.String()\n\tlines := strings.Split(strings.TrimSpace(output), \"\\n\")\n\tfoundOrder := false\n\tfor i, line := range lines {\n\t\tif strings.HasPrefix(line, \"aaa: \") && i+1 < len(lines) && strings.HasPrefix(lines[i+1], \"bbb: \") {\n\t\t\tfoundOrder = true\n\t\t\tbreak\n\t\t}\n\t}\n\tif !foundOrder {\n\t\tt.Errorf(\"expected runs to be printed in argument order (aaa then bbb), got:\\n%s\", output)\n\t}\n}\n\nfunc TestCmdPollMulti_OnlyPrintsOnChange(t *testing.T) {\n\tclient := newMockClient()\n\t// Two polls with same state, then terminal\n\tclient.statuses[\"run1\"] = []*pb.GetStatusResponse{\n\t\t{RunId: \"run1\", State: \"running\"},\n\t\t{RunId: \"run1\", State: \"running\"},\n\t\t{RunId: \"run1\", State: \"succeeded\"},\n\t}\n\n\tvar stdout, stderr bytes.Buffer\n\t_ = cmdPollMulti(client, []string{\"run1\"}, &stdout, &stderr)\n\n\toutput := stdout.String()\n\tcount := strings.Count(output, \"run1: running\")\n\tif count != 1 {\n\t\tt.Errorf(\"expected 'run1: running' to appear once (only on change), appeared %d times in:\\n%s\", count, output)\n\t}\n}\n\nfunc TestPollHelpText(t *testing.T) {\n\ttext, ok := subcommandHelp[\"poll\"]\n\tif !ok {\n\t\tt.Fatal(\"missing help text for poll subcommand\")\n\t}\n\tif !strings.Contains(text, \"run-id...\") {\n\t\tt.Error(\"poll help should mention multiple run IDs\")\n\t}\n\tif !strings.Contains(text, \"multiple\") {\n\t\tt.Error(\"poll help should describe multiple ID behavior\")\n\t}\n}\n","numLines":212,"startLine":1,"totalLines":212}}}
