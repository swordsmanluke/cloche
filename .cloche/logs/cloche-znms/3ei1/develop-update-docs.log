{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017Y363ntxjadyya5n76poC5","type":"tool_result","content":"     1→package dsl\n     2→\n     3→import (\n     4→\t\"fmt\"\n     5→\t\"strconv\"\n     6→\t\"strings\"\n     7→\n     8→\t\"github.com/cloche-dev/cloche/internal/domain\"\n     9→)\n    10→\n    11→type Parser struct {\n    12→\tlexer    *Lexer\n    13→\tcurrent  Token\n    14→\tpeek     Token\n    15→\tlocation domain.WorkflowLocation\n    16→}\n    17→\n    18→// ParseOption configures the parser.\n    19→type ParseOption func(*Parser)\n    20→\n    21→// WithLocation sets the workflow location, enabling location-based validation.\n    22→func WithLocation(loc domain.WorkflowLocation) ParseOption {\n    23→\treturn func(p *Parser) {\n    24→\t\tp.location = loc\n    25→\t}\n    26→}\n    27→\n    28→func Parse(input string, opts ...ParseOption) (*domain.Workflow, error) {\n    29→\tp := &Parser{lexer: NewLexer(input)}\n    30→\tfor _, opt := range opts {\n    31→\t\topt(p)\n    32→\t}\n    33→\tp.advance() // load current\n    34→\tp.advance() // load peek\n    35→\treturn p.parseWorkflow()\n    36→}\n    37→\n    38→// ParseForHost parses a host.cloche file containing a single workflow.\n    39→func ParseForHost(input string) (*domain.Workflow, error) {\n    40→\treturn Parse(input, WithLocation(domain.LocationHost))\n    41→}\n    42→\n    43→// ParseAllForHost parses a host.cloche file that may contain multiple workflows.\n    44→// Returns a map of workflow name to workflow definition.\n    45→func ParseAllForHost(input string) (map[string]*domain.Workflow, error) {\n    46→\tp := &Parser{lexer: NewLexer(input), location: domain.LocationHost}\n    47→\tp.advance() // load current\n    48→\tp.advance() // load peek\n    49→\n    50→\tworkflows := make(map[string]*domain.Workflow)\n    51→\tfor p.current.Type != TokenEOF {\n    52→\t\twf, err := p.parseWorkflow()\n    53→\t\tif err != nil {\n    54→\t\t\treturn nil, err\n    55→\t\t}\n    56→\t\tif _, exists := workflows[wf.Name]; exists {\n    57→\t\t\treturn nil, fmt.Errorf(\"duplicate workflow name %q\", wf.Name)\n    58→\t\t}\n    59→\t\tworkflows[wf.Name] = wf\n    60→\t}\n    61→\n    62→\tif len(workflows) == 0 {\n    63→\t\treturn nil, fmt.Errorf(\"no workflows found in host.cloche\")\n    64→\t}\n    65→\n    66→\treturn workflows, nil\n    67→}\n    68→\n    69→// ParseForContainer parses a container workflow file.\n    70→func ParseForContainer(input string) (*domain.Workflow, error) {\n    71→\treturn Parse(input, WithLocation(domain.LocationContainer))\n    72→}\n    73→\n    74→// ParseAll parses a .cloche file that may contain multiple workflows.\n    75→// Workflows default to LocationContainer but a \"host { }\" block overrides\n    76→// the location to LocationHost, so any .cloche file can define host workflows.\n    77→func ParseAll(input string) (map[string]*domain.Workflow, error) {\n    78→\tp := &Parser{lexer: NewLexer(input), location: domain.LocationContainer}\n    79→\tp.advance() // load current\n    80→\tp.advance() // load peek\n    81→\n    82→\tworkflows := make(map[string]*domain.Workflow)\n    83→\tfor p.current.Type != TokenEOF {\n    84→\t\twf, err := p.parseWorkflow()\n    85→\t\tif err != nil {\n    86→\t\t\treturn nil, err\n    87→\t\t}\n    88→\t\tif _, exists := workflows[wf.Name]; exists {\n    89→\t\t\treturn nil, fmt.Errorf(\"duplicate workflow name %q\", wf.Name)\n    90→\t\t}\n    91→\t\tworkflows[wf.Name] = wf\n    92→\t}\n    93→\n    94→\tif len(workflows) == 0 {\n    95→\t\treturn nil, fmt.Errorf(\"no workflows found\")\n    96→\t}\n    97→\n    98→\treturn workflows, nil\n    99→}\n   100→\n   101→func (p *Parser) advance() {\n   102→\tp.current = p.peek\n   103→\tp.peek = p.lexer.NextToken()\n   104→}\n   105→\n   106→func (p *Parser) expect(typ TokenType) (Token, error) {\n   107→\tif p.current.Type != typ {\n   108→\t\treturn p.current, fmt.Errorf(\"line %d col %d: expected %v, got %v (%q)\",\n   109→\t\t\tp.current.Line, p.current.Col, typ, p.current.Type, p.current.Literal)\n   110→\t}\n   111→\ttok := p.current\n   112→\tp.advance()\n   113→\treturn tok, nil\n   114→}\n   115→\n   116→func (p *Parser) expectIdent(value string) (Token, error) {\n   117→\tif p.current.Type != TokenIdent || p.current.Literal != value {\n   118→\t\treturn p.current, fmt.Errorf(\"line %d col %d: expected %q, got %q\",\n   119→\t\t\tp.current.Line, p.current.Col, value, p.current.Literal)\n   120→\t}\n   121→\ttok := p.current\n   122→\tp.advance()\n   123→\treturn tok, nil\n   124→}\n   125→\n   126→func (p *Parser) parseWorkflow() (*domain.Workflow, error) {\n   127→\tif _, err := p.expectIdent(\"workflow\"); err != nil {\n   128→\t\treturn nil, err\n   129→\t}\n   130→\n   131→\tnameTok, err := p.expect(TokenString)\n   132→\tif err != nil {\n   133→\t\treturn nil, fmt.Errorf(\"expected workflow name string: %w\", err)\n   134→\t}\n   135→\n   136→\tif _, err := p.expect(TokenLBrace); err != nil {\n   137→\t\treturn nil, err\n   138→\t}\n   139→\n   140→\twf := &domain.Workflow{\n   141→\t\tName:     nameTok.Literal,\n   142→\t\tLocation: p.location,\n   143→\t\tSteps:    make(map[string]*domain.Step),\n   144→\t\tConfig:   make(map[string]string),\n   145→\t}\n   146→\n   147→\tfor p.current.Type != TokenRBrace && p.current.Type != TokenEOF {\n   148→\t\tif p.current.Type == TokenIdent && p.current.Literal == \"step\" {\n   149→\t\t\tstep, err := p.parseStep()\n   150→\t\t\tif err != nil {\n   151→\t\t\t\treturn nil, err\n   152→\t\t\t}\n   153→\t\t\twf.Steps[step.Name] = step\n   154→\t\t\tif wf.EntryStep == \"\" {\n   155→\t\t\t\twf.EntryStep = step.Name\n   156→\t\t\t}\n   157→\t\t} else if p.current.Type == TokenIdent && p.current.Literal == \"collect\" {\n   158→\t\t\tcollect, err := p.parseCollect()\n   159→\t\t\tif err != nil {\n   160→\t\t\t\treturn nil, err\n   161→\t\t\t}\n   162→\t\t\twf.Collects = append(wf.Collects, collect)\n   163→\t\t} else if p.current.Type == TokenIdent && p.peek.Type == TokenLBrace {\n   164→\t\t\tif err := p.parseWorkflowConfig(wf); err != nil {\n   165→\t\t\t\treturn nil, err\n   166→\t\t\t}\n   167→\t\t} else if p.current.Type == TokenIdent && p.peek.Type == TokenColon {\n   168→\t\t\twire, err := p.parseWire()\n   169→\t\t\tif err != nil {\n   170→\t\t\t\treturn nil, err\n   171→\t\t\t}\n   172→\t\t\twf.Wiring = append(wf.Wiring, wire)\n   173→\t\t} else {\n   174→\t\t\treturn nil, fmt.Errorf(\"line %d col %d: unexpected token %q\", p.current.Line, p.current.Col, p.current.Literal)\n   175→\t\t}\n   176→\t}\n   177→\n   178→\tif _, err := p.expect(TokenRBrace); err != nil {\n   179→\t\treturn nil, err\n   180→\t}\n   181→\n   182→\tif wf.Location != \"\" {\n   183→\t\tif err := wf.ValidateLocation(); err != nil {\n   184→\t\t\treturn nil, err\n   185→\t\t}\n   186→\t}\n   187→\n   188→\treturn wf, nil\n   189→}\n   190→\n   191→func (p *Parser) parseWorkflowConfig(wf *domain.Workflow) error {\n   192→\tprefix := p.current.Literal // e.g. \"host\", \"container\"\n   193→\tline, col := p.current.Line, p.current.Col\n   194→\tp.advance() // consume prefix ident\n   195→\n   196→\t// Reject conflicting location blocks.\n   197→\tif prefix == \"host\" && wf.Config[\"_location_block\"] == \"container\" {\n   198→\t\treturn fmt.Errorf(\"line %d col %d: workflow %q has both \\\"host\\\" and \\\"container\\\" blocks\", line, col, wf.Name)\n   199→\t}\n   200→\tif prefix == \"container\" && wf.Config[\"_location_block\"] == \"host\" {\n   201→\t\treturn fmt.Errorf(\"line %d col %d: workflow %q has both \\\"host\\\" and \\\"container\\\" blocks\", line, col, wf.Name)\n   202→\t}\n   203→\n   204→\t// A \"host { ... }\" block marks this workflow as a host workflow.\n   205→\tif prefix == \"host\" {\n   206→\t\twf.Location = domain.LocationHost\n   207→\t}\n   208→\tif prefix == \"host\" || prefix == \"container\" {\n   209→\t\twf.Config[\"_location_block\"] = prefix\n   210→\t}\n   211→\n   212→\tif _, err := p.expect(TokenLBrace); err != nil {\n   213→\t\treturn err\n   214→\t}\n   215→\n   216→\tfor p.current.Type != TokenRBrace && p.current.Type != TokenEOF {\n   217→\t\tkeyTok, err := p.expect(TokenIdent)\n   218→\t\tif err != nil {\n   219→\t\t\treturn fmt.Errorf(\"expected field name: %w\", err)\n   220→\t\t}\n   221→\n   222→\t\tif _, err := p.expect(TokenEquals); err != nil {\n   223→\t\t\treturn err\n   224→\t\t}\n   225→\n   226→\t\tval, err := p.parseValue()\n   227→\t\tif err != nil {\n   228→\t\t\treturn err\n   229→\t\t}\n   230→\n   231→\t\twf.Config[prefix+\".\"+keyTok.Literal] = val\n   232→\t}\n   233→\n   234→\tif _, err := p.expect(TokenRBrace); err != nil {\n   235→\t\treturn err\n   236→\t}\n   237→\n   238→\treturn nil\n   239→}\n   240→\n   241→func (p *Parser) parseStep() (*domain.Step, error) {\n   242→\tp.advance() // consume \"step\"\n   243→\n   244→\tnameTok, err := p.expect(TokenIdent)\n   245→\tif err != nil {\n   246→\t\treturn nil, fmt.Errorf(\"expected step name: %w\", err)\n   247→\t}\n   248→\n   249→\tif _, err := p.expect(TokenLBrace); err != nil {\n   250→\t\treturn nil, err\n   251→\t}\n   252→\n   253→\tstep := &domain.Step{\n   254→\t\tName:   nameTok.Literal,\n   255→\t\tConfig: make(map[string]string),\n   256→\t}\n   257→\n   258→\tfor p.current.Type != TokenRBrace && p.current.Type != TokenEOF {\n   259→\t\tif err := p.parseStepField(step, \"\"); err != nil {\n   260→\t\t\treturn nil, err\n   261→\t\t}\n   262→\t}\n   263→\n   264→\tif _, err := p.expect(TokenRBrace); err != nil {\n   265→\t\treturn nil, err\n   266→\t}\n   267→\n   268→\t// Infer step type from content\n   269→\t_, hasPrompt := step.Config[\"prompt\"]\n   270→\t_, hasRun := step.Config[\"run\"]\n   271→\t_, hasWorkflowName := step.Config[\"workflow_name\"]\n   272→\n   273→\tcount := 0\n   274→\tif hasPrompt {\n   275→\t\tcount++\n   276→\t}\n   277→\tif hasRun {\n   278→\t\tcount++\n   279→\t}\n   280→\tif hasWorkflowName {\n   281→\t\tcount++\n   282→\t}\n   283→\n   284→\tif count > 1 {\n   285→\t\treturn nil, fmt.Errorf(\"step %q has multiple of 'prompt', 'run', 'workflow_name'; must have exactly one\", step.Name)\n   286→\t}\n   287→\n   288→\tswitch {\n   289→\tcase hasPrompt:\n   290→\t\tstep.Type = domain.StepTypeAgent\n   291→\tcase hasRun:\n   292→\t\tstep.Type = domain.StepTypeScript\n   293→\tcase hasWorkflowName:\n   294→\t\tstep.Type = domain.StepTypeWorkflow\n   295→\tdefault:\n   296→\t\treturn nil, fmt.Errorf(\"step %q has none of 'prompt', 'run', or 'workflow_name'; must have exactly one\", step.Name)\n   297→\t}\n   298→\n   299→\treturn step, nil\n   300→}\n   301→\n   302→func (p *Parser) parseStepField(step *domain.Step, prefix string) error {\n   303→\tkeyTok, err := p.expect(TokenIdent)\n   304→\tif err != nil {\n   305→\t\treturn fmt.Errorf(\"expected field name: %w\", err)\n   306→\t}\n   307→\n   308→\tkey := keyTok.Literal\n   309→\tif prefix != \"\" {\n   310→\t\tkey = prefix + \".\" + key\n   311→\t}\n   312→\n   313→\t// Sub-block (e.g., container { ... })\n   314→\tif p.current.Type == TokenLBrace {\n   315→\t\tp.advance() // consume {\n   316→\t\tfor p.current.Type != TokenRBrace && p.current.Type != TokenEOF {\n   317→\t\t\tif err := p.parseStepField(step, key); err != nil {\n   318→\t\t\t\treturn err\n   319→\t\t\t}\n   320→\t\t}\n   321→\t\tp.advance() // consume }\n   322→\t\treturn nil\n   323→\t}\n   324→\n   325→\tif _, err := p.expect(TokenEquals); err != nil {\n   326→\t\treturn err\n   327→\t}\n   328→\n   329→\tif key == \"results\" {\n   330→\t\tresults, err := p.parseIdentList()\n   331→\t\tif err != nil {\n   332→\t\t\treturn err\n   333→\t\t}\n   334→\t\tstep.Results = results\n   335→\t} else if p.current.Type == TokenLBracket {\n   336→\t\tvalues, err := p.parseStringList()\n   337→\t\tif err != nil {\n   338→\t\t\treturn err\n   339→\t\t}\n   340→\t\tstep.Config[key] = strings.Join(values, \",\")\n   341→\t} else {\n   342→\t\tval, err := p.parseValue()\n   343→\t\tif err != nil {\n   344→\t\t\treturn err\n   345→\t\t}\n   346→\t\tstep.Config[key] = val\n   347→\t}\n   348→\n   349→\treturn nil\n   350→}\n   351→\n   352→func (p *Parser) parseIdentList() ([]string, error) {\n   353→\tif _, err := p.expect(TokenLBracket); err != nil {\n   354→\t\treturn nil, err\n   355→\t}\n   356→\n   357→\tvar items []string\n   358→\tfor p.current.Type != TokenRBracket && p.current.Type != TokenEOF {\n   359→\t\ttok, err := p.expect(TokenIdent)\n   360→\t\tif err != nil {\n   361→\t\t\treturn nil, err\n   362→\t\t}\n   363→\t\titems = append(items, tok.Literal)\n   364→\t\tif p.current.Type == TokenComma {\n   365→\t\t\tp.advance()\n   366→\t\t}\n   367→\t}\n   368→\n   369→\tif _, err := p.expect(TokenRBracket); err != nil {\n   370→\t\treturn nil, err\n   371→\t}\n   372→\n   373→\treturn items, nil\n   374→}\n   375→\n   376→func (p *Parser) parseStringList() ([]string, error) {\n   377→\tif _, err := p.expect(TokenLBracket); err != nil {\n   378→\t\treturn nil, err\n   379→\t}\n   380→\n   381→\tvar items []string\n   382→\tfor p.current.Type != TokenRBracket && p.current.Type != TokenEOF {\n   383→\t\ttok, err := p.expect(TokenString)\n   384→\t\tif err != nil {\n   385→\t\t\treturn nil, err\n   386→\t\t}\n   387→\t\titems = append(items, tok.Literal)\n   388→\t\tif p.current.Type == TokenComma {\n   389→\t\t\tp.advance()\n   390→\t\t}\n   391→\t}\n   392→\n   393→\tif _, err := p.expect(TokenRBracket); err != nil {\n   394→\t\treturn nil, err\n   395→\t}\n   396→\n   397→\treturn items, nil\n   398→}\n   399→\n   400→func (p *Parser) parseValue() (string, error) {\n   401→\tif p.current.Type == TokenString {\n   402→\t\ttok := p.current\n   403→\t\tp.advance()\n   404→\t\treturn tok.Literal, nil\n   405→\t}\n   406→\n   407→\tif p.current.Type == TokenInt {\n   408→\t\ttok := p.current\n   409→\t\tp.advance()\n   410→\t\treturn tok.Literal, nil\n   411→\t}\n   412→\n   413→\tif p.current.Type == TokenIdent {\n   414→\t\tvar buf strings.Builder\n   415→\t\tbuf.WriteString(p.current.Literal)\n   416→\t\tp.advance()\n   417→\n   418→\t\t// Function call: file(\"...\")\n   419→\t\tif p.current.Type == TokenLParen {\n   420→\t\t\tbuf.WriteRune('(')\n   421→\t\t\tp.advance()\n   422→\t\t\tfor p.current.Type != TokenRParen && p.current.Type != TokenEOF {\n   423→\t\t\t\tif p.current.Type == TokenString {\n   424→\t\t\t\t\tbuf.WriteRune('\"')\n   425→\t\t\t\t\tbuf.WriteString(p.current.Literal)\n   426→\t\t\t\t\tbuf.WriteRune('\"')\n   427→\t\t\t\t} else {\n   428→\t\t\t\t\tbuf.WriteString(p.current.Literal)\n   429→\t\t\t\t}\n   430→\t\t\t\tp.advance()\n   431→\t\t\t}\n   432→\t\t\tbuf.WriteRune(')')\n   433→\t\t\tp.advance() // consume )\n   434→\t\t}\n   435→\n   436→\t\t// Dotted path: step.code.output\n   437→\t\tfor p.current.Type == TokenDot {\n   438→\t\t\tbuf.WriteRune('.')\n   439→\t\t\tp.advance()\n   440→\t\t\tif p.current.Type == TokenIdent {\n   441→\t\t\t\tbuf.WriteString(p.current.Literal)\n   442→\t\t\t\tp.advance()\n   443→\t\t\t}\n   444→\t\t}\n   445→\n   446→\t\treturn buf.String(), nil\n   447→\t}\n   448→\n   449→\treturn \"\", fmt.Errorf(\"line %d col %d: expected value, got %q\", p.current.Line, p.current.Col, p.current.Literal)\n   450→}\n   451→\n   452→func (p *Parser) parseWire() (domain.Wire, error) {\n   453→\tfromTok := p.current\n   454→\tp.advance()\n   455→\n   456→\tif _, err := p.expect(TokenColon); err != nil {\n   457→\t\treturn domain.Wire{}, err\n   458→\t}\n   459→\n   460→\tresultTok, err := p.expect(TokenIdent)\n   461→\tif err != nil {\n   462→\t\treturn domain.Wire{}, err\n   463→\t}\n   464→\n   465→\tif _, err := p.expect(TokenArrow); err != nil {\n   466→\t\treturn domain.Wire{}, err\n   467→\t}\n   468→\n   469→\ttoTok, err := p.expect(TokenIdent)\n   470→\tif err != nil {\n   471→\t\treturn domain.Wire{}, err\n   472→\t}\n   473→\n   474→\tvar mappings []domain.OutputMapping\n   475→\tif p.current.Type == TokenLBracket {\n   476→\t\tmappings, err = p.parseOutputMappings()\n   477→\t\tif err != nil {\n   478→\t\t\treturn domain.Wire{}, err\n   479→\t\t}\n   480→\t}\n   481→\n   482→\treturn domain.Wire{\n   483→\t\tFrom:      fromTok.Literal,\n   484→\t\tResult:    resultTok.Literal,\n   485→\t\tTo:        toTok.Literal,\n   486→\t\tOutputMap: mappings,\n   487→\t}, nil\n   488→}\n   489→\n   490→func (p *Parser) parseOutputMappings() ([]domain.OutputMapping, error) {\n   491→\tif _, err := p.expect(TokenLBracket); err != nil {\n   492→\t\treturn nil, err\n   493→\t}\n   494→\n   495→\tvar mappings []domain.OutputMapping\n   496→\tfor p.current.Type != TokenRBracket && p.current.Type != TokenEOF {\n   497→\t\tkeyTok, err := p.expect(TokenIdent)\n   498→\t\tif err != nil {\n   499→\t\t\treturn nil, fmt.Errorf(\"expected mapping key: %w\", err)\n   500→\t\t}\n   501→\n   502→\t\tif _, err := p.expect(TokenEquals); err != nil {\n   503→\t\t\treturn nil, err\n   504→\t\t}\n   505→\n   506→\t\tpath, err := p.parseOutputPath()\n   507→\t\tif err != nil {\n   508→\t\t\treturn nil, err\n   509→\t\t}\n   510→\n   511→\t\tmappings = append(mappings, domain.OutputMapping{\n   512→\t\t\tEnvVar: keyTok.Literal,\n   513→\t\t\tPath:   path,\n   514→\t\t})\n   515→\n   516→\t\tif p.current.Type == TokenComma {\n   517→\t\t\tp.advance()\n   518→\t\t}\n   519→\t}\n   520→\n   521→\tif _, err := p.expect(TokenRBracket); err != nil {\n   522→\t\treturn nil, err\n   523→\t}\n   524→\n   525→\treturn mappings, nil\n   526→}\n   527→\n   528→func (p *Parser) parseOutputPath() (domain.OutputPath, error) {\n   529→\tif p.current.Type != TokenIdent || p.current.Literal != \"output\" {\n   530→\t\treturn domain.OutputPath{}, fmt.Errorf(\"line %d col %d: expected \\\"output\\\", got %q\",\n   531→\t\t\tp.current.Line, p.current.Col, p.current.Literal)\n   532→\t}\n   533→\tp.advance() // consume \"output\"\n   534→\n   535→\tvar segments []domain.PathSegment\n   536→\tfor {\n   537→\t\tif p.current.Type == TokenDot {\n   538→\t\t\tp.advance() // consume \".\"\n   539→\t\t\tfieldTok, err := p.expect(TokenIdent)\n   540→\t\t\tif err != nil {\n   541→\t\t\t\treturn domain.OutputPath{}, fmt.Errorf(\"expected field name after '.': %w\", err)\n   542→\t\t\t}\n   543→\t\t\tsegments = append(segments, domain.PathSegment{Kind: domain.SegmentField, Field: fieldTok.Literal})\n   544→\t\t} else if p.current.Type == TokenLBracket {\n   545→\t\t\tp.advance() // consume \"[\"\n   546→\t\t\tidxTok, err := p.expect(TokenInt)\n   547→\t\t\tif err != nil {\n   548→\t\t\t\treturn domain.OutputPath{}, fmt.Errorf(\"expected integer index: %w\", err)\n   549→\t\t\t}\n   550→\t\t\tidx, _ := strconv.Atoi(idxTok.Literal)\n   551→\t\t\tif _, err := p.expect(TokenRBracket); err != nil {\n   552→\t\t\t\treturn domain.OutputPath{}, err\n   553→\t\t\t}\n   554→\t\t\tsegments = append(segments, domain.PathSegment{Kind: domain.SegmentIndex, Index: idx})\n   555→\t\t} else {\n   556→\t\t\tbreak\n   557→\t\t}\n   558→\t}\n   559→\n   560→\treturn domain.OutputPath{Segments: segments}, nil\n   561→}\n   562→\n   563→func (p *Parser) parseCollect() (domain.Collect, error) {\n   564→\tp.advance() // consume \"collect\"\n   565→\n   566→\tmodeTok, err := p.expect(TokenIdent)\n   567→\tif err != nil {\n   568→\t\treturn domain.Collect{}, fmt.Errorf(\"expected 'all' or 'any': %w\", err)\n   569→\t}\n   570→\n   571→\tvar mode domain.CollectMode\n   572→\tswitch modeTok.Literal {\n   573→\tcase \"all\":\n   574→\t\tmode = domain.CollectAll\n   575→\tcase \"any\":\n   576→\t\tmode = domain.CollectAny\n   577→\tdefault:\n   578→\t\treturn domain.Collect{}, fmt.Errorf(\"line %d col %d: expected 'all' or 'any', got %q\",\n   579→\t\t\tmodeTok.Line, modeTok.Col, modeTok.Literal)\n   580→\t}\n   581→\n   582→\tif _, err := p.expect(TokenLParen); err != nil {\n   583→\t\treturn domain.Collect{}, err\n   584→\t}\n   585→\n   586→\tvar conditions []domain.WireCondition\n   587→\tfor p.current.Type != TokenRParen && p.current.Type != TokenEOF {\n   588→\t\tstepTok, err := p.expect(TokenIdent)\n   589→\t\tif err != nil {\n   590→\t\t\treturn domain.Collect{}, fmt.Errorf(\"expected step name in collect: %w\", err)\n   591→\t\t}\n   592→\t\tif _, err := p.expect(TokenColon); err != nil {\n   593→\t\t\treturn domain.Collect{}, err\n   594→\t\t}\n   595→\t\tresultTok, err := p.expect(TokenIdent)\n   596→\t\tif err != nil {\n   597→\t\t\treturn domain.Collect{}, fmt.Errorf(\"expected result name in collect: %w\", err)\n   598→\t\t}\n   599→\t\tconditions = append(conditions, domain.WireCondition{Step: stepTok.Literal, Result: resultTok.Literal})\n   600→\t\tif p.current.Type == TokenComma {\n   601→\t\t\tp.advance()\n   602→\t\t}\n   603→\t}\n   604→\n   605→\tif _, err := p.expect(TokenRParen); err != nil {\n   606→\t\treturn domain.Collect{}, err\n   607→\t}\n   608→\tif _, err := p.expect(TokenArrow); err != nil {\n   609→\t\treturn domain.Collect{}, err\n   610→\t}\n   611→\n   612→\ttoTok, err := p.expect(TokenIdent)\n   613→\tif err != nil {\n   614→\t\treturn domain.Collect{}, fmt.Errorf(\"expected target step: %w\", err)\n   615→\t}\n   616→\n   617→\treturn domain.Collect{\n   618→\t\tMode:       mode,\n   619→\t\tConditions: conditions,\n   620→\t\tTo:         toTok.Literal,\n   621→\t}, nil\n   622→}\n   623→"}]},"parent_tool_use_id":null,"session_id":"1bb771f6-215a-40b2-b553-ac3bdf0705ab","uuid":"fe5d5d63-310d-4242-964e-4c633b825be2","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/dsl/parser.go","content":"package dsl\n\nimport (\n\t\"fmt\"\n\t\"strconv\"\n\t\"strings\"\n\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n)\n\ntype Parser struct {\n\tlexer    *Lexer\n\tcurrent  Token\n\tpeek     Token\n\tlocation domain.WorkflowLocation\n}\n\n// ParseOption configures the parser.\ntype ParseOption func(*Parser)\n\n// WithLocation sets the workflow location, enabling location-based validation.\nfunc WithLocation(loc domain.WorkflowLocation) ParseOption {\n\treturn func(p *Parser) {\n\t\tp.location = loc\n\t}\n}\n\nfunc Parse(input string, opts ...ParseOption) (*domain.Workflow, error) {\n\tp := &Parser{lexer: NewLexer(input)}\n\tfor _, opt := range opts {\n\t\topt(p)\n\t}\n\tp.advance() // load current\n\tp.advance() // load peek\n\treturn p.parseWorkflow()\n}\n\n// ParseForHost parses a host.cloche file containing a single workflow.\nfunc ParseForHost(input string) (*domain.Workflow, error) {\n\treturn Parse(input, WithLocation(domain.LocationHost))\n}\n\n// ParseAllForHost parses a host.cloche file that may contain multiple workflows.\n// Returns a map of workflow name to workflow definition.\nfunc ParseAllForHost(input string) (map[string]*domain.Workflow, error) {\n\tp := &Parser{lexer: NewLexer(input), location: domain.LocationHost}\n\tp.advance() // load current\n\tp.advance() // load peek\n\n\tworkflows := make(map[string]*domain.Workflow)\n\tfor p.current.Type != TokenEOF {\n\t\twf, err := p.parseWorkflow()\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t\tif _, exists := workflows[wf.Name]; exists {\n\t\t\treturn nil, fmt.Errorf(\"duplicate workflow name %q\", wf.Name)\n\t\t}\n\t\tworkflows[wf.Name] = wf\n\t}\n\n\tif len(workflows) == 0 {\n\t\treturn nil, fmt.Errorf(\"no workflows found in host.cloche\")\n\t}\n\n\treturn workflows, nil\n}\n\n// ParseForContainer parses a container workflow file.\nfunc ParseForContainer(input string) (*domain.Workflow, error) {\n\treturn Parse(input, WithLocation(domain.LocationContainer))\n}\n\n// ParseAll parses a .cloche file that may contain multiple workflows.\n// Workflows default to LocationContainer but a \"host { }\" block overrides\n// the location to LocationHost, so any .cloche file can define host workflows.\nfunc ParseAll(input string) (map[string]*domain.Workflow, error) {\n\tp := &Parser{lexer: NewLexer(input), location: domain.LocationContainer}\n\tp.advance() // load current\n\tp.advance() // load peek\n\n\tworkflows := make(map[string]*domain.Workflow)\n\tfor p.current.Type != TokenEOF {\n\t\twf, err := p.parseWorkflow()\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t\tif _, exists := workflows[wf.Name]; exists {\n\t\t\treturn nil, fmt.Errorf(\"duplicate workflow name %q\", wf.Name)\n\t\t}\n\t\tworkflows[wf.Name] = wf\n\t}\n\n\tif len(workflows) == 0 {\n\t\treturn nil, fmt.Errorf(\"no workflows found\")\n\t}\n\n\treturn workflows, nil\n}\n\nfunc (p *Parser) advance() {\n\tp.current = p.peek\n\tp.peek = p.lexer.NextToken()\n}\n\nfunc (p *Parser) expect(typ TokenType) (Token, error) {\n\tif p.current.Type != typ {\n\t\treturn p.current, fmt.Errorf(\"line %d col %d: expected %v, got %v (%q)\",\n\t\t\tp.current.Line, p.current.Col, typ, p.current.Type, p.current.Literal)\n\t}\n\ttok := p.current\n\tp.advance()\n\treturn tok, nil\n}\n\nfunc (p *Parser) expectIdent(value string) (Token, error) {\n\tif p.current.Type != TokenIdent || p.current.Literal != value {\n\t\treturn p.current, fmt.Errorf(\"line %d col %d: expected %q, got %q\",\n\t\t\tp.current.Line, p.current.Col, value, p.current.Literal)\n\t}\n\ttok := p.current\n\tp.advance()\n\treturn tok, nil\n}\n\nfunc (p *Parser) parseWorkflow() (*domain.Workflow, error) {\n\tif _, err := p.expectIdent(\"workflow\"); err != nil {\n\t\treturn nil, err\n\t}\n\n\tnameTok, err := p.expect(TokenString)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"expected workflow name string: %w\", err)\n\t}\n\n\tif _, err := p.expect(TokenLBrace); err != nil {\n\t\treturn nil, err\n\t}\n\n\twf := &domain.Workflow{\n\t\tName:     nameTok.Literal,\n\t\tLocation: p.location,\n\t\tSteps:    make(map[string]*domain.Step),\n\t\tConfig:   make(map[string]string),\n\t}\n\n\tfor p.current.Type != TokenRBrace && p.current.Type != TokenEOF {\n\t\tif p.current.Type == TokenIdent && p.current.Literal == \"step\" {\n\t\t\tstep, err := p.parseStep()\n\t\t\tif err != nil {\n\t\t\t\treturn nil, err\n\t\t\t}\n\t\t\twf.Steps[step.Name] = step\n\t\t\tif wf.EntryStep == \"\" {\n\t\t\t\twf.EntryStep = step.Name\n\t\t\t}\n\t\t} else if p.current.Type == TokenIdent && p.current.Literal == \"collect\" {\n\t\t\tcollect, err := p.parseCollect()\n\t\t\tif err != nil {\n\t\t\t\treturn nil, err\n\t\t\t}\n\t\t\twf.Collects = append(wf.Collects, collect)\n\t\t} else if p.current.Type == TokenIdent && p.peek.Type == TokenLBrace {\n\t\t\tif err := p.parseWorkflowConfig(wf); err != nil {\n\t\t\t\treturn nil, err\n\t\t\t}\n\t\t} else if p.current.Type == TokenIdent && p.peek.Type == TokenColon {\n\t\t\twire, err := p.parseWire()\n\t\t\tif err != nil {\n\t\t\t\treturn nil, err\n\t\t\t}\n\t\t\twf.Wiring = append(wf.Wiring, wire)\n\t\t} else {\n\t\t\treturn nil, fmt.Errorf(\"line %d col %d: unexpected token %q\", p.current.Line, p.current.Col, p.current.Literal)\n\t\t}\n\t}\n\n\tif _, err := p.expect(TokenRBrace); err != nil {\n\t\treturn nil, err\n\t}\n\n\tif wf.Location != \"\" {\n\t\tif err := wf.ValidateLocation(); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t}\n\n\treturn wf, nil\n}\n\nfunc (p *Parser) parseWorkflowConfig(wf *domain.Workflow) error {\n\tprefix := p.current.Literal // e.g. \"host\", \"container\"\n\tline, col := p.current.Line, p.current.Col\n\tp.advance() // consume prefix ident\n\n\t// Reject conflicting location blocks.\n\tif prefix == \"host\" && wf.Config[\"_location_block\"] == \"container\" {\n\t\treturn fmt.Errorf(\"line %d col %d: workflow %q has both \\\"host\\\" and \\\"container\\\" blocks\", line, col, wf.Name)\n\t}\n\tif prefix == \"container\" && wf.Config[\"_location_block\"] == \"host\" {\n\t\treturn fmt.Errorf(\"line %d col %d: workflow %q has both \\\"host\\\" and \\\"container\\\" blocks\", line, col, wf.Name)\n\t}\n\n\t// A \"host { ... }\" block marks this workflow as a host workflow.\n\tif prefix == \"host\" {\n\t\twf.Location = domain.LocationHost\n\t}\n\tif prefix == \"host\" || prefix == \"container\" {\n\t\twf.Config[\"_location_block\"] = prefix\n\t}\n\n\tif _, err := p.expect(TokenLBrace); err != nil {\n\t\treturn err\n\t}\n\n\tfor p.current.Type != TokenRBrace && p.current.Type != TokenEOF {\n\t\tkeyTok, err := p.expect(TokenIdent)\n\t\tif err != nil {\n\t\t\treturn fmt.Errorf(\"expected field name: %w\", err)\n\t\t}\n\n\t\tif _, err := p.expect(TokenEquals); err != nil {\n\t\t\treturn err\n\t\t}\n\n\t\tval, err := p.parseValue()\n\t\tif err != nil {\n\t\t\treturn err\n\t\t}\n\n\t\twf.Config[prefix+\".\"+keyTok.Literal] = val\n\t}\n\n\tif _, err := p.expect(TokenRBrace); err != nil {\n\t\treturn err\n\t}\n\n\treturn nil\n}\n\nfunc (p *Parser) parseStep() (*domain.Step, error) {\n\tp.advance() // consume \"step\"\n\n\tnameTok, err := p.expect(TokenIdent)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"expected step name: %w\", err)\n\t}\n\n\tif _, err := p.expect(TokenLBrace); err != nil {\n\t\treturn nil, err\n\t}\n\n\tstep := &domain.Step{\n\t\tName:   nameTok.Literal,\n\t\tConfig: make(map[string]string),\n\t}\n\n\tfor p.current.Type != TokenRBrace && p.current.Type != TokenEOF {\n\t\tif err := p.parseStepField(step, \"\"); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t}\n\n\tif _, err := p.expect(TokenRBrace); err != nil {\n\t\treturn nil, err\n\t}\n\n\t// Infer step type from content\n\t_, hasPrompt := step.Config[\"prompt\"]\n\t_, hasRun := step.Config[\"run\"]\n\t_, hasWorkflowName := step.Config[\"workflow_name\"]\n\n\tcount := 0\n\tif hasPrompt {\n\t\tcount++\n\t}\n\tif hasRun {\n\t\tcount++\n\t}\n\tif hasWorkflowName {\n\t\tcount++\n\t}\n\n\tif count > 1 {\n\t\treturn nil, fmt.Errorf(\"step %q has multiple of 'prompt', 'run', 'workflow_name'; must have exactly one\", step.Name)\n\t}\n\n\tswitch {\n\tcase hasPrompt:\n\t\tstep.Type = domain.StepTypeAgent\n\tcase hasRun:\n\t\tstep.Type = domain.StepTypeScript\n\tcase hasWorkflowName:\n\t\tstep.Type = domain.StepTypeWorkflow\n\tdefault:\n\t\treturn nil, fmt.Errorf(\"step %q has none of 'prompt', 'run', or 'workflow_name'; must have exactly one\", step.Name)\n\t}\n\n\treturn step, nil\n}\n\nfunc (p *Parser) parseStepField(step *domain.Step, prefix string) error {\n\tkeyTok, err := p.expect(TokenIdent)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"expected field name: %w\", err)\n\t}\n\n\tkey := keyTok.Literal\n\tif prefix != \"\" {\n\t\tkey = prefix + \".\" + key\n\t}\n\n\t// Sub-block (e.g., container { ... })\n\tif p.current.Type == TokenLBrace {\n\t\tp.advance() // consume {\n\t\tfor p.current.Type != TokenRBrace && p.current.Type != TokenEOF {\n\t\t\tif err := p.parseStepField(step, key); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t}\n\t\tp.advance() // consume }\n\t\treturn nil\n\t}\n\n\tif _, err := p.expect(TokenEquals); err != nil {\n\t\treturn err\n\t}\n\n\tif key == \"results\" {\n\t\tresults, err := p.parseIdentList()\n\t\tif err != nil {\n\t\t\treturn err\n\t\t}\n\t\tstep.Results = results\n\t} else if p.current.Type == TokenLBracket {\n\t\tvalues, err := p.parseStringList()\n\t\tif err != nil {\n\t\t\treturn err\n\t\t}\n\t\tstep.Config[key] = strings.Join(values, \",\")\n\t} else {\n\t\tval, err := p.parseValue()\n\t\tif err != nil {\n\t\t\treturn err\n\t\t}\n\t\tstep.Config[key] = val\n\t}\n\n\treturn nil\n}\n\nfunc (p *Parser) parseIdentList() ([]string, error) {\n\tif _, err := p.expect(TokenLBracket); err != nil {\n\t\treturn nil, err\n\t}\n\n\tvar items []string\n\tfor p.current.Type != TokenRBracket && p.current.Type != TokenEOF {\n\t\ttok, err := p.expect(TokenIdent)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t\titems = append(items, tok.Literal)\n\t\tif p.current.Type == TokenComma {\n\t\t\tp.advance()\n\t\t}\n\t}\n\n\tif _, err := p.expect(TokenRBracket); err != nil {\n\t\treturn nil, err\n\t}\n\n\treturn items, nil\n}\n\nfunc (p *Parser) parseStringList() ([]string, error) {\n\tif _, err := p.expect(TokenLBracket); err != nil {\n\t\treturn nil, err\n\t}\n\n\tvar items []string\n\tfor p.current.Type != TokenRBracket && p.current.Type != TokenEOF {\n\t\ttok, err := p.expect(TokenString)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t\titems = append(items, tok.Literal)\n\t\tif p.current.Type == TokenComma {\n\t\t\tp.advance()\n\t\t}\n\t}\n\n\tif _, err := p.expect(TokenRBracket); err != nil {\n\t\treturn nil, err\n\t}\n\n\treturn items, nil\n}\n\nfunc (p *Parser) parseValue() (string, error) {\n\tif p.current.Type == TokenString {\n\t\ttok := p.current\n\t\tp.advance()\n\t\treturn tok.Literal, nil\n\t}\n\n\tif p.current.Type == TokenInt {\n\t\ttok := p.current\n\t\tp.advance()\n\t\treturn tok.Literal, nil\n\t}\n\n\tif p.current.Type == TokenIdent {\n\t\tvar buf strings.Builder\n\t\tbuf.WriteString(p.current.Literal)\n\t\tp.advance()\n\n\t\t// Function call: file(\"...\")\n\t\tif p.current.Type == TokenLParen {\n\t\t\tbuf.WriteRune('(')\n\t\t\tp.advance()\n\t\t\tfor p.current.Type != TokenRParen && p.current.Type != TokenEOF {\n\t\t\t\tif p.current.Type == TokenString {\n\t\t\t\t\tbuf.WriteRune('\"')\n\t\t\t\t\tbuf.WriteString(p.current.Literal)\n\t\t\t\t\tbuf.WriteRune('\"')\n\t\t\t\t} else {\n\t\t\t\t\tbuf.WriteString(p.current.Literal)\n\t\t\t\t}\n\t\t\t\tp.advance()\n\t\t\t}\n\t\t\tbuf.WriteRune(')')\n\t\t\tp.advance() // consume )\n\t\t}\n\n\t\t// Dotted path: step.code.output\n\t\tfor p.current.Type == TokenDot {\n\t\t\tbuf.WriteRune('.')\n\t\t\tp.advance()\n\t\t\tif p.current.Type == TokenIdent {\n\t\t\t\tbuf.WriteString(p.current.Literal)\n\t\t\t\tp.advance()\n\t\t\t}\n\t\t}\n\n\t\treturn buf.String(), nil\n\t}\n\n\treturn \"\", fmt.Errorf(\"line %d col %d: expected value, got %q\", p.current.Line, p.current.Col, p.current.Literal)\n}\n\nfunc (p *Parser) parseWire() (domain.Wire, error) {\n\tfromTok := p.current\n\tp.advance()\n\n\tif _, err := p.expect(TokenColon); err != nil {\n\t\treturn domain.Wire{}, err\n\t}\n\n\tresultTok, err := p.expect(TokenIdent)\n\tif err != nil {\n\t\treturn domain.Wire{}, err\n\t}\n\n\tif _, err := p.expect(TokenArrow); err != nil {\n\t\treturn domain.Wire{}, err\n\t}\n\n\ttoTok, err := p.expect(TokenIdent)\n\tif err != nil {\n\t\treturn domain.Wire{}, err\n\t}\n\n\tvar mappings []domain.OutputMapping\n\tif p.current.Type == TokenLBracket {\n\t\tmappings, err = p.parseOutputMappings()\n\t\tif err != nil {\n\t\t\treturn domain.Wire{}, err\n\t\t}\n\t}\n\n\treturn domain.Wire{\n\t\tFrom:      fromTok.Literal,\n\t\tResult:    resultTok.Literal,\n\t\tTo:        toTok.Literal,\n\t\tOutputMap: mappings,\n\t}, nil\n}\n\nfunc (p *Parser) parseOutputMappings() ([]domain.OutputMapping, error) {\n\tif _, err := p.expect(TokenLBracket); err != nil {\n\t\treturn nil, err\n\t}\n\n\tvar mappings []domain.OutputMapping\n\tfor p.current.Type != TokenRBracket && p.current.Type != TokenEOF {\n\t\tkeyTok, err := p.expect(TokenIdent)\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"expected mapping key: %w\", err)\n\t\t}\n\n\t\tif _, err := p.expect(TokenEquals); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tpath, err := p.parseOutputPath()\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tmappings = append(mappings, domain.OutputMapping{\n\t\t\tEnvVar: keyTok.Literal,\n\t\t\tPath:   path,\n\t\t})\n\n\t\tif p.current.Type == TokenComma {\n\t\t\tp.advance()\n\t\t}\n\t}\n\n\tif _, err := p.expect(TokenRBracket); err != nil {\n\t\treturn nil, err\n\t}\n\n\treturn mappings, nil\n}\n\nfunc (p *Parser) parseOutputPath() (domain.OutputPath, error) {\n\tif p.current.Type != TokenIdent || p.current.Literal != \"output\" {\n\t\treturn domain.OutputPath{}, fmt.Errorf(\"line %d col %d: expected \\\"output\\\", got %q\",\n\t\t\tp.current.Line, p.current.Col, p.current.Literal)\n\t}\n\tp.advance() // consume \"output\"\n\n\tvar segments []domain.PathSegment\n\tfor {\n\t\tif p.current.Type == TokenDot {\n\t\t\tp.advance() // consume \".\"\n\t\t\tfieldTok, err := p.expect(TokenIdent)\n\t\t\tif err != nil {\n\t\t\t\treturn domain.OutputPath{}, fmt.Errorf(\"expected field name after '.': %w\", err)\n\t\t\t}\n\t\t\tsegments = append(segments, domain.PathSegment{Kind: domain.SegmentField, Field: fieldTok.Literal})\n\t\t} else if p.current.Type == TokenLBracket {\n\t\t\tp.advance() // consume \"[\"\n\t\t\tidxTok, err := p.expect(TokenInt)\n\t\t\tif err != nil {\n\t\t\t\treturn domain.OutputPath{}, fmt.Errorf(\"expected integer index: %w\", err)\n\t\t\t}\n\t\t\tidx, _ := strconv.Atoi(idxTok.Literal)\n\t\t\tif _, err := p.expect(TokenRBracket); err != nil {\n\t\t\t\treturn domain.OutputPath{}, err\n\t\t\t}\n\t\t\tsegments = append(segments, domain.PathSegment{Kind: domain.SegmentIndex, Index: idx})\n\t\t} else {\n\t\t\tbreak\n\t\t}\n\t}\n\n\treturn domain.OutputPath{Segments: segments}, nil\n}\n\nfunc (p *Parser) parseCollect() (domain.Collect, error) {\n\tp.advance() // consume \"collect\"\n\n\tmodeTok, err := p.expect(TokenIdent)\n\tif err != nil {\n\t\treturn domain.Collect{}, fmt.Errorf(\"expected 'all' or 'any': %w\", err)\n\t}\n\n\tvar mode domain.CollectMode\n\tswitch modeTok.Literal {\n\tcase \"all\":\n\t\tmode = domain.CollectAll\n\tcase \"any\":\n\t\tmode = domain.CollectAny\n\tdefault:\n\t\treturn domain.Collect{}, fmt.Errorf(\"line %d col %d: expected 'all' or 'any', got %q\",\n\t\t\tmodeTok.Line, modeTok.Col, modeTok.Literal)\n\t}\n\n\tif _, err := p.expect(TokenLParen); err != nil {\n\t\treturn domain.Collect{}, err\n\t}\n\n\tvar conditions []domain.WireCondition\n\tfor p.current.Type != TokenRParen && p.current.Type != TokenEOF {\n\t\tstepTok, err := p.expect(TokenIdent)\n\t\tif err != nil {\n\t\t\treturn domain.Collect{}, fmt.Errorf(\"expected step name in collect: %w\", err)\n\t\t}\n\t\tif _, err := p.expect(TokenColon); err != nil {\n\t\t\treturn domain.Collect{}, err\n\t\t}\n\t\tresultTok, err := p.expect(TokenIdent)\n\t\tif err != nil {\n\t\t\treturn domain.Collect{}, fmt.Errorf(\"expected result name in collect: %w\", err)\n\t\t}\n\t\tconditions = append(conditions, domain.WireCondition{Step: stepTok.Literal, Result: resultTok.Literal})\n\t\tif p.current.Type == TokenComma {\n\t\t\tp.advance()\n\t\t}\n\t}\n\n\tif _, err := p.expect(TokenRParen); err != nil {\n\t\treturn domain.Collect{}, err\n\t}\n\tif _, err := p.expect(TokenArrow); err != nil {\n\t\treturn domain.Collect{}, err\n\t}\n\n\ttoTok, err := p.expect(TokenIdent)\n\tif err != nil {\n\t\treturn domain.Collect{}, fmt.Errorf(\"expected target step: %w\", err)\n\t}\n\n\treturn domain.Collect{\n\t\tMode:       mode,\n\t\tConditions: conditions,\n\t\tTo:         toTok.Literal,\n\t}, nil\n}\n","numLines":623,"startLine":1,"totalLines":623}}}
