[2026-03-17T15:14:32Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JYnuBxGWkczDKfyMewFBh9","type":"tool_result","content":"     1→package prompt\n     2→\n     3→import (\n     4→\t\"bufio\"\n     5→\t\"bytes\"\n     6→\t\"context\"\n     7→\t\"encoding/json\"\n     8→\t\"fmt\"\n     9→\t\"os\"\n    10→\t\"os/exec\"\n    11→\t\"path/filepath\"\n    12→\t\"strconv\"\n    13→\t\"strings\"\n    14→\n    15→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    16→\t\"github.com/cloche-dev/cloche/internal/protocol\"\n    17→)\n    18→\n    19→// defaultAgentArgs maps known agent commands to their default arguments.\n    20→// Commands not in this map receive no default arguments (prompt on stdin only).\n    21→var defaultAgentArgs = map[string][]string{\n    22→\t\"claude\": {\"-p\", \"--output-format\", \"stream-json\", \"--verbose\", \"--dangerously-skip-permissions\"},\n    23→}\n    24→\n    25→type Adapter struct {\n    26→\tCommands           []string // ordered fallback chain of agent commands\n    27→\tExplicitArgs       []string // if non-nil, overrides default args for all commands\n    28→\tRunID              string\n    29→\tStatusWriter       *protocol.StatusWriter // optional: streams live output lines\n    30→\tResumeConversation bool                   // when true, resume previous conversation instead of starting new one\n    31→}\n    32→\n    33→func New() *Adapter {\n    34→\treturn &Adapter{\n    35→\t\tCommands: []string{\"claude\"},\n    36→\t}\n    37→}\n    38→\n    39→func (a *Adapter) Name() string {\n    40→\treturn \"prompt\"\n    41→}\n    42→\n    43→// argsFor returns the arguments for the given command. If ExplicitArgs is set,\n    44→// it is used for all commands. Otherwise, known agents get their default args.\n    45→func (a *Adapter) argsFor(command string) []string {\n    46→\tif a.ExplicitArgs != nil {\n    47→\t\treturn a.ExplicitArgs\n    48→\t}\n    49→\tif args, ok := defaultAgentArgs[command]; ok {\n    50→\t\treturn args\n    51→\t}\n    52→\treturn nil\n    53→}\n    54→\n    55→// ParseCommands splits a comma-separated agent_command string into individual\n    56→// command names, trimming whitespace from each entry.\n    57→func ParseCommands(s string) []string {\n    58→\tparts := strings.Split(s, \",\")\n    59→\tvar cmds []string\n    60→\tfor _, p := range parts {\n    61→\t\tp = strings.TrimSpace(p)\n    62→\t\tif p != \"\" {\n    63→\t\t\tcmds = append(cmds, p)\n    64→\t\t}\n    65→\t}\n    66→\treturn cmds\n    67→}\n    68→\n    69→func (a *Adapter) Execute(ctx context.Context, step *domain.Step, workDir string) (string, error) {\n    70→\t// Check attempt count for retry limiting\n    71→\tif maxStr, ok := step.Config[\"max_attempts\"]; ok {\n    72→\t\tmax, err := strconv.Atoi(maxStr)\n    73→\t\tif err == nil {\n    74→\t\t\tcount := readAttemptCount(workDir, step.Name)\n    75→\t\t\tif count >= max {\n    76→\t\t\t\treturn \"give-up\", nil\n    77→\t\t\t}\n    78→\t\t}\n    79→\t}\n    80→\tincrementAttemptCount(workDir, step.Name)\n    81→\n    82→\t// Build the full prompt\n    83→\tvar fullPrompt string\n    84→\tif a.ResumeConversation {\n    85→\t\tfullPrompt = \"retry\"\n    86→\t} else {\n    87→\t\tvar err error\n    88→\t\tfullPrompt, err = assemblePrompt(step, workDir, a.RunID)\n    89→\t\tif err != nil {\n    90→\t\t\treturn \"\", fmt.Errorf(\"assembling prompt: %w\", err)\n    91→\t\t}\n    92→\t}\n    93→\n    94→\t// Try each command in the fallback chain\n    95→\tvar lastResult string\n    96→\tvar lastStdout []byte\n    97→\tvar lastErr error\n    98→\tran := false\n    99→\n   100→\tfor _, command := range a.Commands {\n   101→\t\tresult, stdout, fallbackErr := a.tryCommand(ctx, command, fullPrompt, workDir, step.Name)\n   102→\t\tlastResult = result\n   103→\t\tlastStdout = stdout\n   104→\t\tlastErr = fallbackErr\n   105→\n   106→\t\tif fallbackErr == nil {\n   107→\t\t\t// Definitive result — agent completed (exit 0 or exit non-zero with marker)\n   108→\t\t\tbreak\n   109→\t\t}\n   110→\t\tif stdout != nil {\n   111→\t\t\tran = true\n   112→\t\t}\n   113→\t\t// Fallback-eligible — try next command\n   114→\t}\n   115→\n   116→\tif lastErr != nil && !ran && lastStdout == nil {\n   117→\t\t// All commands failed to produce any output (e.g., all not found)\n   118→\t\treturn \"\", lastErr\n   119→\t}\n   120→\n   121→\tresult := lastResult\n   122→\tif lastErr != nil {\n   123→\t\t// Last command in chain crashed without a result marker\n   124→\t\tresult = \"fail\"\n   125→\t}\n   126→\n   127→\t// Reset attempt counter on success so give-up only triggers after\n   128→\t// consecutive failures, not after successful fixes whose downstream\n   129→\t// tests fail for unrelated reasons.\n   130→\tif result == \"success\" {\n   131→\t\tresetAttemptCount(workDir, step.Name)\n   132→\t}\n   133→\n   134→\t// Write output file\n   135→\toutputDir := filepath.Join(workDir, \".cloche\", \"output\")\n   136→\tif mkErr := os.MkdirAll(outputDir, 0755); mkErr == nil {\n   137→\t\t_ = os.WriteFile(filepath.Join(outputDir, step.Name+\".log\"), lastStdout, 0644)\n   138→\t}\n   139→\tprotocol.AppendHistory(workDir, step.Name, result, true, nil)\n   140→\treturn result, nil\n   141→}\n   142→\n   143→// tryCommand executes a single agent command and returns:\n   144→//   - result: the step result name (e.g. \"success\", \"fail\")\n   145→//   - stdout: captured stdout bytes\n   146→//   - fallbackErr: nil if the result is definitive, non-nil if fallback-eligible\n   147→//\n   148→// Fallback-eligible conditions:\n   149→//   - Command not found or failed to start (stdout will be nil)\n   150→//   - Command exited non-zero without a CLOCHE_RESULT marker\n   151→//\n   152→// Definitive (non-fallback) conditions:\n   153→//   - Command exited 0\n   154→//   - Command exited non-zero but produced a CLOCHE_RESULT marker\n   155→func (a *Adapter) tryCommand(ctx context.Context, command string, prompt string, workDir string, stepName string) (result string, stdout []byte, fallbackErr error) {\n   156→\targs := a.argsFor(command)\n   157→\t// Resume mode: add -c flag to resume previous conversation\n   158→\tif a.ResumeConversation {\n   159→\t\targs = append([]string{\"-c\"}, args...)\n   160→\t}\n   161→\tcmd := exec.CommandContext(ctx, command, args...)\n   162→\tcmd.Dir = workDir\n   163→\tcmd.Stdin = strings.NewReader(prompt)\n   164→\n   165→\t// If we have a StatusWriter, stream stdout line-by-line; otherwise buffer.\n   166→\tif a.StatusWriter == nil {\n   167→\t\tvar stdoutBuf, stderrBuf bytes.Buffer\n   168→\t\tcmd.Stdout = &stdoutBuf\n   169→\t\tcmd.Stderr = &stderrBuf\n   170→\n   171→\t\trunErr := cmd.Run()\n   172→\t\tstdoutBytes := stdoutBuf.Bytes()\n   173→\t\treturn a.classifyResult(command, stdoutBytes, runErr)\n   174→\t}\n   175→\n   176→\t// Streaming path: pipe stdout through a scanner so we can emit lines live.\n   177→\tpipe, err := cmd.StdoutPipe()\n   178→\tif err != nil {\n   179→\t\treturn \"\", nil, fmt.Errorf(\"command %q stdout pipe: %w\", command, err)\n   180→\t}\n   181→\tcmd.Stderr = nil // discard stderr\n   182→\n   183→\tif err := cmd.Start(); err != nil {\n   184→\t\treturn \"\", nil, fmt.Errorf(\"command %q failed to start: %w\", command, err)\n   185→\t}\n   186→\n   187→\t// textBuf accumulates extracted text content for result extraction.\n   188→\t// rawBuf accumulates raw stdout for the output log file.\n   189→\tvar textBuf, rawBuf bytes.Buffer\n   190→\t// lineBuf accumulates text deltas into lines for streaming.\n   191→\tvar lineBuf strings.Builder\n   192→\n   193→\tscanner := bufio.NewScanner(pipe)\n   194→\tscanner.Buffer(make([]byte, 0, 256*1024), 1024*1024)\n   195→\tfor scanner.Scan() {\n   196→\t\traw := scanner.Bytes()\n   197→\t\trawBuf.Write(raw)\n   198→\t\trawBuf.WriteByte('\\n')\n   199→\n   200→\t\ttext := extractStreamText(raw)\n   201→\t\tif text == \"\" {\n   202→\t\t\tcontinue\n   203→\t\t}\n   204→\t\ttextBuf.WriteString(text)\n   205→\n   206→\t\t// Stream complete lines to StatusWriter as they form.\n   207→\t\tlineBuf.WriteString(text)\n   208→\t\tfor {\n   209→\t\t\ts := lineBuf.String()\n   210→\t\t\tidx := strings.IndexByte(s, '\\n')\n   211→\t\t\tif idx < 0 {\n   212→\t\t\t\tbreak\n   213→\t\t\t}\n   214→\t\t\ta.StatusWriter.Log(stepName, s[:idx])\n   215→\t\t\tlineBuf.Reset()\n   216→\t\t\tlineBuf.WriteString(s[idx+1:])\n   217→\t\t}\n   218→\t}\n   219→\t// Flush any remaining partial line.\n   220→\tif lineBuf.Len() > 0 {\n   221→\t\ta.StatusWriter.Log(stepName, lineBuf.String())\n   222→\t}\n   223→\tif scanErr := scanner.Err(); scanErr != nil {\n   224→\t\ta.StatusWriter.Log(stepName, fmt.Sprintf(\"[scan error: %v]\", scanErr))\n   225→\t}\n   226→\n   227→\twaitErr := cmd.Wait()\n   228→\t// Prefer extracted text (stream-json) for result classification; fall back\n   229→\t// to raw output for non-JSON commands (scripts, non-claude agents).\n   230→\tclassifyBuf := textBuf.Bytes()\n   231→\tif len(bytes.TrimSpace(classifyBuf)) == 0 {\n   232→\t\tclassifyBuf = rawBuf.Bytes()\n   233→\t}\n   234→\tresult, _, fallbackErr = a.classifyResult(command, classifyBuf, waitErr)\n   235→\treturn result, rawBuf.Bytes(), fallbackErr\n   236→}\n   237→\n   238→// classifyResult interprets the command's exit status and stdout to determine\n   239→// the step result.\n   240→func (a *Adapter) classifyResult(command string, stdoutBytes []byte, runErr error) (string, []byte, error) {\n   241→\tif runErr != nil {\n   242→\t\tif _, ok := runErr.(*exec.ExitError); !ok {\n   243→\t\t\t// Command failed to start (not found, permission denied, etc.)\n   244→\t\t\treturn \"\", nil, fmt.Errorf(\"command %q failed to start: %w\", command, runErr)\n   245→\t\t}\n   246→\t\t// Command ran but exited non-zero\n   247→\t\tmarkerResult, _, found := protocol.ExtractResult(stdoutBytes)\n   248→\t\tif found {\n   249→\t\t\treturn markerResult, stdoutBytes, nil\n   250→\t\t}\n   251→\t\treturn \"fail\", stdoutBytes, fmt.Errorf(\"command %q exited with error: %w\", command, runErr)\n   252→\t}\n   253→\n   254→\t// Command succeeded (exit 0)\n   255→\tif len(bytes.TrimSpace(stdoutBytes)) == 0 {\n   256→\t\treturn \"fail\", stdoutBytes, fmt.Errorf(\"command %q exited 0 but produced no output (auth/config issue?)\", command)\n   257→\t}\n   258→\tmarkerResult, _, found := protocol.ExtractResult(stdoutBytes)\n   259→\tresult := \"success\"\n   260→\tif found {\n   261→\t\tresult = markerResult\n   262→\t}\n   263→\treturn result, stdoutBytes, nil\n   264→}\n   265→\n   266→// extractStreamText parses a Claude Code stream-json line and returns text content.\n   267→//\n   268→// Claude Code's stream-json emits these event types:\n   269→//   - \"assistant\": one per turn, contains message.content[] with text and tool_use blocks\n   270→//   - \"result\": final event with the full result text (contains CLOCHE_RESULT marker)\n   271→//\n   272→// For assistant events, we extract text blocks and summarize tool_use blocks\n   273→// (e.g. \"--- Tool: Read('path') ---\"). Each assistant event has a unique uuid\n   274→// for dedup by the caller.\n   275→func extractStreamText(line []byte) string {\n   276→\t// Fast path: skip lines that can't contain content we care about.\n   277→\tif !bytes.Contains(line, []byte(`\"type\"`)) {\n   278→\t\treturn \"\"\n   279→\t}\n   280→\n   281→\tvar envelope struct {\n   282→\t\tType string `json:\"type\"`\n   283→\t}\n   284→\tif json.Unmarshal(line, &envelope) != nil {\n   285→\t\treturn \"\"\n   286→\t}\n   287→\n   288→\tswitch envelope.Type {\n   289→\tcase \"assistant\":\n   290→\t\treturn extractAssistantText(line)\n   291→\tcase \"result\":\n   292→\t\treturn extractResultText(line)\n   293→\t}\n   294→\treturn \"\"\n   295→}\n   296→\n   297→// extractAssistantText extracts text and tool-use summaries from an assistant event.\n   298→func extractAssistantText(line []byte) string {\n   299→\tvar event struct {\n   300→\t\tMessage struct {\n   301→\t\t\tContent []struct {\n   302→\t\t\t\tType  string          `json:\"type\"`\n   303→\t\t\t\tText  string          `json:\"text\"`\n   304→\t\t\t\tName  string          `json:\"name\"`\n   305→\t\t\t\tInput json.RawMessage `json:\"input\"`\n   306→\t\t\t} `json:\"content\"`\n   307→\t\t} `json:\"message\"`\n   308→\t}\n   309→\tif json.Unmarshal(line, &event) != nil {\n   310→\t\treturn \"\"\n   311→\t}\n   312→\n   313→\tvar b strings.Builder\n   314→\tfor _, c := range event.Message.Content {\n   315→\t\tswitch c.Type {\n   316→\t\tcase \"text\":\n   317→\t\t\tif c.Text != \"\" {\n   318→\t\t\t\tb.WriteString(c.Text)\n   319→\t\t\t\tif !strings.HasSuffix(c.Text, \"\\n\") {\n   320→\t\t\t\t\tb.WriteByte('\\n')\n   321→\t\t\t\t}\n   322→\t\t\t}\n   323→\t\tcase \"tool_use\":\n   324→\t\t\tb.WriteString(\"--- Tool: \")\n   325→\t\t\tb.WriteString(c.Name)\n   326→\t\t\tb.WriteString(toolInputSummary(c.Input))\n   327→\t\t\tb.WriteString(\" ---\\n\")\n   328→\t\t}\n   329→\t}\n   330→\treturn b.String()\n   331→}\n   332→\n   333→// extractResultText extracts the final result text (contains CLOCHE_RESULT marker).\n   334→func extractResultText(line []byte) string {\n   335→\tif !bytes.Contains(line, []byte(`\"subtype\"`)) {\n   336→\t\treturn \"\"\n   337→\t}\n   338→\tvar event struct {\n   339→\t\tType   string `json:\"type\"`\n   340→\t\tResult string `json:\"result\"`\n   341→\t}\n   342→\tif json.Unmarshal(line, &event) == nil && event.Type == \"result\" {\n   343→\t\treturn event.Result\n   344→\t}\n   345→\treturn \"\"\n   346→}\n   347→\n   348→// toolInputSummary returns a short parenthesized summary of a tool's input.\n   349→func toolInputSummary(input json.RawMessage) string {\n   350→\tif len(input) == 0 {\n   351→\t\treturn \"\"\n   352→\t}\n   353→\tvar m map[string]json.RawMessage\n   354→\tif json.Unmarshal(input, &m) != nil {\n   355→\t\treturn \"\"\n   356→\t}\n   357→\t// Pick the most informative single argument to show.\n   358→\tfor _, key := range []string{\"file_path\", \"command\", \"pattern\", \"prompt\", \"skill\"} {\n   359→\t\tif v, ok := m[key]; ok {\n   360→\t\t\tvar s string\n   361→\t\t\tif json.Unmarshal(v, &s) == nil {\n   362→\t\t\t\tif len(s) > 60 {\n   363→\t\t\t\t\ts = s[:57] + \"...\"\n   364→\t\t\t\t}\n   365→\t\t\t\treturn \"('\" + s + \"')\"\n   366→\t\t\t}\n   367→\t\t}\n   368→\t}\n   369→\treturn \"\"\n   370→}\n   371→\n   372→func assemblePrompt(step *domain.Step, workDir, runID string) (string, error) {\n   373→\tvar parts []string\n   374→\n   375→\t// 1. Read system template from step config\n   376→\tif tmpl, ok := step.Config[\"prompt\"]; ok {\n   377→\t\tcontent, err := resolveContent(tmpl, workDir)\n   378→\t\tif err != nil {\n   379→\t\t\treturn \"\", fmt.Errorf(\"reading prompt template: %w\", err)\n   380→\t\t}\n   381→\t\tparts = append(parts, content)\n   382→\t}\n   383→\n   384→\t// 2. Read user prompt from .cloche/<run-id>/prompt.txt\n   385→\tuserPrompt := readUserPrompt(workDir, runID)\n   386→\tif userPrompt != \"\" {\n   387→\t\tparts = append(parts, \"## User Request\\n\"+userPrompt)\n   388→\t}\n   389→\n   390→\t// 3. Read feedback from .cloche/output/*.log (opt-in via step config)\n   391→\tif step.Config[\"feedback\"] == \"true\" {\n   392→\t\tfeedback := readFeedback(workDir)\n   393→\t\tif feedback != \"\" {\n   394→\t\t\tparts = append(parts, \"## Validation Output\\n\"+feedback)\n   395→\t\t}\n   396→\t}\n   397→\n   398→\t// 4. Result selection instructions\n   399→\tif len(step.Results) > 0 {\n   400→\t\tvar resultLines []string\n   401→\t\tresultLines = append(resultLines, \"## Result Selection\")\n   402→\t\tresultLines = append(resultLines, \"When you are finished, output exactly one of the following on its own line:\")\n   403→\t\tfor _, r := range step.Results {\n   404→\t\t\tresultLines = append(resultLines, protocol.ResultPrefix+r)\n   405→\t\t}\n   406→\t\tparts = append(parts, strings.Join(resultLines, \"\\n\"))\n   407→\t}\n   408→\n   409→\treturn strings.Join(parts, \"\\n\\n\"), nil\n   410→}\n   411→\n   412→// resolveContent handles file(\"path\") syntax or returns the string directly.\n   413→func resolveContent(value string, workDir string) (string, error) {\n   414→\t// Check for file(\"path\") syntax from DSL parser\n   415→\tif strings.HasPrefix(value, `file(\"`) && strings.HasSuffix(value, `\")`) {\n   416→\t\tpath := value[6 : len(value)-2]\n   417→\t\tdata, err := os.ReadFile(filepath.Join(workDir, path))\n   418→\t\tif err != nil {\n   419→\t\t\treturn \"\", fmt.Errorf(\"reading file %q: %w\", path, err)\n   420→\t\t}\n   421→\t\treturn string(data), nil\n   422→\t}\n   423→\treturn value, nil\n   424→}\n   425→\n   426→func readFeedback(workDir string) string {\n   427→\toutputDir := filepath.Join(workDir, \".cloche\", \"output\")\n   428→\tentries, err := os.ReadDir(outputDir)\n   429→\tif err != nil {\n   430→\t\treturn \"\"\n   431→\t}\n   432→\n   433→\tvar parts []string\n   434→\tfor _, entry := range entries {\n   435→\t\tif entry.IsDir() || !strings.HasSuffix(entry.Name(), \".log\") {\n   436→\t\t\tcontinue\n   437→\t\t}\n   438→\t\tdata, err := os.ReadFile(filepath.Join(outputDir, entry.Name()))\n   439→\t\tif err != nil {\n   440→\t\t\tcontinue\n   441→\t\t}\n   442→\t\tcontent := strings.TrimSpace(string(data))\n   443→\t\tif content != \"\" {\n   444→\t\t\tstepName := strings.TrimSuffix(entry.Name(), \".log\")\n   445→\t\t\tparts = append(parts, fmt.Sprintf(\"### %s\\n```\\n%s\\n```\", stepName, content))\n   446→\t\t}\n   447→\t}\n   448→\n   449→\treturn strings.Join(parts, \"\\n\\n\")\n   450→}\n   451→\n   452→func readAttemptCount(workDir, stepName string) int {\n   453→\tpath := filepath.Join(workDir, \".cloche\", \"attempt_count\", stepName)\n   454→\tdata, err := os.ReadFile(path)\n   455→\tif err != nil {\n   456→\t\treturn 0\n   457→\t}\n   458→\tn, _ := strconv.Atoi(strings.TrimSpace(string(data)))\n   459→\treturn n\n   460→}\n   461→\n   462→// readUserPrompt reads the user prompt from .cloche/<run-id>/prompt.txt.\n   463→func readUserPrompt(workDir, runID string) string {\n   464→\tif runID == \"\" {\n   465→\t\treturn \"\"\n   466→\t}\n   467→\tpath := filepath.Join(workDir, \".cloche\", runID, \"prompt.txt\")\n   468→\tif data, err := os.ReadFile(path); err == nil {\n   469→\t\treturn string(data)\n   470→\t}\n   471→\treturn \"\"\n   472→}\n   473→\n   474→func resetAttemptCount(workDir, stepName string) {\n   475→\tpath := filepath.Join(workDir, \".cloche\", \"attempt_count\", stepName)\n   476→\t_ = os.Remove(path)\n   477→}\n   478→\n   479→func incrementAttemptCount(workDir, stepName string) {\n   480→\tdir := filepath.Join(workDir, \".cloche\", \"attempt_count\")\n   481→\t_ = os.MkdirAll(dir, 0755)\n   482→\tcount := readAttemptCount(workDir, stepName) + 1\n   483→\t_ = os.WriteFile(filepath.Join(dir, stepName), []byte(strconv.Itoa(count)), 0644)\n   484→}\n   485→"}]},"parent_tool_use_id":"toolu_01DQc8VGBbBzwbeq56rksjAq","session_id":"d1afb603-fabd-44b7-80c6-1c61044982a2","uuid":"6478c82a-14ae-461f-8d84-4e2644192028","timestamp":"2026-03-17T15:12:28.245Z"}
