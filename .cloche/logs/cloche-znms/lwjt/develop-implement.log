{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Egfj8VbLkQT62zMFMjUoKY","type":"tool_result","content":"     1â†’package dsl\n     2â†’\n     3â†’import (\n     4â†’\t\"fmt\"\n     5â†’\t\"strconv\"\n     6â†’\t\"strings\"\n     7â†’\n     8â†’\t\"github.com/cloche-dev/cloche/internal/domain\"\n     9â†’)\n    10â†’\n    11â†’type Parser struct {\n    12â†’\tlexer    *Lexer\n    13â†’\tcurrent  Token\n    14â†’\tpeek     Token\n    15â†’\tlocation domain.WorkflowLocation\n    16â†’}\n    17â†’\n    18â†’// ParseOption configures the parser.\n    19â†’type ParseOption func(*Parser)\n    20â†’\n    21â†’// WithLocation sets the workflow location, enabling location-based validation.\n    22â†’func WithLocation(loc domain.WorkflowLocation) ParseOption {\n    23â†’\treturn func(p *Parser) {\n    24â†’\t\tp.location = loc\n    25â†’\t}\n    26â†’}\n    27â†’\n    28â†’func Parse(input string, opts ...ParseOption) (*domain.Workflow, error) {\n    29â†’\tp := &Parser{lexer: NewLexer(input)}\n    30â†’\tfor _, opt := range opts {\n    31â†’\t\topt(p)\n    32â†’\t}\n    33â†’\tp.advance() // load current\n    34â†’\tp.advance() // load peek\n    35â†’\treturn p.parseWorkflow()\n    36â†’}\n    37â†’\n    38â†’// ParseForHost parses a host.cloche file containing a single workflow.\n    39â†’func ParseForHost(input string) (*domain.Workflow, error) {\n    40â†’\treturn Parse(input, WithLocation(domain.LocationHost))\n    41â†’}\n    42â†’\n    43â†’// ParseAllForHost parses a host.cloche file that may contain multiple workflows.\n    44â†’// Returns a map of workflow name to workflow definition.\n    45â†’func ParseAllForHost(input string) (map[string]*domain.Workflow, error) {\n    46â†’\tp := &Parser{lexer: NewLexer(input), location: domain.LocationHost}\n    47â†’\tp.advance() // load current\n    48â†’\tp.advance() // load peek\n    49â†’\n    50â†’\tworkflows := make(map[string]*domain.Workflow)\n    51â†’\tfor p.current.Type != TokenEOF {\n    52â†’\t\twf, err := p.parseWorkflow()\n    53â†’\t\tif err != nil {\n    54â†’\t\t\treturn nil, err\n    55â†’\t\t}\n    56â†’\t\tif _, exists := workflows[wf.Name]; exists {\n    57â†’\t\t\treturn nil, fmt.Errorf(\"duplicate workflow name %q\", wf.Name)\n    58â†’\t\t}\n    59â†’\t\tworkflows[wf.Name] = wf\n    60â†’\t}\n    61â†’\n    62â†’\tif len(workflows) == 0 {\n    63â†’\t\treturn nil, fmt.Errorf(\"no workflows found in host.cloche\")\n    64â†’\t}\n    65â†’\n    66â†’\treturn workflows, nil\n    67â†’}\n    68â†’\n    69â†’// ParseForContainer parses a container workflow file.\n    70â†’func ParseForContainer(input string) (*domain.Workflow, error) {\n    71â†’\treturn Parse(input, WithLocation(domain.LocationContainer))\n    72â†’}\n    73â†’\n    74â†’// ParseAll parses a .cloche file that may contain multiple workflows.\n    75â†’// Workflows default to LocationContainer but a \"host { }\" block overrides\n    76â†’// the location to LocationHost, so any .cloche file can define host workflows.\n    77â†’func ParseAll(input string) (map[string]*domain.Workflow, error) {\n    78â†’\tp := &Parser{lexer: NewLexer(input), location: domain.LocationContainer}\n    79â†’\tp.advance() // load current\n    80â†’\tp.advance() // load peek\n    81â†’\n    82â†’\tworkflows := make(map[string]*domain.Workflow)\n    83â†’\tfor p.current.Type != TokenEOF {\n    84â†’\t\twf, err := p.parseWorkflow()\n    85â†’\t\tif err != nil {\n    86â†’\t\t\treturn nil, err\n    87â†’\t\t}\n    88â†’\t\tif _, exists := workflows[wf.Name]; exists {\n    89â†’\t\t\treturn nil, fmt.Errorf(\"duplicate workflow name %q\", wf.Name)\n    90â†’\t\t}\n    91â†’\t\tworkflows[wf.Name] = wf\n    92â†’\t}\n    93â†’\n    94â†’\tif len(workflows) == 0 {\n    95â†’\t\treturn nil, fmt.Errorf(\"no workflows found\")\n    96â†’\t}\n    97â†’\n    98â†’\treturn workflows, nil\n    99â†’}\n   100â†’\n   101â†’func (p *Parser) advance() {\n   102â†’\tp.current = p.peek\n   103â†’\tp.peek = p.lexer.NextToken()\n   104â†’}\n   105â†’\n   106â†’func (p *Parser) expect(typ TokenType) (Token, error) {\n   107â†’\tif p.current.Type != typ {\n   108â†’\t\treturn p.current, fmt.Errorf(\"line %d col %d: expected %v, got %v (%q)\",\n   109â†’\t\t\tp.current.Line, p.current.Col, typ, p.current.Type, p.current.Literal)\n   110â†’\t}\n   111â†’\ttok := p.current\n   112â†’\tp.advance()\n   113â†’\treturn tok, nil\n   114â†’}\n   115â†’\n   116â†’func (p *Parser) expectIdent(value string) (Token, error) {\n   117â†’\tif p.current.Type != TokenIdent || p.current.Literal != value {\n   118â†’\t\treturn p.current, fmt.Errorf(\"line %d col %d: expected %q, got %q\",\n   119â†’\t\t\tp.current.Line, p.current.Col, value, p.current.Literal)\n   120â†’\t}\n   121â†’\ttok := p.current\n   122â†’\tp.advance()\n   123â†’\treturn tok, nil\n   124â†’}\n   125â†’\n   126â†’func (p *Parser) parseWorkflow() (*domain.Workflow, error) {\n   127â†’\tif _, err := p.expectIdent(\"workflow\"); err != nil {\n   128â†’\t\treturn nil, err\n   129â†’\t}\n   130â†’\n   131â†’\tnameTok, err := p.expect(TokenString)\n   132â†’\tif err != nil {\n   133â†’\t\treturn nil, fmt.Errorf(\"expected workflow name string: %w\", err)\n   134â†’\t}\n   135â†’\n   136â†’\tif _, err := p.expect(TokenLBrace); err != nil {\n   137â†’\t\treturn nil, err\n   138â†’\t}\n   139â†’\n   140â†’\twf := &domain.Workflow{\n   141â†’\t\tName:     nameTok.Literal,\n   142â†’\t\tLocation: p.location,\n   143â†’\t\tSteps:    make(map[string]*domain.Step),\n   144â†’\t\tAgents:   make(map[string]*domain.Agent),\n   145â†’\t\tConfig:   make(map[string]string),\n   146â†’\t}\n   147â†’\n   148â†’\tfor p.current.Type != TokenRBrace && p.current.Type != TokenEOF {\n   149â†’\t\tif p.current.Type == TokenIdent && p.current.Literal == \"agent\" && p.peek.Type == TokenIdent {\n   150â†’\t\t\tagent, err := p.parseAgent()\n   151â†’\t\t\tif err != nil {\n   152â†’\t\t\t\treturn nil, err\n   153â†’\t\t\t}\n   154â†’\t\t\tif _, exists := wf.Agents[agent.Name]; exists {\n   155â†’\t\t\t\treturn nil, fmt.Errorf(\"line %d: duplicate agent declaration %q\", p.current.Line, agent.Name)\n   156â†’\t\t\t}\n   157â†’\t\t\twf.Agents[agent.Name] = agent\n   158â†’\t\t} else if p.current.Type == TokenIdent && p.current.Literal == \"step\" {\n   159â†’\t\t\tstep, err := p.parseStep()\n   160â†’\t\t\tif err != nil {\n   161â†’\t\t\t\treturn nil, err\n   162â†’\t\t\t}\n   163â†’\t\t\twf.Steps[step.Name] = step\n   164â†’\t\t\tif wf.EntryStep == \"\" {\n   165â†’\t\t\t\twf.EntryStep = step.Name\n   166â†’\t\t\t}\n   167â†’\t\t} else if p.current.Type == TokenIdent && p.current.Literal == \"collect\" {\n   168â†’\t\t\tcollect, err := p.parseCollect()\n   169â†’\t\t\tif err != nil {\n   170â†’\t\t\t\treturn nil, err\n   171â†’\t\t\t}\n   172â†’\t\t\twf.Collects = append(wf.Collects, collect)\n   173â†’\t\t} else if p.current.Type == TokenIdent && p.peek.Type == TokenLBrace {\n   174â†’\t\t\tif err := p.parseWorkflowConfig(wf); err != nil {\n   175â†’\t\t\t\treturn nil, err\n   176â†’\t\t\t}\n   177â†’\t\t} else if p.current.Type == TokenIdent && p.peek.Type == TokenColon {\n   178â†’\t\t\twire, err := p.parseWire()\n   179â†’\t\t\tif err != nil {\n   180â†’\t\t\t\treturn nil, err\n   181â†’\t\t\t}\n   182â†’\t\t\twf.Wiring = append(wf.Wiring, wire)\n   183â†’\t\t} else {\n   184â†’\t\t\treturn nil, fmt.Errorf(\"line %d col %d: unexpected token %q\", p.current.Line, p.current.Col, p.current.Literal)\n   185â†’\t\t}\n   186â†’\t}\n   187â†’\n   188â†’\tif _, err := p.expect(TokenRBrace); err != nil {\n   189â†’\t\treturn nil, err\n   190â†’\t}\n   191â†’\n   192â†’\tif wf.Location != \"\" {\n   193â†’\t\tif err := wf.ValidateLocation(); err != nil {\n   194â†’\t\t\treturn nil, err\n   195â†’\t\t}\n   196â†’\t}\n   197â†’\n   198â†’\treturn wf, nil\n   199â†’}\n   200â†’\n   201â†’func (p *Parser) parseWorkflowConfig(wf *domain.Workflow) error {\n   202â†’\tprefix := p.current.Literal // e.g. \"host\", \"container\"\n   203â†’\tline, col := p.current.Line, p.current.Col\n   204â†’\tp.advance() // consume prefix ident\n   205â†’\n   206â†’\t// Reject conflicting location blocks.\n   207â†’\tif prefix == \"host\" && wf.Config[\"_location_block\"] == \"container\" {\n   208â†’\t\treturn fmt.Errorf(\"line %d col %d: workflow %q has both \\\"host\\\" and \\\"container\\\" blocks\", line, col, wf.Name)\n   209â†’\t}\n   210â†’\tif prefix == \"container\" && wf.Config[\"_location_block\"] == \"host\" {\n   211â†’\t\treturn fmt.Errorf(\"line %d col %d: workflow %q has both \\\"host\\\" and \\\"container\\\" blocks\", line, col, wf.Name)\n   212â†’\t}\n   213â†’\n   214â†’\t// A \"host { ... }\" block marks this workflow as a host workflow.\n   215â†’\tif prefix == \"host\" {\n   216â†’\t\twf.Location = domain.LocationHost\n   217â†’\t}\n   218â†’\tif prefix == \"host\" || prefix == \"container\" {\n   219â†’\t\twf.Config[\"_location_block\"] = prefix\n   220â†’\t}\n   221â†’\n   222â†’\tif _, err := p.expect(TokenLBrace); err != nil {\n   223â†’\t\treturn err\n   224â†’\t}\n   225â†’\n   226â†’\tfor p.current.Type != TokenRBrace && p.current.Type != TokenEOF {\n   227â†’\t\tkeyTok, err := p.expect(TokenIdent)\n   228â†’\t\tif err != nil {\n   229â†’\t\t\treturn fmt.Errorf(\"expected field name: %w\", err)\n   230â†’\t\t}\n   231â†’\n   232â†’\t\tif _, err := p.expect(TokenEquals); err != nil {\n   233â†’\t\t\treturn err\n   234â†’\t\t}\n   235â†’\n   236â†’\t\tval, err := p.parseValue()\n   237â†’\t\tif err != nil {\n   238â†’\t\t\treturn err\n   239â†’\t\t}\n   240â†’\n   241â†’\t\twf.Config[prefix+\".\"+keyTok.Literal] = val\n   242â†’\t}\n   243â†’\n   244â†’\tif _, err := p.expect(TokenRBrace); err != nil {\n   245â†’\t\treturn err\n   246â†’\t}\n   247â†’\n   248â†’\treturn nil\n   249â†’}\n   250â†’\n   251â†’func (p *Parser) parseAgent() (*domain.Agent, error) {\n   252â†’\tp.advance() // consume \"agent\"\n   253â†’\n   254â†’\tnameTok, err := p.expect(TokenIdent)\n   255â†’\tif err != nil {\n   256â†’\t\treturn nil, fmt.Errorf(\"expected agent name: %w\", err)\n   257â†’\t}\n   258â†’\n   259â†’\tif _, err := p.expect(TokenLBrace); err != nil {\n   260â†’\t\treturn nil, err\n   261â†’\t}\n   262â†’\n   263â†’\tagent := &domain.Agent{Name: nameTok.Literal}\n   264â†’\n   265â†’\tfor p.current.Type != TokenRBrace && p.current.Type != TokenEOF {\n   266â†’\t\tkeyTok, err := p.expect(TokenIdent)\n   267â†’\t\tif err != nil {\n   268â†’\t\t\treturn nil, fmt.Errorf(\"expected field name in agent block: %w\", err)\n   269â†’\t\t}\n   270â†’\n   271â†’\t\tif _, err := p.expect(TokenEquals); err != nil {\n   272â†’\t\t\treturn nil, err\n   273â†’\t\t}\n   274â†’\n   275â†’\t\tval, err := p.parseValue()\n   276â†’\t\tif err != nil {\n   277â†’\t\t\treturn nil, err\n   278â†’\t\t}\n   279â†’\n   280â†’\t\tswitch keyTok.Literal {\n   281â†’\t\tcase \"command\":\n   282â†’\t\t\tagent.Command = val\n   283â†’\t\tcase \"args\":\n   284â†’\t\t\tagent.Args = val\n   285â†’\t\tdefault:\n   286â†’\t\t\treturn nil, fmt.Errorf(\"line %d col %d: unknown agent field %q (expected \\\"command\\\" or \\\"args\\\")\",\n   287â†’\t\t\t\tkeyTok.Line, keyTok.Col, keyTok.Literal)\n   288â†’\t\t}\n   289â†’\t}\n   290â†’\n   291â†’\tif _, err := p.expect(TokenRBrace); err != nil {\n   292â†’\t\treturn nil, err\n   293â†’\t}\n   294â†’\n   295â†’\tif agent.Command == \"\" {\n   296â†’\t\treturn nil, fmt.Errorf(\"agent %q: \\\"command\\\" is required\", agent.Name)\n   297â†’\t}\n   298â†’\n   299â†’\treturn agent, nil\n   300â†’}\n   301â†’\n   302â†’func (p *Parser) parseStep() (*domain.Step, error) {\n   303â†’\tp.advance() // consume \"step\"\n   304â†’\n   305â†’\tnameTok, err := p.expect(TokenIdent)\n   306â†’\tif err != nil {\n   307â†’\t\treturn nil, fmt.Errorf(\"expected step name: %w\", err)\n   308â†’\t}\n   309â†’\n   310â†’\tif _, err := p.expect(TokenLBrace); err != nil {\n   311â†’\t\treturn nil, err\n   312â†’\t}\n   313â†’\n   314â†’\tstep := &domain.Step{\n   315â†’\t\tName:   nameTok.Literal,\n   316â†’\t\tConfig: make(map[string]string),\n   317â†’\t}\n   318â†’\n   319â†’\tfor p.current.Type != TokenRBrace && p.current.Type != TokenEOF {\n   320â†’\t\tif err := p.parseStepField(step, \"\"); err != nil {\n   321â†’\t\t\treturn nil, err\n   322â†’\t\t}\n   323â†’\t}\n   324â†’\n   325â†’\tif _, err := p.expect(TokenRBrace); err != nil {\n   326â†’\t\treturn nil, err\n   327â†’\t}\n   328â†’\n   329â†’\t// Infer step type from content\n   330â†’\t_, hasPrompt := step.Config[\"prompt\"]\n   331â†’\t_, hasRun := step.Config[\"run\"]\n   332â†’\t_, hasWorkflowName := step.Config[\"workflow_name\"]\n   333â†’\n   334â†’\tcount := 0\n   335â†’\tif hasPrompt {\n   336â†’\t\tcount++\n   337â†’\t}\n   338â†’\tif hasRun {\n   339â†’\t\tcount++\n   340â†’\t}\n   341â†’\tif hasWorkflowName {\n   342â†’\t\tcount++\n   343â†’\t}\n   344â†’\n   345â†’\tif count > 1 {\n   346â†’\t\treturn nil, fmt.Errorf(\"step %q has multiple of 'prompt', 'run', 'workflow_name'; must have exactly one\", step.Name)\n   347â†’\t}\n   348â†’\n   349â†’\tswitch {\n   350â†’\tcase hasPrompt:\n   351â†’\t\tstep.Type = domain.StepTypeAgent\n   352â†’\tcase hasRun:\n   353â†’\t\tstep.Type = domain.StepTypeScript\n   354â†’\tcase hasWorkflowName:\n   355â†’\t\tstep.Type = domain.StepTypeWorkflow\n   356â†’\tdefault:\n   357â†’\t\treturn nil, fmt.Errorf(\"step %q has none of 'prompt', 'run', or 'workflow_name'; must have exactly one\", step.Name)\n   358â†’\t}\n   359â†’\n   360â†’\treturn step, nil\n   361â†’}\n   362â†’\n   363â†’func (p *Parser) parseStepField(step *domain.Step, prefix string) error {\n   364â†’\tkeyTok, err := p.expect(TokenIdent)\n   365â†’\tif err != nil {\n   366â†’\t\treturn fmt.Errorf(\"expected field name: %w\", err)\n   367â†’\t}\n   368â†’\n   369â†’\tkey := keyTok.Literal\n   370â†’\tif prefix != \"\" {\n   371â†’\t\tkey = prefix + \".\" + key\n   372â†’\t}\n   373â†’\n   374â†’\t// Sub-block (e.g., container { ... })\n   375â†’\tif p.current.Type == TokenLBrace {\n   376â†’\t\tp.advance() // consume {\n   377â†’\t\tfor p.current.Type != TokenRBrace && p.current.Type != TokenEOF {\n   378â†’\t\t\tif err := p.parseStepField(step, key); err != nil {\n   379â†’\t\t\t\treturn err\n   380â†’\t\t\t}\n   381â†’\t\t}\n   382â†’\t\tp.advance() // consume }\n   383â†’\t\treturn nil\n   384â†’\t}\n   385â†’\n   386â†’\tif _, err := p.expect(TokenEquals); err != nil {\n   387â†’\t\treturn err\n   388â†’\t}\n   389â†’\n   390â†’\tif key == \"results\" {\n   391â†’\t\tresults, err := p.parseIdentList()\n   392â†’\t\tif err != nil {\n   393â†’\t\t\treturn err\n   394â†’\t\t}\n   395â†’\t\tstep.Results = results\n   396â†’\t} else if p.current.Type == TokenLBracket {\n   397â†’\t\tvalues, err := p.parseStringList()\n   398â†’\t\tif err != nil {\n   399â†’\t\t\treturn err\n   400â†’\t\t}\n   401â†’\t\tstep.Config[key] = strings.Join(values, \",\")\n   402â†’\t} else {\n   403â†’\t\tval, err := p.parseValue()\n   404â†’\t\tif err != nil {\n   405â†’\t\t\treturn err\n   406â†’\t\t}\n   407â†’\t\tstep.Config[key] = val\n   408â†’\t}\n   409â†’\n   410â†’\treturn nil\n   411â†’}\n   412â†’\n   413â†’func (p *Parser) parseIdentList() ([]string, error) {\n   414â†’\tif _, err := p.expect(TokenLBracket); err != nil {\n   415â†’\t\treturn nil, err\n   416â†’\t}\n   417â†’\n   418â†’\tvar items []string\n   419â†’\tfor p.current.Type != TokenRBracket && p.current.Type != TokenEOF {\n   420â†’\t\ttok, err := p.expect(TokenIdent)\n   421â†’\t\tif err != nil {\n   422â†’\t\t\treturn nil, err\n   423â†’\t\t}\n   424â†’\t\titems = append(items, tok.Literal)\n   425â†’\t\tif p.current.Type == TokenComma {\n   426â†’\t\t\tp.advance()\n   427â†’\t\t}\n   428â†’\t}\n   429â†’\n   430â†’\tif _, err := p.expect(TokenRBracket); err != nil {\n   431â†’\t\treturn nil, err\n   432â†’\t}\n   433â†’\n   434â†’\treturn items, nil\n   435â†’}\n   436â†’\n   437â†’func (p *Parser) parseStringList() ([]string, error) {\n   438â†’\tif _, err := p.expect(TokenLBracket); err != nil {\n   439â†’\t\treturn nil, err\n   440â†’\t}\n   441â†’\n   442â†’\tvar items []string\n   443â†’\tfor p.current.Type != TokenRBracket && p.current.Type != TokenEOF {\n   444â†’\t\ttok, err := p.expect(TokenString)\n   445â†’\t\tif err != nil {\n   446â†’\t\t\treturn nil, err\n   447â†’\t\t}\n   448â†’\t\titems = append(items, tok.Literal)\n   449â†’\t\tif p.current.Type == TokenComma {\n   450â†’\t\t\tp.advance()\n   451â†’\t\t}\n   452â†’\t}\n   453â†’\n   454â†’\tif _, err := p.expect(TokenRBracket); err != nil {\n   455â†’\t\treturn nil, err\n   456â†’\t}\n   457â†’\n   458â†’\treturn items, nil\n   459â†’}\n   460â†’\n   461â†’func (p *Parser) parseValue() (string, error) {\n   462â†’\tif p.current.Type == TokenString {\n   463â†’\t\ttok := p.current\n   464â†’\t\tp.advance()\n   465â†’\t\treturn tok.Literal, nil\n   466â†’\t}\n   467â†’\n   468â†’\tif p.current.Type == TokenInt {\n   469â†’\t\ttok := p.current\n   470â†’\t\tp.advance()\n   471â†’\t\treturn tok.Literal, nil\n   472â†’\t}\n   473â†’\n   474â†’\tif p.current.Type == TokenIdent {\n   475â†’\t\tvar buf strings.Builder\n   476â†’\t\tbuf.WriteString(p.current.Literal)\n   477â†’\t\tp.advance()\n   478â†’\n   479â†’\t\t// Function call: file(\"...\")\n   480â†’\t\tif p.current.Type == TokenLParen {\n   481â†’\t\t\tbuf.WriteRune('(')\n   482â†’\t\t\tp.advance()\n   483â†’\t\t\tfor p.current.Type != TokenRParen && p.current.Type != TokenEOF {\n   484â†’\t\t\t\tif p.current.Type == TokenString {\n   485â†’\t\t\t\t\tbuf.WriteRune('\"')\n   486â†’\t\t\t\t\tbuf.WriteString(p.current.Literal)\n   487â†’\t\t\t\t\tbuf.WriteRune('\"')\n   488â†’\t\t\t\t} else {\n   489â†’\t\t\t\t\tbuf.WriteString(p.current.Literal)\n   490â†’\t\t\t\t}\n   491â†’\t\t\t\tp.advance()\n   492â†’\t\t\t}\n   493â†’\t\t\tbuf.WriteRune(')')\n   494â†’\t\t\tp.advance() // consume )\n   495â†’\t\t}\n   496â†’\n   497â†’\t\t// Dotted path: step.code.output\n   498â†’\t\tfor p.current.Type == TokenDot {