{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018LG7bUZF2ksW1Yecw9GCmA","type":"tool_result","content":"952-\n953-func TestParser_NumericMaxAttempts(t *testing.T) {\n954-\tinput := `workflow \"retry\" {\n955-  step code {\n956-    prompt = \"write code\"\n957:    max_attempts = 3\n958-    results = [success, fail, give-up]\n959-  }\n960-  code:success -> done\n961-  code:fail -> code\n962-  code:give-up -> abort\n--\n965-\twf, err := dsl.Parse(input)\n966-\trequire.NoError(t, err)\n967-\n968-\tcode := wf.Steps[\"code\"]\n969-\trequire.NotNil(t, code)\n970:\tassert.Equal(t, \"3\", code.Config[\"max_attempts\"])\n971-}"}]},"parent_tool_use_id":"toolu_01DQc8VGBbBzwbeq56rksjAq","session_id":"d1afb603-fabd-44b7-80c6-1c61044982a2","uuid":"7cc1b5f4-4a57-4704-9ecc-7d619d850fe5","timestamp":"2026-03-17T15:12:25.665Z"}
