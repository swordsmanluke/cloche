{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NTJ1MdaWLRRv9SVefMiWZt","type":"tool_result","content":"     1â†’package domain\n     2â†’\n     3â†’import (\n     4â†’\t\"encoding/json\"\n     5â†’\t\"fmt\"\n     6â†’\t\"strings\"\n     7â†’)\n     8â†’\n     9â†’const (\n    10â†’\tStepDone  = \"done\"\n    11â†’\tStepAbort = \"abort\"\n    12â†’)\n    13â†’\n    14â†’type StepType string\n    15â†’\n    16â†’const (\n    17â†’\tStepTypeAgent    StepType = \"agent\"\n    18â†’\tStepTypeScript   StepType = \"script\"\n    19â†’\tStepTypeWorkflow StepType = \"workflow\"\n    20â†’)\n    21â†’\n    22â†’// WorkflowLocation indicates where a workflow is intended to run.\n    23â†’type WorkflowLocation string\n    24â†’\n    25â†’const (\n    26â†’\t// LocationContainer is for workflows that run inside a Docker container.\n    27â†’\t// This is the default for workflows without a \"host { }\" block.\n    28â†’\tLocationContainer WorkflowLocation = \"container\"\n    29â†’\n    30â†’\t// LocationHost is for workflows that run on the host machine.\n    31â†’\t// A workflow declares itself as host by including a \"host { }\" block.\n    32â†’\tLocationHost WorkflowLocation = \"host\"\n    33â†’)\n    34â†’\n    35â†’type Step struct {\n    36â†’\tName    string\n    37â†’\tType    StepType\n    38â†’\tResults []string\n    39â†’\tConfig  map[string]string\n    40â†’}\n    41â†’\n    42â†’type Wire struct {\n    43â†’\tFrom      string\n    44â†’\tResult    string\n    45â†’\tTo        string\n    46â†’\tOutputMap []OutputMapping\n    47â†’}\n    48â†’\n    49â†’type SegmentKind int\n    50â†’\n    51â†’const (\n    52â†’\tSegmentField SegmentKind = iota\n    53â†’\tSegmentIndex\n    54â†’)\n    55â†’\n    56â†’type PathSegment struct {\n    57â†’\tKind  SegmentKind\n    58â†’\tField string // for SegmentField\n    59â†’\tIndex int    // for SegmentIndex\n    60â†’}\n    61â†’\n    62â†’type OutputPath struct {\n    63â†’\tSegments []PathSegment\n    64â†’}\n    65â†’\n    66â†’type OutputMapping struct {\n    67â†’\tEnvVar string\n    68â†’\tPath   OutputPath\n    69â†’}\n    70â†’\n    71â†’// Evaluate navigates the raw output bytes using the path segments.\n    72â†’// With no segments, it returns the raw output as a string.\n    73â†’// With segments, it parses the raw bytes as JSON and navigates using\n    74â†’// field access (SegmentField) and array indexing (SegmentIndex).\n    75â†’func (p OutputPath) Evaluate(raw []byte) (string, error) {\n    76â†’\tif len(p.Segments) == 0 {\n    77â†’\t\treturn string(raw), nil\n    78â†’\t}\n    79â†’\n    80â†’\tvar val any\n    81â†’\tif err := json.Unmarshal(raw, &val); err != nil {\n    82â†’\t\treturn \"\", fmt.Errorf(\"output is not valid JSON\")\n    83â†’\t}\n    84â†’\n    85â†’\tfor _, seg := range p.Segments {\n    86â†’\t\tswitch seg.Kind {\n    87â†’\t\tcase SegmentField:\n    88â†’\t\t\tm, ok := val.(map[string]any)\n    89â†’\t\t\tif !ok {\n    90â†’\t\t\t\treturn \"\", fmt.Errorf(\"expected object for .%s\", seg.Field)\n    91â†’\t\t\t}\n    92â†’\t\t\tval, ok = m[seg.Field]\n    93â†’\t\t\tif !ok {\n    94â†’\t\t\t\treturn \"\", fmt.Errorf(\"field %q not found\", seg.Field)\n    95â†’\t\t\t}\n    96â†’\t\tcase SegmentIndex:\n    97â†’\t\t\tarr, ok := val.([]any)\n    98â†’\t\t\tif !ok {\n    99â†’\t\t\t\treturn \"\", fmt.Errorf(\"expected array for [%d]\", seg.Index)\n   100â†’\t\t\t}\n   101â†’\t\t\tif seg.Index < 0 || seg.Index >= len(arr) {\n   102â†’\t\t\t\treturn \"\", fmt.Errorf(\"index %d out of range (len %d)\", seg.Index, len(arr))\n   103â†’\t\t\t}\n   104â†’\t\t\tval = arr[seg.Index]\n   105â†’\t\t}\n   106â†’\t}\n   107â†’\n   108â†’\tswitch v := val.(type) {\n   109â†’\tcase string:\n   110â†’\t\treturn v, nil\n   111â†’\tdefault:\n   112â†’\t\tb, _ := json.Marshal(v)\n   113â†’\t\treturn string(b), nil\n   114â†’\t}\n   115â†’}\n   116â†’\n   117â†’type CollectMode string\n   118â†’\n   119â†’const (\n   120â†’\tCollectAll CollectMode = \"all\"\n   121â†’\tCollectAny CollectMode = \"any\"\n   122â†’)\n   123â†’\n   124â†’type WireCondition struct {\n   125â†’\tStep   string\n   126â†’\tResult string\n   127â†’}\n   128â†’\n   129â†’type Collect struct {\n   130â†’\tMode       CollectMode\n   131â†’\tConditions []WireCondition\n   132â†’\tTo         string\n   133â†’}\n   134â†’\n   135â†’// Agent declares a named agent with a command and arguments.\n   136â†’// Steps reference agents by identifier via the \"agent\" config key.\n   137â†’type Agent struct {\n   138â†’\tName    string\n   139â†’\tCommand string\n   140â†’\tArgs    string\n   141â†’}\n   142â†’\n   143â†’type Workflow struct {\n   144â†’\tName      string\n   145â†’\tLocation  WorkflowLocation  // host or container\n   146â†’\tSteps     map[string]*Step\n   147â†’\tAgents    map[string]*Agent // declared agents, keyed by identifier\n   148â†’\tWiring    []Wire\n   149â†’\tCollects  []Collect\n   150â†’\tEntryStep string\n   151â†’\tConfig    map[string]string // workflow-level config (e.g. \"container.image\")\n   152â†’}\n   153â†’\n   154â†’func (w *Workflow) Validate() error {\n   155â†’\tif w.EntryStep == \"\" {\n   156â†’\t\treturn fmt.Errorf(\"workflow %q: no entry step defined\", w.Name)\n   157â†’\t}\n   158â†’\tif _, ok := w.Steps[w.EntryStep]; !ok {\n   159â†’\t\treturn fmt.Errorf(\"workflow %q: entry step %q not found\", w.Name, w.EntryStep)\n   160â†’\t}\n   161â†’\n   162â†’\twired := make(map[string]map[string]bool)\n   163â†’\treachable := map[string]bool{w.EntryStep: true}\n   164â†’\tfor _, wire := range w.Wiring {\n   165â†’\t\tif wired[wire.From] == nil {\n   166â†’\t\t\twired[wire.From] = make(map[string]bool)\n   167â†’\t\t}\n   168â†’\t\twired[wire.From][wire.Result] = true\n   169â†’\t\tif wire.To != StepDone && wire.To != StepAbort {\n   170â†’\t\t\treachable[wire.To] = true\n   171â†’\t\t}\n   172â†’\t}\n   173â†’\n   174â†’\t// Validate collects and count their results as wired\n   175â†’\tfor _, c := range w.Collects {\n   176â†’\t\t// Validate target step exists\n   177â†’\t\tif c.To != StepDone && c.To != StepAbort {\n   178â†’\t\t\tif _, ok := w.Steps[c.To]; !ok {\n   179â†’\t\t\t\treturn fmt.Errorf(\"workflow %q: collect target step %q not found\", w.Name, c.To)\n   180â†’\t\t\t}\n   181â†’\t\t\treachable[c.To] = true\n   182â†’\t\t}\n   183â†’\n   184â†’\t\tfor _, cond := range c.Conditions {\n   185â†’\t\t\t// Validate condition step exists\n   186â†’\t\t\tstep, ok := w.Steps[cond.Step]\n   187â†’\t\t\tif !ok {\n   188â†’\t\t\t\treturn fmt.Errorf(\"workflow %q: collect references unknown step %q\", w.Name, cond.Step)\n   189â†’\t\t\t}\n   190â†’\t\t\t// Validate condition result is declared\n   191â†’\t\t\tfound := false\n   192â†’\t\t\tfor _, r := range step.Results {\n   193â†’\t\t\t\tif r == cond.Result {\n   194â†’\t\t\t\t\tfound = true\n   195â†’\t\t\t\t\tbreak\n   196â†’\t\t\t\t}\n   197â†’\t\t\t}\n   198â†’\t\t\tif !found {\n   199â†’\t\t\t\treturn fmt.Errorf(\"workflow %q: collect references undeclared result %q on step %q\", w.Name, cond.Result, cond.Step)\n   200â†’\t\t\t}\n   201â†’\t\t\t// Mark as wired so the \"every result must be wired\" check passes\n   202â†’\t\t\tif wired[cond.Step] == nil {\n   203â†’\t\t\t\twired[cond.Step] = make(map[string]bool)\n   204â†’\t\t\t}\n   205â†’\t\t\twired[cond.Step][cond.Result] = true\n   206â†’\t\t}\n   207â†’\t}\n   208â†’\n   209â†’\tfor name, step := range w.Steps {\n   210â†’\t\tfor _, result := range step.Results {\n   211â†’\t\t\tif !wired[name][result] {\n   212â†’\t\t\t\treturn fmt.Errorf(\"workflow %q: step %q result %q is not wired\", w.Name, name, result)\n   213â†’\t\t\t}\n   214â†’\t\t}\n   215â†’\t}\n   216â†’\n   217â†’\tfor name := range w.Steps {\n   218â†’\t\tif !reachable[name] {\n   219â†’\t\t\treturn fmt.Errorf(\"workflow %q: step %q is orphaned (unreachable)\", w.Name, name)\n   220â†’\t\t}\n   221â†’\t}\n   222â†’\n   223â†’\t// Check for duplicate output mapping env vars targeting the same step\n   224â†’\ttargetEnvVars := make(map[string]map[string]bool) // step -> env var -> seen\n   225â†’\tfor _, wire := range w.Wiring {\n   226â†’\t\tfor _, om := range wire.OutputMap {\n   227â†’\t\t\tif targetEnvVars[wire.To] == nil {\n   228â†’\t\t\t\ttargetEnvVars[wire.To] = make(map[string]bool)\n   229â†’\t\t\t}\n   230â†’\t\t\tif targetEnvVars[wire.To][om.EnvVar] {\n   231â†’\t\t\t\treturn fmt.Errorf(\"duplicate output mapping for env var %q targeting step %q\", om.EnvVar, wire.To)\n   232â†’\t\t\t}\n   233â†’\t\t\ttargetEnvVars[wire.To][om.EnvVar] = true\n   234â†’\t\t}\n   235â†’\t}\n   236â†’\n   237â†’\t// Validate agent references\n   238â†’\tfor name, step := range w.Steps {\n   239â†’\t\tif agentRef, ok := step.Config[\"agent\"]; ok {\n   240â†’\t\t\tif len(w.Agents) == 0 || w.Agents[agentRef] == nil {\n   241â†’\t\t\t\treturn fmt.Errorf(\"workflow %q: step %q references undeclared agent %q\", w.Name, name, agentRef)\n   242â†’\t\t\t}\n   243â†’\t\t\tif step.Type != StepTypeAgent {\n   244â†’\t\t\t\treturn fmt.Errorf(\"workflow %q: step %q references agent %q but is not a prompt step\", w.Name, name, agentRef)\n   245â†’\t\t\t}\n   246â†’\t\t}\n   247â†’\t}\n   248â†’\n   249â†’\treturn nil\n   250â†’}\n   251â†’\n   252â†’// ResolveAgents expands agent references in steps to agent_command/agent_args config.\n   253â†’// Must be called after Validate to ensure references are valid.\n   254â†’func (w *Workflow) ResolveAgents() {\n   255â†’\tfor _, step := range w.Steps {\n   256â†’\t\tagentRef, ok := step.Config[\"agent\"]\n   257â†’\t\tif !ok {\n   258â†’\t\t\tcontinue\n   259â†’\t\t}\n   260â†’\t\tagent := w.Agents[agentRef]\n   261â†’\t\tif agent == nil {\n   262â†’\t\t\tcontinue\n   263â†’\t\t}\n   264â†’\t\t// Only set if not already explicitly overridden at step level\n   265â†’\t\tif _, has := step.Config[\"agent_command\"]; !has && agent.Command != \"\" {\n   266â†’\t\t\tstep.Config[\"agent_command\"] = agent.Command\n   267â†’\t\t}\n   268â†’\t\tif _, has := step.Config[\"agent_args\"]; !has && agent.Args != \"\" {\n   269â†’\t\t\tstep.Config[\"agent_args\"] = agent.Args\n   270â†’\t\t}\n   271â†’\t}\n   272â†’}\n   273â†’\n   274â†’// ValidateLocation checks that step types are compatible with the workflow location.\n   275â†’// workflow_name steps are only allowed in host workflows.\n   276â†’func (w *Workflow) ValidateLocation() error {\n   277â†’\tif w.Location == LocationContainer {\n   278â†’\t\tfor name, step := range w.Steps {\n   279â†’\t\t\tif step.Type == StepTypeWorkflow {\n   280â†’\t\t\t\treturn fmt.Errorf(\"workflow %q: step %q uses workflow_name, which is only allowed in host workflows (host.cloche)\", w.Name, name)\n   281â†’\t\t\t}\n   282â†’\t\t}\n   283â†’\t}\n   284â†’\treturn nil\n   285â†’}\n   286â†’\n   287â†’// knownStepConfigKeys lists recognized step-level config keys.\n   288â†’// Keys with a \"container.\" prefix are also allowed.\n   289â†’var knownStepConfigKeys = map[string]bool{\n   290â†’\t\"prompt\":        true,\n   291â†’\t\"run\":           true,\n   292â†’\t\"max_attempts\":  true,\n   293â†’\t\"timeout\":       true,\n   294â†’\t\"agent_command\": true,\n   295â†’\t\"agent_args\":    true,\n   296â†’\t\"agent\":         true,\n   297â†’\t\"results\":       true,\n   298â†’\t\"feedback\":      true,\n   299â†’\t\"workflow_name\": true,\n   300â†’\t\"prompt_step\":   true,\n   301â†’}\n   302â†’\n   303â†’// ValidateConfig checks step config keys against known keys and returns\n   304â†’// warnings for any unrecognized keys (likely typos).\n   305â†’func (w *Workflow) ValidateConfig() []string {\n   306â†’\tvar warnings []string\n   307â†’\tfor name, step := range w.Steps {\n   308â†’\t\tfor key := range step.Config {\n   309â†’\t\t\tif knownStepConfigKeys[key] {\n   310â†’\t\t\t\tcontinue\n   311â†’\t\t\t}\n   312â†’\t\t\tif strings.HasPrefix(key, \"container.\") || strings.HasPrefix(key, \"host.\") {\n   313â†’\t\t\t\tcontinue\n   314â†’\t\t\t}\n   315â†’\t\t\twarnings = append(warnings, fmt.Sprintf(\n   316â†’\t\t\t\t\"workflow %q: step %q has unrecognized config key %q\", w.Name, name, key))\n   317â†’\t\t}\n   318â†’\t}\n   319â†’\treturn warnings\n   320â†’}\n   321â†’\n   322â†’// NextSteps returns all target step names wired from the given (stepName, result) pair.\n   323â†’// Multiple targets indicate fanout â€” parallel branches launched by the engine.\n   324â†’func (w *Workflow) NextSteps(stepName, result string) ([]string, error) {\n   325â†’\tvar targets []string\n   326â†’\tfor _, wire := range w.Wiring {\n   327â†’\t\tif wire.From == stepName && wire.Result == result {\n   328â†’\t\t\ttargets = append(targets, wire.To)\n   329â†’\t\t}\n   330â†’\t}\n   331â†’\tif len(targets) == 0 {\n   332â†’\t\treturn nil, fmt.Errorf(\"workflow %q: no wiring for step %q result %q\", w.Name, stepName, result)\n   333â†’\t}\n   334â†’\treturn targets, nil\n   335â†’}\n   336â†’\n   337â†’// Deprecated: NextStep returns the first target only. Use NextSteps for fanout support.\n   338â†’func (w *Workflow) NextStep(stepName, result string) (string, error) {\n   339â†’\ttargets, err := w.NextSteps(stepName, result)\n   340â†’\tif err != nil {\n   341â†’\t\treturn \"\", err\n   342â†’\t}\n   343â†’\treturn targets[0], nil\n   344â†’}\n   345â†’"}]},"parent_tool_use_id":"toolu_01DQc8VGBbBzwbeq56rksjAq","session_id":"d1afb603-fabd-44b7-80c6-1c61044982a2","uuid":"438cdb60-d8b2-45bf-bd83-f5c16eeda55b","timestamp":"2026-03-17T15:12:22.317Z"}
