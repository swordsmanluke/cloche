g[key] = val\n   408→\t}\n   409→\n   410→\treturn nil\n   411→}\n   412→\n   413→func (p *Parser) parseIdentList() ([]string, error) {\n   414→\tif _, err := p.expect(TokenLBracket); err != nil {\n   415→\t\treturn nil, err\n   416→\t}\n   417→\n   418→\tvar items []string\n   419→\tfor p.current.Type != TokenRBracket && p.current.Type != TokenEOF {\n   420→\t\ttok, err := p.expect(TokenIdent)\n   421→\t\tif err != nil {\n   422→\t\t\treturn nil, err\n   423→\t\t}\n   424→\t\titems = append(items, tok.Literal)\n   425→\t\tif p.current.Type == TokenComma {\n   426→\t\t\tp.advance()\n   427→\t\t}\n   428→\t}\n   429→\n   430→\tif _, err := p.expect(TokenRBracket); err != nil {\n   431→\t\treturn nil, err\n   432→\t}\n   433→\n   434→\treturn items, nil\n   435→}\n   436→\n   437→func (p *Parser) parseStringList() ([]string, error) {\n   438→\tif _, err := p.expect(TokenLBracket); err != nil {\n   439→\t\treturn nil, err\n   440→\t}\n   441→\n   442→\tvar items []string\n   443→\tfor p.current.Type != TokenRBracket && p.current.Type != TokenEOF {\n   444→\t\ttok, err := p.expect(TokenString)\n   445→\t\tif err != nil {\n   446→\t\t\treturn nil, err\n   447→\t\t}\n   448→\t\titems = append(items, tok.Literal)\n   449→\t\tif p.current.Type == TokenComma {\n   450→\t\t\tp.advance()\n   451→\t\t}\n   452→\t}\n   453→\n   454→\tif _, err := p.expect(TokenRBracket); err != nil {\n   455→\t\treturn nil, err\n   456→\t}\n   457→\n   458→\treturn items, nil\n   459→}\n   460→\n   461→func (p *Parser) parseValue() (string, error) {\n   462→\tif p.current.Type == TokenString {\n   463→\t\ttok := p.current\n   464→\t\tp.advance()\n   465→\t\treturn tok.Literal, nil\n   466→\t}\n   467→\n   468→\tif p.current.Type == TokenInt {\n   469→\t\ttok := p.current\n   470→\t\tp.advance()\n   471→\t\treturn tok.Literal, nil\n   472→\t}\n   473→\n   474→\tif p.current.Type == TokenIdent {\n   475→\t\tvar buf strings.Builder\n   476→\t\tbuf.WriteString(p.current.Literal)\n   477→\t\tp.advanc