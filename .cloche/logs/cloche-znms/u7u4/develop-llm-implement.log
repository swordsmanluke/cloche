{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PLfGJuDYLSaHzkaQs1Cnan","type":"tool_result","content":"     1→// A workflow that demonstrates retry behavior.\n     2→// The test step is flaky - it fails the first time and passes on retry.\n     3→workflow \"flaky-retry\" {\n     4→  step setup {\n     5→    run = \"echo Setting up && echo 0 > attempt_count\"\n     6→    results = [success, fail]\n     7→  }\n     8→\n     9→  step build {\n    10→    run = \"echo Building && echo built > artifact.txt\"\n    11→    results = [success, fail]\n    12→  }\n    13→\n    14→  step test {\n    15→    // Increment counter, fail if count < 2 (simulates flaky test)\n    16→    run = \"count=$(cat attempt_count) && count=$((count + 1)) && echo $count > attempt_count && echo Test attempt $count && test $count -ge 2\"\n    17→    results = [success, fail]\n    18→  }\n    19→\n    20→  setup:success -> build\n    21→  setup:fail -> abort\n    22→\n    23→  build:success -> test\n    24→  build:fail -> abort\n    25→\n    26→  // On test failure, retry from build\n    27→  test:success -> done\n    28→  test:fail -> build\n    29→}\n    30→"}]},"parent_tool_use_id":"toolu_01Ja6MAmcqkw1V2CRxLtyQWk","session_id":"67739637-8b0c-489f-8c14-18b6ea4cc169","uuid":"b3f9654a-99bd-43a6-834e-9c8a7789aee0","timestamp":"2026-03-17T14:54:32.221Z"}
