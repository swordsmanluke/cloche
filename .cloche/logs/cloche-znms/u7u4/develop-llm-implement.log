flow {\n   280→\t\t\t\treturn fmt.Errorf(\"workflow %q: step %q uses workflow_name, which is only allowed in host workflows (host.cloche)\", w.Name, name)\n   281→\t\t\t}\n   282→\t\t}\n   283→\t}\n   284→\treturn nil\n   285→}\n   286→\n   287→// knownStepConfigKeys lists recognized step-level config keys.\n   288→// Keys with a \"container.\" prefix are also allowed.\n   289→var knownStepConfigKeys = map[string]bool{\n   290→\t\"prompt\":        true,\n   291→\t\"run\":           true,\n   292→\t\"max_attempts\":  true,\n   293→\t\"timeout\":       true,\n   294→\t\"agent_command\": true,\n   295→\t\"agent_args\":    true,\n   296→\t\"agent\":         true,\n   297→\t\"results\":       true,\n   298→\t\"feedback\":      true,\n   299→\t\"workflow_name\": true,\n   300→\t\"prompt_step\":   true,\n   301→}\n   302→\n   303→// ValidateConfig checks step config keys against known keys and returns\n   304→// warnings for any unrecognized keys (likely typos).\n   305→func (w *Workflow) ValidateConfig() []string {\n   306→\tvar warnings []string\n   307→\tfor name, step := range w.Steps {\n   308→\t\tfor key := range step.Config {\n   309→\t\t\tif knownStepConfigKeys[key] {\n   310→\t\t\t\tcontinue\n   311→\t\t\t}\n   312→\t\t\tif strings.HasPrefix(key, \"container.\") || strings.HasPrefix(key, \"host.\") {\n   313→\t\t\t\tcontinue\n   314→\t\t\t}\n   315→\t\t\twarnings = append(warnings, fmt.Sprintf(\n   316→\t\t\t\t\"workflow %q: step %q has unrecognized config key %q\", w.Name, name, key))\n   317→\t\t}\n   318→\t}\n   319→\treturn warnings\n   320→}\n   321→\n   322→// NextSteps returns all target step names wired from the given (stepName, result) pair.\n   323→// Multiple targets indicate fanout — parallel branches launched by the engine.\n   324→func (w *Workflow) NextSteps(stepName, result string) ([]string, error) {\n   325→\tvar targets []string\n   326→\tfor _, wire := range w.Wiring {\n   327→\t\tif wire.From == stepName && wire.Result == result {\n   328→\t\t\ttargets = append(targets, wire.To)\n   329→\t\t}\n   330→\t}\n   331→\tif len(targets) == 0 {\n   332→\t\treturn nil, fmt.Errorf(\"workflow %q: no wiring for step %q result %q\", w.Name, stepName, result)\n   333→\t}\n   334→\treturn targets, nil\n   335→}\n   336→\n   337→// Deprecated: NextStep returns the first target only. Use NextSteps for fanout support.\n   338→func (w *Workflow) NextStep(stepName, result string) (string, error) {\n   339→\ttargets, err := w.NextSteps(stepName, result)\n   340→\tif err != nil {\n   341→\t\treturn \"\", err\n   342→\t}\n   343→\treturn targets[0], nil\n   344→}\n   345→"}]},"parent_tool_use_id":"toolu_01Ja6MAmcqkw1V2CRxLtyQWk","session_id":"67739637-8b0c-489f-8c14-18b6ea4cc169","uuid":"e45a4336-43ce-4846-8409-733196080935","timestamp":"2026-03-17T14:54:12.419Z"}
