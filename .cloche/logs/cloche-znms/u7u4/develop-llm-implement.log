{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018CuEByVzKsyPwyNEWRgg5r","type":"tool_result","content":"     1→package domain_test\n     2→\n     3→import (\n     4→\t\"testing\"\n     5→\n     6→\t\"github.com/cloche-dev/cloche/internal/domain\"\n     7→\t\"github.com/stretchr/testify/assert\"\n     8→\t\"github.com/stretchr/testify/require\"\n     9→)\n    10→\n    11→func TestWorkflow_Validate_ValidGraph(t *testing.T) {\n    12→\twf := &domain.Workflow{\n    13→\t\tName: \"test-workflow\",\n    14→\t\tSteps: map[string]*domain.Step{\n    15→\t\t\t\"code\": {\n    16→\t\t\t\tName:    \"code\",\n    17→\t\t\t\tType:    domain.StepTypeAgent,\n    18→\t\t\t\tResults: []string{\"success\", \"fail\"},\n    19→\t\t\t},\n    20→\t\t\t\"check\": {\n    21→\t\t\t\tName:    \"check\",\n    22→\t\t\t\tType:    domain.StepTypeScript,\n    23→\t\t\t\tResults: []string{\"pass\", \"fail\"},\n    24→\t\t\t},\n    25→\t\t},\n    26→\t\tWiring: []domain.Wire{\n    27→\t\t\t{From: \"code\", Result: \"success\", To: \"check\"},\n    28→\t\t\t{From: \"code\", Result: \"fail\", To: domain.StepAbort},\n    29→\t\t\t{From: \"check\", Result: \"pass\", To: domain.StepDone},\n    30→\t\t\t{From: \"check\", Result: \"fail\", To: \"code\"},\n    31→\t\t},\n    32→\t\tEntryStep: \"code\",\n    33→\t}\n    34→\n    35→\terr := wf.Validate()\n    36→\tassert.NoError(t, err)\n    37→}\n    38→\n    39→func TestWorkflow_Validate_UnwiredResult(t *testing.T) {\n    40→\twf := &domain.Workflow{\n    41→\t\tName: \"test-workflow\",\n    42→\t\tSteps: map[string]*domain.Step{\n    43→\t\t\t\"code\": {\n    44→\t\t\t\tName:    \"code\",\n    45→\t\t\t\tType:    domain.StepTypeAgent,\n    46→\t\t\t\tResults: []string{\"success\", \"fail\"},\n    47→\t\t\t},\n    48→\t\t},\n    49→\t\tWiring: []domain.Wire{\n    50→\t\t\t{From: \"code\", Result: \"success\", To: domain.StepDone},"}]},"parent_tool_use_id":"toolu_01Ja6MAmcqkw1V2CRxLtyQWk","session_id":"67739637-8b0c-489f-8c14-18b