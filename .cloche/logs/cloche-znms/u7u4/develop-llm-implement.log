{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GukzLvecuQBSkXwjv921jL","type":"tool_result","content":"    50→\n    51→\tm := &Mutator{}\n    52→\tresult, err := m.AddStep(input, StepDef{\n    53→\t\tName:    \"review\",\n    54→\t\tType:    \"agent\",\n    55→\t\tConfig:  map[string]string{\"prompt\": `file(\"prompts/review.md\")`, \"max_attempts\": `2`},\n    56→\t\tResults: []string{\"success\", \"fail\", \"give-up\"},\n    57→\t})\n    58→\trequire.NoError(t, err)\n    59→\tassert.Contains(t, result, \"step review\")\n    60→\tassert.Contains(t, result, `prompt = file(\"prompts/review.md\")`)\n    61→\tassert.Contains(t, result, `max_attempts = 2`)\n    62→\n    63→\twf, err := Parse(result)\n    64→\trequire.NoError(t, err)\n    65→\tassert.Contains(t, wf.Steps, \"review\")\n    66→\tassert.Equal(t, \"agent\", string(wf.Steps[\"review\"].Type))\n    67→}\n    68→\n    69→func TestMutatorAddWiring(t *testing.T) {\n    70→\tinput := `workflow \"develop\" {\n    71→  step test {\n    72→    run = \"make test\"\n    73→    results = [success, fail]\n    74→  }\n    75→\n    76→  step scan {\n    77→    run = \"gosec ./...\"\n    78→    results = [success, fail]\n    79→  }"}]},"parent_tool_use_id":"toolu_01Ja6MAmcqkw1V2CRxLtyQWk","session_id":"67739637-8b0c-489f-8c14-18b6ea4cc169","uuid":"05687a06-96c9-4fe5-aa4c-cc66c34cae58","timestamp":"2026-03-17T14:54:25.624Z"}
