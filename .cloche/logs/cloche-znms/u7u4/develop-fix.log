 \"evolved prompt\",\n    57→\t\tGeneration: 3,\n    58→\t\tParentID:   \"c-1\",\n    59→\t}\n    60→\tassert.Equal(t, 3, c.Generation)\n    61→\tassert.Equal(t, \"c-1\", c.ParentID)\n    62→}\n    63→\n    64→func TestFitnessRecordJSON(t *testing.T) {\n    65→\tfr := FitnessRecord{\n    66→\t\tCandidateID: \"c-1\",\n    67→\t\tRunID:       \"run-abc\",\n    68→\t\tScore:       0.95,\n    69→\t\tDetails:     \"all tests passed\",\n    70→\t}\n    71→\n    72→\tdata, err := json.Marshal(fr)\n    73→\trequire.NoError(t, err)\n    74→\n    75→\tvar decoded FitnessRecord\n    76→\trequire.NoError(t, json.Unmarshal(data, &decoded))\n    77→\tassert.Equal(t, fr.CandidateID, decoded.CandidateID)\n    78→\tassert.Equal(t, fr.RunID, decoded.RunID)\n    79→\tassert.Equal(t, fr.Score, decoded.Score)\n    80→\tassert.Equal(t, fr.Details, decoded.Details)\n    81→}\n    82→\n    83→func TestFitnessRecordOmitsEmptyDetails(t *testing.T) {\n    84→\tfr := FitnessRecord{\n    85→\t\tCandidateID: \"c-1\",\n    86→\t\tRunID:       \"run-abc\",\n    87→\t\tScore:       0.5,\n    88→\t}\n    89→\n    90→\tdata, err := json.Marshal(fr)\n    91→\trequire.NoError(t, err)\n    92→\tassert.NotContains(t, string(data), \"details\")\n    93→}\n    94→\n    95→func TestFitnessScoresJSON(t *testing.T) {\n    96→\tfs := FitnessScores{\n    97→\t\tTotal:   10.0,\n    98→\t\tCount:   4,\n    99→\t\tAverage: 2.5,\n   100→\t\tScores:  map[string]float64{\"accuracy\": 0.9, \"speed\": 0.8},\n   101→\t}\n   102→\n   103→\tdata, err := json.Marshal(fs)\n   104→\trequire.NoError(t, err)\n   105→\n   106→\tvar decoded FitnessScores\n   107→\trequire.NoError(t, json.Unmarshal(data, &decoded))\n   108→\tassert.Equal(t, fs.Total, decoded.Total)\n   109→\tassert.Equal(t, fs.Count, decoded.Count)\n   110→\tassert.Equal(t, fs.Average, decoded.Average)\n   111→\tassert.Equal(t, 0.9, decoded.Scores[\"accuracy\"])\n   112→\tassert.Equal(t, 0.8, decoded.Scores[\"speed\"])\n   113→}\n   114→\n   115→func TestFitnessS