{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018DwxaUfsxreWvEhQ5mnSuN","type":"tool_result","content":"     1→package dsl\n     2→\n     3→import (\n     4→\t\"fmt\"\n     5→\t\"strconv\"\n     6→\t\"strings\"\n     7→\n     8→\t\"github.com/cloche-dev/cloche/internal/domain\"\n     9→)\n    10→\n    11→type Parser struct {\n    12→\tlexer    *Lexer\n    13→\tcurrent  Token\n    14→\tpeek     Token\n    15→\tlocation domain.WorkflowLocation\n    16→}\n    17→\n    18→// ParseOption configures the parser.\n    19→type ParseOption func(*Parser)\n    20→\n    21→// WithLocation sets the workflow location, enabling location-based validation.\n    22→func WithLocation(loc domain.WorkflowLocation) ParseOption {\n    23→\treturn func(p *Parser) {\n    24→\t\tp.location = loc\n    25→\t}\n    26→}\n    27→\n    28→func Parse(input string, opts ...ParseOption) (*domain.Workflow, error) {\n    29→\tp := &Parser{lexer: NewLexer(input)}\n    30→\tfor _, opt := range opts {\n    31→\t\topt(p)\n    32→\t}\n    33→\tp.advance() // load current\n    34→\tp.advance() // load peek\n    35→\treturn p.parseWorkflow()\n    36→}\n    37→\n    38→// ParseForHost parses a host.cloche file containing a single workflow.\n    39→func ParseForHost(input string) (*domain.Workflow, error) {\n    40→\treturn Parse(input, WithLocation(domain.LocationHost))\n    41→}\n    42→\n    43→// ParseAllForHost parses a host.cloche file that may contain multiple workflows.\n    44→// Returns a map of workflow name to workflow definition.\n    45→func ParseAllForHost(input string) (map[string]*domain.Workflow, error) {\n    46→\tp := &Parser{lexer: NewLexer(input), location: domain.LocationHost}\n    47→\tp.advance() // load current\n    48→\tp.advance() // load peek\n    49→\n    50→\tworkflows := make(map[string]*domain.Workflow)\n    51→\tfor p.current.Type != TokenEOF {\n    52→\t\twf, err := p.parseWorkflow()\n    53→\t\tif err != nil {\n    54→\t\t\treturn nil, err\n    55→\t\t}\n    56→\t\tif _, exists := workflows[wf.Name]; exists {\n    57→\t\t\treturn nil, fmt.Errorf(\"duplicate workflow name %q\", wf.Name)\n    58→\t\t}\n    59→\t\tworkflows[wf.Name] = wf\n    60→\t}\n    61→\n    62→\tif len(workflows) == 0 {\n    63→\t\treturn nil, fmt.Errorf(\"no workflows found in host.cloche\")\n    64→\t}\n    65→\n    66→\treturn workflows, nil\n    67→}\n    68→\n    69→// ParseForContainer parses a container workflow file.\n    70→func ParseForContainer(input string) (*domain.Workflow, error) {\n    71→\treturn Parse(input, WithLocation(domain.LocationContainer))\n    72→}\n    73→\n    74→// ParseAll parses a .cloche file that may contain multiple workflows.\n    75→// Workflows default to LocationContainer but a \"host { }\" block overrides\n    76→// the location to LocationHost, so any .cloche file can define host workflows.\n    77→func ParseAll(input string) (map[string]*domain.Workflow, error) {\n    78→\tp := &Parser{lexer: NewLexer(input), location: domain.LocationContainer}\n    79→\tp.advance() // load current\n    80→\tp.advance() // load peek\n    81→\n    82→\tworkflows := make(map[string]*domain.Workflow)\n    83→\tfor p.current.Type != TokenEOF {\n    84→\t\twf, err := p.parseWorkflow()\n    85→\t\tif err != nil {\n    86→\t\t\treturn nil, err\n    87→\t\t}\n    88→\t\tif _, exists := workflows[wf.Name]; exists {\n    89→\t\t\treturn nil, fmt.Errorf(\"duplicate workflow name %q\", wf.Name)\n    90→\t\t}\n    91→\t\tworkflows[wf.Name] = wf\n    92→\t}\n    93→\n    94→\tif len(workflows) == 0 {\n    95→\t\treturn nil, fmt.Errorf(\"no workflows found\")\n    96→\t}\n    97→\n    98→\treturn workflows, nil\n    99→}\n   100→\n   101→func (p *Parser) advance() {\n   102→\tp.current = p.peek\n   103→\tp.peek = p.lexer.NextToken()\n   104→}\n   105→\n   106→func (p *Parser) expect(typ TokenType) (Token, error) {\n   107→\tif p.current.Type != typ {\n   108→\t\treturn p.current, fmt.Errorf(\"line %d col %d: expected %v, got %v (%q)\",\n   109→\t\t\tp.current.Line, p.current.Col, typ, p.current.Type, p.current.Literal)\n   110→\t}\n   111→\ttok := p.current\n   112→\tp.advance()\n   113→\treturn tok, nil\n   114→}\n   115→\n   116→func (p *Parser) expectIdent(value string) (Token, error) {\n   117→\tif p.current.Type != TokenIdent || p.current.Literal != value {\n   118→\t\treturn p.current, fmt.Errorf(\"line %d col %d: expected %q, got %q\",\n   119→\t\t\tp.current.Line, p.current.Col, value, p.current.Literal)\n   120→\t}\n   121→\ttok := p.current\n   122→\tp.advance()\n   123→\treturn tok, nil\n   124→}\n   125→\n   126→func (p *Parser) parseWorkflow() (*domain.Workflow, error) {\n   127→\tif _, err := p.expectIdent(\"workflow\"); err != nil {\n   128→\t\treturn nil, err\n   129→\t}\n   130→\n   131→\tnameTok, err := p.expect(TokenString)\n   132→\tif err != nil {\n   133→\t\treturn nil, fmt.Errorf(\"expected workflow name string: %w\", err)\n   134→\t}\n   135→\n   136→\tif _, err := p.expect(TokenLBrace); err != nil {\n   137→\t\treturn nil, err\n   138→\t}\n   139→\n   140→\twf := &domain.Workflow{\n   141→\t\tName:     nameTok.Literal,\n   142→\t\tLocation: p.location,\n   143→\t\tSteps:    make(map[string]*domain.Step),\n   144→\t\tAgents:   make(map[string]*domain.Agent),\n   145→\t\tConfig:   make(map[string]string),\n   146→\t}\n   147→\n   148→\tfor p.current.Type != TokenRBrace && p.current.Type != TokenEOF {\n   149→\t\tif p.current.Type == TokenIdent && p.current.Literal == \"agent\" && p.peek.Type == TokenIdent {\n   150→\t\t\tagent, err := p.parseAgent()\n   151→\t\t\tif err != nil {\n   152→\t\t\t\treturn nil, err\n   153→\t\t\t}\n   154→\t\t\tif _, exists := wf.Agents[agent.Name]; exists {\n   155→\t\t\t\treturn nil, fmt.Errorf(\"line %d: duplicate agent declaration %q\", p.current.Line, agent.Name)\n   156→\t\t\t}\n   157→\t\t\twf.Agents[agent.Name] = agent\n   158→\t\t} else if p.current.Type == TokenIdent && p.current.Literal == \"step\" {\n   159→\t\t\tstep, err := p.parseStep()\n   160→\t\t\tif err != nil {\n   161→\t\t\t\treturn nil, err\n   162→\t\t\t}\n   163→\t\t\twf.Steps[step.Name] = step\n   164→\t\t\tif wf.EntryStep == \"\" {\n   165→\t\t\t\twf.EntryStep = step.Name\n   166→\t\t\t}\n   167→\t\t} else if p.current.Type == TokenIdent && p.current.Literal == \"collect\" {\n   168→\t\t\tcollect, err := p.parseCollect()\n   169→\t\t\tif err != nil {\n   170→\t\t\t\treturn nil, err\n   171→\t\t\t}\n   172→\t\t\twf.Collects = append(wf.Collects, collect)\n   173→\t\t} else if p.current.Type == TokenIdent && p.peek.Type == TokenLBrace {\n   174→\t\t\tif err := p.parseWorkflowConfig(wf); err != nil {\n   175→\t\t\t\treturn nil, err\n   176→\t\t\t}\n   177→\t\t} else if p.current.Type == TokenIdent && p.peek.Type == TokenColon {\n   178→\t\t\twire, err := p.parseWire()\n   179→\t\t\tif err != nil {\n   180→\t\t\t\treturn nil, err\n   181→\t\t\t}\n   182→\t\t\twf.Wiring = append(wf.Wiring, wire)\n   183→\t\t} else {\n   184→\t\t\treturn nil, fmt.Errorf(\"line %d col %d: unexpected token %q\", p.current.Line, p.current.Col, p.current.Literal)\n   185→\t\t}\n   186→\t}\n   187→\n   188→\tif _, err := p.expect(TokenRBrace); err != nil {\n   189→\t\treturn nil, err\n   190→\t}\n   191→\n   192→\tif wf.Location != \"\" {\n   193→\t\tif err := wf.ValidateLocation(); err != nil {\n   194→\t\t\treturn nil, err\n   195→\t\t}\n   196→\t}\n   197→\n   198→\treturn wf, nil\n   199→}\n   200→\n   201→func (p *Parser) parseWorkflowConfig(wf *domain.Workflow) error {\n   202→\tprefix := p.current.Literal // e.g. \"host\", \"container\"\n   203→\tline, col := p.current.Line, p.current.Col\n   204→\tp.advance() // consume prefix ident\n   205→\n   206→\t// Reject conflicting location blocks.\n   207→\tif prefix == \"host\" && wf.Config[\"_location_block\"] == \"container\" {\n   208→\t\treturn fmt.Errorf(\"line %d col %d: workflow %q has both \\\"host\\\" and \\\"container\\\" blocks\", line, col, wf.Name)\n   209→\t}\n   210→\tif prefix == \"container\" && wf.Config[\"_location_block\"] == \"host\" {\n   211→\t\treturn fmt.Errorf(\"line %d col %d: workflow %q has both \\\"host\\\" and \\\"container\\\" blocks\", line, col, wf.Name)\n   212→\t}\n   213→\n   214→\t// A \"host { ... }\" block marks this workflow as a host workflow.\n   215→\tif prefix == \"host\" {\n   216→\t\twf.Location = domain.LocationHost\n   217→\t}\n   218→\tif prefix == \"host\" || prefix == \"container\" {\n   219→\t\twf.Config[\"_location_block\"] = prefix\n   220→\t}\n   221→\n   222→\tif _, err := p.expect(TokenLBrace); err != nil {\n   223→\t\treturn err\n   224→\t}\n   225→\n   226→\tfor p.current.Type != TokenRBrace && p.current.Type != TokenEOF {\n   227→\t\tkeyTok, err := p.expect(TokenIdent)\n   228→\t\tif err != nil {\n   229→\t\t\treturn fmt.Errorf(\"expected field name: %w\", err)\n   230→\t\t}\n   231→\n   232→\t\tif _, err := p.expect(TokenEquals); err != nil {\n   233→\t\t\treturn err\n   234→\t\t}\n   235→\n   236→\t\tval, err := p.parseValue()\n   237→\t\tif err != nil {\n   238→\t\t\treturn err\n   239→\t\t}\n   240→\n   241→\t\twf.Config[prefix+\".\"+keyTok.Literal] = val\n   242→\t}\n   243→\n   244→\tif _, err := p.expect(TokenRBrace); err != nil {\n   245→\t\treturn err\n   246→\t}\n   247→\n   248→\treturn nil\n   249→}\n   250→\n   251→func (p *Parser) parseAgent() (*domain.Agent, error) {\n   252→\tp.advance() // consume \"agent\"\n   253→\n   254→\tnameTok, err := p.expect(TokenIdent)\n   255→\tif err != nil {\n   256→\t\treturn nil, fmt.Errorf(\"expected agent name: %w\", err)\n   257→\t}\n   258→\n   259→\tif _, err := p.expect(TokenLBrace); err != nil {\n   260→\t\treturn nil, err\n   261→\t}\n   262→\n   263→\tagent := &domain.Agent{Name: nameTok.Literal}\n   264→\n   265→\tfor p.current.Type != TokenRBrace && p.current.Type != TokenEOF {\n   266→\t\tkeyTok, err := p.expect(TokenIdent)\n   267→\t\tif err != nil {\n   268→\t\t\treturn nil, fmt.Errorf(\"expected field name in agent block: %w\", err)\n   269→\t\t}\n   270→\n   271→\t\tif _, err := p.expect(TokenEquals); err != nil {\n   272→\t\t\treturn nil, err\n   273→\t\t}\n   274→\n   275→\t\tval, err := p.parseValue()\n   276→\t\tif err != nil {\n   277→\t\t\treturn nil, err\n   278→\t\t}\n   279→\n   280→\t\tswitch keyTok.Literal {\n   281→\t\tcase \"command\":\n   282→\t\t\tagent.Command = val\n   283→\t\tcase \"args\":\n   284→\t\t\tagent.Args = val\n   285→\t\tdefault:\n   286→\t\t\treturn nil, fmt.Errorf(\"line %d col %d: unknown agent field %q (expected \\\"command\\\" or \\\"args\\\")\",\n   287→\t\t\t\tkeyTok.Line, keyTok.Col, keyTok.Literal)\n   288→\t\t}\n   289→\t}\n   290→\n   291→\tif _, err := p.expect(TokenRBrace); err != nil {\n   292→\t\treturn nil, err\n   293→\t}\n   294→\n   295→\tif agent.Command == \"\" {\n   296→\t\treturn nil, fmt.Errorf(\"agent %q: \\\"command\\\" is required\", agent.Name)\n   297→\t}\n   298→\n   299→\treturn agent, nil\n   300→}\n   301→\n   302→func (p *Parser) parseStep() (*domain.Step, error) {\n   303→\tp.advance() // consume \"step\"\n   304→\n   305→\tnameTok, err := p.expect(TokenIdent)\n   306→\tif err != nil {\n   307→\t\treturn nil, fmt.Errorf(\"expected step name: %w\", err)\n   308→\t}\n   309→\n   310→\tif _, err := p.expect(TokenLBrace); err != nil {\n   311→\t\treturn nil, err\n   312→\t}\n   313→\n   314→\tstep := &domain.Step{\n   315→\t\tName:   nameTok.Literal,\n   316→\t\tConfig: make(map[string]string),\n   317→\t}\n   318→\n   319→\tfor p.current.Type != TokenRBrace && p.current.Type != TokenEOF {\n   320→\t\tif err := p.parseStepField(step, \"\"); err != nil {\n   321→\t\t\treturn nil, err\n   322→\t\t}\n   323→\t}\n   324→\n   325→\tif _, err := p.expect(TokenRBrace); err != nil {\n   326→\t\treturn nil, err\n   327→\t}\n   328→\n   329→\t// Infer step type from content\n   330→\t_, hasPrompt := step.Config[\"prompt\"]\n   331→\t_, hasRun := step.Config[\"run\"]\n   332→\t_, hasWorkflowName := step.Config[\"workflow_name\"]\n   333→\n   334→\tcount := 0\n   335→\tif hasPrompt {\n   336→\t\tcount++\n   337→\t}\n   338→\tif hasRun {\n   339→\t\tcount++\n   340→\t}\n   341→\tif hasWorkflowName {\n   342→\t\tcount++\n   343→\t}\n   344→\n   345→\tif count > 1 {\n   346→\t\treturn nil, fmt.Errorf(\"step %q has multiple of 'prompt', 'run', 'workflow_name'; must have exactly one\", step.Name)\n   347→\t}\n   348→\n   349→\tswitch {\n   350→\tcase hasPrompt:\n   351→\t\tstep.Type = domain.StepTypeAgent\n   352→\tcase hasRun:\n   353→\t\tstep.Type = domain.StepTypeScript\n   354→\tcase hasWorkflowName:\n   355→\t\tstep.Type = domain.StepTypeWorkflow\n   356→\tdefault:\n   357→\t\treturn nil, fmt.Errorf(\"step %q has none of 'prompt', 'run', or 'workflow_name'; must have exactly one\", step.Name)\n   358→\t}\n   359→\n   360→\treturn step, nil\n   361→}\n   362→\n   363→func (p *Parser) parseStepField(step *domain.Step, prefix string) error {\n   364→\tkeyTok, err := p.expect(TokenIdent)\n   365→\tif err != nil {\n   366→\t\treturn fmt.Errorf(\"expected field name: %w\", err)\n   367→\t}\n   368→\n   369→\tkey := keyTok.Literal\n   370→\tif prefix != \"\" {\n   371→\t\tkey = prefix + \".\" + key\n   372→\t}\n   373→\n   374→\t// Sub-block (e.g., container { ... })\n   375→\tif p.current.Type == TokenLBrace {\n   376→\t\tp.advance() // consume {\n   377→\t\tfor p.current.Type != TokenRBrace && p.current.Type != TokenEOF {\n   378→\t\t\tif err := p.parseStepField(step, key); err != nil {\n   379→\t\t\t\treturn err\n   380→\t\t\t}\n   381→\t\t}\n   382→\t\tp.advance() // consume }\n   383→\t\treturn nil\n   384→\t}\n   385→\n   386→\tif _, err := p.expect(TokenEquals); err != nil {\n   387→\t\treturn err\n   388→\t}\n   389→\n   390→\tif key == \"results\" {\n   391→\t\tresults, err := p.parseIdentList()\n   392→\t\tif err != nil {\n   393→\t\t\treturn err\n   394→\t\t}\n   395→\t\tstep.Results = results\n   396→\t} else if p.current.Type == TokenLBracket {\n   397→\t\tvalues, err := p.parseStringList()\n   398→\t\tif err != nil {\n   399→\t\t\treturn err\n   400→\t\t}\n   401→\t\tstep.Config[key] = strings.Join(values, \",\")\n   402→\t} else {\n   403→\t\t// max_attempts and timeout must be numeric values, not strings.\n   404→\t\tif key == \"max_attempts\" || key == \"timeout\" {\n   405→\t\t\tif p.current.Type != TokenInt {\n   406→\t\t\t\treturn fmt.Errorf(\"line %d col %d: %s must be a numeric value, not a string (use %s = 3, not %s = \\\"3\\\")\",\n   407→\t\t\t\t\tp.current.Line, p.current.Col, key, key, key)\n   408→\t\t\t}\n   409→\t\t}\n   410→\t\tval, err := p.parseValue()\n   411→\t\tif err != nil {\n   412→\t\t\treturn err\n   413→\t\t}\n   414→\t\tstep.Config[key] = val\n   415→\t}\n   416→\n   417→\treturn nil\n   418→}\n   419→\n   420→func (p *Parser) parseIdentList() ([]string, error) {\n   421→\tif _, err := p.expect(TokenLBracket); err != nil {\n   422→\t\treturn nil, err\n   423→\t}\n   424→\n   425→\tvar items []string\n   426→\tfor p.current.Type != TokenRBracket && p.current.Type != TokenEOF {\n   427→\t\ttok, err := p.expect(TokenIdent)\n   428→\t\tif err != nil {\n   429→\t\t\treturn nil, err\n   430→\t\t}\n   431→\t\titems = append(items, tok.Literal)\n   432→\t\tif p.current.Type == TokenComma {\n   433→\t\t\tp.advance()\n   434→\t\t}\n   435→\t}\n   436→\n   437→\tif _, err := p.expect(TokenRBracket); err != nil {\n   438→\t\treturn nil, err\n   439→\t}\n   440→\n   441→\treturn items, nil\n   442→}\n   443→\n   444→func (p *Parser) parseStringList() ([]string, error) {\n   445→\tif _, err := p.expect(TokenLBracket); err != nil {\n   446→\t\treturn nil, err\n   447→\t}\n   448→\n   449→\tvar items []string\n   450→\tfor p.current.Type != TokenRBracket && p.current.Type != TokenEOF {\n   451→\t\ttok, err := p.expect(TokenString)\n   452→\t\tif err != nil {\n   453→\t\t\treturn nil, err\n   454→\t\t}\n   455→\t\titems = append(items, tok.Literal)\n   456→\t\tif p.current.Type == TokenComma {\n   457→\t\t\tp.advance()\n   458→\t\t}\n   459→\t}\n   460→\n