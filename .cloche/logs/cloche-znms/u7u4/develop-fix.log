{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011jaWpPK5Hvy3XEBDuXwbTJ","type":"tool_result","content":"     1→package dsl_test\n     2→\n     3→import (\n     4→\t\"testing\"\n     5→\n     6→\t\"github.com/cloche-dev/cloche/internal/domain\"\n     7→\t\"github.com/cloche-dev/cloche/internal/dsl\"\n     8→\t\"github.com/stretchr/testify/assert\"\n     9→\t\"github.com/stretchr/testify/require\"\n    10→)\n    11→\n    12→func TestParser_FullWorkflow(t *testing.T) {\n    13→\tinput := `workflow \"implement-feature\" {\n    14→  step code {\n    15→    prompt = file(\"prompts/implement.md\")\n    16→    results = [success, fail, retry_with_feedback]\n    17→  }\n    18→\n    19→  step check {\n    20→    run = \"make test && make lint\"\n    21→    results = [pass, fail]\n    22→  }\n    23→\n    24→  code:success -> check\n    25→  code:fail -> abort\n    26→  code:retry_with_feedback -> code\n    27→\n    28→  check:pass -> done\n    29→  check:fail -> code\n    30→}`\n    31→\n    32→\twf, err := dsl.Parse(input)\n    33→\trequire.NoError(t, err)\n    34→\n    35→\tassert.Equal(t, \"implement-feature\", wf.Name)\n    36→\tassert.Len(t, wf.Steps, 2)\n    37→\n    38→\tcode := wf.Steps[\"code\"]\n    39→\trequire.NotNil(t, code)\n    40→\tassert.Equal(t, domain.StepTypeAgent, code.Type)\n    41→\tassert.Equal(t, []string{\"success\", \"fail\", \"retry_with_feedback\"}, code.Results)\n    42→\tassert.Equal(t, `file(\"prompts/implement.md\")`, code.Config[\"prompt\"])\n    43→\n    44→\tcheck := wf.Steps[\"check\"]\n    45→\trequire.NotNil(t, check)\n    46→\tassert.Equal(t, domain.StepTypeScript, check.Type)\n    47→\tassert.Equal(t, \"make test && make lint\", check.Config[\"run\"])\n    48→\n    49→\tassert.Len(t, wf.Wiring, 5)\n    50→\tassert.Equal(t, \"code\", wf.EntryStep)\n    51→}\n    52→\n    53→func TestParser_MinimalWorkflow(t *testing.T) {\n    54→\tinput := `workflow \"simple\" {\n    55→  step build {\n    56→    run = \"make build\"\n    57→    results = [success, fail]\n    58→  }\n    59→\n    60→  build:success -> done\n    61→  build:fail -> abort\n    62→}`\n    63→\n    64→\twf, err := dsl.Parse(input)\n    65→\trequire.NoError(t, err)\n    66→\tassert.Equal(t, \"simple\", wf.Name)\n    67→\tassert.Equal(t, \"build\", wf.EntryStep)\n    68→}\n    69→\n    70→func TestParser_SyntaxError(t *testing.T) {\n    71→\tinput := `workflow { }`\n    72→\t_, err := dsl.Parse(input)\n    73→\tassert.Error(t, err)\n    74→}\n    75→\n    76→func TestParser_ContainerBlock(t *testing.T) {\n    77→\tinput := `workflow \"test\" {\n    78→  step code {\n    79→    prompt = \"do something\"\n    80→    container {\n    81→      image = \"cloche/agent:latest\"\n    82→      network_allow = [\"docs.python.org\", \"internal.example.com\"]\n    83→    }\n    84→    results = [success]\n    85→  }\n    86→  code:success -> done\n    87→}`\n    88→\n    89→\twf, err := dsl.Parse(input)\n    90→\trequire.NoError(t, err)\n    91→\n    92→\tcode := wf.Steps[\"code\"]\n    93→\tassert.Equal(t, \"cloche/agent:latest\", code.Config[\"container.image\"])\n    94→\tassert.Equal(t, \"docs.python.org,internal.example.com\", code.Config[\"container.network_allow\"])\n    95→}\n    96→\n    97→func TestParser_WorkflowContainerBlock(t *testing.T) {\n    98→\tinput := `workflow \"with-image\" {\n    99→  container {\n   100→    image = \"myregistry/myimage:v2\"\n   101→  }\n   102→\n   103→  step code {\n   104→    prompt = \"write code\"\n   105→    results = [success, fail]\n   106→  }\n   107→\n   108→  code:success -> done\n   109→  code:fail -> abort\n   110→}`\n   111→\n   112→\twf, err := dsl.Parse(input)\n   113→\trequire.NoError(t, err)\n   114→\tassert.Equal(t, \"with-image\", wf.Name)\n   115→\tassert.Equal(t, \"myregistry/myimage:v2\", wf.Config[\"container.image\"])\n   116→}\n   117→\n   118→func TestParser_WorkflowContainerBlockMultipleFields(t *testing.T) {\n   119→\tinput := `workflow \"full-config\" {\n   120→  container {\n   121→    image = \"myregistry/myimage:v2\"\n   122→    memory = \"4g\"\n   123→  }\n   124→\n   125→  step code {\n   126→    prompt = \"write code\"\n   127→    results = [success]\n   128→  }\n   129→\n   130→  code:success -> done\n   131→}`\n   132→\n   133→\twf, err := dsl.Parse(input)\n   134→\trequire.NoError(t, err)\n   135→\tassert.Equal(t, \"myregistry/myimage:v2\", wf.Config[\"container.image\"])\n   136→\tassert.Equal(t, \"4g\", wf.Config[\"container.memory\"])\n   137→}\n   138→\n   139→func TestParser_WorkflowWithoutContainerBlock(t *testing.T) {\n   140→\tinput := `workflow \"no-container\" {\n   141→  step code {\n   142→    prompt = \"write code\"\n   143→    results = [success]\n   144→  }\n   145→\n   146→  code:success -> done\n   147→}`\n   148→\n   149→\twf, err := dsl.Parse(input)\n   150→\trequire.NoError(t, err)\n   151→\tassert.Empty(t, wf.Config[\"container.image\"])\n   152→}\n   153→\n   154→func TestParser_InfersTypeFromContent(t *testing.T) {\n   155→\tinput := `workflow \"infer\" {\n   156→  step build {\n   157→    run = \"make build\"\n   158→    results = [success]\n   159→  }\n   160→  step code {\n   161→    prompt = \"write code\"\n   162→    results = [success]\n   163→  }\n   164→  build:success -> code\n   165→  code:success -> done\n   166→}`\n   167→\n   168→\twf, err := dsl.Parse(input)\n   169→\trequire.NoError(t, err)\n   170→\tassert.Equal(t, domain.StepTypeScript, wf.Steps[\"build\"].Type)\n   171→\tassert.Equal(t, domain.StepTypeAgent, wf.Steps[\"code\"].Type)\n   172→}\n   173→\n   174→func TestParser_AmbiguousStepType(t *testing.T) {\n   175→\tinput := `workflow \"bad\" {\n   176→  step both {\n   177→    run = \"make test\"\n   178→    prompt = \"also a prompt\"\n   179→    results = [success]\n   180→  }\n   181→  both:success -> done\n   182→}`\n   183→\n   184→\t_, err := dsl.Parse(input)\n   185→\tassert.Error(t, err)\n   186→\tassert.Contains(t, err.Error(), \"both\")\n   187→}\n   188→\n   189→func TestParser_NoStepType(t *testing.T) {\n   190→\tinput := `workflow \"bad\" {\n   191→  step neither {\n   192→    results = [success]\n   193→  }\n   194→  neither:success -> done\n   195→}`\n   196→\n   197→\t_, err := dsl.Parse(input)\n   198→\tassert.Error(t, err)\n   199→\tassert.Contains(t, err.Error(), \"neither\")\n   200→}\n   201→\n   202→func TestParser_CollectAll(t *testing.T) {\n   203→\tinput := `workflow \"parallel\" {\n   204→  step code {\n   205→    prompt = \"write code\"\n   206→    results = [success]\n   207→  }\n   208→  step test {\n   209→    run = \"make test\"\n   210→    results = [success, fail]\n   211→  }\n   212→  step lint {\n   213→    run = \"make lint\"\n   214→    results = [success, fail]\n   215→  }\n   216→  step merge {\n   217→    run = \"echo merged\"\n   218→    results = [success]\n   219→  }\n   220→\n   221→  code:success -> test\n   222→  code:success -> lint\n   223→  test:fail -> abort\n   224→  lint:fail -> abort\n   225→  collect all(test:success, lint:success) -> merge\n   226→  merge:success -> done\n   227→}`\n   228→\n   229→\twf, err := dsl.Parse(input)\n   230→\trequire.NoError(t, err)\n   231→\n   232→\trequire.Len(t, wf.Collects, 1)\n   233→\tc := wf.Collects[0]\n   234→\tassert.Equal(t, domain.CollectAll, c.Mode)\n   235→\tassert.Equal(t, \"merge\", c.To)\n   236→\trequire.Len(t, c.Conditions, 2)\n   237→\tassert.Equal(t, \"test\", c.Conditions[0].Step)\n   238→\tassert.Equal(t, \"success\", c.Conditions[0].Result)\n   239→\tassert.Equal(t, \"lint\", c.Conditions[1].Step)\n   240→\tassert.Equal(t, \"success\", c.Conditions[1].Result)\n   241→}\n   242→\n   243→func TestParser_WorkflowNameStep(t *testing.T) {\n   244→\tinput := `workflow \"main\" {\n   245→  step prepare-prompt {\n   246→    run     = \"bash scripts/prepare.sh\"\n   247→    results = [success, fail]\n   248→  }\n   249→\n   250→  step develop {\n   251→    workflow_name = \"develop\"\n   252→    results       = [success, fail]\n   253→  }\n   254→\n   255→  prepare-prompt:success -> develop\n   256→  prepare-prompt:fail    -> abort\n   257→  develop:success        -> done\n   258→  develop:fail           -> done\n   259→}`\n   260→\n   261→\twf, err := dsl.Parse(input)\n   262→\trequire.NoError(t, err)\n   263→\n   264→\tassert.Equal(t, \"main\", wf.Name)\n   265→\tassert.Len(t, wf.Steps, 2)\n   266→\n   267→\tdevelop := wf.Steps[\"develop\"]\n   268→\trequire.NotNil(t, develop)\n   269→\tassert.Equal(t, domain.StepTypeWorkflow, develop.Type)\n   270→\tassert.Equal(t, \"develop\", develop.Config[\"workflow_name\"])\n   271→\tassert.Equal(t, []string{\"success\", \"fail\"}, develop.Results)\n   272→\n   273→\tpreparePrompt := wf.Steps[\"prepare-prompt\"]\n   274→\trequire.NotNil(t, preparePrompt)\n   275→\tassert.Equal(t, domain.StepTypeScript, preparePrompt.Type)\n   276→}\n   277→\n   278→func TestParser_WorkflowNameWithPromptStep(t *testing.T) {\n   279→\tinput := `workflow \"orch\" {\n   280→  step prep {\n   281→    run     = \"echo hello\"\n   282→    results = [success, fail]\n   283→  }\n   284→\n   285→  step dev {\n   286→    workflow_name = \"develop\"\n   287→    prompt_step   = \"prep\"\n   288→    results       = [success, fail]\n   289→  }\n   290→\n   291→  prep:success -> dev\n   292→  prep:fail    -> abort\n   293→  dev:success  -> done\n   294→  dev:fail     -> done\n   295→}`\n   296→\n   297→\twf, err := dsl.Parse(input)\n   298→\trequire.NoError(t, err)\n   299→\n   300→\tdev := wf.Steps[\"dev\"]\n   301→\trequire.NotNil(t, dev)\n   302→\tassert.Equal(t, domain.StepTypeWorkflow, dev.Type)\n   303→\tassert.Equal(t, \"prep\", dev.Config[\"prompt_step\"])\n   304→}\n   305→\n   306→func TestParser_WorkflowNameWithPromptErrors(t *testing.T) {\n   307→\tinput := `workflow \"bad\" {\n   308→  step both {\n   309→    workflow_name = \"develop\"\n   310→    prompt        = \"also a prompt\"\n   311→    results       = [success]\n   312→  }\n   313→  both:success -> done\n   314→}`\n   315→\n   316→\t_, err := dsl.Parse(input)\n   317→\tassert.Error(t, err)\n   318→\tassert.Contains(t, err.Error(), \"multiple\")\n   319→}\n   320→\n   321→func TestParser_WorkflowNameWithRunErrors(t *testing.T) {\n   322→\tinput := `workflow \"bad\" {\n   323→  step both {\n   324→    workflow_name = \"develop\"\n   325→    run           = \"make test\"\n   326→    results       = [success]\n   327→  }\n   328→  both:success -> done\n   329→}`\n   330→\n   331→\t_, err := dsl.Parse(input)\n   332→\tassert.Error(t, err)\n   333→\tassert.Contains(t, err.Error(), \"multiple\")\n   334→}\n   335→\n   336→func TestParser_CollectAny(t *testing.T) {\n   337→\tinput := `workflow \"race\" {\n   338→  step fast {\n   339→    run = \"echo fast\"\n   340→    results = [success]\n   341→  }\n   342→  step slow {\n   343→    run = \"sleep 1 && echo slow\"\n   344→    results = [success]\n   345→  }\n   346→  step next {\n   347→    run = \"echo next\"\n   348→    results = [success]\n   349→  }\n   350→\n   351→  collect any(fast:success, slow:success) -> next\n   352→  next:success -> done\n   353→}`\n   354→\n   355→\twf, err := dsl.Parse(input)\n   356→\trequire.NoError(t, err)\n   357→\n   358→\trequire.Len(t, wf.Collects, 1)\n   359→\tassert.Equal(t, domain.CollectAny, wf.Collects[0].Mode)\n   360→}\n   361→\n   362→func TestParseForHost_AllowsWorkflowSteps(t *testing.T) {\n   363→\tinput := `workflow \"main\" {\n   364→  step prepare {\n   365→    run     = \"bash scripts/prepare.sh\"\n   366→    results = [success, fail]\n   367→  }\n   368→  step develop {\n   369→    workflow_name = \"develop\"\n   370→    results       = [success, fail]\n   371→  }\n   372→  prepare:success -> develop\n   373→  prepare:fail    -> abort\n   374→  develop:success -> done\n   375→  develop:fail    -> done\n   376→}`\n   377→\twf, err := dsl.ParseForHost(input)\n   378→\trequire.NoError(t, err)\n   379→\tassert.Equal(t, domain.LocationHost, wf.Location)\n   380→\tassert.Equal(t, domain.StepTypeWorkflow, wf.Steps[\"develop\"].Type)\n   381→}\n   382→\n   383→func TestParseForContainer_RejectsWorkflowSteps(t *testing.T) {\n   384→\tinput := `workflow \"develop\" {\n   385→  step dispatch {\n   386→    workflow_name = \"implement\"\n   387→    results       = [success, fail]\n   388→  }\n   389→  dispatch:success -> done\n   390→  dispatch:fail    -> abort\n   391→}`\n   392→\t_, err := dsl.ParseForContainer(input)\n   393→\trequire.Error(t, err)\n   394→\tassert.Contains(t, err.Error(), \"workflow_name\")\n   395→\tassert.Contains(t, err.Error(), \"host workflows\")\n   396→}\n   397→\n   398→func TestParseForContainer_AllowsAgentAndScript(t *testing.T) {\n   399→\tinput := `workflow \"develop\" {\n   400→  step code {\n   401→    prompt = \"write code\"\n   402→    results = [success, fail]\n   403→  }\n   404→  step test {\n   405→    run = \"make test\"\n   406→    results = [pass, fail]\n   407→  }\n   408→  code:success -> test\n   409→  code:fail -> abort\n   410→  test:pass -> done\n   411→  test:fail -> code\n   412→}`\n   413→\twf, err := dsl.ParseForContainer(input)\n   414→\trequire.NoError(t, err)\n   415→\tassert.Equal(t, domain.LocationContainer, wf.Location)\n   416→}\n   417→\n   418→func TestParser_WireNoMappings(t *testing.T) {\n   419→\tinput := `workflow \"simple\" {\n   420→  step a {\n   421→    run = \"echo a\"\n   422→    results = [success]\n   423→  }\n   424→  a:success -> done\n   425→}`\n   426→\twf, err := dsl.Parse(input)\n   427→\trequire.NoError(t, err)\n   428→\trequire.Len(t, wf.Wiring, 1)\n   429→\tassert.Nil(t, wf.Wiring[0].OutputMap)\n   430→}\n   431→\n   432→func TestParser_WireSingleMapping(t *testing.T) {\n   433→\tinput := `workflow \"mapped\" {\n   434→  step a {\n   435→    run = \"echo a\"\n   436→    results = [success]\n   437→  }\n   438→  step b {\n   439→    run = \"echo b\"\n   440→    results = [success]\n   441→  }\n   442→  a:success -> b [ FOO = output.bar ]\n   443→  b:success -> done\n   444→}`\n   445→\twf, err := dsl.Parse(input)\n   446→\trequire.NoError(t, err)\n   447→\n   448→\twire := wf.Wiring[0]\n   449→\tassert.Equal(t, \"a\", wire.From)\n   450→\tassert.Equal(t, \"b\", wire.To)\n   451→\trequire.Len(t, wire.OutputMap, 1)\n   452→\tassert.Equal(t, \"FOO\", wire.OutputMap[0].EnvVar)\n   453→\trequire.Len(t, wire.OutputMap[0].Path.Segments, 1)\n   454→\tassert.Equal(t, domain.SegmentField, wire.OutputMap[0].Path.Segments[0].Kind)\n   455→\tassert.Equal(t, \"bar\", wire.OutputMap[0].Path.Segments[0].Field)\n   456→}\n   457→\n   458→func TestParser_WireMultipleMappings(t *testing.T) {\n   459→\tinput := `workflow \"mapped\" {\n   460→  step a {\n   461→    run = \"echo a\"\n   462→    results = [success]\n   463→  }\n   464→  step b {\n   465→    run = \"echo b\"\n   466→    results = [success]\n   467→  }\n   468→  a:success -> b [ X = output.a, Y = output.b ]\n   469→  b:success -> done\n   470→}`\n   471→\twf, err := dsl.Parse(input)\n   472→\trequire.NoError(t, err)\n   473→\n   474→\twire := wf.Wiring[0]\n   475→\trequire.Len(t, wire.OutputMap, 2)\n   476→\tassert.Equal(t, \"X\", wire.OutputMap[0].EnvVar)\n   477→\tassert.Equal(t, \"a\", wire.OutputMap[0].Path.Segments[0].Field)\n   478→\tassert.Equal(t, \"Y\", wire.OutputMap[1].EnvVar)\n   479→\tassert.Equal(t, \"b\", wire.OutputMap[1].Path.Segments[0].Field)\n   480→}\n   481→\n   482→func TestParser_WireArrayIndex(t *testing.T) {\n   483→\tinput := `workflow \"mapped\" {\n   484→  step a {\n   485→    run = \"echo a\"\n   486→    results = [success]\n   487→  }\n   488→  step b {\n   489→    run = \"echo b\"\n   490→    results = [success]\n   491→  }\n   492→  a:success -> b [ X = output[0].id ]\n   493→  b:success -> done\n   494→}`\n   495→\twf, err := dsl.Parse(input)\n   496→\trequire.NoError(t, err)\n   497→\n   498→\twire := wf.Wiring[0]\n   499→\trequire.Len(t, wire.OutputMap, 1)\n   500→\tsegs := wire.OutputMap[0].Path.Segments\n   501→\trequire.Len(t, segs, 2)\n   502→\tassert.Equal(t, domain.SegmentIndex, segs[0].Kind)\n   503→\tassert.Equal(t, 0, segs[0].Index)\n   504→\tassert.Equal(t, domain.SegmentField, segs[1].Kind)\n   505→\tassert.Equal(t, \"id\", segs[1].Field)\n   506→}\n   507→\n   508→func TestParser_WireNestedAccess(t *testing.T) {\n   509→\tinput := `workflow \"mapped\" {\n   510→  step a {\n   511→    run = \"echo a\"\n   512→    results = [success]\n   513→  }\n   514→  step b {\n   515→    run = \"echo b\"\n   516→    results = [success]\n   517→  }\n   518→  a:success -> b [ X = output.a.b.c ]\n   519→  b:success -> done\n   520→}`\n   521→\twf, err := dsl.Parse(input)\n   522→\trequire.NoError(t, err)\n   523→\n   524→\tsegs := wf.Wiring[0].OutputMap[0].Path.Segments\n   525→\trequire.Len(t, segs, 3)\n   526→\tassert.Equal(t, \"a\", segs[0].Field)\n   527→\tassert.Equal(t, \"b\", segs[1].Field)\n   528→\tassert.Equal(t, \"c\", segs[2].Field)\n   529→}\n   530→\n   531→func TestParser_WireChainedMixedAccess(t *testing.T) {\n   532→\tinput := `workflow \"mapped\" {\n   533→  step a {\n   534→    run = \"echo a\"\n   535→    results = [success]\n   536→  }\n   537→  step b {\n   538→    run = \"echo b\"\n   539→    results = [success]\n   540→  }\n   541→  a:success -> b [ X = output.items[0].name ]\n   542→  b:success -> done\n   543→}`\n   544→\twf, err := dsl.Parse(input)\n   545→\trequire.NoError(t, err)\n   546→\n   547→\tsegs := wf.Wiring[0].OutputMap[0].Path.Segments\n   548→\trequire.Len(t, segs, 3)\n   549→\tassert.Equal(t, domain.SegmentField, segs[0].Kind)\n   550→\tassert.Equal(t, \"items\", segs[0].Field)\n   551→\tassert.Equal(t, domain.SegmentIndex, segs[1].Kind)\n   552→\tassert.Equal(t, 0, segs[1].Index)\n   553→\tassert.Equal(t, domain.SegmentField, segs[2].Kind)\n   554→\tassert.Equal(t, \"name\", segs[2].Field)\n   555→}\n   556→\n   557→func TestParser_WireBareOutput(t *testing.T) {\n   558→\tinput := `workflow \"mapped\" {\n   559→  step a {\n   560→    run = \"echo a\"\n   561→    results = [success]\n   562→  }\n   563→  step b {\n   564→    run = \"echo b\"\n   565→    results = [success]\n   566→  }\n   567→  a:success -> b [ RAW = output ]\n   568→  b:success -> done\n   569→}`\n   570→\twf, err := dsl.Parse(input)\n   571→\trequire.NoError(t, err)\n   572→\n   573→\twire := wf.Wiring[0]\n   574→\trequire.Len(t, wire.OutputMap, 1)\n   575→\tassert.Equal(t, \"RAW\", wire.OutputMap[0].EnvVar)\n   576→\tassert.Empty(t, wire.OutputMap[0].Path.Segments)\n   577→}\n   578→\n   579→func TestParser_WireMappingErrorMissingOutput(t *testing.T) {\n   580→\tinput := `workflow \"bad\" {\n   581→  step a {\n   582→    run = \"echo a\"\n   583→    results = [success]\n   584→  }\n   585→  step b {\n   586→    run = \"echo b\"\n   587→    results = [success]\n   588→  }\n   589→  a:success -> b [ X = notoutput.foo ]\n   590→  b:success -> done\n   591→}`\n   592→\t_, err := dsl.Parse(input)\n   593→\trequire.Error(t, err)\n   594→\tassert.Contains(t, err.Error(), \"output\")\n   595→}\n   596→\n   597→func TestParser_WireMappingErrorMalformedPath(t *testing.T) {\n   598→\tinput := `workflow \"bad\" {\n   599→  step a {\n   600→    run = \"echo a\"\n   601→    results = [success]\n   602→  }\n   603→  step b {\n   604→    run = \"echo b\"\n   605→    results = [success]\n   606→  }\n   607→  a:success -> b [ X = output.\"bad\" ]\n   608→  b:success -> done\n   609→}`\n   610→\t_, err := dsl.Parse(input)\n   611→\trequire.Error(t, err)\n   612→}\n   613→\n   614→func TestParse_WithoutLocation_NoEnforcement(t *testing.T) {\n   615→\tinput := `workflow \"any\" {\n   616→  step dispatch {\n   617→    workflow_name = \"develop\"\n   618→    results       = [success]\n   619→  }\n   620→  dispatch:success -> done\n   621→}`\n   622→\t// Plain Parse (no location) should not enforce location constraints\n   623→\twf, err := dsl.Parse(input)\n   624→\trequire.NoError(t, err)\n   625→\tassert.Equal(t, domain.WorkflowLocation(\"\"), wf.Location)\n   626→}\n   627→\n   628→// --- ParseAllForHost tests ---\n   629→\n   630→func TestParseAllForHost_SingleWorkflow(t *testing.T) {\n   631→\tinput := `workflow \"main\" {\n   632→  step greet {\n   633→    run     = \"echo hi\"\n   634→    results = [success, fail]\n   635→  }\n   636→  greet:success -> done\n   637→  greet:fail    -> abort\n   638→}`\n   639→\tworkflows, err := dsl.ParseAllForHost(input)\n   640→\trequire.NoError(t, err)\n   641→\trequire.Len(t, workflows, 1)\n   642→\n   643→\twf, ok := workflows[\"main\"]\n   644→\trequire.True(t, ok)\n   645→\tassert.Equal(t, \"main\", wf.Name)\n   646→\tassert.Equal(t, domain.LocationHost, wf.Location)\n   647→}\n   648→\n   649→func TestParseAllForHost_MultipleWorkflows(t *testing.T) {\n   650→\tinput := `workflow \"list-tasks\" {\n   651→  step fetch {\n   652→    run     = \"bash scripts/list-tasks.sh\"\n   653→    results = [success, fail]\n   654→  }\n   655→  fetch:success -> done\n   656→  fetch:fail    -> abort\n   657→}\n   658→\n   659→workflow \"main\" {\n   660→  step prepare {\n   661→    run     = \"echo preparing\"\n   662→    results = [success, fail]\n   663→  }\n   664→  step develop {\n   665→    workflow_name = \"develop\"\n   666→    results       = [success, fail]\n   667→  }\n   668→  prepare:success -> develop\n   669→  prepare:fail    -> abort\n   670→  develop:success -> done\n   671→  develop:fail    -> abort\n   672→}\n   673→\n   674→workflow \"finalize\" {\n   675→  step cleanup {\n   676→    run     = \"echo cleanup\"\n   677→    results = [success, fail]\n   678→  }\n   679→  cleanup:success -> done\n   680→  cleanup:fail    -> abort\n   681→}`\n   682→\n   683→\tworkflows, err := dsl.ParseAllForHost(input)\n   684→\trequire.NoError(t, err)\n   685→\trequire.Len(t, workflows, 3)\n   686→\n   687→\t_, ok := workflows[\"list-tasks\"]\n   688→\tassert.True(t, ok, \"should have list-tasks workflow\")\n   689→\n   690→\t_, ok = workflows[\"main\"]\n   691→\tassert.True(t, ok, \"should have main workflow\")\n   692→\n   693→\t_, ok = workflows[\"finalize\"]\n   694→\tassert.True(t, ok, \"should have finalize workflow\")\n   695→}\n   696→\n   697→func TestParseAllForHost_DuplicateName(t *testing.T) {\n   698→\tinput := `workflow \"main\" {\n   699→  step a {\n   700→    run = \"echo a\"\n   701→    results = [success]\n   702→  }\n   703→  a:success -> done\n   704→}\n   705→workflow \"main\" {\n   706→  step b {\n   707→    run = \"echo b\"\n   708→    results = [success]\n   709→  }\n   710→  b:success -> done\n   711→}`\n   712→\n   713→\t_, err := dsl.ParseAllForHost(input)\n   714→\trequire.Error(t, err)\n   715→\tassert.Contains(t, err.Error(), \"duplicate workflow name\")\n   716→}\n   717→\n   718→func TestParseAllForHost_Empty(t *testing.T) {\n   719→\t_, err := dsl.ParseAllForHost(\"\")\n   720→\trequire.Error(t, err)\n   721→\tassert.Contains(t, err.Error(), \"no workflows found\")\n   722→}\n   723→\n   724→func TestParseAllForHost_AllHostLocation(t *testing.T) {\n   725→\tinput := `workflow \"list-tasks\" {\n   726→  step fetch {\n   727→    run = \"echo fetch\"\n   728→    results = [success]\n   729→  }\n   730→  fetch:success -> done\n   731→}\n   732→workflow \"main\" {\n   733→  step work {\n   734→    run = \"echo work\"\n   735→    results = [success]\n   736→  }\n   737→  work:success -> done\n   738→}`\n   739→\n   740→\tworkflows, err := dsl.ParseAllForHost(input)\n   741→\trequire.NoError(t, err)\n   742→\tfor name, wf := range workflows {\n   743→\t\tassert.Equal(t, domain.LocationHost, wf.Location, \"workflow %q should have host location\", name)\n   744→\t}\n   745→}\n   746→\n   747→func TestParseAll_HostBlockSetsLocation(t *testing.T) {\n   748→\tinput := `workflow \"main\" {\n   749→  host {\n   750→    agent_command = \"claude\"\n   751→  }\n   752→  step work {\n   753→    run = \"echo work\"\n   754→    results = [success]\n   755→  }\n   756→  work:success -> done\n   757→}`\n   758→\tworkflows, err := dsl.ParseAll(input)\n   759→\trequire.NoError(t, err)\n   760→\tassert.Equal(t, domain.LocationHost, workflows[\"main\"].Location)\n   761→}\n   762→\n   763→func TestParseAll_NoHostBlockDefaultsToContainer(t *testing.T) {\n   764→\tinput := `workflow \"build\" {\n   765→  step compile {\n   766→    run = \"make\"\n   767→    results = [success]\n   768→  }\n   769→  compile:success -> done\n   770→}`\n   771→\tworkflows, err := dsl.ParseAll(input)\n   772→\trequire.NoError(t, err)\n   773→\tassert.Equal(t, domain.LocationContainer, workflows[\"build\"].Location)\n   774→}\n   775→\n   776→func TestParse_RejectsHostAndContainerBlocks(t *testing.T) {\n   777→\tinput := `workflow \"bad\" {\n   778→  host {}\n   779→  container {\n   780→    image = \"foo\"\n   781→  }\n   782→  step work {\n   783→    run = \"echo work\"\n   784→    results = [success]\n   785→  }\n   786→  work:success -> done\n   787→}`\n   788→\t_, err := dsl.ParseAll(input)\n   789→\trequire.Error(t, err)\n   790→\tassert.Contains(t, err.Error(), \"both \\\"host\\\" and \\\"container\\\"\")\n   791→}\n   792→\n   793→// --- Agent declaration tests ---\n   794→\n   795→func TestParser_AgentDeclaration(t *testing.T) {\n   796→\tinput := `workflow \"develop\" {\n   797→  agent claude {\n   798→    command = \"claude\"\n   799→    args = \"-p --output-format stream-json\"\n   800→  }\n   801→\n   802→  step code {\n   803→    prompt = \"write code\"\n   804→    agent = claude\n   805→    results = [success, fail]\n   806→  }\n   807→\n   808→  code:success -> done\n   809→  code:fail -> abort\n   810→}`\n   811→\n   812→\twf, err := dsl.Parse(input)\n   813→\trequire.NoError(t, err)\n   814→\n   815→\trequire.Len(t, wf.Agents, 1)\n   816→\tagent := wf.Agents[\"claude\"]\n   817→\trequire.NotNil(t, agent)\n   818→\tassert.Equal(t, \"claude\", agent.Name)\n   819→\tassert.Equal(t, \"claude\", agent.Command)\n   820→\tassert.Equal(t, \"-p --output-format stream-json\", agent.Args)\n   821→\n   822→\tcode := wf.Steps[\"code\"]\n   823→\trequire.NotNil(t, code)\n   824→\tassert.Equal(t, \"claude\", code.Config[\"agent\"])\n   825→}\n   826→\n   827→func TestParser_MultipleAgents(t *testing.T) {\n   828→\tinput := `workflow \"develop\" {\n   829→  agent claude {\n   830→    command = \"claude\"\n   831→    args = \"-p --verbose\"\n   832→  }\n   833→\n   834→  agent codex {\n   835→    command = \"codex\"\n   836→    args = \"--full-auto\"\n   837→  }\n   838→\n   839→  step implement {\n   840→    prompt = \"implement the feature\"\n   841→    agent = claude\n   842→    results = [success, fail]\n   843→  }\n   844→\n   845→  step review {\n   846→    prompt = \"review the code\"\n   847→    agent = codex\n   848→    results = [success, fail]\n   849→  }\n   850→\n   851→  implement:success -> review\n   852→  implement:fail -> abort\n   853→  review:success -> done\n   854→  review:fail -> implement\n   855→}`\n   856→\n   857→\twf, err := dsl.Parse(input)\n   858→\trequire.NoError(t, err)\n   859→\n   860→\trequire.Len(t, wf.Agents, 2)\n   861→\tassert.Equal(t, \"claude\", wf.Agents[\"claude\"].Command)\n   862→\tassert.Equal(t, \"codex\", wf.Agents[\"codex\"].Command)\n   863→\n   864→\tassert.Equal(t, \"claude\", wf.Steps[\"implement\"].Config[\"agent\"])\n   865→\tassert.Equal(t, \"codex\", wf.Steps[\"review\"].Config[\"agent\"])\n   866→}\n   867→\n   868→func TestParser_AgentCommandOnly(t *testing.T) {\n   869→\tinput := `workflow \"simple\" {\n   870→  agent ollama {\n   871→    command = \"ollama\"\n   872→  }\n   873→\n   874→  step code {\n   875→    prompt = \"write code\"\n   876→    agent = ollama\n   877→    results = [success]\n   878→  }\n   879→\n   880→  code:success -> done\n   881→}`\n   882→\n   883→\twf, err := dsl.Parse(input)\n   884→\trequire.NoError(t, err)\n   885→\n   886→\tagent := wf.Agents[\"ollama\"]\n   887→\trequire.NotNil(t, agent)\n   888→\tassert.Equal(t, \"ollama\", agent.Command)\n   889→\tassert.Equal(t, \"\", agent.Args)\n   890→}\n   891→\n   892→func TestParser_AgentMissingCommand(t *testing.T) {\n   893→\tinput := `workflow \"bad\" {\n   894→  agent nocommand {\n   895→    args = \"--verbose\"\n   896→  }\n   897→\n   898→  step code {\n   899→    prompt = \"write\"\n   900→    results = [success]\n   901→  }\n   902→\n   903→  code:success -> done\n   904→}`\n   905→\n   906→\t_, err := dsl.Parse(input)\n   907→\trequire.Error(t, err)\n   908→\tassert.Contains(t, err.Error(), \"command\")\n   909→}\n   910→\n   911→func TestParser_DuplicateAgent(t *testing.T) {\n   912→\tinput := `workflow \"bad\" {\n   913→  agent claude {\n   914→    command = \"claude\"\n   915→  }\n   916→  agent claude {\n   917→    command = \"claude2\"\n   918→  }\n   919→\n   920→  step code {\n   921→    prompt = \"write\"\n   922→    results = [success]\n   923→  }\n   924→\n   925→  code:success -> done\n   926→}`\n   927→\n   928→\t_, err := dsl.Parse(input)\n   929→\trequire.Error(t, err)\n   930→\tassert.Contains(t, err.Error(), \"duplicate agent\")\n   931→}\n   932→\n   933→func TestParser_AgentUnknownField(t *testing.T) {\n   934→\tinput := `workflow \"bad\" {\n   935→  agent claude {\n   936→    command = \"claude\"\n   937→    unknown = \"value\"\n   938→  }\n   939→\n   940→  step code {\n   941→    prompt = \"write\"\n   942→    results = [success]\n   943→  }\n   944→\n   945→  code:success -> done\n   946→}`\n   947→\n   948→\t_, err := dsl.Parse(input)\n   949→\trequire.Error(t, err)\n   950→\tassert.Contains(t, err.Error(), \"unknown agent field\")\n   951→}\n   952→\n   953→func TestParser_NumericMaxAttempts(t *testing.T) {\n   954→\tinput := `workflow \"retry\" {\n   955→  step code {\n   956→    prompt = \"write code\"\n   957→    max_attempts = 3\n   958→    results = [success, fail, give-up]\n   959→  }\n   960→  code:success -> done\n   961→  code:fail -> code\n   962→  code:give-up -> abort\n   963→}`\n   964→\n   965→\twf, err := dsl.Parse(input)\n   966→\trequire.NoError(t, err)\n   967→\n   968→\tcode := wf.Steps[\"code\"]\n   969→\trequire.NotNil(t, code)\n   970→\tassert.Equal(t, \"3\", code.Config[\"max_attempts\"])\n   971→}\n   972→\n   973→func TestParser_MaxAttemptsRejectsString(t *testing.T) {\n   974→\tinput := `workflow \"retry\" {\n   975→  step code {\n   976→    prompt = \"write code\"\n   977→    max_attempts = \"3\"\n   978→    results = [success, fail, give-up]\n   979→  }\n   980→  code:success -> done\n   981→  code:fail -> code\n   982→  code:give-up -> abort\n   983→}`\n   984→\n   985→\t_, err := dsl.Parse(input)\n   986→\trequire.Error(t, err)\n   987→\tassert.Contains(t, err.Error(), \"max_attempts must be a numeric value\")\n   988→}\n   989→"}]},"parent_tool_use_id":null,"session_id":"18c8d076-ce6c-4ee3-a952-5609b36c5194","uuid":"485efbf9-b4e0-4b93-8b0c-67e1893cda62","timestamp":"2026-03-17T15:05:42.214Z","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/dsl/parser_test.go","content":"package dsl_test\n\nimport (\n\t\"testing\"\n\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/dsl\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n)\n\nfunc TestParser_FullWorkflow(t *testing.T) {\n\tinput := `workflow \"implement-feature\" {\n  step code {\n    prompt = file(\"prompts/implement.md\")\n    results = [success, fail, retry_with_feedback]\n  }\n\n  step check {\n    run = \"make test && make lint\"\n    results = [pass, fail]\n  }\n\n  code:success -> check\n  code:fail -> abort\n  code:retry_with_feedback -> code\n\n  check:pass -> done\n  check:fail -> code\n}`\n\n\twf, err := dsl.Parse(input)\n\trequire.NoError(t, err)\n\n\tassert.Equal(t, \"implement-feature\", wf.Name)\n\tassert.Len(t, wf.Steps, 2)\n\n\tcode := wf.Steps[\"code\"]\n\trequire.NotNil(t, code)\n\tassert.Equal(t, domain.StepTypeAgent, code.Type)\n\tassert.Equal(t, []string{\"success\", \"fail\", \"retry_with_feedback\"}, code.Results)\n\tassert.Equal(t, `file(\"prompts/implement.md\")`, code.Config[\"prompt\"])\n\n\tcheck := wf.Steps[\"check\"]\n\trequire.NotNil(t, check)\n\tassert.Equal(t, domain.StepTypeScript, check.Type)\n\tassert.Equal(t, \"make test && make lint\", check.Config[\"run\"])\n\n\tassert.Len(t, wf.Wiring, 5)\n\tassert.Equal(t, \"code\", wf.EntryStep)\n}\n\nfunc TestParser_MinimalWorkflow(t *testing.T) {\n\tinput := `workflow \"simple\" {\n  step build {\n    run = \"make build\"\n    results = [success, fail]\n  }\n\n  build:success -> done\n  build:fail -> abort\n}`\n\n\twf, err := dsl.Parse(input)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"simple\", wf.Name)\n\tassert.Equal(t, \"build\", wf.EntryStep)\n}\n\nfunc TestParser_SyntaxError(t *testing.T) {\n\tinput := `workflow { }`\n\t_, err := dsl.Parse(input)\n\tassert.Error(t, err)\n}\n\nfunc TestParser_ContainerBlock(t *testing.T) {\n\tinput := `workflow \"test\" {\n  step code {\n    prompt = \"do something\"\n    container {\n      image = \"cloche/agent:latest\"\n      network_allow = [\"docs.python.org\", \"internal.example.com\"]\n    }\n    results = [success]\n  }\n  code:success -> done\n}`\n\n\twf, err := dsl.Parse(input)\n\trequire.NoError(t, err)\n\n\tcode := wf.Steps[\"code\"]\n\tassert.Equal(t, \"cloche/agent:latest\", code.Config[\"container.image\"])\n\tassert.Equal(t, \"docs.python.org,internal.example.com\", code.Config[\"container.network_allow\"])\n}\n\nfunc TestParser_WorkflowContainerBlock(t *testing.T) {\n\tinput := `workflow \"with-image\" {\n  container {\n    image = \"myregistry/myimage:v2\"\n  }\n\n  step code {\n    prompt = \"write code\"\n    results = [success, fail]\n  }\n\n  code:success -> done\n  code:fail -> abort\n}`\n\n\twf, err := dsl.Parse(input)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"with-image\", wf.Name)\n\tassert.Equal(t, \"myregistry/myimage:v2\", wf.Config[\"container.image\"])\n}\n\nfunc TestParser_WorkflowContainerBlockMultipleFields(t *testing.T) {\n\tinput := `workflow \"full-config\" {\n  container {\n    image = \"myregistry/myimage:v2\"\n    memory = \"4g\"\n  }\n\n  step code {\n    prompt = \"write code\"\n    results = [success]\n  }\n\n  code:success -> done\n}`\n\n\twf, err := dsl.Parse(input)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"myregistry/myimage:v2\", wf.Config[\"container.image\"])\n\tassert.Equal(t, \"4g\", wf.Config[\"container.memory\"])\n}\n\nfunc TestParser_WorkflowWithoutContainerBlock(t *testing.T) {\n\tinput := `workflow \"no-container\" {\n  step code {\n    prompt = \"write code\"\n    results = [success]\n  }\n\n  code:success -> done\n}`\n\n\twf, err := dsl.Parse(input)\n\trequire.NoError(t, err)\n\tassert.Empty(t, wf.Config[\"container.image\"])\n}\n\nfunc TestParser_InfersTypeFromContent(t *testing.T) {\n\tinput := `workflow \"infer\" {\n  step build {\n    run = \"make build\"\n    results = [success]\n  }\n  step code {\n    prompt = \"write code\"\n    results = [success]\n  }\n  build:success -> code\n  code:success -> done\n}`\n\n\twf, err := dsl.Parse(input)\n\trequire.NoError(t, err)\n\tassert.Equal(t, domain.StepTypeScript, wf.Steps[\"build\"].Type)\n\tassert.Equal(t, domain.StepTypeAgent, wf.Steps[\"code\"].Type)\n}\n\nfunc TestParser_AmbiguousStepType(t *testing.T) {\n\tinput := `workflow \"bad\" {\n  step both {\n    run = \"make test\"\n    prompt = \"also a prompt\"\n    results = [success]\n  }\n  both:success -> done\n}`\n\n\t_, err := dsl.Parse(input)\n\tassert.Error(t, err)\n\tassert.Contains(t, err.Error(), \"both\")\n}\n\nfunc TestParser_NoStepType(t *testing.T) {\n\tinput := `workflow \"bad\" {\n  step neither {\n    results = [success]\n  }\n  neither:success -> done\n}`\n\n\t_, err := dsl.Parse(input)\n\tassert.Error(t, err)\n\tassert.Contains(t, err.Error(), \"neither\")\n}\n\nfunc TestParser_CollectAll(t *testing.T) {\n\tinput := `workflow \"parallel\" {\n  step code {\n    prompt = \"write code\"\n    results = [success]\n  }\n  step test {\n    run = \"make test\"\n    results = [success, fail]\n  }\n  step lint {\n    run = \"make lint\"\n    results = [success, fail]\n  }\n  step merge {\n    run = \"echo merged\"\n    results = [success]\n  }\n\n  code:success -> test\n  code:success -> lint\n  test:fail -> abort\n  lint:fail -> abort\n  collect all(test:success, lint:success) -> merge\n  merge:success -> done\n}`\n\n\twf, err := dsl.Parse(input)\n\trequire.NoError(t, err)\n\n\trequire.Len(t, wf.Collects, 1)\n\tc := wf.Collects[0]\n\tassert.Equal(t, domain.CollectAll, c.Mode)\n\tassert.Equal(t, \"merge\", c.To)\n\trequire.Len(t, c.Conditions, 2)\n\tassert.Equal(t, \"test\", c.Conditions[0].Step)\n\tassert.Equal(t, \"success\", c.Conditions[0].Result)\n\tassert.Equal(t, \"lint\", c.Conditions[1].Step)\n\tassert.Equal(t, \"success\", c.Conditions[1].Result)\n}\n\nfunc TestParser_WorkflowNameStep(t *testing.T) {\n\tinput := `workflow \"main\" {\n  step prepare-prompt {\n    run     = \"bash scripts/prepare.sh\"\n    results = [success, fail]\n  }\n\n  step develop {\n    workflow_name = \"develop\"\n    results       = [success, fail]\n  }\n\n  prepare-prompt:success -> develop\n  prepare-prompt:fail    -> abort\n  develop:success        -> done\n  develop:fail           -> done\n}`\n\n\twf, err := dsl.Parse(input)\n\trequire.NoError(t, err)\n\n\tassert.Equal(t, \"main\", wf.Name)\n\tassert.Len(t, wf.Steps, 2)\n\n\tdevelop := wf.Steps[\"develop\"]\n\trequire.NotNil(t, develop)\n\tassert.Equal(t, domain.StepTypeWorkflow, develop.Type)\n\tassert.Equal(t, \"develop\", develop.Config[\"workflow_name\"])\n\tassert.Equal(t, []string{\"success\", \"fail\"}, develop.Results)\n\n\tpreparePrompt := wf.Steps[\"prepare-prompt\"]\n\trequire.NotNil(t, preparePrompt)\n\tassert.Equal(t, domain.StepTypeScript, preparePrompt.Type)\n}\n\nfunc TestParser_WorkflowNameWithPromptStep(t *testing.T) {\n\tinput := `workflow \"orch\" {\n  step prep {\n    run     = \"echo hello\"\n    results = [success, fail]\n  }\n\n  step dev {\n    workflow_name = \"develop\"\n    prompt_step   = \"prep\"\n    results       = [success, fail]\n  }\n\n  prep:success -> dev\n  prep:fail    -> abort\n  dev:success  -> done\n  dev:fail     -> done\n}`\n\n\twf, err := dsl.Parse(input)\n\trequire.NoError(t, err)\n\n\tdev := wf.Steps[\"dev\"]\n\trequire.NotNil(t, dev)\n\tassert.Equal(t, domain.StepTypeWorkflow, dev.Type)\n\tassert.Equal(t, \"prep\", dev.Config[\"prompt_step\"])\n}\n\nfunc TestParser_WorkflowNameWithPromptErrors(t *testing.T) {\n\tinput := `workflow \"bad\" {\n  step both {\n    workflow_name = \"develop\"\n    prompt        = \"also a prompt\"\n    results       = [success]\n  }\n  both:success -> done\n}`\n\n\t_, err := dsl.Parse(input)\n\tassert.Error(t, err)\n\tassert.Contains(t, err.Error(), \"multiple\")\n}\n\nfunc TestParser_WorkflowNameWithRunErrors(t *testing.T) {\n\tinput := `workflow \"bad\" {\n  step both {\n    workflow_name = \"develop\"\n    run           = \"make test\"\n    results       = [success]\n  }\n  both:success -> done\n}`\n\n\t_, err := dsl.Parse(input)\n\tassert.Error(t, err)\n\tassert.Contains(t, err.Error(), \"multiple\")\n}\n\nfunc TestParser_CollectAny(t *testing.T) {\n\tinput := `workflow \"race\" {\n  step fast {\n    run = \"echo fast\"\n    results = [success]\n  }\n  step slow {\n    run = \"sleep 1 && echo slow\"\n    results = [success]\n  }\n  step next {\n    run = \"echo next\"\n    results = [success]\n  }\n\n  collect any(fast:success, slow:success) -> next\n  next:success -> done\n}`\n\n\twf, err := dsl.Parse(input)\n\trequire.NoError(t, err)\n\n\trequire.Len(t, wf.Collects, 1)\n\tassert.Equal(t, domain.CollectAny, wf.Collects[0].Mode)\n}\n\nfunc TestParseForHost_AllowsWorkflowSteps(t *testing.T) {\n\tinput := `workflow \"main\" {\n  step prepare {\n    run     = \"bash scripts/prepare.sh\"\n    results = [success, fail]\n  }\n  step develop {\n    workflow_name = \"develop\"\n    results       = [success, fail]\n  }\n  prepare:success -> develop\n  prepare:fail    -> abort\n  develop:success -> done\n  develop:fail    -> done\n}`\n\twf, err := dsl.ParseForHost(input)\n\trequire.NoError(t, err)\n\tassert.Equal(t, domain.LocationHost, wf.Location)\n\tassert.Equal(t, domain.StepTypeWorkflow, wf.Steps[\"develop\"].Type)\n}\n\nfunc TestParseForContainer_RejectsWorkflowSteps(t *testing.T) {\n\tinput := `workflow \"develop\" {\n  step dispatch {\n    workflow_name = \"implement\"\n    results       = [success, fail]\n  }\n  dispatch:success -> done\n  dispatch:fail    -> abort\n}`\n\t_, err := dsl.ParseForContainer(input)\n\trequire.Error(t, err)\n\tassert.Contains(t, err.Error(), \"workflow_name\")\n\tassert.Contains(t, err.Error(), \"host workflows\")\n}\n\nfunc TestParseForContainer_AllowsAgentAndScript(t *testing.T) {\n\tinput := `workflow \"develop\" {\n  step code {\n    prompt = \"write code\"\n    results = [success, fail]\n  }\n  step test {\n    run = \"make test\"\n    results = [pass, fail]\n  }\n  code:success -> test\n  code:fail -> abort\n  test:pass -> done\n  test:fail -> code\n}`\n\twf, err := dsl.ParseForContainer(input)\n\trequire.NoError(t, err)\n\tassert.Equal(t, domain.LocationContainer, wf.Location)\n}\n\nfunc TestParser_WireNoMappings(t *testing.T) {\n\tinput := `workflow \"simple\" {\n  step a {\n    run = \"echo a\"\n    results = [success]\n  }\n  a:success -> done\n}`\n\twf, err := dsl.Parse(input)\n\trequire.NoError(t, err)\n\trequire.Len(t, wf.Wiring, 1)\n\tassert.Nil(t, wf.Wiring[0].OutputMap)\n}\n\nfunc TestParser_WireSingleMapping(t *testing.T) {\n\tinput := `workflow \"mapped\" {\n  step a {\n    run = \"echo a\"\n    results = [success]\n  }\n  step b {\n    run = \"echo b\"\n    results = [success]\n  }\n  a:success -> b [ FOO = output.bar ]\n  b:success -> done\n}`\n\twf, err := dsl.Parse(input)\n\trequire.NoError(t, err)\n\n\twire := wf.Wiring[0]\n\tassert.Equal(t, \"a\", wire.From)\n\tassert.Equal(t, \"b\", wire.To)\n\trequire.Len(t, wire.OutputMap, 1)\n\tassert.Equal(t, \"FOO\", wire.OutputMap[0].EnvVar)\n\trequire.Len(t, wire.OutputMap[0].Path.Segments, 1)\n\tassert.Equal(t, domain.SegmentField, wire.OutputMap[0].Path.Segments[0].Kind)\n\tassert.Equal(t, \"bar\", wire.OutputMap[0].Path.Segments[0].Field)\n}\n\nfunc TestParser_WireMultipleMappings(t *testing.T) {\n\tinput := `workflow \"mapped\" {\n  step a {\n    run = \"echo a\"\n    results = [success]\n  }\n  step b {\n    run = \"echo b\"\n    results = [success]\n  }\n  a:success -> b [ X = output.a, Y = output.b ]\n  b:success -> done\n}`\n\twf, err := dsl.Parse(input)\n\trequire.NoError(t, err)\n\n\twire := wf.Wiring[0]\n\trequire.Len(t, wire.OutputMap, 2)\n\tassert.Equal(t, \"X\", wire.OutputMap[0].EnvVar)\n\tassert.Equal(t, \"a\", wire.OutputMap[0].Path.Segments[0].Field)\n\tassert.Equal(t, \"Y\", wire.OutputMap[1].EnvVar)\n\tassert.Equal(t, \"b\", wire.OutputMap[1].Path.Segments[0].Field)\n}\n\nfunc TestParser_WireArrayIndex(t *testing.T) {\n\tinput := `workflow \"mapped\" {\n  step a {\n    run = \"echo a\"\n    results = [success]\n  }\n  step b {\n    run = \"echo b\"\n    results = [success]\n  }\n  a:success -> b [ X = output[0].id ]\n  b:success -> done\n}`\n\twf, err := dsl.Parse(input)\n\trequire.NoError(t, err)\n\n\twire := wf.Wiring[0]\n\trequire.Len(t, wire.OutputMap, 1)\n\tsegs := wire.OutputMap[0].Path.Segments\n\trequire.Len(t, segs, 2)\n\tassert.Equal(t, domain.SegmentIndex, segs[0].Kind)\n\tassert.Equal(t, 0, segs[0].Index)\n\tassert.Equal(t, domain.SegmentField, segs[1].Kind)\n\tassert.Equal(t, \"id\", segs[1].Field)\n}\n\nfunc TestParser_WireNestedAccess(t *testing.T) {\n\tinput := `workflow \"mapped\" {\n  step a {\n    run = \"echo a\"\n    results = [success]\n  }\n  step b {\n    run = \"echo b\"\n    results = [success]\n  }\n  a:success -> b [ X = output.a.b.c ]\n  b:success -> done\n}`\n\twf, err := dsl.Parse(input)\n\trequire.NoError(t, err)\n\n\tsegs := wf.Wiring[0].OutputMap[0].Path.Segments\n\trequire.Len(t, segs, 3)\n\tassert.Equal(t, \"a\", segs[0].Field)\n\tassert.Equal(t, \"b\", segs[1].Field)\n\tassert.Equal(t, \"c\", segs[2].Field)\n}\n\nfunc TestParser_WireChainedMixedAccess(t *testing.T) {\n\tinput := `workflow \"mapped\" {\n  step a {\n    run = \"echo a\"\n    results = [success]\n  }\n  step b {\n    run = \"echo b\"\n    results = [success]\n  }\n  a:success -> b [ X = output.items[0].name ]\n  b:success -> done\n}`\n\twf, err := dsl.Parse(input)\n\trequire.NoError(t, err)\n\n\tsegs := wf.Wiring[0].OutputMap[0].Path.Segments\n\trequire.Len(t, segs, 3)\n\tassert.Equal(t, domain.SegmentField, segs[0].Kind)\n\tassert.Equal(t, \"items\", segs[0].Field)\n\tassert.Equal(t, domain.SegmentIndex, segs[1].Kind)\n\tassert.Equal(t, 0, segs[1].Index)\n\tassert.Equal(t, domain.SegmentField, segs[2].Kind)\n\tassert.Equal(t, \"name\", segs[2].Field)\n}\n\nfunc TestParser_WireBareOutput(t *testing.T) {\n\tinput := `workflow \"mapped\" {\n  step a {\n    run = \"echo a\"\n    results = [success]\n  }\n  step b {\n    run = \"echo b\"\n    results = [success]\n  }\n  a:success -> b [ RAW = output ]\n  b:success -> done\n}`\n\twf, err := dsl.Parse(input)\n\trequire.NoError(t, err)\n\n\twire := wf.Wiring[0]\n\trequire.Len(t, wire.OutputMap, 1)\n\tassert.Equal(t, \"RAW\", wire.OutputMap[0].EnvVar)\n\tassert.Empty(t, wire.OutputMap[0].Path.Segments)\n}\n\nfunc TestParser_WireMappingErrorMissingOutput(t *testing.T) {\n\tinput := `workflow \"bad\" {\n  step a {\n    run = \"echo a\"\n    results = [success]\n  }\n  step b {\n    run = \"echo b\"\n    results = [success]\n  }\n  a:success -> b [ X = notoutput.foo ]\n  b:success -> done\n}`\n\t_, err := dsl.Parse(input)\n\trequire.Error(t, err)\n\tassert.Contains(t, err.Error(), \"output\")\n}\n\nfunc TestParser_WireMappingErrorMalformedPath(t *testing.T) {\n\tinput := `workflow \"bad\" {\n  step a {\n    run = \"echo a\"\n    results = [success]\n  }\n  step b {\n    run = \"echo b\"\n    results = [success]\n  }\n  a:success -> b [ X = output.\"bad\" ]\n  b:success -> done\n}`\n\t_, err := dsl.Parse(input)\n\trequire.Error(t, err)\n}\n\nfunc TestParse_WithoutLocation_NoEnforcement(t *testing.T) {\n\tinput := `workflow \"any\" {\n  step dispatch {\n    workflow_name = \"develop\"\n    results       = [success]\n  }\n  dispatch:success -> done\n}`\n\t// Plain Parse (no location) should not enforce location constraints\n\twf, err := dsl.Parse(input)\n\trequire.NoError(t, err)\n\tassert.Equal(t, domain.WorkflowLocation(\"\"), wf.Location)\n}\n\n// --- ParseAllForHost tests ---\n\nfunc TestParseAllForHost_SingleWorkflow(t *testing.T) {\n\tinput := `workflow \"main\" {\n  step greet {\n    run     = \"echo hi\"\n    results = [success, fail]\n  }\n  greet:success -> done\n  greet:fail    -> abort\n}`\n\tworkflows, err := dsl.ParseAllForHost(input)\n\trequire.NoError(t, err)\n\trequire.Len(t, workflows, 1)\n\n\twf, ok := workflows[\"main\"]\n\trequire.True(t, ok)\n\tassert.Equal(t, \"main\", wf.Name)\n\tassert.Equal(t, domain.LocationHost, wf.Location)\n}\n\nfunc TestParseAllForHost_MultipleWorkflows(t *testing.T) {\n\tinput := `workflow \"list-tasks\" {\n  step fetch {\n    run     = \"bash scripts/list-tasks.sh\"\n    results = [success, fail]\n  }\n  fetch:success -> done\n  fetch:fail    -> abort\n}\n\nworkflow \"main\" {\n  step prepare {\n    run     = \"echo preparing\"\n    results = [success, fail]\n  }\n  step develop {\n    workflow_name = \"develop\"\n    results       = [success, fail]\n  }\n  prepare:success -> develop\n  prepare:fail    -> abort\n  develop:success -> done\n  develop:fail    -> abort\n}\n\nworkflow \"finalize\" {\n  step cleanup {\n    run     = \"echo cleanup\"\n    results = [success, fail]\n  }\n  cleanup:success -> done\n  cleanup:fail    -> abort\n}`\n\n\tworkflows, err := dsl.ParseAllForHost(input)\n\trequire.NoError(t, err)\n\trequire.Len(t, workflows, 3)\n\n\t_, ok := workflows[\"list-tasks\"]\n\tassert.True(t, ok, \"should have list-tasks workflow\")\n\n\t_, ok = workflows[\"main\"]\n\tassert.True(t, ok, \"should have main workflow\")\n\n\t_, ok = workflows[\"finalize\"]\n\tassert.True(t, ok, \"should have finalize workflow\")\n}\n\nfunc TestParseAllForHost_DuplicateName(t *testing.T) {\n\tinput := `workflow \"main\" {\n  step a {\n    run = \"echo a\"\n    results = [success]\n  }\n  a:success -> done\n}\nworkflow \"main\" {\n  step b {\n    run = \"echo b\"\n    results = [success]\n  }\n  b:success -> done\n}`\n\n\t_, err := dsl.ParseAllForHost(input)\n\trequire.Error(t, err)\n\tassert.Contains(t, err.Error(), \"duplicate workflow name\")\n}\n\nfunc TestParseAllForHost_Empty(t *testing.T) {\n\t_, err := dsl.ParseAllForHost(\"\")\n\trequire.Error(t, err)\n\tassert.Contains(t, err.Error(), \"no workflows found\")\n}\n\nfunc TestParseAllForHost_AllHostLocation(t *testing.T) {\n\tinput := `workflow \"list-tasks\" {\n  step fetch {\n    run = \"echo fetch\"\n    results = [success]\n  }\n  fetch:success -> done\n}\nworkflow \"main\" {\n  step work {\n    run = \"echo work\"\n    results = [success]\n  }\n  work:success -> done\n}`\n\n\tworkflows, err := dsl.ParseAllForHost(input)\n\trequire.NoError(t, err)\n\tfor name, wf := range workflows {\n\t\tassert.Equal(t, domain.LocationHost, wf.Location, \"workflow %q should have host location\", name)\n\t}\n}\n\nfunc TestParseAll_HostBlockSetsLocation(t *testing.T) {\n\tinput := `workflow \"main\" {\n  host {\n    agent_command = \"claude\"\n  }\n  step work {\n    run = \"echo work\"\n    results = [success]\n  }\n  work:success -> done\n}`\n\tworkflows, err := dsl.ParseAll(input)\n\trequire.NoError(t, err)\n\tassert.Equal(t, domain.LocationHost, workflows[\"main\"].Location)\n}\n\nfunc TestParseAll_NoHostBlockDefaultsToContainer(t *testing.T) {\n\tinput := `workflow \"build\" {\n  step compile {\n    run = \"make\"\n    results = [success]\n  }\n  compile:success -> done\n}`\n\tworkflows, err := dsl.ParseAll(input)\n\trequire.NoError(t, err)\n\tassert.Equal(t, domain.LocationContainer, workflows[\"build\"].Location)\n}\n\nfunc TestParse_RejectsHostAndContainerBlocks(t *testing.T) {\n\tinput := `workflow \"bad\" {\n  host {}\n  container {\n    image = \"foo\"\n  }\n  step work {\n    run = \"echo work\"\n    results = [success]\n  }\n  work:success -> done\n}`\n\t_, err := dsl.ParseAll(input)\n\trequire.Error(t, err)\n\tassert.Contains(t, err.Error(), \"both \\\"host\\\" and \\\"container\\\"\")\n}\n\n// --- Agent declaration tests ---\n\nfunc TestParser_AgentDeclaration(t *testing.T) {\n\tinput := `workflow \"develop\" {\n  agent claude {\n    command = \"claude\"\n    args = \"-p --output-format stream-json\"\n  }\n\n  step code {\n    prompt = \"write code\"\n    agent = claude\n    results = [success, fail]\n  }\n\n  code:success -> done\n  code:fail -> abort\n}`\n\n\twf, err := dsl.Parse(input)\n\trequire.NoError(t, err)\n\n\trequire.Len(t, wf.Agents, 1)\n\tagent := wf.Agents[\"claude\"]\n\trequire.NotNil(t, agent)\n\tassert.Equal(t, \"claude\", agent.Name)\n\tassert.Equal(t, \"claude\", agent.Command)\n\tassert.Equal(t, \"-p --output-format stream-json\", agent.Args)\n\n\tcode := wf.Steps[\"code\"]\n\trequire.NotNil(t, code)\n\tassert.Equal(t, \"claude\", code.Config[\"agent\"])\n}\n\nfunc TestParser_MultipleAgents(t *testing.T) {\n\tinput := `workflow \"develop\" {\n  agent claude {\n    command = \"claude\"\n    args = \"-p --verbose\"\n  }\n\n  agent codex {\n    command = \"codex\"\n    args = \"--full-auto\"\n  }\n\n  step implement {\n    prompt = \"implement the feature\"\n    agent = claude\n    results = [success, fail]\n  }\n\n  step review {\n    prompt = \"review the code\"\n    agent = codex\n    results = [success, fail]\n  }\n\n  implement:success -> review\n  implement:fail -> abort\n  review:success -> done\n  review:fail -> implement\n}`\n\n\twf, err := dsl.Parse(input)\n\trequire.NoError(t, err)\n\n\trequire.Len(t, wf.Agents, 2)\n\tassert.Equal(t, \"claude\", wf.Agents[\"claude\"].Command)\n\tassert.Equal(t, \"codex\", wf.Agents[\"codex\"].Command)\n\n\tassert.Equal(t, \"claude\", wf.Steps[\"implement\"].Config[\"agent\"])\n\tassert.Equal(t, \"codex\", wf.Steps[\"review\"].Config[\"agent\"])\n}\n\nfunc TestParser_AgentCommandOnly(t *testing.T) {\n\tinput := `workflow \"simple\" {\n  agent ollama {\n    command = \"ollama\"\n  }\n\n  step code {\n    prompt = \"write code\"\n    agent = ollama\n    results = [success]\n  }\n\n  code:success -> done\n}`\n\n\twf, err := dsl.Parse(input)\n\trequire.NoError(t, err)\n\n\tagent := wf.Agents[\"ollama\"]\n\trequire.NotNil(t, agent)\n\tassert.Equal(t, \"ollama\", agent.Command)\n\tassert.Equal(t, \"\", agent.Args)\n}\n\nfunc TestParser_AgentMissingCommand(t *testing.T) {\n\tinput := `workflow \"bad\" {\n  agent nocommand {\n    args = \"--verbose\"\n  }\n\n  step code {\n    prompt = \"write\"\n    results = [success]\n  }\n\n  code:success -> done\n}`\n\n\t_, err := dsl.Parse(input)\n\trequire.Error(t, err)\n\tassert.Contains(t, err.Error(), \"command\")\n}\n\nfunc TestParser_DuplicateAgent(t *testing.T) {\n\tinput := `workflow \"bad\" {\n  agent claude {\n    command = \"claude\"\n  }\n  agent claude {\n    command = \"claude2\"\n  }\n\n  step code {\n    prompt = \"write\"\n    results = [success]\n  }\n\n  code:success -> done\n}`\n\n\t_, err := dsl.Parse(input)\n\trequire.Error(t, err)\n\tassert.Contains(t, err.Error(), \"duplicate agent\")\n}\n\nfunc TestParser_AgentUnknownField(t *testing.T) {\n\tinput := `workflow \"bad\" {\n  agent claude {\n    command = \"claude\"\n    unknown = \"value\"\n  }\n\n  step code {\n    prompt = \"write\"\n    results = [success]\n  }\n\n  code:success -> done\n}`\n\n\t_, err := dsl.Parse(input)\n\trequire.Error(t, err)\n\tassert.Contains(t, err.Error(), \"unknown agent field\")\n}\n\nfunc TestParser_NumericMaxAttempts(t *testing.T) {\n\tinput := `workflow \"retry\" {\n  step code {\n    prompt = \"write code\"\n    max_attempts = 3\n    results = [success, fail, give-up]\n  }\n  code:success -> done\n  code:fail -> code\n  code:give-up -> abort\n}`\n\n\twf, err := dsl.Parse(input)\n\trequire.NoError(t, err)\n\n\tcode := wf.Steps[\"code\"]\n\trequire.NotNil(t, code)\n\tassert.Equal(t, \"3\", code.Config[\"max_attempts\"])\n}\n\nfunc TestParser_MaxAttemptsRejectsString(t *testing.T) {\n\tinput := `workflow \"retry\" {\n  step code {\n    prompt = \"write code\"\n    max_attempts = \"3\"\n    results = [success, fail, give-up]\n  }\n  code:success -> done\n  code:fail -> code\n  code:give-up -> abort\n}`\n\n\t_, err := dsl.Parse(input)\n\trequire.Error(t, err)\n\tassert.Contains(t, err.Error(), \"max_attempts must be a numeric value\")\n}\n","numLines":989,"startLine":1,"totalLines":989}}}
