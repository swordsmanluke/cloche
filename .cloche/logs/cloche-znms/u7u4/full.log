[2026-03-17T15:05:25Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CKPSyQFQNECq3X4VSSEJnZ","type":"tool_result","content":"     1→package dsl\n     2→\n     3→import (\n     4→\t\"fmt\"\n     5→\t\"strconv\"\n     6→\t\"strings\"\n     7→\n     8→\t\"github.com/cloche-dev/cloche/internal/domain\"\n     9→)\n    10→\n    11→type Parser struct {\n    12→\tlexer    *Lexer\n    13→\tcurrent  Token\n    14→\tpeek     Token\n    15→\tlocation domain.WorkflowLocation\n    16→}\n    17→\n    18→// ParseOption configures the parser.\n    19→type ParseOption func(*Parser)\n    20→\n    21→// WithLocation sets the workflow location, enabling location-based validation.\n    22→func WithLocation(loc domain.WorkflowLocation) ParseOption {\n    23→\treturn func(p *Parser) {\n    24→\t\tp.location = loc\n    25→\t}\n    26→}\n    27→\n    28→func Parse(input string, opts ...ParseOption) (*domain.Workflow, error) {\n    29→\tp := &Parser{lexer: NewLexer(input)}\n    30→\tfor _, opt := range opts {\n    31→\t\topt(p)\n    32→\t}\n    33→\tp.advance() // load current\n    34→\tp.advance() // load peek\n    35→\treturn p.parseWorkflow()\n    36→}\n    37→\n    38→// ParseForHost parses a host.cloche file containing a single workflow.\n    39→func ParseForHost(input string) (*domain.Workflow, error) {\n    40→\treturn Parse(input, WithLocation(domain.LocationHost))\n    41→}\n    42→\n    43→// ParseAllForHost parses a host.cloche file that may contain multiple workflows.\n    44→// Returns a map of workflow name to workflow definition.\n    45→func ParseAllForHost(input string) (map[string]*domain.Workflow, error) {\n    46→\tp := &Parser{lexer: NewLexer(input), location: domain.LocationHost}\n    47→\tp.advance() // load current\n    48→\tp.advance() // load peek\n    49→\n    50→\tworkflows := make(map[string]*domain.Workflow)\n    51→\tfor p.current.Type != TokenEOF {\n    52→\t\twf, err := p.parseWorkflow()\n    53→\t\tif err != nil {\n    54→\t\t\treturn nil, err\n    55→\t\t}\n    56→\t\tif _, exists := workflows[wf.Name]; exists {\n    57→\t\t\treturn nil, fmt.Errorf(\"duplicate workflow name %q\", wf.Name)\n    58→\t\t}\n    59→\t\tworkflows[wf.Name] = wf\n    60→\t}\n    61→\n    62→\tif len(workflows) == 0 {\n    63→\t\treturn nil, fmt.Errorf(\"no workflows found in host.cloche\")\n    64→\t}\n    65→\n    66→\treturn workflows, nil\n    67→}\n    68→\n    69→// ParseForContainer parses a container workflow file.\n    70→func ParseForContainer(input string) (*domain.Workflow, error) {\n    71→\treturn Parse(input, WithLocation(domain.LocationContainer))\n    72→}\n    73→\n    74→// ParseAll parses a .cloche file that may contain multiple workflows.\n    75→// Workflows default to LocationContainer but a \"host { }\" block overrides\n    76→// the location to LocationHost, so any .cloche file can define host workflows.\n    77→func ParseAll(input string) (map[string]*domain.Workflow, error) {\n    78→\tp := &Parser{lexer: NewLexer(input), location: domain.LocationContainer}\n    79→\tp.advance() // load current\n    80→\tp.advance() // load peek\n    81→\n    82→\tworkflows := make(map[string]*domain.Workflow)\n    83→\tfor p.current.Type != TokenEOF {\n    84→\t\twf, err := p.parseWorkflow()\n    85→\t\tif err != nil {\n    86→\t\t\treturn nil, err\n    87→\t\t}\n    88→\t\tif _, exists := workflows[wf.Name]; exists {\n    89→\t\t\treturn nil, fmt.Errorf(\"duplicate workflow name %q\", wf.Name)\n    90→\t\t}\n    91→\t\tworkflows[wf.Name] = wf\n    92→\t}\n    93→\n    94→\tif len(workflows) == 0 {\n    95→\t\treturn nil, fmt.Errorf(\"no workflows found\")\n    96→\t}\n    97→\n    98→\treturn workflows, nil\n    99→}\n   100→\n   101→func (p *Parser) advance() {\n   102→\tp.current = p.peek\n   103→\tp.peek = p.lexer.NextToken()\n   104→}\n   105→\n   106→func (p *Parser) expect(typ TokenType) (Token, error) {\n   107→\tif p.current.Type != typ {\n   108→\t\treturn p.current, fmt.Errorf(\"line %d col %d: expected %v, got %v (%q)\",\n   109→\t\t\tp.current.Line, p.current.Col, typ, p.current.Type, p.current.Literal)\n   110→\t}\n   111→\ttok := p.current\n   112→\tp.advance()\n   113→\treturn tok, nil\n   114→}\n   115→\n   116→func (p *Parser) expectIdent(value string) (Token, error) {\n   117→\tif p.current.Type != TokenIdent || p.current.Literal != value {\n   118→\t\treturn p.current, fmt.Errorf(\"line %d col %d: expected %q, got %q\",\n   119→\t\t\tp.current.Line, p.current.Col, value, p.current.Literal)\n   120→\t}\n   121→\ttok := p.current\n   122→\tp.advance()\n   123→\treturn tok, nil\n   124→}\n   125→\n   126→func (p *Parser) parseWorkflow() (*domain.Workflow, error) {\n   127→\tif _, err := p.expectIdent(\"workflow\"); err != nil {\n   128→\t\treturn nil, err\n   129→\t}\n   130→\n   131→\tnameTok, err := p.expect(TokenString)\n   132→\tif err != nil {\n   133→\t\treturn nil, fmt.Errorf(\"expected workflow name string: %w\", err)\n   134→\t}\n   135→\n   136→\tif _, err := p.expect(TokenLBrace); err != nil {\n   137→\t\treturn nil, err\n   138→\t}\n   139→\n   140→\twf := &domain.Workflow{\n   141→\t\tName:     nameTok.Literal,\n   142→\t\tLocation: p.location,\n   143→\t\tSteps:    make(map[string]*domain.Step),\n   144→\t\tAgents:   make(map[string]*domain.Agent),\n   145→\t\tConfig:   make(map[string]string),\n   146→\t}\n   147→\n   148→\tfor p.current.Type != TokenRBrace && p.current.Type != TokenEOF {\n   149→\t\tif p.current.Type == TokenIdent && p.current.Literal == \"agent\" && p.peek.Type == TokenIdent {\n   150→\t\t\tagent, err := p.parseAgent()\n   151→\t\t\tif err != nil {\n   152→\t\t\t\treturn nil, err\n   153→\t\t\t}\n   154→\t\t\tif _, exists := wf.Agents[agent.Name]; exists {\n   155→\t\t\t\treturn nil, fmt.Errorf(\"line %d: duplicate agent declaration %q\", p.current.Line, agent.Name)\n   156→\t\t\t}\n   157→\t\t\twf.Agents[agent.Name] = agent\n   158→\t\t} else if p.current.Type == TokenIdent && p.current.Literal == \"step\" {\n   159→\t\t\tstep, err := p.parseStep()\n   160→\t\t\tif err != nil {\n   161→\t\t\t\treturn nil, err\n   162→\t\t\t}\n   163→\t\t\twf.Steps[step.Name] = step\n   164→\t\t\tif wf.EntryStep == \"\" {\n   165→\t\t\t\twf.EntryStep = step.Name\n   166→\t\t\t}\n   167→\t\t} else if p.current.Type == TokenIdent && p.current.Literal == \"collect\" {\n   168→\t\t\tcollect, err := p.parseCollect()\n   169→\t\t\tif err != nil {\n   170→\t\t\t\treturn nil, err\n   171→\t\t\t}\n   172→\t\t\twf.Collects = append(wf.Collects, collect)\n   173→\t\t} else if p.current.Type == TokenIdent && p.peek.Type == TokenLBrace {\n   174→\t\t\tif err := p.parseWorkflowConfig(wf); err != nil {\n   175→\t\t\t\treturn nil, err\n   176→\t\t\t}\n   177→\t\t} else if p.current.Type == TokenIdent && p.peek.Type == TokenColon {\n   178→\t\t\twire, err := p.parseWire()\n   179→\t\t\tif err != nil {\n   180→\t\t\t\treturn nil, err\n   181→\t\t\t}\n   182→\t\t\twf.Wiring = append(wf.Wiring, wire)\n   183→\t\t} else {\n   184→\t\t\treturn nil, fmt.Errorf(\"line %d col %d: unexpected token %q\", p.current.Line, p.current.Col, p.current.Literal)\n   185→\t\t}\n   186→\t}\n   187→\n   188→\tif _, err := p.expect(TokenRBrace); err != nil {\n   189→\t\treturn nil, err\n   190→\t}\n   191→\n   192→\tif wf.Location != \"\" {\n   193→\t\tif err := wf.ValidateLocation(); err != nil {\n   194→\t\t\treturn nil, err\n   195→\t\t}\n   196→\t}\n   197→\n   198→\treturn wf, nil\n   199→}\n   200→\n   201→func (p *Parser) parseWorkflowConfig(wf *domain.Workflow) error {\n   202→\tprefix := p.current.Literal // e.g. \"host\", \"container\"\n   203→\tline, col := p.current.Line, p.current.Col\n   204→\tp.advance() // consume prefix ident\n   205→\n   206→\t// Reject conflicting location blocks.\n   207→\tif prefix == \"host\" && wf.Config[\"_location_block\"] == \"container\" {\n   208→\t\treturn fmt.Errorf(\"line %d col %d: workflow %q has both \\\"host\\\" and \\\"container\\\" blocks\", line, col, wf.Name)\n   209→\t}\n   210→\tif prefix == \"container\" && wf.Config[\"_location_block\"] == \"host\" {\n   211→\t\treturn fmt.Errorf(\"line %d col %d: workflow %q has both \\\"host\\\" and \\\"container\\\" blocks\", line, col, wf.Name)\n   212→\t}\n   213→\n   214→\t// A \"host { ... }\" block marks this workflow as a host workflow.\n   215→\tif prefix == \"host\" {\n   216→\t\twf.Location = domain.LocationHost\n   217→\t}\n   218→\tif prefix == \"host\" || prefix == \"container\" {\n   219→\t\twf.Config[\"_location_block\"] = prefix\n   220→\t}\n   221→\n   222→\tif _, err := p.expect(TokenLBrace); err != nil {\n   223→\t\treturn err\n   224→\t}\n   225→\n   226→\tfor p.current.Type != TokenRBrace && p.current.Type != TokenEOF {\n   227→\t\tkeyTok, err := p.expect(TokenIdent)\n   228→\t\tif err != nil {\n   229→\t\t\treturn fmt.Errorf(\"expected field name: %w\", err)\n   230→\t\t}\n   231→\n   232→\t\tif _, err := p.expect(TokenEquals); err != nil {\n   233→\t\t\treturn err\n   234→\t\t}\n   235→\n   236→\t\tval, err := p.parseValue()\n   237→\t\tif err != nil {\n   238→\t\t\treturn err\n   239→\t\t}\n   240→\n   241→\t\twf.Config[prefix+\".\"+keyTok.Literal] = val\n   242→\t}\n   243→\n   244→\tif _, err := p.expect(TokenRBrace); err != nil {\n   245→\t\treturn err\n   246→\t}\n   247→\n   248→\treturn nil\n   249→}\n   250→\n   251→func (p *Parser) parseAgent() (*domain.Agent, error) {\n   252→\tp.advance() // consume \"agent\"\n   253→\n   254→\tnameTok, err := p.expect(TokenIdent)\n   255→\tif err != nil {\n   256→\t\treturn nil, fmt.Errorf(\"expected agent name: %w\", err)\n   257→\t}\n   258→\n   259→\tif _, err := p.expect(TokenLBrace); err != nil {\n   260→\t\treturn nil, err\n   261→\t}\n   262→\n   263→\tagent := &domain.Agent{Name: nameTok.Literal}\n   264→\n   265→\tfor p.current.Type != TokenRBrace && p.current.Type != TokenEOF {\n   266→\t\tkeyTok, err := p.expect(TokenIdent)\n   267→\t\tif err != nil {\n   268→\t\t\treturn nil, fmt.Errorf(\"expected field name in agent block: %w\", err)\n   269→\t\t}\n   270→\n   271→\t\tif _, err := p.expect(TokenEquals); err != nil {\n   272→\t\t\treturn nil, err\n   273→\t\t}\n   274→\n   275→\t\tval, err := p.parseValue()\n   276→\t\tif err != nil {\n   277→\t\t\treturn nil, err\n   278→\t\t}\n   279→\n   280→\t\tswitch keyTok.Literal {\n   281→\t\tcase \"command\":\n   282→\t\t\tagent.Command = val\n   283→\t\tcase \"args\":\n   284→\t\t\tagent.Args = val\n   285→\t\tdefault:\n   286→\t\t\treturn nil, fmt.Errorf(\"line %d col %d: unknown agent field %q (expected \\\"command\\\" or \\\"args\\\")\",\n   287→\t\t\t\tkeyTok.Line, keyTok.Col, keyTok.Literal)\n   288→\t\t}\n   289→\t}\n   290→\n   291→\tif _, err := p.expect(TokenRBrace); err != nil {\n   292→\t\treturn nil, err\n   293→\t}\n   294→\n   295→\tif agent.Command == \"\" {\n   296→\t\treturn nil, fmt.Errorf(\"agent %q: \\\"command\\\" is required\", agent.Name)\n   297→\t}\n   298→\n   299→\treturn agent, nil\n   300→}\n   301→\n   302→func (p *Parser) parseStep() (*domain.Step, error) {\n   303→\tp.advance() // consume \"step\"\n   304→\n   305→\tnameTok, err := p.expect(TokenIdent)\n   306→\tif err != nil {\n   307→\t\treturn nil, fmt.Errorf(\"expected step name: %w\", err)\n   308→\t}\n   309→\n   310→\tif _, err := p.expect(TokenLBrace); err != nil {\n   311→\t\treturn nil, err\n   312→\t}\n   313→\n   314→\tstep := &domain.Step{\n   315→\t\tName:   nameTok.Literal,\n   316→\t\tConfig: make(map[string]string),\n   317→\t}\n   318→\n   319→\tfor p.current.Type != TokenRBrace && p.current.Type != TokenEOF {\n   320→\t\tif err := p.parseStepField(step, \"\"); err != nil {\n   321→\t\t\treturn nil, err\n   322→\t\t}\n   323→\t}\n   324→\n   325→\tif _, err := p.expect(TokenRBrace); err != nil {\n   326→\t\treturn nil, err\n   327→\t}\n   328→\n   329→\t// Infer step type from content\n   330→\t_, hasPrompt := step.Config[\"prompt\"]\n   331→\t_, hasRun := step.Config[\"run\"]\n   332→\t_, hasWorkflowName := step.Config[\"workflow_name\"]\n   333→\n   334→\tcount := 0\n   335→\tif hasPrompt {\n   336→\t\tcount++\n   337→\t}\n   338→\tif hasRun {\n   339→\t\tcount++\n   340→\t}\n   341→\tif hasWorkflowName {\n   342→\t\tcount++\n   343→\t}\n   344→\n   345→\tif count > 1 {\n   346→\t\treturn nil, fmt.Errorf(\"step %q has multiple of 'prompt', 'run', 'workflow_name'; must have exactly one\", step.Name)\n   347→\t}\n   348→\n   349→\tswitch {\n   350→\tcase hasPrompt:\n   351→\t\tstep.Type = domain.StepTypeAgent\n   352→\tcase hasRun:\n   353→\t\tstep.Type = domain.StepTypeScript\n   354→\tcase hasWorkflowName:\n   355→\t\tstep.Type = domain.StepTypeWorkflow\n   356→\tdefault:\n   357→\t\treturn nil, fmt.Errorf(\"step %q has none of 'prompt', 'run', or 'workflow_name'; must have exactly one\", step.Name)\n   358→\t}\n   359→\n   360→\treturn step, nil\n   361→}\n   362→\n   363→func (p *Parser) parseStepField(step *domain.Step, prefix string) error {\n   364→\tkeyTok, err := p.expect(TokenIdent)\n   365→\tif err != nil {\n   366→\t\treturn fmt.Errorf(\"expected field name: %w\", err)\n   367→\t}\n   368→\n   369→\tkey := keyTok.Literal\n   370→\tif prefix != \"\" {\n   371→\t\tkey = prefix + \".\" + key\n   372→\t}\n   373→\n   374→\t// Sub-block (e.g., container { ... })\n   375→\tif p.current.Type == TokenLBrace {\n   376→\t\tp.advance() // consume {\n   377→\t\tfor p.current.Type != TokenRBrace && p.current.Type != TokenEOF {\n   378→\t\t\tif err := p.parseStepField(step, key); err != nil {\n   379→\t\t\t\treturn err\n   380→\t\t\t}\n   381→\t\t}\n   382→\t\tp.advance() // consume }\n   383→\t\treturn nil\n   384→\t}\n   385→\n   386→\tif _, err := p.expect(TokenEquals); err != nil {\n   387→\t\treturn err\n   388→\t}\n   389→\n   390→\tif key == \"results\" {\n   391→\t\tresults, err := p.parseIdentList()\n   392→\t\tif err != nil {\n   393→\t\t\treturn err\n   394→\t\t}\n   395→\t\tstep.Results = results\n   396→\t} else if p.current.Type == TokenLBracket {\n   397→\t\tvalues, err := p.parseStringList()\n   398→\t\tif err != nil {\n   399→\t\t\treturn err\n   400→\t\t}\n   401→\t\tstep.Config[key] = strings.Join(values, \",\")\n   402→\t} else {\n   403→\t\t// max_attempts and timeout must be numeric values, not strings.\n   404→\t\tif key == \"max_attempts\" || key == \"timeout\" {\n   405→\t\t\tif p.current.Type != TokenInt {\n   406→\t\t\t\treturn fmt.Errorf(\"line %d col %d: %s must be a numeric value, not a string (use %s = 3, not %s = \\\"3\\\")\",\n   407→\t\t\t\t\tp.current.Line, p.current.Col, key, key, key)\n   408→\t\t\t}\n   409→\t\t}\n   410→\t\tval, err := p.parseValue()\n   411→\t\tif err != nil {\n   412→\t\t\treturn err\n   413→\t\t}\n   414→\t\tstep.Config[key] = val\n   415→\t}\n   416→\n   417→\treturn nil\n   418→}\n   419→\n   420→func (p *Parser) parseIdentList() ([]string, error) {\n   421→\tif _, err := p.expect(TokenLBracket); err != nil {\n   422→\t\treturn nil, err\n   423→\t}\n   424→\n   425→\tvar items []string\n   426→\tfor p.current.Type != TokenRBracket && p.current.Type != TokenEOF {\n   427→\t\ttok, err := p.expect(TokenIdent)\n   428→\t\tif err != nil {\n   429→\t\t\treturn nil, err\n   430→\t\t}\n   431→\t\titems = append(items, tok.Literal)\n   432→\t\tif p.current.Type == TokenComma {\n   433→\t\t\tp.advance()\n   434→\t\t}\n   435→\t}\n   436→\n   437→\tif _, err := p.expect(TokenRBracket); err != nil {\n   438→\t\treturn nil, err\n   439→\t}\n   440→\n   441→\treturn items, nil\n   442→}\n   443→\n   444→func (p *Parser) parseStringList() ([]string, error) {\n   445→\tif _, err := p.expect(TokenLBracket); err != nil {\n   446→\t\treturn nil, err\n   447→\t}\n   448→\n   449→\tvar items []string\n   450→\tfor p.current.Type != TokenRBracket && p.current.Type != TokenEOF {\n   451→\t\ttok, err := p.expect(TokenString)\n   452→\t\tif err != nil {\n   453→\t\t\treturn nil, err\n   454→\t\t}\n   455→\t\titems = append(items, tok.Literal)\n   456→\t\tif p.current.Type == TokenComma {\n   457→\t\t\tp.advance()\n   458→\t\t}\n   459→\t}\n   460→\n   461→\tif _, err := p.expect(TokenRBracket); err != nil {\n   462→\t\treturn nil, err\n   463→\t}\n   464→\n   465→\treturn items, nil\n   466→}\n   467→\n   468→func (p *Parser) parseValue() (string, error) {\n   469→\tif p.current.Type == TokenString {\n   470→\t\ttok := p.current\n   471→\t\tp.advance()\n   472→\t\treturn tok.Literal, nil\n   473→\t}\n   474→\n   475→\tif p.current.Type == TokenInt {\n   476→\t\ttok := p.current\n   477→\t\tp.advance()\n   478→\t\treturn tok.Literal, nil\n   479→\t}\n   480→\n   481→\tif p.current.Type == TokenIdent {\n   482→\t\tvar buf strings.Builder\n   483→\t\tbuf.WriteString(p.current.Literal)\n   484→\t\tp.advance()\n   485→\n   486→\t\t// Function call: file(\"...\")\n   487→\t\tif p.current.Type == TokenLParen {\n   488→\t\t\tbuf.WriteRune('(')\n   489→\t\t\tp.advance()\n   490→\t\t\tfor p.current.Type != TokenRParen && p.current.Type != TokenEOF {\n   491→\t\t\t\tif p.current.Type == TokenString {\n   492→\t\t\t\t\tbuf.WriteRune('\"')\n   493→\t\t\t\t\tbuf.WriteString(p.current.Literal)\n   494→\t\t\t\t\tbuf.WriteRune('\"')\n   495→\t\t\t\t} else {\n   496→\t\t\t\t\tbuf.WriteString(p.current.Literal)\n   497→\t\t\t\t}\n   498→\t\t\t\tp.advance()\n   499→\t\t\t}\n   500→\t\t\tbuf.WriteRune(')')\n   501→\t\t\tp.advance() // consume )\n   502→\t\t}\n   503→\n   504→\t\t// Dotted path: step.code.output\n   505→\t\tfor p.current.Type == TokenDot {\n   506→\t\t\tbuf.WriteRune('.')\n   507→\t\t\tp.advance()\n   508→\t\t\tif p.current.Type == TokenIdent {\n   509→\t\t\t\tbuf.WriteString(p.current.Literal)\n   510→\t\t\t\tp.advance()\n   511→\t\t\t}\n   512→\t\t}\n   513→\n   514→\t\treturn buf.String(), nil\n   515→\t}\n   516→\n   517→\treturn \"\", fmt.Errorf(\"line %d col %d: expected value, got %q\", p.current.Line, p.current.Col, p.current.Literal)\n   518→}\n   519→\n   520→func (p *Parser) parseWire() (domain.Wire, error) {\n   521→\tfromTok := p.current\n   522→\tp.advance()\n   523→\n   524→\tif _, err := p.expect(TokenColon); err != nil {\n   525→\t\treturn domain.Wire{}, err\n   526→\t}\n   527→\n   528→\tresultTok, err := p.expect(TokenIdent)\n   529→\tif err != nil {\n   530→\t\treturn domain.Wire{}, err\n   531→\t}\n   532→\n   533→\tif _, err := p.expect(TokenArrow); err != nil {\n   534→\t\treturn domain.Wire{}, err\n   535→\t}\n   536→\n   537→\ttoTok, err := p.expect(TokenIdent)\n   538→\tif err != nil {\n   539→\t\treturn domain.Wire{}, err\n   540→\t}\n   541→\n   542→\tvar mappings []domain.OutputMapping\n   543→\tif p.current.Type == TokenLBracket {\n   544→\t\tmappings, err = p.parseOutputMappings()\n   545→\t\tif err != nil {\n   546→\t\t\treturn domain.Wire{}, err\n   547→\t\t}\n   548→\t}\n   549→\n   550→\treturn domain.Wire{\n   551→\t\tFrom:      fromTok.Literal,\n   552→\t\tResult:    resultTok.Literal,\n   553→\t\tTo:        toTok.Literal,\n   554→\t\tOutputMap: mappings,\n   555→\t}, nil\n   556→}\n   557→\n   558→func (p *Parser) parseOutputMappings() ([]domain.OutputMapping, error) {\n   559→\tif _, err := p.expect(TokenLBracket); err != nil {\n   560→\t\treturn nil, err\n   561→\t}\n   562→\n   563→\tvar mappings []domain.OutputMapping\n   564→\tfor p.current.Type != TokenRBracket && p.current.Type != TokenEOF {\n   565→\t\tkeyTok, err := p.expect(TokenIdent)\n   566→\t\tif err != nil {\n   567→\t\t\treturn nil, fmt.Errorf(\"expected mapping key: %w\", err)\n   568→\t\t}\n   569→\n   570→\t\tif _, err := p.expect(TokenEquals); err != nil {\n   571→\t\t\treturn nil, err\n   572→\t\t}\n   573→\n   574→\t\tpath, err := p.parseOutputPath()\n   575→\t\tif err != nil {\n   576→\t\t\treturn nil, err\n   577→\t\t}\n   578→\n   579→\t\tmappings = append(mappings, domain.OutputMapping{\n   580→\t\t\tEnvVar: keyTok.Literal,\n   581→\t\t\tPath:   path,\n   582→\t\t})\n   583→\n   584→\t\tif p.current.Type == TokenComma {\n   585→\t\t\tp.advance()\n   586→\t\t}\n   587→\t}\n   588→\n   589→\tif _, err := p.expect(TokenRBracket); err != nil {\n   590→\t\treturn nil, err\n   591→\t}\n   592→\n   593→\treturn mappings, nil\n   594→}\n   595→\n   596→func (p *Parser) parseOutputPath() (domain.OutputPath, error) {\n   597→\tif p.current.Type != TokenIdent || p.current.Literal != \"output\" {\n   598→\t\treturn domain.OutputPath{}, fmt.Errorf(\"line %d col %d: expected \\\"output\\\", got %q\",\n   599→\t\t\tp.current.Line, p.current.Col, p.current.Literal)\n   600→\t}\n   601→\tp.advance() // consume \"output\"\n   602→\n   603→\tvar segments []domain.PathSegment\n   604→\tfor {\n   605→\t\tif p.current.Type == TokenDot {\n   606→\t\t\tp.advance() // consume \".\"\n   607→\t\t\tfieldTok, err := p.expect(TokenIdent)\n   608→\t\t\tif err != nil {\n   609→\t\t\t\treturn domain.OutputPath{}, fmt.Errorf(\"expected field name after '.': %w\", err)\n   610→\t\t\t}\n   611→\t\t\tsegments = append(segments, domain.PathSegment{Kind: domain.SegmentField, Field: fieldTok.Literal})\n   612→\t\t} else if p.current.Type == TokenLBracket {\n   613→\t\t\tp.advance() // consume \"[\"\n   614→\t\t\tidxTok, err := p.expect(TokenInt)\n   615→\t\t\tif err != nil {\n   616→\t\t\t\treturn domain.OutputPath{}, fmt.Errorf(\"expected integer index: %w\", err)\n   617→\t\t\t}\n   618→\t\t\tidx, _ := strconv.Atoi(idxTok.Literal)\n   619→\t\t\tif _, err := p.expect(TokenRBracket); err != nil {\n   620→\t\t\t\treturn domain.OutputPath{}, err\n   621→\t\t\t}\n   622→\t\t\tsegments = append(segments, domain.PathSegment{Kind: domain.SegmentIndex, Index: idx})\n   623→\t\t} else {\n   624→\t\t\tbreak\n   625→\t\t}\n   626→\t}\n   627→\n   628→\treturn domain.OutputPath{Segments: segments}, nil\n   629→}\n   630→\n   631→func (p *Parser) parseCollect() (domain.Collect, error) {\n   632→\tp.advance() // consume \"collect\"\n   633→\n   634→\tmodeTok, err := p.expect(TokenIdent)\n   635→\tif err != nil {\n   636→\t\treturn domain.Collect{}, fmt.Errorf(\"expected 'all' or 'any': %w\", err)\n   637→\t}\n   638→\n   639→\tvar mode domain.CollectMode\n   640→\tswitch modeTok.Literal {\n   641→\tcase \"all\":\n   642→\t\tmode = domain.CollectAll\n   643→\tcase \"any\":\n   644→\t\tmode = domain.CollectAny\n   645→\tdefault:\n   646→\t\treturn domain.Collect{}, fmt.Errorf(\"line %d col %d: expected 'all' or 'any', got %q\",\n   647→\t\t\tmodeTok.Line, modeTok.Col, modeTok.Literal)\n   648→\t}\n   649→\n   650→\tif _, err := p.expect(TokenLParen); err != nil {\n   651→\t\treturn domain.Collect{}, err\n   652→\t}\n   653→\n   654→\tvar conditions []domain.WireCondition\n   655→\tfor p.current.Type != TokenRParen && p.current.Type != TokenEOF {\n   656→\t\tstepTok, err := p.expect(TokenIdent)\n   657→\t\tif err != nil {\n   658→\t\t\treturn domain.Collect{}, fmt.Errorf(\"expected step name in collect: %w\", err)\n   659→\t\t}\n   660→\t\tif _, err := p.expect(TokenColon); err != nil {\n   661→\t\t\treturn domain.Collect{}, err\n   662→\t\t}\n   663→\t\tresultTok, err := p.expect(TokenIdent)\n   664→\t\tif err != nil {\n   665→\t\t\treturn domain.Collect{}, fmt.Errorf(\"expected result name in collect: %w\", err)\n   666→\t\t}\n   667→\t\tconditions = append(conditions, domain.WireCondition{Step: stepTok.Literal, Result: resultTok.Literal})\n   668→\t\tif p.current.Type == TokenComma {\n   669→\t\t\tp.advance()\n   670→\t\t}\n   671→\t}\n   672→\n   673→\tif _, err := p.expect(TokenRParen); err != nil {\n   674→\t\treturn domain.Collect{}, err\n   675→\t}\n   676→\tif _, err := p.expect(TokenArrow); err != nil {\n   677→\t\treturn domain.Collect{}, err\n   678→\t}\n   679→\n   680→\ttoTok, err := p.expect(TokenIdent)\n   681→\tif err != nil {\n   682→\t\treturn domain.Collect{}, fmt.Errorf(\"expected target step: %w\", err)\n   683→\t}\n   684→\n   685→\treturn domain.Collect{\n   686→\t\tMode:       mode,\n   687→\t\tConditions: conditions,\n   688→\t\tTo:         toTok.Literal,\n   689→\t}, nil\n   690→}\n   691→"}]},"parent_tool_use_id":null,"session_id":"b0f6c7e5-6354-4513-b6d9-02e48d113530","uuid":"57d11fcb-6511-4f56-89e9-d42016279d50","timestamp":"2026-03-17T15:04:45.549Z","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/dsl/parser.go","content":"package dsl\n\nimport (\n\t\"fmt\"\n\t\"strconv\"\n\t\"strings\"\n\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n)\n\ntype Parser struct {\n\tlexer    *Lexer\n\tcurrent  Token\n\tpeek     Token\n\tlocation domain.WorkflowLocation\n}\n\n// ParseOption configures the parser.\ntype ParseOption func(*Parser)\n\n// WithLocation sets the workflow location, enabling location-based validation.\nfunc WithLocation(loc domain.WorkflowLocation) ParseOption {\n\treturn func(p *Parser) {\n\t\tp.location = loc\n\t}\n}\n\nfunc Parse(input string, opts ...ParseOption) (*domain.Workflow, error) {\n\tp := &Parser{lexer: NewLexer(input)}\n\tfor _, opt := range opts {\n\t\topt(p)\n\t}\n\tp.advance() // load current\n\tp.advance() // load peek\n\treturn p.parseWorkflow()\n}\n\n// ParseForHost parses a host.cloche file containing a single workflow.\nfunc ParseForHost(input string) (*domain.Workflow, error) {\n\treturn Parse(input, WithLocation(domain.LocationHost))\n}\n\n// ParseAllForHost parses a host.cloche file that may contain multiple workflows.\n// Returns a map of workflow name to workflow definition.\nfunc ParseAllForHost(input string) (map[string]*domain.Workflow, error) {\n\tp := &Parser{lexer: NewLexer(input), location: domain.LocationHost}\n\tp.advance() // load current\n\tp.advance() // load peek\n\n\tworkflows := make(map[string]*domain.Workflow)\n\tfor p.current.Type != TokenEOF {\n\t\twf, err := p.parseWorkflow()\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t\tif _, exists := workflows[wf.Name]; exists {\n\t\t\treturn nil, fmt.Errorf(\"duplicate workflow name %q\", wf.Name)\n\t\t}\n\t\tworkflows[wf.Name] = wf\n\t}\n\n\tif len(workflows) == 0 {\n\t\treturn nil, fmt.Errorf(\"no workflows found in host.cloche\")\n\t}\n\n\treturn workflows, nil\n}\n\n// ParseForContainer parses a container workflow file.\nfunc ParseForContainer(input string) (*domain.Workflow, error) {\n\treturn Parse(input, WithLocation(domain.LocationContainer))\n}\n\n// ParseAll parses a .cloche file that may contain multiple workflows.\n// Workflows default to LocationContainer but a \"host { }\" block overrides\n// the location to LocationHost, so any .cloche file can define host workflows.\nfunc ParseAll(input string) (map[string]*domain.Workflow, error) {\n\tp := &Parser{lexer: NewLexer(input), location: domain.LocationContainer}\n\tp.advance() // load current\n\tp.advance() // load peek\n\n\tworkflows := make(map[string]*domain.Workflow)\n\tfor p.current.Type != TokenEOF {\n\t\twf, err := p.parseWorkflow()\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t\tif _, exists := workflows[wf.Name]; exists {\n\t\t\treturn nil, fmt.Errorf(\"duplicate workflow name %q\", wf.Name)\n\t\t}\n\t\tworkflows[wf.Name] = wf\n\t}\n\n\tif len(workflows) == 0 {\n\t\treturn nil, fmt.Errorf(\"no workflows found\")\n\t}\n\n\treturn workflows, nil\n}\n\nfunc (p *Parser) advance() {\n\tp.current = p.peek\n\tp.peek = p.lexer.NextToken()\n}\n\nfunc (p *Parser) expect(typ TokenType) (Token, error) {\n\tif p.current.Type != typ {\n\t\treturn p.current, fmt.Errorf(\"line %d col %d: expected %v, got %v (%q)\",\n\t\t\tp.current.Line, p.current.Col, typ, p.current.Type, p.current.Literal)\n\t}\n\ttok := p.current\n\tp.advance()\n\treturn tok, nil\n}\n\nfunc (p *Parser) expectIdent(value string) (Token, error) {\n\tif p.current.Type != TokenIdent || p.current.Literal != value {\n\t\treturn p.current, fmt.Errorf(\"line %d col %d: expected %q, got %q\",\n\t\t\tp.current.Line, p.current.Col, value, p.current.Literal)\n\t}\n\ttok := p.current\n\tp.advance()\n\treturn tok, nil\n}\n\nfunc (p *Parser) parseWorkflow() (*domain.Workflow, error) {\n\tif _, err := p.expectIdent(\"workflow\"); err != nil {\n\t\treturn nil, err\n\t}\n\n\tnameTok, err := p.expect(TokenString)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"expected workflow name string: %w\", err)\n\t}\n\n\tif _, err := p.expect(TokenLBrace); err != nil {\n\t\treturn nil, err\n\t}\n\n\twf := &domain.Workflow{\n\t\tName:     nameTok.Literal,\n\t\tLocation: p.location,\n\t\tSteps:    make(map[string]*domain.Step),\n\t\tAgents:   make(map[string]*domain.Agent),\n\t\tConfig:   make(map[string]string),\n\t}\n\n\tfor p.current.Type != TokenRBrace && p.current.Type != TokenEOF {\n\t\tif p.current.Type == TokenIdent && p.current.Literal == \"agent\" && p.peek.Type == TokenIdent {\n\t\t\tagent, err := p.parseAgent()\n\t\t\tif err != nil {\n\t\t\t\treturn nil, err\n\t\t\t}\n\t\t\tif _, exists := wf.Agents[agent.Name]; exists {\n\t\t\t\treturn nil, fmt.Errorf(\"line %d: duplicate agent declaration %q\", p.current.Line, agent.Name)\n\t\t\t}\n\t\t\twf.Agents[agent.Name] = agent\n\t\t} else if p.current.Type == TokenIdent && p.current.Literal == \"step\" {\n\t\t\tstep, err := p.parseStep()\n\t\t\tif err != nil {\n\t\t\t\treturn nil, err\n\t\t\t}\n\t\t\twf.Steps[step.Name] = step\n\t\t\tif wf.EntryStep == \"\" {\n\t\t\t\twf.EntryStep = step.Name\n\t\t\t}\n\t\t} else if p.current.Type == TokenIdent && p.current.Literal == \"collect\" {\n\t\t\tcollect, err := p.parseCollect()\n\t\t\tif err != nil {\n\t\t\t\treturn nil, err\n\t\t\t}\n\t\t\twf.Collects = append(wf.Collects, collect)\n\t\t} else if p.current.Type == TokenIdent && p.peek.Type == TokenLBrace {\n\t\t\tif err := p.parseWorkflowConfig(wf); err != nil {\n\t\t\t\treturn nil, err\n\t\t\t}\n\t\t} else if p.current.Type == TokenIdent && p.peek.Type == TokenColon {\n\t\t\twire, err := p.parseWire()\n\t\t\tif err != nil {\n\t\t\t\treturn nil, err\n\t\t\t}\n\t\t\twf.Wiring = append(wf.Wiring, wire)\n\t\t} else {\n\t\t\treturn nil, fmt.Errorf(\"line %d col %d: unexpected token %q\", p.current.Line, p.current.Col, p.current.Literal)\n\t\t}\n\t}\n\n\tif _, err := p.expect(TokenRBrace); err != nil {\n\t\treturn nil, err\n\t}\n\n\tif wf.Location != \"\" {\n\t\tif err := wf.ValidateLocation(); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t}\n\n\treturn wf, nil\n}\n\nfunc (p *Parser) parseWorkflowConfig(wf *domain.Workflow) error {\n\tprefix := p.current.Literal // e.g. \"host\", \"container\"\n\tline, col := p.current.Line, p.current.Col\n\tp.advance() // consume prefix ident\n\n\t// Reject conflicting location blocks.\n\tif prefix == \"host\" && wf.Config[\"_location_block\"] == \"container\" {\n\t\treturn fmt.Errorf(\"line %d col %d: workflow %q has both \\\"host\\\" and \\\"container\\\" blocks\", line, col, wf.Name)\n\t}\n\tif prefix == \"container\" && wf.Config[\"_location_block\"] == \"host\" {\n\t\treturn fmt.Errorf(\"line %d col %d: workflow %q has both \\\"host\\\" and \\\"container\\\" blocks\", line, col, wf.Name)\n\t}\n\n\t// A \"host { ... }\" block marks this workflow as a host workflow.\n\tif prefix == \"host\" {\n\t\twf.Location = domain.LocationHost\n\t}\n\tif prefix == \"host\" || prefix == \"container\" {\n\t\twf.Config[\"_location_block\"] = prefix\n\t}\n\n\tif _, err := p.expect(TokenLBrace); err != nil {\n\t\treturn err\n\t}\n\n\tfor p.current.Type != TokenRBrace && p.current.Type != TokenEOF {\n\t\tkeyTok, err := p.expect(TokenIdent)\n\t\tif err != nil {\n\t\t\treturn fmt.Errorf(\"expected field name: %w\", err)\n\t\t}\n\n\t\tif _, err := p.expect(TokenEquals); err != nil {\n\t\t\treturn err\n\t\t}\n\n\t\tval, err := p.parseValue()\n\t\tif err != nil {\n\t\t\treturn err\n\t\t}\n\n\t\twf.Config[prefix+\".\"+keyTok.Literal] = val\n\t}\n\n\tif _, err := p.expect(TokenRBrace); err != nil {\n\t\treturn err\n\t}\n\n\treturn nil\n}\n\nfunc (p *Parser) parseAgent() (*domain.Agent, error) {\n\tp.advance() // consume \"agent\"\n\n\tnameTok, err := p.expect(TokenIdent)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"expected agent name: %w\", err)\n\t}\n\n\tif _, err := p.expect(TokenLBrace); err != nil {\n\t\treturn nil, err\n\t}\n\n\tagent := &domain.Agent{Name: nameTok.Literal}\n\n\tfor p.current.Type != TokenRBrace && p.current.Type != TokenEOF {\n\t\tkeyTok, err := p.expect(TokenIdent)\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"expected field name in agent block: %w\", err)\n\t\t}\n\n\t\tif _, err := p.expect(TokenEquals); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tval, err := p.parseValue()\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tswitch keyTok.Literal {\n\t\tcase \"command\":\n\t\t\tagent.Command = val\n\t\tcase \"args\":\n\t\t\tagent.Args = val\n\t\tdefault:\n\t\t\treturn nil, fmt.Errorf(\"line %d col %d: unknown agent field %q (expected \\\"command\\\" or \\\"args\\\")\",\n\t\t\t\tkeyTok.Line, keyTok.Col, keyTok.Literal)\n\t\t}\n\t}\n\n\tif _, err := p.expect(TokenRBrace); err != nil {\n\t\treturn nil, err\n\t}\n\n\tif agent.Command == \"\" {\n\t\treturn nil, fmt.Errorf(\"agent %q: \\\"command\\\" is required\", agent.Name)\n\t}\n\n\treturn agent, nil\n}\n\nfunc (p *Parser) parseStep() (*domain.Step, error) {\n\tp.advance() // consume \"step\"\n\n\tnameTok, err := p.expect(TokenIdent)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"expected step name: %w\", err)\n\t}\n\n\tif _, err := p.expect(TokenLBrace); err != nil {\n\t\treturn nil, err\n\t}\n\n\tstep := &domain.Step{\n\t\tName:   nameTok.Literal,\n\t\tConfig: make(map[string]string),\n\t}\n\n\tfor p.current.Type != TokenRBrace && p.current.Type != TokenEOF {\n\t\tif err := p.parseStepField(step, \"\"); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t}\n\n\tif _, err := p.expect(TokenRBrace); err != nil {\n\t\treturn nil, err\n\t}\n\n\t// Infer step type from content\n\t_, hasPrompt := step.Config[\"prompt\"]\n\t_, hasRun := step.Config[\"run\"]\n\t_, hasWorkflowName := step.Config[\"workflow_name\"]\n\n\tcount := 0\n\tif hasPrompt {\n\t\tcount++\n\t}\n\tif hasRun {\n\t\tcount++\n\t}\n\tif hasWorkflowName {\n\t\tcount++\n\t}\n\n\tif count > 1 {\n\t\treturn nil, fmt.Errorf(\"step %q has multiple of 'prompt', 'run', 'workflow_name'; must have exactly one\", step.Name)\n\t}\n\n\tswitch {\n\tcase hasPrompt:\n\t\tstep.Type = domain.StepTypeAgent\n\tcase hasRun:\n\t\tstep.Type = domain.StepTypeScript\n\tcase hasWorkflowName:\n\t\tstep.Type = domain.StepTypeWorkflow\n\tdefault:\n\t\treturn nil, fmt.Errorf(\"step %q has none of 'prompt', 'run', or 'workflow_name'; must have exactly one\", step.Name)\n\t}\n\n\treturn step, nil\n}\n\nfunc (p *Parser) parseStepField(step *domain.Step, prefix string) error {\n\tkeyTok, err := p.expect(TokenIdent)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"expected field name: %w\", err)\n\t}\n\n\tkey := keyTok.Literal\n\tif prefix != \"\" {\n\t\tkey = prefix + \".\" + key\n\t}\n\n\t// Sub-block (e.g., container { ... })\n\tif p.current.Type == TokenLBrace {\n\t\tp.advance() // consume {\n\t\tfor p.current.Type != TokenRBrace && p.current.Type != TokenEOF {\n\t\t\tif err := p.parseStepField(step, key); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t}\n\t\tp.advance() // consume }\n\t\treturn nil\n\t}\n\n\tif _, err := p.expect(TokenEquals); err != nil {\n\t\treturn err\n\t}\n\n\tif key == \"results\" {\n\t\tresults, err := p.parseIdentList()\n\t\tif err != nil {\n\t\t\treturn err\n\t\t}\n\t\tstep.Results = results\n\t} else if p.current.Type == TokenLBracket {\n\t\tvalues, err := p.parseStringList()\n\t\tif err != nil {\n\t\t\treturn err\n\t\t}\n\t\tstep.Config[key] = strings.Join(values, \",\")\n\t} else {\n\t\t// max_attempts and timeout must be numeric values, not strings.\n\t\tif key == \"max_attempts\" || key == \"timeout\" {\n\t\t\tif p.current.Type != TokenInt {\n\t\t\t\treturn fmt.Errorf(\"line %d col %d: %s must be a numeric value, not a string (use %s = 3, not %s = \\\"3\\\")\",\n\t\t\t\t\tp.current.Line, p.current.Col, key, key, key)\n\t\t\t}\n\t\t}\n\t\tval, err := p.parseValue()\n\t\tif err != nil {\n\t\t\treturn err\n\t\t}\n\t\tstep.Config[key] = val\n\t}\n\n\treturn nil\n}\n\nfunc (p *Parser) parseIdentList() ([]string, error) {\n\tif _, err := p.expect(TokenLBracket); err != nil {\n\t\treturn nil, err\n\t}\n\n\tvar items []string\n\tfor p.current.Type != TokenRBracket && p.current.Type != TokenEOF {\n\t\ttok, err := p.expect(TokenIdent)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t\titems = append(items, tok.Literal)\n\t\tif p.current.Type == TokenComma {\n\t\t\tp.advance()\n\t\t}\n\t}\n\n\tif _, err := p.expect(TokenRBracket); err != nil {\n\t\treturn nil, err\n\t}\n\n\treturn items, nil\n}\n\nfunc (p *Parser) parseStringList() ([]string, error) {\n\tif _, err := p.expect(TokenLBracket); err != nil {\n\t\treturn nil, err\n\t}\n\n\tvar items []string\n\tfor p.current.Type != TokenRBracket && p.current.Type != TokenEOF {\n\t\ttok, err := p.expect(TokenString)\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\t\titems = append(items, tok.Literal)\n\t\tif p.current.Type == TokenComma {\n\t\t\tp.advance()\n\t\t}\n\t}\n\n\tif _, err := p.expect(TokenRBracket); err != nil {\n\t\treturn nil, err\n\t}\n\n\treturn items, nil\n}\n\nfunc (p *Parser) parseValue() (string, error) {\n\tif p.current.Type == TokenString {\n\t\ttok := p.current\n\t\tp.advance()\n\t\treturn tok.Literal, nil\n\t}\n\n\tif p.current.Type == TokenInt {\n\t\ttok := p.current\n\t\tp.advance()\n\t\treturn tok.Literal, nil\n\t}\n\n\tif p.current.Type == TokenIdent {\n\t\tvar buf strings.Builder\n\t\tbuf.WriteString(p.current.Literal)\n\t\tp.advance()\n\n\t\t// Function call: file(\"...\")\n\t\tif p.current.Type == TokenLParen {\n\t\t\tbuf.WriteRune('(')\n\t\t\tp.advance()\n\t\t\tfor p.current.Type != TokenRParen && p.current.Type != TokenEOF {\n\t\t\t\tif p.current.Type == TokenString {\n\t\t\t\t\tbuf.WriteRune('\"')\n\t\t\t\t\tbuf.WriteString(p.current.Literal)\n\t\t\t\t\tbuf.WriteRune('\"')\n\t\t\t\t} else {\n\t\t\t\t\tbuf.WriteString(p.current.Literal)\n\t\t\t\t}\n\t\t\t\tp.advance()\n\t\t\t}\n\t\t\tbuf.WriteRune(')')\n\t\t\tp.advance() // consume )\n\t\t}\n\n\t\t// Dotted path: step.code.output\n\t\tfor p.current.Type == TokenDot {\n\t\t\tbuf.WriteRune('.')\n\t\t\tp.advance()\n\t\t\tif p.current.Type == TokenIdent {\n\t\t\t\tbuf.WriteString(p.current.Literal)\n\t\t\t\tp.advance()\n\t\t\t}\n\t\t}\n\n\t\treturn buf.String(), nil\n\t}\n\n\treturn \"\", fmt.Errorf(\"line %d col %d: expected value, got %q\", p.current.Line, p.current.Col, p.current.Literal)\n}\n\nfunc (p *Parser) parseWire() (domain.Wire, error) {\n\tfromTok := p.current\n\tp.advance()\n\n\tif _, err := p.expect(TokenColon); err != nil {\n\t\treturn domain.Wire{}, err\n\t}\n\n\tresultTok, err := p.expect(TokenIdent)\n\tif err != nil {\n\t\treturn domain.Wire{}, err\n\t}\n\n\tif _, err := p.expect(TokenArrow); err != nil {\n\t\treturn domain.Wire{}, err\n\t}\n\n\ttoTok, err := p.expect(TokenIdent)\n\tif err != nil {\n\t\treturn domain.Wire{}, err\n\t}\n\n\tvar mappings []domain.OutputMapping\n\tif p.current.Type == TokenLBracket {\n\t\tmappings, err = p.parseOutputMappings()\n\t\tif err != nil {\n\t\t\treturn domain.Wire{}, err\n\t\t}\n\t}\n\n\treturn domain.Wire{\n\t\tFrom:      fromTok.Literal,\n\t\tResult:    resultTok.Literal,\n\t\tTo:        toTok.Literal,\n\t\tOutputMap: mappings,\n\t}, nil\n}\n\nfunc (p *Parser) parseOutputMappings() ([]domain.OutputMapping, error) {\n\tif _, err := p.expect(TokenLBracket); err != nil {\n\t\treturn nil, err\n\t}\n\n\tvar mappings []domain.OutputMapping\n\tfor p.current.Type != TokenRBracket && p.current.Type != TokenEOF {\n\t\tkeyTok, err := p.expect(TokenIdent)\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"expected mapping key: %w\", err)\n\t\t}\n\n\t\tif _, err := p.expect(TokenEquals); err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tpath, err := p.parseOutputPath()\n\t\tif err != nil {\n\t\t\treturn nil, err\n\t\t}\n\n\t\tmappings = append(mappings, domain.OutputMapping{\n\t\t\tEnvVar: keyTok.Literal,\n\t\t\tPath:   path,\n\t\t})\n\n\t\tif p.current.Type == TokenComma {\n\t\t\tp.advance()\n\t\t}\n\t}\n\n\tif _, err := p.expect(TokenRBracket); err != nil {\n\t\treturn nil, err\n\t}\n\n\treturn mappings, nil\n}\n\nfunc (p *Parser) parseOutputPath() (domain.OutputPath, error) {\n\tif p.current.Type != TokenIdent || p.current.Literal != \"output\" {\n\t\treturn domain.OutputPath{}, fmt.Errorf(\"line %d col %d: expected \\\"output\\\", got %q\",\n\t\t\tp.current.Line, p.current.Col, p.current.Literal)\n\t}\n\tp.advance() // consume \"output\"\n\n\tvar segments []domain.PathSegment\n\tfor {\n\t\tif p.current.Type == TokenDot {\n\t\t\tp.advance() // consume \".\"\n\t\t\tfieldTok, err := p.expect(TokenIdent)\n\t\t\tif err != nil {\n\t\t\t\treturn domain.OutputPath{}, fmt.Errorf(\"expected field name after '.': %w\", err)\n\t\t\t}\n\t\t\tsegments = append(segments, domain.PathSegment{Kind: domain.SegmentField, Field: fieldTok.Literal})\n\t\t} else if p.current.Type == TokenLBracket {\n\t\t\tp.advance() // consume \"[\"\n\t\t\tidxTok, err := p.expect(TokenInt)\n\t\t\tif err != nil {\n\t\t\t\treturn domain.OutputPath{}, fmt.Errorf(\"expected integer index: %w\", err)\n\t\t\t}\n\t\t\tidx, _ := strconv.Atoi(idxTok.Literal)\n\t\t\tif _, err := p.expect(TokenRBracket); err != nil {\n\t\t\t\treturn domain.OutputPath{}, err\n\t\t\t}\n\t\t\tsegments = append(segments, domain.PathSegment{Kind: domain.SegmentIndex, Index: idx})\n\t\t} else {\n\t\t\tbreak\n\t\t}\n\t}\n\n\treturn domain.OutputPath{Segments: segments}, nil\n}\n\nfunc (p *Parser) parseCollect() (domain.Collect, error) {\n\tp.advance() // consume \"collect\"\n\n\tmodeTok, err := p.expect(TokenIdent)\n\tif err != nil {\n\t\treturn domain.Collect{}, fmt.Errorf(\"expected 'all' or 'any': %w\", err)\n\t}\n\n\tvar mode domain.CollectMode\n\tswitch modeTok.Literal {\n\tcase \"all\":\n\t\tmode = domain.CollectAll\n\tcase \"any\":\n\t\tmode = domain.CollectAny\n\tdefault:\n\t\treturn domain.Collect{}, fmt.Errorf(\"line %d col %d: expected 'all' or 'any', got %q\",\n\t\t\tmodeTok.Line, modeTok.Col, modeTok.Literal)\n\t}\n\n\tif _, err := p.expect(TokenLParen); err != nil {\n\t\treturn domain.Collect{}, err\n\t}\n\n\tvar conditions []domain.WireCondition\n\tfor p.current.Type != TokenRParen && p.current.Type != TokenEOF {\n\t\tstepTok, err := p.expect(TokenIdent)\n\t\tif err != nil {\n\t\t\treturn domain.Collect{}, fmt.Errorf(\"expected step name in collect: %w\", err)\n\t\t}\n\t\tif _, err := p.expect(TokenColon); err != nil {\n\t\t\treturn domain.Collect{}, err\n\t\t}\n\t\tresultTok, err := p.expect(TokenIdent)\n\t\tif err != nil {\n\t\t\treturn domain.Collect{}, fmt.Errorf(\"expected result name in collect: %w\", err)\n\t\t}\n\t\tconditions = append(conditions, domain.WireCondition{Step: stepTok.Literal, Result: resultTok.Literal})\n\t\tif p.current.Type == TokenComma {\n\t\t\tp.advance()\n\t\t}\n\t}\n\n\tif _, err := p.expect(TokenRParen); err != nil {\n\t\treturn domain.Collect{}, err\n\t}\n\tif _, err := p.expect(TokenArrow); err != nil {\n\t\treturn domain.Collect{}, err\n\t}\n\n\ttoTok, err := p.expect(TokenIdent)\n\tif err != nil {\n\t\treturn domain.Collect{}, fmt.Errorf(\"expected target step: %w\", err)\n\t}\n\n\treturn domain.Collect{\n\t\tMode:       mode,\n\t\tConditions: conditions,\n\t\tTo:         toTok.Literal,\n\t}, nil\n}\n","numLines":691,"startLine":1,"totalLines":691}}}
