[2026-03-09T21:12:19Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PhHwdqoLqxos6CVajbCJLX","type":"tool_result","content":"     1â†’package docker\n     2â†’\n     3â†’import (\n     4â†’\t\"bytes\"\n     5â†’\t\"context\"\n     6â†’\t\"fmt\"\n     7â†’\t\"os\"\n     8â†’\t\"os/exec\"\n     9â†’\t\"path/filepath\"\n    10â†’)\n    11â†’\n    12â†’// ExtractResults copies the container workspace to a git branch using worktrees.\n    13â†’// It creates branch cloche/<runID> based on baseSHA, copies the container's\n    14â†’// /workspace into the worktree's cloche/ directory, commits, and cleans up.\n    15â†’func ExtractResults(ctx context.Context, containerID, projectDir, runID, baseSHA, workflowName, result string) error {\n    16â†’\tif baseSHA == \"\" {\n    17â†’\t\treturn fmt.Errorf(\"no base SHA recorded for run %s\", runID)\n    18â†’\t}\n    19â†’\n    20â†’\t// 1. Copy container workspace to temp dir\n    21â†’\ttmpDir, err := os.MkdirTemp(\"\", \"cloche-extract-\"+runID+\"-\")\n    22â†’\tif err != nil {\n    23â†’\t\treturn fmt.Errorf(\"creating temp dir: %w\", err)\n    24â†’\t}\n    25â†’\tdefer os.RemoveAll(tmpDir)\n    26â†’\n    27â†’\tcpCmd := exec.CommandContext(ctx, \"docker\", \"cp\", containerID+\":/workspace/.\", tmpDir+\"/\")\n    28â†’\tvar cpStderr bytes.Buffer\n    29â†’\tcpCmd.Stderr = &cpStderr\n    30â†’\tif err := cpCmd.Run(); err != nil {\n    31â†’\t\treturn fmt.Errorf(\"docker cp from container: %s: %w\", cpStderr.String(), err)\n    32â†’\t}\n    33â†’\n    34â†’\t// 2. Create git worktree\n    35â†’\tworktreeDir := filepath.Join(projectDir, \".gitworktrees\", \"cloche\", runID)\n    36â†’\tif err := os.MkdirAll(filepath.Dir(worktreeDir), 0755); err != nil {\n    37â†’\t\treturn fmt.Errorf(\"creating worktree parent: %w\", err)\n    38â†’\t}\n    39â†’\n    40â†’\taddCmd := exec.CommandContext(ctx, \"git\", \"worktree\", \"add\", \"--detach\", worktreeDir, baseSHA)\n    41â†’\taddCmd.Dir = projectDir\n    42â†’\tif out, err := addCmd.CombinedOutput(); err != nil {\n    43â†’\t\treturn fmt.Errorf(\"git worktree add: %s: %w\", out, err)\n    44â†’\t}\n    45â†’\tdefer func() {\n    46â†’\t\trmCmd := exec.CommandContext(ctx, \"git\", \"worktree\", \"remove\", \"--force\", worktreeDir)\n    47â†’\t\trmCmd.Dir = projectDir\n    48â†’\t\trmCmd.Run()\n    49â†’\t}()\n    50â†’\n    51â†’\t// 3. Copy temp dir contents into worktree root, excluding .git\n    52â†’\t// The container includes .git/ as a full directory, but the worktree has a\n    53â†’\t// .git file pointing back to the main repo. We must not overwrite it.\n    54â†’\tos.RemoveAll(filepath.Join(tmpDir, \".git\"))\n    55â†’\tcpLocalCmd := exec.CommandContext(ctx, \"cp\", \"-a\", tmpDir+\"/.\", worktreeDir+\"/\")\n    56â†’\tif out, err := cpLocalCmd.CombinedOutput(); err != nil {\n    57â†’\t\treturn fmt.Errorf(\"copying to worktree: %s: %w\", out, err)\n    58â†’\t}\n    59â†’\n    60â†’\t// 4. Create branch, add, commit\n    61â†’\tgitEnv := append(os.Environ(),\n    62â†’\t\t\"GIT_AUTHOR_NAME=cloche\", \"GIT_AUTHOR_EMAIL=cloche@local\",\n    63â†’\t\t\"GIT_COMMITTER_NAME=cloche\", \"GIT_COMMITTER_EMAIL=cloche@local\",\n    64â†’\t)\n    65â†’\n    66â†’\tbranch := \"cloche/\" + runID\n    67â†’\n    68â†’\tcheckoutCmd := exec.CommandContext(ctx, \"git\", \"checkout\", \"-b\", branch)\n    69â†’\tcheckoutCmd.Dir = worktreeDir\n    70â†’\tcheckoutCmd.Env = gitEnv\n    71â†’\tif out, err := checkoutCmd.CombinedOutput(); err != nil {\n    72â†’\t\treturn fmt.Errorf(\"git checkout -b: %s: %w\", out, err)\n    73â†’\t}\n    74â†’\n    75â†’\taddFilesCmd := exec.CommandContext(ctx, \"git\", \"add\", \"-A\")\n    76â†’\taddFilesCmd.Dir = worktreeDir\n    77â†’\taddFilesCmd.Env = gitEnv\n    78â†’\tif out, err := addFilesCmd.CombinedOutput(); err != nil {\n    79â†’\t\treturn fmt.Errorf(\"git add: %s: %w\", out, err)\n    80â†’\t}"}]},"parent_tool_use_id":"toolu_01BwC3jW9U52qS7AfxsmW3Le","session_id":"c6864ddb-8a62-468e-9371-23940235ec7e","uuid":"254310eb-656f-47dd-a78e-4d0e3510d195"}
