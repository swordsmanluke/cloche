:= web.NewHandler(store, store, webOpts...)\n    92â†’\t\tif err != nil {\n    93â†’\t\t\tfmt.Fprintf(os.Stderr, \"failed to create web handler: %v\\n\", err)\n    94â†’\t\t\tos.Exit(1)\n    95â†’\t\t}\n    96â†’\t\thttpServer = &http.Server{Addr: httpAddr, Handler: webHandler}\n    97â†’\t\tgo func() {\n    98â†’\t\t\tfmt.Fprintf(os.Stderr, \"cloched web dashboard on http://%s\\n\", httpAddr)\n    99â†’\t\t\tif err := httpServer.ListenAndServe(); err != nil && err != http.ErrServerClosed {\n   100â†’\t\t\t\tfmt.Fprintf(os.Stderr, \"http server error: %v\\n\", err)\n   101â†’\t\t\t}\n   102â†’\t\t}()\n   103â†’\t}\n   104â†’\n   105â†’\t// Auto-execute main workflow for active projects\n   106â†’\tautoRunActiveProjects(store, srv)\n   107â†’\n   108â†’\tsigCh := make(chan os.Signal, 1)\n   109â†’\tsignal.Notify(sigCh, syscall.SIGTERM, syscall.SIGINT)\n   110â†’\tgo func() {\n   111â†’\t\t<-sigCh\n   112â†’\t\tif httpServer != nil {\n   113â†’\t\t\thttpServer.Close()\n   114â†’\t\t}\n   115â†’\t\tgrpcServer.GracefulStop()\n   116â†’\t}()\n   117â†’\n   118â†’\tfmt.Fprintf(os.Stderr, \"cloched listening on %s\\n\", listenAddr)\n   119â†’\tif err := grpcServer.Serve(lis); err != nil {\n   120â†’\t\tfmt.Fprintf(os.Stderr, \"server error: %v\\n\", err)\n   121â†’\t\tos.Exit(1)\n   122â†’\t}\n   123â†’}\n   124â†’\n   125â†’func initRuntime(cfg *config.Config) (ports.ContainerRuntime, error) {\n   126â†’\truntimeType := envOrConfig(\"CLOCHE_RUNTIME\", cfg.Daemon.Runtime, \"docker\")\n   127â†’\n   128â†’\tswitch runtimeType {\n   129â†’\tcase \"local\":\n   130â†’\t\tagentPath := envOrConfig(\"CLOCHE_AGENT_PATH\", cfg.Daemon.AgentPath, \"\")\n   131â†’\t\tif agentPath == \"\" {\n   132â†’\t\t\t// Look for cloche-agent next to this binary\n   133â†’\t\t\texe, err := os.Executable()\n   134â†’\t\t\tif err == nil {\n   135â†’\t\t\t\tagentPath = filepath.Join(filepath.Dir(exe), \"cloche-agent\")\n   136â†’\t\t\t} else {\n   137â†’\t\t\t\tagentPath = \"cloche-agent\"\n   138â†’\t\t\t}\n   139â†’\t\t}\n   140â†’\t\treturn local.NewRuntime(agentPath), nil\n   141â†’\tcase \"docker\":\n   142â†’\t\treturn docker.NewRuntime()\n   143â†’\tdefault:\n   144â†’\t\treturn nil, fmt.Errorf(\"unknown runtime: %s\", runtimeType)\n   145â†’\t}\n   146â†’}\n   147â†’\n   148â†’func initEvolution(globalCfg *config.Config, evoStore ports.EvolutionStore, capStore ports.CaptureStore) *evolution.Trigger {\n   149â†’\t// Load config from working directory (daemon-level defaults)\n   150â†’\tcfg, err := config.Load(\".\")\n   151â†’\tif err != nil || !cfg.Evolution.Enabled {\n   152â†’\t\treturn nil\n   153â†’\t}\n   154â†’\n   155â†’\tllmCmd := envOrConfig(\"CLOCHE_LLM_COMMAND\", globalCfg.Daemon.LLMCommand, \"\")\n   156â†’\tif llmCmd == \"\" {\n   157â†’\t\treturn nil\n   158â†’\t}\n   159â†’\n   160â†’\ttrigger := evolution.NewTrigger(evolution.TriggerConfig{\n   161â†’\t\tDebounceSeconds: cfg.Evolution.DebounceSeconds,\n   162â†’\t\tRunFunc: func(projectDir, workflowName, runID string) {\n   163â†’\t\t\t// Load per-project config for confidence threshold\n   164â†’\t\t\tprojCfg, err := config.Load(projectDir)\n   165â†’\t\t\tif err != nil {\n   166â†’\t\t\t\tprojCfg = cfg // fall back to daemon config\n   167â†’\t\t\t}\n   168â†’\n   169â†’\t\t\tllm := &evolution.CommandLLMClient{Command: llmCmd}\n   170â†’\t\t\torch := evolution.NewOrchestrator(evolution.OrchestratorConfig{\n   171â†’\t\t\t\tProjectDir:    projectDir,\n   172â†’\t\t\t\tWorkflowName:  workflowName,\n   173â†’\t\t\t\tLLM:           llm,\n   174â†’\t\t\t\tMinConfidence: projCfg.Evolution.MinConfidence,\n   175â†’\t\t\t})\n   176â†’\n   177â†’\t\t\tctx := context.Background()\n   178â†’\t\t\tif _, err := orch.Run(ctx, runID, evoStore, capStore); err != nil {\n   179â†’\t\t\t\tfmt.Fprintf(os.Stderr, \"evolution error for %s/%s: %v\\n\", projectDir, workflowName, err)\n   180â†’\t\t\t}\n   181â†’\t\t},\n   182â†’\t})\n   183â†’\n   184â†’\treturn trigger\n   185â†’}\n   186â†’\n   187â†’func listen(addr string) (net.Listener, error) {\n   188â†’\tif len(addr) > 7 && addr[:7] == \"unix://\" {\n   189â†’\t\tsockPath := addr[7:]\n   190â†’\t\tos.Remove(sockPath)\n   191â†’\t\treturn net.Listen(\"unix\", sockPath)\n   192â†’\t}\n   193â†’\treturn net.Listen(\"tcp\", addr)\n   194â†’}\n   195â†’\n   196â†’// autoRunActiveProjects scans known projects for active = true in their config,\n   197â†’// parses .cloche/host.cloche and executes the full host workflow step by step.\n   198â†’func autoRunActiveProjects(store ports.RunStore, srv *adaptgrpc.ClocheServer) {\n   199â†’\tctx := context.Background()\n   200â†’\tprojects, err := store.ListProjects(ctx)\n   201â†’\tif err != nil {\n   202â†’\t\tfmt.Fprintf(os.Stderr, \"startup: failed to list projects: %v\\n\", err)\n   203â†’\t\treturn\n   204â†’\t}\n   205â†’\n   206â†’\tfor _, projectDir := range projects {\n   207â†’\t\tcfg, err := config.Load(projectDir)\n   208â†’\t\tif err != nil || !cfg.Active {\n   209â†’\t\t\tcontinue\n   210â†’\t\t}\n   211â†’\n   212â†’\t\t// Verify host.cloche exists before launching\n   213â†’\t\thostPath := filepath.Join(projectDir, \".cloche\", \"host.cloche\")\n   214â†’\t\tif _, err := os.Stat(hostPath); err != nil {\n   215â†’\t\t\tfmt.Fprintf(os.Stderr, \"startup: skipping active project %s: %v\\n\", projectDir, err)\n   216â†’\t\t\tcontinue\n   217â†’\t\t}\n   218â†’\n   219â†’\t\tfmt.Fprintf(os.Stderr, \"startup: auto-running host workflow for active project %s\\n\", projectDir)\n   220â†’\t\tgo func(projDir string) {\n   221â†’\t\t\trunner := &hostpkg.Runner{\n   222â†’\t\t\t\tDispatcher: srv,\n   223â†’\t\t\t\tStore:      store,\n   224â†’\t\t\t}\n   225â†’\t\t\tresult, err := runner.Run(context.Background(), projDir)\n   226â†’\t\t\tif err != nil {\n   227â†’\t\t\t\tfmt.Fprintf(os.Stderr, \"startup: host workflow failed for %s: %v\\n\", projDir, err)\n   228â†’\t\t\t} else {\n   229â†’\t\t\t\tfmt.Fprintf(os.Stderr, \"startup: host workflow completed for %s: %s (run %s