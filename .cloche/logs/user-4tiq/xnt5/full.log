() {\n   683â†’\t\t\tcontinue\n   684â†’\t\t}\n   685â†’\t\tname := entry.Name()\n   686â†’\t\tif !strings.HasSuffix(name, \".log\") {\n   687â†’\t\t\tcontinue\n   688â†’\t\t}\n   689â†’\n   690â†’\t\tvar fileType, stepName string\n   691â†’\t\tbase := strings.TrimSuffix(name, \".log\")\n   692â†’\n   693â†’\t\tswitch {\n   694â†’\t\tcase name == \"full.log\":\n   695â†’\t\t\tfileType = \"full\"\n   696â†’\t\tcase name == \"container.log\":\n   697â†’\t\t\t// container.log is internal, not indexed as a user-facing log type\n   698â†’\t\t\tcontinue\n   699â†’\t\tcase strings.HasPrefix(name, \"llm-\"):\n   700â†’\t\t\tfileType = \"llm\"\n   701â†’\t\t\tstepName = strings.TrimPrefix(base, \"llm-\")\n   702â†’\t\tdefault:\n   703â†’\t\t\tfileType = \"script\"\n   704â†’\t\t\tstepName = base\n   705â†’\t\t}\n   706â†’\n   707â†’\t\tinfo, _ := entry.Info()\n   708â†’\t\tvar fileSize int64\n   709â†’\t\tif info != nil {\n   710â†’\t\t\tfileSize = info.Size()\n   711â†’\t\t}\n   712â†’\n   713â†’\t\tlogEntry := &ports.LogFileEntry{\n   714â†’\t\t\tRunID:     runID,\n   715â†’\t\t\tStepName:  stepName,\n   716â†’\t\t\tFileType:  fileType,\n   717â†’\t\t\tFilePath:  filepath.Join(outputDir, name),\n   718â†’\t\t\tFileSize:  fileSize,\n   719â†’\t\t\tCreatedAt: now,\n   720â†’\t\t}\n   721â†’\t\tif err := s.logStore.SaveLogFile(ctx, logEntry); err != nil {\n   722â†’\t\t\tlog.Printf(\"run %s: failed to index log file %s: %v\", runID, name, err)\n   723â†’\t\t}\n   724â†’\t}\n   725â†’}\n   726â†’\n   727â†’func gitHEAD(dir string) string {\n   728â†’\tcmd := exec.Command(\"git\", \"rev-parse\", \"HEAD\")\n   729â†’\tcmd.Dir = dir\n   730â†’\tout, err := cmd.Output()\n   731â†’\tif err != nil {\n   732â†’\t\treturn \"\"\n   733â†’\t}\n   734â†’\treturn strings.TrimSpace(string(out))\n   735â†’}\n   736â†’"}]},"parent_tool_use_id":"toolu_01BwC3jW9U52qS7AfxsmW3Le","session_id":"c6864ddb-8a62-468e-9371-23940235ec7e","uuid":"de22d8cb-8d7a-4795-b0c6-e0910d936dd2"}
