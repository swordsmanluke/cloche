[2026-03-09T21:13:29Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VJo5UiistjifBbonRMt2xj","type":"tool_result","content":"     1â†’package host\n     2â†’\n     3â†’import (\n     4â†’\t\"context\"\n     5â†’\t\"fmt\"\n     6â†’\t\"log\"\n     7â†’\t\"os\"\n     8â†’\t\"os/exec\"\n     9â†’\t\"path/filepath\"\n    10â†’\t\"time\"\n    11â†’\n    12â†’\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    13â†’\t\"github.com/cloche-dev/cloche/internal/domain\"\n    14â†’\t\"github.com/cloche-dev/cloche/internal/engine\"\n    15â†’\t\"github.com/cloche-dev/cloche/internal/ports\"\n    16â†’\t\"github.com/cloche-dev/cloche/internal/protocol\"\n    17â†’)\n    18â†’\n    19â†’// RunDispatcher dispatches a container workflow run and returns the run ID.\n    20â†’type RunDispatcher interface {\n    21â†’\tRunWorkflow(ctx context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error)\n    22â†’}\n    23â†’\n    24â†’// Executor implements engine.StepExecutor for host workflow steps.\n    25â†’type Executor struct {\n    26â†’\tProjectDir string\n    27â†’\tDispatcher RunDispatcher\n    28â†’\tStore      ports.RunStore\n    29â†’\tOutputDir  string // directory for step output files\n    30â†’}\n    31â†’\n    32â†’var _ engine.StepExecutor = (*Executor)(nil)\n    33â†’\n    34â†’// Execute runs a single host workflow step.\n    35â†’func (e *Executor) Execute(ctx context.Context, step *domain.Step) (string, error) {\n    36â†’\tswitch step.Type {\n    37â†’\tcase domain.StepTypeScript:\n    38â†’\t\treturn e.executeScript(ctx, step)\n    39â†’\tcase domain.StepTypeWorkflow:\n    40â†’\t\treturn e.executeWorkflow(ctx, step)\n    41â†’\tdefault:\n    42â†’\t\treturn \"\", fmt.Errorf(\"unsupported step type %q in host workflow\", step.Type)\n    43â†’\t}\n    44â†’}\n    45â†’\n    46â†’// executeScript runs a shell command on the host.\n    47â†’func (e *Executor) executeScript(ctx context.Context, step *domain.Step) (string, error) {\n    48â†’\tcmdStr := step.Config[\"run\"]\n    49â†’\tcmd := exec.CommandContext(ctx, \"sh\", \"-c\", cmdStr)\n    50â†’\tcmd.Dir = e.ProjectDir\n    51â†’\tcmd.Env = append(os.Environ(),\n    52â†’\t\t\"CLOCHE_PROJECT_DIR=\"+e.ProjectDir,\n    53â†’\t\t\"CLOCHE_STEP_OUTPUT=\"+e.stepOutputPath(step.Name),\n    54â†’\t)\n    55â†’\n    56â†’\t// Pass previous step output if available\n    57â†’\tif prevOutput := e.findPrevOutput(step); prevOutput != \"\" {\n    58â†’\t\tcmd.Env = append(cmd.Env, \"CLOCHE_PREV_OUTPUT=\"+prevOutput)\n    59â†’\t}\n    60â†’\n    61â†’\toutput, err := cmd.CombinedOutput()\n    62â†’\n    63â†’\t// Extract result marker\n    64â†’\tmarkerResult, cleanOutput, found := protocol.ExtractResult(output)\n    65â†’\n    66â†’\t// Write output to file\n    67â†’\tif mkErr := os.MkdirAll(e.OutputDir, 0755); mkErr == nil {\n    68â†’\t\t_ = os.WriteFile(e.stepOutputPath(step.Name), cleanOutput, 0644)\n    69â†’\t}\n    70â†’\n    71â†’\tif err != nil {\n    72â†’\t\tif _, ok := err.(*exec.ExitError); ok {\n    73â†’\t\t\tresult := \"fail\"\n    74â†’\t\t\tif found {\n    75â†’\t\t\t\tresult = markerResult\n    76â†’\t\t\t}\n    77â†’\t\t\treturn result, nil\n    78â†’\t\t}\n    79â†’\t\treturn \"\", err\n    80â†’\t}\n    81â†’\n    82â†’\tresult := \"success\"\n    83â†’\tif found {\n    84â†’\t\tresult = markerResult\n    85â†’\t}\n    86â†’\treturn result, nil\n    87â†’}\n    88â†’\n    89â†’// executeWorkflow dispatches a container workflow run and blocks until it completes.\n    90â†’func (e *Executor) executeWorkflow(ctx context.Context, step *domain.Step) (string, error) {\n    91â†’\tworkflowName := step.Config[\"workflow_name\"]\n    92â†’\tif workflowName == \"\" {\n    93â†’\t\treturn \"\", fmt.Errorf(\"workflow step %q missing workflow_name\", step.Name)\n    94â†’\t}\n    95â†’\n    96â†’\t// Read prompt from previous step output or prompt_step override\n    97â†’\tvar promptContent string\n    98â†’\tpromptSource := step.Config[\"prompt_step\"]\n    99â†’\tif promptSource != \"\" {\n   100â†’\t\tdata, err := os.ReadFile(e.stepOutputPath(promptSource))\n   101â†’\t\tif err == nil {\n   102â†’\t\t\tpromptContent = string(data)\n   103â†’\t\t}\n   104â†’\t} else if prev := e.findPrevOutput(step); prev != \"\" {\n   105â†’\t\tdata, err := os.ReadFile(prev)\n   106â†’\t\tif err == nil {\n   107â†’\t\t\tpromptContent = string(data)\n   108â†’\t\t}\n   109â†’\t}\n   110â†’\n   111â†’\tresp, err := e.Dispatcher.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n   112â†’\t\tWorkflowName: workflowName,\n   113â†’\t\tProjectDir:   e.ProjectDir,\n   114â†’\t\tPrompt:       promptContent,\n   115â†’\t})\n   116â†’\tif err != nil {\n   117â†’\t\treturn \"\", fmt.Errorf(\"dispatching workflow %q: %w\", workflowName, err)\n   118â†’\t}\n   119â†’\n   120â†’\tlog.Printf(\"host executor: dispatched container workflow %q as run %s\", workflowName, resp.RunId)\n   121â†’\n   122â†’\t// Poll until the run reaches a terminal state\n   123â†’\tstate, err := e.waitForRun(ctx, resp.RunId)\n   124â†’\tif err != nil {\n   125â†’\t\treturn \"\", fmt.Errorf(\"waiting for workflow %q run %s: %w\", workflowName, resp.RunId, err)\n   126â†’\t}\n   127â†’\n   128â†’\tlog.Printf(\"host executor: workflow %q run %s completed with state %s\", workflowName, resp.RunId, state)\n   129â†’\n   130â†’\t// Map run state to step result\n   131â†’\tif state == domain.RunStateSucceeded {\n   132â†’\t\treturn \"success\", nil\n   133â†’\t}\n   134â†’\treturn \"fail\", nil\n   135â†’}\n   136â†’\n   137â†’// waitForRun polls the store until the run reaches a terminal state.\n   138â†’func (e *Executor) waitForRun(ctx context.Context, runID string) (domain.RunState, error) {\n   139â†’\tticker := time.NewTicker(2 * time.Second)\n   140â†’\tdefer ticker.Stop()\n   141â†’\n   142â†’\tfor {\n   143â†’\t\tselect {\n   144â†’\t\tcase <-ctx.Done():\n   145â†’\t\t\treturn \"\", fmt.Errorf(\"context cancelled while waiting for run %s: %w\", runID, ctx.Err())\n   146â†’\t\tcase <-ticker.C:\n   147â†’\t\t\trun, err := e.Store.GetRun(ctx, runID)\n   148â†’\t\t\tif err != nil {\n   149â†’\t\t\t\tcontinue // transient error, retry\n   150â†’\t\t\t}\n   151â†’\t\t\tswitch run.State {\n   152â†’\t\t\tcase domain.RunStateSucceeded, domain.RunStateFailed, domain.RunStateCancelled:\n   153â†’\t\t\t\treturn run.State, nil\n   154â†’\t\t\t}\n   155â†’\t\t\t// Still pending or running, continue polling\n   156â†’\t\t}\n   157â†’\t}\n   158â†’}\n   159â†’\n   160â†’// stepOutputPath returns the path for a step's output file.\n   161â†’func (e *Executor) stepOutputPath(stepName string) string {\n   162â†’\treturn filepath.Join(e.OutputDir, stepName+\".out\")\n   163â†’}\n   164â†’\n   165â†’// findPrevOutput looks for the most recent output file from any previously completed step.\n   166â†’// This is a simplified approach â€” the engine doesn't expose ordering info,\n   167â†’// so we check for common output files that might exist.\n   168â†’func (e *Executor) findPrevOutput(step *domain.Step) string {\n   169â†’\t// Check if there's a prompt_step config\n   170â†’\tif ps := step.Config[\"prompt_step\"]; ps != \"\" {\n   171â†’\t\tpath := e.stepOutputPath(ps)\n   172â†’\t\tif _, err := os.Stat(path); err == nil {\n   173â†’\t\t\treturn path\n   174â†’\t\t}\n   175â†’\t}\n   176â†’\treturn \"\"\n   177â†’}\n   178â†’"}]},"parent_tool_use_id":null,"session_id":"9be06376-5a43-40f9-8380-030cf073c859","uuid":"a4b55230-97c9-4f2d-b96c-9a243535482b","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/host/executor.go","content":"package host\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"log\"\n\t\"os\"\n\t\"os/exec\"\n\t\"path/filepath\"\n\t\"time\"\n\n\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/engine\"\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n\t\"github.com/cloche-dev/cloche/internal/protocol\"\n)\n\n// RunDispatcher dispatches a container workflow run and returns the run ID.\ntype RunDispatcher interface {\n\tRunWorkflow(ctx context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error)\n}\n\n// Executor implements engine.StepExecutor for host workflow steps.\ntype Executor struct {\n\tProjectDir string\n\tDispatcher RunDispatcher\n\tStore      ports.RunStore\n\tOutputDir  string // directory for step output files\n}\n\nvar _ engine.StepExecutor = (*Executor)(nil)\n\n// Execute runs a single host workflow step.\nfunc (e *Executor) Execute(ctx context.Context, step *domain.Step) (string, error) {\n\tswitch step.Type {\n\tcase domain.StepTypeScript:\n\t\treturn e.executeScript(ctx, step)\n\tcase domain.StepTypeWorkflow:\n\t\treturn e.executeWorkflow(ctx, step)\n\tdefault:\n\t\treturn \"\", fmt.Errorf(\"unsupported step type %q in host workflow\", step.Type)\n\t}\n}\n\n// executeScript runs a shell command on the host.\nfunc (e *Executor) executeScript(ctx context.Context, step *domain.Step) (string, error) {\n\tcmdStr := step.Config[\"run\"]\n\tcmd := exec.CommandContext(ctx, \"sh\", \"-c\", cmdStr)\n\tcmd.Dir = e.ProjectDir\n\tcmd.Env = append(os.Environ(),\n\t\t\"CLOCHE_PROJECT_DIR=\"+e.ProjectDir,\n\t\t\"CLOCHE_STEP_OUTPUT=\"+e.stepOutputPath(step.Name),\n\t)\n\n\t// Pass previous step output if available\n\tif prevOutput := e.findPrevOutput(step); prevOutput != \"\" {\n\t\tcmd.Env = append(cmd.Env, \"CLOCHE_PREV_OUTPUT=\"+prevOutput)\n\t}\n\n\toutput, err := cmd.CombinedOutput()\n\n\t// Extract result marker\n\tmarkerResult, cleanOutput, found := protocol.ExtractResult(output)\n\n\t// Write output to file\n\tif mkErr := os.MkdirAll(e.OutputDir, 0755); mkErr == nil {\n\t\t_ = os.WriteFile(e.stepOutputPath(step.Name), cleanOutput, 0644)\n\t}\n\n\tif err != nil {\n\t\tif _, ok := err.(*exec.ExitError); ok {\n\t\t\tresult := \"fail\"\n\t\t\tif found {\n\t\t\t\tresult = markerResult\n\t\t\t}\n\t\t\treturn result, nil\n\t\t}\n\t\treturn \"\", err\n\t}\n\n\tresult := \"success\"\n\tif found {\n\t\tresult = markerResult\n\t}\n\treturn result, nil\n}\n\n// executeWorkflow dispatches a container workflow run and blocks until it completes.\nfunc (e *Executor) executeWorkflow(ctx context.Context, step *domain.Step) (string, error) {\n\tworkflowName := step.Config[\"workflow_name\"]\n\tif workflowName == \"\" {\n\t\treturn \"\", fmt.Errorf(\"workflow step %q missing workflow_name\", step.Name)\n\t}\n\n\t// Read prompt from previous step output or prompt_step override\n\tvar promptContent string\n\tpromptSource := step.Config[\"prompt_step\"]\n\tif promptSource != \"\" {\n\t\tdata, err := os.ReadFile(e.stepOutputPath(promptSource))\n\t\tif err == nil {\n\t\t\tpromptContent = string(data)\n\t\t}\n\t} else if prev := e.findPrevOutput(step); prev != \"\" {\n\t\tdata, err := os.ReadFile(prev)\n\t\tif err == nil {\n\t\t\tpromptContent = string(data)\n\t\t}\n\t}\n\n\tresp, err := e.Dispatcher.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n\t\tWorkflowName: workflowName,\n\t\tProjectDir:   e.ProjectDir,\n\t\tPrompt:       promptContent,\n\t})\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"dispatching workflow %q: %w\", workflowName, err)\n\t}\n\n\tlog.Printf(\"host executor: dispatched container workflow %q as run %s\", workflowName, resp.RunId)\n\n\t// Poll until the run reaches a terminal state\n\tstate, err := e.waitForRun(ctx, resp.RunId)\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"waiting for workflow %q run %s: %w\", workflowName, resp.RunId, err)\n\t}\n\n\tlog.Printf(\"host executor: workflow %q run %s completed with state %s\", workflowName, resp.RunId, state)\n\n\t// Map run state to step result\n\tif state == domain.RunStateSucceeded {\n\t\treturn \"success\", nil\n\t}\n\treturn \"fail\", nil\n}\n\n// waitForRun polls the store until the run reaches a terminal state.\nfunc (e *Executor) waitForRun(ctx context.Context, runID string) (domain.RunState, error) {\n\tticker := time.NewTicker(2 * time.Second)\n\tdefer ticker.Stop()\n\n\tfor {\n\t\tselect {\n\t\tcase <-ctx.Done():\n\t\t\treturn \"\", fmt.Errorf(\"context cancelled while waiting for run %s: %w\", runID, ctx.Err())\n\t\tcase <-ticker.C:\n\t\t\trun, err := e.Store.GetRun(ctx, runID)\n\t\t\tif err != nil {\n\t\t\t\tcontinue // transient error, retry\n\t\t\t}\n\t\t\tswitch run.State {\n\t\t\tcase domain.RunStateSucceeded, domain.RunStateFailed, domain.RunStateCancelled:\n\t\t\t\treturn run.State, nil\n\t\t\t}\n\t\t\t// Still pending or running, continue polling\n\t\t}\n\t}\n}\n\n// stepOutputPath returns the path for a step's output file.\nfunc (e *Executor) stepOutputPath(stepName string) string {\n\treturn filepath.Join(e.OutputDir, stepName+\".out\")\n}\n\n// findPrevOutput looks for the most recent output file from any previously completed step.\n// This is a simplified approach â€” the engine doesn't expose ordering info,\n// so we check for common output files that might exist.\nfunc (e *Executor) findPrevOutput(step *domain.Step) string {\n\t// Check if there's a prompt_step config\n\tif ps := step.Config[\"prompt_step\"]; ps != \"\" {\n\t\tpath := e.stepOutputPath(ps)\n\t\tif _, err := os.Stat(path); err == nil {\n\t\t\treturn path\n\t\t}\n\t}\n\treturn \"\"\n}\n","numLines":178,"startLine":1,"totalLines":178}}}
[2026-03-09T21:13:29Z] [llm] {"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_017LsvASCsqpV8VhSXfrBMAz","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01BLBSwtArvA1VyeF2gJs9ro","name":"Read","input":{"file_path":"/workspace/docs/plans/2026-03-06-host-workflow-design.md"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":4229,"cache_read_input_tokens":15049,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":4229},"output_tokens":18,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"9be06376-5a43-40f9-8380-030cf073c859","uuid":"53881cdd-65c7-4e59-93c7-4e05a6d5c2f7"}
[2026-03-09T21:13:29Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BLBSwtArvA1VyeF2gJs9ro","type":"tool_result","content":"     1â†’# Host Workflow Design (`host.cloche`)\n     2â†’\n     3â†’**Date:** 2026-03-06\n     4â†’**Status:** Design\n     5â†’\n     6â†’## Problem\n     7â†’\n     8â†’The orchestrator's intake â†’ process â†’ output loop is hard-coded in Go\n     9â†’(`internal/orchestrator/orchestrator.go`). Every project must follow the same flow:\n    10â†’pull task â†’ generate prompt â†’ dispatch `develop` container run. This can't be changed\n    11â†’without modifying Cloche itself. Projects that need different orchestration strategies\n    12â†’(push to GitHub for review, group tickets into feature branches, stacked commits, etc.)\n    13â†’have no extension point.\n    14â†’\n    15â†’## Solution: `host.cloche`\n    16â†’\n    17â†’A special workflow file at `.cloche/host.cloche`. It uses the same DSL as container\n    18â†’workflow files, with one additional step type (`workflow`). Steps in this file execute\n    19â†’on the **host machine**, not inside a container.\n    20â†’\n    21â†’The workflow named `main` in this file becomes the per-task orchestration loop\n    22â†’for that project. The Go daemon becomes the executor of this workflow rather than the\n    23â†’hard-coded logic holder.\n    24â†’\n    25â†’### File location\n    26â†’\n    27â†’```\n    28â†’.cloche/host.cloche\n    29â†’```\n    30â†’\n    31â†’If the file does not exist, the daemon falls back to the current hard-coded behavior\n    32â†’(pull task â†’ LLM prompt generation â†’ dispatch container workflow).\n    33â†’\n    34â†’---\n    35â†’\n    36â†’## DSL additions\n    37â†’\n    38â†’### New step type: `workflow`\n    39â†’\n    40â†’A step with `workflow_name` config key is a workflow-dispatch step. It dispatches a\n    41â†’named container workflow run and blocks until that run completes.\n    42â†’\n    43â†’```\n    44â†’step develop {\n    45â†’  workflow_name = \"develop\"\n    46â†’  results = [success, fail]\n    47â†’}\n    48â†’```\n    49â†’\n    50â†’`workflow_name` is added to `knownStepConfigKeys` in `domain/workflow.go`.\n    51â†’\n    52â†’`StepTypeWorkflow` is added to the `StepType` enum in `domain/workflow.go`.\n    53â†’\n    54â†’The parser (`dsl/parser.go`) infers `StepTypeWorkflow` when `workflow_name` is present\n    55â†’(same pattern as `run` â†’ script, `prompt` â†’ agent).\n    56â†’\n    57â†’### Prompt input for `workflow` steps\n    58â†’\n    59â†’The container workflow needs a prompt. By convention, a `workflow` step reads the\n    60â†’previous step's captured output file as the prompt. This is the primary data-passing\n    61â†’mechanism.\n    62â†’\n    63â†’An optional config key `prompt_step` overrides which step's output to read:\n    64â†’```\n    65â†’step develop {\n    66â†’  workflow_name = \"develop\"\n    67â†’  prompt_step   = \"prepare-prompt\"\n    68â†’  results       = [success, fail]\n    69â†’}\n    70â†’```\n    71â†’\n    72â†’---\n    73â†’\n    74â†’## Step output capture\n    75â†’\n    76â†’Every step in a host workflow execution writes its output (stdout of `run` steps,\n    77â†’final response of `prompt` steps) to a file:\n    78â†’\n    79â†’```\n    80â†’.cloche/<orch-run-id>/main/<step_name>.out\n    81â†’```\n    82â†’\n    83â†’`<orch-run-id>` is a unique ID for this orchestration invocation, formatted the same\n    84â†’way as workflow run IDs (e.g. `main-bold-hawk`).\n    85â†’\n    86â†’The daemon tracks the most recently completed step's output path and passes it to the\n    87â†’next step as `CLOCHE_PREV_OUTPUT`.\n    88â†’\n    89â†’---\n    90â†’\n    91â†’## Environment variables injected into host steps\n    92â†’\n    93â†’All `run` and `prompt` steps receive:\n    94â†’\n    95â†’| Variable | Value |\n    96â†’|----------|-------|\n    97â†’| `CLOCHE_TASK_ID` | Task ID being processed |\n    98â†’| `CLOCHE_TASK_TITLE` | Task summary/title |\n    99â†’| `CLOCHE_TASK_BODY` | Task full body/description |\n   100â†’| `CLOCHE_PROJECT_DIR` | Absolute path to the project directory |\n   101â†’| `CLOCHE_STEP_OUTPUT` | Path where this step should write its output |\n   102â†’| `CLOCHE_PREV_OUTPUT` | Path to the previous step's output file |\n   103â†’\n   104â†’For `workflow` steps, `CLOCHE_PREV_OUTPUT` is read automatically (unless `prompt_step`\n   105â†’overrides it).\n   106â†’\n   107â†’---\n   108â†’\n   109â†’## Executor: `internal/orchestrator/hostrunner.go`\n   110â†’\n   111â†’New file. Implements the host workflow execution loop.\n   112â†’\n   113â†’```go\n   114â†’type HostRunner struct {\n   115â†’    Dispatch  RunDispatcher      // existing: dispatches a container workflow run\n   116â†’    WaitRun   RunWaiter          // new: blocks until a run ID completes, returns final state\n   117â†’    AgentCmd  string             // command to invoke for prompt steps on host\n   118â†’}\n   119â†’\n   120â†’// RunWorkflow executes the named workflow from a parsed host.cloche Workflow\n   121â†’// for a single task. Returns the final result (\"done\" or \"abort\").\n   122â†’func (r *HostRunner) RunWorkflow(ctx context.Context, wf *domain.Workflow, task ports.Task, orchRunID string) (string, error)\n   123â†’```\n   124â†’\n   125â†’Step execution:\n   126â†’\n   127â†’- **`script` step** (`run` key): `exec.Command` with env vars, stdout captured to\n   128â†’  `<step>.out`, stderr to `<step>.err`. Exit 0 â†’ `success`, non-zero â†’ `fail`.\n   129â†’- **`agent` step** (`prompt` key): invoke `AgentCmd` on host with the prompt file\n   130â†’  contents injected. Capture output. Exit 0 â†’ `success`, non-zero â†’ `fail`.\n   131â†’- **`workflow` step** (`workflow_name` key): read prompt from prev step's `.out` file\n   132â†’  (or `prompt_step` override), call `Dispatch`, then call `WaitRun` to block until\n   133â†’  the container run completes. Map `succeeded` â†’ `success`, `failed`/`cancelled` â†’\n   134â†’  `fail`.\n   135â†’\n   136â†’`WaitRun` is a new port interface:\n   137â†’\n   138â†’```go\n   139â†’// RunWaiter blocks until the run with the given ID reaches a terminal state.\n   140â†’type RunWaiter interface {\n   141â†’    WaitRun(ctx context.Context, runID string) (domain.RunState, error)\n   142â†’}\n   143â†’```\n   144â†’\n   145â†’The gRPC server / store already has `GetRun`; the waiter can poll it with backoff or\n   146â†’subscribe to the `OnRunComplete` event. A simple polling implementation (1s interval)\n   147â†’is sufficient initially.\n   148â†’\n   149â†’---\n   150â†’\n   151â†’## Refactored `orchestrator.Orchestrator`\n   152â†’\n   153â†’`Orchestrator.Run()` is updated:\n   154â†’\n   155â†’**Current flow (hardcoded):**\n   156â†’1. Pull ready tasks\n   157â†’2. Claim task\n   158â†’3. Call `promptGen.Generate(task)`\n   159â†’4. Call `dispatch(workflow, projectDir, prompt)` â†’ runID\n   160â†’5. (In-flight counter managed, `OnRunComplete` decrements it)\n   161â†’\n   162â†’**New flow (when `host.cloche` exists):**\n   163â†’1. Pull ready tasks\n   164â†’2. Claim task\n   165â†’3. Parse `.cloche/host.cloche` â†’ find `main` workflow\n   166â†’4. Generate an `orchRunID` (`main-<namegen>`)\n   167â†’5. Spin up a goroutine: call `hostRunner.RunWorkflow(ctx, orch wf, task, orchRunID)`\n   168â†’6. On goroutine return: decrement in-flight, update task state (success/fail)\n   169â†’\n   170â†’The old `promptGen` and `dispatch` are still used as the **fallback** when\n   171â†’`host.cloche` is absent (no breaking change for existing projects).\n   172â†’\n   173â†’`WaitRun` needs access to the run store. Wire it in `initOrchestrator` in\n   174â†’`cmd/cloched/main.go`.\n   175â†’\n   176â†’---\n   177â†’\n   178â†’## Default `host.cloche` (from `cloche init`)\n   179â†’\n   180â†’```\n   181â†’# host.cloche â€” orchestration workflow (runs on host, not in container)\n   182â†’# Steps here execute as the daemon user. Keep operations simple and safe.\n   183â†’\n   184â†’workflow \"main\" {\n   185â†’  step prepare-prompt {\n   186â†’    run     = \"bash .cloche/scripts/prepare-prompt.sh\"\n   187â†’    results = [success, fail]\n   188â†’  }\n   189â†’\n   190â†’  step develop {\n   191â†’    workflow_name = \"develop\"\n   192â†’    results       = [success, fail]\n   193â†’  }\n   194â†’\n   195â†’  prepare-prompt:success -> develop\n   196â†’  prepare-prompt:fail    -> abort\n   197â†’  develop:success        -> done\n   198â†’  develop:fail           -> done\n   199â†’}\n   200â†’```\n   201â†’\n   202â†’And `.cloche/scripts/prepare-prompt.sh` (created by init, chmod +x):\n   203â†’\n   204â†’```bash\n   205â†’#!/usr/bin/env bash\n   206â†’# Default prompt generator. Uses task env vars injected by cloched.\n   207â†’# Write the prompt to $CLOCHE_STEP_OUTPUT (also echoed to stdout).\n   208â†’set -euo pipefail\n   209â†’\n   210â†’prompt=\"## Task: ${CLOCHE_TASK_TITLE}\n   211â†’\n   212â†’${CLOCHE_TASK_BODY}\"\n   213â†’\n   214â†’echo \"$prompt\"\n   215â†’[ -n \"${CLOCHE_STEP_OUTPUT:-}\" ] && echo \"$prompt\" > \"$CLOCHE_STEP_OUTPUT\"\n   216â†’```\n   217â†’\n   218â†’---\n   219â†’\n   220â†’## `.gitignore` update\n   221â†’\n   222â†’`cloche init` adds `.cloche/scripts/` is NOT gitignored (scripts are project config).\n   223â†’The orchestration run output dirs follow the same pattern as container run dirs:\n   224â†’`.cloche/main-*/` is gitignored via the existing `.cloche/*/` rule.\n   225â†’\n   226â†’---\n   227â†’\n   228â†’## Safety notes\n   229â†’\n   230â†’- Host steps run with the same OS privileges as the `cloched` process.\n   231â†’- No network isolation.\n   232â†’- `host.cloche` should only reference scripts that are committed to the project.\n   233â†’- Document that `prompt` steps in `host.cloche` invoke an LLM agent with full host\n   234â†’  filesystem access â€” use judiciously.\n   235â†’\n   236â†’---\n   237â†’\n   238â†’## Changes required\n   239â†’\n   240â†’| File | Change |\n   241â†’|------|--------|\n   242â†’| `internal/domain/workflow.go` | Add `StepTypeWorkflow`, add `workflow_name`/`prompt_step` to `knownStepConfigKeys` |\n   243â†’| `internal/dsl/parser.go` | Infer `StepTypeWorkflow` when `workflow_name` key is present |\n   244â†’| `internal/orchestrator/hostrunner.go` | New: host workflow executor |\n   245â†’| `internal/orchestrator/orchestrator.go` | Refactor `Run()` to use `HostRunner` when `host.cloche` exists; fall back to current behavior otherwise |\n   246â†’| `internal/ports/container.go` | Add `RunWaiter` interface |\n   247â†’| `cmd/cloched/main.go` | Wire `HostRunner` into orchestrator init |\n   248â†’| `cmd/cloche/init.go` | Create `host.cloche` and `scripts/prepare-prompt.sh` |\n   249â†’"}]},"parent_tool_use_id":null,"session_id":"9be06376-5a43-40f9-8380-030cf073c859","uuid":"0cec8a9f-f5b7-4183-a58f-ffd6dfd21369","tool_use_result":{"type":"text","file":{"filePath":"/workspace/docs/plans/2026-03-06-host-workflow-design.md","content":"# Host Workflow Design (`host.cloche`)\n\n**Date:** 2026-03-06\n**Status:** Design\n\n## Problem\n\nThe orchestrator's intake â†’ process â†’ output loop is hard-coded in Go\n(`internal/orchestrator/orchestrator.go`). Every project must follow the same flow:\npull task â†’ generate prompt â†’ dispatch `develop` container run. This can't be changed\nwithout modifying Cloche itself. Projects that need different orchestration strategies\n(push to GitHub for review, group tickets into feature branches, stacked commits, etc.)\nhave no extension point.\n\n## Solution: `host.cloche`\n\nA special workflow file at `.cloche/host.cloche`. It uses the same DSL as container\nworkflow files, with one additional step type (`workflow`). Steps in this file execute\non the **host machine**, not inside a container.\n\nThe workflow named `main` in this file becomes the per-task orchestration loop\nfor that project. The Go daemon becomes the executor of this workflow rather than the\nhard-coded logic holder.\n\n### File location\n\n```\n.cloche/host.cloche\n```\n\nIf the file does not exist, the daemon falls back to the current hard-coded behavior\n(pull task â†’ LLM prompt generation â†’ dispatch container workflow).\n\n---\n\n## DSL additions\n\n### New step type: `workflow`\n\nA step with `workflow_name` config key is a workflow-dispatch step. It dispatches a\nnamed container workflow run and blocks until that run completes.\n\n```\nstep develop {\n  workflow_name = \"develop\"\n  results = [success, fail]\n}\n```\n\n`workflow_name` is added to `knownStepConfigKeys` in `domain/workflow.go`.\n\n`StepTypeWorkflow` is added to the `StepType` enum in `domain/workflow.go`.\n\nThe parser (`dsl/parser.go`) infers `StepTypeWorkflow` when `workflow_name` is present\n(same pattern as `run` â†’ script, `prompt` â†’ agent).\n\n### Prompt input for `workflow` steps\n\nThe container workflow needs a prompt. By convention, a `workflow` step reads the\nprevious step's captured output file as the prompt. This is the primary data-passing\nmechanism.\n\nAn optional config key `prompt_step` overrides which step's output to read:\n```\nstep develop {\n  workflow_name = \"develop\"\n  prompt_step   = \"prepare-prompt\"\n  results       = [success, fail]\n}\n```\n\n---\n\n## Step output capture\n\nEvery step in a host workflow execution writes its output (stdout of `run` steps,\nfinal response of `prompt` steps) to a file:\n\n```\n.cloche/<orch-run-id>/main/<step_name>.out\n```\n\n`<orch-run-id>` is a unique ID for this orchestration invocation, formatted the same\nway as workflow run IDs (e.g. `main-bold-hawk`).\n\nThe daemon tracks the most recently completed step's output path and passes it to the\nnext step as `CLOCHE_PREV_OUTPUT`.\n\n---\n\n## Environment variables injected into host steps\n\nAll `run` and `prompt` steps receive:\n\n| Variable | Value |\n|----------|-------|\n| `CLOCHE_TASK_ID` | Task ID being processed |\n| `CLOCHE_TASK_TITLE` | Task summary/title |\n| `CLOCHE_TASK_BODY` | Task full body/description |\n| `CLOCHE_PROJECT_DIR` | Absolute path to the project directory |\n| `CLOCHE_STEP_OUTPUT` | Path where this step should write its output |\n| `CLOCHE_PREV_OUTPUT` | Path to the previous step's output file |\n\nFor `workflow` steps, `CLOCHE_PREV_OUTPUT` is read automatically (unless `prompt_step`\noverrides it).\n\n---\n\n## Executor: `internal/orchestrator/hostrunner.go`\n\nNew file. Implements the host workflow execution loop.\n\n```go\ntype HostRunner struct {\n    Dispatch  RunDispatcher      // existing: dispatches a container workflow run\n    WaitRun   RunWaiter          // new: blocks until a run ID completes, returns final state\n    AgentCmd  string             // command to invoke for prompt steps on host\n}\n\n// RunWorkflow executes the named workflow from a parsed host.cloche Workflow\n// for a single task. Returns the final result (\"done\" or \"abort\").\nfunc (r *HostRunner) RunWorkflow(ctx context.Context, wf *domain.Workflow, task ports.Task, orchRunID string) (string, error)\n```\n\nStep execution:\n\n- **`script` step** (`run` key): `exec.Command` with env vars, stdout captured to\n  `<step>.out`, stderr to `<step>.err`. Exit 0 â†’ `success`, non-zero â†’ `fail`.\n- **`agent` step** (`prompt` key): invoke `AgentCmd` on host with the prompt file\n  contents injected. Capture output. Exit 0 â†’ `success`, non-zero â†’ `fail`.\n- **`workflow` step** (`workflow_name` key): read prompt from prev step's `.out` file\n  (or `prompt_step` override), call `Dispatch`, then call `WaitRun` to block until\n  the container run completes. Map `succeeded` â†’ `success`, `failed`/`cancelled` â†’\n  `fail`.\n\n`WaitRun` is a new port interface:\n\n```go\n// RunWaiter blocks until the run with the given ID reaches a terminal state.\ntype RunWaiter interface {\n    WaitRun(ctx context.Context, runID string) (domain.RunState, error)\n}\n```\n\nThe gRPC server / store already has `GetRun`; the waiter can poll it with backoff or\nsubscribe to the `OnRunComplete` event. A simple polling implementation (1s interval)\nis sufficient initially.\n\n---\n\n## Refactored `orchestrator.Orchestrator`\n\n`Orchestrator.Run()` is updated:\n\n**Current flow (hardcoded):**\n1. Pull ready tasks\n2. Claim task\n3. Call `promptGen.Generate(task)`\n4. Call `dispatch(workflow, projectDir, prompt)` â†’ runID\n5. (In-flight counter managed, `OnRunComplete` decrements it)\n\n**New flow (when `host.cloche` exists):**\n1. Pull ready tasks\n2. Claim task\n3. Parse `.cloche/host.cloche` â†’ find `main` workflow\n4. Generate an `orchRunID` (`main-<namegen>`)\n5. Spin up a goroutine: call `hostRunner.RunWorkflow(ctx, orch wf, task, orchRunID)`\n6. On goroutine return: decrement in-flight, update task state (success/fail)\n\nThe old `promptGen` and `dispatch` are still used as the **fallback** when\n`host.cloche` is absent (no breaking change for existing projects).\n\n`WaitRun` needs access to the run store. Wire it in `initOrchestrator` in\n`cmd/cloched/main.go`.\n\n---\n\n## Default `host.cloche` (from `cloche init`)\n\n```\n# host.cloche â€” orchestration workflow (runs on host, not in container)\n# Steps here execute as the daemon user. Keep operations simple and safe.\n\nworkflow \"main\" {\n  step prepare-prompt {\n    run     = \"bash .cloche/scripts/prepare-prompt.sh\"\n    results = [success, fail]\n  }\n\n  step develop {\n    workflow_name = \"develop\"\n    results       = [success, fail]\n  }\n\n  prepare-prompt:success -> develop\n  prepare-prompt:fail    -> abort\n  develop:success        -> done\n  develop:fail           -> done\n}\n```\n\nAnd `.cloche/scripts/prepare-prompt.sh` (created by init, chmod +x):\n\n```bash\n#!/usr/bin/env bash\n# Default prompt generator. Uses task env vars injected by cloched.\n# Write the prompt to $CLOCHE_STEP_OUTPUT (also echoed to stdout).\nset -euo pipefail\n\nprompt=\"## Task: ${CLOCHE_TASK_TITLE}\n\n${CLOCHE_TASK_BODY}\"\n\necho \"$prompt\"\n[ -n \"${CLOCHE_STEP_OUTPUT:-}\" ] && echo \"$prompt\" > \"$CLOCHE_STEP_OUTPUT\"\n```\n\n---\n\n## `.gitignore` update\n\n`cloche init` adds `.cloche/scripts/` is NOT gitignored (scripts are project config).\nThe orchestration run output dirs follow the same pattern as container run dirs:\n`.cloche/main-*/` is gitignored via the existing `.cloche/*/` rule.\n\n---\n\n## Safety notes\n\n- Host steps run with the same OS privileges as the `cloched` process.\n- No network isolation.\n- `host.cloche` should only reference scripts that are committed to the project.\n- Document that `prompt` steps in `host.cloche` invoke an LLM agent with full host\n  filesystem access â€” use judiciously.\n\n---\n\n## Changes required\n\n| File | Change |\n|------|--------|\n| `internal/domain/workflow.go` | Add `StepTypeWorkflow`, add `workflow_name`/`prompt_step` to `knownStepConfigKeys` |\n| `internal/dsl/parser.go` | Infer `StepTypeWorkflow` when `workflow_name` key is present |\n| `internal/orchestrator/hostrunner.go` | New: host workflow executor |\n| `internal/orchestrator/orchestrator.go` | Refactor `Run()` to use `HostRunner` when `host.cloche` exists; fall back to current behavior otherwise |\n| `internal/ports/container.go` | Add `RunWaiter` interface |\n| `cmd/cloched/main.go` | Wire `HostRunner` into orchestrator init |\n| `cmd/cloche/init.go` | Create `host.cloche` and `scripts/prepare-prompt.sh` |\n","numLines":249,"startLine":1,"totalLines":249}}}
