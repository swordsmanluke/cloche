[2026-03-09T21:12:19Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RHNyEdqE79rSaWVP7ci1PY","type":"tool_result","content":"     1â†’package dsl\n     2â†’\n     3â†’import (\n     4â†’\t\"fmt\"\n     5â†’\t\"strings\"\n     6â†’\n     7â†’\t\"github.com/cloche-dev/cloche/internal/domain\"\n     8â†’)\n     9â†’\n    10â†’type Parser struct {\n    11â†’\tlexer    *Lexer\n    12â†’\tcurrent  Token\n    13â†’\tpeek     Token\n    14â†’\tlocation domain.WorkflowLocation\n    15â†’}\n    16â†’\n    17â†’// ParseOption configures the parser.\n    18â†’type ParseOption func(*Parser)\n    19â†’\n    20â†’// WithLocation sets the workflow location, enabling location-based validation.\n    21â†’func WithLocation(loc domain.WorkflowLocation) ParseOption {\n    22â†’\treturn func(p *Parser) {\n    23â†’\t\tp.location = loc\n    24â†’\t}\n    25â†’}\n    26â†’\n    27â†’func Parse(input string, opts ...ParseOption) (*domain.Workflow, error) {\n    28â†’\tp := &Parser{lexer: NewLexer(input)}\n    29â†’\tfor _, opt := range opts {\n    30â†’\t\topt(p)\n    31â†’\t}\n    32â†’\tp.advance() // load current\n    33â†’\tp.advance() // load peek\n    34â†’\treturn p.parseWorkflow()\n    35â†’}\n    36â†’\n    37â†’// ParseForHost parses a host.cloche file.\n    38â†’func ParseForHost(input string) (*domain.Workflow, error) {\n    39â†’\treturn Parse(input, WithLocation(domain.LocationHost))\n    40â†’}\n    41â†’\n    42â†’// ParseForContainer parses a container workflow file.\n    43â†’func ParseForContainer(input string) (*domain.Workflow, error) {\n    44â†’\treturn Parse(input, WithLocation(domain.LocationContainer))\n    45â†’}\n    46â†’\n    47â†’func (p *Parser) advance() {\n    48â†’\tp.current = p.peek\n    49â†’\tp.peek = p.lexer.NextToken()\n    50â†’}\n    51â†’\n    52â†’func (p *Parser) expect(typ TokenType) (Token, error) {\n    53â†’\tif p.current.Type != typ {\n    54â†’\t\treturn p.current, fmt.Errorf(\"line %d col %d: expected %v, got %v (%q)\",\n    55â†’\t\t\tp.current.Line, p.current.Col, typ, p.current.Type, p.current.Literal)\n    56â†’\t}\n    57â†’\ttok := p.current\n    58â†’\tp.advance()\n    59â†’\treturn tok, nil\n    60â†’}\n    61â†’\n    62â†’func (p *Parser) expectIdent(value string) (Token, error) {\n    63â†’\tif p.current.Type != TokenIdent || p.current.Literal != value {\n    64â†’\t\treturn p.current, fmt.Errorf(\"line %d col %d: expected %q, got %q\",\n    65â†’\t\t\tp.current.Line, p.current.Col, value, p.current.Literal)\n    66â†’\t}\n    67â†’\ttok := p.current\n    68â†’\tp.advance()\n    69â†’\treturn tok, nil\n    70â†’}\n    71â†’\n    72â†’func (p *Parser) parseWorkflow() (*domain.Workflow, error) {\n    73â†’\tif _, err := p.expectIdent(\"workflow\"); err != nil {\n    74â†’\t\treturn nil, err\n    75â†’\t}\n    76â†’\n    77â†’\tnameTok, err := p.expect(TokenString)\n    78â†’\tif err != nil {\n    79â†’\t\treturn nil, fmt.Errorf(\"expected workflow name string: %w\", err)\n    80â†’\t}\n    81â†’\n    82â†’\tif _, err := p.expect(TokenLBrace); err != nil {\n    83â†’\t\treturn nil, err\n    84â†’\t}\n    85â†’\n    86â†’\twf := &domain.Workflow{\n    87â†’\t\tName:     nameTok.Literal,\n    88â†’\t\tLocation: p.location,\n    89â†’\t\tSteps:    make(map[string]*domain.Step),\n    90â†’\t\tConfig:   make(map[string]string),\n    91â†’\t}\n    92â†’\n    93â†’\tfor p.current.Type != TokenRBrace && p.current.Type != TokenEOF {\n    94â†’\t\tif p.current.Type == TokenIdent && p.current.Literal == \"step\" {\n    95â†’\t\t\tstep, err := p.parseStep()\n    96â†’\t\t\tif err != nil {\n    97â†’\t\t\t\treturn nil, err\n    98â†’\t\t\t}\n    99â†’\t\t\twf.Steps[step.Name] = step\n   100â†’\t\t\tif wf.EntryStep == \"\" {\n   101â†’\t\t\t\twf.EntryStep = step.Name\n   102â†’\t\t\t}\n   103â†’\t\t} else if p.current.Type == TokenIdent && p.current.Literal == \"collect\" {\n   104â†’\t\t\tcollect, err := p.parseCollect()\n   105â†’\t\t\tif err != nil {\n   106â†’\t\t\t\treturn nil, err\n   107â†’\t\t\t}\n   108â†’\t\t\twf.Collects = append(wf.Collects, collect)\n   109â†’\t\t} else if p.current.Type == TokenIdent && p.peek.Type == TokenLBrace {\n   110â†’\t\t\tif err := p.parseWorkflowConfig(wf); err != nil {\n   111â†’\t\t\t\treturn nil, err\n   112â†’\t\t\t}\n   113â†’\t\t} else if p.current.Type == TokenIdent && p.peek.Type == TokenColon {\n   114â†’\t\t\twire, err := p.parseWire()\n   115â†’\t\t\tif err != nil {\n   116â†’\t\t\t\treturn nil, err\n   117â†’\t\t\t}\n   118â†’\t\t\twf.Wiring = append(wf.Wiring, wire)\n   119â†’\t\t} else {\n   120â†’\t\t\treturn nil, fmt.Errorf(\"line %d col %d: unexpected token %q\", p.current.Line, p.current.Col, p.current.Literal)\n   121â†’\t\t}\n   122â†’\t}\n   123â†’\n   124â†’\tif _, err := p.expect(TokenRBrace); err != nil {\n   125â†’\t\treturn nil, err\n   126â†’\t}\n   127â†’\n   128â†’\tif wf.Location != \"\" {\n   129â†’\t\tif err := wf.ValidateLocation(); err != nil {\n   130â†’\t\t\treturn nil, err\n   131â†’\t\t}\n   132â†’\t}\n   133â†’\n   134â†’\treturn wf, nil\n   135â†’}\n   136â†’\n   137â†’func (p *Parser) parseWorkflowConfig(wf *domain.Workflow) error {\n   138â†’\tprefix := p.current.Literal // e.g. \"container\"\n   139â†’\tp.advance()                 // consume prefix ident\n   140â†’\n   141â†’\tif _, err := p.expect(TokenLBrace); err != nil {\n   142â†’\t\treturn err\n   143â†’\t}\n   144â†’\n   145â†’\tfor p.current.Type != TokenRBrace && p.current.Type != TokenEOF {\n   146â†’\t\tkeyTok, err := p.expect(TokenIdent)\n   147â†’\t\tif err != nil {\n   148â†’\t\t\treturn fmt.Errorf(\"expected field name: %w\", err)\n   149â†’\t\t}\n   150â†’\n   151â†’\t\tif _, err := p.expect(TokenEquals); err != nil {\n   152â†’\t\t\treturn err\n   153â†’\t\t}\n   154â†’\n   155â†’\t\tval, err := p.parseValue()\n   156â†’\t\tif err != nil {\n   157â†’\t\t\treturn err\n   158â†’\t\t}\n   159â†’\n   160â†’\t\twf.Config[prefix+\".\"+keyTok.Literal] = val\n   161â†’\t}\n   162â†’\n   163â†’\tif _, err := p.expect(TokenRBrace); err != nil {\n   164â†’\t\treturn err\n   165â†’\t}\n   166â†’\n   167â†’\treturn nil\n   168â†’}\n   169â†’\n   170â†’func (p *Parser) parseStep() (*domain.Step, error) {\n   171â†’\tp.advance() // consume \"step\"\n   172â†’\n   173â†’\tnameTok, err := p.expect(TokenIdent)\n   174â†’\tif err != nil {\n   175â†’\t\treturn nil, fmt.Errorf(\"expected step name: %w\", err)\n   176â†’\t}\n   177â†’\n   178â†’\tif _, err := p.expect(TokenLBrace); err != nil {\n   179â†’\t\treturn nil, err\n   180â†’\t}\n   181â†’\n   182â†’\tstep := &domain.Step{\n   183â†’\t\tName:   nameTok.Literal,\n   184â†’\t\tConfig: make(map[string]string),\n   185â†’\t}\n   186â†’\n   187â†’\tfor p.current.Type != TokenRBrace && p.current.Type != TokenEOF {\n   188â†’\t\tif err := p.parseStepField(step, \"\"); err != nil {\n   189â†’\t\t\treturn nil, err\n   190â†’\t\t}\n   191â†’\t}\n   192â†’\n   193â†’\tif _, err := p.expect(TokenRBrace); err != nil {\n   194â†’\t\treturn nil, err\n   195â†’\t}\n   196â†’\n   197â†’\t// Infer step type from content\n   198â†’\t_, hasPrompt := step.Config[\"prompt\"]\n   199â†’\t_, hasRun := step.Config[\"run\"]\n   200â†’\t_, hasWorkflowName := step.Config[\"workflow_name\"]\n   201â†’\n   202â†’\tcount := 0\n   203â†’\tif hasPrompt {\n   204â†’\t\tcount++\n   205â†’\t}\n   206â†’\tif hasRun {\n   207â†’\t\tcount++\n   208â†’\t}\n   209â†’\tif hasWorkflowName {\n   210â†’\t\tcount++\n   211â†’\t}\n   212â†’\n   213â†’\tif count > 1 {\n   214â†’\t\treturn nil, fmt.Errorf(\"step %q has multiple of 'prompt', 'run', 'workflow_name'; must have exactly one\", step.Name)\n   215â†’\t}\n   216â†’\n   217â†’\tswitch {\n   218â†’\tcase hasPrompt:\n   219â†’\t\tstep.Type = domain.StepTypeAgent\n   220â†’\tcase hasRun:\n   221â†’\t\tstep.Type = domain.StepTypeScript\n   222â†’\tcase hasWorkflowName:\n   223â†’\t\tstep.Type = domain.StepTypeWorkflow\n   224â†’\tdefault:\n   225â†’\t\treturn nil, fmt.Errorf(\"step %q has none of 'prompt', 'run', or 'workflow_name'; must have exactly one\", step.Name)\n   226â†’\t}\n   227â†’\n   228â†’\treturn step, nil\n   229â†’}\n   230â†’\n   231â†’func (p *Parser) parseStepField(step *domain.Step, prefix string) error {\n   232â†’\tkeyTok, err := p.expect(TokenIdent)\n   233â†’\tif err != nil {\n   234â†’\t\treturn fmt.Errorf(\"expected field name: %w\", err)\n   235â†’\t}\n   236â†’\n   237â†’\tkey := keyTok.Literal\n   238â†’\tif prefix != \"\" {\n   239â†’\t\tkey = prefix + \".\" + key\n   240â†’\t}\n   241â†’\n   242â†’\t// Sub-block (e.g., container { ... })\n   243â†’\tif p.current.Type == TokenLBrace {\n   244â†’\t\tp.advance() // consume {\n   245â†’\t\tfor p.current.Type != TokenRBrace && p.current.Type != TokenEOF {\n   246â†’\t\t\tif err := p.parseStepField(step, key); err != nil {\n   247â†’\t\t\t\treturn err\n   248â†’\t\t\t}\n   249â†’\t\t}\n   250â†’\t\tp.advance() // consume }\n   251â†’\t\treturn nil\n   252â†’\t}\n   253â†’\n   254â†’\tif _, err := p.expect(TokenEquals); err != nil {\n   255â†’\t\treturn err\n   256â†’\t}\n   257â†’\n   258â†’\tif key == \"results\" {\n   259â†’\t\tresults, err := p.parseIdentList()\n   260â†’\t\tif err != nil {\n   261â†’\t\t\treturn err\n   262â†’\t\t}\n   263â†’\t\tstep.Results = results\n   264â†’\t} else if p.current.Type == TokenLBracket {\n   265â†’\t\tvalues, err := p.parseStringList()\n   266â†’\t\tif err != nil {\n   267â†’\t\t\treturn err\n   268â†’\t\t}\n   269â†’\t\tstep.Config[key] = strings.Join(values, \",\")\n   270â†’\t} else {\n   271â†’\t\tval, err := p.parseValue()\n   272â†’\t\tif err != nil {\n   273â†’\t\t\treturn err\n   274â†’\t\t}\n   275â†’\t\tstep.Config[key] = val\n   276â†’\t}\n   277â†’\n   278â†’\treturn nil\n   279â†’}\n   280â†’\n   281â†’func (p *Parser) parseIdentList() ([]string, error) {\n   282â†’\tif _, err := p.expect(TokenLBracket); err != nil {\n   283â†’\t\treturn nil, err\n   284â†’\t}\n   285â†’\n   286â†’\tvar items []string\n   287â†’\tfor p.current.Type != TokenRBracket && p.current.Type != TokenEOF {\n   288â†’\t\ttok, err := p.expect(TokenIdent)\n   289â†’\t\tif err != nil {\n   290â†’\t\t\treturn nil, err\n   291â†’\t\t}\n   292â†’\t\titems = append(items, tok.Literal)\n   293â†’\t\tif p.current.Type == TokenComma {\n   294â†’\t\t\tp.advance()\n   295â†’\t\t}\n   296â†’\t}\n   297â†’\n   298â†’\tif _, err := p.expect(TokenRBracket); err != nil {\n   299â†’\t\treturn nil, err\n   300â†’\t}\n   301â†’\n   302â†’\treturn items, nil\n   303â†’}\n   304â†’\n   305â†’func (p *Parser) parseStringList() ([]string, error) {\n   306â†’\tif _, err := p.expect(TokenLBracket); err != nil {\n   307â†’\t\treturn nil, err\n   308â†’\t}\n   309â†’\n   310â†’\tvar items []string\n   311â†’\tfor p.current.Type != TokenRBracket && p.current.Type != TokenEOF {\n   312â†’\t\ttok, err := p.expect(TokenString)\n   313â†’\t\tif err != nil {\n   314â†’\t\t\treturn nil, err\n   315â†’\t\t}\n   316â†’\t\titems = append(items, tok.Literal)\n   317â†’\t\tif p.current.Type == TokenComma {\n   318â†’\t\t\tp.advance()\n   319â†’\t\t}\n   320â†’\t}\n   321â†’\n   322â†’\tif _, err := p.expect(TokenRBracket); err != nil {\n   323â†’\t\treturn nil, err\n   324â†’\t}\n   325â†’\n   326â†’\treturn items, nil\n   327â†’}\n   328â†’\n   329â†’func (p *Parser) parseValue() (string, error) {\n   330â†’\tif p.current.Type == TokenString {\n   331â†’\t\ttok := p.current\n   332â†’\t\tp.advance()\n   333â†’\t\treturn tok.Literal, nil\n   334â†’\t}\n   335â†’\n   336â†’\tif p.current.Type == TokenIdent {\n   337â†’\t\tvar buf strings.Builder\n   338â†’\t\tbuf.WriteString(p.current.Literal)\n   339â†’\t\tp.advance()\n   340â†’\n   341â†’\t\t// Function call: file(\"...\")\n   342â†’\t\tif p.current.Type == TokenLParen {\n   343â†’\t\t\tbuf.WriteRune('(')\n   344â†’\t\t\tp.advance()\n   345â†’\t\t\tfor p.current.Type != TokenRParen && p.current.Type != TokenEOF {\n   346â†’\t\t\t\tif p.current.Type == TokenString {\n   347â†’\t\t\t\t\tbuf.WriteRune('\"')\n   348â†’\t\t\t\t\tbuf.WriteString(p.current.Literal)\n   349â†’\t\t\t\t\tbuf.WriteRune('\"')\n   350â†’\t\t\t\t} else {\n   351â†’\t\t\t\t\tbuf.WriteString(p.current.Literal)\n   352â†’\t\t\t\t}\n   353â†’\t\t\t\tp.advance()\n   354â†’\t\t\t}\n   355â†’\t\t\tbuf.WriteRune(')')\n   356â†’\t\t\tp.advance() // consume )\n   357â†’\t\t}\n   358â†’\n   359â†’\t\t// Dotted path: step.code.output\n   360â†’\t\tfor p.current.Type == TokenDot {\n   361â†’\t\t\tbuf.WriteRune('.')\n   362â†’\t\t\tp.advance()\n   363â†’\t\t\tif p.current.Type == TokenIdent {\n   364â†’\t\t\t\tbuf.WriteString(p.current.Literal)\n   365â†’\t\t\t\tp.advance()\n   366â†’\t\t\t}\n   367â†’\t\t}\n   368â†’\n   369â†’\t\treturn buf.String(), nil\n   370â†’\t}\n   371â†’\n   372â†’\treturn \"\", fmt.Errorf(\"line %d col %d: expected value, got %q\", p.current.Line, p.current.Col, p.current.Literal)\n   373â†’}\n   374â†’\n   375â†’func (p *Parser) parseWire() (domain.Wire, error) {\n   376â†’\tfromTok := p.current\n   377â†’\tp.advance()\n   378â†’\n   379â†’\tif _, err := p.expect(TokenColon); err != nil {\n   380â†’\t\treturn domain.Wire{}, err\n   381â†’\t}\n   382â†’\n   383â†’\tresultTok, err := p.expect(TokenIdent)\n   384â†’\tif err != nil {\n   385â†’\t\treturn domain.Wire{}, err\n   386â†’\t}\n   387â†’\n   388â†’\tif _, err := p.expect(TokenArrow); err != nil {\n   389â†’\t\treturn domain.Wire{}, err\n   390â†’\t}\n   391â†’\n   392â†’\ttoTok, err := p.expect(TokenIdent)\n   393â†’\tif err != nil {\n   394â†’\t\treturn domain.Wire{}, err\n   395â†’\t}\n   396â†’\n   397â†’\treturn domain.Wire{\n   398â†’\t\tFrom:   fromTok.Literal,\n   399â†’\t\tResult: resultTok.Literal,\n   400â†’\t\tTo:     toTok.Literal,\n   401â†’\t}, nil\n   402â†’}\n   403â†’\n   404â†’func (p *Parser) parseCollect() (domain.Collect, error) {\n   405â†’\tp.advance() // consume \"collect\"\n   406â†’\n   407â†’\tmodeTok, err := p.expect(TokenIdent)\n   408â†’\tif err != nil {\n   409â†’\t\treturn domain.Collect{}, fmt.Errorf(\"expected 'all' or 'any': %w\", err)\n   410â†’\t}\n   411â†’\n   412â†’\tvar mode domain.CollectMode\n   413â†’\tswitch modeTok.Literal {\n   414â†’\tcase \"all\":\n   415â†’\t\tmode = domain.CollectAll\n   416â†’\tcase \"any\":\n   417â†’\t\tmode = domain.CollectAny\n   418â†’\tdefault:\n   419â†’\t\treturn domain.Collect{}, fmt.Errorf(\"line %d col %d: expected 'all' or 'any', got %q\",\n   420â†’\t\t\tmodeTok.Line, modeTok.Col, modeTok.Literal)\n   421â†’\t}\n   422â†’\n   423â†’\tif _, err := p.expect(TokenLParen); err != nil {\n   424â†’\t\treturn domain.Collect{}, err\n   425â†’\t}\n   426â†’\n   427â†’\tvar conditions []domain.WireCondition\n   428â†’\tfor p.current.Type != TokenRParen && p.current.Type != TokenEOF {\n   429â†’\t\tstepTok, err := p.expect(TokenIdent)\n   430â†’\t\tif err != nil {\n   431â†’\t\t\treturn domain.Collect{}, fmt.Errorf(\"expected step name in collect: %w\", err)\n   432â†’\t\t}\n   433â†’\t\tif _, err := p.expect(TokenColon); err != nil {\n   434â†’\t\t\treturn domain.Collect{}, err\n   435â†’\t\t}\n   436â†’\t\tresultTok, err := p.expect(TokenIdent)\n   437â†’\t\tif err != nil {\n   438â†’\t\t\treturn domain.Collect{}, fmt.Errorf(\"expected result name in collect: %w\", err)\n   439â†’\t\t}\n   440â†’\t\tconditions = append(conditions, domain.WireCondition{Step: stepTok.Literal, Result: resultTok.Literal})\n   441â†’\t\tif p.current.Type == TokenComma {\n   442â†’\t\t\tp.advance()\n   443â†’\t\t}\n   444â†’\t}\n   445â†’\n   446â†’\tif _, err := p.expect(TokenRParen); err != nil {\n   447â†’\t\treturn domain.Collect{}, err\n   448â†’\t}\n   449â†’\tif _, err := p.expect(TokenArrow); err != nil {\n   450â†’\t\treturn domain.Collect{}, err\n   451â†’\t}\n   452â†’\n   453â†’\ttoTok, err := p.expect(TokenIdent)\n   454â†’\tif err != nil {\n   455â†’\t\treturn domain.Collect{}, fmt.Errorf(\"expected target step: %w\", err)\n   456â†’\t}\n   457â†’\n   458â†’\treturn domain.Collect{\n   459â†’\t\tMode:       mode,\n   460â†’\t\tConditions: conditions,\n   461â†’\t\tTo:         toTok.Literal,\n   462â†’\t}, nil\n   463â†’}\n   464â†’"}]},"parent_tool_use_id":"toolu_01BwC3jW9U52qS7AfxsmW3Le","session_id":"c6864ddb-8a62-468e-9371-23940235ec7e","uuid":"93206641-2878-42ca-ac68-67413995194b"}
