[2026-03-09T21:12:19Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01FTPmMNjc2PWEPJYZBRK8zt","type":"tool_result","content":"     1â†’package agent\n     2â†’\n     3â†’import (\n     4â†’\t\"context\"\n     5â†’\t\"fmt\"\n     6â†’\t\"io\"\n     7â†’\t\"os\"\n     8â†’\t\"path/filepath\"\n     9â†’\t\"strings\"\n    10â†’\n    11â†’\t\"github.com/cloche-dev/cloche/internal/adapters/agents/generic\"\n    12â†’\t\"github.com/cloche-dev/cloche/internal/adapters/agents/prompt\"\n    13â†’\t\"github.com/cloche-dev/cloche/internal/domain\"\n    14â†’\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    15â†’\t\"github.com/cloche-dev/cloche/internal/engine\"\n    16â†’\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    17â†’\t\"github.com/cloche-dev/cloche/internal/protocol\"\n    18â†’)\n    19â†’\n    20â†’type RunnerConfig struct {\n    21â†’\tWorkflowPath string\n    22â†’\tWorkDir      string\n    23â†’\tStatusOutput io.Writer\n    24â†’\tRunID        string\n    25â†’}\n    26â†’\n    27â†’type Runner struct {\n    28â†’\tcfg RunnerConfig\n    29â†’}\n    30â†’\n    31â†’func NewRunner(cfg RunnerConfig) *Runner {\n    32â†’\treturn &Runner{\n    33â†’\t\tcfg: cfg,\n    34â†’\t}\n    35â†’}\n    36â†’\n    37â†’func (r *Runner) Run(ctx context.Context) error {\n    38â†’\tdata, err := os.ReadFile(r.cfg.WorkflowPath)\n    39â†’\tif err != nil {\n    40â†’\t\treturn fmt.Errorf(\"reading workflow file: %w\", err)\n    41â†’\t}\n    42â†’\n    43â†’\twf, err := dsl.ParseForContainer(string(data))\n    44â†’\tif err != nil {\n    45â†’\t\treturn fmt.Errorf(\"parsing workflow: %w\", err)\n    46â†’\t}\n    47â†’\n    48â†’\tstatusWriter := protocol.NewStatusWriter(r.cfg.StatusOutput)\n    49â†’\tgenericAdapter := generic.New()\n    50â†’\tpromptAdapter := prompt.New()\n    51â†’\tpromptAdapter.RunID = r.cfg.RunID\n    52â†’\tpromptAdapter.StatusWriter = statusWriter\n    53â†’\tif cmd, ok := os.LookupEnv(\"CLOCHE_AGENT_COMMAND\"); ok {\n    54â†’\t\tpromptAdapter.Commands = prompt.ParseCommands(cmd)\n    55â†’\t}\n    56â†’\tif cmd := wf.Config[\"container.agent_command\"]; cmd != \"\" {\n    57â†’\t\tpromptAdapter.Commands = prompt.ParseCommands(cmd)\n    58â†’\t}\n    59â†’\tif args := wf.Config[\"container.agent_args\"]; args != \"\" {\n    60â†’\t\tpromptAdapter.ExplicitArgs = strings.Fields(args)\n    61â†’\t}\n    62â†’\n    63â†’\t// Reset per-run state from any previous run\n    64â†’\t_ = os.RemoveAll(filepath.Join(r.cfg.WorkDir, \".cloche\", \"attempt_count\"))\n    65â†’\t_ = os.RemoveAll(filepath.Join(r.cfg.WorkDir, \".cloche\", \"output\"))\n    66â†’\n    67â†’\t// Create unified log writer\n    68â†’\tulog, err := logstream.New(r.cfg.WorkDir)\n    69â†’\tif err != nil {\n    70â†’\t\treturn fmt.Errorf(\"creating unified log: %w\", err)\n    71â†’\t}\n    72â†’\tdefer ulog.Close()\n    73â†’\n    74â†’\texecutor := &stepExecutor{\n    75â†’\t\tworkDir:   r.cfg.WorkDir,\n    76â†’\t\tgeneric:   genericAdapter,\n    77â†’\t\tprompt:    promptAdapter,\n    78â†’\t\tlogStream: ulog,\n    79â†’\t}\n    80â†’\n    81â†’\teng := engine.New(executor)\n    82â†’\teng.SetStatusHandler(&statusReporter{writer: statusWriter, logStream: ulog})\n    83â†’\n    84â†’\tprotocol.AppendHistoryMarker(r.cfg.WorkDir, \"workflow:start \"+wf.Name)\n    85â†’\n    86â†’\trun, runErr := eng.Run(ctx, wf)\n    87â†’\tif runErr != nil {\n    88â†’\t\tprotocol.AppendHistoryMarker(r.cfg.WorkDir, \"workflow:end \"+wf.Name+\" result:failed\")\n    89â†’\t\tulog.Log(logstream.TypeStatus, \"error: \"+runErr.Error())\n    90â†’\t\tulog.Log(logstream.TypeStatus, \"run_completed: failed\")\n    91â†’\t\tstatusWriter.Error(\"\", runErr.Error())\n    92â†’\t\tstatusWriter.RunCompleted(\"failed\")\n    93â†’\t\treturn runErr\n    94â†’\t}\n    95â†’\n    96â†’\tprotocol.AppendHistoryMarker(r.cfg.WorkDir, \"workflow:end \"+wf.Name+\" result:\"+string(run.State))\n    97â†’\n    98â†’\tulog.Log(logstream.TypeStatus, \"run_completed: \"+string(run.State))\n    99â†’\tstatusWriter.RunCompleted(string(run.State))\n   100â†’\treturn nil\n   101â†’}\n   102â†’\n   103â†’type stepExecutor struct {\n   104â†’\tworkDir   string\n   105â†’\tgeneric   *generic.Adapter\n   106â†’\tprompt    *prompt.Adapter\n   107â†’\tlogStream *logstream.Writer\n   108â†’}\n   109â†’\n   110â†’func (e *stepExecutor) Execute(ctx context.Context, step *domain.Step) (string, error) {\n   111â†’\tswitch step.Type {\n   112â†’\tcase domain.StepTypeScript:\n   113â†’\t\tresult, err := e.generic.Execute(ctx, step, e.workDir)\n   114â†’\t\te.logStepOutput(step.Name, logstream.TypeScript)\n   115â†’\t\treturn result, err\n   116â†’\tcase domain.StepTypeAgent:\n   117â†’\t\tif _, ok := step.Config[\"run\"]; ok {\n   118â†’\t\t\tresult, err := e.generic.Execute(ctx, step, e.workDir)\n   119â†’\t\t\te.logStepOutput(step.Name, logstream.TypeScript)\n   120â†’\t\t\treturn result, err\n   121â†’\t\t}\n   122â†’\t\tif _, ok := step.Config[\"prompt\"]; ok {\n   123â†’\t\t\tif cmd := step.Config[\"agent_command\"]; cmd != \"\" {\n   124â†’\t\t\t\te.prompt.Commands = prompt.ParseCommands(cmd)\n   125â†’\t\t\t}\n   126â†’\t\t\tif args := step.Config[\"agent_args\"]; args != \"\" {\n   127â†’\t\t\t\te.prompt.ExplicitArgs = strings.Fields(args)\n   128â†’\t\t\t}\n   129â†’\t\t\tresult, err := e.prompt.Execute(ctx, step, e.workDir)\n   130â†’\t\t\te.copyToLLMLog(step.Name)\n   131â†’\t\t\te.logStepOutput(step.Name, logstream.TypeLLM)\n   132â†’\t\t\treturn result, err\n   133â†’\t\t}\n   134â†’\t\treturn \"\", fmt.Errorf(\"agent step %q requires either 'run' or 'prompt' config\", step.Name)\n   135â†’\tdefault:\n   136â†’\t\treturn \"\", fmt.Errorf(\"unknown step type: %s\", step.Type)\n   137â†’\t}\n   138â†’}\n   139â†’\n   140â†’// logStepOutput reads the per-step log file and writes its contents to the unified log.\n   141â†’func (e *stepExecutor) logStepOutput(stepName string, typ logstream.EntryType) {\n   142â†’\tpath := filepath.Join(e.workDir, \".cloche\", \"output\", stepName+\".log\")\n   143â†’\tdata, err := os.ReadFile(path)\n   144â†’\tif err != nil || len(data) == 0 {\n   145â†’\t\treturn\n   146â†’\t}\n   147â†’\te.logStream.Log(typ, string(data))\n   148â†’}\n   149â†’\n   150â†’// copyToLLMLog copies <step>.log to llm-<step>.log for agent prompt steps.\n   151â†’func (e *stepExecutor) copyToLLMLog(stepName string) {\n   152â†’\tsrc := filepath.Join(e.workDir, \".cloche\", \"output\", stepName+\".log\")\n   153â†’\tdst := filepath.Join(e.workDir, \".cloche\", \"output\", \"llm-\"+stepName+\".log\")\n   154â†’\tdata, err := os.ReadFile(src)\n   155â†’\tif err != nil {\n   156â†’\t\treturn\n   157â†’\t}\n   158â†’\t_ = os.WriteFile(dst, data, 0644)\n   159â†’}\n   160â†’\n   161â†’type statusReporter struct {\n   162â†’\twriter    *protocol.StatusWriter\n   163â†’\tlogStream *logstream.Writer\n   164â†’}\n   165â†’\n   166â†’func (s *statusReporter) OnStepStart(_ *domain.Run, step *domain.Step) {\n   167â†’\ts.writer.StepStarted(step.Name)\n   168â†’\ts.logStream.Log(logstream.TypeStatus, \"step_started: \"+step.Name)\n   169â†’}\n   170â†’\n   171â†’func (s *statusReporter) OnStepComplete(_ *domain.Run, step *domain.Step, result string) {\n   172â†’\ts.writer.StepCompleted(step.Name, result)\n   173â†’\ts.logStream.Log(logstream.TypeStatus, \"step_completed: \"+step.Name+\" -> \"+result)\n   174â†’}\n   175â†’\n   176â†’func (s *statusReporter) OnRunComplete(_ *domain.Run) {}\n   177â†’"}]},"parent_tool_use_id":null,"session_id":"c6864ddb-8a62-468e-9371-23940235ec7e","uuid":"6ca5face-bd33-43d0-9e9d-889d6c256048","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/agent/runner.go","content":"package agent\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"io\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"strings\"\n\n\t\"github.com/cloche-dev/cloche/internal/adapters/agents/generic\"\n\t\"github.com/cloche-dev/cloche/internal/adapters/agents/prompt\"\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/dsl\"\n\t\"github.com/cloche-dev/cloche/internal/engine\"\n\t\"github.com/cloche-dev/cloche/internal/logstream\"\n\t\"github.com/cloche-dev/cloche/internal/protocol\"\n)\n\ntype RunnerConfig struct {\n\tWorkflowPath string\n\tWorkDir      string\n\tStatusOutput io.Writer\n\tRunID        string\n}\n\ntype Runner struct {\n\tcfg RunnerConfig\n}\n\nfunc NewRunner(cfg RunnerConfig) *Runner {\n\treturn &Runner{\n\t\tcfg: cfg,\n\t}\n}\n\nfunc (r *Runner) Run(ctx context.Context) error {\n\tdata, err := os.ReadFile(r.cfg.WorkflowPath)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"reading workflow file: %w\", err)\n\t}\n\n\twf, err := dsl.ParseForContainer(string(data))\n\tif err != nil {\n\t\treturn fmt.Errorf(\"parsing workflow: %w\", err)\n\t}\n\n\tstatusWriter := protocol.NewStatusWriter(r.cfg.StatusOutput)\n\tgenericAdapter := generic.New()\n\tpromptAdapter := prompt.New()\n\tpromptAdapter.RunID = r.cfg.RunID\n\tpromptAdapter.StatusWriter = statusWriter\n\tif cmd, ok := os.LookupEnv(\"CLOCHE_AGENT_COMMAND\"); ok {\n\t\tpromptAdapter.Commands = prompt.ParseCommands(cmd)\n\t}\n\tif cmd := wf.Config[\"container.agent_command\"]; cmd != \"\" {\n\t\tpromptAdapter.Commands = prompt.ParseCommands(cmd)\n\t}\n\tif args := wf.Config[\"container.agent_args\"]; args != \"\" {\n\t\tpromptAdapter.ExplicitArgs = strings.Fields(args)\n\t}\n\n\t// Reset per-run state from any previous run\n\t_ = os.RemoveAll(filepath.Join(r.cfg.WorkDir, \".cloche\", \"attempt_count\"))\n\t_ = os.RemoveAll(filepath.Join(r.cfg.WorkDir, \".cloche\", \"output\"))\n\n\t// Create unified log writer\n\tulog, err := logstream.New(r.cfg.WorkDir)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"creating unified log: %w\", err)\n\t}\n\tdefer ulog.Close()\n\n\texecutor := &stepExecutor{\n\t\tworkDir:   r.cfg.WorkDir,\n\t\tgeneric:   genericAdapter,\n\t\tprompt:    promptAdapter,\n\t\tlogStream: ulog,\n\t}\n\n\teng := engine.New(executor)\n\teng.SetStatusHandler(&statusReporter{writer: statusWriter, logStream: ulog})\n\n\tprotocol.AppendHistoryMarker(r.cfg.WorkDir, \"workflow:start \"+wf.Name)\n\n\trun, runErr := eng.Run(ctx, wf)\n\tif runErr != nil {\n\t\tprotocol.AppendHistoryMarker(r.cfg.WorkDir, \"workflow:end \"+wf.Name+\" result:failed\")\n\t\tulog.Log(logstream.TypeStatus, \"error: \"+runErr.Error())\n\t\tulog.Log(logstream.TypeStatus, \"run_completed: failed\")\n\t\tstatusWriter.Error(\"\", runErr.Error())\n\t\tstatusWriter.RunCompleted(\"failed\")\n\t\treturn runErr\n\t}\n\n\tprotocol.AppendHistoryMarker(r.cfg.WorkDir, \"workflow:end \"+wf.Name+\" result:\"+string(run.State))\n\n\tulog.Log(logstream.TypeStatus, \"run_completed: \"+string(run.State))\n\tstatusWriter.RunCompleted(string(run.State))\n\treturn nil\n}\n\ntype stepExecutor struct {\n\tworkDir   string\n\tgeneric   *generic.Adapter\n\tprompt    *prompt.Adapter\n\tlogStream *logstream.Writer\n}\n\nfunc (e *stepExecutor) Execute(ctx context.Context, step *domain.Step) (string, error) {\n\tswitch step.Type {\n\tcase domain.StepTypeScript:\n\t\tresult, err := e.generic.Execute(ctx, step, e.workDir)\n\t\te.logStepOutput(step.Name, logstream.TypeScript)\n\t\treturn result, err\n\tcase domain.StepTypeAgent:\n\t\tif _, ok := step.Config[\"run\"]; ok {\n\t\t\tresult, err := e.generic.Execute(ctx, step, e.workDir)\n\t\t\te.logStepOutput(step.Name, logstream.TypeScript)\n\t\t\treturn result, err\n\t\t}\n\t\tif _, ok := step.Config[\"prompt\"]; ok {\n\t\t\tif cmd := step.Config[\"agent_command\"]; cmd != \"\" {\n\t\t\t\te.prompt.Commands = prompt.ParseCommands(cmd)\n\t\t\t}\n\t\t\tif args := step.Config[\"agent_args\"]; args != \"\" {\n\t\t\t\te.prompt.ExplicitArgs = strings.Fields(args)\n\t\t\t}\n\t\t\tresult, err := e.prompt.Execute(ctx, step, e.workDir)\n\t\t\te.copyToLLMLog(step.Name)\n\t\t\te.logStepOutput(step.Name, logstream.TypeLLM)\n\t\t\treturn result, err\n\t\t}\n\t\treturn \"\", fmt.Errorf(\"agent step %q requires either 'run' or 'prompt' config\", step.Name)\n\tdefault:\n\t\treturn \"\", fmt.Errorf(\"unknown step type: %s\", step.Type)\n\t}\n}\n\n// logStepOutput reads the per-step log file and writes its contents to the unified log.\nfunc (e *stepExecutor) logStepOutput(stepName string, typ logstream.EntryType) {\n\tpath := filepath.Join(e.workDir, \".cloche\", \"output\", stepName+\".log\")\n\tdata, err := os.ReadFile(path)\n\tif err != nil || len(data) == 0 {\n\t\treturn\n\t}\n\te.logStream.Log(typ, string(data))\n}\n\n// copyToLLMLog copies <step>.log to llm-<step>.log for agent prompt steps.\nfunc (e *stepExecutor) copyToLLMLog(stepName string) {\n\tsrc := filepath.Join(e.workDir, \".cloche\", \"output\", stepName+\".log\")\n\tdst := filepath.Join(e.workDir, \".cloche\", \"output\", \"llm-\"+stepName+\".log\")\n\tdata, err := os.ReadFile(src)\n\tif err != nil {\n\t\treturn\n\t}\n\t_ = os.WriteFile(dst, data, 0644)\n}\n\ntype statusReporter struct {\n\twriter    *protocol.StatusWriter\n\tlogStream *logstream.Writer\n}\n\nfunc (s *statusReporter) OnStepStart(_ *domain.Run, step *domain.Step) {\n\ts.writer.StepStarted(step.Name)\n\ts.logStream.Log(logstream.TypeStatus, \"step_started: \"+step.Name)\n}\n\nfunc (s *statusReporter) OnStepComplete(_ *domain.Run, step *domain.Step, result string) {\n\ts.writer.StepCompleted(step.Name, result)\n\ts.logStream.Log(logstream.TypeStatus, \"step_completed: \"+step.Name+\" -> \"+result)\n}\n\nfunc (s *statusReporter) OnRunComplete(_ *domain.Run) {}\n","numLines":177,"startLine":1,"totalLines":177}}}
