[2026-03-09T21:12:19Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CUnbc2GKCfPDhm7A9WKPXc","type":"tool_result","content":"     1â†’package grpc\n     2â†’\n     3â†’import (\n     4â†’\t\"bufio\"\n     5â†’\t\"context\"\n     6â†’\t\"encoding/json\"\n     7â†’\t\"fmt\"\n     8â†’\t\"log\"\n     9â†’\t\"os\"\n    10â†’\t\"os/exec\"\n    11â†’\t\"path/filepath\"\n    12â†’\t\"strings\"\n    13â†’\t\"sync\"\n    14â†’\t\"time\"\n    15â†’\n    16â†’\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    17â†’\t\"github.com/cloche-dev/cloche/internal/adapters/docker\"\n    18â†’\t\"github.com/cloche-dev/cloche/internal/domain\"\n    19â†’\t\"github.com/cloche-dev/cloche/internal/evolution\"\n    20â†’\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    21â†’\t\"github.com/cloche-dev/cloche/internal/ports\"\n    22â†’\t\"github.com/cloche-dev/cloche/internal/protocol\"\n    23â†’\trpcgrpc \"google.golang.org/grpc\"\n    24â†’)\n    25â†’\n    26â†’type ClocheServer struct {\n    27â†’\tpb.UnimplementedClocheServiceServer\n    28â†’\tstore        ports.RunStore\n    29â†’\tcaptures     ports.CaptureStore\n    30â†’\tlogStore     ports.LogStore\n    31â†’\tcontainer    ports.ContainerRuntime\n    32â†’\tdefaultImage string\n    33â†’\tevolution    *evolution.Trigger\n    34â†’\tlogBroadcast *logstream.Broadcaster\n    35â†’\tshutdownFn   func()\n    36â†’\tmu           sync.Mutex\n    37â†’\trunIDs       map[string]string // run_id -> container_id\n    38â†’}\n    39â†’\n    40â†’func NewClocheServer(store ports.RunStore, container ports.ContainerRuntime) *ClocheServer {\n    41â†’\treturn &ClocheServer{\n    42â†’\t\tstore:     store,\n    43â†’\t\tcontainer: container,\n    44â†’\t\trunIDs:    make(map[string]string),\n    45â†’\t}\n    46â†’}\n    47â†’\n    48â†’func NewClocheServerWithCaptures(store ports.RunStore, captures ports.CaptureStore, container ports.ContainerRuntime, defaultImage string) *ClocheServer {\n    49â†’\treturn &ClocheServer{\n    50â†’\t\tstore:        store,\n    51â†’\t\tcaptures:     captures,\n    52â†’\t\tcontainer:    container,\n    53â†’\t\tdefaultImage: defaultImage,\n    54â†’\t\trunIDs:       make(map[string]string),\n    55â†’\t}\n    56â†’}\n    57â†’\n    58â†’// SetLogStore attaches a log store to the server for indexing extracted log files.\n    59â†’func (s *ClocheServer) SetLogStore(ls ports.LogStore) {\n    60â†’\ts.logStore = ls\n    61â†’}\n    62â†’\n    63â†’\n    64â†’// SetEvolution attaches an evolution trigger to the server.\n    65â†’func (s *ClocheServer) SetEvolution(trigger *evolution.Trigger) {\n    66â†’\ts.evolution = trigger\n    67â†’}\n    68â†’\n    69â†’// SetLogBroadcaster attaches a log broadcaster for live-streaming LLM output.\n    70â†’func (s *ClocheServer) SetLogBroadcaster(b *logstream.Broadcaster) {\n    71â†’\ts.logBroadcast = b\n    72â†’}\n    73â†’\n    74â†’// SetShutdownFunc sets the callback invoked when the Shutdown RPC is called.\n    75â†’func (s *ClocheServer) SetShutdownFunc(fn func()) {\n    76â†’\ts.shutdownFn = fn\n    77â†’}\n    78â†’\n    79â†’func (s *ClocheServer) RunWorkflow(ctx context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error) {\n    80â†’\tif s.container == nil {\n    81â†’\t\treturn nil, fmt.Errorf(\"no container runtime configured\")\n    82â†’\t}\n    83â†’\n    84â†’\t// Generate a unique run ID, retrying on collision\n    85â†’\tvar runID string\n    86â†’\tfor attempts := 0; attempts < 10; attempts++ {\n    87â†’\t\trunID = domain.GenerateRunID(req.WorkflowName)\n    88â†’\t\texisting, err := s.store.GetRun(ctx, runID)\n    89â†’\t\tif err != nil {\n    90â†’\t\t\tbreak // ID is free\n    91â†’\t\t}\n    92â†’\t\t// Reuse if completed more than 1 hour ago\n    93â†’\t\tif !existing.CompletedAt.IsZero() && time.Since(existing.CompletedAt) > time.Hour {\n    94â†’\t\t\t_ = s.store.DeleteRun(ctx, runID)\n    95â†’\t\t\tbreak\n    96â†’\t\t}\n    97â†’\t}\n    98â†’\n    99â†’\t// Write prompt to .cloche/<run-id>/prompt.txt (run-specific to avoid conflicts)\n   100â†’\tif req.Prompt != \"\" {\n   101â†’\t\tclocheDir := filepath.Join(req.ProjectDir, \".cloche\", runID)\n   102â†’\t\tif err := os.MkdirAll(clocheDir, 0755); err != nil {\n   103â†’\t\t\treturn nil, fmt.Errorf(\"creating .cloche dir: %w\", err)\n   104â†’\t\t}\n   105â†’\t\tif err := os.WriteFile(filepath.Join(clocheDir, \"prompt.txt\"), []byte(req.Prompt), 0644); err != nil {\n   106â†’\t\t\treturn nil, fmt.Errorf(\"writing prompt: %w\", err)\n   107â†’\t\t}\n   108â†’\t}\n   109â†’\trun := domain.NewRun(runID, req.WorkflowName)\n   110â†’\trun.ProjectDir = req.ProjectDir\n   111â†’\tif err := s.store.CreateRun(ctx, run); err != nil {\n   112â†’\t\treturn nil, fmt.Errorf(\"creating run: %w\", err)\n   113â†’\t}\n   114â†’\n   115â†’\t// Resolve image: request-level override, then server default\n   116â†’\timage := req.Image\n   117â†’\tif image == \"\" {\n   118â†’\t\timage = s.defaultImage\n   119â†’\t}\n   120â†’\n   121â†’\t// Launch container start + tracking in background so the RPC returns immediately.\n   122â†’\t// The run stays in \"pending\" state until the container is up.\n   123â†’\tgo s.launchAndTrack(runID, image, req.KeepContainer, req)\n   124â†’\n   125â†’\treturn &pb.RunWorkflowResponse{RunId: runID}, nil\n   126â†’}\n   127â†’\n   128â†’// launchAndTrack starts the container and then tracks it to completion.\n   129â†’// It runs in a background goroutine with its own context, independent of the\n   130â†’// RPC context which may be cancelled after RunWorkflow returns.\n   131â†’func (s *ClocheServer) launchAndTrack(runID, image string, keepContainer bool, req *pb.RunWorkflowRequest) {\n   132â†’\tctx := context.Background()\n   133â†’\n   134â†’\t// Auto-rebuild image if the project Dockerfile has changed since last build.\n   135â†’\tif ensurer, ok := s.container.(ports.ImageEnsurer); ok {\n   136â†’\t\tif err := ensurer.EnsureImage(ctx, req.ProjectDir, image); err != nil {\n   137â†’\t\t\trun, _ := s.store.GetRun(ctx, runID)\n   138â†’\t\t\tif run != nil {\n   139â†’\t\t\t\trun.Fail(fmt.Sprintf(\"failed to ensure image: %v\", err))\n   140â†’\t\t\t\t_ = s.store.UpdateRun(ctx, run)\n   141â†’\t\t\t}\n   142â†’\t\t\tlog.Printf(\"run %s: failed to ensure image: %v\", runID, err)\n   143â†’\t\t\t\treturn\n   144â†’\t\t}\n   145â†’\t}\n   146â†’\n   147â†’\tbaseSHA := gitHEAD(req.ProjectDir)\n   148â†’\n   149â†’\tcontainerID, err := s.container.Start(ctx, ports.ContainerConfig{\n   150â†’\t\tImage:        image,\n   151â†’\t\tWorkflowName: req.WorkflowName,\n   152â†’\t\tProjectDir:   req.ProjectDir,\n   153â†’\t\tRunID:        runID,\n   154â†’\t\tNetworkAllow: []string{\"*\"},\n   155â†’\t})\n   156â†’\tif err != nil {\n   157â†’\t\trun, _ := s.store.GetRun(ctx, runID)\n   158â†’\t\tif run != nil {\n   159â†’\t\t\trun.Fail(fmt.Sprintf(\"failed to start container: %v\", err))\n   160â†’\t\t\t_ = s.store.UpdateRun(ctx, run)\n   161â†’\t\t}\n   162â†’\t\tlog.Printf(\"run %s: failed to start container: %v\", runID, err)\n   163â†’\t\treturn\n   164â†’\t}\n   165â†’\n   166â†’\ts.mu.Lock()\n   167â†’\ts.runIDs[runID] = containerID\n   168â†’\ts.mu.Unlock()\n   169â†’\n   170â†’\trun, _ := s.store.GetRun(ctx, runID)\n   171â†’\tif run != nil {\n   172â†’\t\trun.Start()\n   173â†’\t\trun.ContainerID = containerID\n   174â†’\t\trun.BaseSHA = baseSHA\n   175â†’\t\t_ = s.store.UpdateRun(ctx, run)\n   176â†’\t}\n   177â†’\n   178â†’\ts.trackRun(runID, containerID, req.ProjectDir, req.WorkflowName, keepContainer)\n   179â†’}\n   180â†’\n   181â†’func (s *ClocheServer) trackRun(runID, containerID, projectDir, workflowName string, keepContainer bool) {\n   182â†’\tctx := context.Background()\n   183â†’\n   184â†’\t// Attach to agent output\n   185â†’\treader, err := s.container.AttachOutput(ctx, containerID)\n   186â†’\tif err != nil {\n   187â†’\t\tlog.Printf(\"failed to attach to output for run %s: %v\", runID, err)\n   188â†’\t\t\treturn\n   189â†’\t}\n   190â†’\n   191â†’\t// Parse JSON-lines status messages\n   192â†’\tvar reportedResult string // captured from MsgRunCompleted, persisted after branch extraction\n   193â†’\tscanner := bufio.NewScanner(reader)\n   194â†’\tfor scanner.Scan() {\n   195â†’\t\tvar msg protocol.StatusMessage\n   196â†’\t\tif err := json.Unmarshal(scanner.Bytes(), &msg); err != nil {\n   197â†’\t\t\tcontinue\n   198â†’\t\t}\n   199â†’\n   200â†’\t\t// Fast path: log messages don't need store interaction.\n   201â†’\t\tif msg.Type == protocol.MsgLog {\n   202â†’\t\t\tif s.logBroadcast != nil {\n   203â†’\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n   204â†’\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n   205â†’\t\t\t\t\tType:      \"llm\",\n   206â†’\t\t\t\t\tContent:   msg.Message,\n   207â†’\t\t\t\t})\n   208â†’\t\t\t}\n   209â†’\t\t\tcontinue\n   210â†’\t\t}\n   211â†’\n   212â†’\t\trun, err := s.store.GetRun(ctx, runID)\n   213â†’\t\tif err != nil {\n   214â†’\t\t\tcontinue\n   215â†’\t\t}\n   216â†’\n   217â†’\t\tswitch msg.Type {\n   218â†’\t\tcase protocol.MsgStepStarted:\n   219â†’\t\t\trun.RecordStepStart(msg.StepName)\n   220â†’\t\t\tif s.captures != nil {\n   221â†’\t\t\t\t_ = s.captures.SaveCapture(ctx, runID, &domain.StepExecution{\n   222â†’\t\t\t\t\tStepName:  msg.StepName,\n   223â†’\t\t\t\t\tStartedAt: msg.Timestamp,\n   224â†’\t\t\t\t})\n   225â†’\t\t\t}\n   226â†’\t\tcase protocol.MsgStepCompleted:\n   227â†’\t\t\trun.RecordStepComplete(msg.StepName, msg.Result)\n   228â†’\t\t\tif s.captures != nil {\n   229â†’\t\t\t\t_ = s.captures.SaveCapture(ctx, runID, &domain.StepExecution{\n   230â†’\t\t\t\t\tStepName:    msg.StepName,\n   231â†’\t\t\t\t\tResult:      msg.Result,\n   232â†’\t\t\t\t\tCompletedAt: msg.Timestamp,\n   233â†’\t\t\t\t})\n   234â†’\t\t\t}\n   235â†’\t\tcase protocol.MsgRunCompleted:\n   236â†’\t\t\treportedResult = msg.Result\n   237â†’\t\t\tcontinue // Don't persist terminal state yet; branch extraction must finish first\n   238â†’\t\t}\n   239â†’\n   240â†’\t\t_ = s.store.UpdateRun(ctx, run)\n   241â†’\t}\n   242â†’\treader.Close()\n   243â†’\n   244â†’\t// Signal live-stream subscribers that this run is done.\n   245â†’\tif s.logBroadcast != nil {\n   246â†’\t\ts.logBroadcast.Finish(runID)\n   247â†’\t}\n   248â†’\n   249â†’\t// Wait for process exit\n   250â†’\texitCode, err := s.container.Wait(ctx, containerID)\n   251â†’\tif err != nil {\n   252â†’\t\tlog.Printf(\"error waiting for run %s: %v\", runID, err)\n   253â†’\t}\n   254â†’\n   255â†’\t// Extract step output files from container before it's removed\n   256â†’\toutputDst := filepath.Join(projectDir, \".cloche\", runID, \"output\")\n   257â†’\tif err := os.MkdirAll(outputDst, 0755); err == nil {\n   258â†’\t\tif cpErr := s.container.CopyFrom(ctx, containerID, \"/workspace/.cloche/output/.\", outputDst); cpErr != nil {\n   259â†’\t\t\tlog.Printf(\"run %s: failed to extract output: %v\", runID, cpErr)\n   260â†’\t\t}\n   261â†’\t}\n   262â†’\n   263â†’\t// Capture full container stdout/stderr before the container is removed\n   264â†’\tif logs, logErr := s.container.Logs(ctx, containerID); logErr == nil && logs != \"\" {\n   265â†’\t\tcontainerLogPath := filepath.Join(outputDst, \"container.log\")\n   266â†’\t\tif writeErr := os.WriteFile(containerLogPath, []byte(logs), 0644); writeErr != nil {\n   267â†’\t\t\tlog.Printf(\"run %s: failed to write container.log: %v\", runID, writeErr)\n   268â†’\t\t}\n   269â†’\t}\n   270â†’\n   271â†’\t// Index extracted log files in the log store\n   272â†’\tif s.logStore != nil {\n   273â†’\t\ts.indexLogFiles(ctx, runID, outputDst)\n   274â†’\t}\n   275â†’\n   276â†’\t// Extract results to git branch BEFORE finalizing state, so that\n   277â†’\t// WaitRun callers (e.g. host workflow merge step) see branches exist\n   278â†’\t// before the run is marked complete.\n   279â†’\tresultLabel := reportedResult\n   280â†’\tif resultLabel == \"\" {\n   281â†’\t\tif exitCode == 0 {\n   282â†’\t\t\tresultLabel = \"succeeded\"\n   283â†’\t\t} else {\n   284â†’\t\t\tresultLabel = \"failed\"\n   285â†’\t\t}\n   286â†’\t}\n   287â†’\t{\n   288â†’\t\textractRun, _ := s.store.GetRun(ctx, runID)\n   289â†’\t\tif extractRun != nil && extractRun.BaseSHA != \"\" {\n   290â†’\t\t\tlog.Printf(\"run %s: extracting results to branch cloche/%s (baseSHA=%s)\", runID, runID, extractRun.BaseSHA)\n   291â†’\t\t\tif err := docker.ExtractResults(ctx, containerID, extractRun.ProjectDir, runID, extractRun.BaseSHA, workflowName, resultLabel); err != nil {\n   292â†’\t\t\t\tlog.Printf(\"run %s: failed to extract results to branch: %v\", runID, err)\n   293â†’\t\t\t} else {\n   294â†’\t\t\t\tlog.Printf(\"run %s: branch cloche/%s created successfully\", runID, runID)\n   295â†’\t\t\t}\n   296â†’\t\t} else {\n   297â†’\t\t\tlog.Printf(\"run %s: skipping branch extraction (baseSHA empty or run not found)\", runID)\n   298â†’\t\t}\n   299â†’\t}\n   300â†’\n   301â†’\t// Now finalize run state\n   302â†’\trun, err := s.store.GetRun(ctx, runID)\n   303â†’\tif err != nil {\n   304â†’\t\treturn\n   305â†’\t}\n   306â†’\tif run.State == domain.RunStateRunning {\n   307â†’\t\tif reportedResult == \"succeeded\" {\n   308â†’\t\t\trun.Complete(domain.RunStateSucceeded)\n   309â†’\t\t} else if reportedResult != \"\" {\n   310â†’\t\t\trun.Complete(domain.RunStateFailed)\n   311â†’\t\t} else if exitCode == 0 {\n   312â†’\t\t\trun.Complete(domain.RunStateSucceeded)\n   313â†’\t\t} else {\n   314â†’\t\t\trun.Fail(fmt.Sprintf(\"container exited with code %d\", exitCode))\n   315â†’\t\t}\n   316â†’\t\t_ = s.store.UpdateRun(ctx, run)\n   317â†’\t}\n   318â†’\n   319â†’\t// Fire evolution trigger if configured\n   320â†’\tif s.evolution != nil {\n   321â†’\t\ts.evolution.Fire(projectDir, workflowName, runID)\n   322â†’\t}\n   323â†’\n   324â†’\t// Merge is handled as a workflow step in host.cloche, not here.\n   325â†’\n   326â†’\t// Container retention policy:\n   327â†’\t// - Failed runs: always keep the container for debugging\n   328â†’\t// - Successful runs + --keep-container: keep the container\n   329â†’\t// - Successful runs without --keep-container: remove the container\n   330â†’\trunFinal, _ := s.store.GetRun(ctx, runID)\n   331â†’\trunFailed := runFinal != nil && (runFinal.State == domain.RunStateFailed || runFinal.State == domain.RunStateCancelled)\n   332â†’\n   333â†’\tif keepContainer || runFailed {\n   334â†’\t\treason := \"--keep-container\"\n   335â†’\t\tif runFailed {\n   336â†’\t\t\treason = \"run failed\"\n   337â†’\t\t}\n   338â†’\t\tlog.Printf(\"run %s: keeping container %s (%s)\", runID, containerID, reason)\n   339â†’\t\tif runFinal != nil {\n   340â†’\t\t\trunFinal.ContainerKept = true\n   341â†’\t\t\t_ = s.store.UpdateRun(ctx, runFinal)\n   342â†’\t\t}\n   343â†’\t} else {\n   344â†’\t\tif err := s.container.Remove(ctx, containerID); err != nil {\n   345â†’\t\t\tlog.Printf(\"run %s: failed to remove container %s: %v\", runID, containerID, err)\n   346â†’\t\t} else {\n   347â†’\t\t\tlog.Printf(\"run %s: removed container %s\", runID, containerID)\n   348â†’\t\t}\n   349â†’\t}\n   350â†’\n   351â†’\t// Cleanup mapping\n   352â†’\ts.mu.Lock()\n   353â†’\tdelete(s.runIDs, runID)\n   354â†’\ts.mu.Unlock()\n   355â†’}\n   356â†’\n   357â†’func (s *ClocheServer) ListRuns(ctx context.Context, req *pb.ListRunsRequest) (*pb.ListRunsResponse, error) {\n   358â†’\tvar since time.Time\n   359â†’\tif !req.All {\n   360â†’\t\tsince = time.Now().Add(-1 * time.Hour)\n   361â†’\t}\n   362â†’\truns, err := s.store.ListRuns(ctx, since)\n   363â†’\tif err != nil {\n   364â†’\t\treturn nil, fmt.Errorf(\"listing runs: %w\", err)\n   365â†’\t}\n   366â†’\n   367â†’\tresp := &pb.ListRunsResponse{}\n   368â†’\tfor _, run := range runs {\n   369â†’\t\tresp.Runs = append(resp.Runs, &pb.RunSummary{\n   370â†’\t\t\tRunId:        run.ID,\n   371â†’\t\t\tWorkflowName: run.WorkflowName,\n   372â†’\t\t\tState:        string(run.State),\n   373â†’\t\t\tStartedAt:    run.StartedAt.String(),\n   374â†’\t\t\tErrorMessage: run.ErrorMessage,\n   375â†’\t\t\tContainerId:  run.ContainerID,\n   376â†’\t\t})\n   377â†’\t}\n   378â†’\treturn resp, nil\n   379â†’}\n   380â†’\n   381â†’func (s *ClocheServer) GetStatus(ctx context.Context, req *pb.GetStatusRequest) (*pb.GetStatusResponse, error) {\n   382â†’\trun, err := s.store.GetRun(ctx, req.RunId)\n   383â†’\tif err != nil {\n   384â†’\t\treturn nil, fmt.Errorf(\"getting run: %w\", err)\n   385â†’\t}\n   386â†’\n   387â†’\tresp := &pb.GetStatusResponse{\n   388â†’\t\tRunId:        run.ID,\n   389â†’\t\tWorkflowName: run.WorkflowName,\n   390â†’\t\tState:        string(run.State),\n   391â†’\t\tCurrentStep:  strings.Join(run.ActiveSteps, \",\"),\n   392â†’\t\tErrorMessage: run.ErrorMessage,\n   393â†’\t\tContainerId:  run.ContainerID,\n   394â†’\t}\n   395â†’\n   396â†’\t// Check container liveness\n   397â†’\tif run.ContainerID != \"\" && s.container != nil {\n   398â†’\t\tif cs, err := s.container.Inspect(ctx, run.ContainerID); err == nil {\n   399â†’\t\t\tresp.ContainerAlive = cs.Running\n   400â†’\t\t\tif !cs.Running && !cs.FinishedAt.IsZero() {\n   401â†’\t\t\t\tresp.ContainerDeadSince = cs.FinishedAt.Format(time.RFC3339Nano)\n   402â†’\t\t\t}\n   403â†’\t\t}\n   404â†’\t}\n   405â†’\n   406â†’\t// Load step executions from captures store if available\n   407â†’\tif s.captures != nil {\n   408â†’\t\tcaptures, err := s.captures.GetCaptures(ctx, req.RunId)\n   409â†’\t\tif err == nil {\n   410â†’\t\t\tfor _, exec := range captures {\n   411â†’\t\t\t\tresp.StepExecutions = append(resp.StepExecutions, &pb.StepExecutionStatus{\n   412â†’\t\t\t\t\tStepName:    exec.StepName,\n   413â†’\t\t\t\t\tResult:      exec.Result,\n   414â†’\t\t\t\t\tStartedAt:   exec.StartedAt.String(),\n   415â†’\t\t\t\t\tCompletedAt: exec.CompletedAt.String(),\n   416â†’\t\t\t\t})\n   417â†’\t\t\t}\n   418â†’\t\t}\n   419â†’\t} else {\n   420â†’\t\tfor _, exec := range run.StepExecutions {\n   421â†’\t\t\tresp.StepExecutions = append(resp.StepExecutions, &pb.StepExecutionStatus{\n   422â†’\t\t\t\tStepName:    exec.StepName,\n   423â†’\t\t\t\tResult:      exec.Result,\n   424â†’\t\t\t\tStartedAt:   exec.StartedAt.String(),\n   425â†’\t\t\t\tCompletedAt: exec.CompletedAt.String(),\n   426â†’\t\t\t})\n   427â†’\t\t}\n   428â†’\t}\n   429â†’\n   430â†’\treturn resp, nil\n   431â†’}\n   432â†’\n   433â†’func (s *ClocheServer) StreamLogs(req *pb.StreamLogsRequest, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n   434â†’\tctx := stream.Context()\n   435â†’\n   436â†’\t// Verify run exists\n   437â†’\trun, err := s.store.GetRun(ctx, req.RunId)\n   438â†’\tif err != nil {\n   439â†’\t\treturn fmt.Errorf(\"run %q not found: %w\", req.RunId, err)\n   440â†’\t}\n   441â†’\n   442â†’\t// If step_name or log_type filter is set, serve content directly from the log index\n   443â†’\tif req.StepName != \"\" || req.LogType != \"\" {\n   444â†’\t\treturn s.streamFilteredLogs(ctx, req, run, stream)\n   445â†’\t}\n   446â†’\n   447â†’\tif s.captures == nil {\n   448â†’\t\treturn fmt.Errorf(\"captures store not configured\")\n   449â†’\t}\n   450â†’\n   451â†’\t// Check for full.log first â€” if it exists, serve it as the unified log\n   452â†’\tfullLogPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", \"full.log\")\n   453â†’\tif data, readErr := os.ReadFile(fullLogPath); readErr == nil && len(data) > 0 {\n   454â†’\t\tif err := stream.Send(&pb.LogEntry{\n   455â†’\t\t\tType:    \"full_log\",\n   456â†’\t\t\tMessage: string(data),\n   457â†’\t\t}); err != nil {\n   458â†’\t\t\treturn err\n   459â†’\t\t}\n   460â†’\t\t// Still send run completion entry\n   461â†’\t\tif run.State != domain.RunStateRunning && run.State != domain.RunStatePending {\n   462â†’\t\t\tif err := stream.Send(&pb.LogEntry{\n   463â†’\t\t\t\tType:      \"run_completed\",\n   464â†’\t\t\t\tResult:    string(run.State),\n   465â†’\t\t\t\tTimestamp: run.CompletedAt.String(),\n   466â†’\t\t\t\tMessage:   run.ErrorMessage,\n   467â†’\t\t\t}); err != nil {\n   468â†’\t\t\t\treturn err\n   469â†’\t\t\t}\n   470â†’\t\t}\n   471â†’\t\treturn nil\n   472â†’\t}\n   473â†’\n   474â†’\t// Fall back to capture-based streaming\n   475â†’\tcaptures, err := s.captures.GetCaptures(ctx, req.RunId)\n   476â†’\tif err != nil {\n   477â†’\t\treturn fmt.Errorf(\"getting captures: %w\", err)\n   478â†’\t}\n   479â†’\n   480â†’\tfor _, exec := range captures {\n   481â†’\t\t// Captures are stored as separate rows: one for step_started (no Result)\n   482â†’\t\t// and one for step_completed (has Result).\n   483â†’\t\tif exec.Result == \"\" {\n   484â†’\t\t\tentry := &pb.LogEntry{\n   485â†’\t\t\t\tType:      \"step_started\",\n   486â†’\t\t\t\tStepName:  exec.StepName,\n   487â†’\t\t\t\tTimestamp: exec.StartedAt.String(),\n   488â†’\t\t\t}\n   489â†’\t\t\tif err := stream.Send(entry); err != nil {\n   490â†’\t\t\t\treturn err\n   491â†’\t\t\t}\n   492â†’\t\t} else {\n   493â†’\t\t\t// Read step output from file, falling back to container.log\n   494â†’\t\t\tvar output string\n   495â†’\t\t\toutputPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", exec.StepName+\".log\")\n   496â†’\t\t\tif data, err := os.ReadFile(outputPath); err == nil && len(data) > 0 {\n   497â†’\t\t\t\toutput = string(data)\n   498â†’\t\t\t} else {\n   499â†’\t\t\t\tcontainerLogPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", \"container.log\")\n   500â†’\t\t\t\tif data, err := os.ReadFile(containerLogPath); err == nil {\n   501â†’\t\t\t\t\toutput = string(data)\n   502â†’\t\t\t\t}\n   503â†’\t\t\t}\n   504â†’\t\t\tentry := &pb.LogEntry{\n   505â†’\t\t\t\tType:      \"step_completed\",\n   506â†’\t\t\t\tStepName:  exec.StepName,\n   507â†’\t\t\t\tResult:    exec.Result,\n   508â†’\t\t\t\tTimestamp: exec.CompletedAt.String(),\n   509â†’\t\t\t\tMessage:   output,\n   510â†’\t\t\t}\n   511â†’\t\t\tif err := stream.Send(entry); err != nil {\n   512â†’\t\t\t\treturn err\n   513â†’\t\t\t}\n   514â†’\t\t}\n   515â†’\t}\n   516â†’\n   517â†’\t// Send run completion entry\n   518â†’\tif run.State != domain.RunStateRunning && run.State != domain.RunStatePending {\n   519â†’\t\tif err := stream.Send(&pb.LogEntry{\n   520â†’\t\t\tType:      \"run_completed\",\n   521â†’\t\t\tResult:    string(run.State),\n   522â†’\t\t\tTimestamp: run.CompletedAt.String(),\n   523â†’\t\t\tMessage:   run.ErrorMessage,\n   524â†’\t\t}); err != nil {\n   525â†’\t\t\treturn err\n   526â†’\t\t}\n   527â†’\t}\n   528â†’\n   529â†’\treturn nil\n   530â†’}\n   531â†’\n   532â†’// streamFilteredLogs serves log content filtered by step name and/or log type.\n   533â†’// It uses the log index when available, falling back to file path conventions.\n   534â†’func (s *ClocheServer) streamFilteredLogs(ctx context.Context, req *pb.StreamLogsRequest, run *domain.Run, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n   535â†’\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\")\n   536â†’\n   537â†’\t// Try log index first\n   538â†’\tif s.logStore != nil {\n   539â†’\t\tvar logFiles []*ports.LogFileEntry\n   540â†’\t\tvar err error\n   541â†’\n   542â†’\t\tif req.StepName != \"\" && req.LogType != \"\" {\n   543â†’\t\t\t// Filter by both step and type\n   544â†’\t\t\tlogFiles, err = s.logStore.GetLogFilesByStep(ctx, req.RunId, req.StepName)\n   545â†’\t\t\tif err == nil {\n   546â†’\t\t\t\tfiltered := logFiles[:0]\n   547â†’\t\t\t\tfor _, lf := range logFiles {\n   548â†’\t\t\t\t\tif lf.FileType == req.LogType {\n   549â†’\t\t\t\t\t\tfiltered = append(filtered, lf)\n   550â†’\t\t\t\t\t}\n   551â†’\t\t\t\t}\n   552â†’\t\t\t\tlogFiles = filtered\n   553â†’\t\t\t}\n   554â†’\t\t} else if req.StepName != \"\" {\n   555â†’\t\t\tlogFiles, err = s.logStore.GetLogFilesByStep(ctx, req.RunId, req.StepName)\n   556â†’\t\t} else {\n   557â†’\t\t\tlogFiles, err = s.logStore.GetLogFileByType(ctx, req.RunId, req.LogType)\n   558â†’\t\t}\n   559â†’\n   560â†’\t\tif err == nil && len(logFiles) > 0 {\n   561â†’\t\t\tfor _, lf := range logFiles {\n   562â†’\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n   563â†’\t\t\t\tif readErr != nil {\n   564â†’\t\t\t\t\tcontinue\n   565â†’\t\t\t\t}\n   566â†’\t\t\t\tif err := stream.Send(&pb.LogEntry{\n   567â†’\t\t\t\t\tType:     lf.FileType + \"_log\",\n   568â†’\t\t\t\t\tStepName: lf.StepName,\n   569â†’\t\t\t\t\tMessage:  string(data),\n   570â†’\t\t\t\t}); err != nil {\n   571â†’\t\t\t\t\treturn err\n   572â†’\t\t\t\t}\n   573â†’\t\t\t}\n   574â†’\t\t\treturn nil\n   575â†’\t\t}\n   576â†’\t}\n   577â†’\n   578â†’\t// Fall back to file path conventions\n   579â†’\tif req.StepName != \"\" {\n   580â†’\t\tvar logPath string\n   581â†’\t\tswitch req.LogType {\n   582â†’\t\tcase \"llm\":\n   583â†’\t\t\tlogPath = filepath.Join(outputDir, \"llm-\"+req.StepName+\".log\")\n   584â†’\t\tdefault:\n   585â†’\t\t\tlogPath = filepath.Join(outputDir, req.StepName+\".log\")\n   586â†’\t\t}\n   587â†’\n   588â†’\t\tdata, err := os.ReadFile(logPath)\n   589â†’\t\tif err != nil {\n   590â†’\t\t\treturn fmt.Errorf(\"log file not found for step %q: %w\", req.StepName, err)\n   591â†’\t\t}\n   592â†’\t\treturn stream.Send(&pb.LogEntry{\n   593â†’\t\t\tType:     \"step_log\",\n   594â†’\t\t\tStepName: req.StepName,\n   595â†’\t\t\tMessage:  string(data),\n   596â†’\t\t})\n   597â†’\t}\n   598â†’\n   599â†’\treturn fmt.Errorf(\"no log files found matching filter\")\n   600â†’}\n   601â†’\n   602â†’func (s *ClocheServer) StopRun(ctx context.Context, req *pb.StopRunRequest) (*pb.StopRunResponse, error) {\n   603â†’\ts.mu.Lock()\n   604â†’\tcontainerID, ok := s.runIDs[req.RunId]\n   605â†’\ts.mu.Unlock()\n   606â†’\n   607â†’\tif !ok {\n   608â†’\t\treturn nil, fmt.Errorf(\"run %q not found or already completed\", req.RunId)\n   609â†’\t}\n   610â†’\n   611â†’\tif err := s.container.Stop(ctx, containerID); err != nil {\n   612â†’\t\treturn nil, fmt.Errorf(\"stopping run: %w\", err)\n   613â†’\t}\n   614â†’\n   615â†’\t// Mark as cancelled in store\n   616â†’\trun, err := s.store.GetRun(ctx, req.RunId)\n   617â†’\tif err == nil {\n   618â†’\t\trun.Complete(domain.RunStateCancelled)\n   619â†’\t\t_ = s.store.UpdateRun(ctx, run)\n   620â†’\t}\n   621â†’\n   622â†’\treturn &pb.StopRunResponse{}, nil\n   623â†’}\n   624â†’\n   625â†’func (s *ClocheServer) DeleteContainer(ctx context.Context, req *pb.DeleteContainerRequest) (*pb.DeleteContainerResponse, error) {\n   626â†’\tif s.container == nil {\n   627â†’\t\treturn nil, fmt.Errorf(\"no container runtime configured\")\n   628â†’\t}\n   629â†’\n   630â†’\tid := req.Id\n   631â†’\tif id == \"\" {\n   632â†’\t\treturn nil, fmt.Errorf(\"id is required\")\n   633â†’\t}\n   634â†’\n   635â†’\t// Try to resolve as a run ID first\n   636â†’\tcontainerID := id\n   637â†’\trun, err := s.store.GetRun(ctx, id)\n   638â†’\tif err == nil {\n   639â†’\t\t// It's a run ID â€” use the container ID from the run record\n   640â†’\t\tif run.ContainerID == \"\" {\n   641â†’\t\t\treturn nil, fmt.Errorf(\"run %q has no associated container\", id)\n   642â†’\t\t}\n   643â†’\t\tcontainerID = run.ContainerID\n   644â†’\t}\n   645â†’\n   646â†’\t// Remove the container\n   647â†’\tif err := s.container.Remove(ctx, containerID); err != nil {\n   648â†’\t\treturn nil, fmt.Errorf(\"removing container: %w\", err)\n   649â†’\t}\n   650â†’\n   651â†’\t// If we resolved a run, clear the container_kept flag\n   652â†’\tif run != nil {\n   653â†’\t\trun.ContainerKept = false\n   654â†’\t\t_ = s.store.UpdateRun(ctx, run)\n   655â†’\t}\n   656â†’\n   657â†’\treturn &pb.DeleteContainerResponse{}, nil\n   658â†’}\n   659â†’\n   660â†’func (s *ClocheServer) Orchestrate(ctx context.Context, req *pb.OrchestrateRequest) (*pb.OrchestrateResponse, error) {\n   661â†’\treturn nil, fmt.Errorf(\"orchestrator has been removed; use host workflow instead\")\n   662â†’}\n   663â†’\n   664â†’func (s *ClocheServer) Shutdown(ctx context.Context, req *pb.ShutdownRequest) (*pb.ShutdownResponse, error) {\n   665â†’\tif s.shutdownFn == nil {\n   666â†’\t\treturn nil, fmt.Errorf(\"shutdown not configured\")\n   667â†’\t}\n   668â†’\tgo s.shutdownFn()\n   669â†’\treturn &pb.ShutdownResponse{}, nil\n   670â†’}\n   671â†’\n   672â†’// indexLogFiles scans the extracted output directory and creates log_files index entries.\n   673â†’func (s *ClocheServer) indexLogFiles(ctx context.Context, runID, outputDir string) {\n   674â†’\tentries, err := os.ReadDir(outputDir)\n   675â†’\tif err != nil {\n   676â†’\t\tlog.Printf(\"run %s: failed to read output dir for indexing: %v\", runID, err)\n   677â†’\t\treturn\n   678â†’\t}\n   679â†’\n   680â†’\tnow := time.Now()\n   681â†’\tfor _, entry := range entries {\n   682â†’\t\tif entry.IsDir() {\n   683â†’\t\t\tcontinue\n   684â†’\t\t}\n   685â†’\t\tname := entry.Name()\n   686â†’\t\tif !strings.HasSuffix(name, \".log\") {\n   687â†’\t\t\tcontinue\n   688â†’\t\t}\n   689â†’\n   690â†’\t\tvar fileType, stepName string\n   691â†’\t\tbase := strings.TrimSuffix(name, \".log\")\n   692â†’\n   693â†’\t\tswitch {\n   694â†’\t\tcase name == \"full.log\":\n   695â†’\t\t\tfileType = \"full\"\n   696â†’\t\tcase name == \"container.log\":\n   697â†’\t\t\t// container.log is internal, not indexed as a user-facing log type\n   698â†’\t\t\tcontinue\n   699â†’\t\tcase strings.HasPrefix(name, \"llm-\"):\n   700â†’\t\t\tfileType = \"llm\"\n   701â†’\t\t\tstepName = strings.TrimPrefix(base, \"llm-\")\n   702â†’\t\tdefault:\n   703â†’\t\t\tfileType = \"script\"\n   704â†’\t\t\tstepName = base\n   705â†’\t\t}\n   706â†’\n   707â†’\t\tinfo, _ := entry.Info()\n   708â†’\t\tvar fileSize int64\n   709â†’\t\tif info != nil {\n   710â†’\t\t\tfileSize = info.Size()\n   711â†’\t\t}\n   712â†’\n   713â†’\t\tlogEntry := &ports.LogFileEntry{\n   714â†’\t\t\tRunID:     runID,\n   715â†’\t\t\tStepName:  stepName,\n   716â†’\t\t\tFileType:  fileType,\n   717â†’\t\t\tFilePath:  filepath.Join(outputDir, name),\n   718â†’\t\t\tFileSize:  fileSize,\n   719â†’\t\t\tCreatedAt: now,\n   720â†’\t\t}\n   721â†’\t\tif err := s.logStore.SaveLogFile(ctx, logEntry); err != nil {\n   722â†’\t\t\tlog.Printf(\"run %s: failed to index log file %s: %v\", runID, name, err)\n   723â†’\t\t}\n   724â†’\t}\n   725â†’}\n   726â†’\n   727â†’func gitHEAD(dir string) string {\n   728â†’\tcmd := exec.Command(\"git\", \"rev-parse\", \"HEAD\")\n   729â†’\tcmd.Dir = dir\n   730â†’\tout, err := cmd.Output()\n   731â†’\tif err != nil {\n   732â†’\t\treturn \"\"\n   733â†’\t}\n   734â†’\treturn strings.TrimSpace(string(out))\n   735â†’}\n   736â†’"}]},"parent_tool_use_id":null,"session_id":"c6864ddb-8a62-468e-9371-23940235ec7e","uuid":"f4f6c6d9-57a6-4dd4-9e93-5ae976a49b75","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/grpc/server.go","content":"package grpc\n\nimport (\n\t\"bufio\"\n\t\"context\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"log\"\n\t\"os\"\n\t\"os/exec\"\n\t\"path/filepath\"\n\t\"strings\"\n\t\"sync\"\n\t\"time\"\n\n\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n\t\"github.com/cloche-dev/cloche/internal/adapters/docker\"\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/evolution\"\n\t\"github.com/cloche-dev/cloche/internal/logstream\"\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n\t\"github.com/cloche-dev/cloche/internal/protocol\"\n\trpcgrpc \"google.golang.org/grpc\"\n)\n\ntype ClocheServer struct {\n\tpb.UnimplementedClocheServiceServer\n\tstore        ports.RunStore\n\tcaptures     ports.CaptureStore\n\tlogStore     ports.LogStore\n\tcontainer    ports.ContainerRuntime\n\tdefaultImage string\n\tevolution    *evolution.Trigger\n\tlogBroadcast *logstream.Broadcaster\n\tshutdownFn   func()\n\tmu           sync.Mutex\n\trunIDs       map[string]string // run_id -> container_id\n}\n\nfunc NewClocheServer(store ports.RunStore, container ports.ContainerRuntime) *ClocheServer {\n\treturn &ClocheServer{\n\t\tstore:     store,\n\t\tcontainer: container,\n\t\trunIDs:    make(map[string]string),\n\t}\n}\n\nfunc NewClocheServerWithCaptures(store ports.RunStore, captures ports.CaptureStore, container ports.ContainerRuntime, defaultImage string) *ClocheServer {\n\treturn &ClocheServer{\n\t\tstore:        store,\n\t\tcaptures:     captures,\n\t\tcontainer:    container,\n\t\tdefaultImage: defaultImage,\n\t\trunIDs:       make(map[string]string),\n\t}\n}\n\n// SetLogStore attaches a log store to the server for indexing extracted log files.\nfunc (s *ClocheServer) SetLogStore(ls ports.LogStore) {\n\ts.logStore = ls\n}\n\n\n// SetEvolution attaches an evolution trigger to the server.\nfunc (s *ClocheServer) SetEvolution(trigger *evolution.Trigger) {\n\ts.evolution = trigger\n}\n\n// SetLogBroadcaster attaches a log broadcaster for live-streaming LLM output.\nfunc (s *ClocheServer) SetLogBroadcaster(b *logstream.Broadcaster) {\n\ts.logBroadcast = b\n}\n\n// SetShutdownFunc sets the callback invoked when the Shutdown RPC is called.\nfunc (s *ClocheServer) SetShutdownFunc(fn func()) {\n\ts.shutdownFn = fn\n}\n\nfunc (s *ClocheServer) RunWorkflow(ctx context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error) {\n\tif s.container == nil {\n\t\treturn nil, fmt.Errorf(\"no container runtime configured\")\n\t}\n\n\t// Generate a unique run ID, retrying on collision\n\tvar runID string\n\tfor attempts := 0; attempts < 10; attempts++ {\n\t\trunID = domain.GenerateRunID(req.WorkflowName)\n\t\texisting, err := s.store.GetRun(ctx, runID)\n\t\tif err != nil {\n\t\t\tbreak // ID is free\n\t\t}\n\t\t// Reuse if completed more than 1 hour ago\n\t\tif !existing.CompletedAt.IsZero() && time.Since(existing.CompletedAt) > time.Hour {\n\t\t\t_ = s.store.DeleteRun(ctx, runID)\n\t\t\tbreak\n\t\t}\n\t}\n\n\t// Write prompt to .cloche/<run-id>/prompt.txt (run-specific to avoid conflicts)\n\tif req.Prompt != \"\" {\n\t\tclocheDir := filepath.Join(req.ProjectDir, \".cloche\", runID)\n\t\tif err := os.MkdirAll(clocheDir, 0755); err != nil {\n\t\t\treturn nil, fmt.Errorf(\"creating .cloche dir: %w\", err)\n\t\t}\n\t\tif err := os.WriteFile(filepath.Join(clocheDir, \"prompt.txt\"), []byte(req.Prompt), 0644); err != nil {\n\t\t\treturn nil, fmt.Errorf(\"writing prompt: %w\", err)\n\t\t}\n\t}\n\trun := domain.NewRun(runID, req.WorkflowName)\n\trun.ProjectDir = req.ProjectDir\n\tif err := s.store.CreateRun(ctx, run); err != nil {\n\t\treturn nil, fmt.Errorf(\"creating run: %w\", err)\n\t}\n\n\t// Resolve image: request-level override, then server default\n\timage := req.Image\n\tif image == \"\" {\n\t\timage = s.defaultImage\n\t}\n\n\t// Launch container start + tracking in background so the RPC returns immediately.\n\t// The run stays in \"pending\" state until the container is up.\n\tgo s.launchAndTrack(runID, image, req.KeepContainer, req)\n\n\treturn &pb.RunWorkflowResponse{RunId: runID}, nil\n}\n\n// launchAndTrack starts the container and then tracks it to completion.\n// It runs in a background goroutine with its own context, independent of the\n// RPC context which may be cancelled after RunWorkflow returns.\nfunc (s *ClocheServer) launchAndTrack(runID, image string, keepContainer bool, req *pb.RunWorkflowRequest) {\n\tctx := context.Background()\n\n\t// Auto-rebuild image if the project Dockerfile has changed since last build.\n\tif ensurer, ok := s.container.(ports.ImageEnsurer); ok {\n\t\tif err := ensurer.EnsureImage(ctx, req.ProjectDir, image); err != nil {\n\t\t\trun, _ := s.store.GetRun(ctx, runID)\n\t\t\tif run != nil {\n\t\t\t\trun.Fail(fmt.Sprintf(\"failed to ensure image: %v\", err))\n\t\t\t\t_ = s.store.UpdateRun(ctx, run)\n\t\t\t}\n\t\t\tlog.Printf(\"run %s: failed to ensure image: %v\", runID, err)\n\t\t\t\treturn\n\t\t}\n\t}\n\n\tbaseSHA := gitHEAD(req.ProjectDir)\n\n\tcontainerID, err := s.container.Start(ctx, ports.ContainerConfig{\n\t\tImage:        image,\n\t\tWorkflowName: req.WorkflowName,\n\t\tProjectDir:   req.ProjectDir,\n\t\tRunID:        runID,\n\t\tNetworkAllow: []string{\"*\"},\n\t})\n\tif err != nil {\n\t\trun, _ := s.store.GetRun(ctx, runID)\n\t\tif run != nil {\n\t\t\trun.Fail(fmt.Sprintf(\"failed to start container: %v\", err))\n\t\t\t_ = s.store.UpdateRun(ctx, run)\n\t\t}\n\t\tlog.Printf(\"run %s: failed to start container: %v\", runID, err)\n\t\treturn\n\t}\n\n\ts.mu.Lock()\n\ts.runIDs[runID] = containerID\n\ts.mu.Unlock()\n\n\trun, _ := s.store.GetRun(ctx, runID)\n\tif run != nil {\n\t\trun.Start()\n\t\trun.ContainerID = containerID\n\t\trun.BaseSHA = baseSHA\n\t\t_ = s.store.UpdateRun(ctx, run)\n\t}\n\n\ts.trackRun(runID, containerID, req.ProjectDir, req.WorkflowName, keepContainer)\n}\n\nfunc (s *ClocheServer) trackRun(runID, containerID, projectDir, workflowName string, keepContainer bool) {\n\tctx := context.Background()\n\n\t// Attach to agent output\n\treader, err := s.container.AttachOutput(ctx, containerID)\n\tif err != nil {\n\t\tlog.Printf(\"failed to attach to output for run %s: %v\", runID, err)\n\t\t\treturn\n\t}\n\n\t// Parse JSON-lines status messages\n\tvar reportedResult string // captured from MsgRunCompleted, persisted after branch extraction\n\tscanner := bufio.NewScanner(reader)\n\tfor scanner.Scan() {\n\t\tvar msg protocol.StatusMessage\n\t\tif err := json.Unmarshal(scanner.Bytes(), &msg); err != nil {\n\t\t\tcontinue\n\t\t}\n\n\t\t// Fast path: log messages don't need store interaction.\n\t\tif msg.Type == protocol.MsgLog {\n\t\t\tif s.logBroadcast != nil {\n\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n\t\t\t\t\tType:      \"llm\",\n\t\t\t\t\tContent:   msg.Message,\n\t\t\t\t})\n\t\t\t}\n\t\t\tcontinue\n\t\t}\n\n\t\trun, err := s.store.GetRun(ctx, runID)\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\n\t\tswitch msg.Type {\n\t\tcase protocol.MsgStepStarted:\n\t\t\trun.RecordStepStart(msg.StepName)\n\t\t\tif s.captures != nil {\n\t\t\t\t_ = s.captures.SaveCapture(ctx, runID, &domain.StepExecution{\n\t\t\t\t\tStepName:  msg.StepName,\n\t\t\t\t\tStartedAt: msg.Timestamp,\n\t\t\t\t})\n\t\t\t}\n\t\tcase protocol.MsgStepCompleted:\n\t\t\trun.RecordStepComplete(msg.StepName, msg.Result)\n\t\t\tif s.captures != nil {\n\t\t\t\t_ = s.captures.SaveCapture(ctx, runID, &domain.StepExecution{\n\t\t\t\t\tStepName:    msg.StepName,\n\t\t\t\t\tResult:      msg.Result,\n\t\t\t\t\tCompletedAt: msg.Timestamp,\n\t\t\t\t})\n\t\t\t}\n\t\tcase protocol.MsgRunCompleted:\n\t\t\treportedResult = msg.Result\n\t\t\tcontinue // Don't persist terminal state yet; branch extraction must finish first\n\t\t}\n\n\t\t_ = s.store.UpdateRun(ctx, run)\n\t}\n\treader.Close()\n\n\t// Signal live-stream subscribers that this run is done.\n\tif s.logBroadcast != nil {\n\t\ts.logBroadcast.Finish(runID)\n\t}\n\n\t// Wait for process exit\n\texitCode, err := s.container.Wait(ctx, containerID)\n\tif err != nil {\n\t\tlog.Printf(\"error waiting for run %s: %v\", runID, err)\n\t}\n\n\t// Extract step output files from container before it's removed\n\toutputDst := filepath.Join(projectDir, \".cloche\", runID, \"output\")\n\tif err := os.MkdirAll(outputDst, 0755); err == nil {\n\t\tif cpErr := s.container.CopyFrom(ctx, containerID, \"/workspace/.cloche/output/.\", outputDst); cpErr != nil {\n\t\t\tlog.Printf(\"run %s: failed to extract output: %v\", runID, cpErr)\n\t\t}\n\t}\n\n\t// Capture full container stdout/stderr before the container is removed\n\tif logs, logErr := s.container.Logs(ctx, containerID); logErr == nil && logs != \"\" {\n\t\tcontainerLogPath := filepath.Join(outputDst, \"container.log\")\n\t\tif writeErr := os.WriteFile(containerLogPath, []byte(logs), 0644); writeErr != nil {\n\t\t\tlog.Printf(\"run %s: failed to write container.log: %v\", runID, writeErr)\n\t\t}\n\t}\n\n\t// Index extracted log files in the log store\n\tif s.logStore != nil {\n\t\ts.indexLogFiles(ctx, runID, outputDst)\n\t}\n\n\t// Extract results to git branch BEFORE finalizing state, so that\n\t// WaitRun callers (e.g. host workflow merge step) see branches exist\n\t// before the run is marked complete.\n\tresultLabel := reportedResult\n\tif resultLabel == \"\" {\n\t\tif exitCode == 0 {\n\t\t\tresultLabel = \"succeeded\"\n\t\t} else {\n\t\t\tresultLabel = \"failed\"\n\t\t}\n\t}\n\t{\n\t\textractRun, _ := s.store.GetRun(ctx, runID)\n\t\tif extractRun != nil && extractRun.BaseSHA != \"\" {\n\t\t\tlog.Printf(\"run %s: extracting results to branch cloche/%s (baseSHA=%s)\", runID, runID, extractRun.BaseSHA)\n\t\t\tif err := docker.ExtractResults(ctx, containerID, extractRun.ProjectDir, runID, extractRun.BaseSHA, workflowName, resultLabel); err != nil {\n\t\t\t\tlog.Printf(\"run %s: failed to extract results to branch: %v\", runID, err)\n\t\t\t} else {\n\t\t\t\tlog.Printf(\"run %s: branch cloche/%s created successfully\", runID, runID)\n\t\t\t}\n\t\t} else {\n\t\t\tlog.Printf(\"run %s: skipping branch extraction (baseSHA empty or run not found)\", runID)\n\t\t}\n\t}\n\n\t// Now finalize run state\n\trun, err := s.store.GetRun(ctx, runID)\n\tif err != nil {\n\t\treturn\n\t}\n\tif run.State == domain.RunStateRunning {\n\t\tif reportedResult == \"succeeded\" {\n\t\t\trun.Complete(domain.RunStateSucceeded)\n\t\t} else if reportedResult != \"\" {\n\t\t\trun.Complete(domain.RunStateFailed)\n\t\t} else if exitCode == 0 {\n\t\t\trun.Complete(domain.RunStateSucceeded)\n\t\t} else {\n\t\t\trun.Fail(fmt.Sprintf(\"container exited with code %d\", exitCode))\n\t\t}\n\t\t_ = s.store.UpdateRun(ctx, run)\n\t}\n\n\t// Fire evolution trigger if configured\n\tif s.evolution != nil {\n\t\ts.evolution.Fire(projectDir, workflowName, runID)\n\t}\n\n\t// Merge is handled as a workflow step in host.cloche, not here.\n\n\t// Container retention policy:\n\t// - Failed runs: always keep the container for debugging\n\t// - Successful runs + --keep-container: keep the container\n\t// - Successful runs without --keep-container: remove the container\n\trunFinal, _ := s.store.GetRun(ctx, runID)\n\trunFailed := runFinal != nil && (runFinal.State == domain.RunStateFailed || runFinal.State == domain.RunStateCancelled)\n\n\tif keepContainer || runFailed {\n\t\treason := \"--keep-container\"\n\t\tif runFailed {\n\t\t\treason = \"run failed\"\n\t\t}\n\t\tlog.Printf(\"run %s: keeping container %s (%s)\", runID, containerID, reason)\n\t\tif runFinal != nil {\n\t\t\trunFinal.ContainerKept = true\n\t\t\t_ = s.store.UpdateRun(ctx, runFinal)\n\t\t}\n\t} else {\n\t\tif err := s.container.Remove(ctx, containerID); err != nil {\n\t\t\tlog.Printf(\"run %s: failed to remove container %s: %v\", runID, containerID, err)\n\t\t} else {\n\t\t\tlog.Printf(\"run %s: removed container %s\", runID, containerID)\n\t\t}\n\t}\n\n\t// Cleanup mapping\n\ts.mu.Lock()\n\tdelete(s.runIDs, runID)\n\ts.mu.Unlock()\n}\n\nfunc (s *ClocheServer) ListRuns(ctx context.Context, req *pb.ListRunsRequest) (*pb.ListRunsResponse, error) {\n\tvar since time.Time\n\tif !req.All {\n\t\tsince = time.Now().Add(-1 * time.Hour)\n\t}\n\truns, err := s.store.ListRuns(ctx, since)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"listing runs: %w\", err)\n\t}\n\n\tresp := &pb.ListRunsResponse{}\n\tfor _, run := range runs {\n\t\tresp.Runs = append(resp.Runs, &pb.RunSummary{\n\t\t\tRunId:        run.ID,\n\t\t\tWorkflowName: run.WorkflowName,\n\t\t\tState:        string(run.State),\n\t\t\tStartedAt:    run.StartedAt.String(),\n\t\t\tErrorMessage: run.ErrorMessage,\n\t\t\tContainerId:  run.ContainerID,\n\t\t})\n\t}\n\treturn resp, nil\n}\n\nfunc (s *ClocheServer) GetStatus(ctx context.Context, req *pb.GetStatusRequest) (*pb.GetStatusResponse, error) {\n\trun, err := s.store.GetRun(ctx, req.RunId)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"getting run: %w\", err)\n\t}\n\n\tresp := &pb.GetStatusResponse{\n\t\tRunId:        run.ID,\n\t\tWorkflowName: run.WorkflowName,\n\t\tState:        string(run.State),\n\t\tCurrentStep:  strings.Join(run.ActiveSteps, \",\"),\n\t\tErrorMessage: run.ErrorMessage,\n\t\tContainerId:  run.ContainerID,\n\t}\n\n\t// Check container liveness\n\tif run.ContainerID != \"\" && s.container != nil {\n\t\tif cs, err := s.container.Inspect(ctx, run.ContainerID); err == nil {\n\t\t\tresp.ContainerAlive = cs.Running\n\t\t\tif !cs.Running && !cs.FinishedAt.IsZero() {\n\t\t\t\tresp.ContainerDeadSince = cs.FinishedAt.Format(time.RFC3339Nano)\n\t\t\t}\n\t\t}\n\t}\n\n\t// Load step executions from captures store if available\n\tif s.captures != nil {\n\t\tcaptures, err := s.captures.GetCaptures(ctx, req.RunId)\n\t\tif err == nil {\n\t\t\tfor _, exec := range captures {\n\t\t\t\tresp.StepExecutions = append(resp.StepExecutions, &pb.StepExecutionStatus{\n\t\t\t\t\tStepName:    exec.StepName,\n\t\t\t\t\tResult:      exec.Result,\n\t\t\t\t\tStartedAt:   exec.StartedAt.String(),\n\t\t\t\t\tCompletedAt: exec.CompletedAt.String(),\n\t\t\t\t})\n\t\t\t}\n\t\t}\n\t} else {\n\t\tfor _, exec := range run.StepExecutions {\n\t\t\tresp.StepExecutions = append(resp.StepExecutions, &pb.StepExecutionStatus{\n\t\t\t\tStepName:    exec.StepName,\n\t\t\t\tResult:      exec.Result,\n\t\t\t\tStartedAt:   exec.StartedAt.String(),\n\t\t\t\tCompletedAt: exec.CompletedAt.String(),\n\t\t\t})\n\t\t}\n\t}\n\n\treturn resp, nil\n}\n\nfunc (s *ClocheServer) StreamLogs(req *pb.StreamLogsRequest, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n\tctx := stream.Context()\n\n\t// Verify run exists\n\trun, err := s.store.GetRun(ctx, req.RunId)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"run %q not found: %w\", req.RunId, err)\n\t}\n\n\t// If step_name or log_type filter is set, serve content directly from the log index\n\tif req.StepName != \"\" || req.LogType != \"\" {\n\t\treturn s.streamFilteredLogs(ctx, req, run, stream)\n\t}\n\n\tif s.captures == nil {\n\t\treturn fmt.Errorf(\"captures store not configured\")\n\t}\n\n\t// Check for full.log first â€” if it exists, serve it as the unified log\n\tfullLogPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", \"full.log\")\n\tif data, readErr := os.ReadFile(fullLogPath); readErr == nil && len(data) > 0 {\n\t\tif err := stream.Send(&pb.LogEntry{\n\t\t\tType:    \"full_log\",\n\t\t\tMessage: string(data),\n\t\t}); err != nil {\n\t\t\treturn err\n\t\t}\n\t\t// Still send run completion entry\n\t\tif run.State != domain.RunStateRunning && run.State != domain.RunStatePending {\n\t\t\tif err := stream.Send(&pb.LogEntry{\n\t\t\t\tType:      \"run_completed\",\n\t\t\t\tResult:    string(run.State),\n\t\t\t\tTimestamp: run.CompletedAt.String(),\n\t\t\t\tMessage:   run.ErrorMessage,\n\t\t\t}); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t}\n\t\treturn nil\n\t}\n\n\t// Fall back to capture-based streaming\n\tcaptures, err := s.captures.GetCaptures(ctx, req.RunId)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"getting captures: %w\", err)\n\t}\n\n\tfor _, exec := range captures {\n\t\t// Captures are stored as separate rows: one for step_started (no Result)\n\t\t// and one for step_completed (has Result).\n\t\tif exec.Result == \"\" {\n\t\t\tentry := &pb.LogEntry{\n\t\t\t\tType:      \"step_started\",\n\t\t\t\tStepName:  exec.StepName,\n\t\t\t\tTimestamp: exec.StartedAt.String(),\n\t\t\t}\n\t\t\tif err := stream.Send(entry); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t} else {\n\t\t\t// Read step output from file, falling back to container.log\n\t\t\tvar output string\n\t\t\toutputPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", exec.StepName+\".log\")\n\t\t\tif data, err := os.ReadFile(outputPath); err == nil && len(data) > 0 {\n\t\t\t\toutput = string(data)\n\t\t\t} else {\n\t\t\t\tcontainerLogPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", \"container.log\")\n\t\t\t\tif data, err := os.ReadFile(containerLogPath); err == nil {\n\t\t\t\t\toutput = string(data)\n\t\t\t\t}\n\t\t\t}\n\t\t\tentry := &pb.LogEntry{\n\t\t\t\tType:      \"step_completed\",\n\t\t\t\tStepName:  exec.StepName,\n\t\t\t\tResult:    exec.Result,\n\t\t\t\tTimestamp: exec.CompletedAt.String(),\n\t\t\t\tMessage:   output,\n\t\t\t}\n\t\t\tif err := stream.Send(entry); err != nil {\n\t\t\t\treturn err\n\t\t\t}\n\t\t}\n\t}\n\n\t// Send run completion entry\n\tif run.State != domain.RunStateRunning && run.State != domain.RunStatePending {\n\t\tif err := stream.Send(&pb.LogEntry{\n\t\t\tType:      \"run_completed\",\n\t\t\tResult:    string(run.State),\n\t\t\tTimestamp: run.CompletedAt.String(),\n\t\t\tMessage:   run.ErrorMessage,\n\t\t}); err != nil {\n\t\t\treturn err\n\t\t}\n\t}\n\n\treturn nil\n}\n\n// streamFilteredLogs serves log content filtered by step name and/or log type.\n// It uses the log index when available, falling back to file path conventions.\nfunc (s *ClocheServer) streamFilteredLogs(ctx context.Context, req *pb.StreamLogsRequest, run *domain.Run, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\")\n\n\t// Try log index first\n\tif s.logStore != nil {\n\t\tvar logFiles []*ports.LogFileEntry\n\t\tvar err error\n\n\t\tif req.StepName != \"\" && req.LogType != \"\" {\n\t\t\t// Filter by both step and type\n\t\t\tlogFiles, err = s.logStore.GetLogFilesByStep(ctx, req.RunId, req.StepName)\n\t\t\tif err == nil {\n\t\t\t\tfiltered := logFiles[:0]\n\t\t\t\tfor _, lf := range logFiles {\n\t\t\t\t\tif lf.FileType == req.LogType {\n\t\t\t\t\t\tfiltered = append(filtered, lf)\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t\tlogFiles = filtered\n\t\t\t}\n\t\t} else if req.StepName != \"\" {\n\t\t\tlogFiles, err = s.logStore.GetLogFilesByStep(ctx, req.RunId, req.StepName)\n\t\t} else {\n\t\t\tlogFiles, err = s.logStore.GetLogFileByType(ctx, req.RunId, req.LogType)\n\t\t}\n\n\t\tif err == nil && len(logFiles) > 0 {\n\t\t\tfor _, lf := range logFiles {\n\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n\t\t\t\tif readErr != nil {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tif err := stream.Send(&pb.LogEntry{\n\t\t\t\t\tType:     lf.FileType + \"_log\",\n\t\t\t\t\tStepName: lf.StepName,\n\t\t\t\t\tMessage:  string(data),\n\t\t\t\t}); err != nil {\n\t\t\t\t\treturn err\n\t\t\t\t}\n\t\t\t}\n\t\t\treturn nil\n\t\t}\n\t}\n\n\t// Fall back to file path conventions\n\tif req.StepName != \"\" {\n\t\tvar logPath string\n\t\tswitch req.LogType {\n\t\tcase \"llm\":\n\t\t\tlogPath = filepath.Join(outputDir, \"llm-\"+req.StepName+\".log\")\n\t\tdefault:\n\t\t\tlogPath = filepath.Join(outputDir, req.StepName+\".log\")\n\t\t}\n\n\t\tdata, err := os.ReadFile(logPath)\n\t\tif err != nil {\n\t\t\treturn fmt.Errorf(\"log file not found for step %q: %w\", req.StepName, err)\n\t\t}\n\t\treturn stream.Send(&pb.LogEntry{\n\t\t\tType:     \"step_log\",\n\t\t\tStepName: req.StepName,\n\t\t\tMessage:  string(data),\n\t\t})\n\t}\n\n\treturn fmt.Errorf(\"no log files found matching filter\")\n}\n\nfunc (s *ClocheServer) StopRun(ctx context.Context, req *pb.StopRunRequest) (*pb.StopRunResponse, error) {\n\ts.mu.Lock()\n\tcontainerID, ok := s.runIDs[req.RunId]\n\ts.mu.Unlock()\n\n\tif !ok {\n\t\treturn nil, fmt.Errorf(\"run %q not found or already completed\", req.RunId)\n\t}\n\n\tif err := s.container.Stop(ctx, containerID); err != nil {\n\t\treturn nil, fmt.Errorf(\"stopping run: %w\", err)\n\t}\n\n\t// Mark as cancelled in store\n\trun, err := s.store.GetRun(ctx, req.RunId)\n\tif err == nil {\n\t\trun.Complete(domain.RunStateCancelled)\n\t\t_ = s.store.UpdateRun(ctx, run)\n\t}\n\n\treturn &pb.StopRunResponse{}, nil\n}\n\nfunc (s *ClocheServer) DeleteContainer(ctx context.Context, req *pb.DeleteContainerRequest) (*pb.DeleteContainerResponse, error) {\n\tif s.container == nil {\n\t\treturn nil, fmt.Errorf(\"no container runtime configured\")\n\t}\n\n\tid := req.Id\n\tif id == \"\" {\n\t\treturn nil, fmt.Errorf(\"id is required\")\n\t}\n\n\t// Try to resolve as a run ID first\n\tcontainerID := id\n\trun, err := s.store.GetRun(ctx, id)\n\tif err == nil {\n\t\t// It's a run ID â€” use the container ID from the run record\n\t\tif run.ContainerID == \"\" {\n\t\t\treturn nil, fmt.Errorf(\"run %q has no associated container\", id)\n\t\t}\n\t\tcontainerID = run.ContainerID\n\t}\n\n\t// Remove the container\n\tif err := s.container.Remove(ctx, containerID); err != nil {\n\t\treturn nil, fmt.Errorf(\"removing container: %w\", err)\n\t}\n\n\t// If we resolved a run, clear the container_kept flag\n\tif run != nil {\n\t\trun.ContainerKept = false\n\t\t_ = s.store.UpdateRun(ctx, run)\n\t}\n\n\treturn &pb.DeleteContainerResponse{}, nil\n}\n\nfunc (s *ClocheServer) Orchestrate(ctx context.Context, req *pb.OrchestrateRequest) (*pb.OrchestrateResponse, error) {\n\treturn nil, fmt.Errorf(\"orchestrator has been removed; use host workflow instead\")\n}\n\nfunc (s *ClocheServer) Shutdown(ctx context.Context, req *pb.ShutdownRequest) (*pb.ShutdownResponse, error) {\n\tif s.shutdownFn == nil {\n\t\treturn nil, fmt.Errorf(\"shutdown not configured\")\n\t}\n\tgo s.shutdownFn()\n\treturn &pb.ShutdownResponse{}, nil\n}\n\n// indexLogFiles scans the extracted output directory and creates log_files index entries.\nfunc (s *ClocheServer) indexLogFiles(ctx context.Context, runID, outputDir string) {\n\tentries, err := os.ReadDir(outputDir)\n\tif err != nil {\n\t\tlog.Printf(\"run %s: failed to read output dir for indexing: %v\", runID, err)\n\t\treturn\n\t}\n\n\tnow := time.Now()\n\tfor _, entry := range entries {\n\t\tif entry.IsDir() {\n\t\t\tcontinue\n\t\t}\n\t\tname := entry.Name()\n\t\tif !strings.HasSuffix(name, \".log\") {\n\t\t\tcontinue\n\t\t}\n\n\t\tvar fileType, stepName string\n\t\tbase := strings.TrimSuffix(name, \".log\")\n\n\t\tswitch {\n\t\tcase name == \"full.log\":\n\t\t\tfileType = \"full\"\n\t\tcase name == \"container.log\":\n\t\t\t// container.log is internal, not indexed as a user-facing log type\n\t\t\tcontinue\n\t\tcase strings.HasPrefix(name, \"llm-\"):\n\t\t\tfileType = \"llm\"\n\t\t\tstepName = strings.TrimPrefix(base, \"llm-\")\n\t\tdefault:\n\t\t\tfileType = \"script\"\n\t\t\tstepName = base\n\t\t}\n\n\t\tinfo, _ := entry.Info()\n\t\tvar fileSize int64\n\t\tif info != nil {\n\t\t\tfileSize = info.Size()\n\t\t}\n\n\t\tlogEntry := &ports.LogFileEntry{\n\t\t\tRunID:     runID,\n\t\t\tStepName:  stepName,\n\t\t\tFileType:  fileType,\n\t\t\tFilePath:  filepath.Join(outputDir, name),\n\t\t\tFileSize:  fileSize,\n\t\t\tCreatedAt: now,\n\t\t}\n\t\tif err := s.logStore.SaveLogFile(ctx, logEntry); err != nil {\n\t\t\tlog.Printf(\"run %s: failed to index log file %s: %v\", runID, name, err)\n\t\t}\n\t}\n}\n\nfunc gitHEAD(dir string) string {\n\tcmd := exec.Command(\"git\", \"rev-parse\", \"HEAD\")\n\tcmd.Dir = dir\n\tout, err := cmd.Output()\n\tif err != nil {\n\t\treturn \"\"\n\t}\n\treturn strings.TrimSpace(string(out))\n}\n","numLines":736,"startLine":1,"totalLines":736}}}
