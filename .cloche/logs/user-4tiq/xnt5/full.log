[2026-03-09T21:12:19Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01MhKxRU7YRxjYGmaFAS3CkQ","type":"tool_result","content":"     1â†’package engine_test\n     2â†’\n     3â†’import (\n     4â†’\t\"context\"\n     5â†’\t\"fmt\"\n     6â†’\t\"sync\"\n     7â†’\t\"testing\"\n     8â†’\t\"time\"\n     9â†’\n    10â†’\t\"github.com/cloche-dev/cloche/internal/domain\"\n    11â†’\t\"github.com/cloche-dev/cloche/internal/engine\"\n    12â†’\t\"github.com/stretchr/testify/assert\"\n    13â†’\t\"github.com/stretchr/testify/require\"\n    14â†’)\n    15â†’\n    16â†’type fakeExecutor struct {\n    17â†’\tmu      sync.Mutex\n    18â†’\tresults map[string]string\n    19â†’\tcalled  []string\n    20â†’}\n    21â†’\n    22â†’func (f *fakeExecutor) Execute(_ context.Context, step *domain.Step) (string, error) {\n    23â†’\tf.mu.Lock()\n    24â†’\tdefer f.mu.Unlock()\n    25â†’\tf.called = append(f.called, step.Name)\n    26â†’\treturn f.results[step.Name], nil\n    27â†’}\n    28â†’\n    29â†’func TestEngine_LinearWorkflow(t *testing.T) {\n    30â†’\twf := &domain.Workflow{\n    31â†’\t\tName: \"linear\",\n    32â†’\t\tSteps: map[string]*domain.Step{\n    33â†’\t\t\t\"build\": {Name: \"build\", Type: domain.StepTypeScript, Results: []string{\"success\"}},\n    34â†’\t\t\t\"test\":  {Name: \"test\", Type: domain.StepTypeScript, Results: []string{\"pass\"}},\n    35â†’\t\t},\n    36â†’\t\tWiring: []domain.Wire{\n    37â†’\t\t\t{From: \"build\", Result: \"success\", To: \"test\"},\n    38â†’\t\t\t{From: \"test\", Result: \"pass\", To: domain.StepDone},\n    39â†’\t\t},\n    40â†’\t\tEntryStep: \"build\",\n    41â†’\t}\n    42â†’\n    43â†’\texec := &fakeExecutor{results: map[string]string{\"build\": \"success\", \"test\": \"pass\"}}\n    44â†’\teng := engine.New(exec)\n    45â†’\n    46â†’\trun, err := eng.Run(context.Background(), wf)\n    47â†’\trequire.NoError(t, err)\n    48â†’\tassert.Equal(t, domain.RunStateSucceeded, run.State)\n    49â†’\tassert.Equal(t, []string{\"build\", \"test\"}, exec.called)\n    50â†’}\n    51â†’\n    52â†’func TestEngine_RetryLoop(t *testing.T) {\n    53â†’\twf := &domain.Workflow{\n    54â†’\t\tName: \"retry\",\n    55â†’\t\tSteps: map[string]*domain.Step{\n    56â†’\t\t\t\"code\":  {Name: \"code\", Type: domain.StepTypeAgent, Results: []string{\"success\", \"fail\"}},\n    57â†’\t\t\t\"check\": {Name: \"check\", Type: domain.StepTypeScript, Results: []string{\"pass\", \"fail\"}},\n    58â†’\t\t},\n    59â†’\t\tWiring: []domain.Wire{\n    60â†’\t\t\t{From: \"code\", Result: \"success\", To: \"check\"},\n    61â†’\t\t\t{From: \"code\", Result: \"fail\", To: domain.StepAbort},\n    62â†’\t\t\t{From: \"check\", Result: \"pass\", To: domain.StepDone},\n    63â†’\t\t\t{From: \"check\", Result: \"fail\", To: \"code\"},\n    64â†’\t\t},\n    65â†’\t\tEntryStep: \"code\",\n    66â†’\t}\n    67â†’\n    68â†’\tcallCount := 0\n    69â†’\tdynamicExec := engine.StepExecutorFunc(func(_ context.Context, step *domain.Step) (string, error) {\n    70â†’\t\tcallCount++\n    71â†’\t\tif step.Name == \"check\" && callCount <= 2 {\n    72â†’\t\t\treturn \"fail\", nil\n    73â†’\t\t}\n    74â†’\t\tif step.Name == \"code\" {\n    75â†’\t\t\treturn \"success\", nil\n    76â†’\t\t}\n    77â†’\t\treturn \"pass\", nil\n    78â†’\t})\n    79â†’\n    80â†’\teng := engine.New(dynamicExec)\n    81â†’\trun, err := eng.Run(context.Background(), wf)\n    82â†’\trequire.NoError(t, err)\n    83â†’\tassert.Equal(t, domain.RunStateSucceeded, run.State)\n    84â†’}\n    85â†’\n    86â†’func TestEngine_Abort(t *testing.T) {\n    87â†’\twf := &domain.Workflow{\n    88â†’\t\tName: \"abort-test\",\n    89â†’\t\tSteps: map[string]*domain.Step{\n    90â†’\t\t\t\"code\": {Name: \"code\", Type: domain.StepTypeAgent, Results: []string{\"success\", \"fail\"}},\n    91â†’\t\t},\n    92â†’\t\tWiring: []domain.Wire{\n    93â†’\t\t\t{From: \"code\", Result: \"success\", To: domain.StepDone},\n    94â†’\t\t\t{From: \"code\", Result: \"fail\", To: domain.StepAbort},\n    95â†’\t\t},\n    96â†’\t\tEntryStep: \"code\",\n    97â†’\t}\n    98â†’\n    99â†’\texec := &fakeExecutor{results: map[string]string{\"code\": \"fail\"}}\n   100â†’\teng := engine.New(exec)\n   101â†’\n   102â†’\trun, err := eng.Run(context.Background(), wf)\n   103â†’\trequire.NoError(t, err)\n   104â†’\tassert.Equal(t, domain.RunStateFailed, run.State)\n   105â†’}\n   106â†’\n   107â†’func TestEngine_ContextCancellation(t *testing.T) {\n   108â†’\twf := &domain.Workflow{\n   109â†’\t\tName: \"cancel-test\",\n   110â†’\t\tSteps: map[string]*domain.Step{\n   111â†’\t\t\t\"slow\": {Name: \"slow\", Type: domain.StepTypeScript, Results: []string{\"done\"}},\n   112â†’\t\t},\n   113â†’\t\tWiring: []domain.Wire{\n   114â†’\t\t\t{From: \"slow\", Result: \"done\", To: domain.StepDone},\n   115â†’\t\t},\n   116â†’\t\tEntryStep: \"slow\",\n   117â†’\t}\n   118â†’\n   119â†’\tctx, cancel := context.WithCancel(context.Background())\n   120â†’\tcancel()\n   121â†’\n   122â†’\texec := &fakeExecutor{results: map[string]string{\"slow\": \"done\"}}\n   123â†’\teng := engine.New(exec)\n   124â†’\n   125â†’\trun, err := eng.Run(ctx, wf)\n   126â†’\trequire.Error(t, err)\n   127â†’\tassert.Equal(t, domain.RunStateCancelled, run.State)\n   128â†’}\n   129â†’\n   130â†’func TestEngine_Fanout(t *testing.T) {\n   131â†’\twf := &domain.Workflow{\n   132â†’\t\tName: \"fanout\",\n   133â†’\t\tSteps: map[string]*domain.Step{\n   134â†’\t\t\t\"code\": {Name: \"code\", Type: domain.StepTypeAgent, Results: []string{\"success\"}},\n   135â†’\t\t\t\"test\": {Name: \"test\", Type: domain.StepTypeScript, Results: []string{\"success\"}},\n   136â†’\t\t\t\"lint\": {Name: \"lint\", Type: domain.StepTypeScript, Results: []string{\"success\"}},\n   137â†’\t\t},\n   138â†’\t\tWiring: []domain.Wire{\n   139â†’\t\t\t{From: \"code\", Result: \"success\", To: \"test\"},\n   140â†’\t\t\t{From: \"code\", Result: \"success\", To: \"lint\"},\n   141â†’\t\t\t{From: \"test\", Result: \"success\", To: domain.StepDone},\n   142â†’\t\t\t{From: \"lint\", Result: \"success\", To: domain.StepDone},\n   143â†’\t\t},\n   144â†’\t\tEntryStep: \"code\",\n   145â†’\t}\n   146â†’\n   147â†’\texec := &fakeExecutor{results: map[string]string{\n   148â†’\t\t\"code\": \"success\", \"test\": \"success\", \"lint\": \"success\",\n   149â†’\t}}\n   150â†’\teng := engine.New(exec)\n   151â†’\n   152â†’\trun, err := eng.Run(context.Background(), wf)\n   153â†’\trequire.NoError(t, err)\n   154â†’\tassert.Equal(t, domain.RunStateSucceeded, run.State)\n   155â†’\t// All three steps must have been called\n   156â†’\texec.mu.Lock()\n   157â†’\tassert.Contains(t, exec.called, \"code\")\n   158â†’\tassert.Contains(t, exec.called, \"test\")\n   159â†’\tassert.Contains(t, exec.called, \"lint\")\n   160â†’\texec.mu.Unlock()\n   161â†’}\n   162â†’\n   163â†’func TestEngine_CollectAll(t *testing.T) {\n   164â†’\twf := &domain.Workflow{\n   165â†’\t\tName: \"collect-all\",\n   166â†’\t\tSteps: map[string]*domain.Step{\n   167â†’\t\t\t\"code\":  {Name: \"code\", Type: domain.StepTypeAgent, Results: []string{\"success\"}},\n   168â†’\t\t\t\"test\":  {Name: \"test\", Type: domain.StepTypeScript, Results: []string{\"success\"}},\n   169â†’\t\t\t\"lint\":  {Name: \"lint\", Type: domain.StepTypeScript, Results: []string{\"success\"}},\n   170â†’\t\t\t\"merge\": {Name: \"merge\", Type: domain.StepTypeScript, Results: []string{\"success\"}},\n   171â†’\t\t},\n   172â†’\t\tWiring: []domain.Wire{\n   173â†’\t\t\t{From: \"code\", Result: \"success\", To: \"test\"},\n   174â†’\t\t\t{From: \"code\", Result: \"success\", To: \"lint\"},\n   175â†’\t\t\t{From: \"merge\", Result: \"success\", To: domain.StepDone},\n   176â†’\t\t},\n   177â†’\t\tCollects: []domain.Collect{\n   178â†’\t\t\t{\n   179â†’\t\t\t\tMode: domain.CollectAll,\n   180â†’\t\t\t\tConditions: []domain.WireCondition{\n   181â†’\t\t\t\t\t{Step: \"test\", Result: \"success\"},\n   182â†’\t\t\t\t\t{Step: \"lint\", Result: \"success\"},\n   183â†’\t\t\t\t},\n   184â†’\t\t\t\tTo: \"merge\",\n   185â†’\t\t\t},\n   186â†’\t\t},\n   187â†’\t\tEntryStep: \"code\",\n   188â†’\t}\n   189â†’\n   190â†’\texec := &fakeExecutor{results: map[string]string{\n   191â†’\t\t\"code\": \"success\", \"test\": \"success\", \"lint\": \"success\", \"merge\": \"success\",\n   192â†’\t}}\n   193â†’\teng := engine.New(exec)\n   194â†’\n   195â†’\trun, err := eng.Run(context.Background(), wf)\n   196â†’\trequire.NoError(t, err)\n   197â†’\tassert.Equal(t, domain.RunStateSucceeded, run.State)\n   198â†’\texec.mu.Lock()\n   199â†’\tassert.Contains(t, exec.called, \"merge\")\n   200â†’\texec.mu.Unlock()\n   201â†’}\n   202â†’\n   203â†’func TestEngine_CollectAny(t *testing.T) {\n   204â†’\twf := &domain.Workflow{\n   205â†’\t\tName: \"collect-any\",\n   206â†’\t\tSteps: map[string]*domain.Step{\n   207â†’\t\t\t\"code\":  {Name: \"code\", Type: domain.StepTypeAgent, Results: []string{\"success\"}},\n   208â†’\t\t\t\"test\":  {Name: \"test\", Type: domain.StepTypeScript, Results: []string{\"success\"}},\n   209â†’\t\t\t\"lint\":  {Name: \"lint\", Type: domain.StepTypeScript, Results: []string{\"success\"}},\n   210â†’\t\t\t\"quick\": {Name: \"quick\", Type: domain.StepTypeScript, Results: []string{\"success\"}},\n   211â†’\t\t},\n   212â†’\t\tWiring: []domain.Wire{\n   213â†’\t\t\t{From: \"code\", Result: \"success\", To: \"test\"},\n   214â†’\t\t\t{From: \"code\", Result: \"success\", To: \"lint\"},\n   215â†’\t\t\t{From: \"test\", Result: \"success\", To: domain.StepDone},\n   216â†’\t\t\t{From: \"lint\", Result: \"success\", To: domain.StepDone},\n   217â†’\t\t\t{From: \"quick\", Result: \"success\", To: domain.StepDone},\n   218â†’\t\t},\n   219â†’\t\tCollects: []domain.Collect{\n   220â†’\t\t\t{\n   221â†’\t\t\t\tMode: domain.CollectAny,\n   222â†’\t\t\t\tConditions: []domain.WireCondition{\n   223â†’\t\t\t\t\t{Step: \"test\", Result: \"success\"},\n   224â†’\t\t\t\t\t{Step: \"lint\", Result: \"success\"},\n   225â†’\t\t\t\t},\n   226â†’\t\t\t\tTo: \"quick\",\n   227â†’\t\t\t},\n   228â†’\t\t},\n   229â†’\t\tEntryStep: \"code\",\n   230â†’\t}\n   231â†’\n   232â†’\texec := &fakeExecutor{results: map[string]string{\n   233â†’\t\t\"code\": \"success\", \"test\": \"success\", \"lint\": \"success\", \"quick\": \"success\",\n   234â†’\t}}\n   235â†’\teng := engine.New(exec)\n   236â†’\n   237â†’\trun, err := eng.Run(context.Background(), wf)\n   238â†’\trequire.NoError(t, err)\n   239â†’\tassert.Equal(t, domain.RunStateSucceeded, run.State)\n   240â†’\texec.mu.Lock()\n   241â†’\tassert.Contains(t, exec.called, \"quick\")\n   242â†’\texec.mu.Unlock()\n   243â†’}\n   244â†’\n   245â†’func TestEngine_UndeclaredResultAborts(t *testing.T) {\n   246â†’\twf := &domain.Workflow{\n   247â†’\t\tName: \"undeclared\",\n   248â†’\t\tSteps: map[string]*domain.Step{\n   249â†’\t\t\t\"code\": {Name: \"code\", Type: domain.StepTypeAgent, Results: []string{\"success\", \"fail\"}},\n   250â†’\t\t},\n   251â†’\t\tWiring: []domain.Wire{\n   252â†’\t\t\t{From: \"code\", Result: \"success\", To: domain.StepDone},\n   253â†’\t\t\t{From: \"code\", Result: \"fail\", To: domain.StepAbort},\n   254â†’\t\t},\n   255â†’\t\tEntryStep: \"code\",\n   256â†’\t}\n   257â†’\n   258â†’\texec := &fakeExecutor{results: map[string]string{\"code\": \"unknown\"}}\n   259â†’\teng := engine.New(exec)\n   260â†’\n   261â†’\trun, err := eng.Run(context.Background(), wf)\n   262â†’\trequire.Error(t, err)\n   263â†’\tassert.Equal(t, domain.RunStateFailed, run.State)\n   264â†’\tassert.Contains(t, err.Error(), \"undeclared\")\n   265â†’}\n   266â†’\n   267â†’// slowExecutor blocks until the context is cancelled, simulating a hanging agent.\n   268â†’type slowExecutor struct {\n   269â†’\tmu     sync.Mutex\n   270â†’\tcalled []string\n   271â†’}\n   272â†’\n   273â†’func (s *slowExecutor) Execute(ctx context.Context, step *domain.Step) (string, error) {\n   274â†’\ts.mu.Lock()\n   275â†’\ts.called = append(s.called, step.Name)\n   276â†’\ts.mu.Unlock()\n   277â†’\t<-ctx.Done()\n   278â†’\treturn \"\", fmt.Errorf(\"step %q timed out: %w\", step.Name, ctx.Err())\n   279â†’}\n   280â†’\n   281â†’func TestEngine_StepTimeout(t *testing.T) {\n   282â†’\twf := &domain.Workflow{\n   283â†’\t\tName: \"timeout-test\",\n   284â†’\t\tSteps: map[string]*domain.Step{\n   285â†’\t\t\t\"hang\": {\n   286â†’\t\t\t\tName:    \"hang\",\n   287â†’\t\t\t\tType:    domain.StepTypeAgent,\n   288â†’\t\t\t\tResults: []string{\"success\", \"fail\"},\n   289â†’\t\t\t\tConfig:  map[string]string{\"prompt\": \"do stuff\", \"timeout\": \"100ms\"},\n   290â†’\t\t\t},\n   291â†’\t\t},\n   292â†’\t\tWiring: []domain.Wire{\n   293â†’\t\t\t{From: \"hang\", Result: \"success\", To: domain.StepDone},\n   294â†’\t\t\t{From: \"hang\", Result: \"fail\", To: domain.StepAbort},\n   295â†’\t\t},\n   296â†’\t\tEntryStep: \"hang\",\n   297â†’\t}\n   298â†’\n   299â†’\texec := &slowExecutor{}\n   300â†’\teng := engine.New(exec)\n   301â†’\n   302â†’\tstart := time.Now()\n   303â†’\trun, err := eng.Run(context.Background(), wf)\n   304â†’\telapsed := time.Since(start)\n   305â†’\n   306â†’\trequire.Error(t, err)\n   307â†’\tassert.Equal(t, domain.RunStateFailed, run.State)\n   308â†’\tassert.Contains(t, err.Error(), \"timed out\")\n   309â†’\tassert.Less(t, elapsed, 5*time.Second, \"timeout should fire quickly, not wait for default 30m\")\n   310â†’}\n   311â†’\n   312â†’func TestEngine_StepTimeoutOverridesDefault(t *testing.T) {\n   313â†’\twf := &domain.Workflow{\n   314â†’\t\tName: \"timeout-override\",\n   315â†’\t\tSteps: map[string]*domain.Step{\n   316â†’\t\t\t\"hang\": {\n   317â†’\t\t\t\tName:    \"hang\",\n   318â†’\t\t\t\tType:    domain.StepTypeAgent,\n   319â†’\t\t\t\tResults: []string{\"success\", \"fail\"},\n   320â†’\t\t\t\tConfig:  map[string]string{\"prompt\": \"do stuff\"}, // no per-step timeout\n   321â†’\t\t\t},\n   322â†’\t\t},\n   323â†’\t\tWiring: []domain.Wire{\n   324â†’\t\t\t{From: \"hang\", Result: \"success\", To: domain.StepDone},\n   325â†’\t\t\t{From: \"hang\", Result: \"fail\", To: domain.StepAbort},\n   326â†’\t\t},\n   327â†’\t\tEntryStep: \"hang\",\n   328â†’\t}\n   329â†’\n   330â†’\texec := &slowExecutor{}\n   331â†’\teng := engine.New(exec)\n   332â†’\teng.SetDefaultTimeout(100 * time.Millisecond)\n   333â†’\n   334â†’\tstart := time.Now()\n   335â†’\trun, err := eng.Run(context.Background(), wf)\n   336â†’\telapsed := time.Since(start)\n   337â†’\n   338â†’\trequire.Error(t, err)\n   339â†’\tassert.Equal(t, domain.RunStateFailed, run.State)\n   340â†’\tassert.Less(t, elapsed, 5*time.Second, \"default timeout should fire quickly\")\n   341â†’}\n   342â†’"}]},"parent_tool_use_id":null,"session_id":"c6864ddb-8a62-468e-9371-23940235ec7e","uuid":"40497099-81ac-4c26-aae1-0dc2e1547891","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/engine/engine_test.go","content":"package engine_test\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"sync\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/engine\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n)\n\ntype fakeExecutor struct {\n\tmu      sync.Mutex\n\tresults map[string]string\n\tcalled  []string\n}\n\nfunc (f *fakeExecutor) Execute(_ context.Context, step *domain.Step) (string, error) {\n\tf.mu.Lock()\n\tdefer f.mu.Unlock()\n\tf.called = append(f.called, step.Name)\n\treturn f.results[step.Name], nil\n}\n\nfunc TestEngine_LinearWorkflow(t *testing.T) {\n\twf := &domain.Workflow{\n\t\tName: \"linear\",\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"build\": {Name: \"build\", Type: domain.StepTypeScript, Results: []string{\"success\"}},\n\t\t\t\"test\":  {Name: \"test\", Type: domain.StepTypeScript, Results: []string{\"pass\"}},\n\t\t},\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"build\", Result: \"success\", To: \"test\"},\n\t\t\t{From: \"test\", Result: \"pass\", To: domain.StepDone},\n\t\t},\n\t\tEntryStep: \"build\",\n\t}\n\n\texec := &fakeExecutor{results: map[string]string{\"build\": \"success\", \"test\": \"pass\"}}\n\teng := engine.New(exec)\n\n\trun, err := eng.Run(context.Background(), wf)\n\trequire.NoError(t, err)\n\tassert.Equal(t, domain.RunStateSucceeded, run.State)\n\tassert.Equal(t, []string{\"build\", \"test\"}, exec.called)\n}\n\nfunc TestEngine_RetryLoop(t *testing.T) {\n\twf := &domain.Workflow{\n\t\tName: \"retry\",\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"code\":  {Name: \"code\", Type: domain.StepTypeAgent, Results: []string{\"success\", \"fail\"}},\n\t\t\t\"check\": {Name: \"check\", Type: domain.StepTypeScript, Results: []string{\"pass\", \"fail\"}},\n\t\t},\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"code\", Result: \"success\", To: \"check\"},\n\t\t\t{From: \"code\", Result: \"fail\", To: domain.StepAbort},\n\t\t\t{From: \"check\", Result: \"pass\", To: domain.StepDone},\n\t\t\t{From: \"check\", Result: \"fail\", To: \"code\"},\n\t\t},\n\t\tEntryStep: \"code\",\n\t}\n\n\tcallCount := 0\n\tdynamicExec := engine.StepExecutorFunc(func(_ context.Context, step *domain.Step) (string, error) {\n\t\tcallCount++\n\t\tif step.Name == \"check\" && callCount <= 2 {\n\t\t\treturn \"fail\", nil\n\t\t}\n\t\tif step.Name == \"code\" {\n\t\t\treturn \"success\", nil\n\t\t}\n\t\treturn \"pass\", nil\n\t})\n\n\teng := engine.New(dynamicExec)\n\trun, err := eng.Run(context.Background(), wf)\n\trequire.NoError(t, err)\n\tassert.Equal(t, domain.RunStateSucceeded, run.State)\n}\n\nfunc TestEngine_Abort(t *testing.T) {\n\twf := &domain.Workflow{\n\t\tName: \"abort-test\",\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"code\": {Name: \"code\", Type: domain.StepTypeAgent, Results: []string{\"success\", \"fail\"}},\n\t\t},\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"code\", Result: \"success\", To: domain.StepDone},\n\t\t\t{From: \"code\", Result: \"fail\", To: domain.StepAbort},\n\t\t},\n\t\tEntryStep: \"code\",\n\t}\n\n\texec := &fakeExecutor{results: map[string]string{\"code\": \"fail\"}}\n\teng := engine.New(exec)\n\n\trun, err := eng.Run(context.Background(), wf)\n\trequire.NoError(t, err)\n\tassert.Equal(t, domain.RunStateFailed, run.State)\n}\n\nfunc TestEngine_ContextCancellation(t *testing.T) {\n\twf := &domain.Workflow{\n\t\tName: \"cancel-test\",\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"slow\": {Name: \"slow\", Type: domain.StepTypeScript, Results: []string{\"done\"}},\n\t\t},\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"slow\", Result: \"done\", To: domain.StepDone},\n\t\t},\n\t\tEntryStep: \"slow\",\n\t}\n\n\tctx, cancel := context.WithCancel(context.Background())\n\tcancel()\n\n\texec := &fakeExecutor{results: map[string]string{\"slow\": \"done\"}}\n\teng := engine.New(exec)\n\n\trun, err := eng.Run(ctx, wf)\n\trequire.Error(t, err)\n\tassert.Equal(t, domain.RunStateCancelled, run.State)\n}\n\nfunc TestEngine_Fanout(t *testing.T) {\n\twf := &domain.Workflow{\n\t\tName: \"fanout\",\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"code\": {Name: \"code\", Type: domain.StepTypeAgent, Results: []string{\"success\"}},\n\t\t\t\"test\": {Name: \"test\", Type: domain.StepTypeScript, Results: []string{\"success\"}},\n\t\t\t\"lint\": {Name: \"lint\", Type: domain.StepTypeScript, Results: []string{\"success\"}},\n\t\t},\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"code\", Result: \"success\", To: \"test\"},\n\t\t\t{From: \"code\", Result: \"success\", To: \"lint\"},\n\t\t\t{From: \"test\", Result: \"success\", To: domain.StepDone},\n\t\t\t{From: \"lint\", Result: \"success\", To: domain.StepDone},\n\t\t},\n\t\tEntryStep: \"code\",\n\t}\n\n\texec := &fakeExecutor{results: map[string]string{\n\t\t\"code\": \"success\", \"test\": \"success\", \"lint\": \"success\",\n\t}}\n\teng := engine.New(exec)\n\n\trun, err := eng.Run(context.Background(), wf)\n\trequire.NoError(t, err)\n\tassert.Equal(t, domain.RunStateSucceeded, run.State)\n\t// All three steps must have been called\n\texec.mu.Lock()\n\tassert.Contains(t, exec.called, \"code\")\n\tassert.Contains(t, exec.called, \"test\")\n\tassert.Contains(t, exec.called, \"lint\")\n\texec.mu.Unlock()\n}\n\nfunc TestEngine_CollectAll(t *testing.T) {\n\twf := &domain.Workflow{\n\t\tName: \"collect-all\",\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"code\":  {Name: \"code\", Type: domain.StepTypeAgent, Results: []string{\"success\"}},\n\t\t\t\"test\":  {Name: \"test\", Type: domain.StepTypeScript, Results: []string{\"success\"}},\n\t\t\t\"lint\":  {Name: \"lint\", Type: domain.StepTypeScript, Results: []string{\"success\"}},\n\t\t\t\"merge\": {Name: \"merge\", Type: domain.StepTypeScript, Results: []string{\"success\"}},\n\t\t},\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"code\", Result: \"success\", To: \"test\"},\n\t\t\t{From: \"code\", Result: \"success\", To: \"lint\"},\n\t\t\t{From: \"merge\", Result: \"success\", To: domain.StepDone},\n\t\t},\n\t\tCollects: []domain.Collect{\n\t\t\t{\n\t\t\t\tMode: domain.CollectAll,\n\t\t\t\tConditions: []domain.WireCondition{\n\t\t\t\t\t{Step: \"test\", Result: \"success\"},\n\t\t\t\t\t{Step: \"lint\", Result: \"success\"},\n\t\t\t\t},\n\t\t\t\tTo: \"merge\",\n\t\t\t},\n\t\t},\n\t\tEntryStep: \"code\",\n\t}\n\n\texec := &fakeExecutor{results: map[string]string{\n\t\t\"code\": \"success\", \"test\": \"success\", \"lint\": \"success\", \"merge\": \"success\",\n\t}}\n\teng := engine.New(exec)\n\n\trun, err := eng.Run(context.Background(), wf)\n\trequire.NoError(t, err)\n\tassert.Equal(t, domain.RunStateSucceeded, run.State)\n\texec.mu.Lock()\n\tassert.Contains(t, exec.called, \"merge\")\n\texec.mu.Unlock()\n}\n\nfunc TestEngine_CollectAny(t *testing.T) {\n\twf := &domain.Workflow{\n\t\tName: \"collect-any\",\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"code\":  {Name: \"code\", Type: domain.StepTypeAgent, Results: []string{\"success\"}},\n\t\t\t\"test\":  {Name: \"test\", Type: domain.StepTypeScript, Results: []string{\"success\"}},\n\t\t\t\"lint\":  {Name: \"lint\", Type: domain.StepTypeScript, Results: []string{\"success\"}},\n\t\t\t\"quick\": {Name: \"quick\", Type: domain.StepTypeScript, Results: []string{\"success\"}},\n\t\t},\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"code\", Result: \"success\", To: \"test\"},\n\t\t\t{From: \"code\", Result: \"success\", To: \"lint\"},\n\t\t\t{From: \"test\", Result: \"success\", To: domain.StepDone},\n\t\t\t{From: \"lint\", Result: \"success\", To: domain.StepDone},\n\t\t\t{From: \"quick\", Result: \"success\", To: domain.StepDone},\n\t\t},\n\t\tCollects: []domain.Collect{\n\t\t\t{\n\t\t\t\tMode: domain.CollectAny,\n\t\t\t\tConditions: []domain.WireCondition{\n\t\t\t\t\t{Step: \"test\", Result: \"success\"},\n\t\t\t\t\t{Step: \"lint\", Result: \"success\"},\n\t\t\t\t},\n\t\t\t\tTo: \"quick\",\n\t\t\t},\n\t\t},\n\t\tEntryStep: \"code\",\n\t}\n\n\texec := &fakeExecutor{results: map[string]string{\n\t\t\"code\": \"success\", \"test\": \"success\", \"lint\": \"success\", \"quick\": \"success\",\n\t}}\n\teng := engine.New(exec)\n\n\trun, err := eng.Run(context.Background(), wf)\n\trequire.NoError(t, err)\n\tassert.Equal(t, domain.RunStateSucceeded, run.State)\n\texec.mu.Lock()\n\tassert.Contains(t, exec.called, \"quick\")\n\texec.mu.Unlock()\n}\n\nfunc TestEngine_UndeclaredResultAborts(t *testing.T) {\n\twf := &domain.Workflow{\n\t\tName: \"undeclared\",\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"code\": {Name: \"code\", Type: domain.StepTypeAgent, Results: []string{\"success\", \"fail\"}},\n\t\t},\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"code\", Result: \"success\", To: domain.StepDone},\n\t\t\t{From: \"code\", Result: \"fail\", To: domain.StepAbort},\n\t\t},\n\t\tEntryStep: \"code\",\n\t}\n\n\texec := &fakeExecutor{results: map[string]string{\"code\": \"unknown\"}}\n\teng := engine.New(exec)\n\n\trun, err := eng.Run(context.Background(), wf)\n\trequire.Error(t, err)\n\tassert.Equal(t, domain.RunStateFailed, run.State)\n\tassert.Contains(t, err.Error(), \"undeclared\")\n}\n\n// slowExecutor blocks until the context is cancelled, simulating a hanging agent.\ntype slowExecutor struct {\n\tmu     sync.Mutex\n\tcalled []string\n}\n\nfunc (s *slowExecutor) Execute(ctx context.Context, step *domain.Step) (string, error) {\n\ts.mu.Lock()\n\ts.called = append(s.called, step.Name)\n\ts.mu.Unlock()\n\t<-ctx.Done()\n\treturn \"\", fmt.Errorf(\"step %q timed out: %w\", step.Name, ctx.Err())\n}\n\nfunc TestEngine_StepTimeout(t *testing.T) {\n\twf := &domain.Workflow{\n\t\tName: \"timeout-test\",\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"hang\": {\n\t\t\t\tName:    \"hang\",\n\t\t\t\tType:    domain.StepTypeAgent,\n\t\t\t\tResults: []string{\"success\", \"fail\"},\n\t\t\t\tConfig:  map[string]string{\"prompt\": \"do stuff\", \"timeout\": \"100ms\"},\n\t\t\t},\n\t\t},\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"hang\", Result: \"success\", To: domain.StepDone},\n\t\t\t{From: \"hang\", Result: \"fail\", To: domain.StepAbort},\n\t\t},\n\t\tEntryStep: \"hang\",\n\t}\n\n\texec := &slowExecutor{}\n\teng := engine.New(exec)\n\n\tstart := time.Now()\n\trun, err := eng.Run(context.Background(), wf)\n\telapsed := time.Since(start)\n\n\trequire.Error(t, err)\n\tassert.Equal(t, domain.RunStateFailed, run.State)\n\tassert.Contains(t, err.Error(), \"timed out\")\n\tassert.Less(t, elapsed, 5*time.Second, \"timeout should fire quickly, not wait for default 30m\")\n}\n\nfunc TestEngine_StepTimeoutOverridesDefault(t *testing.T) {\n\twf := &domain.Workflow{\n\t\tName: \"timeout-override\",\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"hang\": {\n\t\t\t\tName:    \"hang\",\n\t\t\t\tType:    domain.StepTypeAgent,\n\t\t\t\tResults: []string{\"success\", \"fail\"},\n\t\t\t\tConfig:  map[string]string{\"prompt\": \"do stuff\"}, // no per-step timeout\n\t\t\t},\n\t\t},\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"hang\", Result: \"success\", To: domain.StepDone},\n\t\t\t{From: \"hang\", Result: \"fail\", To: domain.StepAbort},\n\t\t},\n\t\tEntryStep: \"hang\",\n\t}\n\n\texec := &slowExecutor{}\n\teng := engine.New(exec)\n\teng.SetDefaultTimeout(100 * time.Millisecond)\n\n\tstart := time.Now()\n\trun, err := eng.Run(context.Background(), wf)\n\telapsed := time.Since(start)\n\n\trequire.Error(t, err)\n\tassert.Equal(t, domain.RunStateFailed, run.State)\n\tassert.Less(t, elapsed, 5*time.Second, \"default timeout should fire quickly\")\n}\n","numLines":342,"startLine":1,"totalLines":342}}}
