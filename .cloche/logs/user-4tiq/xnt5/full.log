[2026-03-09T21:12:19Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KiPK7xTQ3osEdHCFsRRNg7","type":"tool_result","content":"     1â†’package engine\n     2â†’\n     3â†’import (\n     4â†’\t\"context\"\n     5â†’\t\"fmt\"\n     6â†’\t\"log\"\n     7â†’\t\"sync\"\n     8â†’\t\"time\"\n     9â†’\n    10â†’\t\"github.com/cloche-dev/cloche/internal/domain\"\n    11â†’)\n    12â†’\n    13â†’const DefaultStepTimeout = 30 * time.Minute\n    14â†’\n    15â†’// StepExecutor executes a single step and returns the result name.\n    16â†’type StepExecutor interface {\n    17â†’\tExecute(ctx context.Context, step *domain.Step) (string, error)\n    18â†’}\n    19â†’\n    20â†’// StepExecutorFunc adapts a function to the StepExecutor interface.\n    21â†’type StepExecutorFunc func(ctx context.Context, step *domain.Step) (string, error)\n    22â†’\n    23â†’func (f StepExecutorFunc) Execute(ctx context.Context, step *domain.Step) (string, error) {\n    24â†’\treturn f(ctx, step)\n    25â†’}\n    26â†’\n    27â†’// StatusHandler receives notifications about workflow execution progress.\n    28â†’type StatusHandler interface {\n    29â†’\tOnStepStart(run *domain.Run, step *domain.Step)\n    30â†’\tOnStepComplete(run *domain.Run, step *domain.Step, result string)\n    31â†’\tOnRunComplete(run *domain.Run)\n    32â†’}\n    33â†’\n    34â†’type noopStatus struct{}\n    35â†’\n    36â†’func (noopStatus) OnStepStart(*domain.Run, *domain.Step)            {}\n    37â†’func (noopStatus) OnStepComplete(*domain.Run, *domain.Step, string) {}\n    38â†’func (noopStatus) OnRunComplete(*domain.Run)                        {}\n    39â†’\n    40â†’type Engine struct {\n    41â†’\texecutor       StepExecutor\n    42â†’\tstatus         StatusHandler\n    43â†’\tmaxSteps       int\n    44â†’\tdefaultTimeout time.Duration\n    45â†’}\n    46â†’\n    47â†’func New(executor StepExecutor) *Engine {\n    48â†’\treturn &Engine{\n    49â†’\t\texecutor:       executor,\n    50â†’\t\tstatus:         noopStatus{},\n    51â†’\t\tmaxSteps:       1000,\n    52â†’\t\tdefaultTimeout: DefaultStepTimeout,\n    53â†’\t}\n    54â†’}\n    55â†’\n    56â†’func (e *Engine) SetStatusHandler(h StatusHandler) {\n    57â†’\te.status = h\n    58â†’}\n    59â†’\n    60â†’func (e *Engine) SetMaxSteps(n int) {\n    61â†’\te.maxSteps = n\n    62â†’}\n    63â†’\n    64â†’// SetDefaultTimeout sets the default timeout for steps that don't specify one.\n    65â†’func (e *Engine) SetDefaultTimeout(d time.Duration) {\n    66â†’\te.defaultTimeout = d\n    67â†’}\n    68â†’\n    69â†’// stepResult is sent from worker goroutines back to the main event loop.\n    70â†’type stepResult struct {\n    71â†’\tstepName string\n    72â†’\tresult   string\n    73â†’\terr      error\n    74â†’}\n    75â†’\n    76â†’// collectState tracks the satisfaction state of a single Collect clause.\n    77â†’type collectState struct {\n    78â†’\tcollect   *domain.Collect\n    79â†’\tsatisfied map[int]bool\n    80â†’\tfired     bool\n    81â†’}\n    82â†’\n    83â†’func (e *Engine) Run(ctx context.Context, wf *domain.Workflow) (*domain.Run, error) {\n    84â†’\tif err := wf.Validate(); err != nil {\n    85â†’\t\treturn nil, fmt.Errorf(\"invalid workflow: %w\", err)\n    86â†’\t}\n    87â†’\tfor _, w := range wf.ValidateConfig() {\n    88â†’\t\tlog.Printf(\"WARNING: %s\", w)\n    89â†’\t}\n    90â†’\n    91â†’\trun := domain.NewRun(generateRunID(), wf.Name)\n    92â†’\trun.Start()\n    93â†’\n    94â†’\t// Check context cancellation before starting.\n    95â†’\tif err := ctx.Err(); err != nil {\n    96â†’\t\trun.Complete(domain.RunStateCancelled)\n    97â†’\t\treturn run, fmt.Errorf(\"workflow cancelled: %w\", err)\n    98â†’\t}\n    99â†’\n   100â†’\t// Build a set of (step, result) pairs that are handled by collects,\n   101â†’\t// so we know when a missing wire is acceptable.\n   102â†’\tcollectHandled := make(map[string]map[string]bool)\n   103â†’\tfor _, c := range wf.Collects {\n   104â†’\t\tfor _, cond := range c.Conditions {\n   105â†’\t\t\tif collectHandled[cond.Step] == nil {\n   106â†’\t\t\t\tcollectHandled[cond.Step] = make(map[string]bool)\n   107â†’\t\t\t}\n   108â†’\t\t\tcollectHandled[cond.Step][cond.Result] = true\n   109â†’\t\t}\n   110â†’\t}\n   111â†’\n   112â†’\t// Initialize collect states.\n   113â†’\tcStates := make([]*collectState, len(wf.Collects))\n   114â†’\tfor i := range wf.Collects {\n   115â†’\t\tcStates[i] = &collectState{\n   116â†’\t\t\tcollect:   &wf.Collects[i],\n   117â†’\t\t\tsatisfied: make(map[int]bool),\n   118â†’\t\t}\n   119â†’\t}\n   120â†’\n   121â†’\tresults := make(chan stepResult, e.maxSteps)\n   122â†’\tactiveCount := 0\n   123â†’\tstepCount := 0\n   124â†’\tdoneCount := 0\n   125â†’\taborted := false\n   126â†’\tvar runErr error\n   127â†’\n   128â†’\t// Use a mutex to protect run state from concurrent goroutine access.\n   129â†’\t// Only the main loop should touch the Run, but we record step start before\n   130â†’\t// launching the goroutine, so this is safe without a mutex for now.\n   131â†’\t// The goroutines only read the step and send on the channel.\n   132â†’\n   133â†’\tlaunchStep := func(stepName string) error {\n   134â†’\t\tstepCount++\n   135â†’\t\tif stepCount > e.maxSteps {\n   136â†’\t\t\treturn fmt.Errorf(\"workflow exceeded maximum step count (%d)\", e.maxSteps)\n   137â†’\t\t}\n   138â†’\n   139â†’\t\tstep, ok := wf.Steps[stepName]\n   140â†’\t\tif !ok {\n   141â†’\t\t\treturn fmt.Errorf(\"step %q not found in workflow\", stepName)\n   142â†’\t\t}\n   143â†’\n   144â†’\t\tactiveCount++\n   145â†’\t\trun.RecordStepStart(step.Name)\n   146â†’\t\te.status.OnStepStart(run, step)\n   147â†’\n   148â†’\t\tgo func(s *domain.Step) {\n   149â†’\t\t\tstepCtx := ctx\n   150â†’\t\t\tif d := stepTimeout(s, e.defaultTimeout); d > 0 {\n   151â†’\t\t\t\tvar cancel context.CancelFunc\n   152â†’\t\t\t\tstepCtx, cancel = context.WithTimeout(ctx, d)\n   153â†’\t\t\t\tdefer cancel()\n   154â†’\t\t\t}\n   155â†’\t\t\tresult, err := e.executor.Execute(stepCtx, s)\n   156â†’\t\t\tresults <- stepResult{stepName: s.Name, result: result, err: err}\n   157â†’\t\t}(step)\n   158â†’\n   159â†’\t\treturn nil\n   160â†’\t}\n   161â†’\n   162â†’\t// Launch entry step.\n   163â†’\tif err := launchStep(wf.EntryStep); err != nil {\n   164â†’\t\trun.Complete(domain.RunStateFailed)\n   165â†’\t\treturn run, err\n   166â†’\t}\n   167â†’\n   168â†’\t// Main event loop.\n   169â†’\tfor activeCount > 0 {\n   170â†’\t\tselect {\n   171â†’\t\tcase <-ctx.Done():\n   172â†’\t\t\trun.Complete(domain.RunStateCancelled)\n   173â†’\t\t\treturn run, fmt.Errorf(\"workflow cancelled: %w\", ctx.Err())\n   174â†’\n   175â†’\t\tcase sr := <-results:\n   176â†’\t\t\tactiveCount--\n   177â†’\n   178â†’\t\t\t// Step execution error.\n   179â†’\t\t\tif sr.err != nil {\n   180â†’\t\t\t\trun.RecordStepComplete(sr.stepName, \"error\")\n   181â†’\t\t\t\trun.Complete(domain.RunStateFailed)\n   182â†’\t\t\t\te.status.OnRunComplete(run)\n   183â†’\t\t\t\treturn run, fmt.Errorf(\"step %q execution failed: %w\", sr.stepName, sr.err)\n   184â†’\t\t\t}\n   185â†’\n   186â†’\t\t\t// Validate result is declared in the step's Results list.\n   187â†’\t\t\tstep := wf.Steps[sr.stepName]\n   188â†’\t\t\tif !isResultDeclared(step, sr.result) {\n   189â†’\t\t\t\trun.RecordStepComplete(sr.stepName, sr.result)\n   190â†’\t\t\t\trun.Complete(domain.RunStateFailed)\n   191â†’\t\t\t\te.status.OnRunComplete(run)\n   192â†’\t\t\t\treturn run, fmt.Errorf(\"step %q returned undeclared result %q\", sr.stepName, sr.result)\n   193â†’\t\t\t}\n   194â†’\n   195â†’\t\t\trun.RecordStepComplete(sr.stepName, sr.result)\n   196â†’\t\t\te.status.OnStepComplete(run, step, sr.result)\n   197â†’\n   198â†’\t\t\t// Process wiring: get next steps for this (step, result) pair.\n   199â†’\t\t\tnextSteps, wireErr := wf.NextSteps(sr.stepName, sr.result)\n   200â†’\t\t\tif wireErr != nil {\n   201â†’\t\t\t\t// No wire found. Check if any collect handles this (step, result).\n   202â†’\t\t\t\tif !collectHandled[sr.stepName][sr.result] {\n   203â†’\t\t\t\t\t// Neither wires nor collects handle this result.\n   204â†’\t\t\t\t\trun.Complete(domain.RunStateFailed)\n   205â†’\t\t\t\t\te.status.OnRunComplete(run)\n   206â†’\t\t\t\t\treturn run, wireErr\n   207â†’\t\t\t\t}\n   208â†’\t\t\t\t// Collect handles it; no wire targets to launch.\n   209â†’\t\t\t} else {\n   210â†’\t\t\t\t// Process wire targets.\n   211â†’\t\t\t\tfor _, target := range nextSteps {\n   212â†’\t\t\t\t\tswitch target {\n   213â†’\t\t\t\t\tcase domain.StepDone:\n   214â†’\t\t\t\t\t\tdoneCount++\n   215â†’\t\t\t\t\tcase domain.StepAbort:\n   216â†’\t\t\t\t\t\taborted = true\n   217â†’\t\t\t\t\tdefault:\n   218â†’\t\t\t\t\t\tif err := launchStep(target); err != nil {\n   219â†’\t\t\t\t\t\t\trun.Complete(domain.RunStateFailed)\n   220â†’\t\t\t\t\t\t\te.status.OnRunComplete(run)\n   221â†’\t\t\t\t\t\t\treturn run, err\n   222â†’\t\t\t\t\t\t}\n   223â†’\t\t\t\t\t}\n   224â†’\t\t\t\t}\n   225â†’\t\t\t}\n   226â†’\n   227â†’\t\t\t// Check and fire collect conditions.\n   228â†’\t\t\tfor _, cs := range cStates {\n   229â†’\t\t\t\tif cs.fired {\n   230â†’\t\t\t\t\tcontinue\n   231â†’\t\t\t\t}\n   232â†’\t\t\t\tfor i, cond := range cs.collect.Conditions {\n   233â†’\t\t\t\t\tif cond.Step == sr.stepName && cond.Result == sr.result {\n   234â†’\t\t\t\t\t\tcs.satisfied[i] = true\n   235â†’\t\t\t\t\t}\n   236â†’\t\t\t\t}\n   237â†’\n   238â†’\t\t\t\tshouldFire := false\n   239â†’\t\t\t\tswitch cs.collect.Mode {\n   240â†’\t\t\t\tcase domain.CollectAll:\n   241â†’\t\t\t\t\tshouldFire = len(cs.satisfied) == len(cs.collect.Conditions)\n   242â†’\t\t\t\tcase domain.CollectAny:\n   243â†’\t\t\t\t\tshouldFire = len(cs.satisfied) > 0\n   244â†’\t\t\t\t}\n   245â†’\n   246â†’\t\t\t\tif shouldFire {\n   247â†’\t\t\t\t\tcs.fired = true\n   248â†’\t\t\t\t\ttarget := cs.collect.To\n   249â†’\t\t\t\t\tswitch target {\n   250â†’\t\t\t\t\tcase domain.StepDone:\n   251â†’\t\t\t\t\t\tdoneCount++\n   252â†’\t\t\t\t\tcase domain.StepAbort:\n   253â†’\t\t\t\t\t\taborted = true\n   254â†’\t\t\t\t\tdefault:\n   255â†’\t\t\t\t\t\tif err := launchStep(target); err != nil {\n   256â†’\t\t\t\t\t\t\trun.Complete(domain.RunStateFailed)\n   257â†’\t\t\t\t\t\t\te.status.OnRunComplete(run)\n   258â†’\t\t\t\t\t\t\treturn run, err\n   259â†’\t\t\t\t\t\t}\n   260â†’\t\t\t\t\t}\n   261â†’\t\t\t\t}\n   262â†’\t\t\t}\n   263â†’\t\t}\n   264â†’\t}\n   265â†’\n   266â†’\t// Determine final state.\n   267â†’\tif aborted || runErr != nil {\n   268â†’\t\trun.Complete(domain.RunStateFailed)\n   269â†’\t} else if doneCount > 0 {\n   270â†’\t\trun.Complete(domain.RunStateSucceeded)\n   271â†’\t} else {\n   272â†’\t\trun.Complete(domain.RunStateFailed)\n   273â†’\t\trunErr = fmt.Errorf(\"workflow %q: no branches reached done\", wf.Name)\n   274â†’\t}\n   275â†’\n   276â†’\te.status.OnRunComplete(run)\n   277â†’\treturn run, runErr\n   278â†’}\n   279â†’\n   280â†’// isResultDeclared checks whether the given result is in the step's declared Results list.\n   281â†’func isResultDeclared(step *domain.Step, result string) bool {\n   282â†’\tfor _, r := range step.Results {\n   283â†’\t\tif r == result {\n   284â†’\t\t\treturn true\n   285â†’\t\t}\n   286â†’\t}\n   287â†’\treturn false\n   288â†’}\n   289â†’\n   290â†’var (\n   291â†’\trunCounter int\n   292â†’\trunMu      sync.Mutex\n   293â†’)\n   294â†’\n   295â†’func generateRunID() string {\n   296â†’\trunMu.Lock()\n   297â†’\tdefer runMu.Unlock()\n   298â†’\trunCounter++\n   299â†’\treturn fmt.Sprintf(\"run-%d\", runCounter)\n   300â†’}\n   301â†’\n   302â†’// stepTimeout returns the timeout for a step. It checks step.Config[\"timeout\"]\n   303â†’// first, falling back to the provided default.\n   304â†’func stepTimeout(step *domain.Step, defaultTimeout time.Duration) time.Duration {\n   305â†’\tif raw, ok := step.Config[\"timeout\"]; ok {\n   306â†’\t\tif d, err := time.ParseDuration(raw); err == nil {\n   307â†’\t\t\treturn d\n   308â†’\t\t}\n   309â†’\t}\n   310â†’\treturn defaultTimeout\n   311â†’}\n   312â†’"}]},"parent_tool_use_id":"toolu_01BwC3jW9U52qS7AfxsmW3Le","session_id":"c6864ddb-8a62-468e-9371-23940235ec7e","uuid":"27c16969-944f-45d2-9cbc-4ea666d89fa2"}
