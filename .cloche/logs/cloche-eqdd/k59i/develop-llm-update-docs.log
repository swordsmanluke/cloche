{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01ERLqBzwAp7xUVe3bw9Wxff","type":"tool_result","content":"     1→package main\n     2→\n     3→import (\n     4→\t\"strings\"\n     5→\t\"testing\"\n     6→)\n     7→\n     8→func TestHasHelpFlag(t *testing.T) {\n     9→\ttests := []struct {\n    10→\t\targs []string\n    11→\t\twant bool\n    12→\t}{\n    13→\t\t{nil, false},\n    14→\t\t{[]string{}, false},\n    15→\t\t{[]string{\"--workflow\", \"develop\"}, false},\n    16→\t\t{[]string{\"--help\"}, true},\n    17→\t\t{[]string{\"-h\"}, true},\n    18→\t\t{[]string{\"--workflow\", \"develop\", \"--help\"}, true},\n    19→\t\t{[]string{\"-h\", \"--workflow\", \"develop\"}, true},\n    20→\t}\n    21→\n    22→\tfor _, tt := range tests {\n    23→\t\tgot := hasHelpFlag(tt.args)\n    24→\t\tif got != tt.want {\n    25→\t\t\tt.Errorf(\"hasHelpFlag(%v) = %v, want %v\", tt.args, got, tt.want)\n    26→\t\t}\n    27→\t}\n    28→}\n    29→\n    30→func TestSubcommandHelpExists(t *testing.T) {\n    31→\tcommands := []string{\n    32→\t\t\"init\", \"health\", \"run\", \"status\", \"logs\", \"poll\",\n    33→\t\t\"list\", \"stop\", \"delete\", \"tasks\", \"loop\", \"get\", \"set\", \"shutdown\",\n    34→\t}\n    35→\n    36→\tfor _, cmd := range commands {\n    37→\t\ttext, ok := subcommandHelp[cmd]\n    38→\t\tif !ok {\n    39→\t\t\tt.Errorf(\"missing help text for subcommand %q\", cmd)\n    40→\t\t\tcontinue\n    41→\t\t}\n    42→\t\tif text == \"\" {\n    43→\t\t\tt.Errorf(\"empty help text for subcommand %q\", cmd)\n    44→\t\t}\n    45→\t}\n    46→}\n    47→\n    48→func TestSubcommandHelpContainsUsage(t *testing.T) {\n    49→\tfor cmd, text := range subcommandHelp {\n    50→\t\tif !strings.Contains(text, \"Usage:\") {\n    51→\t\t\tt.Errorf(\"help for %q missing Usage: section\", cmd)\n    52→\t\t}\n    53→\t\tif !strings.Contains(text, \"Examples:\") {\n    54→\t\t\tt.Errorf(\"help for %q missing Examples: section\", cmd)\n    55→\t\t}\n    56→\t\tif !strings.Contains(text, \"cloche \"+cmd) {\n    57→\t\t\tt.Errorf(\"help for %q missing usage line with 'cloche %s'\", cmd, cmd)\n    58→\t\t}\n    59→\t}\n    60→}\n    61→\n    62→func TestPrintHelp_UnknownCommand(t *testing.T) {\n    63→\t// printHelp with an unknown command should still return true (help was handled)\n    64→\tgot := printHelp([]string{\"nonexistent\"})\n    65→\tif !got {\n    66→\t\tt.Error(\"printHelp with unknown command should return true\")\n    67→\t}\n    68→}\n    69→\n    70→func TestPrintHelp_NoArgs(t *testing.T) {\n    71→\tgot := printHelp(nil)\n    72→\tif !got {\n    73→\t\tt.Error(\"printHelp with no args should return true\")\n    74→\t}\n    75→}\n    76→\n    77→func TestPrintHelp_ValidCommand(t *testing.T) {\n    78→\tgot := printHelp([]string{\"run\"})\n    79→\tif !got {\n    80→\t\tt.Error(\"printHelp with valid command should return true\")\n    81→\t}\n    82→}\n    83→"}]},"parent_tool_use_id":null,"session_id":"5c40c135-d6d6-46ff-91b7-1e8ee6d44e10","uuid":"23167ee7-374f-4a45-a537-2b2032b0c2a2","tool_use_result":{"type":"text","file":{"filePath":"/workspace/cmd/cloche/help_test.go","content":"package main\n\nimport (\n\t\"strings\"\n\t\"testing\"\n)\n\nfunc TestHasHelpFlag(t *testing.T) {\n\ttests := []struct {\n\t\targs []string\n\t\twant bool\n\t}{\n\t\t{nil, false},\n\t\t{[]string{}, false},\n\t\t{[]string{\"--workflow\", \"develop\"}, false},\n\t\t{[]string{\"--help\"}, true},\n\t\t{[]string{\"-h\"}, true},\n\t\t{[]string{\"--workflow\", \"develop\", \"--help\"}, true},\n\t\t{[]string{\"-h\", \"--workflow\", \"develop\"}, true},\n\t}\n\n\tfor _, tt := range tests {\n\t\tgot := hasHelpFlag(tt.args)\n\t\tif got != tt.want {\n\t\t\tt.Errorf(\"hasHelpFlag(%v) = %v, want %v\", tt.args, got, tt.want)\n\t\t}\n\t}\n}\n\nfunc TestSubcommandHelpExists(t *testing.T) {\n\tcommands := []string{\n\t\t\"init\", \"health\", \"run\", \"status\", \"logs\", \"poll\",\n\t\t\"list\", \"stop\", \"delete\", \"tasks\", \"loop\", \"get\", \"set\", \"shutdown\",\n\t}\n\n\tfor _, cmd := range commands {\n\t\ttext, ok := subcommandHelp[cmd]\n\t\tif !ok {\n\t\t\tt.Errorf(\"missing help text for subcommand %q\", cmd)\n\t\t\tcontinue\n\t\t}\n\t\tif text == \"\" {\n\t\t\tt.Errorf(\"empty help text for subcommand %q\", cmd)\n\t\t}\n\t}\n}\n\nfunc TestSubcommandHelpContainsUsage(t *testing.T) {\n\tfor cmd, text := range subcommandHelp {\n\t\tif !strings.Contains(text, \"Usage:\") {\n\t\t\tt.Errorf(\"help for %q missing Usage: section\", cmd)\n\t\t}\n\t\tif !strings.Contains(text, \"Examples:\") {\n\t\t\tt.Errorf(\"help for %q missing Examples: section\", cmd)\n\t\t}\n\t\tif !strings.Contains(text, \"cloche \"+cmd) {\n\t\t\tt.Errorf(\"help for %q missing usage line with 'cloche %s'\", cmd, cmd)\n\t\t}\n\t}\n}\n\nfunc TestPrintHelp_UnknownCommand(t *testing.T) {\n\t// printHelp with an unknown command should still return true (help was handled)\n\tgot := printHelp([]string{\"nonexistent\"})\n\tif !got {\n\t\tt.Error(\"printHelp with unknown command should return true\")\n\t}\n}\n\nfunc TestPrintHelp_NoArgs(t *testing.T) {\n\tgot := printHelp(nil)\n\tif !got {\n\t\tt.Error(\"printHelp with no args should return true\")\n\t}\n}\n\nfunc TestPrintHelp_ValidCommand(t *testing.T) {\n\tgot := printHelp([]string{\"run\"})\n\tif !got {\n\t\tt.Error(\"printHelp with valid command should return true\")\n\t}\n}\n","numLines":83,"startLine":1,"totalLines":83}}}
