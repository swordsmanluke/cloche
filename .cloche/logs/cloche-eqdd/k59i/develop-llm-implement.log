 56→\t\tt.Fatalf(\"Set: %v\", err)\n    57→\t}\n    58→\n    59→\t// Verify the file exists\n    60→\tpath := runcontext.ContextPath(dir, runID)\n    61→\tif _, err := os.Stat(path); os.IsNotExist(err) {\n    62→\t\tt.Fatalf(\"context.json not created at %s\", path)\n    63→\t}\n    64→}\n    65→\n    66→func TestCmdSet_WritesContextFile(t *testing.T) {\n    67→\tdir := t.TempDir()\n    68→\trunID := \"test-run-abcd\"\n    69→\n    70→\tif err := runcontext.Set(dir, runID, \"mykey\", \"myval\"); err != nil {\n    71→\t\tt.Fatalf(\"Set: %v\", err)\n    72→\t}\n    73→\n    74→\tval, ok, err := runcontext.Get(dir, runID, \"mykey\")\n    75→\tif err != nil {\n    76→\t\tt.Fatalf(\"Get: %v\", err)\n    77→\t}\n    78→\tif !ok || val != \"myval\" {\n    79→\t\tt.Errorf(\"Get = (%q, %v), want (%q, true)\", val, ok, \"myval\")\n    80→\t}\n    81→\n    82→\t// Verify the JSON file is well-formed\n    83→\tdata, err := os.ReadFile(filepath.Join(dir, \".cloche\", runID, \"context.json\"))\n    84→\tif err != nil {\n    85→\t\tt.Fatalf(\"reading context.json: %v\", err)\n    86→\t}\n    87→\tif len(data) == 0 {\n    88→\t\tt.Error(\"context.json is empty\")\n    89→\t}\n    90→}\n    91→\n    92→func TestCmdSet_StdinValue(t *testing.T) {\n    93→\tdir := t.TempDir()\n    94→\trunID := \"test-run-stdin\"\n    95→\n    96→\tt.Setenv(\"CLOCHE_RUN_ID\", runID)\n    97→\tt.Setenv(\"CLOCHE_PROJECT_DIR\", dir)\n    98→\n    99→\t// Swap stdin to read from a string\n   100→\torigStdin := os.Stdin\n   101→\tr, w, err := os.Pipe()\n   102→\tif err != nil {\n   103→\t\tt.Fatalf(\"creating pipe: %v\", err)\n   104→\t}\n   105→\tos.Stdin = r\n   106→\tdefer func() { os.Stdin = origStdin }()\n   107→\n   108→\t// Write multi-line content and close\n   109→\tcontent := \"line one\\nline two\\n\"\n   110→\tgo func() {\n   111→\t\tw.WriteString(content)\n   112→\t\tw.Close()\n   113→\t}()\n   114→\n   115→\tcmdSet([]string{\"multiline_key\", \"-\"})\n   116→\n   117→\t// Verify the value was 