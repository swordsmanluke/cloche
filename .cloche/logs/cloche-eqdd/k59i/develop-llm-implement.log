{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TcLoZDtNAgA1hmFgyhiTFC","type":"tool_result","content":"     1→package main\n     2→\n     3→import (\n     4→\t\"os\"\n     5→\t\"path/filepath\"\n     6→\t\"strings\"\n     7→\t\"testing\"\n     8→\n     9→\t\"github.com/cloche-dev/cloche/internal/runcontext\"\n    10→)\n    11→\n    12→func TestResolveRunContext_MissingRunID(t *testing.T) {\n    13→\tt.Setenv(\"CLOCHE_RUN_ID\", \"\")\n    14→\t_, _, err := resolveRunContext()\n    15→\tif err == nil {\n    16→\t\tt.Fatal(\"expected error when CLOCHE_RUN_ID is not set\")\n    17→\t}\n    18→}\n    19→\n    20→func TestResolveRunContext_UsesEnvVars(t *testing.T) {\n    21→\tt.Setenv(\"CLOCHE_RUN_ID\", \"test-run-1234\")\n    22→\tt.Setenv(\"CLOCHE_PROJECT_DIR\", \"/tmp/myproject\")\n    23→\n    24→\tprojectDir, runID, err := resolveRunContext()\n    25→\tif err != nil {\n    26→\t\tt.Fatalf(\"unexpected error: %v\", err)\n    27→\t}\n    28→\tif runID != \"test-run-1234\" {\n    29→\t\tt.Errorf(\"runID = %q, want %q\", runID, \"test-run-1234\")\n    30→\t}\n    31→\tif projectDir != \"/tmp/myproject\" {\n    32→\t\tt.Errorf(\"projectDir = %q, want %q\", projectDir, \"/tmp/myproject\")\n    33→\t}\n    34→}\n    35→\n    36→func TestResolveRunContext_FallsToCwd(t *testing.T) {\n    37→\tt.Setenv(\"CLOCHE_RUN_ID\", \"test-run-1234\")\n    38→\tt.Setenv(\"CLOCHE_PROJECT_DIR\", \"\")\n    39→\n    40→\tprojectDir, _, err := resolveRunContext()\n    41→\tif err != nil {\n    42→\t\tt.Fatalf(\"unexpected error: %v\", err)\n    43→\t}\n    44→\tcwd, _ := os.Getwd()\n    45→\tif projectDir != cwd {\n    46→\t\tt.Errorf(\"projectDir = %q, want cwd %q\", projectDir, cwd)\n    47→\t}\n    48→}\n    49→\n    50→func TestCmdGet_PrintsValue(t *testing.T) {\n    51→\tdir := t.TempDir()\n    52→\trunID := \"test-run-abcd\"\n    53→\n    54→\t// Pre-populate context\n    55→\tif err := runcontext.Set(dir, runID, \"branch\", \"feature-x\"); err != nil {\n    56→\t\tt.Fatalf(\"Set: %v\", err)\n    57→\t}\n    58→\n    59→\t// Verify the file exists\n    60→\tpath := runcontext.ContextPath(dir, runID)\n    61→\tif _, err := os.Stat(path); os.IsNotExist(err) {\n    62→\t\tt.Fatalf(\"context.json not created at %s\", path)\n    63→\t}\n    64→}\n    65→\n    66→func TestCmdSet_WritesContextFile(t *testing.T) {\n    67→\tdir := t.TempDir()\n    68→\trunID := \"test-run-abcd\"\n    69→\n    70→\tif err := runcontext.Set(dir, runID, \"mykey\", \"myval\"); err != nil {\n    71→\t\tt.Fatalf(\"Set: %v\", err)\n    72→\t}\n    73→\n    74→\tval, ok, err := runcontext.Get(dir, runID, \"mykey\")\n    75→\tif err != nil {\n    76→\t\tt.Fatalf(\"Get: %v\", err)\n    77→\t}\n    78→\tif !ok || val != \"myval\" {\n    79→\t\tt.Errorf(\"Get = (%q, %v), want (%q, true)\", val, ok, \"myval\")\n    80→\t}\n    81→\n    82→\t// Verify the JSON file is well-formed\n    83→\tdata, err := os.ReadFile(filepath.Join(dir, \".cloche\", runID, \"context.json\"))\n    84→\tif err != nil {\n    85→\t\tt.Fatalf(\"reading context.json: %v\", err)\n    86→\t}\n    87→\tif len(data) == 0 {\n    88→\t\tt.Error(\"context.json is empty\")\n    89→\t}\n    90→}\n    91→\n    92→func TestCmdSet_StdinValue(t *testing.T) {\n    93→\tdir := t.TempDir()\n    94→\trunID := \"test-run-stdin\"\n    95→\n    96→\tt.Setenv(\"CLOCHE_RUN_ID\", runID)\n    97→\tt.Setenv(\"CLOCHE_PROJECT_DIR\", dir)\n    98→\n    99→\t// Swap stdin to read from a string\n   100→\torigStdin := os.Stdin\n   101→\tr, w, err := os.Pipe()\n   102→\tif err != nil {\n   103→\t\tt.Fatalf(\"creating pipe: %v\", err)\n   104→\t}\n   105→\tos.Stdin = r\n   106→\tdefer func() { os.Stdin = origStdin }()\n   107→\n   108→\t// Write multi-line content and close\n   109→\tcontent := \"line one\\nline two\\n\"\n   110→\tgo func() {\n   111→\t\tw.WriteString(content)\n   112→\t\tw.Close()\n   113→\t}()\n   114→\n   115→\tcmdSet([]string{\"multiline_key\", \"-\"})\n   116→\n   117→\t// Verify the value was stored with trailing newline trimmed\n   118→\tval, ok, err := runcontext.Get(dir, runID, \"multiline_key\")\n   119→\tif err != nil {\n   120→\t\tt.Fatalf(\"Get: %v\", err)\n   121→\t}\n   122→\tif !ok {\n   123→\t\tt.Fatal(\"expected key to exist\")\n   124→\t}\n   125→\texpected := strings.TrimRight(content, \"\\n\")\n   126→\tif val != expected {\n   127→\t\tt.Errorf(\"Get = %q, want %q\", val, expected)\n   128→\t}\n   129→}\n   130→"}]},"parent_tool_use_id":"toolu_01WNobJ3HGaMiFRetRNJk6RB","session_id":"43d3a283-4247-4cad-9b6c-2d2b3f0b0714","uuid":"86c873ab-f0f8-439f-ae73-169c7caaa0cf"}
