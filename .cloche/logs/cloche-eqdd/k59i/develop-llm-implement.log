{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01C3AgDxuYQjFzFP4H14LZKh","type":"tool_result","content":"     1→package main\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"fmt\"\n     6→\t\"os\"\n     7→\t\"time\"\n     8→\n     9→\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    10→)\n    11→\n    12→func cmdPoll(client pb.ClocheServiceClient, args []string) {\n    13→\tif len(args) < 1 {\n    14→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche poll <run-id>\\n\")\n    15→\t\tos.Exit(1)\n    16→\t}\n    17→\n    18→\trunID := args[0]\n    19→\tpollInterval := 2 * time.Second\n    20→\tcontainerDeadThreshold := 1 * time.Minute\n    21→\n    22→\tvar lastStepCount int\n    23→\tvar lastState string\n    24→\n    25→\tfor {\n    26→\t\tctx, cancel := context.WithTimeout(context.Background(), 10*time.Second)\n    27→\t\tresp, err := client.GetStatus(ctx, &pb.GetStatusRequest{RunId: runID})\n    28→\t\tcancel()\n    29→\n    30→\t\tif err != nil {\n    31→\t\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n    32→\t\t\tos.Exit(1)\n    33→\t\t}\n    34→\n    35→\t\t// Print new step events\n    36→\t\tfor i := lastStepCount; i < len(resp.StepExecutions); i++ {\n    37→\t\t\texec := resp.StepExecutions[i]\n    38→\t\t\tts := time.Now().Format(\"15:04:05\")\n    39→\t\t\tif exec.Result == \"\" {\n    40→\t\t\t\tfmt.Printf(\"[%s] Step %q started\\n\", ts, exec.StepName)\n    41→\t\t\t} else {\n    42→\t\t\t\tfmt.Printf(\"[%s] Step %q completed: %s\\n\", ts, exec.StepName, exec.Result)\n    43→\t\t\t}\n    44→\t\t}\n    45→\t\tlastStepCount = len(resp.StepExecutions)\n    46→\n    47→\t\t// Print state changes\n    48→\t\tif resp.State != lastState {\n    49→\t\t\tts := time.Now().Format(\"15:04:05\")\n    50→\t\t\tfmt.Printf(\"[%s] Run %s is %s\\n\", ts, runID, resp.State)\n    51→\t\t\tlastState = resp.State\n    52→\t\t}\n    53→\n    54→\t\t// Check terminal states\n    55→\t\tswitch resp.State {\n    56→\t\tcase \"succeeded\":\n    57→\t\t\tos.Exit(0)\n    58→\t\tcase \"failed\", \"cancelled\":\n    59→\t\t\tif resp.ErrorMessage != \"\" {\n    60→\t\t\t\tfmt.Fprintf(os.Stderr, \"Error: %s\\n\", resp.ErrorMessage)\n    61→\t\t\t}\n    62→\t\t\tos.Exit(1)\n    63→\t\t}\n    64→\n    65→\t\t// Check container death\n    66→\t\tif !resp.ContainerAlive && resp.ContainerDeadSince != \"\" {\n    67→\t\t\tdeadSince, err := time.Parse(time.RFC3339Nano, resp.ContainerDeadSince)\n    68→\t\t\tif err == nil && time.Since(deadSince) > containerDeadThreshold {\n    69→\t\t\t\tfmt.Fprintf(os.Stderr, \"[%s] Container has been dead for >1 minute (since %s)\\n\",\n    70→\t\t\t\t\ttime.Now().Format(\"15:04:05\"), deadSince.Format(\"15:04:05\"))\n    71→\t\t\t\tos.Exit(1)\n    72→\t\t\t}\n    73→\t\t}\n    74→\n    75→\t\ttime.Sleep(pollInterval)\n    76→\t}\n    77→}\n    78→"}]},"parent_tool_use_id":"toolu_01WNobJ3HGaMiFRetRNJk6RB","session_id":"43d3a283-4247-4cad-9b6c-2d2b3f0b0714","uuid":"915eca90-d460-4f79-b0ad-5999f854f345"}
