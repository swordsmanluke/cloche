{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0171bwYyBRcq1U4AiWUPbwYo","type":"tool_result","content":"   200→\tfor scanner.Scan() {\n   201→\t\tvar msg protocol.StatusMessage\n   202→\t\tif err := json.Unmarshal(scanner.Bytes(), &msg); err != nil {\n   203→\t\t\tcontinue\n   204→\t\t}\n   205→\n   206→\t\t// Fast path: log messages don't need store interaction.\n   207→\t\tif msg.Type == protocol.MsgLog {\n   208→\t\t\tif s.logBroadcast != nil {\n   209→\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n   210→\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n   211→\t\t\t\t\tType:      \"llm\",\n   212→\t\t\t\t\tContent:   msg.Message,\n   213→\t\t\t\t\tStepName:  msg.StepName,\n   214→\t\t\t\t})\n   215→\t\t\t}\n   216→\t\t\tcontinue\n   217→\t\t}\n   218→\n   219→\t\trun, err := s.store.GetRun(ctx, runID)\n   220→\t\tif err != nil {\n   221→\t\t\tcontinue\n   222→\t\t}\n   223→\n   224→\t\tswitch msg.Type {\n   225→\t\tcase protocol.MsgStepStarted:\n   226→\t\t\trun.RecordStepStart(msg.StepName)\n   227→\t\t\tif s.captures != nil {\n   228→\t\t\t\t_ = s.captures.SaveCapture(ctx, runID, &domain.StepExecution{\n   229→\t\t\t\t\tStepName:  msg.StepName,\n   230→\t\t\t\t\tStartedAt: msg.Timestamp,\n   231→\t\t\t\t})\n   232→\t\t\t}\n   233→\t\t\tif s.logBroadcast != nil {\n   234→\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n   235→\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n   236→\t\t\t\t\tType:      \"status\",\n   237→\t\t\t\t\tContent:   \"step_started: \" + msg.StepName,\n   238→\t\t\t\t\tStepName:  msg.StepName,\n   239→\t\t\t\t})\n   240→\t\t\t}\n   241→\t\tcase protocol.MsgStepCompleted:\n   242→\t\t\trun.RecordStepComplete(msg.StepName, msg.Result)\n   243→\t\t\tif s.captures != nil {\n   244→\t\t\t\t_ = s.captures.SaveCapture(ctx, runID, &domain.StepExecution{\n   245→\t\t\t\t\tStepName:    msg.StepName,\n   246→\t\t\t\t\tResult:      msg.Result,\n   247→\t\t\t\t\tCompletedAt: msg.Timestamp,\n   248→\t\t\t\t})\n   249→\t\t\t}\n   250→\t\t\tif s.logBroadcast != nil {\n   251→\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n   252→\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n   253→\t\t\t\t\tType:      \"status\",\n   254→\t\t\t\t\tContent:   \"step_completed: \" + msg.StepName + \" -> \" + msg.Result,\n   255→\t\t\t\t\tStepName:  msg.StepName,\n   256→\t\t\t\t})\n   257→\t\t\t}\n   258→\t\tcase protocol.MsgRunTitle:\n   259→\t\t\tif run.Title == \"\" {\n   260→\t\t\t\trun.Title = msg.Message\n   261→\t\t\t}\n   262→\t\tcase protocol.MsgRunCompleted:\n   263→\t\t\treportedResult = msg.Result\n   264→\t\t\tcontinue // Don't persist terminal state yet; branch extraction must finish first\n   265→\t\t}\n   266→\n   267→\t\t_ = s.store.UpdateRun(ctx, run)\n   268→\t}\n   269→\treader.Close()\n   270→\n   271→\t// Signal live-stream subscribers that this run is done.\n   272→\tif s.logBroadcast != nil {\n   273→\t\ts.logBroadcast.Finish(runID)\n   274→\t}\n   275→\n   276→\t// Wait for process exit\n   277→\texitCode, err := s.container.Wait(ctx, containerID)\n   278→\tif err != nil {\n   279→\t\tlog.Printf(\"error waiting for run %s: %v\", runID, err)\n   280→\t}\n   281→\n   282→\t// Extract step output files from container before it's removed\n   283→\toutputDst := filepath.Join(projectDir, \".cloche\", runID, \"output\")\n   284→\tif err := os.MkdirAll(outputDst, 0755); err == nil {\n   285→\t\tif cpErr := s.container.CopyFrom(ctx, containerID, \"/workspace/.cloche/output/.\", outputDst); cpErr != nil {\n   286→\t\t\tlog.Printf(\"run %s: failed to extract output: %v\", runID, cpErr)\n   287→\t\t}\n   288→\t}\n   289→\n   290→\t// Capture full container stdout/stderr before the container is removed\n   291→\tif logs, logErr := s.container.Logs(ctx, containerID); logErr == nil && logs != \"\" {\n   292→\t\tcontainerLogPath := filepath.Join(outputDst, \"container.log\")\n   293→\t\tif writeErr := os.WriteFile(containerLogPath, []byte(logs), 0644); writeErr != nil {\n   294→\t\t\tlog.Printf(\"run %s: failed to write container.log: %v\", runID, writeErr)\n   295→\t\t}\n   296→\t}\n   297→\n   298→\t// Index extracted log files in the log store\n   299→\tif s.logStore != nil {\n   300→\t\ts.indexLogFiles(ctx, runID, outputDst)\n   301→\t}\n   302→\n   303→\t// Extract results to git branch BEFORE finalizing state, so that\n   304→\t// WaitRun callers (e.g. host workflow merge step) see branches exist\n   305→\t// before the run is marked complete.\n   306→\tresultLabel := reportedResult\n   307→\tif resultLabel == \"\" {\n   308→\t\tif exitCode == 0 {\n   309→\t\t\tresultLabel = \"succeeded\"\n   310→\t\t} else {\n   311→\t\t\tresultLabel = \"failed\"\n   312→\t\t}\n   313→\t}\n   314→\t{\n   315→\t\textractRun, _ := s.store.GetRun(ctx, runID)\n   316→\t\tif extractRun != nil && extractRun.BaseSHA != \"\" {\n   317→\t\t\tlog.Printf(\"run %s: extracting results to branch cloche/%s (baseSHA=%s)\", runID, runID, extractRun.BaseSHA)\n   318→\t\t\tif err := docker.ExtractResults(ctx, containerID, extractRun.ProjectDir, runID, extractRun.BaseSHA, workflowName, resultLabel); err != nil {\n   319→\t\t\t\tlog.Printf(\"run %s: failed to extract results to branch: %v\", runID, err)\n   320→\t\t\t} else {\n   321→\t\t\t\tlog.Printf(\"run %s: branch cloche/%s created successfully\", runID, runID)\n   322→\t\t\t}\n   323→\t\t} else {\n   324→\t\t\tlog.Printf(\"run %s: skipping branch extraction (baseSHA empty or run not found)\", runID)\n   325→\t\t}\n   326→\t}\n   327→\n   328→\t// Now finalize run state\n   329→\trun, err := s.store.GetRun(ctx, runID)\n   330→\tif err != nil {\n   331→\t\treturn\n   332→\t}\n   333→\tif run.State == domain.RunStateRunning {\n   334→\t\tif reportedResult == \"succeeded\" {\n   335→\t\t\trun.Complete(domain.RunStateSucceeded)\n   336→\t\t} else if reportedResult != \"\" {\n   337→\t\t\trun.Complete(domain.RunStateFailed)\n   338→\t\t} else if exitCode == 0 {\n   339→\t\t\trun.Complete(domain.RunStateSucceeded)\n   340→\t\t} else {\n   341→\t\t\trun.Fail(fmt.Sprintf(\"container exited with code %d\", exitCode))\n   342→\t\t}\n   343→\t\t_ = s.store.UpdateRun(ctx, run)\n   344→\t}\n   345→\n   346→\t// Fire evolution trigger if configured\n   347→\tif s.evolution != nil {\n   348→\t\ts.evolution.Fire(projectDir, workflowName, runID)\n   349→\t}\n   350→\n   351→\t// Merge is handled as a workflow step in host.cloche, not here.\n   352→\n   353→\t// Container retention policy:\n   354→\t// - Failed runs: always keep the container for debugging\n   355→\t// - Successful runs + --keep-container: keep the container\n   356→\t// - Successful runs without --keep-container: remove the container\n   357→\trunFinal, _ := s.store.GetRun(ctx, runID)\n   358→\trunFailed := runFinal != nil && (runFinal.State == domain.RunStateFailed || runFinal.State == domain.RunStateCancelled)\n   359→\n   360→\tif keepContainer || runFailed {\n   361→\t\treason := \"--keep-container\"\n   362→\t\tif runFailed {\n   363→\t\t\treason = \"run failed\"\n   364→\t\t}\n   365→\t\tlog.Printf(\"run %s: keeping container %s (%s)\", runID, containerID, reason)\n   366→\t\tif runFinal != nil {\n   367→\t\t\trunFinal.ContainerKept = true\n   368→\t\t\t_ = s.store.UpdateRun(ctx, runFinal)\n   369→\t\t}\n   370→\t} else {\n   371→\t\tif err := s.container.Remove(ctx, containerID); err != nil {\n   372→\t\t\tlog.Printf(\"run %s: failed to remove container %s: %v\", runID, containerID, err)\n   373→\t\t} else {\n   374→\t\t\tlog.Printf(\"run %s: removed container %s\", runID, containerID)\n   375→\t\t}\n   376→\t}\n   377→\n   378→\t// Cleanup mapping\n   379→\ts.mu.Lock()\n   380→\tdelete(s.runIDs, runID)\n   381→\ts.mu.Unlock()\n   382→}\n   383→\n   384→func (s *ClocheServer) ListRuns(ctx context.Context, req *pb.ListRunsRequest) (*pb.ListRunsResponse, error) {\n   385→\tvar since time.Time\n   386→\tif !req.All {\n   387→\t\tsince = time.Now().Add(-1 * time.Hour)\n   388→\t}\n   389→\truns, err := s.store.ListRuns(ctx, since)\n   390→\tif err != nil {\n   391→\t\treturn nil, fmt.Errorf(\"listing runs: %w\", err)\n   392→\t}\n   393→\n   394→\tresp := &pb.ListRunsResponse{}\n   395→\tfor _, run := range runs {\n   396→\t\tresp.Runs = append(resp.Runs, &pb.RunSummary{\n   397→\t\t\tRunId:        run.ID,\n   398→\t\t\tWorkflowName: run.WorkflowName,\n   399→\t\t\tState:        string(run.State),\n   400→\t\t\tStartedAt:    run.StartedAt.String(),\n   401→\t\t\tErrorMessage: run.ErrorMessage,\n   402→\t\t\tContainerId:  run.ContainerID,\n   403→\t\t\tTitle:        run.Title,\n   404→\t\t\tIsHost:       run.IsHost,\n   405→\t\t})\n   406→\t}\n   407→\treturn resp, nil\n   408→}\n   409→\n   410→func (s *ClocheServer) GetStatus(ctx context.Context, req *pb.GetStatusRequest) (*pb.GetStatusResponse, error) {\n   411→\trun, err := s.store.GetRun(ctx, req.RunId)\n   412→\tif err != nil {\n   413→\t\treturn nil, fmt.Errorf(\"getting run: %w\", err)\n   414→\t}\n   415→\n   416→\tresp := &pb.GetStatusResponse{\n   417→\t\tRunId:        run.ID,\n   418→\t\tWorkflowName: run.WorkflowName,\n   419→\t\tState:        string(run.State),\n   420→\t\tCurrentStep:  strings.Join(run.ActiveSteps, \",\"),\n   421→\t\tErrorMessage: run.ErrorMessage,\n   422→\t\tContainerId:  run.ContainerID,\n   423→\t\tTitle:        run.Title,\n   424→\t\tIsHost:       run.IsHost,\n   425→\t}\n   426→\n   427→\t// Check container liveness\n   428→\tif run.ContainerID != \"\" && s.container != nil {\n   429→\t\tif cs, err := s.container.Inspect(ctx, run.ContainerID); err == nil {\n   430→\t\t\tresp.ContainerAlive = cs.Running\n   431→\t\t\tif !cs.Running && !cs.FinishedAt.IsZero() {\n   432→\t\t\t\tresp.ContainerDeadSince = cs.FinishedAt.Format(time.RFC3339Nano)\n   433→\t\t\t}\n   434→\t\t}\n   435→\t}\n   436→\n   437→\t// Load step executions from captures store if available\n   438→\tif s.captures != nil {\n   439→\t\tcaptures, err := s.captures.GetCaptures(ctx, req.RunId)\n   440→\t\tif err == nil {\n   441→\t\t\tfor _, exec := range captures {\n   442→\t\t\t\tresp.StepExecutions = append(resp.StepExecutions, &pb.StepExecutionStatus{\n   443→\t\t\t\t\tStepName:    exec.StepName,\n   444→\t\t\t\t\tResult:      exec.Result,\n   445→\t\t\t\t\tStartedAt:   exec.StartedAt.String(),\n   446→\t\t\t\t\tCompletedAt: exec.CompletedAt.String(),\n   447→\t\t\t\t})\n   448→\t\t\t}\n   449→\t\t}\n   450→\t} else {\n   451→\t\tfor _, exec := range run.StepExecutions {\n   452→\t\t\tresp.StepExecutions = append(resp.StepExecutions, &pb.StepExecutionStatus{\n   453→\t\t\t\tStepName:    exec.StepName,\n   454→\t\t\t\tResult:      exec.Result,\n   455→\t\t\t\tStartedAt:   exec.StartedAt.String(),\n   456→\t\t\t\tCompletedAt: exec.CompletedAt.String(),\n   457→\t\t\t})\n   458→\t\t}\n   459→\t}\n   460→\n   461→\treturn resp, nil\n   462→}\n   463→\n   464→func (s *ClocheServer) StreamLogs(req *pb.StreamLogsRequest, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n   465→\tctx := stream.Context()\n   466→\n   467→\t// Verify run exists\n   468→\trun, err := s.store.GetRun(ctx, req.RunId)\n   469→\tif err != nil {\n   470→\t\treturn fmt.Errorf(\"run %q not found: %w\", req.RunId, err)\n   471→\t}\n   472→\n   473→\t// If step_name or log_type filter is set, serve content directly from the log index\n   474→\tif req.StepName != \"\" || req.LogType != \"\" {\n   475→\t\treturn s.streamFilteredLogs(ctx, req, run, stream)\n   476→\t}\n   477→\n   478→\t// For active runs, stream live from the broadcaster so callers can tail output.\n   479→\tif (run.State == domain.RunStateRunning || run.State == domain.RunStatePending) && s.logBroadcast != nil {\n   480→\t\treturn s.streamLiveLogs(req.RunId, stream)\n   481→\t}\n   482→\n   483→\tif s.captures == nil {\n   484→\t\treturn fmt.Errorf(\"captures store not configured\")\n   485→\t}\n   486→\n   487→\t// Check for full.log first — if it exists, serve it as the unified log\n   488→\tfullLogPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", \"full.log\")\n   489→\tif data, readErr := os.ReadFile(fullLogPath); readErr == nil && len(data) > 0 {\n   490→\t\tif err := stream.Send(&pb.LogEntry{\n   491→\t\t\tType:    \"full_log\",\n   492→\t\t\tMessage: string(data),\n   493→\t\t}); err != nil {\n   494→\t\t\treturn err\n   495→\t\t}\n   496→\t\t// Still send run completion entry\n   497→\t\tif run.State != domain.RunStateRunning && run.State != domain.RunStatePending {\n   498→\t\t\tif err := stream.Send(&pb.LogEntry{\n   499→\t\t\t\tType:      \"run_completed\","}]},"parent_tool_use_id":"toolu_01SrdTMeCBVxpeRyCsfQRUZn","session_id":"a5ceff1a-0d2b-4db0-a018-cacf9a2b2a3f","uuid":"a958c5e1-eaeb-4a04-96e3-2908b2f8e1e9"}
