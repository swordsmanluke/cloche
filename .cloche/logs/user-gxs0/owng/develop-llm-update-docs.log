{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018KBubyJbWXzsGBGvVaaB5u","type":"tool_result","content":"     1→package dsl\n     2→\n     3→import (\n     4→\t\"fmt\"\n     5→\t\"strconv\"\n     6→\t\"strings\"\n     7→\n     8→\t\"github.com/cloche-dev/cloche/internal/domain\"\n     9→)\n    10→\n    11→type Parser struct {\n    12→\tlexer    *Lexer\n    13→\tcurrent  Token\n    14→\tpeek     Token\n    15→\tlocation domain.WorkflowLocation\n    16→}\n    17→\n    18→// ParseOption configures the parser.\n    19→type ParseOption func(*Parser)\n    20→\n    21→// WithLocation sets the workflow location, enabling location-based validation.\n    22→func WithLocation(loc domain.WorkflowLocation) ParseOption {\n    23→\treturn func(p *Parser) {\n    24→\t\tp.location = loc\n    25→\t}\n    26→}\n    27→\n    28→func Parse(input string, opts ...ParseOption) (*domain.Workflow, error) {\n    29→\tp := &Parser{lexer: NewLexer(input)}\n    30→\tfor _, opt := range opts {\n    31→\t\topt(p)\n    32→\t}\n    33→\tp.advance() // load current\n    34→\tp.advance() // load peek\n    35→\treturn p.parseWorkflow()\n    36→}\n    37→\n    38→// ParseForHost parses a host.cloche file containing a single workflow.\n    39→func ParseForHost(input string) (*domain.Workflow, error) {\n    40→\treturn Parse(input, WithLocation(domain.LocationHost))\n    41→}\n    42→\n    43→// ParseAllForHost parses a host.cloche file that may contain multiple workflows.\n    44→// Returns a map of workflow name to workflow definition.\n    45→func ParseAllForHost(input string) (map[string]*domain.Workflow, error) {\n    46→\tp := &Parser{lexer: NewLexer(input), location: domain.LocationHost}\n    47→\tp.advance() // load current\n    48→\tp.advance() // load peek\n    49→\n    50→\tworkflows := make(map[string]*domain.Workflow)\n    51→\tfor p.current.Type != TokenEOF {\n    52→\t\twf, err := p.parseWorkflow()\n    53→\t\tif err != nil {\n    54→\t\t\treturn nil, err\n    55→\t\t}\n    56→\t\tif _, exists := workflows[wf.Name]; exists {\n    57→\t\t\treturn nil, fmt.Errorf(\"duplicate workflow name %q\", wf.Name)\n    58→\t\t}\n    59→\t\tworkflows[wf.Name] = wf\n    60→\t}\n    61→\n    62→\tif len(workflows) == 0 {\n    63→\t\treturn nil, fmt.Errorf(\"no workflows found in host.cloche\")\n    64→\t}\n    65→\n    66→\treturn workflows, nil\n    67→}\n    68→\n    69→// ParseForContainer parses a container workflow file.\n    70→func ParseForContainer(input string) (*domain.Workflow, error) {\n    71→\treturn Parse(input, WithLocation(domain.LocationContainer))\n    72→}\n    73→\n    74→func (p *Parser) advance() {\n    75→\tp.current = p.peek\n    76→\tp.peek = p.lexer.NextToken()\n    77→}\n    78→\n    79→func (p *Parser) expect(typ TokenType) (Token, error) {\n    80→\tif p.current.Type != typ {\n    81→\t\treturn p.current, fmt.Errorf(\"line %d col %d: expected %v, got %v (%q)\",\n    82→\t\t\tp.current.Line, p.current.Col, typ, p.current.Type, p.current.Literal)\n    83→\t}\n    84→\ttok := p.current\n    85→\tp.advance()\n    86→\treturn tok, nil\n    87→}\n    88→\n    89→func (p *Parser) expectIdent(value string) (Token, error) {\n    90→\tif p.current.Type != TokenIdent || p.current.Literal != value {\n    91→\t\treturn p.current, fmt.Errorf(\"line %d col %d: expected %q, got %q\",\n    92→\t\t\tp.current.Line, p.current.Col, value, p.current.Literal)\n    93→\t}\n    94→\ttok := p.current\n    95→\tp.advance()\n    96→\treturn tok, nil\n    97→}\n    98→\n    99→func (p *Parser) parseWorkflow() (*domain.Workflow, error) {\n   100→\tif _, err := p.expectIdent(\"workflow\"); err != nil {\n   101→\t\treturn nil, err\n   102→\t}\n   103→\n   104→\tnameTok, err := p.expect(TokenString)\n   105→\tif err != nil {\n   106→\t\treturn nil, fmt.Errorf(\"expected workflow name string: %w\", err)\n   107→\t}\n   108→\n   109→\tif _, err := p.expect(TokenLBrace); err != nil {\n   110→\t\treturn nil, err\n   111→\t}\n   112→\n   113→\twf := &domain.Workflow{\n   114→\t\tName:     nameTok.Literal,\n   115→\t\tLocation: p.location,\n   116→\t\tSteps:    make(map[string]*domain.Step),\n   117→\t\tConfig:   make(map[string]string),\n   118→\t}\n   119→\n   120→\tfor p.current.Type != TokenRBrace && p.current.Type != TokenEOF {\n   121→\t\tif p.current.Type == TokenIdent && p.current.Literal == \"step\" {\n   122→\t\t\tstep, err := p.parseStep()\n   123→\t\t\tif err != nil {\n   124→\t\t\t\treturn nil, err\n   125→\t\t\t}\n   126→\t\t\twf.Steps[step.Name] = step\n   127→\t\t\tif wf.EntryStep == \"\" {\n   128→\t\t\t\twf.EntryStep = step.Name\n   129→\t\t\t}\n   130→\t\t} else if p.current.Type == TokenIdent && p.current.Literal == \"collect\" {\n   131→\t\t\tcollect, err := p.parseCollect()\n   132→\t\t\tif err != nil {\n   133→\t\t\t\treturn nil, err\n   134→\t\t\t}\n   135→\t\t\twf.Collects = append(wf.Collects, collect)\n   136→\t\t} else if p.current.Type == TokenIdent && p.peek.Type == TokenLBrace {\n   137→\t\t\tif err := p.parseWorkflowConfig(wf); err != nil {\n   138→\t\t\t\treturn nil, err\n   139→\t\t\t}\n   140→\t\t} else if p.current.Type == TokenIdent && p.peek.Type == TokenColon {\n   141→\t\t\twire, err := p.parseWire()\n   142→\t\t\tif err != nil {\n   143→\t\t\t\treturn nil, err\n   144→\t\t\t}\n   145→\t\t\twf.Wiring = append(wf.Wiring, wire)\n   146→\t\t} else {\n   147→\t\t\treturn nil, fmt.Errorf(\"line %d col %d: unexpected token %q\", p.current.Line, p.current.Col, p.current.Literal)\n   148→\t\t}\n   149→\t}\n   150→\n   151→\tif _, err := p.expect(TokenRBrace); err != nil {\n   152→\t\treturn nil, err\n   153→\t}\n   154→\n   155→\tif wf.Location != \"\" {\n   156→\t\tif err := wf.ValidateLocation(); err != nil {\n   157→\t\t\treturn nil, err\n   158→\t\t}\n   159→\t}\n   160→\n   161→\treturn wf, nil\n   162→}\n   163→\n   164→func (p *Parser) parseWorkflowConfig(wf *domain.Workflow) error {\n   165→\tprefix := p.current.Literal // e.g. \"container\"\n   166→\tp.advance()                 // consume prefix ident\n   167→\n   168→\tif _, err := p.expect(TokenLBrace); err != nil {\n   169→\t\treturn err\n   170→\t}\n   171→\n   172→\tfor p.current.Type != TokenRBrace && p.current.Type != TokenEOF {\n   173→\t\tkeyTok, err := p.expect(TokenIdent)\n   174→\t\tif err != nil {\n   175→\t\t\treturn fmt.Errorf(\"expected field name: %w\", err)\n   176→\t\t}\n   177→\n   178→\t\tif _, err := p.expect(TokenEquals); err != nil {\n   179→\t\t\treturn err\n   180→\t\t}\n   181→\n   182→\t\tval, err := p.parseValue()\n   183→\t\tif err != nil {\n   184→\t\t\treturn err\n   185→\t\t}\n   186→\n   187→\t\twf.Config[prefix+\".\"+keyTok.Literal] = val\n   188→\t}\n   189→\n   190→\tif _, err := p.expect(TokenRBrace); err != nil {\n   191→\t\treturn err\n   192→\t}\n   193→\n   194→\treturn nil\n   195→}\n   196→\n   197→func (p *Parser) parseStep() (*domain.Step, error) {\n   198→\tp.advance() // consume \"step\"\n   199→\n   200→\tnameTok, err := p.expect(TokenIdent)"}]},"parent_tool_use_id":"toolu_01SrdTMeCBVxpeRyCsfQRUZn","session_id":"a5ceff1a-0d2b-4db0-a018-cacf9a2b2a3f","uuid":"2fd6efe5-a393-48d2-acfd-262a221c3bdd"}
