{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UVRJcFhFMBtrmJ74QATaNi","type":"tool_result","content":"     1→package dsl_test\n     2→\n     3→import (\n     4→\t\"testing\"\n     5→\n     6→\t\"github.com/cloche-dev/cloche/internal/domain\"\n     7→\t\"github.com/cloche-dev/cloche/internal/dsl\"\n     8→\t\"github.com/stretchr/testify/assert\"\n     9→\t\"github.com/stretchr/testify/require\"\n    10→)\n    11→\n    12→func TestParser_FullWorkflow(t *testing.T) {\n    13→\tinput := `workflow \"implement-feature\" {\n    14→  step code {\n    15→    prompt = file(\"prompts/implement.md\")\n    16→    results = [success, fail, retry_with_feedback]\n    17→  }\n    18→\n    19→  step check {\n    20→    run = \"make test && make lint\"\n    21→    results = [pass, fail]\n    22→  }\n    23→\n    24→  code:success -> check\n    25→  code:fail -> abort\n    26→  code:retry_with_feedback -> code\n    27→\n    28→  check:pass -> done\n    29→  check:fail -> code\n    30→}`\n    31→\n    32→\twf, err := dsl.Parse(input)\n    33→\trequire.NoError(t, err)\n    34→\n    35→\tassert.Equal(t, \"implement-feature\", wf.Name)\n    36→\tassert.Len(t, wf.Steps, 2)\n    37→\n    38→\tcode := wf.Steps[\"code\"]\n    39→\trequire.NotNil(t, code)\n    40→\tassert.Equal(t, domain.StepTypeAgent, code.Type)\n    41→\tassert.Equal(t, []string{\"success\", \"fail\", \"retry_with_feedback\"}, code.Results)\n    42→\tassert.Equal(t, `file(\"prompts/implement.md\")`, code.Config[\"prompt\"])\n    43→\n    44→\tcheck := wf.Steps[\"check\"]\n    45→\trequire.NotNil(t, check)\n    46→\tassert.Equal(t, domain.StepTypeScript, check.Type)\n    47→\tassert.Equal(t, \"make test && make lint\", check.Config[\"run\"])\n    48→\n    49→\tassert.Len(t, wf.Wiring, 5)\n    50→\tassert.Equal(t, \"code\", wf.EntryStep)\n    51→}\n    52→\n    53→func TestParser_MinimalWorkflow(t *testing.T) {\n    54→\tinput := `workflow \"simple\" {\n    55→  step build {\n    56→    run = \"make build\"\n    57→    results = [success, fail]\n    58→  }\n    59→\n    60→  build:success -> done\n    61→  build:fail -> abort\n    62→}`\n    63→\n    64→\twf, err := dsl.Parse(input)\n    65→\trequire.NoError(t, err)\n    66→\tassert.Equal(t, \"simple\", wf.Name)\n    67→\tassert.Equal(t, \"build\", wf.EntryStep)\n    68→}\n    69→\n    70→func TestParser_SyntaxError(t *testing.T) {\n    71→\tinput := `workflow { }`\n    72→\t_, err := dsl.Parse(input)\n    73→\tassert.Error(t, err)\n    74→}\n    75→\n    76→func TestParser_ContainerBlock(t *testing.T) {\n    77→\tinput := `workflow \"test\" {\n    78→  step code {\n    79→    prompt = \"do something\"\n    80→    container {\n    81→      image = \"cloche/agent:latest\"\n    82→      network_allow = [\"docs.python.org\", \"internal.example.com\"]\n    83→    }\n    84→    results = [success]\n    85→  }\n    86→  code:success -> done\n    87→}`\n    88→\n    89→\twf, err := dsl.Parse(input)\n    90→\trequire.NoError(t, err)\n    91→\n    92→\tcode := wf.Steps[\"code\"]\n    93→\tassert.Equal(t, \"cloche/agent:latest\", code.Config[\"container.image\"])\n    94→\tassert.Equal(t, \"docs.python.org,internal.example.com\", code.Config[\"container.network_allow\"])\n    95→}\n    96→\n    97→func TestParser_WorkflowContainerBlock(t *testing.T) {\n    98→\tinput := `workflow \"with-image\" {\n    99→  container {\n   100→    image = \"myregistry/myimage:v2\"\n   101→  }\n   102→\n   103→  step code {\n   104→    prompt = \"write code\"\n   105→    results = [success, fail]\n   106→  }\n   107→\n   108→  code:success -> done\n   109→  code:fail -> abort\n   110→}`\n   111→\n   112→\twf, err := dsl.Parse(input)\n   113→\trequire.NoError(t, err)\n   114→\tassert.Equal(t, \"with-image\", wf.Name)\n   115→\tassert.Equal(t, \"myregistry/myimage:v2\", wf.Config[\"container.image\"])\n   116→}\n   117→\n   118→func TestParser_WorkflowContainerBlockMultipleFields(t *testing.T) {\n   119→\tinput := `workflow \"full-config\" {\n   120→  container {\n   121→    image = \"myregistry/myimage:v2\"\n   122→    memory = \"4g\"\n   123→  }\n   124→\n   125→  step code {\n   126→    prompt = \"write code\"\n   127→    results = [success]\n   128→  }\n   129→\n   130→  code:success -> done\n   131→}`\n   132→\n   133→\twf, err := dsl.Parse(input)\n   134→\trequire.NoError(t, err)\n   135→\tassert.Equal(t, \"myregistry/myimage:v2\", wf.Config[\"container.image\"])\n   136→\tassert.Equal(t, \"4g\", wf.Config[\"container.memory\"])\n   137→}\n   138→\n   139→func TestParser_WorkflowWithoutContainerBlock(t *testing.T) {\n   140→\tinput := `workflow \"no-container\" {\n   141→  step code {\n   142→    prompt = \"write code\"\n   143→    results = [success]\n   144→  }\n   145→\n   146→  code:success -> done\n   147→}`\n   148→\n   149→\twf, err := dsl.Parse(input)\n   150→\trequire.NoError(t, err)\n   151→\tassert.Empty(t, wf.Config[\"container.image\"])\n   152→}\n   153→\n   154→func TestParser_InfersTypeFromContent(t *testing.T) {\n   155→\tinput := `workflow \"infer\" {\n   156→  step build {\n   157→    run = \"make build\"\n   158→    results = [success]\n   159→  }\n   160→  step code {\n   161→    prompt = \"write code\"\n   162→    results = [success]\n   163→  }\n   164→  build:success -> code\n   165→  code:success -> done\n   166→}`\n   167→\n   168→\twf, err := dsl.Parse(input)\n   169→\trequire.NoError(t, err)\n   170→\tassert.Equal(t, domain.StepTypeScript, wf.Steps[\"build\"].Type)\n   171→\tassert.Equal(t, domain.StepTypeAgent, wf.Steps[\"code\"].Type)\n   172→}\n   173→\n   174→func TestParser_AmbiguousStepType(t *testing.T) {\n   175→\tinput := `workflow \"bad\" {\n   176→  step both {\n   177→    run = \"make test\"\n   178→    prompt = \"also a prompt\"\n   179→    results = [success]\n   180→  }\n   181→  both:success -> done\n   182→}`\n   183→\n   184→\t_, err := dsl.Parse(input)\n   185→\tassert.Error(t, err)\n   186→\tassert.Contains(t, err.Error(), \"both\")\n   187→}\n   188→\n   189→func TestParser_NoStepType(t *testing.T) {\n   190→\tinput := `workflow \"bad\" {\n   191→  step neither {\n   192→    results = [success]\n   193→  }\n   194→  neither:success -> done\n   195→}`\n   196→\n   197→\t_, err := dsl.Parse(input)\n   198→\tassert.Error(t, err)\n   199→\tassert.Contains(t, err.Error(), \"neither\")\n   200→}"}]},"parent_tool_use_id":"toolu_01SrdTMeCBVxpeRyCsfQRUZn","session_id":"a5ceff1a-0d2b-4db0-a018-cacf9a2b2a3f","uuid":"476dfdc0-929d-432f-aa8f-031ce4be5399"}
