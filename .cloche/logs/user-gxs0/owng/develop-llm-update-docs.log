{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016XhHFdnVEhkvqCmizAJxu3","type":"tool_result","content":"     1→package grpc\n     2→\n     3→import (\n     4→\t\"bufio\"\n     5→\t\"context\"\n     6→\t\"encoding/json\"\n     7→\t\"fmt\"\n     8→\t\"log\"\n     9→\t\"os\"\n    10→\t\"os/exec\"\n    11→\t\"path/filepath\"\n    12→\t\"strings\"\n    13→\t\"sync\"\n    14→\t\"time\"\n    15→\n    16→\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    17→\t\"github.com/cloche-dev/cloche/internal/adapters/docker\"\n    18→\t\"github.com/cloche-dev/cloche/internal/config\"\n    19→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    20→\t\"github.com/cloche-dev/cloche/internal/evolution\"\n    21→\t\"github.com/cloche-dev/cloche/internal/host\"\n    22→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    23→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    24→\t\"github.com/cloche-dev/cloche/internal/protocol\"\n    25→\trpcgrpc \"google.golang.org/grpc\"\n    26→)\n    27→\n    28→type ClocheServer struct {\n    29→\tpb.UnimplementedClocheServiceServer\n    30→\tstore        ports.RunStore\n    31→\tcaptures     ports.CaptureStore\n    32→\tlogStore     ports.LogStore\n    33→\tcontainer    ports.ContainerRuntime\n    34→\tdefaultImage string\n    35→\tevolution    *evolution.Trigger\n    36→\tlogBroadcast *logstream.Broadcaster\n    37→\tshutdownFn   func()\n    38→\tmu           sync.Mutex\n    39→\trunIDs       map[string]string      // run_id -> container_id\n    40→\tloops        map[string]*host.Loop  // project_dir -> orchestration loop\n    41→}\n    42→\n    43→func NewClocheServer(store ports.RunStore, container ports.ContainerRuntime) *ClocheServer {\n    44→\treturn &ClocheServer{\n    45→\t\tstore:     store,\n    46→\t\tcontainer: container,\n    47→\t\trunIDs:    make(map[string]string),\n    48→\t\tloops:     make(map[string]*host.Loop),\n    49→\t}\n    50→}\n    51→\n    52→func NewClocheServerWithCaptures(store ports.RunStore, captures ports.CaptureStore, container ports.ContainerRuntime, defaultImage string) *ClocheServer {\n    53→\treturn &ClocheServer{\n    54→\t\tstore:        store,\n    55→\t\tcaptures:     captures,\n    56→\t\tcontainer:    container,\n    57→\t\tdefaultImage: defaultImage,\n    58→\t\trunIDs:       make(map[string]string),\n    59→\t\tloops:        make(map[string]*host.Loop),\n    60→\t}\n    61→}\n    62→\n    63→// SetLogStore attaches a log store to the server for indexing extracted log files.\n    64→func (s *ClocheServer) SetLogStore(ls ports.LogStore) {\n    65→\ts.logStore = ls\n    66→}\n    67→\n    68→\n    69→// SetEvolution attaches an evolution trigger to the server.\n    70→func (s *ClocheServer) SetEvolution(trigger *evolution.Trigger) {\n    71→\ts.evolution = trigger\n    72→}\n    73→\n    74→// SetLogBroadcaster attaches a log broadcaster for live-streaming LLM output.\n    75→func (s *ClocheServer) SetLogBroadcaster(b *logstream.Broadcaster) {\n    76→\ts.logBroadcast = b\n    77→}\n    78→\n    79→// SetShutdownFunc sets the callback invoked when the Shutdown RPC is called.\n    80→func (s *ClocheServer) SetShutdownFunc(fn func()) {\n    81→\ts.shutdownFn = fn\n    82→}\n    83→\n    84→func (s *ClocheServer) RunWorkflow(ctx context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error) {\n    85→\tif s.container == nil {\n    86→\t\treturn nil, fmt.Errorf(\"no container runtime configured\")\n    87→\t}\n    88→\n    89→\t// Generate a unique run ID, retrying on collision\n    90→\tvar runID string\n    91→\tfor attempts := 0; attempts < 10; attempts++ {\n    92→\t\trunID = domain.GenerateRunID(req.WorkflowName)\n    93→\t\texisting, err := s.store.GetRun(ctx, runID)\n    94→\t\tif err != nil {\n    95→\t\t\tbreak // ID is free\n    96→\t\t}\n    97→\t\t// Reuse if completed more than 1 hour ago\n    98→\t\tif !existing.CompletedAt.IsZero() && time.Since(existing.CompletedAt) > time.Hour {\n    99→\t\t\t_ = s.store.DeleteRun(ctx, runID)\n   100→\t\t\tbreak\n   101→\t\t}\n   102→\t}\n   103→\n   104→\t// Write prompt to .cloche/<run-id>/prompt.txt (run-specific to avoid conflicts)\n   105→\tif req.Prompt != \"\" {\n   106→\t\tclocheDir := filepath.Join(req.ProjectDir, \".cloche\", runID)\n   107→\t\tif err := os.MkdirAll(clocheDir, 0755); err != nil {\n   108→\t\t\treturn nil, fmt.Errorf(\"creating .cloche dir: %w\", err)\n   109→\t\t}\n   110→\t\tif err := os.WriteFile(filepath.Join(clocheDir, \"prompt.txt\"), []byte(req.Prompt), 0644); err != nil {\n   111→\t\t\treturn nil, fmt.Errorf(\"writing prompt: %w\", err)\n   112→\t\t}\n   113→\t}\n   114→\trun := domain.NewRun(runID, req.WorkflowName)\n   115→\trun.ProjectDir = req.ProjectDir\n   116→\trun.Title = req.Title\n   117→\tif err := s.store.CreateRun(ctx, run); err != nil {\n   118→\t\treturn nil, fmt.Errorf(\"creating run: %w\", err)\n   119→\t}\n   120→\n   121→\t// Resolve image: request-level override, then server default\n   122→\timage := req.Image\n   123→\tif image == \"\" {\n   124→\t\timage = s.defaultImage\n   125→\t}\n   126→\n   127→\t// Launch container start + tracking in background so the RPC returns immediately.\n   128→\t// The run stays in \"pending\" state until the container is up.\n   129→\tgo s.launchAndTrack(runID, image, req.KeepContainer, req)\n   130→\n   131→\treturn &pb.RunWorkflowResponse{RunId: runID}, nil\n   132→}\n   133→\n   134→// launchAndTrack starts the container and then tracks it to completion.\n   135→// It runs in a background goroutine with its own context, independent of the\n   136→// RPC context which may be cancelled after RunWorkflow returns.\n   137→func (s *ClocheServer) launchAndTrack(runID, image string, keepContainer bool, req *pb.RunWorkflowRequest) {\n   138→\tctx := context.Background()\n   139→\n   140→\t// Auto-rebuild image if the project Dockerfile has changed since last build.\n   141→\tif ensurer, ok := s.container.(ports.ImageEnsurer); ok {\n   142→\t\tif err := ensurer.EnsureImage(ctx, req.ProjectDir, image); err != nil {\n   143→\t\t\trun, _ := s.store.GetRun(ctx, runID)\n   144→\t\t\tif run != nil {\n   145→\t\t\t\trun.Fail(fmt.Sprintf(\"failed to ensure image: %v\", err))\n   146→\t\t\t\t_ = s.store.UpdateRun(ctx, run)\n   147→\t\t\t}\n   148→\t\t\tlog.Printf(\"run %s: failed to ensure image: %v\", runID, err)\n   149→\t\t\t\treturn\n   150→\t\t}\n   151→\t}\n   152→\n   153→\tbaseSHA := gitHEAD(req.ProjectDir)\n   154→\n   155→\tcontainerID, err := s.container.Start(ctx, ports.ContainerConfig{\n   156→\t\tImage:        image,\n   157→\t\tWorkflowName: req.WorkflowName,\n   158→\t\tProjectDir:   req.ProjectDir,\n   159→\t\tRunID:        runID,\n   160→\t\tNetworkAllow: []string{\"*\"},\n   161→\t})\n   162→\tif err != nil {\n   163→\t\trun, _ := s.store.GetRun(ctx, runID)\n   164→\t\tif run != nil {\n   165→\t\t\trun.Fail(fmt.Sprintf(\"failed to start container: %v\", err))\n   166→\t\t\t_ = s.store.UpdateRun(ctx, run)\n   167→\t\t}\n   168→\t\tlog.Printf(\"run %s: failed to start container: %v\", runID, err)\n   169→\t\treturn\n   170→\t}\n   171→\n   172→\ts.mu.Lock()\n   173→\ts.runIDs[runID] = containerID\n   174→\ts.mu.Unlock()\n   175→\n   176→\trun, _ := s.store.GetRun(ctx, runID)\n   177→\tif run != nil {\n   178→\t\trun.Start()\n   179→\t\trun.ContainerID = containerID\n   180→\t\trun.BaseSHA = baseSHA\n   181→\t\t_ = s.store.UpdateRun(ctx, run)\n   182→\t}\n   183→\n   184→\ts.trackRun(runID, containerID, req.ProjectDir, req.WorkflowName, keepContainer)\n   185→}\n   186→\n   187→func (s *ClocheServer) trackRun(runID, containerID, projectDir, workflowName string, keepContainer bool) {\n   188→\tctx := context.Background()\n   189→\n   190→\t// Attach to agent output\n   191→\treader, err := s.container.AttachOutput(ctx, containerID)\n   192→\tif err != nil {\n   193→\t\tlog.Printf(\"failed to attach to output for run %s: %v\", runID, err)\n   194→\t\t\treturn\n   195→\t}\n   196→\n   197→\t// Parse JSON-lines status messages\n   198→\tvar reportedResult string // captured from MsgRunCompleted, persisted after branch extraction\n   199→\tscanner := bufio.NewScanner(reader)\n   200→\tfor scanner.Scan() {"}]},"parent_tool_use_id":"toolu_01SrdTMeCBVxpeRyCsfQRUZn","session_id":"a5ceff1a-0d2b-4db0-a018-cacf9a2b2a3f","uuid":"e9c7b897-ee84-4d66-9b5e-cc023e54c6b1"}
