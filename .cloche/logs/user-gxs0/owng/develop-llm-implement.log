{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Gs5eYNfMZWJaC17pWQPdqH","type":"tool_result","content":"     1→package host\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"sync\"\n     6→\t\"sync/atomic\"\n     7→\t\"testing\"\n     8→\t\"time\"\n     9→\n    10→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    11→\t\"github.com/stretchr/testify/assert\"\n    12→)\n    13→\n    14→func TestLoop_StartStop(t *testing.T) {\n    15→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n    16→\tvar called atomic.Int32\n    17→\n    18→\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n    19→\t\tcalled.Add(1)\n    20→\t\t// Simulate a run that finds no work (failed = aborted).\n    21→\t\ttime.Sleep(50 * time.Millisecond)\n    22→\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n    23→\t}\n    24→\n    25→\tloop := NewLoop(LoopConfig{\n    26→\t\tProjectDir:    \"/tmp/test-project\",\n    27→\t\tMaxConcurrent: 1,\n    28→\t}, store, runFn)\n    29→\n    30→\tif loop.Running() {\n    31→\t\tt.Fatal(\"loop should not be running before Start\")\n    32→\t}\n    33→\n    34→\tloop.Start()\n    35→\tif !loop.Running() {\n    36→\t\tt.Fatal(\"loop should be running after Start\")\n    37→\t}\n    38→\n    39→\t// Wait enough time for at least one run to happen.\n    40→\ttime.Sleep(200 * time.Millisecond)\n    41→\tloop.Stop()\n    42→\n    43→\tif loop.Running() {\n    44→\t\tt.Fatal(\"loop should not be running after Stop\")\n    45→\t}\n    46→\n    47→\tif called.Load() < 1 {\n    48→\t\tt.Fatal(\"expected at least one run to be launched\")\n    49→\t}\n    50→}\n    51→\n    52→func TestLoop_RampsUpOnSuccess(t *testing.T) {\n    53→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n    54→\tvar called atomic.Int32\n    55→\n    56→\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n    57→\t\tn := called.Add(1)\n    58→\t\ttime.Sleep(20 * time.Millisecond)\n    59→\t\t// First 3 succeed, then fail (no more work).\n    60→\t\tif n <= 3 {\n    61→\t\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n    62→\t\t}\n    63→\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n    64→\t}\n    65→\n    66→\tloop := NewLoop(LoopConfig{\n    67→\t\tProjectDir:    \"/tmp/test-project\",\n    68→\t\tMaxConcurrent: 1,\n    69→\t}, store, runFn)\n    70→\n    71→\tloop.Start()\n    72→\t// With no backoff between successes, 3 successful + 1 failed should happen fast.\n    73→\ttime.Sleep(300 * time.Millisecond)\n    74→\tloop.Stop()\n    75→\n    76→\tif called.Load() < 4 {\n    77→\t\tt.Fatalf(\"expected at least 4 runs, got %d\", called.Load())\n    78→\t}\n    79→}\n    80→\n    81→func TestLoop_DoubleStartIsNoop(t *testing.T) {\n    82→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n    83→\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n    84→\t\ttime.Sleep(100 * time.Millisecond)\n    85→\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n    86→\t}\n    87→\n    88→\tloop := NewLoop(LoopConfig{\n    89→\t\tProjectDir:    \"/tmp/test-project\",\n    90→\t\tMaxConcurrent: 1,\n    91→\t}, store, runFn)\n    92→\n    93→\tloop.Start()\n    94→\tloop.Start() // Should be a no-op.\n    95→\tloop.Stop()\n    96→}\n    97→\n    98→// fakeTaskAssigner implements TaskAssigner for testing.\n    99→type fakeTaskAssigner struct {\n   100→\tmu    sync.Mutex\n   101→\ttasks []Task\n   102→\tcalls int\n   103→}\n   104→\n   105→func (f *fakeTaskAssigner) ListTasks(_ context.Context, _ string) ([]Task, error) {\n   106→\tf.mu.Lock()\n   107→\tdefer f.mu.Unlock()\n   108→\tf.calls++\n   109→\tresult := make([]Task, len(f.tasks))\n   110→\tcopy(result, f.tasks)\n   111→\treturn result, nil\n   112→}\n   113→\n   114→func TestLoop_TaskAssigner_PassesTaskID(t *testing.T) {\n   115→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   116→\n   117→\tassigner := &fakeTaskAssigner{\n   118→\t\ttasks: []Task{\n   119→\t\t\t{ID: \"task-1\", Title: \"Fix bug\"},\n   120→\t\t\t{ID: \"task-2\", Title: \"Add feature\"},\n   121→\t\t},\n   122→\t}\n   123→\n   124→\tvar receivedTaskIDs []string\n   125→\tvar mu sync.Mutex\n   126→\n   127→\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   128→\t\tmu.Lock()\n   129→\t\treceivedTaskIDs = append(receivedTaskIDs, taskID)\n   130→\t\tmu.Unlock()\n   131→\t\ttime.Sleep(20 * time.Millisecond)\n   132→\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n   133→\t}\n   134→\n   135→\tloop := NewLoop(LoopConfig{\n   136→\t\tProjectDir:    \"/tmp/test-project\",\n   137→\t\tMaxConcurrent: 1,\n   138→\t\tDedupTimeout:  1 * time.Second,\n   139→\t}, store, runFn)\n   140→\tloop.SetTaskAssigner(assigner)\n   141→\n   142→\tloop.Start()\n   143→\ttime.Sleep(200 * time.Millisecond)\n   144→\tloop.Stop()\n   145→\n   146→\tmu.Lock()\n   147→\tdefer mu.Unlock()\n   148→\t// Should have received task-1 first, then task-2 (task-1 is deduped).\n   149→\tassert.GreaterOrEqual(t, len(receivedTaskIDs), 2)\n   150→\tassert.Equal(t, \"task-1\", receivedTaskIDs[0])\n   151→\tassert.Equal(t, \"task-2\", receivedTaskIDs[1])\n   152→}\n   153→\n   154→func TestLoop_TaskAssigner_DedupPreventsReassignment(t *testing.T) {\n   155→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   156→\n   157→\tassigner := &fakeTaskAssigner{\n   158→\t\ttasks: []Task{{ID: \"task-1\"}},\n   159→\t}\n   160→\n   161→\tvar receivedTaskIDs []string\n   162→\tvar mu sync.Mutex\n   163→\n   164→\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   165→\t\tmu.Lock()\n   166→\t\treceivedTaskIDs = append(receivedTaskIDs, taskID)\n   167→\t\tmu.Unlock()\n   168→\t\ttime.Sleep(20 * time.Millisecond)\n   169→\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n   170→\t}\n   171→\n   172→\tloop := NewLoop(LoopConfig{\n   173→\t\tProjectDir:    \"/tmp/test-project\",\n   174→\t\tMaxConcurrent: 1,\n   175→\t\tDedupTimeout:  2 * time.Second, // long enough that task-1 won't be reassigned during test\n   176→\t}, store, runFn)\n   177→\tloop.SetTaskAssigner(assigner)\n   178→\n   179→\tloop.Start()\n   180→\ttime.Sleep(200 * time.Millisecond)\n   181→\tloop.Stop()\n   182→\n   183→\tmu.Lock()\n   184→\tdefer mu.Unlock()\n   185→\t// Only one run should have been launched since task-1 is deduped after first assignment.\n   186→\tassert.Equal(t, 1, len(receivedTaskIDs))\n   187→\tassert.Equal(t, \"task-1\", receivedTaskIDs[0])\n   188→}\n   189→\n   190→func TestLoop_TaskAssigner_DedupExpires(t *testing.T) {\n   191→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   192→\n   193→\tassigner := &fakeTaskAssigner{\n   194→\t\ttasks: []Task{{ID: \"task-1\"}},\n   195→\t}\n   196→\n   197→\tvar receivedTaskIDs []string\n   198→\tvar mu sync.Mutex\n   199→\n   200→\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   201→\t\tmu.Lock()\n   202→\t\treceivedTaskIDs = append(receivedTaskIDs, taskID)\n   203→\t\tmu.Unlock()\n   204→\t\t// Run takes longer than dedup timeout, so by the time the run\n   205→\t\t// completes the dedup window has already expired and pickTask\n   206→\t\t// can re-assign immediately without hitting capacityPollInterval.\n   207→\t\ttime.Sleep(100 * time.Millisecond)\n   208→\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n   209→\t}\n   210→\n   211→\tloop := NewLoop(LoopConfig{\n   212→\t\tProjectDir:    \"/tmp/test-project\",\n   213→\t\tMaxConcurrent: 1,\n   214→\t\tDedupTimeout:  50 * time.Millisecond,\n   215→\t}, store, runFn)\n   216→\tloop.SetTaskAssigner(assigner)\n   217→\n   218→\tloop.Start()\n   219→\ttime.Sleep(500 * time.Millisecond)\n   220→\tloop.Stop()\n   221→\n   222→\tmu.Lock()\n   223→\tdefer mu.Unlock()\n   224→\t// With 50ms dedup and 100ms run time, dedup expires before run completes,\n   225→\t// so task-1 should be assigned multiple times.\n   226→\tassert.GreaterOrEqual(t, len(receivedTaskIDs), 2, \"dedup should have expired, allowing reassignment\")\n   227→\tfor _, id := range receivedTaskIDs {\n   228→\t\tassert.Equal(t, \"task-1\", id)\n   229→\t}\n   230→}\n   231→\n   232→func TestLoop_TaskAssigner_NoTasks_BacksOff(t *testing.T) {\n   233→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   234→\n   235→\tassigner := &fakeTaskAssigner{\n   236→\t\ttasks: nil, // no tasks available\n   237→\t}\n   238→\n   239→\tvar called atomic.Int32\n   240→\n   241→\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   242→\t\tcalled.Add(1)\n   243→\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n   244→\t}\n   245→\n   246→\tloop := NewLoop(LoopConfig{\n   247→\t\tProjectDir:    \"/tmp/test-project\",\n   248→\t\tMaxConcurrent: 1,\n   249→\t}, store, runFn)\n   250→\tloop.SetTaskAssigner(assigner)\n   251→\n   252→\tloop.Start()\n   253→\ttime.Sleep(200 * time.Millisecond)\n   254→\tloop.Stop()\n   255→\n   256→\t// With no tasks, no runs should have been launched.\n   257→\tassert.Equal(t, int32(0), called.Load())\n   258→}\n   259→\n   260→func TestLoop_NoTaskAssigner_EmptyTaskID(t *testing.T) {\n   261→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   262→\n   263→\tvar receivedTaskID string\n   264→\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n   265→\t\treceivedTaskID = taskID\n   266→\t\ttime.Sleep(20 * time.Millisecond)\n   267→\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n   268→\t}\n   269→\n   270→\tloop := NewLoop(LoopConfig{\n   271→\t\tProjectDir:    \"/tmp/test-project\",\n   272→\t\tMaxConcurrent: 1,\n   273→\t}, store, runFn)\n   274→\t// No SetTaskAssigner call — backward compatible mode.\n   275→\n   276→\tloop.Start()\n   277→\ttime.Sleep(200 * time.Millisecond)\n   278→\tloop.Stop()\n   279→\n   280→\t// Without a task assigner, taskID should be empty.\n   281→\tassert.Empty(t, receivedTaskID)\n   282→}\n   283→"}]},"parent_tool_use_id":"toolu_01Ridt9FPsfSuyMKMzddcvoS","session_id":"84afe276-0872-4aba-bc33-ed0e3777b6c9","uuid":"0445fd88-0348-44a6-ab2d-a2761d40aae2"}
