eep(20 * time.Millisecond)\n    59→\t\t// First 3 succeed, then fail (no more work).\n    60→\t\tif n <= 3 {\n    61→\t\t\treturn &RunResult{State: domain.RunStateSucceeded}, nil\n    62→\t\t}\n    63→\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n    64→\t}\n    65→\n    66→\tloop := NewLoop(LoopConfig{\n    67→\t\tProjectDir:    \"/tmp/test-project\",\n    68→\t\tMaxConcurrent: 1,\n    69→\t}, store, runFn)\n    70→\n    71→\tloop.Start()\n    72→\t// With no backoff between successes, 3 successful + 1 failed should happen fast.\n    73→\ttime.Sleep(300 * time.Millisecond)\n    74→\tloop.Stop()\n    75→\n    76→\tif called.Load() < 4 {\n    77→\t\tt.Fatalf(\"expected at least 4 runs, got %d\", called.Load())\n    78→\t}\n    79→}\n    80→\n    81→func TestLoop_DoubleStartIsNoop(t *testing.T) {\n    82→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n    83→\trunFn := func(ctx context.Context, projectDir string, taskID string) (*RunResult, error) {\n    84→\t\ttime.Sleep(100 * time.Millisecond)\n    85→\t\treturn &RunResult{State: domain.RunStateFailed}, nil\n    86→\t}\n    87→\n    88→\tloop := NewLoop(LoopConfig{\n    89→\t\tProjectDir:    \"/tmp/test-project\",\n    90→\t\tMaxConcurrent: 1,\n    91→\t}, store, runFn)\n    92→\n    93→\tloop.Start()\n    94→\tloop.Start() // Should be a no-op.\n    95→\tloop.Stop()\n    96→}\n    97→\n    98→// fakeTaskAssigner implements TaskAssigner for testing.\n    99→type fakeTaskAssigner struct {\n   100→\tmu    sync.Mutex\n   101→\ttasks []Task\n   102→\tcalls int\n   103→}\n   104→\n   105→func (f *fakeTaskAssigner) ListTasks(_ context.Context, _ string) ([]Task, error) {\n   106→\tf.mu.Lock()\n   107→\tdefer f.mu.Unlock()\n   108→\tf.calls++\n   109→\tresult := make([]Task, len(f.tasks))\n   110→\tcopy(result, f.tasks)\n   111→\treturn result, nil\n   112→}\n   113→\n   114→func TestLoop_TaskAssigner_PassesTaskID(t *testing.T) {\n   115→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   116→\n   