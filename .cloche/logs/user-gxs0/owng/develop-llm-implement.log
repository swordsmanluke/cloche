{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01B7mSc1vz3b86tmaghfqJfj","type":"tool_result","content":"     1→package dsl\n     2→\n     3→import (\n     4→\t\"fmt\"\n     5→\t\"strconv\"\n     6→\t\"strings\"\n     7→\n     8→\t\"github.com/cloche-dev/cloche/internal/domain\"\n     9→)\n    10→\n    11→type Parser struct {\n    12→\tlexer    *Lexer\n    13→\tcurrent  Token\n    14→\tpeek     Token\n    15→\tlocation domain.WorkflowLocation\n    16→}\n    17→\n    18→// ParseOption configures the parser.\n    19→type ParseOption func(*Parser)\n    20→\n    21→// WithLocation sets the workflow location, enabling location-based validation.\n    22→func WithLocation(loc domain.WorkflowLocation) ParseOption {\n    23→\treturn func(p *Parser) {\n    24→\t\tp.location = loc\n    25→\t}\n    26→}\n    27→\n    28→func Parse(input string, opts ...ParseOption) (*domain.Workflow, error) {\n    29→\tp := &Parser{lexer: NewLexer(input)}\n    30→\tfor _, opt := range opts {\n    31→\t\topt(p)\n    32→\t}\n    33→\tp.advance() // load current\n    34→\tp.advance() // load peek\n    35→\treturn p.parseWorkflow()\n    36→}\n    37→\n    38→// ParseForHost parses a host.cloche file.\n    39→func ParseForHost(input string) (*domain.Workflow, error) {\n    40→\treturn Parse(input, WithLocation(domain.LocationHost))\n    41→}\n    42→\n    43→// ParseForContainer parses a container workflow file.\n    44→func ParseForContainer(input string) (*domain.Workflow, error) {\n    45→\treturn Parse(input, WithLocation(domain.LocationContainer))\n    46→}\n    47→\n    48→func (p *Parser) advance() {\n    49→\tp.current = p.peek\n    50→\tp.peek = p.lexer.NextToken()\n    51→}\n    52→\n    53→func (p *Parser) expect(typ TokenType) (Token, error) {\n    54→\tif p.current.Type != typ {\n    55→\t\treturn p.current, fmt.Errorf(\"line %d col %d: expected %v, got %v (%q)\",\n    56→\t\t\tp.current.Line, p.current.Col, typ, p.current.Type, p.current.Literal)\n    57→\t}\n    58→\ttok := p.current\n    59→\tp.advance()\n    60→\treturn tok, nil\n    61→}\n    62→\n    63→func (p *Parser) expectIdent(value string) (Token, error) {\n    64→\tif p.current.Type != TokenIdent || p.current.Literal != value {\n    65→\t\treturn p.current, fmt.Errorf(\"line %d col %d: expected %q, got %q\",\n    66→\t\t\tp.current.Line, p.current.Col, value, p.current.Literal)\n    67→\t}\n    68→\ttok := p.current\n    69→\tp.advance()\n    70→\treturn tok, nil\n    71→}\n    72→\n    73→func (p *Parser) parseWorkflow() (*domain.Workflow, error) {\n    74→\tif _, err := p.expectIdent(\"workflow\"); err != nil {\n    75→\t\treturn nil, err\n    76→\t}\n    77→\n    78→\tnameTok, err := p.expect(TokenString)\n    79→\tif err != nil {\n    80→\t\treturn nil, fmt.Errorf(\"expected workflow name string: %w\", err)\n    81→\t}\n    82→\n    83→\tif _, err := p.expect(TokenLBrace); err != nil {\n    84→\t\treturn nil, err\n    85→\t}\n    86→\n    87→\twf := &domain.Workflow{\n    88→\t\tName:     nameTok.Literal,\n    89→\t\tLocation: p.location,\n    90→\t\tSteps:    make(map[string]*domain.Step),\n    91→\t\tConfig:   make(map[string]string),\n    92→\t}\n    93→\n    94→\tfor p.current.Type != TokenRBrace && p.current.Type != TokenEOF {\n    95→\t\tif p.current.Type == TokenIdent && p.current.Literal == \"step\" {\n    96→\t\t\tstep, err := p.parseStep()\n    97→\t\t\tif err != nil {\n    98→\t\t\t\treturn nil, err\n    99→\t\t\t}\n   100→\t\t\twf.Steps[step.Name] = step\n   101→\t\t\tif wf.EntryStep == \"\" {\n   102→\t\t\t\twf.EntryStep = step.Name\n   103→\t\t\t}\n   104→\t\t} else if p.current.Type == TokenIdent && p.current.Literal == \"collect\" {\n   105→\t\t\tcollect, err := p.parseCollect()\n   106→\t\t\tif err != nil {\n   107→\t\t\t\treturn nil, err\n   108→\t\t\t}\n   109→\t\t\twf.Collects = append(wf.Collects, collect)\n   110→\t\t} else if p.current.Type == TokenIdent && p.peek.Type == TokenLBrace {\n   111→\t\t\tif err := p.parseWorkflowConfig(wf); err != nil {\n   112→\t\t\t\treturn nil, err\n   113→\t\t\t}\n   114→\t\t} else if p.current.Type == TokenIdent && p.peek.Type == TokenColon {\n   115→\t\t\twire, err := p.parseWire()\n   116→\t\t\tif err != nil {\n   117→\t\t\t\treturn nil, err\n   118→\t\t\t}\n   119→\t\t\twf.Wiring = append(wf.Wiring, wire)\n   120→\t\t} else {\n   121→\t\t\treturn nil, fmt.Errorf(\"line %d col %d: unexpected token %q\", p.current.Line, p.current.Col, p.current.Literal)\n   122→\t\t}\n   123→\t}\n   124→\n   125→\tif _, err := p.expect(TokenRBrace); err != nil {\n   126→\t\treturn nil, err\n   127→\t}\n   128→\n   129→\tif wf.Location != \"\" {\n   130→\t\tif err := wf.ValidateLocation(); err != nil {\n   131→\t\t\treturn nil, err\n   132→\t\t}\n   133→\t}\n   134→\n   135→\treturn wf, nil\n   136→}\n   137→\n   138→func (p *Parser) parseWorkflowConfig(wf *domain.Workflow) error {\n   139→\tprefix := p.current.Literal // e.g. \"container\"\n   140→\tp.advance()                 // consume prefix ident\n   141→\n   142→\tif _, err := p.expect(TokenLBrace); err != nil {\n   143→\t\treturn err\n   144→\t}\n   145→\n   146→\tfor p.current.Type != TokenRBrace && p.current.Type != TokenEOF {\n   147→\t\tkeyTok, err := p.expect(TokenIdent)\n   148→\t\tif err != nil {\n   149→\t\t\treturn fmt.Errorf(\"expected field name: %w\", err)\n   150→\t\t}"}]},"parent_tool_use_id":"toolu_01Ridt9FPsfSuyMKMzddcvoS","session_id":"84afe276-0872-4aba-bc33-ed0e3777b6c9","uuid":"220a6a77-a418-4b6f-96c6-54201132b8ee"}
