/host.cloche and executes the full host workflow step by step.\n   198→func autoRunActiveProjects(store ports.RunStore, srv *adaptgrpc.ClocheServer) {\n   199→\tctx := context.Background()\n   200→\tprojects, err := store.ListProjects(ctx)\n   201→\tif err != nil {\n   202→\t\tfmt.Fprintf(os.Stderr, \"startup: failed to list projects: %v\\n\", err)\n   203→\t\treturn\n   204→\t}\n   205→\n   206→\tfor _, projectDir := range projects {\n   207→\t\tcfg, err := config.Load(projectDir)\n   208→\t\tif err != nil || !cfg.Active {\n   209→\t\t\tcontinue\n   210→\t\t}\n   211→\n   212→\t\t// Verify host.cloche exists before launching\n   213→\t\thostPath := filepath.Join(projectDir, \".cloche\", \"host.cloche\")\n   214→\t\tif _, err := os.Stat(hostPath); err != nil {\n   215→\t\t\tfmt.Fprintf(os.Stderr, \"startup: skipping active project %s: %v\\n\", projectDir, err)\n   216→\t\t\tcontinue\n   217→\t\t}\n   218→\n   219→\t\tfmt.Fprintf(os.Stderr, \"startup: auto-running host workflow for active project %s\\n\", projectDir)\n   220→\t\tgo func(projDir string) {\n   221→\t\t\trunner := &hostpkg.Runner{\n   222→\t\t\t\tDispatcher: srv,\n   223→\t\t\t\tStore:      store,\n   224→\t\t\t}\n   225→\t\t\tresult, err := runner.Run(context.Background(), projDir)\n   226→\t\t\tif err != nil {\n   227→\t\t\t\tfmt.Fprintf(os.Stderr, \"startup: host workflow failed for %s: %v\\n\", projDir, err)\n   228→\t\t\t} else {\n   229→\t\t\t\tfmt.Fprintf(os.Stderr, \"startup: host workflow completed for %s: %s (run %s)\\n\", projDir, result.State, result.RunID)\n   230→\t\t\t}\n   231→\t\t}(projectDir)\n   232→\t}\n   233→}\n   234→\n   235→// envOrConfig returns the env var value if set, otherwise the config file\n   236→// value if non-empty, otherwise the fallback default.\n   237→func envOrConfig(envKey, configVal, fallback string) string {\n   238→\tif v := os.Getenv(envKey); v != \"\" {\n   239→\t\treturn v\n   240→\t}\n   241→\tif configVal != \"\" {\n   242→\t\treturn configVal\n   243→\