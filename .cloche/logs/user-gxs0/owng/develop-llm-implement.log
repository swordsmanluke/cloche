rkflow\n- `createPhaseLoop()` wires up list-tasks → main → finalize using `Runner.RunNamed()`\n- Finalize receives `CLOCHE_MAIN_RUN_ID` and `CLOCHE_MAIN_OUTCOME` env vars\n- Falls back to legacy single-function mode when no list-tasks workflow exists\n\n### Tests Added\n- JSONL parsing: basic, metadata, empty lines, error handling, all statuses\n- `Task.IsOpen()`: all status variants\n- `ParseAllForHost`: single, multiple, duplicate names, empty, location validation\n- `RunNamed`: main, multi-workflow, not-found error\n- `ExtraEnv`: executor-level and runner-level propagation\n- `ReadListTasksOutput`: basic, empty dir, picks latest file\n- Phase loop: basic flow, skips closed tasks, finalize on failure, no finalize, dedup filtering\n\nCLOCHE_RESULT:success","stop_reason":"end_turn","session_id":"84afe276-0872-4aba-bc33-ed0e3777b6c9","total_cost_usd":4.56413415,"usage":{"input_tokens":51,"cache_creation_input_tokens":140047,"cache_read_input_tokens":4975395,"output_tokens":41666,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":140047,"ephemeral_5m_input_tokens":0},"inference_geo":"","iterations":[],"speed":"standard"},"modelUsage":{"claude-opus-4-6":{"inputTokens":51,"outputTokens":41666,"cacheReadInputTokens":4975395,"cacheCreationInputTokens":140047,"webSearchRequests":0,"costUSD":4.40489625,"contextWindow":200000,"maxOutputTokens":32000},"claude-haiku-4-5-20251001":{"inputTokens":69,"outputTokens":6113,"cacheReadInputTokens":735614,"cacheCreationInputTokens":44034,"webSearchRequests":0,"costUSD":0.1592379,"contextWindow":200000,"maxOutputTokens":32000}},"permission_denials":[],"fast_mode_state":"off","uuid":"7b664be1-83ec-4951-a30a-1f9cc7c41df4"}
