{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AjTGNVzmAEpCT29XbAWiD7","type":"tool_result","content":"     1→package host\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"fmt\"\n     6→\t\"log\"\n     7→\t\"os\"\n     8→\t\"os/exec\"\n     9→\t\"path/filepath\"\n    10→\t\"strings\"\n    11→\t\"time\"\n    12→\n    13→\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    14→\t\"github.com/cloche-dev/cloche/internal/adapters/agents/prompt\"\n    15→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    16→\t\"github.com/cloche-dev/cloche/internal/engine\"\n    17→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    18→\t\"github.com/cloche-dev/cloche/internal/protocol\"\n    19→)\n    20→\n    21→// resolveOutputMappings finds all wires targeting stepName that have output mappings,\n    22→// reads the source step's output, evaluates each mapping path, and returns KEY=value\n    23→// strings suitable for adding to a command's environment.\n    24→func (e *Executor) resolveOutputMappings(stepName string, wires []domain.Wire) ([]string, error) {\n    25→\tvar env []string\n    26→\tfor _, w := range wires {\n    27→\t\tif w.To != stepName || len(w.OutputMap) == 0 {\n    28→\t\t\tcontinue\n    29→\t\t}\n    30→\t\tdata, err := os.ReadFile(e.stepOutputPath(w.From))\n    31→\t\tif err != nil {\n    32→\t\t\treturn nil, fmt.Errorf(\"reading output of %s: %w\", w.From, err)\n    33→\t\t}\n    34→\t\tfor _, m := range w.OutputMap {\n    35→\t\t\tval, err := m.Path.Evaluate(data)\n    36→\t\t\tif err != nil {\n    37→\t\t\t\treturn nil, fmt.Errorf(\"mapping %s for step %s: %w\", m.EnvVar, stepName, err)\n    38→\t\t\t}\n    39→\t\t\tenv = append(env, m.EnvVar+\"=\"+val)\n    40→\t\t}\n    41→\t}\n    42→\treturn env, nil\n    43→}\n    44→\n    45→// RunDispatcher dispatches a container workflow run and returns the run ID.\n    46→type RunDispatcher interface {\n    47→\tRunWorkflow(ctx context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error)\n    48→}\n    49→\n    50→// Executor implements engine.StepExecutor for host workflow steps.\n    51→type Executor struct {\n    52→\tProjectDir    string\n    53→\tMainDir       string         // main branch worktree dir; scripts execute from here\n    54→\tDispatcher    RunDispatcher\n    55→\tStore         ports.RunStore\n    56→\tOutputDir     string         // directory for step output files\n    57→\tWires         []domain.Wire  // workflow wiring (for output mappings)\n    58→\tHostRunID     string         // ID of the parent host run (set on child runs)\n    59→\tAgentCommands []string       // workflow-level agent command fallback chain\n    60→\tAgentArgs     []string       // workflow-level explicit agent args (overrides defaults)\n    61→\tTaskID        string         // optional task ID assigned by the daemon loop\n    62→}\n    63→\n    64→// scriptDir returns the directory from which scripts should execute.\n    65→// Uses MainDir if set, otherwise falls back to ProjectDir.\n    66→func (e *Executor) scriptDir() string {\n    67→\tif e.MainDir != \"\" {\n    68→\t\treturn e.MainDir\n    69→\t}\n    70→\treturn e.ProjectDir\n    71→}\n    72→\n    73→var _ engine.StepExecutor = (*Executor)(nil)\n    74→\n    75→// Execute runs a single host workflow step.\n    76→func (e *Executor) Execute(ctx context.Context, step *domain.Step) (string, error) {\n    77→\tswitch step.Type {\n    78→\tcase domain.StepTypeScript:\n    79→\t\treturn e.executeScript(ctx, step)\n    80→\tcase domain.StepTypeWorkflow:\n    81→\t\treturn e.executeWorkflow(ctx, step)\n    82→\tcase domain.StepTypeAgent:\n    83→\t\treturn e.executeAgent(ctx, step)\n    84→\tdefault:\n    85→\t\treturn \"\", fmt.Errorf(\"unsupported step type %q in host workflow\", step.Type)\n    86→\t}\n    87→}\n    88→\n    89→// executeScript runs a shell command on the host.\n    90→func (e *Executor) executeScript(ctx context.Context, step *domain.Step) (string, error) {\n    91→\tcmdStr := step.Config[\"run\"]\n    92→\tcmd := exec.CommandContext(ctx, \"sh\", \"-c\", cmdStr)\n    93→\tcmd.Dir = e.scriptDir()\n    94→\tcmd.Env = append(os.Environ(),\n    95→\t\t\"CLOCHE_PROJECT_DIR=\"+e.ProjectDir,\n    96→\t\t\"CLOCHE_STEP_OUTPUT=\"+e.stepOutputPath(step.Name),\n    97→\t)\n    98→\n    99→\t// Pass daemon-assigned task ID if available\n   100→\tif e.TaskID != \"\" {\n   101→\t\tcmd.Env = append(cmd.Env, \"CLOCHE_TASK_ID=\"+e.TaskID)\n   102→\t}\n   103→\n   104→\t// Pass previous step output if available\n   105→\tif prevOutput := e.findPrevOutput(step); prevOutput != \"\" {\n   106→\t\tcmd.Env = append(cmd.Env, \"CLOCHE_PREV_OUTPUT=\"+prevOutput)\n   107→\t}\n   108→\n   109→\t// Resolve output mappings from wires and add as env vars\n   110→\tif len(e.Wires) > 0 {\n   111→\t\tmapped, err := e.resolveOutputMappings(step.Name, e.Wires)\n   112→\t\tif err != nil {\n   113→\t\t\treturn \"\", fmt.Errorf(\"resolving output mappings for step %q: %w\", step.Name, err)\n   114→\t\t}\n   115→\t\tcmd.Env = append(cmd.Env, mapped...)\n   116→\t}\n   117→\n   118→\toutput, err := cmd.CombinedOutput()\n   119→\n   120→\t// Extract result marker\n   121→\tmarkerResult, cleanOutput, found := protocol.ExtractResult(output)\n   122→\n   123→\t// Write output to file\n   124→\tif mkErr := os.MkdirAll(e.OutputDir, 0755); mkErr == nil {\n   125→\t\t_ = os.WriteFile(e.stepOutputPath(step.Name), cleanOutput, 0644)\n   126→\t}\n   127→\n   128→\tif err != nil {\n   129→\t\tif _, ok := err.(*exec.ExitError); ok {\n   130→\t\t\tresult := \"fail\"\n   131→\t\t\tif found {\n   132→\t\t\t\tresult = markerResult\n   133→\t\t\t}\n   134→\t\t\treturn result, nil\n   135→\t\t}\n   136→\t\treturn \"\", err\n   137→\t}\n   138→\n   139→\tresult := \"success\"\n   140→\tif found {\n   141→\t\tresult = markerResult\n   142→\t}\n   143→\treturn result, nil\n   144→}\n   145→\n   146→// executeWorkflow dispatches a container workflow run and blocks until it completes.\n   147→func (e *Executor) executeWorkflow(ctx context.Context, step *domain.Step) (string, error) {\n   148→\tworkflowName := step.Config[\"workflow_name\"]\n   149→\tif workflowName == \"\" {\n   150→\t\treturn \"\", fmt.Errorf(\"workflow step %q missing workflow_name\", step.Name)\n   151→\t}\n   152→\n   153→\t// Read prompt from previous step output or prompt_step override\n   154→\tvar promptContent string\n   155→\tpromptSource := step.Config[\"prompt_step\"]\n   156→\tif promptSource != \"\" {\n   157→\t\tdata, err := os.ReadFile(e.stepOutputPath(promptSource))\n   158→\t\tif err == nil {\n   159→\t\t\tpromptContent = string(data)\n   160→\t\t}\n   161→\t} else if prev := e.findPrevOutput(step); prev != \"\" {\n   162→\t\tdata, err := os.ReadFile(prev)\n   163→\t\tif err == nil {\n   164→\t\t\tpromptContent = string(data)\n   165→\t\t}\n   166→\t}\n   167→\n   168→\tresp, err := e.Dispatcher.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n   169→\t\tWorkflowName: workflowName,\n   170→\t\tProjectDir:   e.ProjectDir,\n   171→\t\tPrompt:       promptContent,\n   172→\t})\n   173→\tif err != nil {\n   174→\t\treturn \"\", fmt.Errorf(\"dispatching workflow %q: %w\", workflowName, err)\n   175→\t}\n   176→\n   177→\tlog.Printf(\"host executor: dispatched container workflow %q as run %s\", workflowName, resp.RunId)\n   178→\n   179→\t// Link child run to parent host run\n   180→\tif e.HostRunID != \"\" {\n   181→\t\tif childRun, err := e.Store.GetRun(ctx, resp.RunId); err == nil {\n   182→\t\t\tchildRun.ParentRunID = e.HostRunID\n   183→\t\t\t_ = e.Store.UpdateRun(ctx, childRun)\n   184→\t\t}\n   185→\t}\n   186→\n   187→\t// Write run ID to step output so downstream steps (e.g. merge) can find it\n   188→\tif mkErr := os.MkdirAll(e.OutputDir, 0755); mkErr == nil {\n   189→\t\t_ = os.WriteFile(e.stepOutputPath(step.Name), []byte(resp.RunId), 0644)\n   190→\t}\n   191→\n   192→\t// Poll until the run reaches a terminal state\n   193→\tstate, err := e.waitForRun(ctx, resp.RunId)\n   194→\tif err != nil {\n   195→\t\treturn \"\", fmt.Errorf(\"waiting for workflow %q run %s: %w\", workflowName, resp.RunId, err)\n   196→\t}\n   197→\n   198→\tlog.Printf(\"host executor: workflow %q run %s completed with state %s\", workflowName, resp.RunId, state)\n   199→\n   200→\t// Map run state to step result\n   201→\tif state == domain.RunStateSucceeded {\n   202→\t\treturn \"success\", nil\n   203→\t}\n   204→\treturn \"fail\", nil\n   205→}\n   206→\n   207→// executeAgent runs an agent command on the host using the prompt adapter.\n   208→func (e *Executor) executeAgent(ctx context.Context, step *domain.Step) (string, error) {\n   209→\tadapter := prompt.New()\n   210→\n   211→\t// Apply workflow-level agent config\n   212→\tif len(e.AgentCommands) > 0 {\n   213→\t\tadapter.Commands = e.AgentCommands\n   214→\t}\n   215→\tif len(e.AgentArgs) > 0 {\n   216→\t\tadapter.ExplicitArgs = e.AgentArgs\n   217→\t}\n   218→\n   219→\t// Step-level overrides\n   220→\tif cmd := step.Config[\"agent_command\"]; cmd != \"\" {\n   221→\t\tadapter.Commands = prompt.ParseCommands(cmd)\n   222→\t}\n   223→\tif args := step.Config[\"agent_args\"]; args != \"\" {\n   224→\t\tadapter.ExplicitArgs = strings.Fields(args)\n   225→\t}\n   226→\n   227→\tadapter.RunID = e.HostRunID\n   228→\n   229→\t// Write previous step output as user prompt so the adapter can pick it up.\n   230→\tvar promptContent string\n   231→\tpromptSource := step.Config[\"prompt_step\"]\n   232→\tif promptSource != \"\" {\n   233→\t\tif data, err := os.ReadFile(e.stepOutputPath(promptSource)); err == nil {\n   234→\t\t\tpromptContent = string(data)\n   235→\t\t}\n   236→\t} else if prev := e.findPrevOutput(step); prev != \"\" {\n   237→\t\tif data, err := os.ReadFile(prev); err == nil {\n   238→\t\t\tpromptContent = string(data)\n   239→\t\t}\n   240→\t}\n   241→\n   242→\tif promptContent != \"\" {\n   243→\t\tpromptDir := filepath.Join(e.ProjectDir, \".cloche\", e.HostRunID)\n   244→\t\t_ = os.MkdirAll(promptDir, 0755)\n   245→\t\t_ = os.WriteFile(filepath.Join(promptDir, \"prompt.txt\"), []byte(promptContent), 0644)\n   246→\t}\n   247→\n   248→\tresult, err := adapter.Execute(ctx, step, e.ProjectDir)\n   249→\tif err != nil {\n   250→\t\treturn \"\", err\n   251→\t}\n   252→\n   253→\t// Copy output from adapter's output location to executor's output path\n   254→\tadapterOutput := filepath.Join(e.ProjectDir, \".cloche\", \"output\", step.Name+\".log\")\n   255→\tif data, readErr := os.ReadFile(adapterOutput); readErr == nil {\n   256→\t\tif mkErr := os.MkdirAll(e.OutputDir, 0755); mkErr == nil {\n   257→\t\t\t_ = os.WriteFile(e.stepOutputPath(step.Name), data, 0644)\n   258→\t\t}\n   259→\t}\n   260→\n   261→\treturn result, nil\n   262→}\n   263→\n   264→// waitForRun polls the store until the run reaches a terminal state.\n   265→func (e *Executor) waitForRun(ctx context.Context, runID string) (domain.RunState, error) {\n   266→\tticker := time.NewTicker(2 * time.Second)\n   267→\tdefer ticker.Stop()\n   268→\n   269→\tfor {\n   270→\t\tselect {\n   271→\t\tcase <-ctx.Done():\n   272→\t\t\treturn \"\", fmt.Errorf(\"context cancelled while waiting for run %s: %w\", runID, ctx.Err())\n   273→\t\tcase <-ticker.C:\n   274→\t\t\trun, err := e.Store.GetRun(ctx, runID)\n   275→\t\t\tif err != nil {\n   276→\t\t\t\tcontinue // transient error, retry\n   277→\t\t\t}\n   278→\t\t\tswitch run.State {\n   279→\t\t\tcase domain.RunStateSucceeded, domain.RunStateFailed, domain.RunStateCancelled:\n   280→\t\t\t\treturn run.State, nil\n   281→\t\t\t}\n   282→\t\t\t// Still pending or running, continue polling\n   283→\t\t}\n   284→\t}\n   285→}\n   286→\n   287→// stepOutputPath returns the path for a step's output file.\n   288→func (e *Executor) stepOutputPath(stepName string) string {\n   289→\treturn filepath.Join(e.OutputDir, stepName+\".out\")\n   290→}\n   291→\n   292→// findPrevOutput finds the output file from the step that wires into this one.\n   293→// It checks prompt_step config first, then walks the wiring graph to find the\n   294→// source step.\n   295→func (e *Executor) findPrevOutput(step *domain.Step) string {\n   296→\t// Explicit prompt_step config takes priority\n   297→\tif ps := step.Config[\"prompt_step\"]; ps != \"\" {\n   298→\t\tpath := e.stepOutputPath(ps)\n   299→\t\tif _, err := os.Stat(path); err == nil {\n   300→\t\t\treturn path\n   301→\t\t}\n   302→\t}\n   303→\n   304→\t// Walk wiring to find the step that feeds into this one\n   305→\tfor _, w := range e.Wires {\n   306→\t\tif w.To == step.Name {\n   307→\t\t\tpath := e.stepOutputPath(w.From)\n   308→\t\t\tif _, err := os.Stat(path); err == nil {\n   309→\t\t\t\treturn path\n   310→\t\t\t}\n   311→\t\t}\n   312→\t}\n   313→\treturn \"\"\n   314→}\n   315→\n   316→// MainWorktreeDir returns the path of the main (non-linked) git worktree for\n   317→// the repository containing projectDir. If projectDir is already the main\n   318→// worktree, it returns projectDir unchanged. Falls back to projectDir on any\n   319→// error (e.g. not a git repo).\n   320→func MainWorktreeDir(projectDir string) string {\n   321→\tcmd := exec.Command(\"git\", \"-C\", projectDir, \"worktree\", \"list\", \"--porcelain\")\n   322→\tout, err := cmd.Output()\n   323→\tif err != nil {\n   324→\t\treturn projectDir\n   325→\t}\n   326→\t// The first \"worktree <path>\" line is always the main worktree.\n   327→\tfor _, line := range strings.Split(string(out), \"\\n\") {\n   328→\t\tif strings.HasPrefix(line, \"worktree \") {\n   329→\t\t\treturn strings.TrimPrefix(line, \"worktree \")\n   330→\t\t}\n   331→\t}\n   332→\treturn projectDir\n   333→}\n   334→"}]},"parent_tool_use_id":"toolu_01Ridt9FPsfSuyMKMzddcvoS","session_id":"84afe276-0872-4aba-bc33-ed0e3777b6c9","uuid":"7f0d86a4-f083-4bc8-a503-533e6c18ac99"}
