the updated prompt content`\n\n\tuserPrompt := fmt.Sprintf(\"## Current Prompt Content\\n```\\n%s\\n```\\n\\n## Lesson to Merge\\nInsight: %s\\nSuggested Action: %s\",\n\t\tstring(current), lesson.Insight, lesson.SuggestedAction)\n\n\tupdated, err := c.LLM.Complete(ctx, systemPrompt, userPrompt)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"curator LLM call: %w\", err)\n\t}\n\n\t// Snapshot before writing\n\tvar snapName string\n\tif c.Audit != nil {\n\t\tsnapName, _ = c.Audit.Snapshot(lesson.Target)\n\t}\n\n\tif err := os.WriteFile(targetPath, []byte(updated), 0644); err != nil {\n\t\treturn nil, fmt.Errorf(\"writing updated prompt: %w\", err)\n\t}\n\n\treturn &Change{\n\t\tType:     \"prompt_update\",\n\t\tFile:     lesson.Target,\n\t\tReason:   lesson.Insight,\n\t\tSnapshot: snapName,\n\t}, nil\n}\n","structuredPatch":[{"oldStart":36,"oldLines":11,"newStart":36,"newLines":13,"lines":["   userPrompt := fmt.Sprintf(\"## Current Prompt Content\\n```\\n%s\\n```\\n\\n## Lesson to Merge\\nInsight: %s\\nSuggested Action: %s\",","     string(current), lesson.Insight, lesson.SuggestedAction)"," ","-  updated, err := c.LLM.Complete(ctx, systemPrompt, userPrompt)","+  raw, err := c.LLM.Complete(ctx, systemPrompt, userPrompt)","   if err != nil {","     return nil, fmt.Errorf(\"curator LLM call: %w\", err)","   }"," ","+  updated := stripCodeFences(raw)","+","   // Snapshot before writing","   var snapName string","   if c.Audit != nil {"]}],"userModified":false,"replaceAll":false}}
