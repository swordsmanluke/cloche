LLM.Complete(ctx, systemPrompt, userPrompt)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"curator LLM call: %w\", err)\n\t}\n\n\t// Snapshot before writing\n\tvar snapName string\n\tif c.Audit != nil {\n\t\tsnapName, _ = c.Audit.Snapshot(lesson.Target)\n\t}\n\n\tif err := os.WriteFile(targetPath, []byte(updated), 0644); err != nil {\n\t\treturn nil, fmt.Errorf(\"writing updated prompt: %w\", err)\n\t}\n\n\treturn &Change{\n\t\tType:     \"prompt_update\",\n\t\tFile:     lesson.Target,\n\t\tReason:   lesson.Insight,\n\t\tSnapshot: snapName,\n\t}, nil\n}\n","structuredPatch":[{"oldStart":5,"oldLines":6,"newStart":5,"newLines":7,"lines":["   \"fmt\"","   \"os\"","   \"path/filepath\"","+  \"strings\""," )"," "," // Curator merges lessons into prompt files using ACE-style curation."]}],"userModified":false,"replaceAll":false}}
