{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018pxEFjTZrpwi6VYtm2Gv7x","type":"tool_result","content":"     1→package dsl\n     2→\n     3→import (\n     4→\t\"testing\"\n     5→\n     6→\t\"github.com/stretchr/testify/assert\"\n     7→\t\"github.com/stretchr/testify/require\"\n     8→)\n     9→\n    10→func TestMutatorAddStep(t *testing.T) {\n    11→\tinput := `workflow \"develop\" {\n    12→  step test {\n    13→    run = \"make test\"\n    14→    results = [success, fail]\n    15→  }\n    16→\n    17→  test:success -> done\n    18→  test:fail -> abort\n    19→}`\n    20→\n    21→\tm := &Mutator{}\n    22→\tresult, err := m.AddStep(input, StepDef{\n    23→\t\tName:    \"security-scan\",\n    24→\t\tType:    \"script\",\n    25→\t\tConfig:  map[string]string{\"run\": `\"gosec ./...\"`},\n    26→\t\tResults: []string{\"success\", \"fail\"},\n    27→\t})\n    28→\trequire.NoError(t, err)\n    29→\tassert.Contains(t, result, \"step security-scan\")\n    30→\tassert.Contains(t, result, `run = \"gosec ./...\"`)\n    31→\tassert.Contains(t, result, \"results = [success, fail]\")\n    32→\n    33→\t// Verify the result still parses\n    34→\twf, err := Parse(result)\n    35→\trequire.NoError(t, err)\n    36→\tassert.Contains(t, wf.Steps, \"security-scan\")\n    37→\tassert.Equal(t, \"script\", string(wf.Steps[\"security-scan\"].Type))\n    38→}\n    39→\n    40→func TestMutatorAddStepAgent(t *testing.T) {\n    41→\tinput := `workflow \"develop\" {\n    42→  step test {\n    43→    run = \"make test\"\n    44→    results = [success, fail]\n    45→  }\n    46→\n    47→  test:success -> done\n    48→  test:fail -> abort\n    49→}`\n    50→\n    51→\tm := &Mutator{}\n    52→\tresult, err := m.AddStep(input, StepDef{\n    53→\t\tName:    \"review\",\n    54→\t\tType:    \"agent\",\n    55→\t\tConfig:  map[string]string{\"prompt\": `file(\"prompts/review.md\")`, \"max_attempts\": `\"2\"`},\n    56→\t\tResults: []string{\"success\", \"fail\", \"give-up\"},\n    57→\t})\n    58→\trequire.NoError(t, err)\n    59→\tassert.Contains(t, result, \"step review\")\n    60→\tassert.Contains(t, result, `prompt = file(\"prompts/review.md\")`)\n    61→\tassert.Contains(t, result, `max_attempts = \"2\"`)\n    62→\n    63→\twf, err := Parse(result)\n    64→\trequire.NoError(t, err)\n    65→\tassert.Contains(t, wf.Steps, \"review\")\n    66→\tassert.Equal(t, \"agent\", string(wf.Steps[\"review\"].Type))\n    67→}\n    68→\n    69→func TestMutatorAddWiring(t *testing.T) {\n    70→\tinput := `workflow \"develop\" {\n    71→  step test {\n    72→    run = \"make test\"\n    73→    results = [success, fail]\n    74→  }\n    75→\n    76→  step scan {\n    77→    run = \"gosec ./...\"\n    78→    results = [success, fail]\n    79→  }\n    80→\n    81→  test:success -> done\n    82→  test:fail -> abort\n    83→}`\n    84→\n    85→\tm := &Mutator{}\n    86→\tresult, err := m.AddWiring(input, []WireDef{\n    87→\t\t{From: \"test\", Result: \"success\", To: \"scan\"},\n    88→\t\t{From: \"scan\", Result: \"fail\", To: \"abort\"},\n    89→\t\t{From: \"scan\", Result: \"success\", To: \"done\"},\n    90→\t})\n    91→\trequire.NoError(t, err)\n    92→\tassert.Contains(t, result, \"test:success -> scan\")\n    93→\tassert.Contains(t, result, \"scan:fail -> abort\")\n    94→\tassert.Contains(t, result, \"scan:success -> done\")\n    95→\n    96→\twf, err := Parse(result)\n    97→\trequire.NoError(t, err)\n    98→\t// Original 2 wires + 3 new = 5\n    99→\tassert.Len(t, wf.Wiring, 5)\n   100→}\n   101→\n   102→func TestMutatorUpdateCollect(t *testing.T) {\n   103→\tinput := `workflow \"develop\" {\n   104→  step test {\n   105→    run = \"make test\"\n   106→    results = [success, fail]\n   107→  }\n   108→\n   109→  step lint {\n   110→    run = \"golint ./...\"\n   111→    results = [success, fail]\n   112→  }\n   113→\n   114→  step scan {\n   115→    run = \"gosec ./...\"\n   116→    results = [success, fail]\n   117→  }\n   118→\n   119→  step fmt {\n   120→    run = \"gofmt -l .\"\n   121→    results = [success, fail]\n   122→  }\n   123→\n   124→  test:success -> lint\n   125→  test:success -> scan\n   126→  collect all(lint:success, scan:success) -> done\n   127→  test:fail -> abort\n   128→}`\n   129→\n   130→\tm := &Mutator{}\n   131→\tresult, err := m.UpdateCollect(input, CollectAddition{\n   132→\t\tCollectTarget: \"done\",\n   133→\t\tStep:          \"fmt\",\n   134→\t\tResult:        \"success\",\n   135→\t})\n   136→\trequire.NoError(t, err)\n   137→\tassert.Contains(t, result, \"fmt:success\")\n   138→\n   139→\twf, err := Parse(result)\n   140→\trequire.NoError(t, err)\n   141→\trequire.Len(t, wf.Collects, 1)\n   142→\tassert.Len(t, wf.Collects[0].Conditions, 3)\n   143→}\n   144→"}]},"parent_tool_use_id":"toolu_01TBN3y7JGQF9Yd5tYEfwQue","session_id":"0d459df6-6a73-41bb-9a61-5157dd36e9c2","uuid":"e7e70f5a-84df-4e9f-be72-bf08b28dd11f"}
