{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WK5eYZEDF532qv7cLo6zNk","type":"tool_result","content":"   100→    image = \"myregistry/myimage:v2\"\n   101→  }\n   102→\n   103→  step code {\n   104→    prompt = \"write code\"\n   105→    results = [success, fail]\n   106→  }\n   107→\n   108→  code:success -> done\n   109→  code:fail -> abort\n   110→}`\n   111→\n   112→\twf, err := dsl.Parse(input)\n   113→\trequire.NoError(t, err)\n   114→\tassert.Equal(t, \"with-image\", wf.Name)\n   115→\tassert.Equal(t, \"myregistry/myimage:v2\", wf.Config[\"container.image\"])\n   116→}\n   117→\n   118→func TestParser_WorkflowContainerBlockMultipleFields(t *testing.T) {\n   119→\tinput := `workflow \"full-config\" {\n   120→  container {\n   121→    image = \"myregistry/myimage:v2\"\n   122→    memory = \"4g\"\n   123→  }\n   124→\n   125→  step code {\n   126→    prompt = \"write code\"\n   127→    results = [success]\n   128→  }\n   129→\n   130→  code:success -> done\n   131→}`\n   132→\n   133→\twf, err := dsl.Parse(input)\n   134→\trequire.NoError(t, err)\n   135→\tassert.Equal(t, \"myregistry/myimage:v2\", wf.Config[\"container.image\"])\n   136→\tassert.Equal(t, \"4g\", wf.Config[\"container.memory\"])\n   137→}\n   138→\n   139→func TestParser_WorkflowWithoutContainerBlock(t *testing.T) {\n   140→\tinput := `workflow \"no-container\" {\n   141→  step code {\n   142→    prompt = \"write code\"\n   143→    results = [success]\n   144→  }\n   145→\n   146→  code:success -> done\n   147→}`\n   148→\n   149→\twf, err := dsl.Parse(input)\n   150→\trequire.NoError(t, err)\n   151→\tassert.Empty(t, wf.Config[\"container.image\"])\n   152→}\n   153→\n   154→func TestParser_InfersTypeFromContent(t *testing.T) {\n   155→\tinput := `workflow \"infer\" {\n   156→  step build {\n   157→    run = \"make build\"\n   158→    results = [success]\n   159→  }\n   160→  step code {\n   161→    prompt = \"write code\"\n   162→    results = [success]\n   163→  }\n   164→  build:success -> code\n   165→  code:success -> done\n   166→}`\n   167→\n   168→\twf, err := dsl.Parse(input)\n   169→\trequire.NoError(t, err)\n   170→\tassert.Equal(t, domain.StepTypeScript, wf.Steps[\"build\"].Type)\n   171→\tassert.Equal(t, domain.StepTypeAgent, wf.Steps[\"code\"].Type)\n   172→}\n   173→\n   174→func TestParser_AmbiguousStepType(t *testing.T) {\n   175→\tinput := `workflow \"bad\" {\n   176→  step both {\n   177→    run = \"make test\"\n   178→    prompt = \"also a prompt\"\n   179→    results = [success]\n   180→  }\n   181→  both:success -> done\n   182→}`\n   183→\n   184→\t_, err := dsl.Parse(input)\n   185→\tassert.Error(t, err)\n   186→\tassert.Contains(t, err.Error(), \"both\")\n   187→}\n   188→\n   189→func TestParser_NoStepType(t *testing.T) {\n   190→\tinput := `workflow \"bad\" {\n   191→  step neither {\n   192→    results = [success]\n   193→  }\n   194→  neither:success -> done\n   195→}`\n   196→\n   197→\t_, err := dsl.Parse(input)\n   198→\tassert.Error(t, err)\n   199→\tassert.Contains(t, err.Error(), \"neither\")\n   200→}\n   201→\n   202→func TestParser_CollectAll(t *testing.T) {\n   203→\tinput := `workflow \"parallel\" {\n   204→  step code {\n   205→    prompt = \"write code\"\n   206→    results = [success]\n   207→  }\n   208→  step test {\n   209→    run = \"make test\"\n   210→    results = [success, fail]\n   211→  }\n   212→  step lint {\n   213→    run = \"make lint\"\n   214→    results = [success, fail]\n   215→  }\n   216→  step merge {\n   217→    run = \"echo merged\"\n   218→    results = [success]\n   219→  }\n   220→\n   221→  code:success -> test\n   222→  code:success -> lint\n   223→  test:fail -> abort\n   224→  lint:fail -> abort\n   225→  collect all(test:success, lint:success) -> merge\n   226→  merge:success -> done\n   227→}`\n   228→\n   229→\twf, err := dsl.Parse(input)\n   230→\trequire.NoError(t, err)\n   231→\n   232→\trequire.Len(t, wf.Collects, 1)\n   233→\tc := wf.Collects[0]\n   234→\tassert.Equal(t, domain.CollectAll, c.Mode)\n   235→\tassert.Equal(t, \"merge\", c.To)\n   236→\trequire.Len(t, c.Conditions, 2)\n   237→\tassert.Equal(t, \"test\", c.Conditions[0].Step)\n   238→\tassert.Equal(t, \"success\", c.Conditions[0].Result)\n   239→\tassert.Equal(t, \"lint\", c.Conditions[1].Step)\n   240→\tassert.Equal(t, \"success\", c.Conditions[1].Result)\n   241→}\n   242→\n   243→func TestParser_WorkflowNameStep(t *testing.T) {\n   244→\tinput := `workflow \"main\" {\n   245→  step prepare-prompt {\n   246→    run     = \"bash scripts/prepare.sh\"\n   247→    results = [success, fail]\n   248→  }\n   249→\n   250→  step develop {\n   251→    workflow_name = \"develop\"\n   252→    results       = [success, fail]\n   253→  }\n   254→\n   255→  prepare-prompt:success -> develop\n   256→  prepare-prompt:fail    -> abort\n   257→  develop:success        -> done\n   258→  develop:fail           -> done\n   259→}`\n   260→\n   261→\twf, err := dsl.Parse(input)\n   262→\trequire.NoError(t, err)\n   263→\n   264→\tassert.Equal(t, \"main\", wf.Name)\n   265→\tassert.Len(t, wf.Steps, 2)\n   266→\n   267→\tdevelop := wf.Steps[\"develop\"]\n   268→\trequire.NotNil(t, develop)\n   269→\tassert.Equal(t, domain.StepTypeWorkflow, develop.Type)\n   270→\tassert.Equal(t, \"develop\", develop.Config[\"workflow_name\"])\n   271→\tassert.Equal(t, []string{\"success\", \"fail\"}, develop.Results)\n   272→\n   273→\tpreparePrompt := wf.Steps[\"prepare-prompt\"]\n   274→\trequire.NotNil(t, preparePrompt)\n   275→\tassert.Equal(t, domain.StepTypeScript, preparePrompt.Type)\n   276→}\n   277→\n   278→func TestParser_WorkflowNameWithPromptStep(t *testing.T) {\n   279→\tinput := `workflow \"orch\" {\n   280→  step prep {\n   281→    run     = \"echo hello\"\n   282→    results = [success, fail]\n   283→  }\n   284→\n   285→  step dev {\n   286→    workflow_name = \"develop\"\n   287→    prompt_step   = \"prep\"\n   288→    results       = [success, fail]\n   289→  }\n   290→\n   291→  prep:success -> dev\n   292→  prep:fail    -> abort\n   293→  dev:success  -> done\n   294→  dev:fail     -> done\n   295→}`\n   296→\n   297→\twf, err := dsl.Parse(input)\n   298→\trequire.NoError(t, err)\n   299→\n   300→\tdev := wf.Steps[\"dev\"]\n   301→\trequire.NotNil(t, dev)\n   302→\tassert.Equal(t, domain.StepTypeWorkflow, dev.Type)\n   303→\tassert.Equal(t, \"prep\", dev.Config[\"prompt_step\"])\n   304→}\n   305→\n   306→func TestParser_WorkflowNameWithPromptErrors(t *testing.T) {\n   307→\tinput := `workflow \"bad\" {\n   308→  step both {\n   309→    workflow_name = \"develop\"\n   310→    prompt        = \"also a prompt\"\n   311→    results       = [success]\n   312→  }\n   313→  both:success -> done\n   314→}`\n   315→\n   316→\t_, err := dsl.Parse(input)\n   317→\tassert.Error(t, err)\n   318→\tassert.Contains(t, err.Error(), \"multiple\")\n   319→}\n   320→\n   321→func TestParser_WorkflowNameWithRunErrors(t *testing.T) {\n   322→\tinput := `workflow \"bad\" {\n   323→  step both {\n   324→    workflow_name = \"develop\"\n   325→    run           = \"make test\"\n   326→    results       = [success]\n   327→  }\n   328→  both:success -> done\n   329→}`\n   330→\n   331→\t_, err := dsl.Parse(input)\n   332→\tassert.Error(t, err)\n   333→\tassert.Contains(t, err.Error(), \"multiple\")\n   334→}\n   335→\n   336→func TestParser_CollectAny(t *testing.T) {\n   337→\tinput := `workflow \"race\" {\n   338→  step fast {\n   339→    run = \"echo fast\"\n   340→    results = [success]\n   341→  }\n   342→  step slow {\n   343→    run = \"sleep 1 && echo slow\"\n   344→    results = [success]\n   345→  }\n   346→  step next {\n   347→    run = \"echo next\"\n   348→    results = [success]\n   349→  }\n   350→\n   351→  collect any(fast:success, slow:success) -> next\n   352→  next:success -> done\n   353→}`\n   354→\n   355→\twf, err := dsl.Parse(input)\n   356→\trequire.NoError(t, err)\n   357→\n   358→\trequire.Len(t, wf.Collects, 1)\n   359→\tassert.Equal(t, domain.CollectAny, wf.Collects[0].Mode)\n   360→}\n   361→\n   362→func TestParseForHost_AllowsWorkflowSteps(t *testing.T) {\n   363→\tinput := `workflow \"main\" {\n   364→  step prepare {\n   365→    run     = \"bash scripts/prepare.sh\"\n   366→    results = [success, fail]\n   367→  }\n   368→  step develop {\n   369→    workflow_name = \"develop\"\n   370→    results       = [success, fail]\n   371→  }\n   372→  prepare:success -> develop\n   373→  prepare:fail    -> abort\n   374→  develop:success -> done\n   375→  develop:fail    -> done\n   376→}`\n   377→\twf, err := dsl.ParseForHost(input)\n   378→\trequire.NoError(t, err)\n   379→\tassert.Equal(t, domain.LocationHost, wf.Location)\n   380→\tassert.Equal(t, domain.StepTypeWorkflow, wf.Steps[\"develop\"].Type)\n   381→}\n   382→\n   383→func TestParseForContainer_RejectsWorkflowSteps(t *testing.T) {\n   384→\tinput := `workflow \"develop\" {\n   385→  step dispatch {\n   386→    workflow_name = \"implement\"\n   387→    results       = [success, fail]\n   388→  }\n   389→  dispatch:success -> done\n   390→  dispatch:fail    -> abort\n   391→}`\n   392→\t_, err := dsl.ParseForContainer(input)\n   393→\trequire.Error(t, err)\n   394→\tassert.Contains(t, err.Error(), \"workflow_name\")\n   395→\tassert.Contains(t, err.Error(), \"host workflows\")\n   396→}\n   397→\n   398→func TestParseForContainer_AllowsAgentAndScript(t *testing.T) {\n   399→\tinput := `workflow \"develop\" {\n   400→  step code {\n   401→    prompt = \"write code\"\n   402→    results = [success, fail]\n   403→  }\n   404→  step test {\n   405→    run = \"make test\"\n   406→    results = [pass, fail]\n   407→  }\n   408→  code:success -> test\n   409→  code:fail -> abort\n   410→  test:pass -> done\n   411→  test:fail -> code\n   412→}`\n   413→\twf, err := dsl.ParseForContainer(input)\n   414→\trequire.NoError(t, err)\n   415→\tassert.Equal(t, domain.LocationContainer, wf.Location)\n   416→}\n   417→\n   418→func TestParser_WireNoMappings(t *testing.T) {\n   419→\tinput := `workflow \"simple\" {\n   420→  step a {\n   421→    run = \"echo a\"\n   422→    results = [success]\n   423→  }\n   424→  a:success -> done\n   425→}`\n   426→\twf, err := dsl.Parse(input)\n   427→\trequire.NoError(t, err)\n   428→\trequire.Len(t, wf.Wiring, 1)\n   429→\tassert.Nil(t, wf.Wiring[0].OutputMap)\n   430→}\n   431→\n   432→func TestParser_WireSingleMapping(t *testing.T) {\n   433→\tinput := `workflow \"mapped\" {\n   434→  step a {\n   435→    run = \"echo a\"\n   436→    results = [success]\n   437→  }\n   438→  step b {\n   439→    run = \"echo b\"\n   440→    results = [success]\n   441→  }\n   442→  a:success -> b [ FOO = output.bar ]\n   443→  b:success -> done\n   444→}`\n   445→\twf, err := dsl.Parse(input)\n   446→\trequire.NoError(t, err)\n   447→\n   448→\twire := wf.Wiring[0]\n   449→\tassert.Equal(t, \"a\", wire.From)\n   450→\tassert.Equal(t, \"b\", wire.To)\n   451→\trequire.Len(t, wire.OutputMap, 1)\n   452→\tassert.Equal(t, \"FOO\", wire.OutputMap[0].EnvVar)\n   453→\trequire.Len(t, wire.OutputMap[0].Path.Segments, 1)\n   454→\tassert.Equal(t, domain.SegmentField, wire.OutputMap[0].Path.Segments[0].Kind)\n   455→\tassert.Equal(t, \"bar\", wire.OutputMap[0].Path.Segments[0].Field)\n   456→}\n   457→\n   458→func TestParser_WireMultipleMappings(t *testing.T) {\n   459→\tinput := `workflow \"mapped\" {\n   460→  step a {\n   461→    run = \"echo a\"\n   462→    results = [success]\n   463→  }\n   464→  step b {\n   465→    run = \"echo b\"\n   466→    results = [success]\n   467→  }\n   468→  a:success -> b [ X = output.a, Y = output.b ]\n   469→  b:success -> done\n   470→}`\n   471→\twf, err := dsl.Parse(input)\n   472→\trequire.NoError(t, err)\n   473→\n   474→\twire := wf.Wiring[0]\n   475→\trequire.Len(t, wire.OutputMap, 2)\n   476→\tassert.Equal(t, \"X\", wire.OutputMap[0].EnvVar)\n   477→\tassert.Equal(t, \"a\", wire.OutputMap[0].Path.Segments[0].Field)\n   478→\tassert.Equal(t, \"Y\", wire.OutputMap[1].EnvVar)\n   479→\tassert.Equal(t, \"b\", wire.OutputMap[1].Path.Segments[0].Field)\n   480→}\n   481→\n   482→func TestParser_WireArrayIndex(t *testing.T) {\n   483→\tinput := `workflow \"mapped\" {\n   484→  step a {\n   485→    run = \"echo a\"\n   486→    results = [success]\n   487→  }\n   488→  step b {\n   489→    run = \"echo b\"\n   490→    results = [success]\n   491→  }\n   492→  a:success -> b [ X = output[0].id ]\n   493→  b:success -> done\n   494→}`\n   495→\twf, err := dsl.Parse(input)\n   496→\trequire.NoError(t, err)\n   497→\n   498→\twire := wf.Wiring[0]\n   499→\trequire.Len(t, wire.OutputMap, 1)\n   500→\tsegs := wire.OutputMap[0].Path.Segments\n   501→\trequire.Len(t, segs, 2)\n   502→\tassert.Equal(t, domain.SegmentIndex, segs[0].Kind)\n   503→\tassert.Equal(t, 0, segs[0].Index)\n   504→\tassert.Equal(t, domain.SegmentField, segs[1].Kind)\n   505→\tassert.Equal(t, \"id\", segs[1].Field)\n   506→}\n   507→\n   508→func TestParser_WireNestedAccess(t *testing.T) {\n   509→\tinput := `workflow \"mapped\" {\n   510→  step a {\n   511→    run = \"echo a\"\n   512→    results = [success]\n   513→  }\n   514→  step b {\n   515→    run = \"echo b\"\n   516→    results = [success]\n   517→  }\n   518→  a:success -> b [ X = output.a.b.c ]\n   519→  b:success -> done\n   520→}`\n   521→\twf, err := dsl.Parse(input)\n   522→\trequire.NoError(t, err)\n   523→\n   524→\tsegs := wf.Wiring[0].OutputMap[0].Path.Segments\n   525→\trequire.Len(t, segs, 3)\n   526→\tassert.Equal(t, \"a\", segs[0].Field)\n   527→\tassert.Equal(t, \"b\", segs[1].Field)\n   528→\tassert.Equal(t, \"c\", segs[2].Field)\n   529→}\n   530→\n   531→func TestParser_WireChainedMixedAccess(t *testing.T) {\n   532→\tinput := `workflow \"mapped\" {\n   533→  step a {\n   534→    run = \"echo a\"\n   535→    results = [success]\n   536→  }\n   537→  step b {\n   538→    run = \"echo b\"\n   539→    results = [success]\n   540→  }\n   541→  a:success -> b [ X = output.items[0].name ]\n   542→  b:success -> done\n   543→}`\n   544→\twf, err := dsl.Parse(input)\n   545→\trequire.NoError(t, err)\n   546→\n   547→\tsegs := wf.Wiring[0].OutputMap[0].Path.Segments\n   548→\trequire.Len(t, segs, 3)\n   549→\tassert.Equal(t, domain.SegmentField, segs[0].Kind)\n   550→\tassert.Equal(t, \"items\", segs[0].Field)\n   551→\tassert.Equal(t, domain.SegmentIndex, segs[1].Kind)\n   552→\tassert.Equal(t, 0, segs[1].Index)\n   553→\tassert.Equal(t, domain.SegmentField, segs[2].Kind)\n   554→\tassert.Equal(t, \"name\", segs[2].Field)\n   555→}\n   556→\n   557→func TestParser_WireBareOutput(t *testing.T) {\n   558→\tinput := `workflow \"mapped\" {\n   559→  step a {\n   560→    run = \"echo a\"\n   561→    results = [success]\n   562→  }\n   563→  step b {\n   564→    run = \"echo b\"\n   565→    results = [success]\n   566→  }\n   567→  a:success -> b [ RAW = output ]\n   568→  b:success -> done\n   569→}`\n   570→\twf, err := dsl.Parse(input)\n   571→\trequire.NoError(t, err)\n   572→\n   573→\twire := wf.Wiring[0]\n   574→\trequire.Len(t, wire.OutputMap, 1)\n   575→\tassert.Equal(t, \"RAW\", wire.OutputMap[0].EnvVar)\n   576→\tassert.Empty(t, wire.OutputMap[0].Path.Segments)\n   577→}\n   578→\n   579→func TestParser_WireMappingErrorMissingOutput(t *testing.T) {\n   580→\tinput := `workflow \"bad\" {\n   581→  step a {\n   582→    run = \"echo a\"\n   583→    results = [success]\n   584→  }\n   585→  step b {\n   586→    run = \"echo b\"\n   587→    results = [success]\n   588→  }\n   589→  a:success -> b [ X = notoutput.foo ]\n   590→  b:success -> done\n   591→}`\n   592→\t_, err := dsl.Parse(input)\n   593→\trequire.Error(t, err)\n   594→\tassert.Contains(t, err.Error(), \"output\")\n   595→}\n   596→\n   597→func TestParser_WireMappingErrorMalformedPath(t *testing.T) {\n   598→\tinput := `workflow \"bad\" {\n   599→  step a {\n   600→    run = \"echo a\"\n   601→    results = [success]\n   602→  }\n   603→  step b {\n   604→    run = \"echo b\"\n   605→    results = [success]\n   606→  }\n   607→  a:success -> b [ X = output.\"bad\" ]\n   608→  b:success -> done\n   609→}`\n   610→\t_, err := dsl.Parse(input)\n   611→\trequire.Error(t, err)\n   612→}\n   613→\n   614→func TestParse_WithoutLocation_NoEnforcement(t *testing.T) {\n   615→\tinput := `workflow \"any\" {\n   616→  step dispatch {\n   617→    workflow_name = \"develop\"\n   618→    results       = [success]\n   619→  }\n   620→  dispatch:success -> done\n   621→}`\n   622→\t// Plain Parse (no location) should not enforce location constraints\n   623→\twf, err := dsl.Parse(input)\n   624→\trequire.NoError(t, err)\n   625→\tassert.Equal(t, domain.WorkflowLocation(\"\"), wf.Location)\n   626→}\n   627→\n   628→// --- ParseAllForHost tests ---\n   629→\n   630→func TestParseAllForHost_SingleWorkflow(t *testing.T) {\n   631→\tinput := `workflow \"main\" {\n   632→  step greet {\n   633→    run     = \"echo hi\"\n   634→    results = [success, fail]\n   635→  }\n   636→  greet:success -> done\n   637→  greet:fail    -> abort\n   638→}`\n   639→\tworkflows, err := dsl.ParseAllForHost(input)\n   640→\trequire.NoError(t, err)\n   641→\trequire.Len(t, workflows, 1)\n   642→\n   643→\twf, ok := workflows[\"main\"]\n   644→\trequire.True(t, ok)\n   645→\tassert.Equal(t, \"main\", wf.Name)\n   646→\tassert.Equal(t, domain.LocationHost, wf.Location)\n   647→}\n   648→\n   649→func TestParseAllForHost_MultipleWorkflows(t *testing.T) {\n   650→\tinput := `workflow \"list-tasks\" {\n   651→  step fetch {\n   652→    run     = \"bash scripts/list-tasks.sh\"\n   653→    results = [success, fail]\n   654→  }\n   655→  fetch:success -> done\n   656→  fetch:fail    -> abort\n   657→}\n   658→\n   659→workflow \"main\" {\n   660→  step prepare {\n   661→    run     = \"echo preparing\"\n   662→    results = [success, fail]\n   663→  }\n   664→  step develop {\n   665→    workflow_name = \"develop\"\n   666→    results       = [success, fail]\n   667→  }\n   668→  prepare:success -> develop\n   669→  prepare:fail    -> abort\n   670→  develop:success -> done\n   671→  develop:fail    -> abort\n   672→}\n   673→\n   674→workflow \"finalize\" {\n   675→  step cleanup {\n   676→    run     = \"echo cleanup\"\n   677→    results = [success, fail]\n   678→  }\n   679→  cleanup:success -> done\n   680→  cleanup:fail    -> abort\n   681→}`\n   682→\n   683→\tworkflows, err := dsl.ParseAllForHost(input)\n   684→\trequire.NoError(t, err)\n   685→\trequire.Len(t, workflows, 3)\n   686→\n   687→\t_, ok := workflows[\"list-tasks\"]\n   688→\tassert.True(t, ok, \"should have list-tasks workflow\")\n   689→\n   690→\t_, ok = workflows[\"main\"]\n   691→\tassert.True(t, ok, \"should have main workflow\")\n   692→\n   693→\t_, ok = workflows[\"finalize\"]\n   694→\tassert.True(t, ok, \"should have finalize workflow\")\n   695→}\n   696→\n   697→func TestParseAllForHost_DuplicateName(t *testing.T) {\n   698→\tinput := `workflow \"main\" {\n   699→  step a {\n   700→    run = \"echo a\"\n   701→    results = [success]\n   702→  }\n   703→  a:success -> done\n   704→}\n   705→workflow \"main\" {\n   706→  step b {\n   707→    run = \"echo b\"\n   708→    results = [success]\n   709→  }\n   710→  b:success -> done\n   711→}`\n   712→\n   713→\t_, err := dsl.ParseAllForHost(input)\n   714→\trequire.Error(t, err)\n   715→\tassert.Contains(t, err.Error(), \"duplicate workflow name\")\n   716→}\n   717→\n   718→func TestParseAllForHost_Empty(t *testing.T) {\n   719→\t_, err := dsl.ParseAllForHost(\"\")\n   720→\trequire.Error(t, err)\n   721→\tassert.Contains(t, err.Error(), \"no workflows found\")\n   722→}\n   723→\n   724→func TestParseAllForHost_AllHostLocation(t *testing.T) {\n   725→\tinput := `workflow \"list-tasks\" {\n   726→  step fetch {\n   727→    run = \"echo fetch\"\n   728→    results = [success]\n   729→  }\n   730→  fetch:success -> done\n   731→}\n   732→workflow \"main\" {\n   733→  step work {\n   734→    run = \"echo work\"\n   735→    results = [success]\n   736→  }\n   737→  work:success -> done\n   738→}`\n   739→\n   740→\tworkflows, err := dsl.ParseAllForHost(input)\n   741→\trequire.NoError(t, err)\n   742→\tfor name, wf := range workflows {\n   743→\t\tassert.Equal(t, domain.LocationHost, wf.Location, \"workflow %q should have host location\", name)\n   744→\t}\n   745→}\n   746→"}]},"parent_tool_use_id":"toolu_01TBN3y7JGQF9Yd5tYEfwQue","session_id":"0d459df6-6a73-41bb-9a61-5157dd36e9c2","uuid":"4dc93341-ffbc-4908-98d2-febea7ec2508"}
