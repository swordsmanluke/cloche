p\"},\n    57→\t})\n    58→\trequire.NoError(t, err)\n    59→\tassert.Contains(t, result, \"step review\")\n    60→\tassert.Contains(t, result, `prompt = file(\"prompts/review.md\")`)\n    61→\tassert.Contains(t, result, `max_attempts = \"2\"`)\n    62→\n    63→\twf, err := Parse(result)\n    64→\trequire.NoError(t, err)\n    65→\tassert.Contains(t, wf.Steps, \"review\")\n    66→\tassert.Equal(t, \"agent\", string(wf.Steps[\"review\"].Type))\n    67→}\n    68→\n    69→func TestMutatorAddWiring(t *testing.T) {\n    70→\tinput := `workflow \"develop\" {\n    71→  step test {\n    72→    run = \"make test\"\n    73→    results = [success, fail]\n    74→  }\n    75→\n    76→  step scan {\n    77→    run = \"gosec ./...\"\n    78→    results = [success, fail]\n    79→  }\n    80→\n    81→  test:success -> done\n    82→  test:fail -> abort\n    83→}`\n    84→\n    85→\tm := &Mutator{}\n    86→\tresult, err := m.AddWiring(input, []WireDef{\n    87→\t\t{From: \"test\", Result: \"success\", To: \"scan\"},\n    88→\t\t{From: \"scan\", Result: \"fail\", To: \"abort\"},\n    89→\t\t{From: \"scan\", Result: \"success\", To: \"done\"},\n    90→\t})\n    91→\trequire.NoError(t, err)\n    92→\tassert.Contains(t, result, \"test:success -> scan\")\n    93→\tassert.Contains(t, result, \"scan:fail -> abort\")\n    94→\tassert.Contains(t, result, \"scan:success -> done\")\n    95→\n    96→\twf, err := Parse(result)\n    97→\trequire.NoError(t, err)\n    98→\t// Original 2 wires + 3 new = 5\n    99→\tassert.Len(t, wf.Wiring, 5)\n   100→}\n   101→\n   102→func TestMutatorUpdateCollect(t *testing.T) {\n   103→\tinput := `workflow \"develop\" {\n   104→  step test {\n   105→    run = \"make test\"\n   106→    results = [success, fail]\n   107→  }\n   108→\n   109→  step lint {\n   110→    run = \"golint ./...\"\n   111→    results = [success, fail]\n   112→  }\n   113→\n   114→  step scan {\n   115→    run = \"gosec ./...\"\n   116→    results = [success, fail]\n   117→  }\n   118→\n   119→  step fmt {\n   120→    run = \"gofmt -l .\"\n   121→    results = [success, fail]\n   122→  }\n   123→\n   124→  test:success -> lint\n   125→  test:success -> scan\n   126→  collect all(lint:success, scan:success) -> done\n   127→  test:fail -> abort\n   128→}`\n   129→\n   130→\tm := &Mutator{}\n   131→\tresult, err := m.UpdateCollect(input, CollectAddition{\n   132→\t\tCollectTarget: \"done\",\n   133→\t\tStep:          \"fmt\",\n   134→\t\tResult:        \"success\",\n   135→\t})\n   136→\trequire.NoError(t, err)\n   137→\tassert.Contains(t, result, \"fmt:success\")\n   138→\n   139→\twf, err := Parse(result)\n   140→\trequire.NoError(t, err)\n   141→\trequire.Len(t, wf.Collects, 1)\n   142→\tassert.Len(t, wf.Collects[0].Conditions, 3)\n   143→}\n   144→"}]},"parent_tool_use_id":null,"session_id":"0d459df6-6a73-41bb-9a61-5157dd36e9c2","uuid":"3c20846c-ab0c-497a-8d81-b1d4972f7228","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/dsl/mutator_test.go","content":"package dsl\n\nimport (\n\t\"testing\"\n\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n)\n\nfunc TestMutatorAddStep(t *testing.T) {\n\tinput := `workflow \"develop\" {\n  step test {\n    run = \"make test\"\n    results = [success, fail]\n  }\n\n  test:success -> done\n  test:fail -> abort\n}`\n\n\tm := &Mutator{}\n\tresult, err := m.AddStep(input, StepDef{\n\t\tName:    \"security-scan\",\n\t\tType:    \"script\",\n\t\tConfig:  map[string]string{\"run\": `\"gosec ./...\"`},\n\t\tResults: []string{\"success\", \"fail\"},\n\t})\n\trequire.NoError(t, err)\n\tassert.Contains(t, result, \"step security-scan\")\n\tassert.Contains(t, result, `run = \"gosec ./...\"`)\n\tassert.Contains(t, result, \"results = [success, fail]\")\n\n\t// Verify the result still parses\n\twf, err := Parse(result)\n\trequire.NoError(t, err)\n\tassert.Contains(t, wf.Steps, \"security-scan\")\n\tassert.Equal(t, \"script\", string(wf.Steps[\"security-scan\"].Type))\n}\n\nfunc TestMutatorAddStepAgent(t *testing.T) {\n\tinput := `workflow \"develop\" {\n  step test {\n    run = \"make test\"\n    results = [success, fail]\n  }\n\n  test:success -> done\n  test:fail -> abort\n}`\n\n\tm := &Mutator{}\n\tresult, err := m.AddStep(input, StepDef{\n\t\tName:    \"review\",\n\t\tType:    \"agent\",\n\t\tConfig:  map[string]string{\"prompt\": `file(\"prompts/review.md\")`, \"max_attempts\": `\"2\"`},\n\t\tResults: []string{\"success\", \"fail\", \"give-up\"},\n\t})\n\trequire.NoError(t, err)\n\tassert.Contains(t, result, \"step review\")\n\tassert.Contains(t, result, `prompt = file(\"prompts/review.md\")`)\n\tassert.Contains(t, result, `max_attempts = \"2\"`)\n\n\twf, err := Parse(result)\n\trequire.NoError(t, err)\n\tassert.Contains(t, wf.Steps, \"review\")\n\tassert.Equal(t, \"agent\", string(wf.Steps[\"review\"].Type))\n}\n\nfunc TestMutatorAddWiring(t *testing.T) {\n\tinput := `workflow \"develop\" {\n  step test {\n    run = \"make test\"\n    results = [success, fail]\n  }\n\n  step scan {\n    run = \"gosec ./...\"\n    results = [success, fail]\n  }\n\n  test:success -> done\n  test:fail -> abort\n}`\n\n\tm := &Mutator{}\n\tresult, err := m.AddWiring(input, []WireDef{\n\t\t{From: \"test\", Result: \"success\", To: \"scan\"},\n\t\t{From: \"scan\", Result: \"fail\", To: \"abort\"},\n\t\t{From: \"scan\", Result: \"success\", To: \"done\"},\n\t})\n\trequire.NoError(t, err)\n\tassert.Contains(t, result, \"test:success -> scan\")\n\tassert.Contains(t, result, \"scan:fail -> abort\")\n\tassert.Contains(t, result, \"scan:success -> done\")\n\n\twf, err := Parse(result)\n\trequire.NoError(t, err)\n\t// Original 2 wires + 3 new = 5\n\tassert.Len(t, wf.Wiring, 5)\n}\n\nfunc TestMutatorUpdateCollect(t *testing.T) {\n\tinput := `workflow \"develop\" {\n  step test {\n    run = \"make test\"\n    results = [success, fail]\n  }\n\n  step lint {\n    run = \"golint ./...\"\n    results = [success, fail]\n  }\n\n  step scan {\n    run = \"gosec ./...\"\n    results = [success, fail]\n  }\n\n  step fmt {\n    run = \"gofmt -l .\"\n    results = [success, fail]\n  }\n\n  test:success -> lint\n  test:success -> scan\n  collect all(lint:success, scan:success) -> done\n  test:fail -> abort\n}`\n\n\tm := &Mutator{}\n\tresult, err := m.UpdateCollect(input, CollectAddition{\n\t\tCollectTarget: \"done\",\n\t\tStep:          \"fmt\",\n\t\tResult:        \"success\",\n\t})\n\trequire.NoError(t, err)\n\tassert.Contains(t, result, \"fmt:success\")\n\n\twf, err := Parse(result)\n\trequire.NoError(t, err)\n\trequire.Len(t, wf.Collects, 1)\n\tassert.Len(t, wf.Collects[0].Conditions, 3)\n}\n","numLines":144,"startLine":1,"totalLines":144}}}
