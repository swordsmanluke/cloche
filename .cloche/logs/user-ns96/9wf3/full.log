[2026-03-09T23:34:07Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NUpXmvuZMvyC8MQrs2aFmf","type":"tool_result","content":"     1→package host\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"fmt\"\n     6→\t\"log\"\n     7→\t\"os\"\n     8→\t\"os/exec\"\n     9→\t\"path/filepath\"\n    10→\t\"time\"\n    11→\n    12→\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    13→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    14→\t\"github.com/cloche-dev/cloche/internal/engine\"\n    15→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    16→\t\"github.com/cloche-dev/cloche/internal/protocol\"\n    17→)\n    18→\n    19→// resolveOutputMappings finds all wires targeting stepName that have output mappings,\n    20→// reads the source step's output, evaluates each mapping path, and returns KEY=value\n    21→// strings suitable for adding to a command's environment.\n    22→func (e *Executor) resolveOutputMappings(stepName string, wires []domain.Wire) ([]string, error) {\n    23→\tvar env []string\n    24→\tfor _, w := range wires {\n    25→\t\tif w.To != stepName || len(w.OutputMap) == 0 {\n    26→\t\t\tcontinue\n    27→\t\t}\n    28→\t\tdata, err := os.ReadFile(e.stepOutputPath(w.From))\n    29→\t\tif err != nil {\n    30→\t\t\treturn nil, fmt.Errorf(\"reading output of %s: %w\", w.From, err)\n    31→\t\t}\n    32→\t\tfor _, m := range w.OutputMap {\n    33→\t\t\tval, err := m.Path.Evaluate(data)\n    34→\t\t\tif err != nil {\n    35→\t\t\t\treturn nil, fmt.Errorf(\"mapping %s for step %s: %w\", m.EnvVar, stepName, err)\n    36→\t\t\t}\n    37→\t\t\tenv = append(env, m.EnvVar+\"=\"+val)\n    38→\t\t}\n    39→\t}\n    40→\treturn env, nil\n    41→}\n    42→\n    43→// RunDispatcher dispatches a container workflow run and returns the run ID.\n    44→type RunDispatcher interface {\n    45→\tRunWorkflow(ctx context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error)\n    46→}\n    47→\n    48→// Executor implements engine.StepExecutor for host workflow steps.\n    49→type Executor struct {\n    50→\tProjectDir string\n    51→\tDispatcher RunDispatcher\n    52→\tStore      ports.RunStore\n    53→\tOutputDir  string         // directory for step output files\n    54→\tWires      []domain.Wire  // workflow wiring (for output mappings)\n    55→}\n    56→\n    57→var _ engine.StepExecutor = (*Executor)(nil)\n    58→\n    59→// Execute runs a single host workflow step.\n    60→func (e *Executor) Execute(ctx context.Context, step *domain.Step) (string, error) {\n    61→\tswitch step.Type {\n    62→\tcase domain.StepTypeScript:\n    63→\t\treturn e.executeScript(ctx, step)\n    64→\tcase domain.StepTypeWorkflow:\n    65→\t\treturn e.executeWorkflow(ctx, step)\n    66→\tdefault:\n    67→\t\treturn \"\", fmt.Errorf(\"unsupported step type %q in host workflow\", step.Type)\n    68→\t}\n    69→}\n    70→\n    71→// executeScript runs a shell command on the host.\n    72→func (e *Executor) executeScript(ctx context.Context, step *domain.Step) (string, error) {\n    73→\tcmdStr := step.Config[\"run\"]\n    74→\tcmd := exec.CommandContext(ctx, \"sh\", \"-c\", cmdStr)\n    75→\tcmd.Dir = e.ProjectDir\n    76→\tcmd.Env = append(os.Environ(),\n    77→\t\t\"CLOCHE_PROJECT_DIR=\"+e.ProjectDir,\n    78→\t\t\"CLOCHE_STEP_OUTPUT=\"+e.stepOutputPath(step.Name),\n    79→\t)\n    80→\n    81→\t// Pass previous step output if available\n    82→\tif prevOutput := e.findPrevOutput(step); prevOutput != \"\" {\n    83→\t\tcmd.Env = append(cmd.Env, \"CLOCHE_PREV_OUTPUT=\"+prevOutput)\n    84→\t}\n    85→\n    86→\t// Resolve output mappings from wires and add as env vars\n    87→\tif len(e.Wires) > 0 {\n    88→\t\tmapped, err := e.resolveOutputMappings(step.Name, e.Wires)\n    89→\t\tif err != nil {\n    90→\t\t\treturn \"\", fmt.Errorf(\"resolving output mappings for step %q: %w\", step.Name, err)\n    91→\t\t}\n    92→\t\tcmd.Env = append(cmd.Env, mapped...)\n    93→\t}\n    94→\n    95→\toutput, err := cmd.CombinedOutput()\n    96→\n    97→\t// Extract result marker\n    98→\tmarkerResult, cleanOutput, found := protocol.ExtractResult(output)\n    99→\n   100→\t// Write output to file\n   101→\tif mkErr := os.MkdirAll(e.OutputDir, 0755); mkErr == nil {\n   102→\t\t_ = os.WriteFile(e.stepOutputPath(step.Name), cleanOutput, 0644)\n   103→\t}\n   104→\n   105→\tif err != nil {\n   106→\t\tif _, ok := err.(*exec.ExitError); ok {\n   107→\t\t\tresult := \"fail\"\n   108→\t\t\tif found {\n   109→\t\t\t\tresult = markerResult\n   110→\t\t\t}\n   111→\t\t\treturn result, nil\n   112→\t\t}\n   113→\t\treturn \"\", err\n   114→\t}\n   115→\n   116→\tresult := \"success\"\n   117→\tif found {\n   118→\t\tresult = markerResult\n   119→\t}\n   120→\treturn result, nil\n   121→}\n   122→\n   123→// executeWorkflow dispatches a container workflow run and blocks until it completes.\n   124→func (e *Executor) executeWorkflow(ctx context.Context, step *domain.Step) (string, error) {\n   125→\tworkflowName := step.Config[\"workflow_name\"]\n   126→\tif workflowName == \"\" {\n   127→\t\treturn \"\", fmt.Errorf(\"workflow step %q missing workflow_name\", step.Name)\n   128→\t}\n   129→\n   130→\t// Read prompt from previous step output or prompt_step override\n   131→\tvar promptContent string\n   132→\tpromptSource := step.Config[\"prompt_step\"]\n   133→\tif promptSource != \"\" {\n   134→\t\tdata, err := os.ReadFile(e.stepOutputPath(promptSource))\n   135→\t\tif err == nil {\n   136→\t\t\tpromptContent = string(data)\n   137→\t\t}\n   138→\t} else if prev := e.findPrevOutput(step); prev != \"\" {\n   139→\t\tdata, err := os.ReadFile(prev)\n   140→\t\tif err == nil {\n   141→\t\t\tpromptContent = string(data)\n   142→\t\t}\n   143→\t}\n   144→\n   145→\tresp, err := e.Dispatcher.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n   146→\t\tWorkflowName: workflowName,\n   147→\t\tProjectDir:   e.ProjectDir,\n   148→\t\tPrompt:       promptContent,\n   149→\t})\n   150→\tif err != nil {\n   151→\t\treturn \"\", fmt.Errorf(\"dispatching workflow %q: %w\", workflowName, err)\n   152→\t}\n   153→\n   154→\tlog.Printf(\"host executor: dispatched container workflow %q as run %s\", workflowName, resp.RunId)\n   155→\n   156→\t// Poll until the run reaches a terminal state\n   157→\tstate, err := e.waitForRun(ctx, resp.RunId)\n   158→\tif err != nil {\n   159→\t\treturn \"\", fmt.Errorf(\"waiting for workflow %q run %s: %w\", workflowName, resp.RunId, err)\n   160→\t}\n   161→\n   162→\tlog.Printf(\"host executor: workflow %q run %s completed with state %s\", workflowName, resp.RunId, state)\n   163→\n   164→\t// Map run state to step result\n   165→\tif state == domain.RunStateSucceeded {\n   166→\t\treturn \"success\", nil\n   167→\t}\n   168→\treturn \"fail\", nil\n   169→}\n   170→\n   171→// waitForRun polls the store until the run reaches a terminal state.\n   172→func (e *Executor) waitForRun(ctx context.Context, runID string) (domain.RunState, error) {\n   173→\tticker := time.NewTicker(2 * time.Second)\n   174→\tdefer ticker.Stop()\n   175→\n   176→\tfor {\n   177→\t\tselect {\n   178→\t\tcase <-ctx.Done():\n   179→\t\t\treturn \"\", fmt.Errorf(\"context cancelled while waiting for run %s: %w\", runID, ctx.Err())\n   180→\t\tcase <-ticker.C:\n   181→\t\t\trun, err := e.Store.GetRun(ctx, runID)\n   182→\t\t\tif err != nil {\n   183→\t\t\t\tcontinue // transient error, retry\n   184→\t\t\t}\n   185→\t\t\tswitch run.State {\n   186→\t\t\tcase domain.RunStateSucceeded, domain.RunStateFailed, domain.RunStateCancelled:\n   187→\t\t\t\treturn run.State, nil\n   188→\t\t\t}\n   189→\t\t\t// Still pending or running, continue polling\n   190→\t\t}\n   191→\t}\n   192→}\n   193→\n   194→// stepOutputPath returns the path for a step's output file.\n   195→func (e *Executor) stepOutputPath(stepName string) string {\n   196→\treturn filepath.Join(e.OutputDir, stepName+\".out\")\n   197→}\n   198→\n   199→// findPrevOutput looks for the most recent output file from any previously completed step.\n   200→// This is a simplified approach — the engine doesn't expose ordering info,\n   201→// so we check for common output files that might exist.\n   202→func (e *Executor) findPrevOutput(step *domain.Step) string {\n   203→\t// Check if there's a prompt_step config\n   204→\tif ps := step.Config[\"prompt_step\"]; ps != \"\" {\n   205→\t\tpath := e.stepOutputPath(ps)\n   206→\t\tif _, err := os.Stat(path); err == nil {\n   207→\t\t\treturn path\n   208→\t\t}\n   209→\t}\n   210→\treturn \"\"\n   211→}\n   212→"}]},"parent_tool_use_id":null,"session_id":"1e0e12bb-4bb1-400c-b220-98492039a122","uuid":"a89b3587-358d-4255-8eec-403b5b28d9c1","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/host/executor.go","content":"package host\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"log\"\n\t\"os\"\n\t\"os/exec\"\n\t\"path/filepath\"\n\t\"time\"\n\n\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/engine\"\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n\t\"github.com/cloche-dev/cloche/internal/protocol\"\n)\n\n// resolveOutputMappings finds all wires targeting stepName that have output mappings,\n// reads the source step's output, evaluates each mapping path, and returns KEY=value\n// strings suitable for adding to a command's environment.\nfunc (e *Executor) resolveOutputMappings(stepName string, wires []domain.Wire) ([]string, error) {\n\tvar env []string\n\tfor _, w := range wires {\n\t\tif w.To != stepName || len(w.OutputMap) == 0 {\n\t\t\tcontinue\n\t\t}\n\t\tdata, err := os.ReadFile(e.stepOutputPath(w.From))\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"reading output of %s: %w\", w.From, err)\n\t\t}\n\t\tfor _, m := range w.OutputMap {\n\t\t\tval, err := m.Path.Evaluate(data)\n\t\t\tif err != nil {\n\t\t\t\treturn nil, fmt.Errorf(\"mapping %s for step %s: %w\", m.EnvVar, stepName, err)\n\t\t\t}\n\t\t\tenv = append(env, m.EnvVar+\"=\"+val)\n\t\t}\n\t}\n\treturn env, nil\n}\n\n// RunDispatcher dispatches a container workflow run and returns the run ID.\ntype RunDispatcher interface {\n\tRunWorkflow(ctx context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error)\n}\n\n// Executor implements engine.StepExecutor for host workflow steps.\ntype Executor struct {\n\tProjectDir string\n\tDispatcher RunDispatcher\n\tStore      ports.RunStore\n\tOutputDir  string         // directory for step output files\n\tWires      []domain.Wire  // workflow wiring (for output mappings)\n}\n\nvar _ engine.StepExecutor = (*Executor)(nil)\n\n// Execute runs a single host workflow step.\nfunc (e *Executor) Execute(ctx context.Context, step *domain.Step) (string, error) {\n\tswitch step.Type {\n\tcase domain.StepTypeScript:\n\t\treturn e.executeScript(ctx, step)\n\tcase domain.StepTypeWorkflow:\n\t\treturn e.executeWorkflow(ctx, step)\n\tdefault:\n\t\treturn \"\", fmt.Errorf(\"unsupported step type %q in host workflow\", step.Type)\n\t}\n}\n\n// executeScript runs a shell command on the host.\nfunc (e *Executor) executeScript(ctx context.Context, step *domain.Step) (string, error) {\n\tcmdStr := step.Config[\"run\"]\n\tcmd := exec.CommandContext(ctx, \"sh\", \"-c\", cmdStr)\n\tcmd.Dir = e.ProjectDir\n\tcmd.Env = append(os.Environ(),\n\t\t\"CLOCHE_PROJECT_DIR=\"+e.ProjectDir,\n\t\t\"CLOCHE_STEP_OUTPUT=\"+e.stepOutputPath(step.Name),\n\t)\n\n\t// Pass previous step output if available\n\tif prevOutput := e.findPrevOutput(step); prevOutput != \"\" {\n\t\tcmd.Env = append(cmd.Env, \"CLOCHE_PREV_OUTPUT=\"+prevOutput)\n\t}\n\n\t// Resolve output mappings from wires and add as env vars\n\tif len(e.Wires) > 0 {\n\t\tmapped, err := e.resolveOutputMappings(step.Name, e.Wires)\n\t\tif err != nil {\n\t\t\treturn \"\", fmt.Errorf(\"resolving output mappings for step %q: %w\", step.Name, err)\n\t\t}\n\t\tcmd.Env = append(cmd.Env, mapped...)\n\t}\n\n\toutput, err := cmd.CombinedOutput()\n\n\t// Extract result marker\n\tmarkerResult, cleanOutput, found := protocol.ExtractResult(output)\n\n\t// Write output to file\n\tif mkErr := os.MkdirAll(e.OutputDir, 0755); mkErr == nil {\n\t\t_ = os.WriteFile(e.stepOutputPath(step.Name), cleanOutput, 0644)\n\t}\n\n\tif err != nil {\n\t\tif _, ok := err.(*exec.ExitError); ok {\n\t\t\tresult := \"fail\"\n\t\t\tif found {\n\t\t\t\tresult = markerResult\n\t\t\t}\n\t\t\treturn result, nil\n\t\t}\n\t\treturn \"\", err\n\t}\n\n\tresult := \"success\"\n\tif found {\n\t\tresult = markerResult\n\t}\n\treturn result, nil\n}\n\n// executeWorkflow dispatches a container workflow run and blocks until it completes.\nfunc (e *Executor) executeWorkflow(ctx context.Context, step *domain.Step) (string, error) {\n\tworkflowName := step.Config[\"workflow_name\"]\n\tif workflowName == \"\" {\n\t\treturn \"\", fmt.Errorf(\"workflow step %q missing workflow_name\", step.Name)\n\t}\n\n\t// Read prompt from previous step output or prompt_step override\n\tvar promptContent string\n\tpromptSource := step.Config[\"prompt_step\"]\n\tif promptSource != \"\" {\n\t\tdata, err := os.ReadFile(e.stepOutputPath(promptSource))\n\t\tif err == nil {\n\t\t\tpromptContent = string(data)\n\t\t}\n\t} else if prev := e.findPrevOutput(step); prev != \"\" {\n\t\tdata, err := os.ReadFile(prev)\n\t\tif err == nil {\n\t\t\tpromptContent = string(data)\n\t\t}\n\t}\n\n\tresp, err := e.Dispatcher.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n\t\tWorkflowName: workflowName,\n\t\tProjectDir:   e.ProjectDir,\n\t\tPrompt:       promptContent,\n\t})\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"dispatching workflow %q: %w\", workflowName, err)\n\t}\n\n\tlog.Printf(\"host executor: dispatched container workflow %q as run %s\", workflowName, resp.RunId)\n\n\t// Poll until the run reaches a terminal state\n\tstate, err := e.waitForRun(ctx, resp.RunId)\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"waiting for workflow %q run %s: %w\", workflowName, resp.RunId, err)\n\t}\n\n\tlog.Printf(\"host executor: workflow %q run %s completed with state %s\", workflowName, resp.RunId, state)\n\n\t// Map run state to step result\n\tif state == domain.RunStateSucceeded {\n\t\treturn \"success\", nil\n\t}\n\treturn \"fail\", nil\n}\n\n// waitForRun polls the store until the run reaches a terminal state.\nfunc (e *Executor) waitForRun(ctx context.Context, runID string) (domain.RunState, error) {\n\tticker := time.NewTicker(2 * time.Second)\n\tdefer ticker.Stop()\n\n\tfor {\n\t\tselect {\n\t\tcase <-ctx.Done():\n\t\t\treturn \"\", fmt.Errorf(\"context cancelled while waiting for run %s: %w\", runID, ctx.Err())\n\t\tcase <-ticker.C:\n\t\t\trun, err := e.Store.GetRun(ctx, runID)\n\t\t\tif err != nil {\n\t\t\t\tcontinue // transient error, retry\n\t\t\t}\n\t\t\tswitch run.State {\n\t\t\tcase domain.RunStateSucceeded, domain.RunStateFailed, domain.RunStateCancelled:\n\t\t\t\treturn run.State, nil\n\t\t\t}\n\t\t\t// Still pending or running, continue polling\n\t\t}\n\t}\n}\n\n// stepOutputPath returns the path for a step's output file.\nfunc (e *Executor) stepOutputPath(stepName string) string {\n\treturn filepath.Join(e.OutputDir, stepName+\".out\")\n}\n\n// findPrevOutput looks for the most recent output file from any previously completed step.\n// This is a simplified approach — the engine doesn't expose ordering info,\n// so we check for common output files that might exist.\nfunc (e *Executor) findPrevOutput(step *domain.Step) string {\n\t// Check if there's a prompt_step config\n\tif ps := step.Config[\"prompt_step\"]; ps != \"\" {\n\t\tpath := e.stepOutputPath(ps)\n\t\tif _, err := os.Stat(path); err == nil {\n\t\t\treturn path\n\t\t}\n\t}\n\treturn \"\"\n}\n","numLines":212,"startLine":1,"totalLines":212}}}
