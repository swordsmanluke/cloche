{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Y8i4exwNaN68iCHhksr5E8","type":"tool_result","content":"     1→package web\n     2→\n     3→import (\n     4→\t\"bufio\"\n     5→\t\"context\"\n     6→\t\"embed\"\n     7→\t\"encoding/json\"\n     8→\t\"fmt\"\n     9→\t\"html/template\"\n    10→\t\"io/fs\"\n    11→\t\"net/http\"\n    12→\t\"os\"\n    13→\t\"os/exec\"\n    14→\t\"path/filepath\"\n    15→\t\"regexp\"\n    16→\t\"sort\"\n    17→\t\"strconv\"\n    18→\t\"strings\"\n    19→\t\"time\"\n    20→\n    21→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    22→\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    23→\t\"github.com/cloche-dev/cloche/internal/logparse\"\n    24→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    25→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    26→)\n    27→\n    28→// HandlerOption configures optional Handler dependencies.\n    29→type HandlerOption func(*Handler)\n    30→\n    31→// WithContainerLogger sets the container runtime for fetching live logs.\n    32→func WithContainerLogger(c ContainerLogger) HandlerOption {\n    33→\treturn func(h *Handler) { h.container = c }\n    34→}\n    35→\n    36→// WithContainerManager sets a full container manager (logs, inspect, remove).\n    37→func WithContainerManager(c ContainerManager) HandlerOption {\n    38→\treturn func(h *Handler) { h.container = c }\n    39→}\n    40→\n    41→// WithLogBroadcaster sets the log broadcaster for SSE streaming.\n    42→func WithLogBroadcaster(b *logstream.Broadcaster) HandlerOption {\n    43→\treturn func(h *Handler) { h.logBroadcast = b }\n    44→}\n    45→\n    46→// WithLogStore sets the log store for indexed log file lookups.\n    47→func WithLogStore(ls ports.LogStore) HandlerOption {\n    48→\treturn func(h *Handler) { h.logStore = ls }\n    49→}\n    50→\n    51→// WithOrchestrateFunc sets the function called when the orchestrator is triggered.\n    52→func WithOrchestrateFunc(fn func(ctx context.Context, projectDir string) (int, error)) HandlerOption {\n    53→\treturn func(h *Handler) { h.orchestrateFn = fn }\n    54→}\n    55→\n    56→// OrchestratorController provides per-project orchestrator control.\n    57→type OrchestratorController interface {\n    58→\tStatus(dir string) (enabled bool, inFlight int, concurrency int)\n    59→\tSetEnabled(dir string, enabled bool)\n    60→\tSetConcurrency(dir string, concurrency int)\n    61→}\n    62→\n    63→// WithOrchestrator sets the orchestrator controller for project-level control.\n    64→func WithOrchestrator(oc OrchestratorController) HandlerOption {\n    65→\treturn func(h *Handler) { h.orchestrator = oc }\n    66→}\n    67→\n    68→//go:embed templates/*.html static/*\n    69→var content embed.FS\n    70→\n    71→// Handler serves the web dashboard.\n    72→// ContainerLogger can retrieve logs from a container by ID.\n    73→type ContainerLogger interface {\n    74→\tLogs(ctx context.Context, containerID string) (string, error)\n    75→}\n    76→\n    77→// ContainerManager extends ContainerLogger with container lifecycle operations.\n    78→type ContainerManager interface {\n    79→\tContainerLogger\n    80→\tRemove(ctx context.Context, containerID string) error\n    81→\tInspect(ctx context.Context, containerID string) (*ports.ContainerStatus, error)\n    82→}\n    83→\n    84→type Handler struct {\n    85→\tstore         ports.RunStore\n    86→\tcaptures      ports.CaptureStore\n    87→\tlogStore      ports.LogStore\n    88→\tcontainer     ContainerLogger\n    89→\tlogBroadcast  *logstream.Broadcaster\n    90→\torchestrateFn func(ctx context.Context, projectDir string) (int, error)\n    91→\torchestrator  OrchestratorController\n    92→\tpages         map[string]*template.Template\n    93→\tmux           *http.ServeMux\n    94→}\n    95→\n    96→// NewHandler creates a web dashboard handler.\n    97→func NewHandler(store ports.RunStore, captures ports.CaptureStore, opts ...HandlerOption) (*Handler, error) {\n    98→\tfuncMap := template.FuncMap{\n    99→\t\t\"stateColor\":       stateColor,\n   100→\t\t\"healthColor\":      healthColor,\n   101→\t\t\"formatTime\":       formatTime,\n   102→\t\t\"formatDuration\":   formatDuration,\n   103→\t\t\"truncate\":         truncate,\n   104→\t\t\"shortContainerID\": shortContainerID,\n   105→\t}\n   106→\n   107→\tbase, err := template.New(\"\").Funcs(funcMap).ParseFS(content, \"templates/layout.html\")\n   108→\tif err != nil {\n   109→\t\treturn nil, fmt.Errorf(\"parse layout: %w\", err)\n   110→\t}\n   111→\n   112→\tpages := map[string]*template.Template{}\n   113→\tfor _, page := range []string{\"projects\", \"runs\", \"run_detail\", \"project_detail\"} {\n   114→\t\tclone, err := base.Clone()\n   115→\t\tif err != nil {\n   116→\t\t\treturn nil, fmt.Errorf(\"clone layout for %s: %w\", page, err)\n   117→\t\t}\n   118→\t\t_, err = clone.ParseFS(content, \"templates/\"+page+\".html\")\n   119→\t\tif err != nil {\n   120→\t\t\treturn nil, fmt.Errorf(\"parse %s: %w\", page, err)\n   121→\t\t}\n   122→\t\tpages[page] = clone\n   123→\t}\n   124→\n   125→\th := &Handler{\n   126→\t\tstore:    store,\n   127→\t\tcaptures: captures,\n   128→\t\tpages:    pages,\n   129→\t\tmux:      http.NewServeMux(),\n   130→\t}\n   131→\tfor _, opt := range opts {\n   132→\t\topt(h)\n   133→\t}\n   134→\n   135→\tstaticFS, err := fs.Sub(content, \"static\")\n   136→\tif err != nil {\n   137→\t\treturn nil, fmt.Errorf(\"static sub-fs: %w\", err)\n   138→\t}\n   139→\n   140→\th.mux.HandleFunc(\"GET /{$}\", h.handleProjectOverview)\n   141→\th.mux.HandleFunc(\"GET /runs\", h.handleRunsList)\n   142→\th.mux.HandleFunc(\"GET /runs/{id}\", h.handleRunDetail)\n   143→\th.mux.HandleFunc(\"GET /projects/{name}\", h.handleProjectDetail)\n   144→\th.mux.HandleFunc(\"GET /api/projects\", h.handleAPIProjects)\n   145→\th.mux.HandleFunc(\"GET /api/runs\", h.handleAPIRuns)\n   146→\th.mux.HandleFunc(\"GET /api/runs/{id}\", h.handleAPIRunDetail)\n   147→\th.mux.HandleFunc(\"GET /api/runs/{id}/steps/{step}/output\", h.handleAPIStepOutput)\n   148→\th.mux.HandleFunc(\"DELETE /api/runs/{id}/container\", h.handleAPIDeleteContainer)\n   149→\th.mux.HandleFunc(\"POST /api/projects/{name}/trigger\", h.handleAPITriggerOrchestrator)\n   150→\th.mux.HandleFunc(\"GET /api/projects/{name}/orchestrator\", h.handleAPIOrchestratorStatus)\n   151→\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/start\", h.handleAPIOrchestratorStart)\n   152→\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/stop\", h.handleAPIOrchestratorStop)\n   153→\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/concurrency\", h.handleAPIOrchestratorConcurrency)\n   154→\th.mux.HandleFunc(\"GET /api/projects/{name}/info\", h.handleAPIProjectInfo)\n   155→\th.mux.HandleFunc(\"GET /api/projects/{name}/info/prompt-diff\", h.handleAPIPromptDiff)\n   156→\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows\", h.handleAPIWorkflows)\n   157→\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows/{workflow}/steps/{step}/content\", h.handleAPIStepContent)\n   158→\th.mux.HandleFunc(\"GET /api/runs/{id}/stream\", h.handleAPIStream)\n   159→\th.mux.Handle(\"GET /static/\", http.StripPrefix(\"/static/\", http.FileServerFS(staticFS)))\n   160→\n   161→\treturn h, nil\n   162→}\n   163→\n   164→func (h *Handler) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n   165→\th.mux.ServeHTTP(w, r)\n   166→}\n   167→\n   168→// --- HTML handlers ---\n   169→\n   170→// projectOverviewEntry holds data for a single project card on the landing page.\n   171→type projectOverviewEntry struct {\n   172→\tDir         string\n   173→\tLabel       string\n   174→\tHealth      domain.HealthResult\n   175→\tRecentRuns  []recentRunDot\n   176→\tActiveCount int\n   177→}\n   178→\n   179→// recentRunDot is a minimal representation of a run for the mini history display.\n   180→type recentRunDot struct {\n   181→\tID    string\n   182→\tState string\n   183→}\n   184→\n   185→const healthWindowSize = 10\n   186→\n   187→func (h *Handler) handleProjectOverview(w http.ResponseWriter, r *http.Request) {\n   188→\tprojects, _ := h.store.ListProjects(r.Context())\n   189→\tlabels := projectLabels(projects)\n   190→\n   191→\tvar entries []projectOverviewEntry\n   192→\tfor _, dir := range projects {\n   193→\t\truns, err := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   194→\t\tif err != nil {\n   195→\t\t\tcontinue\n   196→\t\t}\n   197→\n   198→\t\t// Convert []*domain.Run to []domain.Run for CalculateHealth.\n   199→\t\trunValues := make([]domain.Run, len(runs))\n   200→\t\tfor i, rr := range runs {\n   201→\t\t\trunValues[i] = *rr\n   202→\t\t}\n   203→\n   204→\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n   205→\n   206→\t\t// Take the last N runs for the mini history (most recent first).\n   207→\t\tn := healthWindowSize\n   208→\t\tif n > len(runs) {\n   209→\t\t\tn = len(runs)\n   210→\t\t}\n   211→\t\tdots := make([]recentRunDot, n)\n   212→\t\tfor i := 0; i < n; i++ {\n   213→\t\t\tdots[i] = recentRunDot{\n   214→\t\t\t\tID:    runs[i].ID,\n   215→\t\t\t\tState: string(runs[i].State),\n   216→\t\t\t}\n   217→\t\t}\n   218→\n   219→\t\tvar activeCount int\n   220→\t\tfor _, rr := range runs {\n   221→\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n   222→\t\t\t\tactiveCount++\n   223→\t\t\t}\n   224→\t\t}\n   225→\n   226→\t\tentries = append(entries, projectOverviewEntry{\n   227→\t\t\tDir:         dir,\n   228→\t\t\tLabel:       labels[dir],\n   229→\t\t\tHealth:      health,\n   230→\t\t\tRecentRuns:  dots,\n   231→\t\t\tActiveCount: activeCount,\n   232→\t\t})\n   233→\t}\n   234→\n   235→\tsort.Slice(entries, func(i, j int) bool {\n   236→\t\treturn entries[i].Label < entries[j].Label\n   237→\t})\n   238→\n   239→\tdata := map[string]any{\n   240→\t\t\"Title\":    \"Projects\",\n   241→\t\t\"Projects\": entries,\n   242→\t}\n   243→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   244→\tif err := h.pages[\"projects\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   245→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   246→\t}\n   247→}\n   248→\n   249→func (h *Handler) handleRunsList(w http.ResponseWriter, r *http.Request) {\n   250→\tprojectFilter := r.URL.Query().Get(\"project\")\n   251→\n   252→\tvar runs []*domain.Run\n   253→\tvar err error\n   254→\tif projectFilter != \"\" {\n   255→\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n   256→\t} else {\n   257→\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n   258→\t}\n   259→\tif err != nil {\n   260→\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n   261→\t\treturn\n   262→\t}\n   263→\n   264→\tprojects, _ := h.store.ListProjects(r.Context())\n   265→\tlabels := projectLabels(projects)\n   266→\n   267→\t// Count retained containers per project\n   268→\tcontainerCounts := map[string]int{}\n   269→\tallRuns, _ := h.store.ListRuns(r.Context(), time.Time{})\n   270→\tfor _, run := range allRuns {\n   271→\t\tif run.ContainerKept {\n   272→\t\t\tcontainerCounts[run.ProjectDir]++\n   273→\t\t}\n   274→\t}\n   275→\n   276→\tvar projectList []projectEntry\n   277→\tfor _, dir := range projects {\n   278→\t\tprojectList = append(projectList, projectEntry{Dir: dir, Label: labels[dir], ContainerCount: containerCounts[dir]})\n   279→\t}\n   280→\tsort.Slice(projectList, func(i, j int) bool {\n   281→\t\treturn projectList[i].Label < projectList[j].Label\n   282→\t})\n   283→\n   284→\tdata := map[string]any{\n   285→\t\t\"Title\":         \"Runs\",\n   286→\t\t\"Runs\":          runs,\n   287→\t\t\"Projects\":      projectList,\n   288→\t\t\"ProjectFilter\": projectFilter,\n   289→\t\t\"ProjectLabels\": labels,\n   290→\t}\n   291→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   292→\tif err := h.pages[\"runs\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   293→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   294→\t}\n   295→}\n   296→\n   297→// stepEntry is a merged view of a step execution for the template.\n   298→type stepEntry struct {\n   299→\tIndex     int\n   300→\tStepName  string\n   301→\tResult    string\n   302→\tStartedAt time.Time\n   303→\tDuration  string\n   304→}\n   305→\n   306→// mergeCaptures collapses started/completed capture pairs into single entries.\n   307→func mergeCaptures(caps []*domain.StepExecution) []stepEntry {\n   308→\tvar entries []stepEntry\n   309→\t// Track pending started rows by step name (LIFO for retries)\n   310→\tpending := map[string]*domain.StepExecution{}\n   311→\n   312→\tfor _, c := range caps {\n   313→\t\tif c.Result == \"\" {\n   314→\t\t\t// step_started row\n   315→\t\t\tpending[c.StepName] = c\n   316→\t\t\tcontinue\n   317→\t\t}\n   318→\t\t// step_completed row — merge with pending started if available\n   319→\t\tstartedAt := c.StartedAt\n   320→\t\tif started := pending[c.StepName]; started != nil {\n   321→\t\t\tstartedAt = started.StartedAt\n   322→\t\t\tdelete(pending, c.StepName)\n   323→\t\t}\n   324→\t\tentries = append(entries, stepEntry{\n   325→\t\t\tIndex:     len(entries),\n   326→\t\t\tStepName:  c.StepName,\n   327→\t\t\tResult:    c.Result,\n   328→\t\t\tStartedAt: startedAt,\n   329→\t\t\tDuration:  formatDuration(startedAt, c.CompletedAt),\n   330→\t\t})\n   331→\t}\n   332→\n   333→\t// Append any started-but-not-completed steps (still running)\n   334→\tfor _, c := range caps {\n   335→\t\tif c.Result == \"\" {\n   336→\t\t\tif _, used := pending[c.StepName]; !used {\n   337→\t\t\t\tcontinue\n   338→\t\t\t}\n   339→\t\t\tentries = append(entries, stepEntry{\n   340→\t\t\t\tIndex:     len(entries),\n   341→\t\t\t\tStepName:  c.StepName,\n   342→\t\t\t\tStartedAt: c.StartedAt,\n   343→\t\t\t})\n   344→\t\t\tdelete(pending, c.StepName)\n   345→\t\t}\n   346→\t}\n   347→\n   348→\treturn entries\n   349→}\n   350→\n   351→// containerState inspects the container for a run and returns one of:\n   352→//   - \"running\"   – container exists and is running\n   353→//   - \"stopped\"   – container exists, not running, not kept\n   354→//   - \"available\" – container exists, not running, kept (can be deleted)\n   355→//   - \"removed\"   – no container ID, no manager, or inspect failed\n   356→func (h *Handler) containerState(ctx context.Context, run *domain.Run) string {\n   357→\tif run.ContainerID == \"\" {\n   358→\t\treturn \"removed\"\n   359→\t}\n   360→\tmgr, ok := h.container.(ContainerManager)\n   361→\tif !ok {\n   362→\t\treturn \"removed\"\n   363→\t}\n   364→\tstatus, err := mgr.Inspect(ctx, run.ContainerID)\n   365→\tif err != nil {\n   366→\t\treturn \"removed\"\n   367→\t}\n   368→\tif status.Running {\n   369→\t\treturn \"running\"\n   370→\t}\n   371→\tif run.ContainerKept {\n   372→\t\treturn \"available\"\n   373→\t}\n   374→\treturn \"stopped\"\n   375→}\n   376→\n   377→func (h *Handler) handleRunDetail(w http.ResponseWriter, r *http.Request) {\n   378→\tid := r.PathValue(\"id\")\n   379→\n   380→\trun, err := h.store.GetRun(r.Context(), id)\n   381→\tif err != nil {\n   382→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   383→\t\treturn\n   384→\t}\n   385→\n   386→\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n   387→\tif err != nil {\n   388→\t\tcaps = nil // non-fatal\n   389→\t}\n   390→\n   391→\tsteps := mergeCaptures(caps)\n   392→\n   393→\tdata := map[string]any{\n   394→\t\t\"Title\":          \"Run \" + run.ID,\n   395→\t\t\"Run\":            run,\n   396→\t\t\"Steps\":          steps,\n   397→\t\t\"Page\":           \"detail\",\n   398→\t\t\"ContainerState\": h.containerState(r.Context(), run),\n   399→\t}\n   400→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   401→\tif err := h.pages[\"run_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   402→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   403→\t}\n   404→}\n   405→\n   406→// --- JSON API handlers ---\n   407→\n   408→type apiRun struct {\n   409→\tID           string `json:\"id\"`\n   410→\tWorkflowName string `json:\"workflow_name\"`\n   411→\tProjectDir   string `json:\"project_dir\"`\n   412→\tProjectLabel string `json:\"project_label\"`\n   413→\tState        string `json:\"state\"`\n   414→\tStartedAt    string `json:\"started_at\"`\n   415→\tCompletedAt  string `json:\"completed_at\"`\n   416→\tContainerID  string `json:\"container_id\"`\n   417→\tErrorMessage string `json:\"error_message\"`\n   418→}\n   419→\n   420→type apiStep struct {\n   421→\tStepName    string `json:\"step_name\"`\n   422→\tResult      string `json:\"result\"`\n   423→\tStartedAt   string `json:\"started_at\"`\n   424→\tCompletedAt string `json:\"completed_at\"`\n   425→\tDuration    string `json:\"duration\"`\n   426→}\n   427→\n   428→type apiRunDetail struct {\n   429→\tapiRun\n   430→\tContainerState string    `json:\"container_state\"`\n   431→\tSteps          []apiStep `json:\"steps\"`\n   432→}\n   433→\n   434→func toAPIRun(r *domain.Run, labels map[string]string) apiRun {\n   435→\treturn apiRun{\n   436→\t\tID:           r.ID,\n   437→\t\tWorkflowName: r.WorkflowName,\n   438→\t\tProjectDir:   r.ProjectDir,\n   439→\t\tProjectLabel: labels[r.ProjectDir],\n   440→\t\tState:        string(r.State),\n   441→\t\tStartedAt:    formatTime(r.StartedAt),\n   442→\t\tCompletedAt:  formatTime(r.CompletedAt),\n   443→\t\tContainerID:  r.ContainerID,\n   444→\t\tErrorMessage: r.ErrorMessage,\n   445→\t}\n   446→}\n   447→\n   448→func (h *Handler) handleAPIRuns(w http.ResponseWriter, r *http.Request) {\n   449→\tprojectFilter := r.URL.Query().Get(\"project\")\n   450→\n   451→\tvar runs []*domain.Run\n   452→\tvar err error\n   453→\tif projectFilter != \"\" {\n   454→\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n   455→\t} else {\n   456→\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n   457→\t}\n   458→\tif err != nil {\n   459→\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n   460→\t\treturn\n   461→\t}\n   462→\n   463→\tprojects, _ := h.store.ListProjects(r.Context())\n   464→\tlabels := projectLabels(projects)\n   465→\n   466→\tresult := make([]apiRun, len(runs))\n   467→\tfor i, run := range runs {\n   468→\t\tresult[i] = toAPIRun(run, labels)\n   469→\t}\n   470→\n   471→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   472→\tjson.NewEncoder(w).Encode(result)\n   473→}\n   474→\n   475→func (h *Handler) handleAPIProjects(w http.ResponseWriter, r *http.Request) {\n   476→\tprojects, err := h.store.ListProjects(r.Context())\n   477→\tif err != nil {\n   478→\t\thttp.Error(w, \"failed to list projects\", http.StatusInternalServerError)\n   479→\t\treturn\n   480→\t}\n   481→\tlabels := projectLabels(projects)\n   482→\n   483→\ttype apiHealth struct {\n   484→\t\tStatus string `json:\"status\"`\n   485→\t\tPassed int    `json:\"passed\"`\n   486→\t\tFailed int    `json:\"failed\"`\n   487→\t\tTotal  int    `json:\"total\"`\n   488→\t}\n   489→\ttype apiProject struct {\n   490→\t\tDir         string    `json:\"dir\"`\n   491→\t\tLabel       string    `json:\"label\"`\n   492→\t\tHealth      apiHealth `json:\"health\"`\n   493→\t\tActiveCount int       `json:\"active_count\"`\n   494→\t}\n   495→\tresult := make([]apiProject, len(projects))\n   496→\tfor i, dir := range projects {\n   497→\t\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   498→\t\trunValues := make([]domain.Run, len(runs))\n   499→\t\tfor j, rr := range runs {\n   500→\t\t\trunValues[j] = *rr\n   501→\t\t}\n   502→\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n   503→\t\tvar activeCount int\n   504→\t\tfor _, rr := range runs {\n   505→\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n   506→\t\t\t\tactiveCount++\n   507→\t\t\t}\n   508→\t\t}\n   509→\t\tresult[i] = apiProject{\n   510→\t\t\tDir:   dir,\n   511→\t\t\tLabel: labels[dir],\n   512→\t\t\tHealth: apiHealth{\n   513→\t\t\t\tStatus: string(health.Status),\n   514→\t\t\t\tPassed: health.Passed,\n   515→\t\t\t\tFailed: health.Failed,\n   516→\t\t\t\tTotal:  health.Total,\n   517→\t\t\t},\n   518→\t\t\tActiveCount: activeCount,\n   519→\t\t}\n   520→\t}\n   521→\n   522→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   523→\tjson.NewEncoder(w).Encode(result)\n   524→}\n   525→\n   526→func (h *Handler) handleAPIRunDetail(w http.ResponseWriter, r *http.Request) {\n   527→\tid := r.PathValue(\"id\")\n   528→\n   529→\trun, err := h.store.GetRun(r.Context(), id)\n   530→\tif err != nil {\n   531→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   532→\t\treturn\n   533→\t}\n   534→\n   535→\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n   536→\tif err != nil {\n   537→\t\tcaps = nil\n   538→\t}\n   539→\n   540→\tprojects, _ := h.store.ListProjects(r.Context())\n   541→\tlabels := projectLabels(projects)\n   542→\n   543→\tmerged := mergeCaptures(caps)\n   544→\tsteps := make([]apiStep, len(merged))\n   545→\tfor i, e := range merged {\n   546→\t\tsteps[i] = apiStep{\n   547→\t\t\tStepName:  e.StepName,\n   548→\t\t\tResult:    e.Result,\n   549→\t\t\tStartedAt: formatTime(e.StartedAt),\n   550→\t\t\tDuration:  e.Duration,\n   551→\t\t}\n   552→\t}\n   553→\n   554→\tdetail := apiRunDetail{\n   555→\t\tapiRun:         toAPIRun(run, labels),\n   556→\t\tContainerState: h.containerState(r.Context(), run),\n   557→\t\tSteps:          steps,\n   558→\t}\n   559→\n   560→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   561→\tjson.NewEncoder(w).Encode(detail)\n   562→}\n   563→\n   564→func (h *Handler) handleAPIStepOutput(w http.ResponseWriter, r *http.Request) {\n   565→\tid := r.PathValue(\"id\")\n   566→\tstep := r.PathValue(\"step\")\n   567→\tlogType := r.URL.Query().Get(\"type\")   // optional: \"script\", \"llm\"\n   568→\tformat := r.URL.Query().Get(\"format\")  // optional: \"raw\" to skip parsing\n   569→\n   570→\trun, err := h.store.GetRun(r.Context(), id)\n   571→\tif err != nil {\n   572→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   573→\t\treturn\n   574→\t}\n   575→\n   576→\twriteOutput := func(data []byte) {\n   577→\t\tif format != \"raw\" {\n   578→\t\t\tdata = logparse.FormatStreamJSON(data)\n   579→\t\t}\n   580→\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   581→\t\tw.Write(data)\n   582→\t}\n   583→\n   584→\t// Try log index first for fast lookup\n   585→\tif h.logStore != nil {\n   586→\t\tlogFiles, err := h.logStore.GetLogFilesByStep(r.Context(), id, step)\n   587→\t\tif err == nil && len(logFiles) > 0 {\n   588→\t\t\t// If type filter specified, narrow results\n   589→\t\t\tfor _, lf := range logFiles {\n   590→\t\t\t\tif logType != \"\" && lf.FileType != logType {\n   591→\t\t\t\t\tcontinue\n   592→\t\t\t\t}\n   593→\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n   594→\t\t\t\tif readErr == nil && len(data) > 0 {\n   595→\t\t\t\t\twriteOutput(data)\n   596→\t\t\t\t\treturn\n   597→\t\t\t\t}\n   598→\t\t\t}\n   599→\t\t}\n   600→\t}\n   601→\n   602→\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", id, \"output\")\n   603→\n   604→\t// Fall back to file path conventions\n   605→\t// If type is \"llm\", try llm-<step>.log\n   606→\tif logType == \"llm\" {\n   607→\t\tllmPath := filepath.Join(outputDir, \"llm-\"+step+\".log\")\n   608→\t\tdata, err := os.ReadFile(llmPath)\n   609→\t\tif err == nil && len(data) > 0 {\n   610→\t\t\twriteOutput(data)\n   611→\t\t\treturn\n   612→\t\t}\n   613→\t}\n   614→\n   615→\t// Try per-step output first, fall back to container.log, then live docker logs\n   616→\toutputPath := filepath.Join(outputDir, step+\".log\")\n   617→\tdata, err := os.ReadFile(outputPath)\n   618→\tif err == nil && len(data) > 0 {\n   619→\t\twriteOutput(data)\n   620→\t\treturn\n   621→\t}\n   622→\n   623→\tcontainerLog := filepath.Join(outputDir, \"container.log\")\n   624→\tdata, err = os.ReadFile(containerLog)\n   625→\tif err == nil && len(data) > 0 {\n   626→\t\twriteOutput(data)\n   627→\t\treturn\n   628→\t}\n   629→\n   630→\t// Last resort: try live docker logs from still-existing container\n   631→\tif h.container != nil && run.ContainerID != \"\" {\n   632→\t\tif logs, logErr := h.container.Logs(r.Context(), run.ContainerID); logErr == nil && logs != \"\" {\n   633→\t\t\twriteOutput([]byte(logs))\n   634→\t\t\treturn\n   635→\t\t}\n   636→\t}\n   637→\n   638→\thttp.Error(w, \"step output not found\", http.StatusNotFound)\n   639→}\n   640→\n   641→func (h *Handler) handleAPIDeleteContainer(w http.ResponseWriter, r *http.Request) {\n   642→\tid := r.PathValue(\"id\")\n   643→\n   644→\trun, err := h.store.GetRun(r.Context(), id)\n   645→\tif err != nil {\n   646→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   647→\t\tw.WriteHeader(http.StatusNotFound)\n   648→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"run not found\"})\n   649→\t\treturn\n   650→\t}\n   651→\n   652→\tmgr, ok := h.container.(ContainerManager)\n   653→\tif !ok || run.ContainerID == \"\" {\n   654→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   655→\t\tw.WriteHeader(http.StatusBadRequest)\n   656→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"container management not available\"})\n   657→\t\treturn\n   658→\t}\n   659→\n   660→\tif err := mgr.Remove(r.Context(), run.ContainerID); err != nil {\n   661→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   662→\t\tw.WriteHeader(http.StatusInternalServerError)\n   663→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to remove container: %v\", err)})\n   664→\t\treturn\n   665→\t}\n   666→\n   667→\trun.ContainerKept = false\n   668→\tif err := h.store.UpdateRun(r.Context(), run); err != nil {\n   669→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   670→\t\tw.WriteHeader(http.StatusInternalServerError)\n   671→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to update run: %v\", err)})\n   672→\t\treturn\n   673→\t}\n   674→\n   675→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   676→\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n   677→}\n   678→\n   679→func (h *Handler) handleAPITriggerOrchestrator(w http.ResponseWriter, r *http.Request) {\n   680→\tlabel := r.PathValue(\"name\")\n   681→\n   682→\t// Resolve label back to project directory via the store.\n   683→\tprojects, _ := h.store.ListProjects(r.Context())\n   684→\tlabels := projectLabels(projects)\n   685→\tvar projectDir string\n   686→\tfor dir, l := range labels {\n   687→\t\tif l == label {\n   688→\t\t\tprojectDir = dir\n   689→\t\t\tbreak\n   690→\t\t}\n   691→\t}\n   692→\tif projectDir == \"\" {\n   693→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   694→\t\tw.WriteHeader(http.StatusNotFound)\n   695→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"project not found\"})\n   696→\t\treturn\n   697→\t}\n   698→\n   699→\tif h.orchestrateFn == nil {\n   700→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   701→\t\tw.WriteHeader(http.StatusNotImplemented)\n   702→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n   703→\t\treturn\n   704→\t}\n   705→\n   706→\tdispatched, err := h.orchestrateFn(r.Context(), projectDir)\n   707→\tif err != nil {\n   708→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   709→\t\tw.WriteHeader(http.StatusInternalServerError)\n   710→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": err.Error()})\n   711→\t\treturn\n   712→\t}\n   713→\n   714→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   715→\tjson.NewEncoder(w).Encode(map[string]any{\"status\": \"ok\", \"project\": label, \"dispatched\": dispatched})\n   716→}\n   717→\n   718→// handleAPIStream serves an SSE stream of log lines for a run.\n   719→// For active runs, it subscribes to the live broadcaster.\n   720→// For completed runs, it serves the archived full.log then closes.\n   721→func (h *Handler) handleAPIStream(w http.ResponseWriter, r *http.Request) {\n   722→\tid := r.PathValue(\"id\")\n   723→\n   724→\trun, err := h.store.GetRun(r.Context(), id)\n   725→\tif err != nil {\n   726→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   727→\t\treturn\n   728→\t}\n   729→\n   730→\tflusher, ok := w.(http.Flusher)\n   731→\tif !ok {\n   732→\t\thttp.Error(w, \"streaming not supported\", http.StatusInternalServerError)\n   733→\t\treturn\n   734→\t}\n   735→\n   736→\tw.Header().Set(\"Content-Type\", \"text/event-stream\")\n   737→\tw.Header().Set(\"Cache-Control\", \"no-cache\")\n   738→\tw.Header().Set(\"Connection\", \"keep-alive\")\n   739→\tw.Header().Set(\"X-Accel-Buffering\", \"no\")\n   740→\n   741→\tisComplete := run.State == domain.RunStateSucceeded ||\n   742→\t\trun.State == domain.RunStateFailed ||\n   743→\t\trun.State == domain.RunStateCancelled\n   744→\n   745→\tif isComplete {\n   746→\t\t// Serve archived full.log\n   747→\t\th.streamFullLog(w, flusher, run)\n   748→\t\t// Send done event\n   749→\t\tfmt.Fprintf(w, \"event: done\\ndata: %s\\n\\n\", string(run.State))\n   750→\t\tflusher.Flush()\n   751→\t\treturn\n   752→\t}\n   753→\n   754→\t// Active run: subscribe to live broadcaster\n   755→\tif h.logBroadcast == nil {\n   756→\t\thttp.Error(w, \"log streaming not available\", http.StatusServiceUnavailable)\n   757→\t\treturn\n   758→\t}\n   759→\n   760→\tsub := h.logBroadcast.Subscribe(id)\n   761→\tdefer h.logBroadcast.Unsubscribe(id, sub)\n   762→\n   763→\tctx := r.Context()\n   764→\tfor {\n   765→\t\tselect {\n   766→\t\tcase <-ctx.Done():\n   767→\t\t\treturn\n   768→\t\tcase line, ok := <-sub.C:\n   769→\t\t\tif !ok {\n   770→\t\t\t\t// Stream finished (run completed)\n   771→\t\t\t\tfmt.Fprintf(w, \"event: done\\ndata: completed\\n\\n\")\n   772→\t\t\t\tflusher.Flush()\n   773→\t\t\t\treturn\n   774→\t\t\t}\n   775→\t\t\tdata, _ := json.Marshal(line)\n   776→\t\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n   777→\t\t\tflusher.Flush()\n   778→\t\t}\n   779→\t}\n   780→}\n   781→\n   782→// logLineRegex parses \"[timestamp] [type] content\" format from full.log.\n   783→var logLineRegex = regexp.MustCompile(`^\\[([^\\]]+)\\] \\[([^\\]]+)\\] (.*)$`)\n   784→\n   785→// streamFullLog reads the archived full.log file and sends its entries as SSE events.\n   786→func (h *Handler) streamFullLog(w http.ResponseWriter, flusher http.Flusher, run *domain.Run) {\n   787→\tlogPath := filepath.Join(run.ProjectDir, \".cloche\", run.ID, \"output\", \"full.log\")\n   788→\tf, err := os.Open(logPath)\n   789→\tif err != nil {\n   790→\t\treturn\n   791→\t}\n   792→\tdefer f.Close()\n   793→\n   794→\tscanner := bufio.NewScanner(f)\n   795→\tfor scanner.Scan() {\n   796→\t\ttext := scanner.Text()\n   797→\t\tline := parseFullLogLine(text)\n   798→\t\tdata, _ := json.Marshal(line)\n   799→\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n   800→\t\tflusher.Flush()\n   801→\t}\n   802→}\n   803→\n   804→// parseFullLogLine parses a \"[timestamp] [type] content\" line into a LogLine.\n   805→func parseFullLogLine(text string) logstream.LogLine {\n   806→\tm := logLineRegex.FindStringSubmatch(text)\n   807→\tif m == nil {\n   808→\t\treturn logstream.LogLine{\n   809→\t\t\tTimestamp: time.Now().UTC().Format(time.RFC3339),\n   810→\t\t\tType:      \"script\",\n   811→\t\t\tContent:   text,\n   812→\t\t}\n   813→\t}\n   814→\treturn logstream.LogLine{\n   815→\t\tTimestamp: m[1],\n   816→\t\tType:      m[2],\n   817→\t\tContent:   m[3],\n   818→\t}\n   819→}\n   820→\n   821→// --- Project detail handlers ---\n   822→\n   823→// resolveProjectDir resolves a project label from the URL to its directory path.\n   824→// Returns (dir, label, ok). Writes a JSON error response if not found.\n   825→func (h *Handler) resolveProjectDir(w http.ResponseWriter, r *http.Request) (string, string, bool) {\n   826→\tlabel := r.PathValue(\"name\")\n   827→\tprojects, _ := h.store.ListProjects(r.Context())\n   828→\tlabels := projectLabels(projects)\n   829→\tfor dir, l := range labels {\n   830→\t\tif l == label {\n   831→\t\t\treturn dir, label, true\n   832→\t\t}\n   833→\t}\n   834→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   835→\tw.WriteHeader(http.StatusNotFound)\n   836→\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"project not found\"})\n   837→\treturn \"\", \"\", false\n   838→}\n   839→\n   840→func (h *Handler) handleProjectDetail(w http.ResponseWriter, r *http.Request) {\n   841→\tdir, label, ok := h.resolveProjectDir(w, r)\n   842→\tif !ok {\n   843→\t\treturn\n   844→\t}\n   845→\n   846→\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   847→\tn := 10\n   848→\tif n > len(runs) {\n   849→\t\tn = len(runs)\n   850→\t}\n   851→\tdots := make([]recentRunDot, n)\n   852→\tfor i := 0; i < n; i++ {\n   853→\t\tdots[i] = recentRunDot{ID: runs[i].ID, State: string(runs[i].State)}\n   854→\t}\n   855→\n   856→\tdata := map[string]any{\n   857→\t\t\"Title\":      label,\n   858→\t\t\"Label\":      label,\n   859→\t\t\"Dir\":        dir,\n   860→\t\t\"RecentRuns\": dots,\n   861→\t}\n   862→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   863→\tif err := h.pages[\"project_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   864→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   865→\t}\n   866→}\n   867→\n   868→func (h *Handler) handleAPIOrchestratorStatus(w http.ResponseWriter, r *http.Request) {\n   869→\tdir, _, ok := h.resolveProjectDir(w, r)\n   870→\tif !ok {\n   871→\t\treturn\n   872→\t}\n   873→\tif h.orchestrator == nil {\n   874→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   875→\t\tjson.NewEncoder(w).Encode(map[string]any{\"enabled\": false, \"in_flight\": 0, \"concurrency\": 0})\n   876→\t\treturn\n   877→\t}\n   878→\tenabled, inFlight, concurrency := h.orchestrator.Status(dir)\n   879→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   880→\tjson.NewEncoder(w).Encode(map[string]any{\n   881→\t\t\"enabled\":     enabled,\n   882→\t\t\"in_flight\":   inFlight,\n   883→\t\t\"concurrency\": concurrency,\n   884→\t})\n   885→}\n   886→\n   887→func (h *Handler) handleAPIOrchestratorStart(w http.ResponseWriter, r *http.Request) {\n   888→\tdir, _, ok := h.resolveProjectDir(w, r)\n   889→\tif !ok {\n   890→\t\treturn\n   891→\t}\n   892→\tif h.orchestrator == nil {\n   893→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   894→\t\tw.WriteHeader(http.StatusNotImplemented)\n   895→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n   896→\t\treturn\n   897→\t}\n   898→\th.orchestrator.SetEnabled(dir, true)\n   899→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   900→\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n   901→}\n   902→\n   903→func (h *Handler) handleAPIOrchestratorStop(w http.ResponseWriter, r *http.Request) {\n   904→\tdir, _, ok := h.resolveProjectDir(w, r)\n   905→\tif !ok {\n   906→\t\treturn\n   907→\t}\n   908→\tif h.orchestrator == nil {\n   909→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   910→\t\tw.WriteHeader(http.StatusNotImplemented)\n   911→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n   912→\t\treturn\n   913→\t}\n   914→\th.orchestrator.SetEnabled(dir, false)\n   915→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   916→\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n   917→}\n   918→\n   919→func (h *Handler) handleAPIOrchestratorConcurrency(w http.ResponseWriter, r *http.Request) {\n   920→\tdir, _, ok := h.resolveProjectDir(w, r)\n   921→\tif !ok {\n   922→\t\treturn\n   923→\t}\n   924→\tif h.orchestrator == nil {\n   925→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   926→\t\tw.WriteHeader(http.StatusNotImplemented)\n   927→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n   928→\t\treturn\n   929→\t}\n   930→\tvar body struct {\n   931→\t\tConcurrency int `json:\"concurrency\"`\n   932→\t}\n   933→\tif err := json.NewDecoder(r.Body).Decode(&body); err != nil || body.Concurrency < 1 {\n   934→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   935→\t\tw.WriteHeader(http.StatusBadRequest)\n   936→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"concurrency must be a positive integer\"})\n   937→\t\treturn\n   938→\t}\n   939→\th.orchestrator.SetConcurrency(dir, body.Concurrency)\n   940→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   941→\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n   942→}\n   943→\n   944→func (h *Handler) handleAPIProjectInfo(w http.ResponseWriter, r *http.Request) {\n   945→\tdir, _, ok := h.resolveProjectDir(w, r)\n   946→\tif !ok {\n   947→\t\treturn\n   948→\t}\n   949→\n   950→\t// Docker image: read FROM line from Dockerfile\n   951→\tdockerImage := \"\"\n   952→\tdockerfilePath := filepath.Join(dir, \".cloche\", \"Dockerfile\")\n   953→\tif data, err := os.ReadFile(dockerfilePath); err == nil {\n   954→\t\t// Find the last FROM line (final stage)\n   955→\t\tfor _, line := range strings.Split(string(data), \"\\n\") {\n   956→\t\t\ttrimmed := strings.TrimSpace(line)\n   957→\t\t\tif strings.HasPrefix(strings.ToUpper(trimmed), \"FROM \") {\n   958→\t\t\t\tparts := strings.Fields(trimmed)\n   959→\t\t\t\tif len(parts) >= 2 {\n   960→\t\t\t\t\tdockerImage = parts[1]\n   961→\t\t\t\t}\n   962→\t\t\t}\n   963→\t\t}\n   964→\t}\n   965→\n   966→\t// Version\n   967→\tversion := 0\n   968→\tversionPath := filepath.Join(dir, \".cloche\", \"version\")\n   969→\tif data, err := os.ReadFile(versionPath); err == nil {\n   970→\t\tif v, err := strconv.Atoi(strings.TrimSpace(string(data))); err == nil {\n   971→\t\t\tversion = v\n   972→\t\t}\n   973→\t}\n   974→\n   975→\t// Prompt files history\n   976→\ttype commitEntry struct {\n   977→\t\tSHA     string `json:\"sha\"`\n   978→\t\tDate    string `json:\"date\"`\n   979→\t\tMessage string `json:\"message\"`\n   980→\t}\n   981→\ttype promptFile struct {\n   982→\t\tPath    string        `json:\"path\"`\n   983→\t\tHistory []commitEntry `json:\"history\"`\n   984→\t}\n   985→\n   986→\tvar promptFiles []promptFile\n   987→\tpromptsDir := filepath.Join(dir, \".cloche\", \"prompts\")\n   988→\tif entries, err := os.ReadDir(promptsDir); err == nil {\n   989→\t\tfor _, e := range entries {\n   990→\t\t\tif e.IsDir() {\n   991→\t\t\t\tcontinue\n   992→\t\t\t}\n   993→\t\t\trelPath := filepath.Join(\".cloche\", \"prompts\", e.Name())\n   994→\t\t\tcmd := exec.Command(\"git\", \"log\", \"--follow\", \"--format=%H %aI %s\", \"--\", relPath)\n   995→\t\t\tcmd.Dir = dir\n   996→\t\t\tout, err := cmd.Output()\n   997→\t\t\tif err != nil {\n   998→\t\t\t\tcontinue\n   999→\t\t\t}\n  1000→\t\t\tvar history []commitEntry\n  1001→\t\t\tfor _, line := range strings.Split(strings.TrimSpace(string(out)), \"\\n\") {\n  1002→\t\t\t\tif line == \"\" {\n  1003→\t\t\t\t\tcontinue\n  1004→\t\t\t\t}\n  1005→\t\t\t\tparts := strings.SplitN(line, \" \", 3)\n  1006→\t\t\t\tif len(parts) < 3 {\n  1007→\t\t\t\t\tcontinue\n  1008→\t\t\t\t}\n  1009→\t\t\t\t// Parse date to short form\n  1010→\t\t\t\tdateStr := parts[1]\n  1011→\t\t\t\tif t, err := time.Parse(time.RFC3339, dateStr); err == nil {\n  1012→\t\t\t\t\tdateStr = t.Format(\"2006-01-02\")\n  1013→\t\t\t\t}\n  1014→\t\t\t\thistory = append(history, commitEntry{\n  1015→\t\t\t\t\tSHA:     parts[0][:7],\n  1016→\t\t\t\t\tDate:    dateStr,\n  1017→\t\t\t\t\tMessage: parts[2],\n  1018→\t\t\t\t})\n  1019→\t\t\t}\n  1020→\t\t\tpromptFiles = append(promptFiles, promptFile{Path: relPath, History: history})\n  1021→\t\t}\n  1022→\t}\n  1023→\n  1024→\tw.Header().Set(\"Content-Type\", \"application/json\")\n  1025→\tjson.NewEncoder(w).Encode(map[string]any{\n  1026→\t\t\"docker_image\": dockerImage,\n  1027→\t\t\"version\":      version,\n  1028→\t\t\"prompt_files\": promptFiles,\n  1029→\t})\n  1030→}\n  1031→\n  1032→func (h *Handler) handleAPIPromptDiff(w http.ResponseWriter, r *http.Request) {\n  1033→\tdir, _, ok := h.resolveProjectDir(w, r)\n  1034→\tif !ok {\n  1035→\t\treturn\n  1036→\t}\n  1037→\tfile := r.URL.Query().Get(\"file\")\n  1038→\tsha := r.URL.Query().Get(\"sha\")\n  1039→\tif file == \"\" || sha == \"\" {\n  1040→\t\thttp.Error(w, \"file and sha required\", http.StatusBadRequest)\n  1041→\t\treturn\n  1042→\t}\n  1043→\n  1044→\t// Validate sha is alphanumeric to prevent injection\n  1045→\tfor _, c := range sha {\n  1046→\t\tif !((c >= '0' && c <= '9') || (c >= 'a' && c <= 'f') || (c >= 'A' && c <= 'F')) {\n  1047→\t\t\thttp.Error(w, \"invalid sha\", http.StatusBadRequest)\n  1048→\t\t\treturn\n  1049→\t\t}\n  1050→\t}\n  1051→\n  1052→\tcmd := exec.Command(\"git\", \"diff\", sha+\"^..\"+sha, \"--\", file)\n  1053→\tcmd.Dir = dir\n  1054→\tout, err := cmd.Output()\n  1055→\tif err != nil {\n  1056→\t\thttp.Error(w, \"diff not available\", http.StatusNotFound)\n  1057→\t\treturn\n  1058→\t}\n  1059→\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n  1060→\tw.Write(out)\n  1061→}\n  1062→\n  1063→func (h *Handler) handleAPIWorkflows(w http.ResponseWriter, r *http.Request) {\n  1064→\tdir, _, ok := h.resolveProjectDir(w, r)\n  1065→\tif !ok {\n  1066→\t\treturn\n  1067→\t}\n  1068→\n  1069→\tclocheDir := filepath.Join(dir, \".cloche\")\n  1070→\tentries, err := os.ReadDir(clocheDir)\n  1071→\tif err != nil {\n  1072→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n  1073→\t\tjson.NewEncoder(w).Encode([]any{})\n  1074→\t\treturn\n  1075→\t}\n  1076→\n  1077→\ttype apiWire struct {\n  1078→\t\tFrom   string `json:\"from\"`\n  1079→\t\tResult string `json:\"result\"`\n  1080→\t\tTo     string `json:\"to\"`\n  1081→\t}\n  1082→\ttype apiStepDef struct {\n  1083→\t\tName    string            `json:\"name\"`\n  1084→\t\tType    string            `json:\"type\"`\n  1085→\t\tResults []string          `json:\"results\"`\n  1086→\t\tConfig  map[string]string `json:\"config\"`\n  1087→\t}\n  1088→\ttype apiWorkflow struct {\n  1089→\t\tName      string       `json:\"name\"`\n  1090→\t\tFile      string       `json:\"file\"`\n  1091→\t\tSteps     []apiStepDef `json:\"steps\"`\n  1092→\t\tWires     []apiWire    `json:\"wires\"`\n  1093→\t\tEntryStep string       `json:\"entry_step\"`\n  1094→\t}\n  1095→\n  1096→\tvar workflows []apiWorkflow\n  1097→\tfor _, e := range entries {\n  1098→\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n  1099→\t\t\tcontinue\n  1100→\t\t}\n  1101→\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n  1102→\t\tif err != nil {\n  1103→\t\t\tcontinue\n  1104→\t\t}\n  1105→\t\twf, err := dsl.Parse(string(data))\n  1106→\t\tif err != nil {\n  1107→\t\t\tcontinue\n  1108→\t\t}\n  1109→\t\tvar steps []apiStepDef\n  1110→\t\tfor _, s := range wf.Steps {\n  1111→\t\t\tsteps = append(steps, apiStepDef{\n  1112→\t\t\t\tName:    s.Name,\n  1113→\t\t\t\tType:    string(s.Type),\n  1114→\t\t\t\tResults: s.Results,\n  1115→\t\t\t\tConfig:  s.Config,\n  1116→\t\t\t})\n  1117→\t\t}\n  1118→\t\t// Sort steps by name for consistent ordering\n  1119→\t\tsort.Slice(steps, func(i, j int) bool { return steps[i].Name < steps[j].Name })\n  1120→\n  1121→\t\tvar wires []apiWire\n  1122→\t\tfor _, wire := range wf.Wiring {\n  1123→\t\t\twires = append(wires, apiWire{From: wire.From, Result: wire.Result, To: wire.To})\n  1124→\t\t}\n  1125→\n  1126→\t\tworkflows = append(workflows, apiWorkflow{\n  1127→\t\t\tName:      wf.Name,\n  1128→\t\t\tFile:      filepath.Join(\".cloche\", e.Name()),\n  1129→\t\t\tSteps:     steps,\n  1130→\t\t\tWires:     wires,\n  1131→\t\t\tEntryStep: wf.EntryStep,\n  1132→\t\t})\n  1133→\t}\n  1134→\n  1135→\tw.Header().Set(\"Content-Type\", \"application/json\")\n  1136→\tjson.NewEncoder(w).Encode(workflows)\n  1137→}\n  1138→\n  1139→func (h *Handler) handleAPIStepContent(w http.ResponseWriter, r *http.Request) {\n  1140→\tdir, _, ok := h.resolveProjectDir(w, r)\n  1141→\tif !ok {\n  1142→\t\treturn\n  1143→\t}\n  1144→\tworkflowName := r.PathValue(\"workflow\")\n  1145→\tstepName := r.PathValue(\"step\")\n  1146→\n  1147→\t// Find the workflow file\n  1148→\tclocheDir := filepath.Join(dir, \".cloche\")\n  1149→\tvar wf *domain.Workflow\n  1150→\tentries, _ := os.ReadDir(clocheDir)\n  1151→\tfor _, e := range entries {\n  1152→\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n  1153→\t\t\tcontinue\n  1154→\t\t}\n  1155→\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n  1156→\t\tif err != nil {\n  1157→\t\t\tcontinue\n  1158→\t\t}\n  1159→\t\tparsed, err := dsl.Parse(string(data))\n  1160→\t\tif err != nil {\n  1161→\t\t\tcontinue\n  1162→\t\t}\n  1163→\t\tif parsed.Name == workflowName {\n  1164→\t\t\twf = parsed\n  1165→\t\t\tbreak\n  1166→\t\t}\n  1167→\t}\n  1168→\tif wf == nil {\n  1169→\t\thttp.Error(w, \"workflow not found\", http.StatusNotFound)\n  1170→\t\treturn\n  1171→\t}\n  1172→\n  1173→\tstep, ok := wf.Steps[stepName]\n  1174→\tif !ok {\n  1175→\t\thttp.Error(w, \"step not found\", http.StatusNotFound)\n  1176→\t\treturn\n  1177→\t}\n  1178→\n  1179→\t// Try to read the referenced file from step config\n  1180→\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n  1181→\n  1182→\tif prompt := step.Config[\"prompt\"]; prompt != \"\" {\n  1183→\t\tdata, err := os.ReadFile(filepath.Join(dir, prompt))\n  1184→\t\tif err == nil {\n  1185→\t\t\tw.Write(data)\n  1186→\t\t\treturn\n  1187→\t\t}\n  1188→\t}\n  1189→\tif script := step.Config[\"command\"]; script != \"\" {\n  1190→\t\tw.Write([]byte(script))\n  1191→\t\treturn\n  1192→\t}\n  1193→\tif script := step.Config[\"script\"]; script != \"\" {\n  1194→\t\tdata, err := os.ReadFile(filepath.Join(dir, script))\n  1195→\t\tif err == nil {\n  1196→\t\t\tw.Write(data)\n  1197→\t\t\treturn\n  1198→\t\t}\n  1199→\t\tw.Write([]byte(script))\n  1200→\t\treturn\n  1201→\t}\n  1202→\n  1203→\thttp.Error(w, \"no content available\", http.StatusNotFound)\n  1204→}\n  1205→\n  1206→// --- Template helpers ---\n  1207→\n  1208→func stateColor(state domain.RunState) string {\n  1209→\tswitch state {\n  1210→\tcase domain.RunStatePending:\n  1211→\t\treturn \"pending\"\n  1212→\tcase domain.RunStateRunning:\n  1213→\t\treturn \"running\"\n  1214→\tcase domain.RunStateSucceeded:\n  1215→\t\treturn \"succeeded\"\n  1216→\tcase domain.RunStateFailed:\n  1217→\t\treturn \"failed\"\n  1218→\tcase domain.RunStateCancelled:\n  1219→\t\treturn \"cancelled\"\n  1220→\tdefault:\n  1221→\t\treturn \"pending\"\n  1222→\t}\n  1223→}\n  1224→\n  1225→func healthColor(status domain.HealthStatus) string {\n  1226→\tswitch status {\n  1227→\tcase domain.HealthGreen:\n  1228→\t\treturn \"green\"\n  1229→\tcase domain.HealthYellow:\n  1230→\t\treturn \"yellow\"\n  1231→\tcase domain.HealthRed:\n  1232→\t\treturn \"red\"\n  1233→\tcase domain.HealthBlue:\n  1234→\t\treturn \"blue\"\n  1235→\tdefault:\n  1236→\t\treturn \"grey\"\n  1237→\t}\n  1238→}\n  1239→\n  1240→func formatTime(t time.Time) string {\n  1241→\tif t.IsZero() {\n  1242→\t\treturn \"\"\n  1243→\t}\n  1244→\treturn t.Format(\"2006-01-02 15:04:05\")\n  1245→}\n  1246→\n  1247→func formatDuration(start, end time.Time) string {\n  1248→\tif start.IsZero() || end.IsZero() {\n  1249→\t\treturn \"\"\n  1250→\t}\n  1251→\td := end.Sub(start)\n  1252→\tif d < time.Second {\n  1253→\t\treturn fmt.Sprintf(\"%dms\", d.Milliseconds())\n  1254→\t}\n  1255→\tif d < time.Minute {\n  1256→\t\treturn fmt.Sprintf(\"%.1fs\", d.Seconds())\n  1257→\t}\n  1258→\treturn fmt.Sprintf(\"%dm%ds\", int(d.Minutes()), int(d.Seconds())%60)\n  1259→}\n  1260→\n  1261→func truncate(s string, n int) string {\n  1262→\tif len(s) <= n {\n  1263→\t\treturn s\n  1264→\t}\n  1265→\treturn s[:n] + \"...\"\n  1266→}\n  1267→\n  1268→func shortContainerID(id string) string {\n  1269→\tif len(id) > 12 {\n  1270→\t\treturn id[:12]\n  1271→\t}\n  1272→\treturn id\n  1273→}\n  1274→\n  1275→// projectLabels builds a mapping from full project directory paths to short\n  1276→// display labels. Each label is the final directory component (e.g.\n  1277→// \"myproject\" from \"/home/user/workspace/myproject\"). When two projects share\n  1278→// the same final name, the parent directory is prepended to disambiguate\n  1279→// (e.g. \"foo/bar\" vs \"baz/bar\").\n  1280→func projectLabels(dirs []string) map[string]string {\n  1281→\tlabels := make(map[string]string, len(dirs))\n  1282→\t// Group dirs by their base name to detect conflicts.\n  1283→\tbyBase := map[string][]string{}\n  1284→\tfor _, d := range dirs {\n  1285→\t\tbase := filepath.Base(d)\n  1286→\t\tbyBase[base] = append(byBase[base], d)\n  1287→\t}\n  1288→\tfor base, paths := range byBase {\n  1289→\t\tif len(paths) == 1 {\n  1290→\t\t\tlabels[paths[0]] = base\n  1291→\t\t} else {\n  1292→\t\t\tfor _, p := range paths {\n  1293→\t\t\t\tparent := filepath.Base(filepath.Dir(p))\n  1294→\t\t\t\tlabels[p] = parent + \"/\" + base\n  1295→\t\t\t}\n  1296→\t\t}\n  1297→\t}\n  1298→\treturn labels\n  1299→}\n  1300→\n  1301→type projectEntry struct {\n  1302→\tDir            string\n  1303→\tLabel          string\n  1304→\tContainerCount int\n  1305→}\n  1306→"}]},"parent_tool_use_id":"toolu_01YA5fCikpVs5e6CmMWS3Awo","session_id":"681eabd5-00bc-42d3-9384-f3323237aaa3","uuid":"be5e7c0f-842a-4e74-a73d-1f3a90a8f9da"}
