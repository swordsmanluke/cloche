n    54→\t\t\t\tif ev.ContentBlock.Type == \"tool_use\" && ev.ContentBlock.Name != \"\" {\n    55→\t\t\t\t\tout.WriteString(\"\\n--- \" + ev.ContentBlock.Name + \" ---\\n\")\n    56→\t\t\t\t}\n    57→\t\t\t}\n    58→\n    59→\t\tcase \"content_block_delta\":\n    60→\t\t\tvar ev contentBlockDelta\n    61→\t\t\tif json.Unmarshal(line, &ev) == nil {\n    62→\t\t\t\tswitch ev.Delta.Type {\n    63→\t\t\t\tcase \"text_delta\":\n    64→\t\t\t\t\tout.WriteString(ev.Delta.Text)\n    65→\t\t\t\tcase \"input_json_delta\":\n    66→\t\t\t\t\t// Skip raw tool input JSON — it's noisy and not useful.\n    67→\t\t\t\t}\n    68→\t\t\t}\n    69→\n    70→\t\tcase \"content_block_stop\":\n    71→\t\t\t// If we just finished a text block, ensure a trailing newline.\n    72→\t\t\tif lastBlockType == \"text\" {\n    73→\t\t\t\tif out.Len() > 0 {\n    74→\t\t\t\t\ts := out.String()\n    75→\t\t\t\t\tif s[len(s)-1] != '\\n' {\n    76→\t\t\t\t\t\tout.WriteByte('\\n')\n    77→\t\t\t\t\t}\n    78→\t\t\t\t}\n    79→\t\t\t}\n    80→\t\t\tlastBlockType = \"\"\n    81→\n    82→\t\tcase \"result\":\n    83→\t\t\tvar ev resultEvent\n    84→\t\t\tif json.Unmarshal(line, &ev) == nil && ev.Result != \"\" {\n    85→\t\t\t\tout.WriteString(ev.Result)\n    86→\t\t\t\tif !strings.HasSuffix(ev.Result, \"\\n\") {\n    87→\t\t\t\t\tout.WriteByte('\\n')\n    88→\t\t\t\t}\n    89→\t\t\t}\n    90→\n    91→\t\t// Skip metadata events: message_start, message_delta, message_stop, etc.\n    92→\t\t}\n    93→\t}\n    94→\n    95→\tresult := out.String()\n    96→\tif strings.TrimSpace(result) == \"\" {\n    97→\t\t// Parsing produced nothing useful — return original.\n    98→\t\treturn raw\n    99→\t}\n   100→\treturn []byte(result)\n   101→}\n   102→\n   103→// IsStreamJSON checks whether the content appears to be Claude Code stream-json.\n   104→func IsStreamJSON(data []byte) bool {\n   105→\tfirst := firstNonEmptyLine(data)\n   106→\tif len(first) == 0 || first[0] != '{' {\n   107→\t\treturn false\n   108→\t}\n   109→\tvar base struct {\n   110→\t\tType string `json:\"type\"`\n   111→\t}\n   112→\tif json.Unmarshal(first, &base) != nil {\n   113→\t\treturn false\n   114→\t}\n   115→\t// Known Claude Code stream-json event types.\n   116→\tswitch base.Type {\n   117→\tcase \"message_start\", \"content_block_start\", \"content_block_delta\",\n   118→\t\t\"content_block_stop\", \"message_delta\", \"message_stop\", \"result\":\n   119→\t\treturn true\n   120→\t}\n   121→\treturn false\n   122→}\n   123→\n   124→func firstNonEmptyLine(data []byte) []byte {\n   125→\tscanner := bufio.NewScanner(bytes.NewReader(data))\n   126→\tfor scanner.Scan() {\n   127→\t\tline := bytes.TrimSpace(scanner.Bytes())\n   128→\t\tif len(line) > 0 {\n   129→\t\t\treturn line\n   130→\t\t}\n   131→\t}\n   132→\treturn nil\n   133→}\n   134→\n   135→// --- JSON event structures ---\n   136→\n   137→type contentBlockStart struct {\n   138→\tType         string `json:\"type\"`\n   139→\tContentBlock struct {\n   140→\t\tType string `json:\"type\"`\n   141→\t\tName string `json:\"name\"` // tool_use name\n   142→\t} `json:\"content_block\"`\n   143→}\n   144→\n   145→type contentBlockDelta struct {\n   146→\tType  string `json:\"type\"`\n   147→\tDelta struct {\n   148→\t\tType string `json:\"type\"`\n   149→\t\tText string `json:\"text\"` // text_delta\n   150→\t} `json:\"delta\"`\n   151→}\n   152→\n   153→type resultEvent struct {\n   154→\tType   string `json:\"type\"`\n   155→\tResult string `json:\"result\"`\n   156→}\n   157→"}]},"parent_tool_use_id":null,"session_id":"681eabd5-00bc-42d3-9384-f3323237aaa3","uuid":"c5ad66fb-00ab-4acd-98c6-87edc4b3f9a1","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/logparse/parse.go","content":"// Package logparse converts raw Claude Code stream-json output into\n// human-readable text for display in run history.\npackage logparse\n\nimport (\n\t\"bufio\"\n\t\"bytes\"\n\t\"encoding/json\"\n\t\"strings\"\n)\n\n// FormatStreamJSON parses raw Claude Code stream-json lines and returns\n// human-readable text. If the input doesn't look like stream-json, it is\n// returned unchanged.\nfunc FormatStreamJSON(raw []byte) []byte {\n\tif len(bytes.TrimSpace(raw)) == 0 {\n\t\treturn raw\n\t}\n\n\t// Quick check: if the first non-empty line isn't JSON, return as-is.\n\tfirst := firstNonEmptyLine(raw)\n\tif len(first) == 0 || first[0] != '{' {\n\t\treturn raw\n\t}\n\n\tvar out strings.Builder\n\tscanner := bufio.NewScanner(bytes.NewReader(raw))\n\tscanner.Buffer(make([]byte, 0, 256*1024), 1024*1024)\n\n\tvar lastBlockType string // tracks current content block type\n\n\tfor scanner.Scan() {\n\t\tline := scanner.Bytes()\n\t\tif len(bytes.TrimSpace(line)) == 0 {\n\t\t\tcontinue\n\t\t}\n\n\t\t// Parse the event type quickly.\n\t\tvar base struct {\n\t\t\tType string `json:\"type\"`\n\t\t}\n\t\tif json.Unmarshal(line, &base) != nil {\n\t\t\t// Not JSON — include verbatim (could be a non-JSON agent).\n\t\t\tout.Write(line)\n\t\t\tout.WriteByte('\\n')\n\t\t\tcontinue\n\t\t}\n\n\t\tswitch base.Type {\n\t\tcase \"content_block_start\":\n\t\t\tvar ev contentBlockStart\n\t\t\tif json.Unmarshal(line, &ev) == nil {\n\t\t\t\tlastBlockType = ev.ContentBlock.Type\n\t\t\t\tif ev.ContentBlock.Type == \"tool_use\" && ev.ContentBlock.Name != \"\" {\n\t\t\t\t\tout.WriteString(\"\\n--- \" + ev.ContentBlock.Name + \" ---\\n\")\n\t\t\t\t}\n\t\t\t}\n\n\t\tcase \"content_block_delta\":\n\t\t\tvar ev contentBlockDelta\n\t\t\tif json.Unmarshal(line, &ev) == nil {\n\t\t\t\tswitch ev.Delta.Type {\n\t\t\t\tcase \"text_delta\":\n\t\t\t\t\tout.WriteString(ev.Delta.Text)\n\t\t\t\tcase \"input_json_delta\":\n\t\t\t\t\t// Skip raw tool input JSON — it's noisy and not useful.\n\t\t\t\t}\n\t\t\t}\n\n\t\tcase \"content_block_stop\":\n\t\t\t// If we just finished a text block, ensure a trailing newline.\n\t\t\tif lastBlockType == \"text\" {\n\t\t\t\tif out.Len() > 0 {\n\t\t\t\t\ts := out.String()\n\t\t\t\t\tif s[len(s)-1] != '\\n' {\n\t\t\t\t\t\tout.WriteByte('\\n')\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t\tlastBlockType = \"\"\n\n\t\tcase \"result\":\n\t\t\tvar ev resultEvent\n\t\t\tif json.Unmarshal(line, &ev) == nil && ev.Result != \"\" {\n\t\t\t\tout.WriteString(ev.Result)\n\t\t\t\tif !strings.HasSuffix(ev.Result, \"\\n\") {\n\t\t\t\t\tout.WriteByte('\\n')\n\t\t\t\t}\n\t\t\t}\n\n\t\t// Skip metadata events: message_start, message_delta, message_stop, etc.\n\t\t}\n\t}\n\n\tresult := out.String()\n\tif strings.TrimSpace(result) == \"\" {\n\t\t// Parsing produced nothing useful — return original.\n\t\treturn raw\n\t}\n\treturn []byte(result)\n}\n\n// IsStreamJSON checks whether the content appears to be Claude Code stream-json.\nfunc IsStreamJSON(data []byte) bool {\n\tfirst := firstNonEmptyLine(data)\n\tif len(first) == 0 || first[0] != '{' {\n\t\treturn false\n\t}\n\tvar base struct {\n\t\tType string `json:\"type\"`\n\t}\n\tif json.Unmarshal(first, &base) != nil {\n\t\treturn false\n\t}\n\t// Known Claude Code stream-json event types.\n\tswitch base.Type {\n\tcase \"message_start\", \"content_block_start\", \"content_block_delta\",\n\t\t\"content_block_stop\", \"message_delta\", \"message_stop\", \"result\":\n\t\treturn true\n\t}\n\treturn false\n}\n\nfunc firstNonEmptyLine(data []byte) []byte {\n\tscanner := bufio.NewScanner(bytes.NewReader(data))\n\tfor scanner.Scan() {\n\t\tline := bytes.TrimSpace(scanner.Bytes())\n\t\tif len(line) > 0 {\n\t\t\treturn line\n\t\t}\n\t}\n\treturn nil\n}\n\n// --- JSON event structures ---\n\ntype contentBlockStart struct {\n\tType         string `json:\"type\"`\n\tContentBlock struct {\n\t\tType string `json:\"type\"`\n\t\tName string `json:\"name\"` // tool_use name\n\t} `json:\"content_block\"`\n}\n\ntype contentBlockDelta struct {\n\tType  string `json:\"type\"`\n\tDelta struct {\n\t\tType string `json:\"type\"`\n\t\tText string `json:\"text\"` // text_delta\n\t} `json:\"delta\"`\n}\n\ntype resultEvent struct {\n\tType   string `json:\"type\"`\n\tResult string `json:\"result\"`\n}\n","numLines":157,"startLine":1,"totalLines":157}}}
