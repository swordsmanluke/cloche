[2026-03-09T15:17:31Z] [llm] {"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_019jpcS5i9xuG28bbv5RX7yC","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_015wnc2cZnT2BS2roqdVLopb","name":"Write","input":{"file_path":"/workspace/internal/logparse/parse.go","content":"// Package logparse converts raw Claude Code stream-json output into\n// human-readable text for display in run history.\npackage logparse\n\nimport (\n\t\"bufio\"\n\t\"bytes\"\n\t\"encoding/json\"\n\t\"strings\"\n)\n\n// FormatStreamJSON parses raw Claude Code stream-json lines and returns\n// human-readable text. If the input doesn't look like stream-json, it is\n// returned unchanged.\nfunc FormatStreamJSON(raw []byte) []byte {\n\tif len(bytes.TrimSpace(raw)) == 0 {\n\t\treturn raw\n\t}\n\n\t// Quick check: if the first non-empty line isn't JSON, return as-is.\n\tfirst := firstNonEmptyLine(raw)\n\tif len(first) == 0 || first[0] != '{' {\n\t\treturn raw\n\t}\n\n\tvar out strings.Builder\n\tscanner := bufio.NewScanner(bytes.NewReader(raw))\n\tscanner.Buffer(make([]byte, 0, 256*1024), 1024*1024)\n\n\tvar lastBlockType string // tracks current content block type\n\n\tfor scanner.Scan() {\n\t\tline := scanner.Bytes()\n\t\tif len(bytes.TrimSpace(line)) == 0 {\n\t\t\tcontinue\n\t\t}\n\n\t\t// Parse the event type quickly.\n\t\tvar base struct {\n\t\t\tType string `json:\"type\"`\n\t\t}\n\t\tif json.Unmarshal(line, &base) != nil {\n\t\t\t// Not JSON — include verbatim (could be a non-JSON agent).\n\t\t\tout.Write(line)\n\t\t\tout.WriteByte('\\n')\n\t\t\tcontinue\n\t\t}\n\n\t\tswitch base.Type {\n\t\tcase \"content_block_start\":\n\t\t\tvar ev contentBlockStart\n\t\t\tif json.Unmarshal(line, &ev) == nil {\n\t\t\t\tlastBlockType = ev.ContentBlock.Type\n\t\t\t\tif ev.ContentBlock.Type == \"tool_use\" && ev.ContentBlock.Name != \"\" {\n\t\t\t\t\tout.WriteString(\"\\n--- \" + ev.ContentBlock.Name + \" ---\\n\")\n\t\t\t\t}\n\t\t\t}\n\n\t\tcase \"content_block_delta\":\n\t\t\tvar ev contentBlockDelta\n\t\t\tif json.Unmarshal(line, &ev) == nil {\n\t\t\t\tswitch ev.Delta.Type {\n\t\t\t\tcase \"text_delta\":\n\t\t\t\t\tout.WriteString(ev.Delta.Text)\n\t\t\t\tcase \"input_json_delta\":\n\t\t\t\t\t// Skip raw tool input JSON — it's noisy and not useful.\n\t\t\t\t}\n\t\t\t}\n\n\t\tcase \"content_block_stop\":\n\t\t\t// If we just finished a text block, ensure a trailing newline.\n\t\t\tif lastBlockType == \"text\" {\n\t\t\t\tif out.Len() > 0 {\n\t\t\t\t\ts := out.String()\n\t\t\t\t\tif s[len(s)-1] != '\\n' {\n\t\t\t\t\t\tout.WriteByte('\\n')\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t}\n\t\t\tlastBlockType = \"\"\n\n\t\tcase \"result\":\n\t\t\tvar ev resultEvent\n\t\t\tif json.Unmarshal(line, &ev) == nil && ev.Result != \"\" {\n\t\t\t\tout.WriteString(ev.Result)\n\t\t\t\tif !strings.HasSuffix(ev.Result, \"\\n\") {\n\t\t\t\t\tout.WriteByte('\\n')\n\t\t\t\t}\n\t\t\t}\n\n\t\t// Skip metadata events: message_start, message_delta, message_stop, etc.\n\t\t}\n\t}\n\n\tresult := out.String()\n\tif strings.TrimSpace(result) == \"\" {\n\t\t// Parsing produced nothing useful — return original.\n\t\treturn raw\n\t}\n\treturn []byte(result)\n}\n\n// IsStreamJSON checks whether the content appears to be Claude Code stream-json.\nfunc IsStreamJSON(data []byte) bool {\n\tfirst := firstNonEmptyLine(data)\n\tif len(first) == 0 || first[0] != '{' {\n\t\treturn false\n\t}\n\tvar base struct {\n\t\tType string `json:\"type\"`\n\t}\n\tif json.Unmarshal(first, &base) != nil {\n\t\treturn false\n\t}\n\t// Known Claude Code stream-json event types.\n\tswitch base.Type {\n\tcase \"message_start\", \"content_block_start\", \"content_block_delta\",\n\t\t\"content_block_stop\", \"message_delta\", \"message_stop\", \"result\":\n\t\treturn true\n\t}\n\treturn false\n}\n\nfunc firstNonEmptyLine(data []byte) []byte {\n\tscanner := bufio.NewScanner(bytes.NewReader(data))\n\tfor scanner.Scan() {\n\t\tline := bytes.TrimSpace(scanner.Bytes())\n\t\tif len(line) > 0 {\n\t\t\treturn line\n\t\t}\n\t}\n\treturn nil\n}\n\n// --- JSON event structures ---\n\ntype contentBlockStart struct {\n\tType         string `json:\"type\"`\n\tContentBlock struct {\n\t\tType string `json:\"type\"`\n\t\tName string `json:\"name\"` // tool_use name\n\t} `json:\"content_block\"`\n}\n\ntype contentBlockDelta struct {\n\tType  string `json:\"type\"`\n\tDelta struct {\n\t\tType string `json:\"type\"`\n\t\tText string `json:\"text\"` // text_delta\n\t} `json:\"delta\"`\n}\n\ntype resultEvent struct {\n\tType   string `json:\"type\"`\n\tResult string `json:\"result\"`\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":107,"cache_read_input_tokens":43434,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":107},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"34e205ce-686a-450f-bced-2ed6d70cc0e4","uuid":"513f9535-a9d4-4e31-b75e-495ba15bf13a"}
