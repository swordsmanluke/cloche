\n   497→\t}\n   498→\n   499→\t// Fall back to capture-based streaming\n   500→\tcaptures, err := s.captures.GetCaptures(ctx, req.RunId)\n   501→\tif err != nil {\n   502→\t\treturn fmt.Errorf(\"getting captures: %w\", err)\n   503→\t}\n   504→\n   505→\tfor _, exec := range captures {\n   506→\t\t// Captures are stored as separate rows: one for step_started (no Result)\n   507→\t\t// and one for step_completed (has Result).\n   508→\t\tif exec.Result == \"\" {\n   509→\t\t\tentry := &pb.LogEntry{\n   510→\t\t\t\tType:      \"step_started\",\n   511→\t\t\t\tStepName:  exec.StepName,\n   512→\t\t\t\tTimestamp: exec.StartedAt.String(),\n   513→\t\t\t}\n   514→\t\t\tif err := stream.Send(entry); err != nil {\n   515→\t\t\t\treturn err\n   516→\t\t\t}\n   517→\t\t} else {\n   518→\t\t\t// Read step output from file, falling back to container.log\n   519→\t\t\tvar output string\n   520→\t\t\toutputPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", exec.StepName+\".log\")\n   521→\t\t\tif data, err := os.ReadFile(outputPath); err == nil && len(data) > 0 {\n   522→\t\t\t\toutput = string(data)\n   523→\t\t\t} else {\n   524→\t\t\t\tcontainerLogPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", \"container.log\")\n   525→\t\t\t\tif data, err := os.ReadFile(containerLogPath); err == nil {\n   526→\t\t\t\t\toutput = string(data)\n   527→\t\t\t\t}\n   528→\t\t\t}\n   529→\t\t\tentry := &pb.LogEntry{\n   530→\t\t\t\tType:      \"step_completed\",\n   531→\t\t\t\tStepName:  exec.StepName,\n   532→\t\t\t\tResult:    exec.Result,\n   533→\t\t\t\tTimestamp: exec.CompletedAt.String(),\n   534→\t\t\t\tMessage:   output,\n   535→\t\t\t}\n   536→\t\t\tif err := stream.Send(entry); err != nil {\n   537→\t\t\t\treturn err\n   538→\t\t\t}\n   539→\t\t}\n   540→\t}\n   541→\n   542→\t// Send run completion entry\n   543→\tif run.State != domain.RunStateRunning && run.State != domain.RunStatePending {\n   544→\t\tif err := stream.Send(&pb.LogEntry{\n   545→\t\t\tType:      \"run_completed\",\n   546→\t\t\tResult:    string(run.State),\n   547→\t\t\tTimestamp: run.CompletedAt.String(),\n   548→\t\t\tMessage:   run.ErrorMessage,\n   549→\t\t}); err != nil {\n   550→\t\t\treturn err\n   551→\t\t}\n   552→\t}\n   553→\n   554→\treturn nil\n   555→}\n   556→\n   557→// streamFilteredLogs serves log content filtered by step name and/or log type.\n   558→// It uses the log index when available, falling back to file path conventions.\n   559→func (s *ClocheServer) streamFilteredLogs(ctx context.Context, req *pb.StreamLogsRequest, run *domain.Run, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n   560→\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\")\n   561→\n   562→\t// Try log index first\n   563→\tif s.logStore != nil {\n   564→\t\tvar logFiles []*ports.LogFileEntry\n   565→\t\tvar err error\n   566→\n   567→\t\tif req.StepName != \"\" && req.LogType != \"\" {\n   568→\t\t\t// Filter by both step and type\n   569→\t\t\tlogFiles, err = s.logStore.GetLogFilesByStep(ctx, req.RunId, req.StepName)\n   570→\t\t\tif err == nil {\n   571→\t\t\t\tfiltered := logFiles[:0]\n   572→\t\t\t\tfor _, lf := range logFiles {\n   573→\t\t\t\t\tif lf.FileType == req.LogType {\n   574→\t\t\t\t\t\tfiltered = append(filtered, lf)\n   575→\t\t\t\t\t}\n   576→\t\t\t\t}\n   577→\t\t\t\tlogFiles = filtered\n   578→\t\t\t}\n   579→\t\t} else if req.StepName != \"\" {\n   580→\t\t\tlogFiles, err = s.logStore.GetLogFilesByStep(ctx, req.RunId, req.StepName)\n   581→\t\t} else {\n   582→\t\t\tlogFiles, err = s.logStore.GetLogFileByType(ctx, req.RunId, req.LogType)\n   583→\t\t}\n   584→\n   585→\t\tif err == nil && len(logFiles) > 0 {\n   586→\t\t\tfor _, lf := range logFiles {\n   587→\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n   588→\t\t\t\tif readErr != nil {\n   589→\t\t\t\t\tcontinue\n   590→\t\t\t\t}\n   591→\t\t\t\tif err := stream.Send(&pb.LogEntry{\n   592→\t\t\t\t\tType:     lf.FileType + \"_log\",\n   593→\t\t\t\t\tStepName: lf.StepName,\n   594→\t\t\t\t\tMessage:  string(data),\n   595→\t\t\t\t}); err != nil {\n   596→\t\t\t\t\treturn err\n   597→\t\t\t\t}\n   598→\t\t\t}\n   599→\t\t\treturn nil"}]},"parent_tool_use_id":"toolu_01YA5fCikpVs5e6CmMWS3Awo","session_id":"681eabd5-00bc-42d3-9384-f3323237aaa3","uuid":"91f90186-30e2-420f-847f-4500cee1bbcb"}
