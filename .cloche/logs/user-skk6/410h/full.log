[2026-03-09T15:19:58Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012KfQ7zKLBajMZM3k3Xy78w","type":"tool_result","content":"     1→package logparse_test\n     2→\n     3→import (\n     4→\t\"testing\"\n     5→\n     6→\t\"github.com/cloche-dev/cloche/internal/logparse\"\n     7→\t\"github.com/stretchr/testify/assert\"\n     8→)\n     9→\n    10→func TestFormatStreamJSON_TextDelta(t *testing.T) {\n    11→\tinput := `{\"type\":\"message_start\",\"message\":{\"id\":\"msg_1\",\"type\":\"message\",\"role\":\"assistant\"}}\n    12→{\"type\":\"content_block_start\",\"index\":0,\"content_block\":{\"type\":\"text\",\"text\":\"\"}}\n    13→{\"type\":\"content_block_delta\",\"index\":0,\"delta\":{\"type\":\"text_delta\",\"text\":\"Hello \"}}\n    14→{\"type\":\"content_block_delta\",\"index\":0,\"delta\":{\"type\":\"text_delta\",\"text\":\"world!\"}}\n    15→{\"type\":\"content_block_stop\",\"index\":0}\n    16→{\"type\":\"message_stop\"}\n    17→`\n    18→\tresult := logparse.FormatStreamJSON([]byte(input))\n    19→\tassert.Equal(t, \"Hello world!\\n\", string(result))\n    20→}\n    21→\n    22→func TestFormatStreamJSON_ToolUse(t *testing.T) {\n    23→\tinput := `{\"type\":\"message_start\",\"message\":{\"id\":\"msg_1\",\"type\":\"message\",\"role\":\"assistant\"}}\n    24→{\"type\":\"content_block_start\",\"index\":0,\"content_block\":{\"type\":\"text\",\"text\":\"\"}}\n    25→{\"type\":\"content_block_delta\",\"index\":0,\"delta\":{\"type\":\"text_delta\",\"text\":\"Let me read that file.\"}}\n    26→{\"type\":\"content_block_stop\",\"index\":0}\n    27→{\"type\":\"content_block_start\",\"index\":1,\"content_block\":{\"type\":\"tool_use\",\"id\":\"toolu_1\",\"name\":\"Read\"}}\n    28→{\"type\":\"content_block_delta\",\"index\":1,\"delta\":{\"type\":\"input_json_delta\",\"partial_json\":\"{\\\"path\\\":\\\"/foo\\\"}\"}}\n    29→{\"type\":\"content_block_stop\",\"index\":1}\n    30→{\"type\":\"message_stop\"}\n    31→`\n    32→\tresult := string(logparse.FormatStreamJSON([]byte(input)))\n    33→\tassert.Contains(t, result, \"Let me read that file.\")\n    34→\tassert.Contains(t, result, \"--- Read ---\")\n    35→\t// Tool input JSON should not appear\n    36→\tassert.NotContains(t, result, \"/foo\")\n    37→}\n    38→\n    39→func TestFormatStreamJSON_ResultEvent(t *testing.T) {\n    40→\tinput := `{\"type\":\"message_start\",\"message\":{\"id\":\"msg_1\",\"type\":\"message\",\"role\":\"assistant\"}}\n    41→{\"type\":\"content_block_start\",\"index\":0,\"content_block\":{\"type\":\"text\",\"text\":\"\"}}\n    42→{\"type\":\"content_block_delta\",\"index\":0,\"delta\":{\"type\":\"text_delta\",\"text\":\"Done.\"}}\n    43→{\"type\":\"content_block_stop\",\"index\":0}\n    44→{\"type\":\"message_stop\"}\n    45→{\"type\":\"result\",\"subtype\":\"success\",\"result\":\"CLOCHE_RESULT:success\"}\n    46→`\n    47→\tresult := string(logparse.FormatStreamJSON([]byte(input)))\n    48→\tassert.Contains(t, result, \"Done.\")\n    49→\tassert.Contains(t, result, \"CLOCHE_RESULT:success\")\n    50→}\n    51→\n    52→func TestFormatStreamJSON_PlainText(t *testing.T) {\n    53→\tinput := \"just plain text\\nno json here\\n\"\n    54→\tresult := logparse.FormatStreamJSON([]byte(input))\n    55→\tassert.Equal(t, input, string(result))\n    56→}\n    57→\n    58→func TestFormatStreamJSON_Empty(t *testing.T) {\n    59→\tresult := logparse.FormatStreamJSON([]byte(\"\"))\n    60→\tassert.Equal(t, \"\", string(result))\n    61→}\n    62→\n    63→func TestIsStreamJSON(t *testing.T) {\n    64→\tassert.True(t, logparse.IsStreamJSON([]byte(`{\"type\":\"message_start\",\"message\":{}}`)))\n    65→\tassert.True(t, logparse.IsStreamJSON([]byte(`{\"type\":\"content_block_delta\",\"delta\":{}}`)))\n    66→\tassert.False(t, logparse.IsStreamJSON([]byte(\"plain text output\")))\n    67→\tassert.False(t, logparse.IsStreamJSON([]byte(`{\"type\":\"unknown_event\"}`)))\n    68→\tassert.False(t, logparse.IsStreamJSON([]byte(\"\")))\n    69→}\n    70→\n    71→func TestFormatStreamJSON_MultipleToolCalls(t *testing.T) {\n    72→\tinput := `{\"type\":\"message_start\",\"message\":{\"id\":\"msg_1\",\"type\":\"message\",\"role\":\"assistant\"}}\n    73→{\"type\":\"content_block_start\",\"index\":0,\"content_block\":{\"type\":\"text\",\"text\":\"\"}}\n    74→{\"type\":\"content_block_delta\",\"index\":0,\"delta\":{\"type\":\"text_delta\",\"text\":\"I'll check two files.\\n\"}}\n    75→{\"type\":\"content_block_stop\",\"index\":0}\n    76→{\"type\":\"content_block_start\",\"index\":1,\"content_block\":{\"type\":\"tool_use\",\"id\":\"t1\",\"name\":\"Read\"}}\n    77→{\"type\":\"content_block_stop\",\"index\":1}\n    78→{\"type\":\"content_block_start\",\"index\":2,\"content_block\":{\"type\":\"tool_use\",\"id\":\"t2\",\"name\":\"Grep\"}}\n    79→{\"type\":\"content_block_stop\",\"index\":2}\n    80→{\"type\":\"message_stop\"}\n    81→`\n    82→\tresult := string(logparse.FormatStreamJSON([]byte(input)))\n    83→\tassert.Contains(t, result, \"--- Read ---\")\n    84→\tassert.Contains(t, result, \"--- Grep ---\")\n    85→\tassert.Contains(t, result, \"I'll check two files.\")\n    86→}\n    87→"}]},"parent_tool_use_id":null,"session_id":"681eabd5-00bc-42d3-9384-f3323237aaa3","uuid":"edf058cc-20d9-44bc-a66d-12985c4af5e4","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/logparse/parse_test.go","content":"package logparse_test\n\nimport (\n\t\"testing\"\n\n\t\"github.com/cloche-dev/cloche/internal/logparse\"\n\t\"github.com/stretchr/testify/assert\"\n)\n\nfunc TestFormatStreamJSON_TextDelta(t *testing.T) {\n\tinput := `{\"type\":\"message_start\",\"message\":{\"id\":\"msg_1\",\"type\":\"message\",\"role\":\"assistant\"}}\n{\"type\":\"content_block_start\",\"index\":0,\"content_block\":{\"type\":\"text\",\"text\":\"\"}}\n{\"type\":\"content_block_delta\",\"index\":0,\"delta\":{\"type\":\"text_delta\",\"text\":\"Hello \"}}\n{\"type\":\"content_block_delta\",\"index\":0,\"delta\":{\"type\":\"text_delta\",\"text\":\"world!\"}}\n{\"type\":\"content_block_stop\",\"index\":0}\n{\"type\":\"message_stop\"}\n`\n\tresult := logparse.FormatStreamJSON([]byte(input))\n\tassert.Equal(t, \"Hello world!\\n\", string(result))\n}\n\nfunc TestFormatStreamJSON_ToolUse(t *testing.T) {\n\tinput := `{\"type\":\"message_start\",\"message\":{\"id\":\"msg_1\",\"type\":\"message\",\"role\":\"assistant\"}}\n{\"type\":\"content_block_start\",\"index\":0,\"content_block\":{\"type\":\"text\",\"text\":\"\"}}\n{\"type\":\"content_block_delta\",\"index\":0,\"delta\":{\"type\":\"text_delta\",\"text\":\"Let me read that file.\"}}\n{\"type\":\"content_block_stop\",\"index\":0}\n{\"type\":\"content_block_start\",\"index\":1,\"content_block\":{\"type\":\"tool_use\",\"id\":\"toolu_1\",\"name\":\"Read\"}}\n{\"type\":\"content_block_delta\",\"index\":1,\"delta\":{\"type\":\"input_json_delta\",\"partial_json\":\"{\\\"path\\\":\\\"/foo\\\"}\"}}\n{\"type\":\"content_block_stop\",\"index\":1}\n{\"type\":\"message_stop\"}\n`\n\tresult := string(logparse.FormatStreamJSON([]byte(input)))\n\tassert.Contains(t, result, \"Let me read that file.\")\n\tassert.Contains(t, result, \"--- Read ---\")\n\t// Tool input JSON should not appear\n\tassert.NotContains(t, result, \"/foo\")\n}\n\nfunc TestFormatStreamJSON_ResultEvent(t *testing.T) {\n\tinput := `{\"type\":\"message_start\",\"message\":{\"id\":\"msg_1\",\"type\":\"message\",\"role\":\"assistant\"}}\n{\"type\":\"content_block_start\",\"index\":0,\"content_block\":{\"type\":\"text\",\"text\":\"\"}}\n{\"type\":\"content_block_delta\",\"index\":0,\"delta\":{\"type\":\"text_delta\",\"text\":\"Done.\"}}\n{\"type\":\"content_block_stop\",\"index\":0}\n{\"type\":\"message_stop\"}\n{\"type\":\"result\",\"subtype\":\"success\",\"result\":\"CLOCHE_RESULT:success\"}\n`\n\tresult := string(logparse.FormatStreamJSON([]byte(input)))\n\tassert.Contains(t, result, \"Done.\")\n\tassert.Contains(t, result, \"CLOCHE_RESULT:success\")\n}\n\nfunc TestFormatStreamJSON_PlainText(t *testing.T) {\n\tinput := \"just plain text\\nno json here\\n\"\n\tresult := logparse.FormatStreamJSON([]byte(input))\n\tassert.Equal(t, input, string(result))\n}\n\nfunc TestFormatStreamJSON_Empty(t *testing.T) {\n\tresult := logparse.FormatStreamJSON([]byte(\"\"))\n\tassert.Equal(t, \"\", string(result))\n}\n\nfunc TestIsStreamJSON(t *testing.T) {\n\tassert.True(t, logparse.IsStreamJSON([]byte(`{\"type\":\"message_start\",\"message\":{}}`)))\n\tassert.True(t, logparse.IsStreamJSON([]byte(`{\"type\":\"content_block_delta\",\"delta\":{}}`)))\n\tassert.False(t, logparse.IsStreamJSON([]byte(\"plain text output\")))\n\tassert.False(t, logparse.IsStreamJSON([]byte(`{\"type\":\"unknown_event\"}`)))\n\tassert.False(t, logparse.IsStreamJSON([]byte(\"\")))\n}\n\nfunc TestFormatStreamJSON_MultipleToolCalls(t *testing.T) {\n\tinput := `{\"type\":\"message_start\",\"message\":{\"id\":\"msg_1\",\"type\":\"message\",\"role\":\"assistant\"}}\n{\"type\":\"content_block_start\",\"index\":0,\"content_block\":{\"type\":\"text\",\"text\":\"\"}}\n{\"type\":\"content_block_delta\",\"index\":0,\"delta\":{\"type\":\"text_delta\",\"text\":\"I'll check two files.\\n\"}}\n{\"type\":\"content_block_stop\",\"index\":0}\n{\"type\":\"content_block_start\",\"index\":1,\"content_block\":{\"type\":\"tool_use\",\"id\":\"t1\",\"name\":\"Read\"}}\n{\"type\":\"content_block_stop\",\"index\":1}\n{\"type\":\"content_block_start\",\"index\":2,\"content_block\":{\"type\":\"tool_use\",\"id\":\"t2\",\"name\":\"Grep\"}}\n{\"type\":\"content_block_stop\",\"index\":2}\n{\"type\":\"message_stop\"}\n`\n\tresult := string(logparse.FormatStreamJSON([]byte(input)))\n\tassert.Contains(t, result, \"--- Read ---\")\n\tassert.Contains(t, result, \"--- Grep ---\")\n\tassert.Contains(t, result, \"I'll check two files.\")\n}\n","numLines":87,"startLine":1,"totalLines":87}}}
