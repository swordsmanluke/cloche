)\n   772→\t\t\t\tflusher.Flush()\n   773→\t\t\t\treturn\n   774→\t\t\t}\n   775→\t\t\tdata, _ := json.Marshal(line)\n   776→\t\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n   777→\t\t\tflusher.Flush()\n   778→\t\t}\n   779→\t}\n   780→}\n   781→\n   782→// logLineRegex parses \"[timestamp] [type] content\" format from full.log.\n   783→var logLineRegex = regexp.MustCompile(`^\\[([^\\]]+)\\] \\[([^\\]]+)\\] (.*)$`)\n   784→\n   785→// streamFullLog reads the archived full.log file and sends its entries as SSE events.\n   786→func (h *Handler) streamFullLog(w http.ResponseWriter, flusher http.Flusher, run *domain.Run) {\n   787→\tlogPath := filepath.Join(run.ProjectDir, \".cloche\", run.ID, \"output\", \"full.log\")\n   788→\tf, err := os.Open(logPath)\n   789→\tif err != nil {\n   790→\t\treturn\n   791→\t}\n   792→\tdefer f.Close()\n   793→\n   794→\tscanner := bufio.NewScanner(f)\n   795→\tfor scanner.Scan() {\n   796→\t\ttext := scanner.Text()\n   797→\t\tline := parseFullLogLine(text)\n   798→\t\tdata, _ := json.Marshal(line)\n   799→\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n   800→\t\tflusher.Flush()\n   801→\t}\n   802→}\n   803→\n   804→// parseFullLogLine parses a \"[timestamp] [type] content\" line into a LogLine.\n   805→func parseFullLogLine(text string) logstream.LogLine {\n   806→\tm := logLineRegex.FindStringSubmatch(text)\n   807→\tif m == nil {\n   808→\t\treturn logstream.LogLine{\n   809→\t\t\tTimestamp: time.Now().UTC().Format(time.RFC3339),\n   810→\t\t\tType:      \"script\",\n   811→\t\t\tContent:   text,\n   812→\t\t}\n   813→\t}\n   814→\treturn logstream.LogLine{\n   815→\t\tTimestamp: m[1],\n   816→\t\tType:      m[2],\n   817→\t\tContent:   m[3],\n   818→\t}\n   819→}\n   820→"}]},"parent_tool_use_id":null,"session_id":"681eabd5-00bc-42d3-9384-f3323237aaa3","uuid":"a9128884-f488-4d3d-be5c-7a17b934cf81","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/web/handler.go","content":"func (h *Handler) handleAPIStream(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\tflusher, ok := w.(http.Flusher)\n\tif !ok {\n\t\thttp.Error(w, \"streaming not supported\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"text/event-stream\")\n\tw.Header().Set(\"Cache-Control\", \"no-cache\")\n\tw.Header().Set(\"Connection\", \"keep-alive\")\n\tw.Header().Set(\"X-Accel-Buffering\", \"no\")\n\n\tisComplete := run.State == domain.RunStateSucceeded ||\n\t\trun.State == domain.RunStateFailed ||\n\t\trun.State == domain.RunStateCancelled\n\n\tif isComplete {\n\t\t// Serve archived full.log\n\t\th.streamFullLog(w, flusher, run)\n\t\t// Send done event\n\t\tfmt.Fprintf(w, \"event: done\\ndata: %s\\n\\n\", string(run.State))\n\t\tflusher.Flush()\n\t\treturn\n\t}\n\n\t// Active run: subscribe to live broadcaster\n\tif h.logBroadcast == nil {\n\t\thttp.Error(w, \"log streaming not available\", http.StatusServiceUnavailable)\n\t\treturn\n\t}\n\n\tsub := h.logBroadcast.Subscribe(id)\n\tdefer h.logBroadcast.Unsubscribe(id, sub)\n\n\tctx := r.Context()\n\tfor {\n\t\tselect {\n\t\tcase <-ctx.Done():\n\t\t\treturn\n\t\tcase line, ok := <-sub.C:\n\t\t\tif !ok {\n\t\t\t\t// Stream finished (run completed)\n\t\t\t\tfmt.Fprintf(w, \"event: done\\ndata: completed\\n\\n\")\n\t\t\t\tflusher.Flush()\n\t\t\t\treturn\n\t\t\t}\n\t\t\tdata, _ := json.Marshal(line)\n\t\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n\t\t\tflusher.Flush()\n\t\t}\n\t}\n}\n\n// logLineRegex parses \"[timestamp] [type] content\" format from full.log.\nvar logLineRegex = regexp.MustCompile(`^\\[([^\\]]+)\\] \\[([^\\]]+)\\] (.*)$`)\n\n// streamFullLog reads the archived full.log file and sends its entries as SSE events.\nfunc (h *Handler) streamFullLog(w http.ResponseWriter, flusher http.Flusher, run *domain.Run) {\n\tlogPath := filepath.Join(run.ProjectDir, \".cloche\", run.ID, \"output\", \"full.log\")\n\tf, err := os.Open(logPath)\n\tif err != nil {\n\t\treturn\n\t}\n\tdefer f.Close()\n\n\tscanner := bufio.NewScanner(f)\n\tfor scanner.Scan() {\n\t\ttext := scanner.Text()\n\t\tline := parseFullLogLine(text)\n\t\tdata, _ := json.Marshal(line)\n\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n\t\tflusher.Flush()\n\t}\n}\n\n// parseFullLogLine parses a \"[timestamp] [type] content\" line into a LogLine.\nfunc parseFullLogLine(text string) logstream.LogLine {\n\tm := logLineRegex.FindStringSubmatch(text)\n\tif m == nil {\n\t\treturn logstream.LogLine{\n\t\t\tTimestamp: time.Now().UTC().Format(time.RFC3339),\n\t\t\tType:      \"script\",\n\t\t\tContent:   text,\n\t\t}\n\t}\n\treturn logstream.LogLine{\n\t\tTimestamp: m[1],\n\t\tType:      m[2],\n\t\tContent:   m[3],\n\t}\n}\n","numLines":100,"startLine":721,"totalLines":1306}}}
[2026-03-09T15:19:58Z] [llm] {"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01KSJ3ivGfbfjgWKhRm8nMAA","type":"message","role":"assistant","content":[{"type":"thinking","thinking":"Now I understand the problem clearly. Each line in full.log with type \"llm\" contains a raw stream-json event (a single JSON line from Claude Code's output). The `appendLogLine` function in run_detail.html displays each one as-is, which shows raw JSON to the user.\n\nThe best approach is to parse the LLM content client-side in the JavaScript, since each SSE event is a single stream-json line. We need to:\n\n1. In `appendLogLine`, detect `llm` type lines\n2. Parse the JSON content to extract meaningful data\n3. Only display text deltas, tool names, and results\n\n\n4. Skip metadata events\n\nI'm weighing whether to parse server-side before sending to the SSE stream versus handling it client-side in JavaScript. Server-side parsing would require maintaining state during live streaming, which gets complicated. Client-side keeps the server simpler and lets the client handle the presentation logic, so I'll go with parsing in the template.\n\nFor the client-side implementation, I need to handle each event type from the LLM JSON: show tool names for `content_block_start` with tool_use, display text deltas, skip input JSON deltas and metadata events like message_start and message_stop, and show result text when it appears.\n\nImplementing the parsing logic...","signature":""}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1925,"cache_read_input_tokens":24707,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1925},"output_tokens":8,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"681eabd5-00bc-42d3-9384-f3323237aaa3","uuid":"36a5280d-1be2-4f5d-928e-0b8153e35da9"}
[2026-03-09T15:19:58Z] [llm] {"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01KSJ3ivGfbfjgWKhRm8nMAA","type":"message","role":"assistant","content":[{"type":"text","text":"Now I understand the problem. The log viewer in `run_detail.html` displays every LLM log line verbatim, including raw JSON stream events like `{\"type\":\"content_block_delta\",\"delta\":{\"type\":\"text_delta\",\"text\":\"...\"}}`. The fix is to parse these client-side in the `appendLogLine` function, mirroring the logic from `logparse.FormatStreamJSON`."}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1925,"cache_read_input_tokens":24707,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1925},"output_tokens":8,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"681eabd5-00bc-42d3-9384-f3323237aaa3","uuid":"2657b505-8413-4626-9865-42b33aea20f1"}
[2026-03-09T15:19:58Z] [llm] {"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01KSJ3ivGfbfjgWKhRm8nMAA","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_018evXr9sjJTGZntBBUuLTRM","name":"Edit","input":{"replace_all":false,"file_path":"/workspace/internal/adapters/web/templates/run_detail.html","old_string":"    function appendLogLine(line) {\n        var span = document.createElement('span');\n        span.className = 'log-line log-type-' + (line.type || 'script');\n        span.textContent = '[' + line.timestamp + '] [' + line.type + '] ' + line.content + '\\n';\n        logContent.appendChild(span);\n        if (autoScroll) {\n            logViewer.scrollTop = logViewer.scrollHeight;\n        }\n    }","new_string":"    function parseLLMContent(content) {\n        // Parse Claude Code stream-json events and return human-readable text, or null to skip.\n        if (!content || content.charAt(0) !== '{') return content;\n        try {\n            var ev = JSON.parse(content);\n        } catch(e) {\n            return content;\n        }\n        switch (ev.type) {\n        case 'content_block_start':\n            if (ev.content_block && ev.content_block.type === 'tool_use' && ev.content_block.name) {\n                return '\\n--- ' + ev.content_block.name + ' ---';\n            }\n            return null; // skip text block starts\n        case 'content_block_delta':\n            if (ev.delta && ev.delta.type === 'text_delta' && ev.delta.text) {\n                return ev.delta.text;\n            }\n            return null; // skip input_json_delta\n        case 'result':\n            if (ev.result) return ev.result;\n            return null;\n        default:\n            // Skip metadata: message_start, message_delta, message_stop, content_block_stop\n            return null;\n        }\n    }\n\n    function appendLogLine(line) {\n        var type = line.type || 'script';\n        var text;\n\n        if (type === 'llm') {\n            text = parseLLMContent(line.content);\n            if (text === null) return; // skip noise events\n        } else {\n            text = '[' + line.timestamp + '] [' + type + '] ' + line.content;\n        }\n\n        var span = document.createElement('span');\n        span.className = 'log-line log-type-' + type;\n        span.textContent = text + '\\n';\n        logContent.appendChild(span);\n        if (autoScroll) {\n            logViewer.scrollTop = logViewer.scrollHeight;\n        }\n    }"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1925,"cache_read_input_tokens":24707,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1925},"output_tokens":8,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"681eabd5-00bc-42d3-9384-f3323237aaa3","uuid":"ba70a518-ea65-482b-8ab5-058485155367"}
[2026-03-09T15:19:58Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018evXr9sjJTGZntBBUuLTRM","type":"tool_result","content":"The file /workspace/internal/adapters/web/templates/run_detail.html has been updated successfully."}]},"parent_tool_use_id":null,"session_id":"681eabd5-00bc-42d3-9384-f3323237aaa3","uuid":"7ae07dc2-f3ed-4344-9a06-813d3321e3a8","tool_use_result":{"filePath":"/workspace/internal/adapters/web/templates/run_detail.html","oldString":"    function appendLogLine(line) {\n        var span = document.createElement('span');\n        span.className = 'log-line log-type-' + (line.type || 'script');\n        span.textContent = '[' + line.timestamp + '] [' + line.type + '] ' + line.content + '\\n';\n        logContent.appendChild(span);\n        if (autoScroll) {\n            logViewer.scrollTop = logViewer.scrollHeight;\n        }\n    }","newString":"    function parseLLMContent(content) {\n        // Parse Claude Code stream-json events and return human-readable text, or null to skip.\n        if (!content || content.charAt(0) !== '{') return content;\n        try {\n            var ev = JSON.parse(content);\n        } catch(e) {\n            return content;\n        }\n        switch (ev.type) {\n        case 'content_block_start':\n            if (ev.content_block && ev.content_block.type === 'tool_use' && ev.content_block.name) {\n                return '\\n--- ' + ev.content_block.name + ' ---';\n            }\n            return null; // skip text block starts\n        case 'content_block_delta':\n            if (ev.delta && ev.delta.type === 'text_delta' && ev.delta.text) {\n                return ev.delta.text;\n            }\n            return null; // skip input_json_delta\n        case 'result':\n            if (ev.result) return ev.result;\n            return null;\n        default:\n            // Skip metadata: message_start, message_delta, message_stop, content_block_stop\n            return null;\n        }\n    }\n\n    function appendLogLine(line) {\n        var type = line.type || 'script';\n        var text;\n\n        if (type === 'llm') {\n            text = parseLLMContent(line.content);\n            if (text === null) return; // skip noise events\n        } else {\n            text = '[' + line.timestamp + '] [' + type + '] ' + line.content;\n        }\n\n        var span = document.createElement('span');\n        span.className = 'log-line log-type-' + type;\n        span.textContent = text + '\\n';\n        logContent.appendChild(span);\n        if (autoScroll) {\n            logViewer.scrollTop = logViewer.scrollHeight;\n        }\n    }","originalFile":"{{define \"content\"}}\n<h1>\n    <a href=\"/runs\">Runs</a> / {{.Run.ID}}\n    <span class=\"badge badge-{{stateColor .Run.State}}\">{{.Run.State}}</span>\n</h1>\n\n<div class=\"run-meta\">\n    <dl>\n        <dt>Workflow</dt><dd>{{.Run.WorkflowName}}</dd>\n        <dt>Started</dt><dd>{{formatTime .Run.StartedAt}}</dd>\n        <dt>Completed</dt><dd>{{formatTime .Run.CompletedAt}}</dd>\n        <dt>Container</dt><dd class=\"mono\">{{.Run.ContainerID}}</dd>\n        <dt>Container Status</dt>\n        <dd id=\"container-status\">\n            {{if eq .ContainerState \"running\"}}\n                <span class=\"badge badge-running\">Container running</span>\n            {{else if eq .ContainerState \"stopped\"}}\n                <span class=\"badge badge-stopped\">Container stopped</span>\n            {{else if eq .ContainerState \"available\"}}\n                <span class=\"badge badge-succeeded\">Container available</span>\n                <button class=\"btn btn-danger btn-sm\" id=\"delete-container-btn\" onclick=\"deleteContainer('{{.Run.ID}}')\">Delete Container</button>\n            {{else}}\n                <span class=\"badge badge-pending\">Container removed</span>\n            {{end}}\n        </dd>\n    </dl>\n</div>\n\n{{if .Run.ErrorMessage}}\n<div class=\"error-box\">{{.Run.ErrorMessage}}</div>\n{{end}}\n\n<h2>Steps</h2>\n<table class=\"runs-table\">\n    <thead>\n        <tr>\n            <th>Step</th>\n            <th>Result</th>\n            <th>Started</th>\n            <th>Duration</th>\n        </tr>\n    </thead>\n    <tbody id=\"steps-body\">\n    {{if .Steps}}\n        {{range .Steps}}\n        <tr class=\"step-row\" data-run-id=\"{{$.Run.ID}}\" data-step=\"{{.StepName}}\" data-index=\"{{.Index}}\">\n            <td>{{.StepName}}</td>\n            <td>{{if .Result}}<span class=\"badge badge-{{if eq .Result \"success\"}}succeeded{{else if eq .Result \"fail\"}}failed{{else}}pending{{end}}\">{{.Result}}</span>{{else}}<span class=\"badge badge-running\">running</span>{{end}}</td>\n            <td>{{formatTime .StartedAt}}</td>\n            <td>{{.Duration}}</td>\n        </tr>\n        <tr class=\"output-row\" id=\"output-{{.Index}}\" style=\"display:none\">\n            <td colspan=\"4\"><pre class=\"step-output\">Loading...</pre></td>\n        </tr>\n        {{end}}\n    {{else}}\n        <tr><td colspan=\"4\" class=\"empty\">No step executions recorded.</td></tr>\n    {{end}}\n    </tbody>\n</table>\n\n<h2>\n    Log\n    <span id=\"log-status\" class=\"badge badge-running\" style=\"font-size:0.7rem; margin-left:0.5rem;\">Live</span>\n</h2>\n<div id=\"log-viewer\" class=\"log-viewer\"><pre id=\"log-content\"></pre></div>\n{{end}}\n\n{{define \"scripts\"}}\n<script>\n(function() {\n    var runState = '{{.Run.State}}';\n    var runID = '{{.Run.ID}}';\n\n    // --- Log Viewer ---\n    var logContent = document.getElementById('log-content');\n    var logViewer = document.getElementById('log-viewer');\n    var logStatus = document.getElementById('log-status');\n    var autoScroll = true;\n\n    // Track scroll position to enable/disable auto-scroll\n    logViewer.addEventListener('scroll', function() {\n        var atBottom = logViewer.scrollHeight - logViewer.scrollTop - logViewer.clientHeight < 40;\n        autoScroll = atBottom;\n    });\n\n    function appendLogLine(line) {\n        var span = document.createElement('span');\n        span.className = 'log-line log-type-' + (line.type || 'script');\n        span.textContent = '[' + line.timestamp + '] [' + line.type + '] ' + line.content + '\\n';\n        logContent.appendChild(span);\n        if (autoScroll) {\n            logViewer.scrollTop = logViewer.scrollHeight;\n        }\n    }\n\n    function markComplete() {\n        logStatus.textContent = 'Complete';\n        logStatus.className = 'badge badge-succeeded';\n    }\n\n    // Connect to SSE stream\n    var source = new EventSource('/api/runs/' + runID + '/stream');\n    source.onmessage = function(e) {\n        try {\n            var line = JSON.parse(e.data);\n            appendLogLine(line);\n        } catch(err) {}\n    };\n    source.addEventListener('done', function(e) {\n        markComplete();\n        source.close();\n    });\n    source.onerror = function() {\n        markComplete();\n        source.close();\n    };\n\n    // If already complete, mark the badge immediately\n    if (runState === 'succeeded' || runState === 'failed' || runState === 'cancelled') {\n        logStatus.textContent = 'Complete';\n        logStatus.className = 'badge badge-succeeded';\n    }\n\n    // --- Steps Polling (for active runs) ---\n    if (runState !== 'succeeded' && runState !== 'failed' && runState !== 'cancelled') {\n        function poll() {\n            fetch('/api/runs/' + runID)\n                .then(function(r) { return r.json(); })\n                .then(function(data) {\n                    if (data.state !== runState) {\n                        location.reload();\n                        return;\n                    }\n                    // Update container status\n                    var statusEl = document.getElementById('container-status');\n                    if (statusEl && data.container_state) {\n                        var cs = data.container_state;\n                        if (cs === 'running') {\n                            statusEl.innerHTML = '<span class=\"badge badge-running\">Container running</span>';\n                        } else if (cs === 'stopped') {\n                            statusEl.innerHTML = '<span class=\"badge badge-stopped\">Container stopped</span>';\n                        } else if (cs === 'available') {\n                            statusEl.innerHTML = '<span class=\"badge badge-succeeded\">Container available</span>' +\n                                ' <button class=\"btn btn-danger btn-sm\" id=\"delete-container-btn\" onclick=\"deleteContainer(\\'' + escapeHtml(runID) + '\\')\">Delete Container</button>';\n                        } else {\n                            statusEl.innerHTML = '<span class=\"badge badge-pending\">Container removed</span>';\n                        }\n                    }\n                    var tbody = document.getElementById('steps-body');\n                    if (!data.steps || data.steps.length === 0) {\n                        tbody.innerHTML = '<tr><td colspan=\"4\" class=\"empty\">No step executions recorded.</td></tr>';\n                        return;\n                    }\n                    var html = '';\n                    for (var i = 0; i < data.steps.length; i++) {\n                        var s = data.steps[i];\n                        var badge = '';\n                        if (s.result) {\n                            var cls = s.result === 'success' ? 'succeeded' : s.result === 'fail' ? 'failed' : 'pending';\n                            badge = '<span class=\"badge badge-' + cls + '\">' + escapeHtml(s.result) + '</span>';\n                        } else {\n                            badge = '<span class=\"badge badge-running\">running</span>';\n                        }\n                        html += '<tr class=\"step-row\" data-run-id=\"' + escapeHtml(runID) + '\" data-step=\"' + escapeHtml(s.step_name) + '\" data-index=\"' + i + '\">' +\n                            '<td>' + escapeHtml(s.step_name) + '</td>' +\n                            '<td>' + badge + '</td>' +\n                            '<td>' + s.started_at + '</td>' +\n                            '<td>' + s.duration + '</td>' +\n                            '</tr>' +\n                            '<tr class=\"output-row\" id=\"output-' + i + '\" style=\"display:none\">' +\n                            '<td colspan=\"4\"><pre class=\"step-output\">Loading...</pre></td>' +\n                            '</tr>';\n                    }\n                    tbody.innerHTML = html;\n                })\n                .catch(function() {});\n        }\n        setInterval(poll, 2000);\n    }\n\n    function escapeHtml(s) {\n        if (!s) return '';\n        var d = document.createElement('div');\n        d.appendChild(document.createTextNode(s));\n        return d.innerHTML;\n    }\n})();\n\n// Delete container\n    window.deleteContainer = function(runID) {\n        var btn = document.getElementById('delete-container-btn');\n        if (btn) btn.disabled = true;\n        fetch('/api/runs/' + runID + '/container', { method: 'DELETE' })\n            .then(function(r) { return r.json().then(function(d) { return {ok: r.ok, data: d}; }); })\n            .then(function(res) {\n                var statusEl = document.getElementById('container-status');\n                if (res.ok) {\n                    statusEl.innerHTML = '<span class=\"badge badge-pending\">Container removed</span>';\n                } else {\n                    if (btn) btn.disabled = false;\n                    alert('Failed to delete container: ' + (res.data.error || 'unknown error'));\n                }\n            })\n            .catch(function() {\n                if (btn) btn.disabled = false;\n                alert('Failed to delete container');\n            });\n    };\n\n    // Toggle step output rows\ndocument.addEventListener('click', function(e) {\n    var row = e.target.closest('.step-row');\n    if (!row) return;\n    var idx = row.dataset.index;\n    var outputRow = document.getElementById('output-' + idx);\n    if (!outputRow) return;\n\n    if (outputRow.style.display === 'none') {\n        outputRow.style.display = '';\n        var pre = outputRow.querySelector('.step-output');\n        if (pre.textContent === 'Loading...') {\n            var runId = row.dataset.runId;\n            var step = row.dataset.step;\n            fetch('/api/runs/' + runId + '/steps/' + step + '/output')\n                .then(function(r) {\n                    if (!r.ok) return 'No output available.';\n                    return r.text();\n                })\n                .then(function(text) { pre.textContent = text; })\n                .catch(function() { pre.textContent = 'Failed to load output.'; });\n        }\n    } else {\n        outputRow.style.display = 'none';\n    }\n});\n</script>\n{{end}}\n","structuredPatch":[{"oldStart":84,"oldLines":10,"newStart":84,"newLines":48,"lines":["         autoScroll = atBottom;","     });"," ","+    function parseLLMContent(content) {","+        // Parse Claude Code stream-json events and return human-readable text, or null to skip.","+        if (!content || content.charAt(0) !== '{') return content;","+        try {","+            var ev = JSON.parse(content);","+        } catch(e) {","+            return content;","+        }","+        switch (ev.type) {","+        case 'content_block_start':","+            if (ev.content_block && ev.content_block.type === 'tool_use' && ev.content_block.name) {","+                return '\\n--- ' + ev.content_block.name + ' ---';","+            }","+            return null; // skip text block starts","+        case 'content_block_delta':","+            if (ev.delta && ev.delta.type === 'text_delta' && ev.delta.text) {","+                return ev.delta.text;","+            }","+            return null; // skip input_json_delta","+        case 'result':","+            if (ev.result) return ev.result;","+            return null;","+        default:","+            // Skip metadata: message_start, message_delta, message_stop, content_block_stop","+            return null;","+        }","+    }","+","     function appendLogLine(line) {","+        var type = line.type || 'script';","+        var text;","+","+        if (type === 'llm') {","+            text = parseLLMContent(line.content);","+            if (text === null) return; // skip noise events","+        } else {","+            text = '[' + line.timestamp + '] [' + type + '] ' + line.content;","+        }","+","         var span = document.createElement('span');","-        span.className = 'log-line log-type-' + (line.type || 'script');","-        span.textContent = '[' + line.timestamp + '] [' + line.type + '] ' + line.content + '\\n';","+        span.className = 'log-line log-type-' + type;","+        span.textContent = text + '\\n';","         logContent.appendChild(span);","         if (autoScroll) {","             logViewer.scrollTop = logViewer.scrollHeight;"]}],"userModified":false,"replaceAll":false}}
