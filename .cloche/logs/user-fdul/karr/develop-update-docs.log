1→\t\t\t}\n   112→\t\tcase \"--prompt\", \"-p\":\n   113→\t\t\tif i+1 < len(args) {\n   114→\t\t\t\ti++\n   115→\t\t\t\tprompt = args[i]\n   116→\t\t\t}\n   117→\t\tcase \"--keep-container\":\n   118→\t\t\tkeepContainer = true\n   119→\t\tdefault:\n   120→\t\t\t// Support bare positional arg as workflow name for backwards compat\n   121→\t\t\tif workflow == \"\" && !strings.HasPrefix(args[i], \"-\") {\n   122→\t\t\t\tworkflow = args[i]\n   123→\t\t\t}\n   124→\t\t}\n   125→\t}\n   126→\n   127→\tif workflow == \"\" {\n   128→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche run --workflow <name> [--prompt \\\"...\\\"]\\n\")\n   129→\t\tos.Exit(1)\n   130→\t}\n   131→\n   132→\tcwd, _ := os.Getwd()\n   133→\n   134→\t// Resolve image from workflow file (soft failure — fall back to daemon default)\n   135→\tvar image string\n   136→\twfPath := filepath.Join(cwd, \".cloche\", workflow+\".cloche\")\n   137→\tif data, err := os.ReadFile(wfPath); err == nil {\n   138→\t\tif wf, err := dsl.Parse(string(data)); err == nil {\n   139→\t\t\timage = wf.Config[\"container.image\"]\n   140→\t\t}\n   141→\t}\n   142→\n   143→\tresp, err := client.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n   144→\t\tWorkflowName:  workflow,\n   145→\t\tProjectDir:    cwd,\n   146→\t\tImage:         image,\n   147→\t\tPrompt:        prompt,\n   148→\t\tKeepContainer: keepContainer,\n   149→\t})\n   150→\tif err != nil {\n   151→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   152→\t\tos.Exit(1)\n   153→\t}\n   154→\tfmt.Printf(\"Started run: %s\\n\", resp.RunId)\n   155→}\n   156→\n   157→func cmdStatus(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   158→\tif len(args) < 1 {\n   159→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche status <run-id>\\n\")\n   160→\t\tos.Exit(1)\n   161→\t}\n   162→\n   163→\tresp, err := client.GetStatus(ctx, &pb.GetStatusRequest{RunId: args[0]})\n   164→\tif err != nil {\n   165→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   166→\t\tos.Exit(1)\