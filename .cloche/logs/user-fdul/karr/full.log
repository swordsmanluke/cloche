gent\" shell script at test.cloche that outputs JSON status lines.\n    53→\t// The local runtime runs: sh <projectDir>/test.cloche\n    54→\tmsgs := []protocol.StatusMessage{\n    55→\t\t{Type: protocol.MsgStepStarted, StepName: \"build\"},\n    56→\t\t{Type: protocol.MsgStepCompleted, StepName: \"build\", Result: \"success\"},\n    57→\t\t{Type: protocol.MsgRunCompleted, Result: \"succeeded\"},\n    58→\t}\n    59→\tscript := \"#!/bin/sh\\n\"\n    60→\tfor _, msg := range msgs {\n    61→\t\tdata, _ := json.Marshal(msg)\n    62→\t\tscript += \"echo '\" + string(data) + \"'\\n\"\n    63→\t}\n    64→\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \".cloche\"), 0755))\n    65→\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"test.cloche\"), []byte(script), 0755))\n    66→\n    67→\t// Use \"sh\" as the agent binary so it runs: sh test.cloche\n    68→\trt := local.NewRuntime(\"sh\")\n    69→\tsrv := server.NewClocheServerWithCaptures(store, store, rt, \"\")\n    70→\n    71→\tresp, err := srv.RunWorkflow(context.Background(), &pb.RunWorkflowRequest{\n    72→\t\tWorkflowName: \"test\",\n    73→\t\tProjectDir:   dir,\n    74→\t\tPrompt:       \"hello world\",\n    75→\t})\n    76→\trequire.NoError(t, err)\n    77→\tassert.NotEmpty(t, resp.RunId)\n    78→\n    79→\t// Verify prompt was written to run-specific path\n    80→\tpromptData, err := os.ReadFile(filepath.Join(dir, \".cloche\", resp.RunId, \"prompt.txt\"))\n    81→\trequire.NoError(t, err)\n    82→\tassert.Equal(t, \"hello world\", string(promptData))\n    83→\n    84→\t// Poll until the background goroutine finishes processing (up to 5s)\n    85→\tvar status *pb.GetStatusResponse\n    86→\tdeadline := time.Now().Add(5 * time.Second)\n    87→\tfor time.Now().Before(deadline) {\n    88→\t\tstatus, err = srv.GetStatus(context.Background(), &pb.GetStatusRequest{RunId: resp.RunId})\n    89→\t\trequire.NoError(t, err)\n    90→\t\tif status.State == \"succeeded\" && len(status.StepExecutions) >= 1 {\n    91→\t\t\tbreak\n    92→\t\t}\n    93→\t\ttime.Sleep(50 * time.Millisecond)\n    94→\t}\n    95→\n    96→\t// Check that the run was tracked and completed\n    97→\trequire.NotNil(t, status)\n    98→\tassert.Equal(t, resp.RunId, status.RunId)\n    99→\tassert.Equal(t, \"succeeded\", status.State)\n   100→\tassert.GreaterOrEqual(t, len(status.StepExecutions), 1)\n   101→}\n   102→\n   103→func TestServer_RunWorkflow_CapturesStepMetadata(t *testing.T) {\n   104→\tstore, err := sqlite.NewStore(\":memory:\")\n   105→\trequire.NoError(t, err)\n   106→\tdefer store.Close()\n   107→\n   108→\tdir := t.TempDir()\n   109→\n   110→\t// Mock agent outputs status messages\n   111→\tmsgs := []protocol.StatusMessage{\n   112→\t\t{Type: protocol.MsgStepStarted, StepName: \"implement\"},\n   113→\t\t{Type: protocol.MsgStepCompleted, StepName: \"implement\", Result: \"success\"},\n   114→\t\t{Type: protocol.MsgRunCompleted, Result: \"succeeded\"},\n   115→\t}\n   116→\tscript := \"#!/bin/sh\\n\"\n   117→\tfor _, msg := range msgs {\n   118→\t\tdata, _ := json.Marshal(msg)\n   119→\t\tscript += \"echo '\" + string(data) + \"'\\n\"\n   120→\t}\n   121→\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \".cloche\"), 0755))\n   122→\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"capture.cloche\"), []byte(script), 0755))\n   123→\n   124→\trt := local.NewRuntime(\"sh\")\n   125→\tsrv := server.NewClocheServerWithCaptures(store, store, rt, \"\")\n   126→\n   127→\tresp, err := srv.RunWorkflow(context.Background(), &pb.RunWorkflowRequest{\n   128→\t\tWorkflowName: \"capture\",\n   129→\t\tProjectDir:   dir,\n   130→\t})\n   131→\trequire.NoError(t, err)\n   132→\n   133→\t// Poll until complete and captures are stored\n   134→\tvar captures []*domain.StepExecution\n   135→\tdeadline := time.Now().Add(5 * time.Second)\n   136→\tfor time.Now().Before(deadline) {\n   137→\t\tstatus, err := srv.GetStatus(context.Background(), &pb.GetStatusRequest{RunId: resp.RunId})\n   138→\t\trequire.NoError(t, err)\n   139→\t\tif status.State == \"succeeded\" {\n   140→\t\t\tcaptures, err = store.GetCaptures(context.Background(), resp.RunId)\n   141→\t\t\trequire.NoError(t, err)\n   142→\t\t\tif len(captures) >= 2 {\n   143→\t\t\t\tbreak\n   144→\t\t\t}\n   145→\t\t}\n   146→\t\ttime.Sleep(50 * time.Millisecond)\n   147→\t}\n   148→\n   149→\t// Should have 2 captures: one for step_started, one for step_completed\n   150→\trequire.GreaterOrEqual(t, len(captures), 2)\n   151→\n   152→\t// Check captures directly - one for step_started, one for step_completed\n   153→\tvar foundStarted, foundCompleted bool\n   154→\tfor _, c := range captures {\n   155→\t\tif c.StepName == \"implement\" && c.Result == \"\" {\n   156→\t\t\tfoundStarted = true\n   157→\t\t}\n   158→\t\tif c.StepName == \"implement\" && c.Result == \"success\" {\n   159→\t\t\tfoundCompleted = true\n   160→\t\t}\n   161→\t}\n   162→\tassert.True(t, foundStarted, \"should find capture for step started\")\n   163→\tassert.True(t, foundCompleted, \"should find capture for step completed\")\n   164→}\n   165→\n   166→func TestServer_StreamLogs(t *testing.T) {\n   167→\tstore, err := sqlite.NewStore(\":memory:\")\n   168→\trequire.NoError(t, err)\n   169→\tdefer store.Close()\n   170→\n   171→\tdir := t.TempDir()\n   172→\n   173→\t// Mock agent outputs status messages\n   174→\tmsgs := []protocol.StatusMessage{\n   175→\t\t{Type: protocol.MsgStepStarted, StepName: \"build\"},\n   176→\t\t{Type: protocol.MsgStepCompleted, StepName: \"build\", Result: \"success\"},\n   177→\t\t{Type: protocol.MsgRunCompleted, Result: \"succeeded\"},\n   178→\t}\n   179→\tscript := \"#!/bin/sh\\n\"\n   180→\tfor _, msg := range msgs {\n   181→\t\tdata, _ := json.Marshal(msg)\n   182→\t\tscript += \"echo '\" + string(data) + \"'\\n\"\n   183→\t}\n   184→\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \".cloche\"), 0755))\n   185→\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"test.cloche\"), []byte(script), 0755))\n   186→\n   187→\trt := local.NewRuntime(\"sh\")\n   188→\tsrv := server.NewClocheServerWithCaptures(store, store, rt, \"\")\n   189→\n   190→\tresp, err := srv.RunWorkflow(context.Background(), &pb.RunWorkflowRequest{\n   191→\t\tWorkflowName: \"test\",\n   192→\t\tProjectDir:   dir,\n   193→\t})\n   194→\trequire.NoError(t, err)\n   195→\n   196→\t// Poll until the run completes and captures are stored\n   197→\tdeadline := time.Now().Add(5 * time.Second)\n   198→\tfor time.Now().Before(deadline) {\n   199→\t\tstatus, err := srv.GetStatus(context.Background(), &pb.GetStatusRequest{RunId: resp.RunId})\n   200→\t\trequire.NoError(t, err)\n   201→\t\tif status.State == \"succeeded\" {\n   202→\t\t\tcaptures, _ := store.GetCaptures(context.Background(), resp.RunId)\n   203→\t\t\tif len(captures) >= 2 {\n   204→\t\t\t\tbreak\n   205→\t\t\t}\n   206→\t\t}\n   207→\t\ttime.Sleep(50 * time.Millisecond)\n   208→\t}\n   209→\n   210→\t// Use a mock stream to collect LogEntry messages\n   211→\tmock := &mockLogStream{ctx: context.Background()}\n   212→\terr = srv.StreamLogs(&pb.StreamLogsRequest{RunId: resp.RunId}, mock)\n   213→\trequire.NoError(t, err)\n   214→\n   215→\t// Should have entries: step_started, step_completed, run_completed\n   216→\trequire.GreaterOrEqual(t, len(mock.entries), 3)\n   217→\n   218→\t// Find step_started and step_completed entries\n   219→\tvar foundStarted, foundCompleted, foundRun bool\n   220→\tfor _, e := range mock.entries {\n   221→\t\tswitch e.Type {\n   222→\t\tcase \"step_started\":\n   223→\t\t\tif e.StepName == \"build\" {\n   224→\t\t\t\tfoundStarted = true\n   225→\t\t\t}\n   226→\t\tcase \"step_completed\":\n   227→\t\t\tif e.StepName == \"build\" {\n   228→\t\t\t\tfoundCompleted = true\n   229→\t\t\t\tassert.Equal(t, \"success\", e.Result)\n   230→\t\t\t}\n   231→\t\tcase \"run_completed\":\n   232→\t\t\tfoundRun = true\n   233→\t\t\tassert.Equal(t, \"succeeded\", e.Result)\n   234→\t\t}\n   235→\t}\n   236→\tassert.True(t, foundStarted, \"should find step_started for build\")\n   237→\tassert.True(t, foundCompleted, \"should find step_completed for build\")\n   238→\tassert.True(t, foundRun, \"should find run_completed\")\n   239→}\n   240→\n   241→// mockLogStream implements grpc.ServerStreamingServer[pb.LogEntry] for testing.\n   242→type mockLogStream struct {\n   243→\tgrpclib.ServerStream\n   244→\tctx     context.Context\n   245→\tentries []*pb.LogEntry\n   246→}\n   247→\n   248→func (m *mockLogStream) Send(entry *pb.LogEntry) error {\n   249→\tm.entries = append(m.entries, entry)\n   250→\treturn nil\n   251→}\n   252→\n   253→func (m *mockLogStream) Context() context.Context {\n   254→\treturn m.ctx\n   255→}\n   256→\n   257→func TestServer_StreamLogs_FallsBackToContainerLog(t *testing.T) {\n   258→\tstore, err := sqlite.NewStore(\":memory:\")\n   259→\trequire.NoError(t, err)\n   260→\tdefer store.Close()\n   261→\n   262→\tdir := t.TempDir()\n   263→\n   264→\t// Mock agent outputs a step that fails — no per-step output file will exist\n   265→\tmsgs := []protocol.StatusMessage{\n   266→\t\t{Type: protocol.MsgStepStarted, StepName: \"implement\"},\n   267→\t\t{Type: protocol.MsgStepCompleted, StepName: \"implement\", Result: \"fail\"},\n   268→\t\t{Type: protocol.MsgRunCompleted, Result: \"failed\"},\n   269→\t}\n   270→\tscript := \"#!/bin/sh\\n\"\n   271→\tfor _, msg := range msgs {\n   272→\t\tdata, _ := json.Marshal(msg)\n   273→\t\tscript += \"echo '\" + string(data) + \"'\\n\"\n   274→\t}\n   275→\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \".cloche\"), 0755))\n   276→\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"test.cloche\"), []byte(script), 0755))\n   277→\n   278→\trt := local.NewRuntime(\"sh\")\n   279→\tsrv := server.NewClocheServerWithCaptures(store, store, rt, \"\")\n   280→\n   281→\tresp, err := srv.RunWorkflow(context.Background(), &pb.RunWorkflowRequest{\n   282→\t\tWorkflowName: \"test\",\n   283→\t\tProjectDir:   dir,\n   284→\t})\n   285→\trequire.NoError(t, err)\n   286→\n   287→\t// Poll until run completes\n   288→\tdeadline := time.Now().Add(5 * time.Second)\n   289→\tfor time.Now().Before(deadline) {\n   290→\t\tstatus, err := srv.GetStatus(context.Background(), &pb.GetStatusRequest{RunId: resp.RunId})\n   291→\t\trequire.NoError(t, err)\n   292→\t\tif status.State != \"running\" && status.State != \"pending\" {\n   293→\t\t\tcaptures, _ := store.GetCaptures(context.Background(), resp.RunId)\n   294→\t\t\tif len(captures) >= 2 {\n   295→\t\t\t\tbreak\n   296→\t\t\t}\n   297→\t\t}\n   298→\t\ttime.Sleep(50 * time.Millisecond)\n   299→\t}\n   300→\n   301→\t// Simulate container.log being written (local runtime Logs() returns empty,\n   302→\t// so write it manually to test the StreamLogs fallback path)\n   303→\toutputDir := filepath.Join(dir, \".cloche\", resp.RunId, \"output\")\n   304→\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n   305→\trequire.NoError(t, os.WriteFile(\n   306→\t\tfilepath.Join(outputDir, \"container.log\"),\n   307→\t\t[]byte(\"error: compilation failed\\ndetailed stack trace here\"),\n   308→\t\t0644,\n   309→\t))\n   310→\n   311→\t// Stream logs and verify the step_completed entry falls back to container.log\n   312→\tmock := &mockLogStream{ctx: context.Background()}\n   313→\terr = srv.StreamLogs(&pb.StreamLogsRequest{RunId: resp.RunId}, mock)\n   314→\trequire.NoError(t, err)\n   315→\n   316→\tvar foundCompleted bool\n   317→\tfor _, e := range mock.entries {\n   318→\t\tif e.Type == \"step_completed\" && e.StepName == \"implement\" {\n   319→\t\t\tfoundCompleted = true\n   320→\t\t\tassert.Equal(t, \"fail\", e.Result)\n   321→\t\t\tassert.Contains(t, e.Message, \"error: compilation failed\")\n   322→\t\t\tassert.Contains(t, e.Message, \"detailed stack trace here\")\n   323→\t\t}\n   324→\t}\n   325→\tassert.True(t, foundCompleted, \"should find step_completed with container.log fallback content\")\n   326→}\n   327→\n   328→func TestServer_StreamLogs_PrefersStepOutput(t *testing.T) {\n   329→\tstore, err := sqlite.NewStore(\":memory:\")\n   330→\trequire.NoError(t, err)\n   331→\tdefer store.Close()\n   332→\n   333→\tdir := t.TempDir()\n   334→\n   335→\tmsgs := []protocol.StatusMessage{\n   336→\t\t{Type: protocol.MsgStepStarted, StepName: \"build\"},\n   337→\t\t{Type: protocol.MsgStepCompleted, StepName: \"build\", Result: \"success\"},\n   338→\t\t{Type: protocol.MsgRunCompleted, Result: \"succeeded\"},\n   339→\t}\n   340→\tscript := \"#!/bin/sh\\n\"\n   341→\tfor _, msg := range msgs {\n   342→\t\tdata, _ := json.Marshal(msg)\n   343→\t\tscript += \"echo '\" + string(data) + \"'\\n\"\n   344→\t}\n   345→\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \".cloche\"), 0755))\n   346→\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"test.cloche\"), []byte(script), 0755))\n   347→\n   348→\trt := local.NewRuntime(\"sh\")\n   349→\tsrv := server.NewClocheServerWithCaptures(store, store, rt, \"\")\n   350→\n   351→\tresp, err := srv.RunWorkflow(context.Background(), &pb.RunWorkflowRequest{\n   352→\t\tWorkflowName: \"test\",\n   353→\t\tProjectDir:   dir,\n   354→\t})\n   355→\trequire.NoError(t, err)\n   356→\n   357→\t// Poll until complete\n   358→\tdeadline := time.Now().Add(5 * time.Second)\n   359→\tfor time.Now().Before(deadline) {\n   360→\t\tstatus, err := srv.GetStatus(context.Background(), &pb.GetStatusRequest{RunId: resp.RunId})\n   361→\t\trequire.NoError(t, err)\n   362→\t\tif status.State == \"succeeded\" {\n   363→\t\t\tcaptures, _ := store.GetCaptures(context.Background(), resp.RunId)\n   364→\t\t\tif len(captures) >= 2 {\n   365→\t\t\t\tbreak\n   366→\t\t\t}\n   367→\t\t}\n   368→\t\ttime.Sleep(50 * time.Millisecond)\n   369→\t}\n   370→\n   371→\t// Write both per-step output AND container.log — per-step should win\n   372→\toutputDir := filepath.Join(dir, \".cloche\", resp.RunId, \"output\")\n   373→\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n   374→\trequire.NoError(t, os.WriteFile(filepath.Join(outputDir, \"build.log\"), []byte(\"step-specific output\"), 0644))\n   375→\trequire.NoError(t, os.WriteFile(filepath.Join(outputDir, \"container.log\"), []byte(\"full container output\"), 0644))\n   376→\n   377→\tmock := &mockLogStream{ctx: context.Background()}\n   378→\terr = srv.StreamLogs(&pb.StreamLogsRequest{RunId: resp.RunId}, mock)\n   379→\trequire.NoError(t, err)\n   380→\n   381→\tvar foundCompleted bool\n   382→\tfor _, e := range mock.entries {\n   383→\t\tif e.Type == \"step_completed\" && e.StepName == \"build\" {\n   384→\t\t\tfoundCompleted = true\n   385→\t\t\tassert.Equal(t, \"step-specific output\", e.Message, \"should prefer per-step output over container.log\")\n   386→\t\t}\n   387→\t}\n   388→\tassert.True(t, foundCompleted, \"should find step_completed entry\")\n   389→}\n   390→\n   391→func TestServer_GetStatus_ContainerID(t *testing.T) {\n   392→\tstore, err := sqlite.NewStore(\":memory:\")\n   393→\trequire.NoError(t, err)\n   394→\tdefer store.Close()\n   395→\n   396→\tctx := context.Background()\n   397→\trun := domain.NewRun(\"cid-test\", \"develop\")\n   398→\trun.Start()\n   399→\trun.ContainerID = \"4647e7e70e3fabc123def456\"\n   400→\trequire.NoError(t, store.CreateRun(ctx, run))\n   401→\n   402→\tsrv := server.NewClocheServer(store, nil)\n   403→\tresp, err := srv.GetStatus(ctx, &pb.GetStatusRequest{RunId: \"cid-test\"})\n   404→\trequire.NoError(t, err)\n   405→\tassert.Equal(t, \"4647e7e70e3fabc123def456\", resp.ContainerId)\n   406→}\n   407→\n   408→func TestServer_Shutdown(t *testing.T) {\n   409→\tstore, err := sqlite.NewStore(\":memory:\")\n   410→\trequire.NoError(t, err)\n   411→\tdefer store.Close()\n   412→\n   413→\tsrv := server.NewClocheServer(store, nil)\n   414→\n   415→\tcalled := make(chan struct{}, 1)\n   416→\tsrv.SetShutdownFunc(func() { called <- struct{}{} })\n   417→\n   418→\tresp, err := srv.Shutdown(context.Background(), &pb.ShutdownRequest{})\n   419→\trequire.NoError(t, err)\n   420→\tassert.NotNil(t, resp)\n   421→\n   422→\tselect {\n   423→\tcase <-called:\n   424→\tcase <-time.After(time.Second):\n   425→\t\tt.Fatal(\"shutdown callback was not called\")\n   426→\t}\n   427→}\n   428→\n   429→func TestServer_Shutdown_NotConfigured(t *testing.T) {\n   430→\tstore, err := sqlite.NewStore(\":memory:\")\n   431→\trequire.NoError(t, err)\n   432→\tdefer store.Close()\n   433→\n   434→\tsrv := server.NewClocheServer(store, nil)\n   435→\n   436→\t_, err = srv.Shutdown(context.Background(), &pb.ShutdownRequest{})\n   437→\tassert.Error(t, err)\n   438→\tassert.Contains(t, err.Error(), \"shutdown not configured\")\n   439→}\n   440→\n   441→func TestServer_RunWorkflow_NoRuntime(t *testing.T) {\n   442→\tstore, err := sqlite.NewStore(\":memory:\")\n   443→\trequire.NoError(t, err)\n   444→\tdefer store.Close()\n   445→\n   446→\tsrv := server.NewClocheServer(store, nil)\n   447→\t_, err = srv.RunWorkflow(context.Background(), &pb.RunWorkflowRequest{\n   448→\t\tWorkflowName: \"test\",\n   449→\t\tProjectDir:   t.TempDir(),\n   450→\t})\n   451→\tassert.Error(t, err)\n   452→\tassert.Contains(t, err.Error(), \"no container runtime configured\")\n   453→}\n   454→\n   455→// trackingRuntime wraps a local.Runtime and tracks Remove calls.\n   456→type trackingRuntime struct {\n   457→\t*local.Runtime\n   458→\tremoveCalled atomic.Int32\n   459→}\n   460→\n   461→func (tr *trackingRuntime) Remove(ctx context.Context, containerID string) error {\n   462→\ttr.removeCalled.Add(1)\n   463→\treturn tr.Runtime.Remove(ctx, containerID)\n   464→}\n   465→\n   466→// ensuringRuntime wraps a local.Runtime and implements ImageEnsurer to track calls.\n   467→type ensuringRuntime struct {\n   468→\t*local.Runtime\n   469→\tensureCalled atomic.Int32\n   470→\tensureErr    error\n   471→}\n   472→\n   473→func (e *ensuringRuntime) EnsureImage(ctx context.Context, projectDir, image string) error {\n   474→\te.ensureCalled.Add(1)\n   475→\treturn e.ensureErr\n   476→}\n   477→\n   478→func TestServer_RunWorkflow_CallsEnsureImage(t *testing.T) {\n   479→\tstore, err := sqlite.NewStore(\":memory:\")\n   480→\trequire.NoError(t, err)\n   481→\tdefer store.Close()\n   482→\n   483→\tdir := t.TempDir()\n   484→\n   485→\tmsgs := []protocol.StatusMessage{\n   486→\t\t{Type: protocol.MsgStepStarted, StepName: \"build\"},\n   487→\t\t{Type: protocol.MsgStepCompleted, StepName: \"build\", Result: \"success\"},\n   488→\t\t{Type: protocol.MsgRunCompleted, Result: \"succeeded\"},\n   489→\t}\n   490→\tscript := \"#!/bin/sh\\n\"\n   491→\tfor _, msg := range msgs {\n   492→\t\tdata, _ := json.Marshal(msg)\n   493→\t\tscript += \"echo '\" + string(data) + \"'\\n\"\n   494→\t}\n   495→\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \".cloche\"), 0755))\n   496→\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"test.cloche\"), []byte(script), 0755))\n   497→\n   498→\trt := &ensuringRuntime{Runtime: local.NewRuntime(\"sh\")}\n   499→\tsrv := server.NewClocheServerWithCaptures(store, store, rt, \"test-image:latest\")\n   500→\n   501→\tresp, err := srv.RunWorkflow(context.Background(), &pb.RunWorkflowRequest{\n   502→\t\tWorkflowName: \"test\",\n   503→\t\tProjectDir:   dir,\n   504→\t})\n   505→\trequire.NoError(t, err)\n   506→\n   507→\t// Wait for run to complete\n   508→\tdeadline := time.Now().Add(5 * time.Second)\n   509→\tfor time.Now().Before(deadline) {\n   510→\t\tstatus, err := srv.GetStatus(context.Background(), &pb.GetStatusRequest{RunId: resp.RunId})\n   511→\t\trequire.NoError(t, err)\n   512→\t\tif status.State == \"succeeded\" {\n   513→\t\t\tbreak\n   514→\t\t}\n   515→\t\ttime.Sleep(50 * time.Millisecond)\n   516→\t}\n   517→\n   518→\tassert.Equal(t, int32(1), rt.ensureCalled.Load(), \"EnsureImage should be called once\")\n   519→}\n   520→\n   521→func TestServer_RunWorkflow_FailedRunKeepsContainer(t *testing.T) {\n   522→\tstore, err := sqlite.NewStore(\":memory:\")\n   523→\trequire.NoError(t, err)\n   524→\tdefer store.Close()\n   525→\n   526→\tdir := t.TempDir()\n   527→\n   528→\t// Mock agent outputs a failed run and exits with non-zero code\n   529→\tmsgs := []protocol.StatusMessage{\n   530→\t\t{Type: protocol.MsgStepStarted, StepName: \"build\"},\n   531→\t\t{Type: protocol.MsgStepCompleted, StepName: \"build\", Result: \"fail\"},\n   532→\t\t{Type: protocol.MsgRunCompleted, Result: \"failed\"},\n   533→\t}\n   534→\tscript := \"#!/bin/sh\\n\"\n   535→\tfor _, msg := range msgs {\n   536→\t\tdata, _ := json.Marshal(msg)\n   537→\t\tscript += \"echo '\" + string(data) + \"'\\n\"\n   538→\t}\n   539→\tscript += \"exit 1\\n\"\n   540→\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \".cloche\"), 0755))\n   541→\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"test.cloche\"), []byte(script), 0755))\n   542→\n   543→\trt := &trackingRuntime{Runtime: local.NewRuntime(\"sh\")}\n   544→\tsrv := server.NewClocheServerWithCaptures(store, store, rt, \"\")\n   545→\n   546→\tresp, err := srv.RunWorkflow(context.Background(), &pb.RunWorkflowRequest{\n   547→\t\tWorkflowName:  \"test\",\n   548→\t\tProjectDir:    dir,\n   549→\t\tKeepContainer: false, // NOT requesting keep, but should still keep on failure\n   550→\t})\n   551→\trequire.NoError(t, err)\n   552→\n   553→\t// Poll until the run completes (failed state)\n   554→\tdeadline := time.Now().Add(5 * time.Second)\n   555→\tfor time.Now().Before(deadline) {\n   556→\t\tstatus, err := srv.GetStatus(context.Background(), &pb.GetStatusRequest{RunId: resp.RunId})\n   557→\t\trequire.NoError(t, err)\n   558→\t\tif status.State == \"failed\" {\n   559→\t\t\tbreak\n   560→\t\t}\n   561→\t\ttime.Sleep(50 * time.Millisecond)\n   562→\t}\n   563→\n   564→\t// Wait for post-completion cleanup (container retention logic) to finish\n   565→\ttime.Sleep(500 * time.Millisecond)\n   566→\n   567→\t// Container should NOT have been removed\n   568→\tassert.Equal(t, int32(0), rt.removeCalled.Load(), \"Remove should not be called for failed runs\")\n   569→\n   570→\t// ContainerKept should be true in the store\n   571→\trun, err := store.GetRun(context.Background(), resp.RunId)\n   572→\trequire.NoError(t, err)\n   573→\tassert.Equal(t, domain.RunStateFailed, run.State)\n   574→\tassert.True(t, run.ContainerKept, \"ContainerKept should be true for failed runs\")\n   575→}\n   576→\n   577→func TestServer_RunWorkflow_SucceededRunRemovesContainer(t *testing.T) {\n   578→\tstore, err := sqlite.NewStore(\":memory:\")\n   579→\trequire.NoError(t, err)\n   580→\tdefer store.Close()\n   581→\n   582→\tdir := t.TempDir()\n   583→\n   584→\t// Mock agent outputs a successful run\n   585→\tmsgs := []protocol.StatusMessage{\n   586→\t\t{Type: protocol.MsgStepStarted, StepName: \"build\"},\n   587→\t\t{Type: protocol.MsgStepCompleted, StepName: \"build\", Result: \"success\"},\n   588→\t\t{Type: protocol.MsgRunCompleted, Result: \"succeeded\"},\n   589→\t}\n   590→\tscript := \"#!/bin/sh\\n\"\n   591→\tfor _, msg := range msgs {\n   592→\t\tdata, _ := json.Marshal(msg)\n   593→\t\tscript += \"echo '\" + string(data) + \"'\\n\"\n   594→\t}\n   595→\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \".cloche\"), 0755))\n   596→\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"test.cloche\"), []byte(script), 0755))\n   597→\n   598→\trt := &trackingRuntime{Runtime: local.NewRuntime(\"sh\")}\n   599→\tsrv := server.NewClocheServerWithCaptures(store, store, rt, \"\")\n   600→\n   601→\tresp, err := srv.RunWorkflow(context.Background(), &pb.RunWorkflowRequest{\n   602→\t\tWorkflowName:  \"test\",\n   603→\t\tProjectDir:    dir,\n   604→\t\tKeepContainer: false,\n   605→\t})\n   606→\trequire.NoError(t, err)\n   607→\n   608→\t// Poll until the run completes\n   609→\tdeadline := time.Now().Add(5 * time.Second)\n   610→\tfor time.Now().Before(deadline) {\n   611→\t\tstatus, err := srv.GetStatus(context.Background(), &pb.GetStatusRequest{RunId: resp.RunId})\n   612→\t\trequire.NoError(t, err)\n   613→\t\tif status.State == \"succeeded\" {\n   614→\t\t\tbreak\n   615→\t\t}\n   616→\t\ttime.Sleep(50 * time.Millisecond)\n   617→\t}\n   618→\n   619→\t// Wait a bit more for the post-completion cleanup to run\n   620→\ttime.Sleep(200 * time.Millisecond)\n   621→\n   622→\t// Container should have been removed\n   623→\tassert.Equal(t, int32(1), rt.removeCalled.Load(), \"Remove should be called for succeeded runs without --keep-container\")\n   624→\n   625→\t// ContainerKept should be false\n   626→\trun, err := store.GetRun(context.Background(), resp.RunId)\n   627→\trequire.NoError(t, err)\n   628→\tassert.False(t, run.ContainerKept, \"ContainerKept should be false for succeeded runs\")\n   629→}\n   630→\n   631→func TestServer_RunWorkflow_KeepContainerOnSuccess(t *testing.T) {\n   632→\tstore, err := sqlite.NewStore(\":memory:\")\n   633→\trequire.NoError(t, err)\n   634→\tdefer store.Close()\n   635→\n   636→\tdir := t.TempDir()\n   637→\n   638→\t// Mock agent outputs a successful run\n   639→\tmsgs := []protocol.StatusMessage{\n   640→\t\t{Type: protocol.MsgStepStarted, StepName: \"build\"},\n   641→\t\t{Type: protocol.MsgStepCompleted, StepName: \"build\", Result: \"success\"},\n   642→\t\t{Type: protocol.MsgRunCompleted, Result: \"succeeded\"},\n   643→\t}\n   644→\tscript := \"#!/bin/sh\\n\"\n   645→\tfor _, msg := range msgs {\n   646→\t\tdata, _ := json.Marshal(msg)\n   647→\t\tscript += \"echo '\" + string(data) + \"'\\n\"\n   648→\t}\n   649→\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \".cloche\"), 0755))\n   650→\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"test.cloche\"), []byte(script), 0755))\n   651→\n   652→\trt := &trackingRuntime{Runtime: local.NewRuntime(\"sh\")}\n   653→\tsrv := server.NewClocheServerWithCaptures(store, store, rt, \"\")\n   654→\n   655→\tresp, err := srv.RunWorkflow(context.Background(), &pb.RunWorkflowRequest{\n   656→\t\tWorkflowName:  \"test\",\n   657→\t\tProjectDir:    dir,\n   658→\t\tKeepContainer: true, // --keep-container flag set\n   659→\t})\n   660→\trequire.NoError(t, err)\n   661→\n   662→\t// Poll until the run completes\n   663→\tdeadline := time.Now().Add(5 * time.Second)\n   664→\tfor time.Now().Before(deadline) {\n   665→\t\tstatus, err := srv.GetStatus(context.Background(), &pb.GetStatusRequest{RunId: resp.RunId})\n   666→\t\trequire.NoError(t, err)\n   667→\t\tif status.State == \"succeeded\" {\n   668→\t\t\tbreak\n   669→\t\t}\n   670→\t\ttime.Sleep(50 * time.Millisecond)\n   671→\t}\n   672→\n   673→\t// Wait a bit more for the post-completion cleanup to run\n   674→\ttime.Sleep(200 * time.Millisecond)\n   675→\n   676→\t// Container should NOT have been removed (--keep-container)\n   677→\tassert.Equal(t, int32(0), rt.removeCalled.Load(), \"Remove should not be called when --keep-container is set\")\n   678→\n   679→\t// ContainerKept should be true\n   680→\trun, err := store.GetRun(context.Background(), resp.RunId)\n   681→\trequire.NoError(t, err)\n   682→\tassert.True(t, run.ContainerKept, \"ContainerKept should be true with --keep-container\")\n   683→}\n   684→\n   685→func TestServer_DeleteContainer_ByRunID(t *testing.T) {\n   686→\tstore, err := sqlite.NewStore(\":memory:\")\n   687→\trequire.NoError(t, err)\n   688→\tdefer store.Close()\n   689→\n   690→\tctx := context.Background()\n   691→\n   692→\t// Create a run with a container ID and container_kept=true\n   693→\trun := domain.NewRun(\"delete-test-run\", \"develop\")\n   694→\trun.Start()\n   695→\trun.ContainerID = \"abc123def456\"\n   696→\trun.ContainerKept = true\n   697→\trun.Complete(domain.RunStateFailed)\n   698→\trequire.NoError(t, store.CreateRun(ctx, run))\n   699→\n   700→\trt := &trackingRuntime{Runtime: local.NewRuntime(\"sh\")}\n   701→\tsrv := server.NewClocheServer(store, rt)\n   702→\n   703→\tresp, err := srv.DeleteContainer(ctx, &pb.DeleteContainerRequest{Id: \"delete-test-run\"})\n   704→\trequire.NoError(t, err)\n   705→\tassert.NotNil(t, resp)\n   706→\n   707→\t// Verify Remove was called\n   708→\tassert.Equal(t, int32(1), rt.removeCalled.Load())\n   709→\n   710→\t// Verify container_kept was cleared\n   711→\tupdated, err := store.GetRun(ctx, \"delete-test-run\")\n   712→\trequire.NoError(t, err)\n   713→\tassert.False(t, updated.ContainerKept)\n   714→}\n   715→\n   716→func TestServer_DeleteContainer_ByContainerID(t *testing.T) {\n   717→\tstore, err := sqlite.NewStore(\":memory:\")\n   718→\trequire.NoError(t, err)\n   719→\tdefer store.Close()\n   720→\n   721→\tctx := context.Background()\n   722→\trt := &trackingRuntime{Runtime: local.NewRuntime(\"sh\")}\n   723→\tsrv := server.NewClocheServer(store, rt)\n   724→\n   725→\t// Pass a raw container ID (not a run ID)\n   726→\tresp, err := srv.DeleteContainer(ctx, &pb.DeleteContainerRequest{Id: \"some-docker-container-id\"})\n   727→\trequire.NoError(t, err)\n   728→\tassert.NotNil(t, resp)\n   729→\n   730→\t// Remove should still be called with the container ID\n   731→\tassert.Equal(t, int32(1), rt.removeCalled.Load())\n   732→}\n   733→\n   734→func TestServer_DeleteContainer_EmptyID(t *testing.T) {\n   735→\tstore, err := sqlite.NewStore(\":memory:\")\n   736→\trequire.NoError(t, err)\n   737→\tdefer store.Close()\n   738→\n   739→\tsrv := server.NewClocheServer(store, &trackingRuntime{Runtime: local.NewRuntime(\"sh\")})\n   740→\t_, err = srv.DeleteContainer(context.Background(), &pb.DeleteContainerRequest{Id: \"\"})\n   741→\tassert.Error(t, err)\n   742→\tassert.Contains(t, err.Error(), \"id is required\")\n   743→}\n   744→\n   745→func TestServer_DeleteContainer_NoRuntime(t *testing.T) {\n   746→\tstore, err := sqlite.NewStore(\":memory:\")\n   747→\trequire.NoError(t, err)\n   748→\tdefer store.Close()\n   749→\n   750→\tsrv := server.NewClocheServer(store, nil)\n   751→\t_, err = srv.DeleteContainer(context.Background(), &pb.DeleteContainerRequest{Id: \"some-id\"})\n   752→\tassert.Error(t, err)\n   753→\tassert.Contains(t, err.Error(), \"no container runtime configured\")\n   754→}\n   755→\n   756→func TestServer_DeleteContainer_RunWithNoContainer(t *testing.T) {\n   757→\tstore, err := sqlite.NewStore(\":memory:\")\n   758→\trequire.NoError(t, err)\n   759→\tdefer store.Close()\n   760→\n   761→\tctx := context.Background()\n   762→\n   763→\t// Create a run without a container ID\n   764→\trun := domain.NewRun(\"no-container-run\", \"develop\")\n   765→\trun.Start()\n   766→\trequire.NoError(t, store.CreateRun(ctx, run))\n   767→\n   768→\trt := &trackingRuntime{Runtime: local.NewRuntime(\"sh\")}\n   769→\tsrv := server.NewClocheServer(store, rt)\n   770→\n   771→\t_, err = srv.DeleteContainer(ctx, &pb.DeleteContainerRequest{Id: \"no-container-run\"})\n   772→\tassert.Error(t, err)\n   773→\tassert.Contains(t, err.Error(), \"no associated container\")\n   774→}\n   775→\n   776→func TestServer_RunWorkflow_EnsureImageFailure(t *testing.T) {\n   777→\tstore, err := sqlite.NewStore(\":memory:\")\n   778→\trequire.NoError(t, err)\n   779→\tdefer store.Close()\n   780→\n   781→\tdir := t.TempDir()\n   782→\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \".cloche\"), 0755))\n   783→\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"test.cloche\"), []byte(\"#!/bin/sh\\necho ok\\n\"), 0755))\n   784→\n   785→\trt := &ensuringRuntime{\n   786→\t\tRuntime:   local.NewRuntime(\"sh\"),\n   787→\t\tensureErr: fmt.Errorf(\"build failed: Dockerfile syntax error\"),\n   788→\t}\n   789→\tsrv := server.NewClocheServerWithCaptures(store, store, rt, \"test-image:latest\")\n   790→\n   791→\tresp, err := srv.RunWorkflow(context.Background(), &pb.RunWorkflowRequest{\n   792→\t\tWorkflowName: \"test\",\n   793→\t\tProjectDir:   dir,\n   794→\t})\n   795→\trequire.NoError(t, err) // RPC returns immediately\n   796→\n   797→\t// Wait for the background goroutine to mark the run as failed\n   798→\tdeadline := time.Now().Add(5 * time.Second)\n   799→\tvar status *pb.GetStatusResponse\n   800→\tfor time.Now().Before(deadline) {\n   801→\t\tstatus, err = srv.GetStatus(context.Background(), &pb.GetStatusRequest{RunId: resp.RunId})\n   802→\t\trequire.NoError(t, err)\n   803→\t\tif status.State == \"failed\" {\n   804→\t\t\tbreak\n   805→\t\t}\n   806→\t\ttime.Sleep(50 * time.Millisecond)\n   807→\t}\n   808→\n   809→\tassert.Equal(t, \"failed\", status.State)\n   810→\tassert.Contains(t, status.ErrorMessage, \"failed to ensure image\")\n   811→}\n   812→\n   813→func TestServer_LogIndexing(t *testing.T) {\n   814→\tstore, err := sqlite.NewStore(\":memory:\")\n   815→\trequire.NoError(t, err)\n   816→\tdefer store.Close()\n   817→\n   818→\tdir := t.TempDir()\n   819→\n   820→\t// Mock agent that outputs status messages and creates output files\n   821→\tmsgs := []protocol.StatusMessage{\n   822→\t\t{Type: protocol.MsgStepStarted, StepName: \"build\"},\n   823→\t\t{Type: protocol.MsgStepCompleted, StepName: \"build\", Result: \"success\"},\n   824→\t\t{Type: protocol.MsgRunCompleted, Result: \"succeeded\"},\n   825→\t}\n   826→\tscript := \"#!/bin/sh\\n\"\n   827→\t// Create output directory and files from within the script\n   828→\t// Local runtime sets working dir to projectDir, so use relative paths\n   829→\tscript += \"mkdir -p .cloche/output\\n\"\n   830→\tscript += \"echo 'build script output' > .cloche/output/build.log\\n\"\n   831→\tscript += \"echo 'build llm output' > .cloche/output/llm-build.log\\n\"\n   832→\tscript += \"echo 'full unified log' > .cloche/output/full.log\\n\"\n   833→\tfor _, msg := range msgs {\n   834→\t\tdata, _ := json.Marshal(msg)\n   835→\t\tscript += \"echo '\" + string(data) + \"'\\n\"\n   836→\t}\n   837→\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \".cloche\"), 0755))\n   838→\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"test.cloche\"), []byte(script), 0755))\n   839→\n   840→\trt := local.NewRuntime(\"sh\")\n   841→\tsrv := server.NewClocheServerWithCaptures(store, store, rt, \"\")\n   842→\tsrv.SetLogStore(store)\n   843→\n   844→\tresp, err := srv.RunWorkflow(context.Background(), &pb.RunWorkflowRequest{\n   845→\t\tWorkflowName: \"test\",\n   846→\t\tProjectDir:   dir,\n   847→\t})\n   848→\trequire.NoError(t, err)\n   849→\n   850→\t// Poll until complete\n   851→\tdeadline := time.Now().Add(5 * time.Second)\n   852→\tfor time.Now().Before(deadline) {\n   853→\t\tstatus, err := srv.GetStatus(context.Background(), &pb.GetStatusRequest{RunId: resp.RunId})\n   854→\t\trequire.NoError(t, err)\n   855→\t\tif status.State == \"succeeded\" {\n   856→\t\t\tbreak\n   857→\t\t}\n   858→\t\ttime.Sleep(50 * time.Millisecond)\n   859→\t}\n   860→\n   861→\t// Wait for post-completion processing (log indexing happens after run completes)\n   862→\ttime.Sleep(500 * time.Millisecond)\n   863→\n   864→\t// Verify log files were indexed in the store\n   865→\tlogFiles, err := store.GetLogFiles(context.Background(), resp.RunId)\n   866→\trequire.NoError(t, err)\n   867→\tassert.GreaterOrEqual(t, len(logFiles), 3, \"should have indexed at least full.log, build.log, llm-build.log\")\n   868→\n   869→\t// Check that we can find by step name\n   870→\tbuildLogs, err := store.GetLogFilesByStep(context.Background(), resp.RunId, \"build\")\n   871→\trequire.NoError(t, err)\n   872→\tassert.GreaterOrEqual(t, len(buildLogs), 2, \"should have script and llm logs for build step\")\n   873→\n   874→\t// Check file types\n   875→\tvar hasScript, hasLLM, hasFull bool\n   876→\tfor _, lf := range logFiles {\n   877→\t\tswitch lf.FileType {\n   878→\t\tcase \"script\":\n   879→\t\t\thasScript = true\n   880→\t\tcase \"llm\":\n   881→\t\t\thasLLM = true\n   882→\t\tcase \"full\":\n   883→\t\t\thasFull = true\n   884→\t\t}\n   885→\t}\n   886→\tassert.True(t, hasScript, \"should have script log\")\n   887→\tassert.True(t, hasLLM, \"should have llm log\")\n   888→\tassert.True(t, hasFull, \"should have full log\")\n   889→}\n   890→\n   891→func TestServer_StreamLogs_StepFilter(t *testing.T) {\n   892→\tstore, err := sqlite.NewStore(\":memory:\")\n   893→\trequire.NoError(t, err)\n   894→\tdefer store.Close()\n   895→\n   896→\tdir := t.TempDir()\n   897→\n   898→\t// Mock agent outputs status messages for two steps\n   899→\tmsgs := []protocol.StatusMessage{\n   900→\t\t{Type: protocol.MsgStepStarted, StepName: \"build\"},\n   901→\t\t{Type: protocol.MsgStepCompleted, StepName: \"build\", Result: \"success\"},\n   902→\t\t{Type: protocol.MsgStepStarted, StepName: \"test\"},\n   903→\t\t{Type: protocol.MsgStepCompleted, StepName: \"test\", Result: \"success\"},\n   904→\t\t{Type: protocol.MsgRunCompleted, Result: \"succeeded\"},\n   905→\t}\n   906→\tscript := \"#!/bin/sh\\n\"\n   907→\tscript += \"mkdir -p .cloche/output\\n\"\n   908→\tscript += \"echo 'build step output' > .cloche/output/build.log\\n\"\n   909→\tscript += \"echo 'test step output' > .cloche/output/test.log\\n\"\n   910→\tscript += \"echo 'build llm conversation' > .cloche/output/llm-build.log\\n\"\n   911→\tfor _, msg := range msgs {\n   912→\t\tdata, _ := json.Marshal(msg)\n   913→\t\tscript += \"echo '\" + string(data) + \"'\\n\"\n   914→\t}\n   915→\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \".cloche\"), 0755))\n   916→\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"test.cloche\"), []byte(script), 0755))\n   917→\n   918→\trt := local.NewRuntime(\"sh\")\n   919→\tsrv := server.NewClocheServerWithCaptures(store, store, rt, \"\")\n   920→\tsrv.SetLogStore(store)\n   921→\n   922→\tresp, err := srv.RunWorkflow(context.Background(), &pb.RunWorkflowRequest{\n   923→\t\tWorkflowName: \"test\",\n   924→\t\tProjectDir:   dir,\n   925→\t})\n   926→\trequire.NoError(t, err)\n   927→\n   928→\t// Poll until complete\n   929→\tdeadline := time.Now().Add(5 * time.Second)\n   930→\tfor time.Now().Before(deadline) {\n   931→\t\tstatus, err := srv.GetStatus(context.Background(), &pb.GetStatusRequest{RunId: resp.RunId})\n   932→\t\trequire.NoError(t, err)\n   933→\t\tif status.State == \"succeeded\" {\n   934→\t\t\tbreak\n   935→\t\t}\n   936→\t\ttime.Sleep(50 * time.Millisecond)\n   937→\t}\n   938→\ttime.Sleep(500 * time.Millisecond)\n   939→\n   940→\t// StreamLogs with step filter should return only that step's logs\n   941→\tmock := &mockLogStream{ctx: context.Background()}\n   942→\terr = srv.StreamLogs(&pb.StreamLogsRequest{\n   943→\t\tRunId:    resp.RunId,\n   944→\t\tStepName: \"build\",\n   945→\t}, mock)\n   946→\trequire.NoError(t, err)\n   947→\tassert.GreaterOrEqual(t, len(mock.entries), 1, \"should have at least one entry for build step\")\n   948→\n   949→\t// All entries should be about the build step\n   950→\tfor _, e := range mock.entries {\n   951→\t\tif e.StepName != \"\" {\n   952→\t\t\tassert.Equal(t, \"build\", e.StepName, \"filtered output should only contain build step\")\n   953→\t\t}\n   954→\t}\n   955→\n   956→\t// StreamLogs with type filter\n   957→\tmock2 := &mockLogStream{ctx: context.Background()}\n   958→\terr = srv.StreamLogs(&pb.StreamLogsRequest{\n   959→\t\tRunId:    resp.RunId,\n   960→\t\tStepName: \"build\",\n   961→\t\tLogType:  \"llm\",\n   962→\t}, mock2)\n   963→\trequire.NoError(t, err)\n   964→\tassert.GreaterOrEqual(t, len(mock2.entries), 1, \"should have at least one LLM log entry\")\n   965→\n   966→\tfor _, e := range mock2.entries {\n   967→\t\tif e.Message != \"\" {\n   968→\t\t\tassert.Contains(t, e.Message, \"llm conversation\", \"should contain LLM output\")\n   969→\t\t}\n   970→\t}\n   971→}\n   972→\n   973→func TestServer_StreamLogs_FullLog(t *testing.T) {\n   974→\tstore, err := sqlite.NewStore(\":memory:\")\n   975→\trequire.NoError(t, err)\n   976→\tdefer store.Close()\n   977→\n   978→\tdir := t.TempDir()\n   979→\n   980→\tmsgs := []protocol.StatusMessage{\n   981→\t\t{Type: protocol.MsgStepStarted, StepName: \"build\"},\n   982→\t\t{Type: protocol.MsgStepCompleted, StepName: \"build\", Result: \"success\"},\n   983→\t\t{Type: protocol.MsgRunCompleted, Result: \"succeeded\"},\n   984→\t}\n   985→\tscript := \"#!/bin/sh\\n\"\n   986→\tscript += \"mkdir -p .cloche/output\\n\"\n   987→\tscript += \"echo 'unified log content here' > .cloche/output/full.log\\n\"\n   988→\tfor _, msg := range msgs {\n   989→\t\tdata, _ := json.Marshal(msg)\n   990→\t\tscript += \"echo '\" + string(data) + \"'\\n\"\n   991→\t}\n   992→\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \".cloche\"), 0755))\n   993→\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"test.cloche\"), []byte(script), 0755))\n   994→\n   995→\trt := local.NewRuntime(\"sh\")\n   996→\tsrv := server.NewClocheServerWithCaptures(store, store, rt, \"\")\n   997→\n   998→\tresp, err := srv.RunWorkflow(context.Background(), &pb.RunWorkflowRequest{\n   999→\t\tWorkflowName: \"test\",\n  1000→\t\tProjectDir:   dir,\n  1001→\t})\n  1002→\trequire.NoError(t, err)\n  1003→\n  1004→\t// Poll until complete\n  1005→\tdeadline := time.Now().Add(5 * time.Second)\n  1006→\tfor time.Now().Before(deadline) {\n  1007→\t\tstatus, err := srv.GetStatus(context.Background(), &pb.GetStatusRequest{RunId: resp.RunId})\n  1008→\t\trequire.NoError(t, err)\n  1009→\t\tif status.State == \"succeeded\" {\n  1010→\t\t\tbreak\n  1011→\t\t}\n  1012→\t\ttime.Sleep(50 * time.Millisecond)\n  1013→\t}\n  1014→\ttime.Sleep(500 * time.Millisecond)\n  1015→\n  1016→\t// StreamLogs with no filters should serve full.log content\n  1017→\tmock := &mockLogStream{ctx: context.Background()}\n  1018→\terr = srv.StreamLogs(&pb.StreamLogsRequest{RunId: resp.RunId}, mock)\n  1019→\trequire.NoError(t, err)\n  1020→\n  1021→\t// Should have a full_log entry\n  1022→\tvar foundFullLog bool\n  1023→\tfor _, e := range mock.entries {\n  1024→\t\tif e.Type == \"full_log\" {\n  1025→\t\t\tfoundFullLog = true\n  1026→\t\t\tassert.Contains(t, e.Message, \"unified log content here\")\n  1027→\t\t}\n  1028→\t}\n  1029→\tassert.True(t, foundFullLog, \"should serve full.log as unified log when available\")\n  1030→}\n  1031→\n  1032→"}]},"parent_tool_use_id":null,"session_id":"e4429857-76e5-431c-977a-09143fc65f99","uuid":"ca43f936-1dd1-4d4e-988a-aab7dc29fb1c","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/grpc/server_test.go","content":"package grpc_test\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"sync/atomic\"\n\t\"testing\"\n\t\"time\"\n\n\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n\tserver \"github.com/cloche-dev/cloche/internal/adapters/grpc\"\n\t\"github.com/cloche-dev/cloche/internal/adapters/local\"\n\t\"github.com/cloche-dev/cloche/internal/adapters/sqlite\"\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/protocol\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n\tgrpclib \"google.golang.org/grpc\"\n)\n\nfunc TestServer_ListRuns_Empty(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tsrv := server.NewClocheServer(store, nil)\n\tresp, err := srv.ListRuns(context.Background(), &pb.ListRunsRequest{All: true})\n\trequire.NoError(t, err)\n\tassert.Empty(t, resp.Runs)\n}\n\nfunc TestServer_GetStatus_NotFound(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tsrv := server.NewClocheServer(store, nil)\n\t_, err = srv.GetStatus(context.Background(), &pb.GetStatusRequest{RunId: \"nonexistent\"})\n\tassert.Error(t, err)\n}\n\nfunc TestServer_RunWorkflow(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tdir := t.TempDir()\n\n\t// Create a mock \"agent\" shell script at test.cloche that outputs JSON status lines.\n\t// The local runtime runs: sh <projectDir>/test.cloche\n\tmsgs := []protocol.StatusMessage{\n\t\t{Type: protocol.MsgStepStarted, StepName: \"build\"},\n\t\t{Type: protocol.MsgStepCompleted, StepName: \"build\", Result: \"success\"},\n\t\t{Type: protocol.MsgRunCompleted, Result: \"succeeded\"},\n\t}\n\tscript := \"#!/bin/sh\\n\"\n\tfor _, msg := range msgs {\n\t\tdata, _ := json.Marshal(msg)\n\t\tscript += \"echo '\" + string(data) + \"'\\n\"\n\t}\n\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \".cloche\"), 0755))\n\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"test.cloche\"), []byte(script), 0755))\n\n\t// Use \"sh\" as the agent binary so it runs: sh test.cloche\n\trt := local.NewRuntime(\"sh\")\n\tsrv := server.NewClocheServerWithCaptures(store, store, rt, \"\")\n\n\tresp, err := srv.RunWorkflow(context.Background(), &pb.RunWorkflowRequest{\n\t\tWorkflowName: \"test\",\n\t\tProjectDir:   dir,\n\t\tPrompt:       \"hello world\",\n\t})\n\trequire.NoError(t, err)\n\tassert.NotEmpty(t, resp.RunId)\n\n\t// Verify prompt was written to run-specific path\n\tpromptData, err := os.ReadFile(filepath.Join(dir, \".cloche\", resp.RunId, \"prompt.txt\"))\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"hello world\", string(promptData))\n\n\t// Poll until the background goroutine finishes processing (up to 5s)\n\tvar status *pb.GetStatusResponse\n\tdeadline := time.Now().Add(5 * time.Second)\n\tfor time.Now().Before(deadline) {\n\t\tstatus, err = srv.GetStatus(context.Background(), &pb.GetStatusRequest{RunId: resp.RunId})\n\t\trequire.NoError(t, err)\n\t\tif status.State == \"succeeded\" && len(status.StepExecutions) >= 1 {\n\t\t\tbreak\n\t\t}\n\t\ttime.Sleep(50 * time.Millisecond)\n\t}\n\n\t// Check that the run was tracked and completed\n\trequire.NotNil(t, status)\n\tassert.Equal(t, resp.RunId, status.RunId)\n\tassert.Equal(t, \"succeeded\", status.State)\n\tassert.GreaterOrEqual(t, len(status.StepExecutions), 1)\n}\n\nfunc TestServer_RunWorkflow_CapturesStepMetadata(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tdir := t.TempDir()\n\n\t// Mock agent outputs status messages\n\tmsgs := []protocol.StatusMessage{\n\t\t{Type: protocol.MsgStepStarted, StepName: \"implement\"},\n\t\t{Type: protocol.MsgStepCompleted, StepName: \"implement\", Result: \"success\"},\n\t\t{Type: protocol.MsgRunCompleted, Result: \"succeeded\"},\n\t}\n\tscript := \"#!/bin/sh\\n\"\n\tfor _, msg := range msgs {\n\t\tdata, _ := json.Marshal(msg)\n\t\tscript += \"echo '\" + string(data) + \"'\\n\"\n\t}\n\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \".cloche\"), 0755))\n\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"capture.cloche\"), []byte(script), 0755))\n\n\trt := local.NewRuntime(\"sh\")\n\tsrv := server.NewClocheServerWithCaptures(store, store, rt, \"\")\n\n\tresp, err := srv.RunWorkflow(context.Background(), &pb.RunWorkflowRequest{\n\t\tWorkflowName: \"capture\",\n\t\tProjectDir:   dir,\n\t})\n\trequire.NoError(t, err)\n\n\t// Poll until complete and captures are stored\n\tvar captures []*domain.StepExecution\n\tdeadline := time.Now().Add(5 * time.Second)\n\tfor time.Now().Before(deadline) {\n\t\tstatus, err := srv.GetStatus(context.Background(), &pb.GetStatusRequest{RunId: resp.RunId})\n\t\trequire.NoError(t, err)\n\t\tif status.State == \"succeeded\" {\n\t\t\tcaptures, err = store.GetCaptures(context.Background(), resp.RunId)\n\t\t\trequire.NoError(t, err)\n\t\t\tif len(captures) >= 2 {\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\t\ttime.Sleep(50 * time.Millisecond)\n\t}\n\n\t// Should have 2 captures: one for step_started, one for step_completed\n\trequire.GreaterOrEqual(t, len(captures), 2)\n\n\t// Check captures directly - one for step_started, one for step_completed\n\tvar foundStarted, foundCompleted bool\n\tfor _, c := range captures {\n\t\tif c.StepName == \"implement\" && c.Result == \"\" {\n\t\t\tfoundStarted = true\n\t\t}\n\t\tif c.StepName == \"implement\" && c.Result == \"success\" {\n\t\t\tfoundCompleted = true\n\t\t}\n\t}\n\tassert.True(t, foundStarted, \"should find capture for step started\")\n\tassert.True(t, foundCompleted, \"should find capture for step completed\")\n}\n\nfunc TestServer_StreamLogs(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tdir := t.TempDir()\n\n\t// Mock agent outputs status messages\n\tmsgs := []protocol.StatusMessage{\n\t\t{Type: protocol.MsgStepStarted, StepName: \"build\"},\n\t\t{Type: protocol.MsgStepCompleted, StepName: \"build\", Result: \"success\"},\n\t\t{Type: protocol.MsgRunCompleted, Result: \"succeeded\"},\n\t}\n\tscript := \"#!/bin/sh\\n\"\n\tfor _, msg := range msgs {\n\t\tdata, _ := json.Marshal(msg)\n\t\tscript += \"echo '\" + string(data) + \"'\\n\"\n\t}\n\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \".cloche\"), 0755))\n\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"test.cloche\"), []byte(script), 0755))\n\n\trt := local.NewRuntime(\"sh\")\n\tsrv := server.NewClocheServerWithCaptures(store, store, rt, \"\")\n\n\tresp, err := srv.RunWorkflow(context.Background(), &pb.RunWorkflowRequest{\n\t\tWorkflowName: \"test\",\n\t\tProjectDir:   dir,\n\t})\n\trequire.NoError(t, err)\n\n\t// Poll until the run completes and captures are stored\n\tdeadline := time.Now().Add(5 * time.Second)\n\tfor time.Now().Before(deadline) {\n\t\tstatus, err := srv.GetStatus(context.Background(), &pb.GetStatusRequest{RunId: resp.RunId})\n\t\trequire.NoError(t, err)\n\t\tif status.State == \"succeeded\" {\n\t\t\tcaptures, _ := store.GetCaptures(context.Background(), resp.RunId)\n\t\t\tif len(captures) >= 2 {\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\t\ttime.Sleep(50 * time.Millisecond)\n\t}\n\n\t// Use a mock stream to collect LogEntry messages\n\tmock := &mockLogStream{ctx: context.Background()}\n\terr = srv.StreamLogs(&pb.StreamLogsRequest{RunId: resp.RunId}, mock)\n\trequire.NoError(t, err)\n\n\t// Should have entries: step_started, step_completed, run_completed\n\trequire.GreaterOrEqual(t, len(mock.entries), 3)\n\n\t// Find step_started and step_completed entries\n\tvar foundStarted, foundCompleted, foundRun bool\n\tfor _, e := range mock.entries {\n\t\tswitch e.Type {\n\t\tcase \"step_started\":\n\t\t\tif e.StepName == \"build\" {\n\t\t\t\tfoundStarted = true\n\t\t\t}\n\t\tcase \"step_completed\":\n\t\t\tif e.StepName == \"build\" {\n\t\t\t\tfoundCompleted = true\n\t\t\t\tassert.Equal(t, \"success\", e.Result)\n\t\t\t}\n\t\tcase \"run_completed\":\n\t\t\tfoundRun = true\n\t\t\tassert.Equal(t, \"succeeded\", e.Result)\n\t\t}\n\t}\n\tassert.True(t, foundStarted, \"should find step_started for build\")\n\tassert.True(t, foundCompleted, \"should find step_completed for build\")\n\tassert.True(t, foundRun, \"should find run_completed\")\n}\n\n// mockLogStream implements grpc.ServerStreamingServer[pb.LogEntry] for testing.\ntype mockLogStream struct {\n\tgrpclib.ServerStream\n\tctx     context.Context\n\tentries []*pb.LogEntry\n}\n\nfunc (m *mockLogStream) Send(entry *pb.LogEntry) error {\n\tm.entries = append(m.entries, entry)\n\treturn nil\n}\n\nfunc (m *mockLogStream) Context() context.Context {\n\treturn m.ctx\n}\n\nfunc TestServer_StreamLogs_FallsBackToContainerLog(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tdir := t.TempDir()\n\n\t// Mock agent outputs a step that fails — no per-step output file will exist\n\tmsgs := []protocol.StatusMessage{\n\t\t{Type: protocol.MsgStepStarted, StepName: \"implement\"},\n\t\t{Type: protocol.MsgStepCompleted, StepName: \"implement\", Result: \"fail\"},\n\t\t{Type: protocol.MsgRunCompleted, Result: \"failed\"},\n\t}\n\tscript := \"#!/bin/sh\\n\"\n\tfor _, msg := range msgs {\n\t\tdata, _ := json.Marshal(msg)\n\t\tscript += \"echo '\" + string(data) + \"'\\n\"\n\t}\n\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \".cloche\"), 0755))\n\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"test.cloche\"), []byte(script), 0755))\n\n\trt := local.NewRuntime(\"sh\")\n\tsrv := server.NewClocheServerWithCaptures(store, store, rt, \"\")\n\n\tresp, err := srv.RunWorkflow(context.Background(), &pb.RunWorkflowRequest{\n\t\tWorkflowName: \"test\",\n\t\tProjectDir:   dir,\n\t})\n\trequire.NoError(t, err)\n\n\t// Poll until run completes\n\tdeadline := time.Now().Add(5 * time.Second)\n\tfor time.Now().Before(deadline) {\n\t\tstatus, err := srv.GetStatus(context.Background(), &pb.GetStatusRequest{RunId: resp.RunId})\n\t\trequire.NoError(t, err)\n\t\tif status.State != \"running\" && status.State != \"pending\" {\n\t\t\tcaptures, _ := store.GetCaptures(context.Background(), resp.RunId)\n\t\t\tif len(captures) >= 2 {\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\t\ttime.Sleep(50 * time.Millisecond)\n\t}\n\n\t// Simulate container.log being written (local runtime Logs() returns empty,\n\t// so write it manually to test the StreamLogs fallback path)\n\toutputDir := filepath.Join(dir, \".cloche\", resp.RunId, \"output\")\n\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n\trequire.NoError(t, os.WriteFile(\n\t\tfilepath.Join(outputDir, \"container.log\"),\n\t\t[]byte(\"error: compilation failed\\ndetailed stack trace here\"),\n\t\t0644,\n\t))\n\n\t// Stream logs and verify the step_completed entry falls back to container.log\n\tmock := &mockLogStream{ctx: context.Background()}\n\terr = srv.StreamLogs(&pb.StreamLogsRequest{RunId: resp.RunId}, mock)\n\trequire.NoError(t, err)\n\n\tvar foundCompleted bool\n\tfor _, e := range mock.entries {\n\t\tif e.Type == \"step_completed\" && e.StepName == \"implement\" {\n\t\t\tfoundCompleted = true\n\t\t\tassert.Equal(t, \"fail\", e.Result)\n\t\t\tassert.Contains(t, e.Message, \"error: compilation failed\")\n\t\t\tassert.Contains(t, e.Message, \"detailed stack trace here\")\n\t\t}\n\t}\n\tassert.True(t, foundCompleted, \"should find step_completed with container.log fallback content\")\n}\n\nfunc TestServer_StreamLogs_PrefersStepOutput(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tdir := t.TempDir()\n\n\tmsgs := []protocol.StatusMessage{\n\t\t{Type: protocol.MsgStepStarted, StepName: \"build\"},\n\t\t{Type: protocol.MsgStepCompleted, StepName: \"build\", Result: \"success\"},\n\t\t{Type: protocol.MsgRunCompleted, Result: \"succeeded\"},\n\t}\n\tscript := \"#!/bin/sh\\n\"\n\tfor _, msg := range msgs {\n\t\tdata, _ := json.Marshal(msg)\n\t\tscript += \"echo '\" + string(data) + \"'\\n\"\n\t}\n\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \".cloche\"), 0755))\n\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"test.cloche\"), []byte(script), 0755))\n\n\trt := local.NewRuntime(\"sh\")\n\tsrv := server.NewClocheServerWithCaptures(store, store, rt, \"\")\n\n\tresp, err := srv.RunWorkflow(context.Background(), &pb.RunWorkflowRequest{\n\t\tWorkflowName: \"test\",\n\t\tProjectDir:   dir,\n\t})\n\trequire.NoError(t, err)\n\n\t// Poll until complete\n\tdeadline := time.Now().Add(5 * time.Second)\n\tfor time.Now().Before(deadline) {\n\t\tstatus, err := srv.GetStatus(context.Background(), &pb.GetStatusRequest{RunId: resp.RunId})\n\t\trequire.NoError(t, err)\n\t\tif status.State == \"succeeded\" {\n\t\t\tcaptures, _ := store.GetCaptures(context.Background(), resp.RunId)\n\t\t\tif len(captures) >= 2 {\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\t\ttime.Sleep(50 * time.Millisecond)\n\t}\n\n\t// Write both per-step output AND container.log — per-step should win\n\toutputDir := filepath.Join(dir, \".cloche\", resp.RunId, \"output\")\n\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n\trequire.NoError(t, os.WriteFile(filepath.Join(outputDir, \"build.log\"), []byte(\"step-specific output\"), 0644))\n\trequire.NoError(t, os.WriteFile(filepath.Join(outputDir, \"container.log\"), []byte(\"full container output\"), 0644))\n\n\tmock := &mockLogStream{ctx: context.Background()}\n\terr = srv.StreamLogs(&pb.StreamLogsRequest{RunId: resp.RunId}, mock)\n\trequire.NoError(t, err)\n\n\tvar foundCompleted bool\n\tfor _, e := range mock.entries {\n\t\tif e.Type == \"step_completed\" && e.StepName == \"build\" {\n\t\t\tfoundCompleted = true\n\t\t\tassert.Equal(t, \"step-specific output\", e.Message, \"should prefer per-step output over container.log\")\n\t\t}\n\t}\n\tassert.True(t, foundCompleted, \"should find step_completed entry\")\n}\n\nfunc TestServer_GetStatus_ContainerID(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\trun := domain.NewRun(\"cid-test\", \"develop\")\n\trun.Start()\n\trun.ContainerID = \"4647e7e70e3fabc123def456\"\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\n\tsrv := server.NewClocheServer(store, nil)\n\tresp, err := srv.GetStatus(ctx, &pb.GetStatusRequest{RunId: \"cid-test\"})\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"4647e7e70e3fabc123def456\", resp.ContainerId)\n}\n\nfunc TestServer_Shutdown(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tsrv := server.NewClocheServer(store, nil)\n\n\tcalled := make(chan struct{}, 1)\n\tsrv.SetShutdownFunc(func() { called <- struct{}{} })\n\n\tresp, err := srv.Shutdown(context.Background(), &pb.ShutdownRequest{})\n\trequire.NoError(t, err)\n\tassert.NotNil(t, resp)\n\n\tselect {\n\tcase <-called:\n\tcase <-time.After(time.Second):\n\t\tt.Fatal(\"shutdown callback was not called\")\n\t}\n}\n\nfunc TestServer_Shutdown_NotConfigured(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tsrv := server.NewClocheServer(store, nil)\n\n\t_, err = srv.Shutdown(context.Background(), &pb.ShutdownRequest{})\n\tassert.Error(t, err)\n\tassert.Contains(t, err.Error(), \"shutdown not configured\")\n}\n\nfunc TestServer_RunWorkflow_NoRuntime(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tsrv := server.NewClocheServer(store, nil)\n\t_, err = srv.RunWorkflow(context.Background(), &pb.RunWorkflowRequest{\n\t\tWorkflowName: \"test\",\n\t\tProjectDir:   t.TempDir(),\n\t})\n\tassert.Error(t, err)\n\tassert.Contains(t, err.Error(), \"no container runtime configured\")\n}\n\n// trackingRuntime wraps a local.Runtime and tracks Remove calls.\ntype trackingRuntime struct {\n\t*local.Runtime\n\tremoveCalled atomic.Int32\n}\n\nfunc (tr *trackingRuntime) Remove(ctx context.Context, containerID string) error {\n\ttr.removeCalled.Add(1)\n\treturn tr.Runtime.Remove(ctx, containerID)\n}\n\n// ensuringRuntime wraps a local.Runtime and implements ImageEnsurer to track calls.\ntype ensuringRuntime struct {\n\t*local.Runtime\n\tensureCalled atomic.Int32\n\tensureErr    error\n}\n\nfunc (e *ensuringRuntime) EnsureImage(ctx context.Context, projectDir, image string) error {\n\te.ensureCalled.Add(1)\n\treturn e.ensureErr\n}\n\nfunc TestServer_RunWorkflow_CallsEnsureImage(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tdir := t.TempDir()\n\n\tmsgs := []protocol.StatusMessage{\n\t\t{Type: protocol.MsgStepStarted, StepName: \"build\"},\n\t\t{Type: protocol.MsgStepCompleted, StepName: \"build\", Result: \"success\"},\n\t\t{Type: protocol.MsgRunCompleted, Result: \"succeeded\"},\n\t}\n\tscript := \"#!/bin/sh\\n\"\n\tfor _, msg := range msgs {\n\t\tdata, _ := json.Marshal(msg)\n\t\tscript += \"echo '\" + string(data) + \"'\\n\"\n\t}\n\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \".cloche\"), 0755))\n\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"test.cloche\"), []byte(script), 0755))\n\n\trt := &ensuringRuntime{Runtime: local.NewRuntime(\"sh\")}\n\tsrv := server.NewClocheServerWithCaptures(store, store, rt, \"test-image:latest\")\n\n\tresp, err := srv.RunWorkflow(context.Background(), &pb.RunWorkflowRequest{\n\t\tWorkflowName: \"test\",\n\t\tProjectDir:   dir,\n\t})\n\trequire.NoError(t, err)\n\n\t// Wait for run to complete\n\tdeadline := time.Now().Add(5 * time.Second)\n\tfor time.Now().Before(deadline) {\n\t\tstatus, err := srv.GetStatus(context.Background(), &pb.GetStatusRequest{RunId: resp.RunId})\n\t\trequire.NoError(t, err)\n\t\tif status.State == \"succeeded\" {\n\t\t\tbreak\n\t\t}\n\t\ttime.Sleep(50 * time.Millisecond)\n\t}\n\n\tassert.Equal(t, int32(1), rt.ensureCalled.Load(), \"EnsureImage should be called once\")\n}\n\nfunc TestServer_RunWorkflow_FailedRunKeepsContainer(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tdir := t.TempDir()\n\n\t// Mock agent outputs a failed run and exits with non-zero code\n\tmsgs := []protocol.StatusMessage{\n\t\t{Type: protocol.MsgStepStarted, StepName: \"build\"},\n\t\t{Type: protocol.MsgStepCompleted, StepName: \"build\", Result: \"fail\"},\n\t\t{Type: protocol.MsgRunCompleted, Result: \"failed\"},\n\t}\n\tscript := \"#!/bin/sh\\n\"\n\tfor _, msg := range msgs {\n\t\tdata, _ := json.Marshal(msg)\n\t\tscript += \"echo '\" + string(data) + \"'\\n\"\n\t}\n\tscript += \"exit 1\\n\"\n\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \".cloche\"), 0755))\n\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"test.cloche\"), []byte(script), 0755))\n\n\trt := &trackingRuntime{Runtime: local.NewRuntime(\"sh\")}\n\tsrv := server.NewClocheServerWithCaptures(store, store, rt, \"\")\n\n\tresp, err := srv.RunWorkflow(context.Background(), &pb.RunWorkflowRequest{\n\t\tWorkflowName:  \"test\",\n\t\tProjectDir:    dir,\n\t\tKeepContainer: false, // NOT requesting keep, but should still keep on failure\n\t})\n\trequire.NoError(t, err)\n\n\t// Poll until the run completes (failed state)\n\tdeadline := time.Now().Add(5 * time.Second)\n\tfor time.Now().Before(deadline) {\n\t\tstatus, err := srv.GetStatus(context.Background(), &pb.GetStatusRequest{RunId: resp.RunId})\n\t\trequire.NoError(t, err)\n\t\tif status.State == \"failed\" {\n\t\t\tbreak\n\t\t}\n\t\ttime.Sleep(50 * time.Millisecond)\n\t}\n\n\t// Wait for post-completion cleanup (container retention logic) to finish\n\ttime.Sleep(500 * time.Millisecond)\n\n\t// Container should NOT have been removed\n\tassert.Equal(t, int32(0), rt.removeCalled.Load(), \"Remove should not be called for failed runs\")\n\n\t// ContainerKept should be true in the store\n\trun, err := store.GetRun(context.Background(), resp.RunId)\n\trequire.NoError(t, err)\n\tassert.Equal(t, domain.RunStateFailed, run.State)\n\tassert.True(t, run.ContainerKept, \"ContainerKept should be true for failed runs\")\n}\n\nfunc TestServer_RunWorkflow_SucceededRunRemovesContainer(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tdir := t.TempDir()\n\n\t// Mock agent outputs a successful run\n\tmsgs := []protocol.StatusMessage{\n\t\t{Type: protocol.MsgStepStarted, StepName: \"build\"},\n\t\t{Type: protocol.MsgStepCompleted, StepName: \"build\", Result: \"success\"},\n\t\t{Type: protocol.MsgRunCompleted, Result: \"succeeded\"},\n\t}\n\tscript := \"#!/bin/sh\\n\"\n\tfor _, msg := range msgs {\n\t\tdata, _ := json.Marshal(msg)\n\t\tscript += \"echo '\" + string(data) + \"'\\n\"\n\t}\n\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \".cloche\"), 0755))\n\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"test.cloche\"), []byte(script), 0755))\n\n\trt := &trackingRuntime{Runtime: local.NewRuntime(\"sh\")}\n\tsrv := server.NewClocheServerWithCaptures(store, store, rt, \"\")\n\n\tresp, err := srv.RunWorkflow(context.Background(), &pb.RunWorkflowRequest{\n\t\tWorkflowName:  \"test\",\n\t\tProjectDir:    dir,\n\t\tKeepContainer: false,\n\t})\n\trequire.NoError(t, err)\n\n\t// Poll until the run completes\n\tdeadline := time.Now().Add(5 * time.Second)\n\tfor time.Now().Before(deadline) {\n\t\tstatus, err := srv.GetStatus(context.Background(), &pb.GetStatusRequest{RunId: resp.RunId})\n\t\trequire.NoError(t, err)\n\t\tif status.State == \"succeeded\" {\n\t\t\tbreak\n\t\t}\n\t\ttime.Sleep(50 * time.Millisecond)\n\t}\n\n\t// Wait a bit more for the post-completion cleanup to run\n\ttime.Sleep(200 * time.Millisecond)\n\n\t// Container should have been removed\n\tassert.Equal(t, int32(1), rt.removeCalled.Load(), \"Remove should be called for succeeded runs without --keep-container\")\n\n\t// ContainerKept should be false\n\trun, err := store.GetRun(context.Background(), resp.RunId)\n\trequire.NoError(t, err)\n\tassert.False(t, run.ContainerKept, \"ContainerKept should be false for succeeded runs\")\n}\n\nfunc TestServer_RunWorkflow_KeepContainerOnSuccess(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tdir := t.TempDir()\n\n\t// Mock agent outputs a successful run\n\tmsgs := []protocol.StatusMessage{\n\t\t{Type: protocol.MsgStepStarted, StepName: \"build\"},\n\t\t{Type: protocol.MsgStepCompleted, StepName: \"build\", Result: \"success\"},\n\t\t{Type: protocol.MsgRunCompleted, Result: \"succeeded\"},\n\t}\n\tscript := \"#!/bin/sh\\n\"\n\tfor _, msg := range msgs {\n\t\tdata, _ := json.Marshal(msg)\n\t\tscript += \"echo '\" + string(data) + \"'\\n\"\n\t}\n\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \".cloche\"), 0755))\n\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"test.cloche\"), []byte(script), 0755))\n\n\trt := &trackingRuntime{Runtime: local.NewRuntime(\"sh\")}\n\tsrv := server.NewClocheServerWithCaptures(store, store, rt, \"\")\n\n\tresp, err := srv.RunWorkflow(context.Background(), &pb.RunWorkflowRequest{\n\t\tWorkflowName:  \"test\",\n\t\tProjectDir:    dir,\n\t\tKeepContainer: true, // --keep-container flag set\n\t})\n\trequire.NoError(t, err)\n\n\t// Poll until the run completes\n\tdeadline := time.Now().Add(5 * time.Second)\n\tfor time.Now().Before(deadline) {\n\t\tstatus, err := srv.GetStatus(context.Background(), &pb.GetStatusRequest{RunId: resp.RunId})\n\t\trequire.NoError(t, err)\n\t\tif status.State == \"succeeded\" {\n\t\t\tbreak\n\t\t}\n\t\ttime.Sleep(50 * time.Millisecond)\n\t}\n\n\t// Wait a bit more for the post-completion cleanup to run\n\ttime.Sleep(200 * time.Millisecond)\n\n\t// Container should NOT have been removed (--keep-container)\n\tassert.Equal(t, int32(0), rt.removeCalled.Load(), \"Remove should not be called when --keep-container is set\")\n\n\t// ContainerKept should be true\n\trun, err := store.GetRun(context.Background(), resp.RunId)\n\trequire.NoError(t, err)\n\tassert.True(t, run.ContainerKept, \"ContainerKept should be true with --keep-container\")\n}\n\nfunc TestServer_DeleteContainer_ByRunID(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\n\t// Create a run with a container ID and container_kept=true\n\trun := domain.NewRun(\"delete-test-run\", \"develop\")\n\trun.Start()\n\trun.ContainerID = \"abc123def456\"\n\trun.ContainerKept = true\n\trun.Complete(domain.RunStateFailed)\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\n\trt := &trackingRuntime{Runtime: local.NewRuntime(\"sh\")}\n\tsrv := server.NewClocheServer(store, rt)\n\n\tresp, err := srv.DeleteContainer(ctx, &pb.DeleteContainerRequest{Id: \"delete-test-run\"})\n\trequire.NoError(t, err)\n\tassert.NotNil(t, resp)\n\n\t// Verify Remove was called\n\tassert.Equal(t, int32(1), rt.removeCalled.Load())\n\n\t// Verify container_kept was cleared\n\tupdated, err := store.GetRun(ctx, \"delete-test-run\")\n\trequire.NoError(t, err)\n\tassert.False(t, updated.ContainerKept)\n}\n\nfunc TestServer_DeleteContainer_ByContainerID(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\trt := &trackingRuntime{Runtime: local.NewRuntime(\"sh\")}\n\tsrv := server.NewClocheServer(store, rt)\n\n\t// Pass a raw container ID (not a run ID)\n\tresp, err := srv.DeleteContainer(ctx, &pb.DeleteContainerRequest{Id: \"some-docker-container-id\"})\n\trequire.NoError(t, err)\n\tassert.NotNil(t, resp)\n\n\t// Remove should still be called with the container ID\n\tassert.Equal(t, int32(1), rt.removeCalled.Load())\n}\n\nfunc TestServer_DeleteContainer_EmptyID(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tsrv := server.NewClocheServer(store, &trackingRuntime{Runtime: local.NewRuntime(\"sh\")})\n\t_, err = srv.DeleteContainer(context.Background(), &pb.DeleteContainerRequest{Id: \"\"})\n\tassert.Error(t, err)\n\tassert.Contains(t, err.Error(), \"id is required\")\n}\n\nfunc TestServer_DeleteContainer_NoRuntime(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tsrv := server.NewClocheServer(store, nil)\n\t_, err = srv.DeleteContainer(context.Background(), &pb.DeleteContainerRequest{Id: \"some-id\"})\n\tassert.Error(t, err)\n\tassert.Contains(t, err.Error(), \"no container runtime configured\")\n}\n\nfunc TestServer_DeleteContainer_RunWithNoContainer(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\n\t// Create a run without a container ID\n\trun := domain.NewRun(\"no-container-run\", \"develop\")\n\trun.Start()\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\n\trt := &trackingRuntime{Runtime: local.NewRuntime(\"sh\")}\n\tsrv := server.NewClocheServer(store, rt)\n\n\t_, err = srv.DeleteContainer(ctx, &pb.DeleteContainerRequest{Id: \"no-container-run\"})\n\tassert.Error(t, err)\n\tassert.Contains(t, err.Error(), \"no associated container\")\n}\n\nfunc TestServer_RunWorkflow_EnsureImageFailure(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tdir := t.TempDir()\n\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \".cloche\"), 0755))\n\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"test.cloche\"), []byte(\"#!/bin/sh\\necho ok\\n\"), 0755))\n\n\trt := &ensuringRuntime{\n\t\tRuntime:   local.NewRuntime(\"sh\"),\n\t\tensureErr: fmt.Errorf(\"build failed: Dockerfile syntax error\"),\n\t}\n\tsrv := server.NewClocheServerWithCaptures(store, store, rt, \"test-image:latest\")\n\n\tresp, err := srv.RunWorkflow(context.Background(), &pb.RunWorkflowRequest{\n\t\tWorkflowName: \"test\",\n\t\tProjectDir:   dir,\n\t})\n\trequire.NoError(t, err) // RPC returns immediately\n\n\t// Wait for the background goroutine to mark the run as failed\n\tdeadline := time.Now().Add(5 * time.Second)\n\tvar status *pb.GetStatusResponse\n\tfor time.Now().Before(deadline) {\n\t\tstatus, err = srv.GetStatus(context.Background(), &pb.GetStatusRequest{RunId: resp.RunId})\n\t\trequire.NoError(t, err)\n\t\tif status.State == \"failed\" {\n\t\t\tbreak\n\t\t}\n\t\ttime.Sleep(50 * time.Millisecond)\n\t}\n\n\tassert.Equal(t, \"failed\", status.State)\n\tassert.Contains(t, status.ErrorMessage, \"failed to ensure image\")\n}\n\nfunc TestServer_LogIndexing(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tdir := t.TempDir()\n\n\t// Mock agent that outputs status messages and creates output files\n\tmsgs := []protocol.StatusMessage{\n\t\t{Type: protocol.MsgStepStarted, StepName: \"build\"},\n\t\t{Type: protocol.MsgStepCompleted, StepName: \"build\", Result: \"success\"},\n\t\t{Type: protocol.MsgRunCompleted, Result: \"succeeded\"},\n\t}\n\tscript := \"#!/bin/sh\\n\"\n\t// Create output directory and files from within the script\n\t// Local runtime sets working dir to projectDir, so use relative paths\n\tscript += \"mkdir -p .cloche/output\\n\"\n\tscript += \"echo 'build script output' > .cloche/output/build.log\\n\"\n\tscript += \"echo 'build llm output' > .cloche/output/llm-build.log\\n\"\n\tscript += \"echo 'full unified log' > .cloche/output/full.log\\n\"\n\tfor _, msg := range msgs {\n\t\tdata, _ := json.Marshal(msg)\n\t\tscript += \"echo '\" + string(data) + \"'\\n\"\n\t}\n\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \".cloche\"), 0755))\n\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"test.cloche\"), []byte(script), 0755))\n\n\trt := local.NewRuntime(\"sh\")\n\tsrv := server.NewClocheServerWithCaptures(store, store, rt, \"\")\n\tsrv.SetLogStore(store)\n\n\tresp, err := srv.RunWorkflow(context.Background(), &pb.RunWorkflowRequest{\n\t\tWorkflowName: \"test\",\n\t\tProjectDir:   dir,\n\t})\n\trequire.NoError(t, err)\n\n\t// Poll until complete\n\tdeadline := time.Now().Add(5 * time.Second)\n\tfor time.Now().Before(deadline) {\n\t\tstatus, err := srv.GetStatus(context.Background(), &pb.GetStatusRequest{RunId: resp.RunId})\n\t\trequire.NoError(t, err)\n\t\tif status.State == \"succeeded\" {\n\t\t\tbreak\n\t\t}\n\t\ttime.Sleep(50 * time.Millisecond)\n\t}\n\n\t// Wait for post-completion processing (log indexing happens after run completes)\n\ttime.Sleep(500 * time.Millisecond)\n\n\t// Verify log files were indexed in the store\n\tlogFiles, err := store.GetLogFiles(context.Background(), resp.RunId)\n\trequire.NoError(t, err)\n\tassert.GreaterOrEqual(t, len(logFiles), 3, \"should have indexed at least full.log, build.log, llm-build.log\")\n\n\t// Check that we can find by step name\n\tbuildLogs, err := store.GetLogFilesByStep(context.Background(), resp.RunId, \"build\")\n\trequire.NoError(t, err)\n\tassert.GreaterOrEqual(t, len(buildLogs), 2, \"should have script and llm logs for build step\")\n\n\t// Check file types\n\tvar hasScript, hasLLM, hasFull bool\n\tfor _, lf := range logFiles {\n\t\tswitch lf.FileType {\n\t\tcase \"script\":\n\t\t\thasScript = true\n\t\tcase \"llm\":\n\t\t\thasLLM = true\n\t\tcase \"full\":\n\t\t\thasFull = true\n\t\t}\n\t}\n\tassert.True(t, hasScript, \"should have script log\")\n\tassert.True(t, hasLLM, \"should have llm log\")\n\tassert.True(t, hasFull, \"should have full log\")\n}\n\nfunc TestServer_StreamLogs_StepFilter(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tdir := t.TempDir()\n\n\t// Mock agent outputs status messages for two steps\n\tmsgs := []protocol.StatusMessage{\n\t\t{Type: protocol.MsgStepStarted, StepName: \"build\"},\n\t\t{Type: protocol.MsgStepCompleted, StepName: \"build\", Result: \"success\"},\n\t\t{Type: protocol.MsgStepStarted, StepName: \"test\"},\n\t\t{Type: protocol.MsgStepCompleted, StepName: \"test\", Result: \"success\"},\n\t\t{Type: protocol.MsgRunCompleted, Result: \"succeeded\"},\n\t}\n\tscript := \"#!/bin/sh\\n\"\n\tscript += \"mkdir -p .cloche/output\\n\"\n\tscript += \"echo 'build step output' > .cloche/output/build.log\\n\"\n\tscript += \"echo 'test step output' > .cloche/output/test.log\\n\"\n\tscript += \"echo 'build llm conversation' > .cloche/output/llm-build.log\\n\"\n\tfor _, msg := range msgs {\n\t\tdata, _ := json.Marshal(msg)\n\t\tscript += \"echo '\" + string(data) + \"'\\n\"\n\t}\n\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \".cloche\"), 0755))\n\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"test.cloche\"), []byte(script), 0755))\n\n\trt := local.NewRuntime(\"sh\")\n\tsrv := server.NewClocheServerWithCaptures(store, store, rt, \"\")\n\tsrv.SetLogStore(store)\n\n\tresp, err := srv.RunWorkflow(context.Background(), &pb.RunWorkflowRequest{\n\t\tWorkflowName: \"test\",\n\t\tProjectDir:   dir,\n\t})\n\trequire.NoError(t, err)\n\n\t// Poll until complete\n\tdeadline := time.Now().Add(5 * time.Second)\n\tfor time.Now().Before(deadline) {\n\t\tstatus, err := srv.GetStatus(context.Background(), &pb.GetStatusRequest{RunId: resp.RunId})\n\t\trequire.NoError(t, err)\n\t\tif status.State == \"succeeded\" {\n\t\t\tbreak\n\t\t}\n\t\ttime.Sleep(50 * time.Millisecond)\n\t}\n\ttime.Sleep(500 * time.Millisecond)\n\n\t// StreamLogs with step filter should return only that step's logs\n\tmock := &mockLogStream{ctx: context.Background()}\n\terr = srv.StreamLogs(&pb.StreamLogsRequest{\n\t\tRunId:    resp.RunId,\n\t\tStepName: \"build\",\n\t}, mock)\n\trequire.NoError(t, err)\n\tassert.GreaterOrEqual(t, len(mock.entries), 1, \"should have at least one entry for build step\")\n\n\t// All entries should be about the build step\n\tfor _, e := range mock.entries {\n\t\tif e.StepName != \"\" {\n\t\t\tassert.Equal(t, \"build\", e.StepName, \"filtered output should only contain build step\")\n\t\t}\n\t}\n\n\t// StreamLogs with type filter\n\tmock2 := &mockLogStream{ctx: context.Background()}\n\terr = srv.StreamLogs(&pb.StreamLogsRequest{\n\t\tRunId:    resp.RunId,\n\t\tStepName: \"build\",\n\t\tLogType:  \"llm\",\n\t}, mock2)\n\trequire.NoError(t, err)\n\tassert.GreaterOrEqual(t, len(mock2.entries), 1, \"should have at least one LLM log entry\")\n\n\tfor _, e := range mock2.entries {\n\t\tif e.Message != \"\" {\n\t\t\tassert.Contains(t, e.Message, \"llm conversation\", \"should contain LLM output\")\n\t\t}\n\t}\n}\n\nfunc TestServer_StreamLogs_FullLog(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tdir := t.TempDir()\n\n\tmsgs := []protocol.StatusMessage{\n\t\t{Type: protocol.MsgStepStarted, StepName: \"build\"},\n\t\t{Type: protocol.MsgStepCompleted, StepName: \"build\", Result: \"success\"},\n\t\t{Type: protocol.MsgRunCompleted, Result: \"succeeded\"},\n\t}\n\tscript := \"#!/bin/sh\\n\"\n\tscript += \"mkdir -p .cloche/output\\n\"\n\tscript += \"echo 'unified log content here' > .cloche/output/full.log\\n\"\n\tfor _, msg := range msgs {\n\t\tdata, _ := json.Marshal(msg)\n\t\tscript += \"echo '\" + string(data) + \"'\\n\"\n\t}\n\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \".cloche\"), 0755))\n\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"test.cloche\"), []byte(script), 0755))\n\n\trt := local.NewRuntime(\"sh\")\n\tsrv := server.NewClocheServerWithCaptures(store, store, rt, \"\")\n\n\tresp, err := srv.RunWorkflow(context.Background(), &pb.RunWorkflowRequest{\n\t\tWorkflowName: \"test\",\n\t\tProjectDir:   dir,\n\t})\n\trequire.NoError(t, err)\n\n\t// Poll until complete\n\tdeadline := time.Now().Add(5 * time.Second)\n\tfor time.Now().Before(deadline) {\n\t\tstatus, err := srv.GetStatus(context.Background(), &pb.GetStatusRequest{RunId: resp.RunId})\n\t\trequire.NoError(t, err)\n\t\tif status.State == \"succeeded\" {\n\t\t\tbreak\n\t\t}\n\t\ttime.Sleep(50 * time.Millisecond)\n\t}\n\ttime.Sleep(500 * time.Millisecond)\n\n\t// StreamLogs with no filters should serve full.log content\n\tmock := &mockLogStream{ctx: context.Background()}\n\terr = srv.StreamLogs(&pb.StreamLogsRequest{RunId: resp.RunId}, mock)\n\trequire.NoError(t, err)\n\n\t// Should have a full_log entry\n\tvar foundFullLog bool\n\tfor _, e := range mock.entries {\n\t\tif e.Type == \"full_log\" {\n\t\t\tfoundFullLog = true\n\t\t\tassert.Contains(t, e.Message, \"unified log content here\")\n\t\t}\n\t}\n\tassert.True(t, foundFullLog, \"should serve full.log as unified log when available\")\n}\n\n","numLines":1032,"startLine":1,"totalLines":1032}}}
