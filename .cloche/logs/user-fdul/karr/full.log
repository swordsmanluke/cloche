\tdefer tx.Rollback()\n   442→\n   443→\t// Check if there is already an in_progress merge for this project\n   444→\tvar count int\n   445→\terr = tx.QueryRowContext(ctx,\n   446→\t\t`SELECT COUNT(*) FROM merge_queue WHERE project = ? AND status = 'in_progress'`,\n   447→\t\tproject).Scan(&count)\n   448→\tif err != nil {\n   449→\t\treturn nil, err\n   450→\t}\n   451→\tif count > 0 {\n   452→\t\treturn nil, nil // another merge is already in progress\n   453→\t}\n   454→\n   455→\t// Get the oldest pending merge for this project\n   456→\trow := tx.QueryRowContext(ctx,\n   457→\t\t`SELECT run_id, branch, project, enqueued_at FROM merge_queue\n   458→\t\t WHERE project = ? AND status = 'pending'\n   459→\t\t ORDER BY enqueued_at ASC LIMIT 1`, project)\n   460→\n   461→\tentry := &ports.MergeQueueEntry{}\n   462→\tvar enqueuedAt string\n   463→\terr = row.Scan(&entry.RunID, &entry.Branch, &entry.Project, &enqueuedAt)\n   464→\tif err == sql.ErrNoRows {\n   465→\t\treturn nil, nil\n   466→\t}\n   467→\tif err != nil {\n   468→\t\treturn nil, err\n   469→\t}\n   470→\tentry.EnqueuedAt = parseTime(enqueuedAt)\n   471→\tentry.Status = \"in_progress\"\n   472→\n   473→\t// Mark it as in_progress\n   474→\t_, err = tx.ExecContext(ctx,\n   475→\t\t`UPDATE merge_queue SET status = 'in_progress' WHERE run_id = ?`,\n   476→\t\tentry.RunID)\n   477→\tif err != nil {\n   478→\t\treturn nil, err\n   479→\t}\n   480→\n   481→\tif err := tx.Commit(); err != nil {\n   482→\t\treturn nil, err\n   483→\t}\n   484→\treturn entry, nil\n   485→}\n   486→\n   487→func (s *Store) CompleteMerge(ctx context.Context, runID string) error {\n   488→\t_, err := s.db.ExecContext(ctx,\n   489→\t\t`UPDATE merge_queue SET status = 'completed', completed_at = ? WHERE run_id = ?`,\n   490→\t\tformatTime(time.Now()), runID,\n   491→\t)\n   492→\treturn err\n   493→}\n   494→\n   495→func (s *Store) FailMerge(ctx context.Context, runID string) error {\n   496→\t_, err := s.db.ExecContext(ctx,\n   497→\t\t`UPDATE merge_queue SET status = 'failed', completed_at = ? WHERE run_id = ?`,\n   498→\t\tformatTime(time.Now()), runID,\n   499→\t)\n   500→\treturn err\n   501→}\n   502→\n   503→func (s *Store) FailStaleRuns(ctx context.Context) (int64, error) {\n   504→\tnow := formatTime(time.Now())\n   505→\tres, err := s.db.ExecContext(ctx,\n   506→\t\t`UPDATE runs SET state = 'failed', completed_at = ?, error_message = 'daemon restarted while run was active'\n   507→\t\t WHERE state IN ('pending', 'running')`,\n   508→\t\tnow,\n   509→\t)\n   510→\tif err != nil {\n   511→\t\treturn 0, err\n   512→\t}\n   513→\treturn res.RowsAffected()\n   514→}\n   515→\n   516→func formatTime(t time.Time) string {\n   517→\tif t.IsZero() {\n   518→\t\treturn \"\"\n   519→\t}\n   520→\treturn t.Format(time.RFC3339Nano)\n   521→}\n   522→\n   523→func parseTime(s string) time.Time {\n   524→\tif s == \"\" {\n   525→\t\treturn time.Time{}\n   526→\t}\n   527→\tt, _ := time.Parse(time.RFC3339Nano, s)\n   528→\treturn t\n   529→}\n   530→\n   531→func boolToInt(b bool) int {\n   532→\tif b {\n   533→\t\treturn 1\n   534→\t}\n   535→\treturn 0\n   536→}\n   537→"}]},"parent_tool_use_id":"toolu_01FW1vt11VhSB8mpYAgAHsRr","session_id":"e4429857-76e5-431c-977a-09143fc65f99","uuid":"8638423a-a4ad-4142-841f-06bcd419d1ed"}
