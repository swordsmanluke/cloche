[2026-03-08T01:38:25Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BYjSkQeJJk18K6jXoFQUmx","type":"tool_result","content":"     1→package main\n     2→\n     3→import (\n     4→\t\"bufio\"\n     5→\t\"context\"\n     6→\t\"encoding/json\"\n     7→\t\"errors\"\n     8→\t\"fmt\"\n     9→\t\"io\"\n    10→\t\"net/http\"\n    11→\t\"os\"\n    12→\t\"path/filepath\"\n    13→\t\"strings\"\n    14→\t\"time\"\n    15→\n    16→\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    17→\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    18→\t\"google.golang.org/grpc\"\n    19→\t\"google.golang.org/grpc/credentials/insecure\"\n    20→)\n    21→\n    22→func main() {\n    23→\tif len(os.Args) < 2 {\n    24→\t\tusage()\n    25→\t\tos.Exit(1)\n    26→\t}\n    27→\n    28→\t// Commands that don't need a daemon connection\n    29→\tswitch os.Args[1] {\n    30→\tcase \"init\":\n    31→\t\tcmdInit(os.Args[2:])\n    32→\t\treturn\n    33→\tcase \"health\":\n    34→\t\tcmdHealth(os.Args[2:])\n    35→\t\treturn\n    36→\t}\n    37→\n    38→\t// Commands that need a daemon connection\n    39→\taddr := os.Getenv(\"CLOCHE_ADDR\")\n    40→\tif addr == \"\" {\n    41→\t\taddr = \"unix:///tmp/cloche.sock\"\n    42→\t}\n    43→\n    44→\tconn, err := grpc.NewClient(addr, grpc.WithTransportCredentials(insecure.NewCredentials()))\n    45→\tif err != nil {\n    46→\t\tfmt.Fprintf(os.Stderr, \"failed to connect: %v\\n\", err)\n    47→\t\tos.Exit(1)\n    48→\t}\n    49→\tdefer conn.Close()\n    50→\n    51→\tclient := pb.NewClocheServiceClient(conn)\n    52→\tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n    53→\tdefer cancel()\n    54→\n    55→\tswitch os.Args[1] {\n    56→\tcase \"run\":\n    57→\t\tcmdRun(ctx, client, os.Args[2:])\n    58→\tcase \"status\":\n    59→\t\tcmdStatus(ctx, client, os.Args[2:])\n    60→\tcase \"logs\":\n    61→\t\tcmdLogs(client, os.Args[2:])\n    62→\tcase \"poll\":\n    63→\t\tcmdPoll(client, os.Args[2:])\n    64→\tcase \"list\":\n    65→\t\tcmdList(ctx, client, os.Args[2:])\n    66→\tcase \"stop\":\n    67→\t\tcmdStop(ctx, client, os.Args[2:])\n    68→\tcase \"delete\":\n    69→\t\tcmdDelete(ctx, client, os.Args[2:])\n    70→\tcase \"orchestrate\":\n    71→\t\tcmdOrchestrate(ctx, client)\n    72→\tcase \"shutdown\":\n    73→\t\tcmdShutdown(ctx, client)\n    74→\tdefault:\n    75→\t\tusage()\n    76→\t\tos.Exit(1)\n    77→\t}\n    78→}\n    79→\n    80→func usage() {\n    81→\tfmt.Fprintf(os.Stderr, `usage: cloche <command> [args]\n    82→\n    83→Commands:\n    84→  init [--workflow <name>] [--base-image <image>]\n    85→                                             Initialize a Cloche project\n    86→  health                                   Show project health summary\n    87→  run --workflow <name> [--prompt \"...\"] [--keep-container]\n    88→                                             Launch a workflow run\n    89→  status <run-id>                            Check run status\n    90→  logs <run-id> [--step <name>] [--type <full|script|llm>] [--follow]\n    91→                                             Show logs for a run\n    92→  poll <run-id>                              Wait for a run to finish\n    93→  list [--all]                                List runs (last hour by default)\n    94→  stop <run-id>                              Stop a running workflow\n    95→  delete <container-or-run-id>               Delete a retained container\n    96→  orchestrate                                Dispatch ready workflow runs\n    97→  shutdown                                   Shut down the daemon\n    98→`)\n    99→}\n   100→\n   101→func cmdRun(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   102→\tvar workflow, prompt string\n   103→\tvar keepContainer bool\n   104→\n   105→\tfor i := 0; i < len(args); i++ {\n   106→\t\tswitch args[i] {\n   107→\t\tcase \"--workflow\":\n   108→\t\t\tif i+1 < len(args) {\n   109→\t\t\t\ti++\n   110→\t\t\t\tworkflow = args[i]\n   111→\t\t\t}\n   112→\t\tcase \"--prompt\", \"-p\":\n   113→\t\t\tif i+1 < len(args) {\n   114→\t\t\t\ti++\n   115→\t\t\t\tprompt = args[i]\n   116→\t\t\t}\n   117→\t\tcase \"--keep-container\":\n   118→\t\t\tkeepContainer = true\n   119→\t\tdefault:\n   120→\t\t\t// Support bare positional arg as workflow name for backwards compat\n   121→\t\t\tif workflow == \"\" && !strings.HasPrefix(args[i], \"-\") {\n   122→\t\t\t\tworkflow = args[i]\n   123→\t\t\t}\n   124→\t\t}\n   125→\t}\n   126→\n   127→\tif workflow == \"\" {\n   128→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche run --workflow <name> [--prompt \\\"...\\\"]\\n\")\n   129→\t\tos.Exit(1)\n   130→\t}\n   131→\n   132→\tcwd, _ := os.Getwd()\n   133→\n   134→\t// Resolve image from workflow file (soft failure — fall back to daemon default)\n   135→\tvar image string\n   136→\twfPath := filepath.Join(cwd, \".cloche\", workflow+\".cloche\")\n   137→\tif data, err := os.ReadFile(wfPath); err == nil {\n   138→\t\tif wf, err := dsl.Parse(string(data)); err == nil {\n   139→\t\t\timage = wf.Config[\"container.image\"]\n   140→\t\t}\n   141→\t}\n   142→\n   143→\tresp, err := client.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n   144→\t\tWorkflowName:  workflow,\n   145→\t\tProjectDir:    cwd,\n   146→\t\tImage:         image,\n   147→\t\tPrompt:        prompt,\n   148→\t\tKeepContainer: keepContainer,\n   149→\t})\n   150→\tif err != nil {\n   151→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   152→\t\tos.Exit(1)\n   153→\t}\n   154→\tfmt.Printf(\"Started run: %s\\n\", resp.RunId)\n   155→}\n   156→\n   157→func cmdStatus(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   158→\tif len(args) < 1 {\n   159→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche status <run-id>\\n\")\n   160→\t\tos.Exit(1)\n   161→\t}\n   162→\n   163→\tresp, err := client.GetStatus(ctx, &pb.GetStatusRequest{RunId: args[0]})\n   164→\tif err != nil {\n   165→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   166→\t\tos.Exit(1)\n   167→\t}\n   168→\n   169→\tfmt.Printf(\"Run:       %s\\n\", resp.RunId)\n   170→\tfmt.Printf(\"Workflow:  %s\\n\", resp.WorkflowName)\n   171→\tfmt.Printf(\"State:     %s\\n\", resp.State)\n   172→\tif resp.ContainerId != \"\" {\n   173→\t\tcid := resp.ContainerId\n   174→\t\tif len(cid) > 12 {\n   175→\t\t\tcid = cid[:12]\n   176→\t\t}\n   177→\t\tfmt.Printf(\"Container: %s\\n\", cid)\n   178→\t}\n   179→\tif resp.ErrorMessage != \"\" {\n   180→\t\tfmt.Printf(\"Error:     %s\\n\", resp.ErrorMessage)\n   181→\t}\n   182→\tfmt.Printf(\"Active:    %s\\n\", resp.CurrentStep)\n   183→\tfor _, exec := range resp.StepExecutions {\n   184→\t\tfmt.Printf(\"  %s: %s (%s -> %s)\\n\", exec.StepName, exec.Result, exec.StartedAt, exec.CompletedAt)\n   185→\t}\n   186→}\n   187→\n   188→func cmdList(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   189→\tvar all bool\n   190→\tfor _, arg := range args {\n   191→\t\tif arg == \"--all\" {\n   192→\t\t\tall = true\n   193→\t\t}\n   194→\t}\n   195→\n   196→\tresp, err := client.ListRuns(ctx, &pb.ListRunsRequest{All: all})\n   197→\tif err != nil {\n   198→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   199→\t\tos.Exit(1)\n   200→\t}\n   201→\n   202→\tif len(resp.Runs) == 0 {\n   203→\t\tfmt.Println(\"No runs found.\")\n   204→\t\treturn\n   205→\t}\n   206→\n   207→\tfor _, run := range resp.Runs {\n   208→\t\tline := fmt.Sprintf(\"%s  %-20s  %-10s\", run.RunId, run.WorkflowName, run.State)\n   209→\t\tif run.ContainerId != \"\" {\n   210→\t\t\tline += \"  \" + run.ContainerId\n   211→\t\t}\n   212→\t\tif run.ErrorMessage != \"\" {\n   213→\t\t\terrMsg := run.ErrorMessage\n   214→\t\t\tif len(errMsg) > 60 {\n   215→\t\t\t\terrMsg = errMsg[:57] + \"...\"\n   216→\t\t\t}\n   217→\t\t\tline += \"  \" + errMsg\n   218→\t\t}\n   219→\t\tfmt.Println(line)\n   220→\t}\n   221→}\n   222→\n   223→func cmdLogs(client pb.ClocheServiceClient, args []string) {\n   224→\tif len(args) < 1 {\n   225→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche logs <run-id> [--step <name>] [--type <full|script|llm>] [--follow]\\n\")\n   226→\t\tos.Exit(1)\n   227→\t}\n   228→\n   229→\tvar stepFilter, typeFilter string\n   230→\tvar follow bool\n   231→\trunID := args[0]\n   232→\n   233→\tfor i := 1; i < len(args); i++ {\n   234→\t\tswitch args[i] {\n   235→\t\tcase \"--step\":\n   236→\t\t\tif i+1 < len(args) {\n   237→\t\t\t\ti++\n   238→\t\t\t\tstepFilter = args[i]\n   239→\t\t\t}\n   240→\t\tcase \"--type\":\n   241→\t\t\tif i+1 < len(args) {\n   242→\t\t\t\ti++\n   243→\t\t\t\ttypeFilter = args[i]\n   244→\t\t\t}\n   245→\t\tcase \"--follow\", \"-f\":\n   246→\t\t\tfollow = true\n   247→\t\t}\n   248→\t}\n   249→\n   250→\tif follow {\n   251→\t\tcmdLogsFollow(runID)\n   252→\t\treturn\n   253→\t}\n   254→\n   255→\t// Use background context — log output can be large\n   256→\tstream, err := client.StreamLogs(context.Background(), &pb.StreamLogsRequest{\n   257→\t\tRunId:    runID,\n   258→\t\tStepName: stepFilter,\n   259→\t\tLogType:  typeFilter,\n   260→\t})\n   261→\tif err != nil {\n   262→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   263→\t\tos.Exit(1)\n   264→\t}\n   265→\n   266→\tfor {\n   267→\t\tentry, err := stream.Recv()\n   268→\t\tif err != nil {\n   269→\t\t\tif errors.Is(err, io.EOF) {\n   270→\t\t\t\tbreak\n   271→\t\t\t}\n   272→\t\t\tfmt.Fprintf(os.Stderr, \"error reading logs: %v\\n\", err)\n   273→\t\t\tos.Exit(1)\n   274→\t\t}\n   275→\n   276→\t\tswitch entry.Type {\n   277→\t\tcase \"step_started\":\n   278→\t\t\tfmt.Printf(\"--- %s started ---\\n\", entry.StepName)\n   279→\t\t\tif entry.Message != \"\" {\n   280→\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n   281→\t\t\t}\n   282→\t\tcase \"step_completed\":\n   283→\t\t\tfmt.Printf(\"--- %s: %s ---\\n\", entry.StepName, entry.Result)\n   284→\t\t\tif entry.Message != \"\" {\n   285→\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n   286→\t\t\t}\n   287→\t\tcase \"run_completed\":\n   288→\t\t\tfmt.Printf(\"\\nRun result: %s\\n\", entry.Result)\n   289→\t\t\tif entry.Message != \"\" {\n   290→\t\t\t\tfmt.Printf(\"Error:      %s\\n\", entry.Message)\n   291→\t\t\t}\n   292→\t\tcase \"full_log\":\n   293→\t\t\tfmt.Print(entry.Message)\n   294→\t\tdefault:\n   295→\t\t\t// Handles filtered log entries like \"script_log\", \"llm_log\", \"step_log\"\n   296→\t\t\tif entry.StepName != \"\" {\n   297→\t\t\t\tfmt.Printf(\"--- %s ---\\n\", entry.StepName)\n   298→\t\t\t}\n   299→\t\t\tif entry.Message != \"\" {\n   300→\t\t\t\tfmt.Print(entry.Message)\n   301→\t\t\t}\n   302→\t\t}\n   303→\t}\n   304→}\n   305→\n   306→func cmdLogsFollow(runID string) {\n   307→\t// Determine HTTP address from env\n   308→\thttpAddr := os.Getenv(\"CLOCHE_HTTP\")\n   309→\tif httpAddr == \"\" {\n   310→\t\thttpAddr = \"localhost:8080\"\n   311→\t}\n   312→\t// Strip protocol prefix if present\n   313→\thttpAddr = strings.TrimPrefix(httpAddr, \"http://\")\n   314→\n   315→\tsseURL := fmt.Sprintf(\"http://%s/api/runs/%s/stream\", httpAddr, runID)\n   316→\treq, err := http.NewRequest(\"GET\", sseURL, nil)\n   317→\tif err != nil {\n   318→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   319→\t\tos.Exit(1)\n   320→\t}\n   321→\treq.Header.Set(\"Accept\", \"text/event-stream\")\n   322→\n   323→\tresp, err := http.DefaultClient.Do(req)\n   324→\tif err != nil {\n   325→\t\tfmt.Fprintf(os.Stderr, \"error connecting to SSE stream: %v\\n\", err)\n   326→\t\tos.Exit(1)\n   327→\t}\n   328→\tdefer resp.Body.Close()\n   329→\n   330→\tif resp.StatusCode != 200 {\n   331→\t\tbody, _ := io.ReadAll(resp.Body)\n   332→\t\tfmt.Fprintf(os.Stderr, \"error: HTTP %d: %s\\n\", resp.StatusCode, strings.TrimSpace(string(body)))\n   333→\t\tos.Exit(1)\n   334→\t}\n   335→\n   336→\tscanner := bufio.NewScanner(resp.Body)\n   337→\tfor scanner.Scan() {\n   338→\t\tline := scanner.Text()\n   339→\t\tif strings.HasPrefix(line, \"event: done\") {\n   340→\t\t\tbreak\n   341→\t\t}\n   342→\t\tif !strings.HasPrefix(line, \"data: \") {\n   343→\t\t\tcontinue\n   344→\t\t}\n   345→\t\tdata := strings.TrimPrefix(line, \"data: \")\n   346→\n   347→\t\tvar entry struct {\n   348→\t\t\tTimestamp string `json:\"timestamp\"`\n   349→\t\t\tType      string `json:\"type\"`\n   350→\t\t\tContent   string `json:\"content\"`\n   351→\t\t}\n   352→\t\tif err := json.Unmarshal([]byte(data), &entry); err != nil {\n   353→\t\t\tcontinue\n   354→\t\t}\n   355→\n   356→\t\t// Color-code by type\n   357→\t\tswitch entry.Type {\n   358→\t\tcase \"status\":\n   359→\t\t\tfmt.Printf(\"\\033[34m[%s] [%s] %s\\033[0m\\n\", entry.Timestamp, entry.Type, entry.Content)\n   360→\t\tcase \"llm\":\n   361→\t\t\tfmt.Printf(\"\\033[32m[%s] [%s] %s\\033[0m\\n\", entry.Timestamp, entry.Type, entry.Content)\n   362→\t\tdefault:\n   363→\t\t\tfmt.Printf(\"[%s] [%s] %s\\n\", entry.Timestamp, entry.Type, entry.Content)\n   364→\t\t}\n   365→\t}\n   366→}\n   367→\n   368→func cmdStop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   369→\tif len(args) < 1 {\n   370→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche stop <run-id>\\n\")\n   371→\t\tos.Exit(1)\n   372→\t}\n   373→\n   374→\t_, err := client.StopRun(ctx, &pb.StopRunRequest{RunId: args[0]})\n   375→\tif err != nil {\n   376→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   377→\t\tos.Exit(1)\n   378→\t}\n   379→\tfmt.Printf(\"Stopped run: %s\\n\", args[0])\n   380→}\n   381→\n   382→func cmdDelete(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   383→\tif len(args) < 1 {\n   384→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche delete <container-or-run-id>\\n\")\n   385→\t\tos.Exit(1)\n   386→\t}\n   387→\n   388→\t_, err := client.DeleteContainer(ctx, &pb.DeleteContainerRequest{Id: args[0]})\n   389→\tif err != nil {\n   390→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   391→\t\tos.Exit(1)\n   392→\t}\n   393→\tfmt.Printf(\"Deleted container: %s\\n\", args[0])\n   394→}\n   395→\n   396→func cmdOrchestrate(ctx context.Context, client pb.ClocheServiceClient) {\n   397→\tcwd, _ := os.Getwd()\n   398→\tresp, err := client.Orchestrate(ctx, &pb.OrchestrateRequest{ProjectDir: cwd})\n   399→\tif err != nil {\n   400→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   401→\t\tos.Exit(1)\n   402→\t}\n   403→\tif resp.Dispatched == 0 {\n   404→\t\tfmt.Println(\"No ready work found.\")\n   405→\t} else {\n   406→\t\tfmt.Printf(\"Dispatched %d run(s).\\n\", resp.Dispatched)\n   407→\t}\n   408→}\n   409→\n   410→func cmdShutdown(ctx context.Context, client pb.ClocheServiceClient) {\n   411→\t_, err := client.Shutdown(ctx, &pb.ShutdownRequest{})\n   412→\tif err != nil {\n   413→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   414→\t\tos.Exit(1)\n   415→\t}\n   416→\tfmt.Println(\"Daemon shutting down.\")\n   417→}\n   418→"}]},"parent_tool_use_id":null,"session_id":"b9d3bc4e-ff02-4cfe-87ed-015ff9f5f3a8","uuid":"673de1d6-6429-4a81-91a9-35b1db96ee2a","tool_use_result":{"type":"text","file":{"filePath":"/workspace/cmd/cloche/main.go","content":"package main\n\nimport (\n\t\"bufio\"\n\t\"context\"\n\t\"encoding/json\"\n\t\"errors\"\n\t\"fmt\"\n\t\"io\"\n\t\"net/http\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"strings\"\n\t\"time\"\n\n\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n\t\"github.com/cloche-dev/cloche/internal/dsl\"\n\t\"google.golang.org/grpc\"\n\t\"google.golang.org/grpc/credentials/insecure\"\n)\n\nfunc main() {\n\tif len(os.Args) < 2 {\n\t\tusage()\n\t\tos.Exit(1)\n\t}\n\n\t// Commands that don't need a daemon connection\n\tswitch os.Args[1] {\n\tcase \"init\":\n\t\tcmdInit(os.Args[2:])\n\t\treturn\n\tcase \"health\":\n\t\tcmdHealth(os.Args[2:])\n\t\treturn\n\t}\n\n\t// Commands that need a daemon connection\n\taddr := os.Getenv(\"CLOCHE_ADDR\")\n\tif addr == \"\" {\n\t\taddr = \"unix:///tmp/cloche.sock\"\n\t}\n\n\tconn, err := grpc.NewClient(addr, grpc.WithTransportCredentials(insecure.NewCredentials()))\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"failed to connect: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tdefer conn.Close()\n\n\tclient := pb.NewClocheServiceClient(conn)\n\tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n\tdefer cancel()\n\n\tswitch os.Args[1] {\n\tcase \"run\":\n\t\tcmdRun(ctx, client, os.Args[2:])\n\tcase \"status\":\n\t\tcmdStatus(ctx, client, os.Args[2:])\n\tcase \"logs\":\n\t\tcmdLogs(client, os.Args[2:])\n\tcase \"poll\":\n\t\tcmdPoll(client, os.Args[2:])\n\tcase \"list\":\n\t\tcmdList(ctx, client, os.Args[2:])\n\tcase \"stop\":\n\t\tcmdStop(ctx, client, os.Args[2:])\n\tcase \"delete\":\n\t\tcmdDelete(ctx, client, os.Args[2:])\n\tcase \"orchestrate\":\n\t\tcmdOrchestrate(ctx, client)\n\tcase \"shutdown\":\n\t\tcmdShutdown(ctx, client)\n\tdefault:\n\t\tusage()\n\t\tos.Exit(1)\n\t}\n}\n\nfunc usage() {\n\tfmt.Fprintf(os.Stderr, `usage: cloche <command> [args]\n\nCommands:\n  init [--workflow <name>] [--base-image <image>]\n                                             Initialize a Cloche project\n  health                                   Show project health summary\n  run --workflow <name> [--prompt \"...\"] [--keep-container]\n                                             Launch a workflow run\n  status <run-id>                            Check run status\n  logs <run-id> [--step <name>] [--type <full|script|llm>] [--follow]\n                                             Show logs for a run\n  poll <run-id>                              Wait for a run to finish\n  list [--all]                                List runs (last hour by default)\n  stop <run-id>                              Stop a running workflow\n  delete <container-or-run-id>               Delete a retained container\n  orchestrate                                Dispatch ready workflow runs\n  shutdown                                   Shut down the daemon\n`)\n}\n\nfunc cmdRun(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tvar workflow, prompt string\n\tvar keepContainer bool\n\n\tfor i := 0; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--workflow\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tworkflow = args[i]\n\t\t\t}\n\t\tcase \"--prompt\", \"-p\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tprompt = args[i]\n\t\t\t}\n\t\tcase \"--keep-container\":\n\t\t\tkeepContainer = true\n\t\tdefault:\n\t\t\t// Support bare positional arg as workflow name for backwards compat\n\t\t\tif workflow == \"\" && !strings.HasPrefix(args[i], \"-\") {\n\t\t\t\tworkflow = args[i]\n\t\t\t}\n\t\t}\n\t}\n\n\tif workflow == \"\" {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche run --workflow <name> [--prompt \\\"...\\\"]\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tcwd, _ := os.Getwd()\n\n\t// Resolve image from workflow file (soft failure — fall back to daemon default)\n\tvar image string\n\twfPath := filepath.Join(cwd, \".cloche\", workflow+\".cloche\")\n\tif data, err := os.ReadFile(wfPath); err == nil {\n\t\tif wf, err := dsl.Parse(string(data)); err == nil {\n\t\t\timage = wf.Config[\"container.image\"]\n\t\t}\n\t}\n\n\tresp, err := client.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n\t\tWorkflowName:  workflow,\n\t\tProjectDir:    cwd,\n\t\tImage:         image,\n\t\tPrompt:        prompt,\n\t\tKeepContainer: keepContainer,\n\t})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Printf(\"Started run: %s\\n\", resp.RunId)\n}\n\nfunc cmdStatus(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche status <run-id>\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tresp, err := client.GetStatus(ctx, &pb.GetStatusRequest{RunId: args[0]})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tfmt.Printf(\"Run:       %s\\n\", resp.RunId)\n\tfmt.Printf(\"Workflow:  %s\\n\", resp.WorkflowName)\n\tfmt.Printf(\"State:     %s\\n\", resp.State)\n\tif resp.ContainerId != \"\" {\n\t\tcid := resp.ContainerId\n\t\tif len(cid) > 12 {\n\t\t\tcid = cid[:12]\n\t\t}\n\t\tfmt.Printf(\"Container: %s\\n\", cid)\n\t}\n\tif resp.ErrorMessage != \"\" {\n\t\tfmt.Printf(\"Error:     %s\\n\", resp.ErrorMessage)\n\t}\n\tfmt.Printf(\"Active:    %s\\n\", resp.CurrentStep)\n\tfor _, exec := range resp.StepExecutions {\n\t\tfmt.Printf(\"  %s: %s (%s -> %s)\\n\", exec.StepName, exec.Result, exec.StartedAt, exec.CompletedAt)\n\t}\n}\n\nfunc cmdList(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tvar all bool\n\tfor _, arg := range args {\n\t\tif arg == \"--all\" {\n\t\t\tall = true\n\t\t}\n\t}\n\n\tresp, err := client.ListRuns(ctx, &pb.ListRunsRequest{All: all})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tif len(resp.Runs) == 0 {\n\t\tfmt.Println(\"No runs found.\")\n\t\treturn\n\t}\n\n\tfor _, run := range resp.Runs {\n\t\tline := fmt.Sprintf(\"%s  %-20s  %-10s\", run.RunId, run.WorkflowName, run.State)\n\t\tif run.ContainerId != \"\" {\n\t\t\tline += \"  \" + run.ContainerId\n\t\t}\n\t\tif run.ErrorMessage != \"\" {\n\t\t\terrMsg := run.ErrorMessage\n\t\t\tif len(errMsg) > 60 {\n\t\t\t\terrMsg = errMsg[:57] + \"...\"\n\t\t\t}\n\t\t\tline += \"  \" + errMsg\n\t\t}\n\t\tfmt.Println(line)\n\t}\n}\n\nfunc cmdLogs(client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche logs <run-id> [--step <name>] [--type <full|script|llm>] [--follow]\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tvar stepFilter, typeFilter string\n\tvar follow bool\n\trunID := args[0]\n\n\tfor i := 1; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--step\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tstepFilter = args[i]\n\t\t\t}\n\t\tcase \"--type\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\ttypeFilter = args[i]\n\t\t\t}\n\t\tcase \"--follow\", \"-f\":\n\t\t\tfollow = true\n\t\t}\n\t}\n\n\tif follow {\n\t\tcmdLogsFollow(runID)\n\t\treturn\n\t}\n\n\t// Use background context — log output can be large\n\tstream, err := client.StreamLogs(context.Background(), &pb.StreamLogsRequest{\n\t\tRunId:    runID,\n\t\tStepName: stepFilter,\n\t\tLogType:  typeFilter,\n\t})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tfor {\n\t\tentry, err := stream.Recv()\n\t\tif err != nil {\n\t\t\tif errors.Is(err, io.EOF) {\n\t\t\t\tbreak\n\t\t\t}\n\t\t\tfmt.Fprintf(os.Stderr, \"error reading logs: %v\\n\", err)\n\t\t\tos.Exit(1)\n\t\t}\n\n\t\tswitch entry.Type {\n\t\tcase \"step_started\":\n\t\t\tfmt.Printf(\"--- %s started ---\\n\", entry.StepName)\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n\t\t\t}\n\t\tcase \"step_completed\":\n\t\t\tfmt.Printf(\"--- %s: %s ---\\n\", entry.StepName, entry.Result)\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n\t\t\t}\n\t\tcase \"run_completed\":\n\t\t\tfmt.Printf(\"\\nRun result: %s\\n\", entry.Result)\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Printf(\"Error:      %s\\n\", entry.Message)\n\t\t\t}\n\t\tcase \"full_log\":\n\t\t\tfmt.Print(entry.Message)\n\t\tdefault:\n\t\t\t// Handles filtered log entries like \"script_log\", \"llm_log\", \"step_log\"\n\t\t\tif entry.StepName != \"\" {\n\t\t\t\tfmt.Printf(\"--- %s ---\\n\", entry.StepName)\n\t\t\t}\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Print(entry.Message)\n\t\t\t}\n\t\t}\n\t}\n}\n\nfunc cmdLogsFollow(runID string) {\n\t// Determine HTTP address from env\n\thttpAddr := os.Getenv(\"CLOCHE_HTTP\")\n\tif httpAddr == \"\" {\n\t\thttpAddr = \"localhost:8080\"\n\t}\n\t// Strip protocol prefix if present\n\thttpAddr = strings.TrimPrefix(httpAddr, \"http://\")\n\n\tsseURL := fmt.Sprintf(\"http://%s/api/runs/%s/stream\", httpAddr, runID)\n\treq, err := http.NewRequest(\"GET\", sseURL, nil)\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\treq.Header.Set(\"Accept\", \"text/event-stream\")\n\n\tresp, err := http.DefaultClient.Do(req)\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error connecting to SSE stream: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tdefer resp.Body.Close()\n\n\tif resp.StatusCode != 200 {\n\t\tbody, _ := io.ReadAll(resp.Body)\n\t\tfmt.Fprintf(os.Stderr, \"error: HTTP %d: %s\\n\", resp.StatusCode, strings.TrimSpace(string(body)))\n\t\tos.Exit(1)\n\t}\n\n\tscanner := bufio.NewScanner(resp.Body)\n\tfor scanner.Scan() {\n\t\tline := scanner.Text()\n\t\tif strings.HasPrefix(line, \"event: done\") {\n\t\t\tbreak\n\t\t}\n\t\tif !strings.HasPrefix(line, \"data: \") {\n\t\t\tcontinue\n\t\t}\n\t\tdata := strings.TrimPrefix(line, \"data: \")\n\n\t\tvar entry struct {\n\t\t\tTimestamp string `json:\"timestamp\"`\n\t\t\tType      string `json:\"type\"`\n\t\t\tContent   string `json:\"content\"`\n\t\t}\n\t\tif err := json.Unmarshal([]byte(data), &entry); err != nil {\n\t\t\tcontinue\n\t\t}\n\n\t\t// Color-code by type\n\t\tswitch entry.Type {\n\t\tcase \"status\":\n\t\t\tfmt.Printf(\"\\033[34m[%s] [%s] %s\\033[0m\\n\", entry.Timestamp, entry.Type, entry.Content)\n\t\tcase \"llm\":\n\t\t\tfmt.Printf(\"\\033[32m[%s] [%s] %s\\033[0m\\n\", entry.Timestamp, entry.Type, entry.Content)\n\t\tdefault:\n\t\t\tfmt.Printf(\"[%s] [%s] %s\\n\", entry.Timestamp, entry.Type, entry.Content)\n\t\t}\n\t}\n}\n\nfunc cmdStop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche stop <run-id>\\n\")\n\t\tos.Exit(1)\n\t}\n\n\t_, err := client.StopRun(ctx, &pb.StopRunRequest{RunId: args[0]})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Printf(\"Stopped run: %s\\n\", args[0])\n}\n\nfunc cmdDelete(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche delete <container-or-run-id>\\n\")\n\t\tos.Exit(1)\n\t}\n\n\t_, err := client.DeleteContainer(ctx, &pb.DeleteContainerRequest{Id: args[0]})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Printf(\"Deleted container: %s\\n\", args[0])\n}\n\nfunc cmdOrchestrate(ctx context.Context, client pb.ClocheServiceClient) {\n\tcwd, _ := os.Getwd()\n\tresp, err := client.Orchestrate(ctx, &pb.OrchestrateRequest{ProjectDir: cwd})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tif resp.Dispatched == 0 {\n\t\tfmt.Println(\"No ready work found.\")\n\t} else {\n\t\tfmt.Printf(\"Dispatched %d run(s).\\n\", resp.Dispatched)\n\t}\n}\n\nfunc cmdShutdown(ctx context.Context, client pb.ClocheServiceClient) {\n\t_, err := client.Shutdown(ctx, &pb.ShutdownRequest{})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Println(\"Daemon shutting down.\")\n}\n","numLines":418,"startLine":1,"totalLines":418}}}
[2026-03-08T01:38:25Z] [llm] {"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_018KyEqkNvhe6wExJdAbkQs8","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01ERXuEisMXPCYfLEqJMrZyj","name":"Read","input":{"file_path":"/workspace/docs/USAGE.md"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":3,"cache_creation_input_tokens":1951,"cache_read_input_tokens":12884,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1951},"output_tokens":9,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"b9d3bc4e-ff02-4cfe-87ed-015ff9f5f3a8","uuid":"789d2058-d893-4f3c-9fb0-884754601cad"}
[2026-03-08T01:38:25Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01ERXuEisMXPCYfLEqJMrZyj","type":"tool_result","content":"     1→# Usage\n     2→\n     3→Cloche runs containerized workflows for autonomous coding agents. You write a\n     4→workflow graph in the `.cloche` DSL, point Cloche at a project directory, and it\n     5→handles execution, retry logic, and status tracking.\n     6→\n     7→## Prerequisites\n     8→\n     9→- Go 1.25+\n    10→- Docker\n    11→- Git\n    12→- An `ANTHROPIC_API_KEY` (for agent steps using Claude Code)\n    13→\n    14→For detailed installation options (pre-built binaries, `go install`, Homebrew,\n    15→Docker-based usage), see [INSTALL.md](INSTALL.md).\n    16→\n    17→## Quick Start\n    18→\n    19→### 1. Build everything\n    20→\n    21→```\n    22→make build\n    23→make docker-build\n    24→```\n    25→\n    26→This produces `bin/cloche`, `bin/cloched`, `bin/cloche-agent`, and the\n    27→`cloche-agent:latest` Docker image.\n    28→\n    29→### 2. Start the daemon\n    30→\n    31→```\n    32→bin/cloched\n    33→```\n    34→\n    35→The daemon listens on a Unix socket at `/tmp/cloche.sock` by default. It\n    36→manages Docker containers, tracks run state in SQLite, and handles\n    37→container cleanup. Containers are automatically removed after successful\n    38→runs unless `--keep-container` is set. Failed runs always keep their\n    39→container for debugging.\n    40→\n    41→To enable the web dashboard, set `CLOCHE_HTTP` (e.g.\n    42→`CLOCHE_HTTP=:8080 bin/cloched`). The dashboard is not started unless\n    43→this variable is set.\n    44→\n    45→### 3. Run a workflow\n    46→\n    47→From your project directory (must be inside a git repository):\n    48→\n    49→```\n    50→cd my-project\n    51→cloche run --workflow develop --prompt \"Add user authentication\"\n    52→```\n    53→\n    54→This will:\n    55→1. Write your prompt to `.cloche/<run-id>/prompt.txt`\n    56→2. Create a Docker container and copy your entire project into it (no bind mounts)\n    57→3. Apply any override files from `.cloche/overrides/` on top\n    58→4. Start the container, which runs `cloche-agent` to walk the workflow graph\n    59→5. When the workflow finishes, the daemon extracts results to a `cloche/<run-id>` branch\n    60→\n    61→### 4. Monitor progress\n    62→\n    63→```\n    64→cloche status <run-id>\n    65→cloche list\n    66→```\n    67→\n    68→### 5. Get the results\n    69→\n    70→When the run completes, the agent's work is on a git branch:\n    71→\n    72→```\n    73→git branch | grep cloche/\n    74→git diff main..cloche/<run-id>\n    75→```\n    76→\n    77→To merge results into your working branch:\n    78→\n    79→```\n    80→git merge cloche/<run-id>\n    81→# or cherry-pick, rebase, etc.\n    82→```\n    83→\n    84→To clean up run branches:\n    85→\n    86→```\n    87→git branch -D cloche/<run-id>\n    88→```\n    89→\n    90→## Container Isolation Model\n    91→\n    92→Cloche provides **total filesystem isolation** between the host and container:\n    93→\n    94→- **Files in**: `docker cp` copies the entire project root into the container at\n    95→  `/workspace/`. No bind mounts for project files. Override files from\n    96→  `.cloche/overrides/` are then copied on top (e.g., a container-specific\n    97→  `CLAUDE.md`). The `.git/` directory is included so agents have git context.\n    98→- **Files out**: When the workflow completes, the daemon extracts results from\n    99→  the container via `docker cp` into a git worktree and commits them to a\n   100→  `cloche/<run-id>` branch.\n   101→- **Auth mounts**: `~/.claude` and `~/.claude.json` are bind-mounted read-only\n   102→  for Claude Code OAuth session reuse. `ANTHROPIC_API_KEY` is passed as an\n   103→  environment variable.\n   104→- **Network**: Containers have network access (needed for API calls).\n   105→\n   106→Your project directory is never modified by the container. All changes live\n   107→on the run branch until you explicitly merge them.\n   108→\n   109→## CLI Reference\n   110→\n   111→### `cloche init`\n   112→\n   113→Scaffold a new Cloche project in the current directory.\n   114→\n   115→```\n   116→cloche init [--workflow <name>] [--image <base>]\n   117→```\n   118→\n   119→| Flag | Default | Description |\n   120→|------|---------|-------------|\n   121→| `--workflow <name>` | `develop` | Workflow name. Creates `.cloche/<name>.cloche`. |\n   122→| `--image <base>` | `ubuntu:24.04` | Base Docker image for the generated Dockerfile. |\n   123→\n   124→Creates `.cloche/` with a workflow file, Dockerfile, configuration file\n   125→(`config.toml`), and prompt templates (`implement.md`, `fix.md`,\n   126→`update-docs.md`). Skips files that already exist.\n   127→Also adds gitignore entries for runtime state directories.\n   128→\n   129→### `cloche health`\n   130→\n   131→Show project health summary based on recent run results.\n   132→\n   133→```\n   134→cloche health\n   135→```\n   136→\n   137→Requires `CLOCHE_HTTP` to be set (e.g. `export CLOCHE_HTTP=localhost:8080`).\n   138→Fetches health data from the daemon's HTTP API (`GET /api/projects`) and\n   139→displays a table with per-project pass/fail counts:\n   140→\n   141→```\n   142→PROJECT          STATUS    PASSED  FAILED  TOTAL\n   143→my-project       green     5       0       5\n   144→other-project    yellow    3       2       5\n   145→```\n   146→\n   147→Status is colored (green/yellow/red) when output is a TTY.\n   148→\n   149→### `cloche run`\n   150→\n   151→Launch a workflow run.\n   152→\n   153→```\n   154→cloche run --workflow <name> [--prompt \"...\"] [--keep-container]\n   155→```\n   156→\n   157→| Flag | Description |\n   158→|------|-------------|\n   159→| `--workflow <name>` | Workflow name. Resolves to `.cloche/<name>.cloche` in the project directory. |\n   160→| `--prompt \"...\"`, `-p` | Inline prompt written to `.cloche/<run-id>/prompt.txt` and injected into agent steps. |\n   161→| `--keep-container` | Keep the Docker container even on success (default: remove on success). Failed runs always keep their container for debugging. |\n   162→\n   163→The current working directory is used as the project directory. It must be\n   164→inside a git repository (Cloche needs the repo root for result extraction\n   165→via git worktrees).\n   166→\n   167→When starting a run, the daemon checks whether the Docker image is up-to-date\n   168→with the project's `.cloche/Dockerfile`. If the Dockerfile has changed since\n   169→the last build (tracked via a SHA-256 label on the image), the daemon rebuilds\n   170→the image automatically before launching the container.\n   171→\n   172→### `cloche status`\n   173→\n   174→Check the status of a run.\n   175→\n   176→```\n   177→cloche status <run-id>\n   178→```\n   179→\n   180→Output includes the run state, active steps, and per-step results with timestamps.\n   181→\n   182→### `cloche list`\n   183→\n   184→List runs (last hour by default).\n   185→\n   186→```\n   187→cloche list [--all]\n   188→```\n   189→\n   190→| Flag | Description |\n   191→|------|-------------|\n   192→| `--all` | Show all runs, not just the last hour. |\n   193→\n   194→Columns: run ID, workflow name, state, container ID (if running), error message (if failed).\n   195→\n   196→### `cloche logs`\n   197→\n   198→Show logs for a run.\n   199→\n   200→```\n   201→cloche logs <run-id> [--step <name>] [--type <full|script|llm>] [--follow]\n   202→```\n   203→\n   204→| Flag | Description |\n   205→|------|-------------|\n   206→| `--step <name>` | Show only logs for the specified step. |\n   207→| `--type <full\\|script\\|llm>` | Show only logs of the specified type (`full` = unified log, `script` = script output, `llm` = LLM conversation). |\n   208→| `--follow`, `-f` | Stream live log lines via SSE. Color-coded by type: status (blue), LLM (green), script (default). Exits when the run completes. Connects to the daemon's HTTP endpoint (see `CLOCHE_HTTP` in Client Configuration). |\n   209→\n   210→Without flags, shows the unified log (`full.log`) if available, otherwise streams\n   211→step start/completion events and run results.\n   212→With `--follow`, connects to the SSE endpoint and prints log lines in real-time.\n   213→\n   214→### `cloche poll`\n   215→\n   216→Wait for a run to finish, printing progress updates.\n   217→\n   218→```\n   219→cloche poll <run-id>\n   220→```\n   221→\n   222→Polls every 2 seconds. Exits 0 on success, 1 on failure or if the container\n   223→dies unexpectedly.\n   224→\n   225→### `cloche stop`\n   226→\n   227→Cancel a running workflow.\n   228→\n   229→```\n   230→cloche stop <run-id>\n   231→```\n   232→\n   233→### `cloche delete`\n   234→\n   235→Delete a retained Docker container. Accepts either a Docker container name/ID\n   236→or a Cloche run ID. If given a run ID, the daemon looks up the associated\n   237→container.\n   238→\n   239→```\n   240→cloche delete <container-or-run-id>\n   241→```\n   242→\n   243→### `cloche orchestrate`\n   244→\n   245→Dispatch ready workflow runs for the current project. Checks the project's\n   246→issue tracker for unclaimed tasks, generates prompts, and launches runs.\n   247→\n   248→```\n   249→cloche orchestrate\n   250→```\n   251→\n   252→Uses the current working directory as the project directory. Prints \"No ready\n   253→work found.\" if there are no tasks to dispatch, or \"Dispatched N run(s).\"\n   254→with the count.\n   255→\n   256→### `cloche shutdown`\n   257→\n   258→Shut down the daemon.\n   259→\n   260→```\n   261→cloche shutdown\n   262→```\n   263→\n   264→## Setting Up a New Project\n   265→\n   266→### 1. Scaffold the project\n   267→\n   268→Run `cloche init` from your project root to create the `.cloche/` directory with\n   269→default workflow, Dockerfile, and prompt templates:\n   270→\n   271→```\n   272→cd my-project\n   273→cloche init\n   274→```\n   275→\n   276→Or create the structure manually:\n   277→\n   278→### 2. Create a workflow file\n   279→\n   280→Add `.cloche/<name>.cloche`:\n   281→\n   282→```\n   283→workflow \"develop\" {\n   284→  step implement {\n   285→    prompt = file(\".cloche/prompts/implement.md\")\n   286→    results = [success, fail]\n   287→  }\n   288→\n   289→  step test {\n   290→    run = \"make test 2>&1\"\n   291→    results = [success, fail]\n   292→  }\n   293→\n   294→  step fix {\n   295→    prompt = file(\".cloche/prompts/fix.md\")\n   296→    max_attempts = \"2\"\n   297→    results = [success, fail, give-up]\n   298→  }\n   299→\n   300→  step update-docs {\n   301→    prompt = file(\".cloche/prompts/update-docs.md\")\n   302→    results = [success, fail]\n   303→  }\n   304→\n   305→  implement:success -> test\n   306→  implement:fail -> abort\n   307→\n   308→  test:success -> update-docs\n   309→  test:fail -> fix\n   310→\n   311→  fix:success -> test\n   312→  fix:fail -> abort\n   313→  fix:give-up -> abort\n   314→\n   315→  update-docs:success -> done\n   316→  update-docs:fail -> done\n   317→}\n   318→```\n   319→\n   320→### 3. Write prompt templates\n   321→\n   322→Create `.cloche/prompts/` with markdown files:\n   323→\n   324→**`.cloche/prompts/implement.md`** — Instructions for the initial implementation:\n   325→```markdown\n   326→You are working on a project. Implement the following change:\n   327→\n   328→## User Request\n   329→(The user prompt is injected automatically by the agent adapter)\n   330→\n   331→## Guidelines\n   332→- Follow existing project conventions\n   333→- Write tests for new functionality\n   334→- Run tests locally before declaring success\n   335→```\n   336→\n   337→**`.cloche/prompts/fix.md`** — Instructions for fixing failures:\n   338→```markdown\n   339→The previous attempt had failures. Review the output logs in .cloche/output/\n   340→and fix the issues.\n   341→\n   342→## Guidelines\n   343→- Read the test/lint output carefully\n   344→- Fix the root cause, not the symptoms\n   345→- Run tests again to verify your fix\n   346→```\n   347→\n   348→**`.cloche/prompts/update-docs.md`** — Instructions for keeping docs in sync:\n   349→```markdown\n   350→Review the CLI source code and update usage documentation to reflect any changes.\n   351→```\n   352→\n   353→### 4. Add overrides (optional)\n   354→\n   355→Files in `.cloche/overrides/` are copied on top of `/workspace/` in the\n   356→container. Use this for container-specific configuration:\n   357→\n   358→```\n   359→.cloche/overrides/\n   360→  CLAUDE.md              # Container-specific CLAUDE.md (replaces host version)\n   361→```\n   362→\n   363→### 5. Make sure your project builds in the container\n   364→\n   365→The default Dockerfile generated by `cloche init` uses `ubuntu:24.04` as its\n   366→base image (configurable via `--image`). If your project needs different\n   367→dependencies, edit `.cloche/Dockerfile`:\n   368→\n   369→```dockerfile\n   370→FROM golang:1.25 AS builder\n   371→WORKDIR /src\n   372→COPY go.mod go.sum ./\n   373→RUN go mod download\n   374→COPY . .\n   375→RUN CGO_ENABLED=0 go build -o /cloche-agent ./cmd/cloche-agent\n   376→\n   377→FROM ubuntu:24.04\n   378→RUN apt-get update && apt-get install -y git <your-deps> && rm -rf /var/lib/apt/lists/*\n   379→RUN npm install -g @anthropic-ai/claude-code\n   380→COPY --from=builder /cloche-agent /usr/local/bin/cloche-agent\n   381→RUN useradd -m -s /bin/bash agent\n   382→WORKDIR /workspace\n   383→RUN chown agent:agent /workspace\n   384→USER agent\n   385→```\n   386→\n   387→Key requirements for the image:\n   388→- `cloche-agent` binary at `/usr/local/bin/cloche-agent`\n   389→- `git` installed (for pushing results back)\n   390→- An `agent` user (cloche wraps the command with `chown` + `su agent`)\n   391→- `/workspace` as the working directory\n   392→- Your project's build dependencies\n   393→\n   394→The daemon automatically rebuilds the image when `.cloche/Dockerfile` changes\n   395→(see `cloche run` above). To build manually:\n   396→```\n   397→docker build -t my-project-agent -f .cloche/Dockerfile .\n   398→CLOCHE_IMAGE=my-project-agent:latest bin/cloched\n   399→```\n   400→\n   401→### 6. Run it\n   402→\n   403→```\n   404→cd my-project\n   405→cloche run --workflow develop --prompt \"Add feature X\"\n   406→```\n   407→\n   408→## Writing Workflows\n   409→\n   410→Workflow files use the `.cloche` extension and live in the `.cloche/` directory. See\n   411→[workflows.md](workflows.md) for full DSL reference.\n   412→\n   413→### Step Types\n   414→\n   415→**Agent steps** (has `prompt`) — Invokes a coding agent autonomously:\n   416→\n   417→```\n   418→step implement {\n   419→  prompt = file(\".cloche/prompts/implement.md\")\n   420→  results = [success, fail]\n   421→}\n   422→```\n   423→\n   424→**Script steps** (has `run`) — Runs a shell command:\n   425→\n   426→```\n   427→step test {\n   428→  run = \"make test 2>&1\"\n   429→  results = [success, fail]\n   430→}\n   431→```\n   432→\n   433→### Wiring\n   434→\n   435→Connect steps with `step:result -> next_step`:\n   436→\n   437→```\n   438→implement:success -> test\n   439→implement:fail -> abort\n   440→test:success -> done\n   441→test:fail -> fix\n   442→```\n   443→\n   444→`done` and `abort` are built-in terminals for success and failure.\n   445→\n   446→### Retry Loops\n   447→\n   448→Wire failures back to earlier steps:\n   449→\n   450→```\n   451→test:fail -> fix\n   452→fix:success -> test    // retry the test\n   453→fix:fail -> abort\n   454→```\n   455→\n   456→### Max Attempts\n   457→\n   458→Limit retries on agent steps. When exhausted, the step returns `give-up`:\n   459→\n   460→```\n   461→step fix {\n   462→  prompt = file(\".cloche/prompts/fix.md\")\n   463→  max_attempts = \"2\"\n   464→  results = [success, fail, give-up]\n   465→}\n   466→```\n   467→\n   468→### Parallel Branches\n   469→\n   470→Wire one result to multiple targets for concurrent execution:\n   471→\n   472→```\n   473→test:success -> lint\n   474→test:success -> quality\n   475→```\n   476→\n   477→### Collect (Join)\n   478→\n   479→Synchronize parallel branches:\n   480→\n   481→```\n   482→collect all(lint:success, quality:success) -> done\n   483→```\n   484→\n   485→`all` fires when every condition is met. `any` fires when at least one is.\n   486→\n   487→### Agent Command Override\n   488→\n   489→Agent steps use Claude Code by default. Override per-step:\n   490→\n   491→```\n   492→step implement {\n   493→  prompt = \"...\"\n   494→  agent_command = \"aider\"\n   495→  results = [success, fail]\n   496→}\n   497→```\n   498→\n   499→Or at the workflow level via a `container` block:\n   500→\n   501→```\n   502→workflow \"develop\" {\n   503→  container {\n   504→    agent_command = \"gemini\"\n   505→  }\n   506→  ...\n   507→}\n   508→```\n   509→\n   510→Or globally via `CLOCHE_AGENT_COMMAND` environment variable.\n   511→\n   512→Priority (highest to lowest): step-level `agent_command`, workflow-level\n   513→`container { agent_command }`, `CLOCHE_AGENT_COMMAND` env var, default (`claude`).\n   514→\n   515→### Agent Fallback Chains\n   516→\n   517→Use a comma-separated list in `agent_command` to configure fallback chains. If\n   518→the first agent errors without reporting a result, the system tries the next:\n   519→\n   520→```\n   521→step implement {\n   522→  prompt = \"...\"\n   523→  agent_command = \"claude,gemini,codex\"\n   524→  results = [success, fail]\n   525→}\n   526→```\n   527→\n   528→Fallback rules:\n   529→- **Command not found or failed to start** — fall back to next command\n   530→- **Exit non-zero without `CLOCHE_RESULT` marker** — fall back to next command\n   531→- **Exit non-zero with `CLOCHE_RESULT` marker** — use that result (no fallback)\n   532→- **Exit 0** — use result (no fallback)\n   533→- **All commands fail to start** — step returns an error\n   534→- **Last command crashes without marker** — step returns `fail`\n   535→\n   536→Known agents have default arguments (e.g., Claude gets\n   537→`-p --output-format text --dangerously-skip-permissions`). Other agents receive\n   538→the prompt on stdin with no extra flags. Override with `agent_args` at the step\n   539→or workflow level.\n   540→\n   541→## Result Protocol\n   542→\n   543→Steps report results by writing a marker to stdout:\n   544→\n   545→```\n   546→CLOCHE_RESULT:<name>\n   547→```\n   548→\n   549→For script steps, if no marker is written, the exit code determines the result:\n   550→0 = `success`, non-zero = `fail`. Agent steps follow the same convention.\n   551→\n   552→## Prompt Assembly\n   553→\n   554→When an agent step runs, Cloche assembles a prompt from multiple sources:\n   555→\n   556→1. The step's `prompt` content (inline or from `file()`)\n   557→2. The user prompt from `.cloche/<run-id>/prompt.txt` (set via `--prompt`)\n   558→3. Validation output from `.cloche/<run-id>/output/*.log` (output from previous script steps)\n   559→4. Result selection instructions listing the step's declared results\n   560→\n   561→## Project Directory Layout\n   562→\n   563→```\n   564→my-project/\n   565→├── .cloche/\n   566→│   ├── develop.cloche        # Workflow definition\n   567→│   ├── Dockerfile            # Container image\n   568→│   ├── config.toml           # Project configuration (orchestration, evolution)\n   569→│   ├── prompts/\n   570→│   │   ├── implement.md      # Prompt templates\n   571→│   │   ├── fix.md\n   572→│   │   └── update-docs.md\n   573→│   ├── overrides/            # Files copied on top of /workspace/ in container\n   574→│   │   └── CLAUDE.md         # Container-specific CLAUDE.md (optional)\n   575→│   └── <run-id>/             # Runtime state (gitignored)\n   576→│       ├── prompt.txt        # User prompt (from --prompt flag)\n   577→│       ├── output/\n   578→│       │   ├── full.log      # Unified chronological log (status + script + LLM)\n   579→│       │   ├── test.log      # Per-step script output\n   580→│       │   └── llm-impl.log  # Per-step LLM conversation output\n   581→│       ├── attempt_count/\n   582→│       │   └── fix           # Retry counter for max_attempts\n   583→│       └── history.log       # Step execution log\n   584→├── src/                      # Existing project source (untouched)\n   585→├── CLAUDE.md                 # Host CLAUDE.md\n   586→└── .git/\n   587→```\n   588→\n   589→## Daemon Configuration\n   590→\n   591→| Variable | Default | Description |\n   592→|----------|---------|-------------|\n   593→| `CLOCHE_LISTEN` | `unix:///tmp/cloche.sock` | Listen address (unix socket or TCP) |\n   594→| `CLOCHE_DB` | `cloche.db` | SQLite database path |\n   595→| `CLOCHE_RUNTIME` | `docker` | `docker` (container) or `local` (subprocess, for dev) |\n   596→| `CLOCHE_IMAGE` | `cloche-agent:latest` | Default Docker image |\n   597→| `CLOCHE_HTTP` | — | HTTP address for the web dashboard. Not started unless set. |\n   598→| `CLOCHE_AGENT_PATH` | (auto-detected) | Path to `cloche-agent` binary (local runtime) |\n   599→| `CLOCHE_LLM_COMMAND` | — | Command for LLM calls — evolution and merge conflict resolution (e.g. `claude`) |\n   600→| `ANTHROPIC_API_KEY` | — | Passed into Docker containers |\n   601→| `CLOCHE_EXTRA_MOUNTS` | — | Extra bind mounts (comma-separated `host:container`) |\n   602→| `CLOCHE_EXTRA_ENV` | — | Extra env vars (comma-separated `KEY=VALUE`) |\n   603→\n   604→### Client Configuration\n   605→\n   606→| Variable | Default | Description |\n   607→|----------|---------|-------------|\n   608→| `CLOCHE_ADDR` | `unix:///tmp/cloche.sock` | Daemon address (gRPC) |\n   609→| `CLOCHE_HTTP` | `localhost:8080` | Daemon HTTP address (web dashboard, `cloche logs --follow`) |\n   610→\n   611→## Build Commands\n   612→\n   613→```\n   614→make build          # Build all binaries to bin/\n   615→make test           # Run all tests\n   616→make test-short     # Run tests (skip slow ones)\n   617→make lint           # Run go vet\n   618→make proto          # Regenerate gRPC code from protobuf\n   619→make docker-build   # Build the cloche-agent Docker image\n   620→make install        # Build, install to ~/.local/bin/, restart daemon\n   621→make clean          # Remove bin/\n   622→```\n   623→"}]},"parent_tool_use_id":null,"session_id":"b9d3bc4e-ff02-4cfe-87ed-015ff9f5f3a8","uuid":"7ea7dd9d-387e-4009-903d-ebafc07eb4f4","tool_use_result":{"type":"text","file":{"filePath":"/workspace/docs/USAGE.md","content":"# Usage\n\nCloche runs containerized workflows for autonomous coding agents. You write a\nworkflow graph in the `.cloche` DSL, point Cloche at a project directory, and it\nhandles execution, retry logic, and status tracking.\n\n## Prerequisites\n\n- Go 1.25+\n- Docker\n- Git\n- An `ANTHROPIC_API_KEY` (for agent steps using Claude Code)\n\nFor detailed installation options (pre-built binaries, `go install`, Homebrew,\nDocker-based usage), see [INSTALL.md](INSTALL.md).\n\n## Quick Start\n\n### 1. Build everything\n\n```\nmake build\nmake docker-build\n```\n\nThis produces `bin/cloche`, `bin/cloched`, `bin/cloche-agent`, and the\n`cloche-agent:latest` Docker image.\n\n### 2. Start the daemon\n\n```\nbin/cloched\n```\n\nThe daemon listens on a Unix socket at `/tmp/cloche.sock` by default. It\nmanages Docker containers, tracks run state in SQLite, and handles\ncontainer cleanup. Containers are automatically removed after successful\nruns unless `--keep-container` is set. Failed runs always keep their\ncontainer for debugging.\n\nTo enable the web dashboard, set `CLOCHE_HTTP` (e.g.\n`CLOCHE_HTTP=:8080 bin/cloched`). The dashboard is not started unless\nthis variable is set.\n\n### 3. Run a workflow\n\nFrom your project directory (must be inside a git repository):\n\n```\ncd my-project\ncloche run --workflow develop --prompt \"Add user authentication\"\n```\n\nThis will:\n1. Write your prompt to `.cloche/<run-id>/prompt.txt`\n2. Create a Docker container and copy your entire project into it (no bind mounts)\n3. Apply any override files from `.cloche/overrides/` on top\n4. Start the container, which runs `cloche-agent` to walk the workflow graph\n5. When the workflow finishes, the daemon extracts results to a `cloche/<run-id>` branch\n\n### 4. Monitor progress\n\n```\ncloche status <run-id>\ncloche list\n```\n\n### 5. Get the results\n\nWhen the run completes, the agent's work is on a git branch:\n\n```\ngit branch | grep cloche/\ngit diff main..cloche/<run-id>\n```\n\nTo merge results into your working branch:\n\n```\ngit merge cloche/<run-id>\n# or cherry-pick, rebase, etc.\n```\n\nTo clean up run branches:\n\n```\ngit branch -D cloche/<run-id>\n```\n\n## Container Isolation Model\n\nCloche provides **total filesystem isolation** between the host and container:\n\n- **Files in**: `docker cp` copies the entire project root into the container at\n  `/workspace/`. No bind mounts for project files. Override files from\n  `.cloche/overrides/` are then copied on top (e.g., a container-specific\n  `CLAUDE.md`). The `.git/` directory is included so agents have git context.\n- **Files out**: When the workflow completes, the daemon extracts results from\n  the container via `docker cp` into a git worktree and commits them to a\n  `cloche/<run-id>` branch.\n- **Auth mounts**: `~/.claude` and `~/.claude.json` are bind-mounted read-only\n  for Claude Code OAuth session reuse. `ANTHROPIC_API_KEY` is passed as an\n  environment variable.\n- **Network**: Containers have network access (needed for API calls).\n\nYour project directory is never modified by the container. All changes live\non the run branch until you explicitly merge them.\n\n## CLI Reference\n\n### `cloche init`\n\nScaffold a new Cloche project in the current directory.\n\n```\ncloche init [--workflow <name>] [--image <base>]\n```\n\n| Flag | Default | Description |\n|------|---------|-------------|\n| `--workflow <name>` | `develop` | Workflow name. Creates `.cloche/<name>.cloche`. |\n| `--image <base>` | `ubuntu:24.04` | Base Docker image for the generated Dockerfile. |\n\nCreates `.cloche/` with a workflow file, Dockerfile, configuration file\n(`config.toml`), and prompt templates (`implement.md`, `fix.md`,\n`update-docs.md`). Skips files that already exist.\nAlso adds gitignore entries for runtime state directories.\n\n### `cloche health`\n\nShow project health summary based on recent run results.\n\n```\ncloche health\n```\n\nRequires `CLOCHE_HTTP` to be set (e.g. `export CLOCHE_HTTP=localhost:8080`).\nFetches health data from the daemon's HTTP API (`GET /api/projects`) and\ndisplays a table with per-project pass/fail counts:\n\n```\nPROJECT          STATUS    PASSED  FAILED  TOTAL\nmy-project       green     5       0       5\nother-project    yellow    3       2       5\n```\n\nStatus is colored (green/yellow/red) when output is a TTY.\n\n### `cloche run`\n\nLaunch a workflow run.\n\n```\ncloche run --workflow <name> [--prompt \"...\"] [--keep-container]\n```\n\n| Flag | Description |\n|------|-------------|\n| `--workflow <name>` | Workflow name. Resolves to `.cloche/<name>.cloche` in the project directory. |\n| `--prompt \"...\"`, `-p` | Inline prompt written to `.cloche/<run-id>/prompt.txt` and injected into agent steps. |\n| `--keep-container` | Keep the Docker container even on success (default: remove on success). Failed runs always keep their container for debugging. |\n\nThe current working directory is used as the project directory. It must be\ninside a git repository (Cloche needs the repo root for result extraction\nvia git worktrees).\n\nWhen starting a run, the daemon checks whether the Docker image is up-to-date\nwith the project's `.cloche/Dockerfile`. If the Dockerfile has changed since\nthe last build (tracked via a SHA-256 label on the image), the daemon rebuilds\nthe image automatically before launching the container.\n\n### `cloche status`\n\nCheck the status of a run.\n\n```\ncloche status <run-id>\n```\n\nOutput includes the run state, active steps, and per-step results with timestamps.\n\n### `cloche list`\n\nList runs (last hour by default).\n\n```\ncloche list [--all]\n```\n\n| Flag | Description |\n|------|-------------|\n| `--all` | Show all runs, not just the last hour. |\n\nColumns: run ID, workflow name, state, container ID (if running), error message (if failed).\n\n### `cloche logs`\n\nShow logs for a run.\n\n```\ncloche logs <run-id> [--step <name>] [--type <full|script|llm>] [--follow]\n```\n\n| Flag | Description |\n|------|-------------|\n| `--step <name>` | Show only logs for the specified step. |\n| `--type <full\\|script\\|llm>` | Show only logs of the specified type (`full` = unified log, `script` = script output, `llm` = LLM conversation). |\n| `--follow`, `-f` | Stream live log lines via SSE. Color-coded by type: status (blue), LLM (green), script (default). Exits when the run completes. Connects to the daemon's HTTP endpoint (see `CLOCHE_HTTP` in Client Configuration). |\n\nWithout flags, shows the unified log (`full.log`) if available, otherwise streams\nstep start/completion events and run results.\nWith `--follow`, connects to the SSE endpoint and prints log lines in real-time.\n\n### `cloche poll`\n\nWait for a run to finish, printing progress updates.\n\n```\ncloche poll <run-id>\n```\n\nPolls every 2 seconds. Exits 0 on success, 1 on failure or if the container\ndies unexpectedly.\n\n### `cloche stop`\n\nCancel a running workflow.\n\n```\ncloche stop <run-id>\n```\n\n### `cloche delete`\n\nDelete a retained Docker container. Accepts either a Docker container name/ID\nor a Cloche run ID. If given a run ID, the daemon looks up the associated\ncontainer.\n\n```\ncloche delete <container-or-run-id>\n```\n\n### `cloche orchestrate`\n\nDispatch ready workflow runs for the current project. Checks the project's\nissue tracker for unclaimed tasks, generates prompts, and launches runs.\n\n```\ncloche orchestrate\n```\n\nUses the current working directory as the project directory. Prints \"No ready\nwork found.\" if there are no tasks to dispatch, or \"Dispatched N run(s).\"\nwith the count.\n\n### `cloche shutdown`\n\nShut down the daemon.\n\n```\ncloche shutdown\n```\n\n## Setting Up a New Project\n\n### 1. Scaffold the project\n\nRun `cloche init` from your project root to create the `.cloche/` directory with\ndefault workflow, Dockerfile, and prompt templates:\n\n```\ncd my-project\ncloche init\n```\n\nOr create the structure manually:\n\n### 2. Create a workflow file\n\nAdd `.cloche/<name>.cloche`:\n\n```\nworkflow \"develop\" {\n  step implement {\n    prompt = file(\".cloche/prompts/implement.md\")\n    results = [success, fail]\n  }\n\n  step test {\n    run = \"make test 2>&1\"\n    results = [success, fail]\n  }\n\n  step fix {\n    prompt = file(\".cloche/prompts/fix.md\")\n    max_attempts = \"2\"\n    results = [success, fail, give-up]\n  }\n\n  step update-docs {\n    prompt = file(\".cloche/prompts/update-docs.md\")\n    results = [success, fail]\n  }\n\n  implement:success -> test\n  implement:fail -> abort\n\n  test:success -> update-docs\n  test:fail -> fix\n\n  fix:success -> test\n  fix:fail -> abort\n  fix:give-up -> abort\n\n  update-docs:success -> done\n  update-docs:fail -> done\n}\n```\n\n### 3. Write prompt templates\n\nCreate `.cloche/prompts/` with markdown files:\n\n**`.cloche/prompts/implement.md`** — Instructions for the initial implementation:\n```markdown\nYou are working on a project. Implement the following change:\n\n## User Request\n(The user prompt is injected automatically by the agent adapter)\n\n## Guidelines\n- Follow existing project conventions\n- Write tests for new functionality\n- Run tests locally before declaring success\n```\n\n**`.cloche/prompts/fix.md`** — Instructions for fixing failures:\n```markdown\nThe previous attempt had failures. Review the output logs in .cloche/output/\nand fix the issues.\n\n## Guidelines\n- Read the test/lint output carefully\n- Fix the root cause, not the symptoms\n- Run tests again to verify your fix\n```\n\n**`.cloche/prompts/update-docs.md`** — Instructions for keeping docs in sync:\n```markdown\nReview the CLI source code and update usage documentation to reflect any changes.\n```\n\n### 4. Add overrides (optional)\n\nFiles in `.cloche/overrides/` are copied on top of `/workspace/` in the\ncontainer. Use this for container-specific configuration:\n\n```\n.cloche/overrides/\n  CLAUDE.md              # Container-specific CLAUDE.md (replaces host version)\n```\n\n### 5. Make sure your project builds in the container\n\nThe default Dockerfile generated by `cloche init` uses `ubuntu:24.04` as its\nbase image (configurable via `--image`). If your project needs different\ndependencies, edit `.cloche/Dockerfile`:\n\n```dockerfile\nFROM golang:1.25 AS builder\nWORKDIR /src\nCOPY go.mod go.sum ./\nRUN go mod download\nCOPY . .\nRUN CGO_ENABLED=0 go build -o /cloche-agent ./cmd/cloche-agent\n\nFROM ubuntu:24.04\nRUN apt-get update && apt-get install -y git <your-deps> && rm -rf /var/lib/apt/lists/*\nRUN npm install -g @anthropic-ai/claude-code\nCOPY --from=builder /cloche-agent /usr/local/bin/cloche-agent\nRUN useradd -m -s /bin/bash agent\nWORKDIR /workspace\nRUN chown agent:agent /workspace\nUSER agent\n```\n\nKey requirements for the image:\n- `cloche-agent` binary at `/usr/local/bin/cloche-agent`\n- `git` installed (for pushing results back)\n- An `agent` user (cloche wraps the command with `chown` + `su agent`)\n- `/workspace` as the working directory\n- Your project's build dependencies\n\nThe daemon automatically rebuilds the image when `.cloche/Dockerfile` changes\n(see `cloche run` above). To build manually:\n```\ndocker build -t my-project-agent -f .cloche/Dockerfile .\nCLOCHE_IMAGE=my-project-agent:latest bin/cloched\n```\n\n### 6. Run it\n\n```\ncd my-project\ncloche run --workflow develop --prompt \"Add feature X\"\n```\n\n## Writing Workflows\n\nWorkflow files use the `.cloche` extension and live in the `.cloche/` directory. See\n[workflows.md](workflows.md) for full DSL reference.\n\n### Step Types\n\n**Agent steps** (has `prompt`) — Invokes a coding agent autonomously:\n\n```\nstep implement {\n  prompt = file(\".cloche/prompts/implement.md\")\n  results = [success, fail]\n}\n```\n\n**Script steps** (has `run`) — Runs a shell command:\n\n```\nstep test {\n  run = \"make test 2>&1\"\n  results = [success, fail]\n}\n```\n\n### Wiring\n\nConnect steps with `step:result -> next_step`:\n\n```\nimplement:success -> test\nimplement:fail -> abort\ntest:success -> done\ntest:fail -> fix\n```\n\n`done` and `abort` are built-in terminals for success and failure.\n\n### Retry Loops\n\nWire failures back to earlier steps:\n\n```\ntest:fail -> fix\nfix:success -> test    // retry the test\nfix:fail -> abort\n```\n\n### Max Attempts\n\nLimit retries on agent steps. When exhausted, the step returns `give-up`:\n\n```\nstep fix {\n  prompt = file(\".cloche/prompts/fix.md\")\n  max_attempts = \"2\"\n  results = [success, fail, give-up]\n}\n```\n\n### Parallel Branches\n\nWire one result to multiple targets for concurrent execution:\n\n```\ntest:success -> lint\ntest:success -> quality\n```\n\n### Collect (Join)\n\nSynchronize parallel branches:\n\n```\ncollect all(lint:success, quality:success) -> done\n```\n\n`all` fires when every condition is met. `any` fires when at least one is.\n\n### Agent Command Override\n\nAgent steps use Claude Code by default. Override per-step:\n\n```\nstep implement {\n  prompt = \"...\"\n  agent_command = \"aider\"\n  results = [success, fail]\n}\n```\n\nOr at the workflow level via a `container` block:\n\n```\nworkflow \"develop\" {\n  container {\n    agent_command = \"gemini\"\n  }\n  ...\n}\n```\n\nOr globally via `CLOCHE_AGENT_COMMAND` environment variable.\n\nPriority (highest to lowest): step-level `agent_command`, workflow-level\n`container { agent_command }`, `CLOCHE_AGENT_COMMAND` env var, default (`claude`).\n\n### Agent Fallback Chains\n\nUse a comma-separated list in `agent_command` to configure fallback chains. If\nthe first agent errors without reporting a result, the system tries the next:\n\n```\nstep implement {\n  prompt = \"...\"\n  agent_command = \"claude,gemini,codex\"\n  results = [success, fail]\n}\n```\n\nFallback rules:\n- **Command not found or failed to start** — fall back to next command\n- **Exit non-zero without `CLOCHE_RESULT` marker** — fall back to next command\n- **Exit non-zero with `CLOCHE_RESULT` marker** — use that result (no fallback)\n- **Exit 0** — use result (no fallback)\n- **All commands fail to start** — step returns an error\n- **Last command crashes without marker** — step returns `fail`\n\nKnown agents have default arguments (e.g., Claude gets\n`-p --output-format text --dangerously-skip-permissions`). Other agents receive\nthe prompt on stdin with no extra flags. Override with `agent_args` at the step\nor workflow level.\n\n## Result Protocol\n\nSteps report results by writing a marker to stdout:\n\n```\nCLOCHE_RESULT:<name>\n```\n\nFor script steps, if no marker is written, the exit code determines the result:\n0 = `success`, non-zero = `fail`. Agent steps follow the same convention.\n\n## Prompt Assembly\n\nWhen an agent step runs, Cloche assembles a prompt from multiple sources:\n\n1. The step's `prompt` content (inline or from `file()`)\n2. The user prompt from `.cloche/<run-id>/prompt.txt` (set via `--prompt`)\n3. Validation output from `.cloche/<run-id>/output/*.log` (output from previous script steps)\n4. Result selection instructions listing the step's declared results\n\n## Project Directory Layout\n\n```\nmy-project/\n├── .cloche/\n│   ├── develop.cloche        # Workflow definition\n│   ├── Dockerfile            # Container image\n│   ├── config.toml           # Project configuration (orchestration, evolution)\n│   ├── prompts/\n│   │   ├── implement.md      # Prompt templates\n│   │   ├── fix.md\n│   │   └── update-docs.md\n│   ├── overrides/            # Files copied on top of /workspace/ in container\n│   │   └── CLAUDE.md         # Container-specific CLAUDE.md (optional)\n│   └── <run-id>/             # Runtime state (gitignored)\n│       ├── prompt.txt        # User prompt (from --prompt flag)\n│       ├── output/\n│       │   ├── full.log      # Unified chronological log (status + script + LLM)\n│       │   ├── test.log      # Per-step script output\n│       │   └── llm-impl.log  # Per-step LLM conversation output\n│       ├── attempt_count/\n│       │   └── fix           # Retry counter for max_attempts\n│       └── history.log       # Step execution log\n├── src/                      # Existing project source (untouched)\n├── CLAUDE.md                 # Host CLAUDE.md\n└── .git/\n```\n\n## Daemon Configuration\n\n| Variable | Default | Description |\n|----------|---------|-------------|\n| `CLOCHE_LISTEN` | `unix:///tmp/cloche.sock` | Listen address (unix socket or TCP) |\n| `CLOCHE_DB` | `cloche.db` | SQLite database path |\n| `CLOCHE_RUNTIME` | `docker` | `docker` (container) or `local` (subprocess, for dev) |\n| `CLOCHE_IMAGE` | `cloche-agent:latest` | Default Docker image |\n| `CLOCHE_HTTP` | — | HTTP address for the web dashboard. Not started unless set. |\n| `CLOCHE_AGENT_PATH` | (auto-detected) | Path to `cloche-agent` binary (local runtime) |\n| `CLOCHE_LLM_COMMAND` | — | Command for LLM calls — evolution and merge conflict resolution (e.g. `claude`) |\n| `ANTHROPIC_API_KEY` | — | Passed into Docker containers |\n| `CLOCHE_EXTRA_MOUNTS` | — | Extra bind mounts (comma-separated `host:container`) |\n| `CLOCHE_EXTRA_ENV` | — | Extra env vars (comma-separated `KEY=VALUE`) |\n\n### Client Configuration\n\n| Variable | Default | Description |\n|----------|---------|-------------|\n| `CLOCHE_ADDR` | `unix:///tmp/cloche.sock` | Daemon address (gRPC) |\n| `CLOCHE_HTTP` | `localhost:8080` | Daemon HTTP address (web dashboard, `cloche logs --follow`) |\n\n## Build Commands\n\n```\nmake build          # Build all binaries to bin/\nmake test           # Run all tests\nmake test-short     # Run tests (skip slow ones)\nmake lint           # Run go vet\nmake proto          # Regenerate gRPC code from protobuf\nmake docker-build   # Build the cloche-agent Docker image\nmake install        # Build, install to ~/.local/bin/, restart daemon\nmake clean          # Remove bin/\n```\n","numLines":623,"startLine":1,"totalLines":623}}}
