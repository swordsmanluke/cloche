 image has changed locally.\n    49→\tif baseStale, reason := isBaseImageStale(ctx, image, content); baseStale {\n    50→\t\tlog.Printf(\"image %s base image is stale (%s); rebuilding\", image, reason)\n    51→\t\treturn buildImage(ctx, projectDir, dockerfilePath, image, currentHash, content)\n    52→\t}\n    53→\n    54→\tlog.Printf(\"image %s is up-to-date (dockerfile hash %s)\", image, currentHash[:12])\n    55→\treturn nil\n    56→}\n    57→\n    58→// parseBaseImage extracts the base image reference from the final FROM directive\n    59→// in a Dockerfile. It handles \"FROM image:tag\" and \"FROM image:tag AS stage\".\n    60→// Returns an empty string if no FROM directive is found.\n    61→func parseBaseImage(dockerfileContent []byte) string {\n    62→\tvar lastFrom string\n    63→\tscanner := bufio.NewScanner(bytes.NewReader(dockerfileContent))\n    64→\tfor scanner.Scan() {\n    65→\t\tline := strings.TrimSpace(scanner.Text())\n    66→\t\tif line == \"\" || strings.HasPrefix(line, \"#\") {\n    67→\t\t\tcontinue\n    68→\t\t}\n    69→\t\tupper := strings.ToUpper(line)\n    70→\t\tif !strings.HasPrefix(upper, \"FROM \") {\n    71→\t\t\tcontinue\n    72→\t\t}\n    73→\t\t// Extract the image reference. Skip any --flag=value options\n    74→\t\t// (e.g. --platform=linux/amd64) that appear before the image.\n    75→\t\tfields := strings.Fields(line)\n    76→\t\tfor _, f := range fields[1:] {\n    77→\t\t\tif !strings.HasPrefix(f, \"--\") {\n    78→\t\t\t\tlastFrom = f\n    79→\t\t\t\tbreak\n    80→\t\t\t}\n    81→\t\t}\n    82→\t}\n    83→\treturn lastFrom\n    84→}\n    85→\n    86→// baseImageID returns the image ID of a locally available Docker image.\n    87→// Returns an error if the image is not available locally.\n    88→func baseImageID(ctx context.Context, image string) (string, error) {\n    89→\tcmd := exec.CommandContext(ctx, \"docker\", \"inspect\", \"--format\", \"{{.Id}}\", image)\n    90→\tvar stdout, stderr bytes.Buffer\n    91→\tcmd.Stdout = &s