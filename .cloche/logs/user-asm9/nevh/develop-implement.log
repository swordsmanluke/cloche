{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_011Rx6X8UNowcdwTU5eLbY5u","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_019ys3eSSyCkzwbd6toFBRFM","name":"Write","input":{"file_path":"/workspace/internal/adapters/docker/build.go","content":"package docker\n\nimport (\n\t\"bufio\"\n\t\"bytes\"\n\t\"context\"\n\t\"crypto/sha256\"\n\t\"encoding/hex\"\n\t\"fmt\"\n\t\"io\"\n\t\"log\"\n\t\"os\"\n\t\"os/exec\"\n\t\"path/filepath\"\n\t\"sort\"\n\t\"strings\"\n\t\"time\"\n)\n\nconst (\n\tdockerfileHashLabel  = \"cloche.dockerfile.hash\"\n\tbaseImageDigestLabel = \"cloche.baseimage.digest\"\n\tbasePullIntervalFile = \".cloche/.last-base-pull\"\n\tbasePullInterval     = 1 * time.Hour\n)\n\n// EnsureImage checks whether the Docker image is up-to-date with the project\n// Dockerfile, build context files (.cloche/overrides/), and base image. If the\n// image does not exist or any input has changed since the last build, it\n// rebuilds automatically.\nfunc (r *Runtime) EnsureImage(ctx context.Context, projectDir, image string) error {\n\tdockerfilePath := filepath.Join(projectDir, \".cloche\", \"Dockerfile\")\n\n\tcontent, err := os.ReadFile(dockerfilePath)\n\tif err != nil {\n\t\tif os.IsNotExist(err) {\n\t\t\t// No project Dockerfile — nothing to validate.\n\t\t\treturn nil\n\t\t}\n\t\treturn fmt.Errorf(\"reading Dockerfile: %w\", err)\n\t}\n\n\tcurrentHash := hashBuildContext(content, filepath.Join(projectDir, \".cloche\", \"overrides\"))\n\n\tstoredHash, hashErr := imageLabel(ctx, image, dockerfileHashLabel)\n\n\t// Check base image staleness (rate-limited pull).\n\tbaseStale := false\n\tbaseDigest := \"\"\n\tfromImage := parseFromImage(content)\n\tif fromImage != \"\" {\n\t\tbaseDigest, baseStale = checkBaseImageStaleness(ctx, projectDir, image, fromImage)\n\t}\n\n\tif hashErr == nil && storedHash == currentHash && !baseStale {\n\t\tlog.Printf(\"image %s is up-to-date (context hash %s)\", image, currentHash[:12])\n\t\treturn nil\n\t}\n\n\t// Image is missing or stale — rebuild.\n\tif hashErr != nil {\n\t\tlog.Printf(\"image %s not found or cannot inspect; building\", image)\n\t} else if baseStale {\n\t\tlog.Printf(\"image %s base image changed; rebuilding\", image)\n\t} else {\n\t\tlog.Printf(\"image %s is stale (have %s, want %s); rebuilding\", image, storedHash[:12], currentHash[:12])\n\t}\n\n\treturn buildImage(ctx, projectDir, dockerfilePath, image, currentHash, baseDigest)\n}\n\n// hashBuildContext produces a deterministic hash of the Dockerfile content and\n// all files in the overrides directory (sorted by path).\nfunc hashBuildContext(dockerfileContent []byte, overridesDir string) string {\n\th := sha256.New()\n\th.Write(dockerfileContent)\n\n\tentries, err := walkDirSorted(overridesDir)\n\tif err != nil {\n\t\t// No overrides dir or unreadable — hash only Dockerfile.\n\t\treturn hex.EncodeToString(h.Sum(nil))\n\t}\n\n\tfor _, e := range entries {\n\t\t// Include relative path in hash so renames are detected.\n\t\trel, _ := filepath.Rel(overridesDir, e)\n\t\th.Write([]byte(rel))\n\t\tdata, err := os.ReadFile(e)\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\th.Write(data)\n\t}\n\n\treturn hex.EncodeToString(h.Sum(nil))\n}\n\n// walkDirSorted returns all regular file paths under dir, sorted.\nfunc walkDirSorted(dir string) ([]string, error) {\n\tvar paths []string\n\terr := filepath.Walk(dir, func(path string, info os.FileInfo, err error) error {\n\t\tif err != nil {\n\t\t\treturn err\n\t\t}\n\t\tif !info.IsDir() {\n\t\t\tpaths = append(paths, path)\n\t\t}\n\t\treturn nil\n\t})\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\tsort.Strings(paths)\n\treturn paths, nil\n}\n\n// hashBytes returns the hex-encoded SHA-256 digest of data.\nfunc hashBytes(data []byte) string {\n\th := sha256.Sum256(data)\n\treturn hex.EncodeToString(h[:])\n}\n\n// parseFromImage extracts the base image from the first FROM instruction in a\n// Dockerfile. Returns \"\" if no FROM is found.\nfunc parseFromImage(dockerfile []byte) string {\n\tscanner := bufio.NewScanner(bytes.NewReader(dockerfile))\n\tfor scanner.Scan() {\n\t\tline := strings.TrimSpace(scanner.Text())\n\t\tif strings.HasPrefix(strings.ToUpper(line), \"FROM \") {\n\t\t\tparts := strings.Fields(line)\n\t\t\tif len(parts) >= 2 {\n\t\t\t\treturn parts[1]\n\t\t\t}\n\t\t}\n\t}\n\treturn \"\"\n}\n\n// checkBaseImageStaleness checks if the base image has been updated upstream.\n// It rate-limits pulls to at most once per basePullInterval by writing a\n// timestamp file. Returns the current digest and whether a rebuild is needed.\nfunc checkBaseImageStaleness(ctx context.Context, projectDir, builtImage, fromImage string) (digest string, stale bool) {\n\t// Rate-limit: check last pull timestamp.\n\ttsFile := filepath.Join(projectDir, basePullIntervalFile)\n\tif !shouldPullBase(tsFile) {\n\t\treturn \"\", false\n\t}\n\n\t// Pull the base image to get the latest digest.\n\tlog.Printf(\"pulling base image %s\", fromImage)\n\tpullCmd := exec.CommandContext(ctx, \"docker\", \"pull\", \"-q\", fromImage)\n\tpullCmd.Stdout = io.Discard\n\tpullCmd.Stderr = io.Discard\n\tif err := pullCmd.Run(); err != nil {\n\t\tlog.Printf(\"warning: failed to pull base image %s: %v\", fromImage, err)\n\t\treturn \"\", false\n\t}\n\n\t// Record pull timestamp.\n\t_ = os.MkdirAll(filepath.Dir(tsFile), 0755)\n\t_ = os.WriteFile(tsFile, []byte(time.Now().UTC().Format(time.RFC3339)), 0644)\n\n\t// Get digest of the pulled base image.\n\tcurrentDigest, err := imageDigest(ctx, fromImage)\n\tif err != nil {\n\t\treturn \"\", false\n\t}\n\n\t// Compare to stored digest on the built image.\n\tstoredDigest, err := imageLabel(ctx, builtImage, baseImageDigestLabel)\n\tif err != nil {\n\t\t// Built image doesn't exist or has no label — will rebuild anyway.\n\t\treturn currentDigest, false\n\t}\n\n\tif storedDigest != currentDigest {\n\t\treturn currentDigest, true\n\t}\n\treturn currentDigest, false\n}\n\n// shouldPullBase returns true if enough time has passed since the last pull.\nfunc shouldPullBase(tsFile string) bool {\n\tdata, err := os.ReadFile(tsFile)\n\tif err != nil {\n\t\treturn true // No file — pull.\n\t}\n\tt, err := time.Parse(time.RFC3339, strings.TrimSpace(string(data)))\n\tif err != nil {\n\t\treturn true\n\t}\n\treturn time.Since(t) >= basePullInterval\n}\n\n// imageDigest returns the repo digest of a local Docker image.\nfunc imageDigest(ctx context.Context, image string) (string, error) {\n\tcmd := exec.CommandContext(ctx, \"docker\", \"inspect\",\n\t\t\"--format\", \"{{index .RepoDigests 0}}\", image)\n\tvar stdout, stderr bytes.Buffer\n\tcmd.Stdout = &stdout\n\tcmd.Stderr = &stderr\n\tif err := cmd.Run(); err != nil {\n\t\treturn \"\", fmt.Errorf(\"getting digest for %s: %s: %w\", image, strings.TrimSpace(stderr.String()), err)\n\t}\n\tval := strings.TrimSpace(stdout.String())\n\tif val == \"\" || val == \"<no value>\" {\n\t\treturn \"\", fmt.Errorf(\"no digest for image %s\", image)\n\t}\n\treturn val, nil\n}\n\n// imageLabel retrieves a label value from a Docker image.\n// Returns an error if the image does not exist or cannot be inspected.\nfunc imageLabel(ctx context.Context, image, label string) (string, error) {\n\tcmd := exec.CommandContext(ctx, \"docker\", \"inspect\",\n\t\t\"--format\", fmt.Sprintf(\"{{index .Config.Labels %q}}\", label),\n\t\timage)\n\tvar stdout, stderr bytes.Buffer\n\tcmd.Stdout = &stdout\n\tcmd.Stderr = &stderr\n\tif err := cmd.Run(); err != nil {\n\t\treturn \"\", fmt.Errorf(\"inspecting image %s: %s: %w\", image, strings.TrimSpace(stderr.String()), err)\n\t}\n\tval := strings.TrimSpace(stdout.String())\n\tif val == \"\" || val == \"<no value>\" {\n\t\treturn \"\", fmt.Errorf(\"label %s not set on image %s\", label, image)\n\t}\n\treturn val, nil\n}\n\n// buildImage runs docker build for the project, tagging the result with the\n// given image name and embedding the context hash and base image digest as labels.\nfunc buildImage(ctx context.Context, projectDir, dockerfilePath, image, hash, baseDigest string) error {\n\tlog.Printf(\"building image %s from %s\", image, dockerfilePath)\n\n\targs := []string{\n\t\t\"build\",\n\t\t\"-t\", image,\n\t\t\"-f\", dockerfilePath,\n\t\t\"--label\", fmt.Sprintf(\"%s=%s\", dockerfileHashLabel, hash),\n\t}\n\n\tif baseDigest != \"\" {\n\t\targs = append(args, \"--label\", fmt.Sprintf(\"%s=%s\", baseImageDigestLabel, baseDigest))\n\t}\n\n\targs = append(args, projectDir)\n\n\tcmd := exec.CommandContext(ctx, \"docker\", args...)\n\tcmd.Stdout = os.Stderr // stream build output to daemon stderr\n\tcmd.Stderr = os.Stderr\n\tif err := cmd.Run(); err != nil {\n\t\treturn fmt.Errorf(\"building image %s: %w\", image, err)\n\t}\n\n\tlog.Printf(\"image %s built successfully\", image)\n\treturn nil\n}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":278,"cache_read_input_tokens":25484,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":278},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"e1df95e1-5a48-42ea-95bc-c2f753d81c51","uuid":"a42b9813-524a-4cc6-97b8-9ec329e5e3d5"}
