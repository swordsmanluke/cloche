ocker commands,\n\t// so we test its components individually.\n\n\tt.Run(\"shouldPullBase returns true for missing file\", func(t *testing.T) {\n\t\tassert.True(t, shouldPullBase(\"/nonexistent\"))\n\t})\n\n\tt.Run(\"shouldPullBase returns false for recent pull\", func(t *testing.T) {\n\t\tf := filepath.Join(t.TempDir(), \"ts\")\n\t\trequire.NoError(t, os.WriteFile(f, []byte(time.Now().UTC().Format(time.RFC3339)), 0644))\n\t\tassert.False(t, shouldPullBase(f))\n\t})\n}\n\nfunc TestEnsureImage_RebuildsWhenOverrideChanges(t *testing.T) {\n\tif err := exec.Command(\"docker\", \"info\").Run(); err != nil {\n\t\tt.Skip(\"Docker not available\")\n\t}\n\n\tdir := t.TempDir()\n\tclocheDir := filepath.Join(dir, \".cloche\")\n\toverridesDir := filepath.Join(clocheDir, \"overrides\")\n\trequire.NoError(t, os.MkdirAll(overridesDir, 0755))\n\n\tdockerfilePath := filepath.Join(clocheDir, \"Dockerfile\")\n\tdockerfile := []byte(\"FROM alpine:latest\\nRUN echo override-test\\n\")\n\trequire.NoError(t, os.WriteFile(dockerfilePath, dockerfile, 0644))\n\n\timage := \"cloche-test-override-rebuild:latest\"\n\texec.Command(\"docker\", \"rmi\", \"-f\", image).Run()\n\tdefer exec.Command(\"docker\", \"rmi\", \"-f\", image).Run()\n\n\trt := &Runtime{}\n\n\t// Build with no overrides.\n\terr := rt.EnsureImage(context.Background(), dir, image)\n\trequire.NoError(t, err)\n\n\tlabel1, err := imageLabel(context.Background(), image, dockerfileHashLabel)\n\trequire.NoError(t, err)\n\n\t// Add an override file.\n\trequire.NoError(t, os.WriteFile(filepath.Join(overridesDir, \"extra.conf\"), []byte(\"setting=1\"), 0644))\n\n\t// Should detect changed overrides and rebuild.\n\terr = rt.EnsureImage(context.Background(), dir, image)\n\trequire.NoError(t, err)\n\n\tlabel2, err := imageLabel(context.Background(), image, dockerfileHashLabel)\n\trequire.NoError(t, err)\n\tassert.NotEqual(t, label1, label2, \"label should change after adding an override file\")\n}\n","structuredPatch":[{"oldStart":6,"oldLine