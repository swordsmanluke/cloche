{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AueRHwwSBE5sot7JKTUZiu","type":"tool_result","content":"     1→package dsl\n     2→\n     3→import (\n     4→\t\"fmt\"\n     5→\t\"strconv\"\n     6→\t\"strings\"\n     7→\n     8→\t\"github.com/cloche-dev/cloche/internal/domain\"\n     9→)\n    10→\n    11→type Parser struct {\n    12→\tlexer    *Lexer\n    13→\tcurrent  Token\n    14→\tpeek     Token\n    15→\tlocation domain.WorkflowLocation\n    16→}\n    17→\n    18→// ParseOption configures the parser.\n    19→type ParseOption func(*Parser)\n    20→\n    21→// WithLocation sets the workflow location, enabling location-based validation.\n    22→func WithLocation(loc domain.WorkflowLocation) ParseOption {\n    23→\treturn func(p *Parser) {\n    24→\t\tp.location = loc\n    25→\t}\n    26→}\n    27→\n    28→func Parse(input string, opts ...ParseOption) (*domain.Workflow, error) {\n    29→\tp := &Parser{lexer: NewLexer(input)}\n    30→\tfor _, opt := range opts {\n    31→\t\topt(p)\n    32→\t}\n    33→\tp.advance() // load current\n    34→\tp.advance() // load peek\n    35→\treturn p.parseWorkflow()\n    36→}\n    37→\n    38→// ParseForHost parses a host.cloche file containing a single workflow.\n    39→func ParseForHost(input string) (*domain.Workflow, error) {\n    40→\treturn Parse(input, WithLocation(domain.LocationHost))\n    41→}\n    42→\n    43→// ParseAllForHost parses a host.cloche file that may contain multiple workflows.\n    44→// Returns a map of workflow name to workflow definition.\n    45→func ParseAllForHost(input string) (map[string]*domain.Workflow, error) {\n    46→\tp := &Parser{lexer: NewLexer(input), location: domain.LocationHost}\n    47→\tp.advance() // load current\n    48→\tp.advance() // load peek\n    49→\n    50→\tworkflows := make(map[string]*domain.Workflow)\n    51→\tfor p.current.Type != TokenEOF {\n    52→\t\twf, err := p.parseWorkflow()\n    53→\t\tif err != nil {\n    54→\t\t\treturn nil, err\n    55→\t\t}\n    56→\t\tif _, exists := workflows[wf.Name]; exists {\n    57→\t\t\treturn nil, fmt.Errorf(\"duplicate workflow name %q\", wf.Name)\n    58→\t\t}\n    59→\t\tworkflows[wf.Name] = wf\n    60→\t}\n    61→\n    62→\tif len(workflows) == 0 {\n    63→\t\treturn nil, fmt.Errorf(\"no workflows found in host.cloche\")\n    64→\t}\n    65→\n    66→\treturn workflows, nil\n    67→}\n    68→\n    69→// ParseForContainer parses a container workflow file.\n    70→func ParseForContainer(input string) (*domain.Workflow, error) {\n    71→\treturn Parse(input, WithLocation(domain.LocationContainer))\n    72→}\n    73→\n    74→// ParseAll parses a .cloche file that may contain multiple workflows.\n    75→// Workflows default to LocationContainer but a \"host { }\" block overrides\n    76→// the location to LocationHost, so any .cloche file can define host workflows.\n    77→func ParseAll(input string) (map[string]*domain.Workflow, error) {\n    78→\tp := &Parser{lexer: NewLexer(input), location: domain.LocationContainer}\n    79→\tp.advance() // load current\n    80→\tp.advance() // load peek\n    81→\n    82→\tworkflows := make(map[string]*domain.Workflow)\n    83→\tfor p.current.Type != TokenEOF {\n    84→\t\twf, err := p.parseWorkflow()\n    85→\t\tif err != nil {\n    86→\t\t\treturn nil, err\n    87→\t\t}\n    88→\t\tif _, exists := workflows[wf.Name]; exists {\n    89→\t\t\treturn nil, fmt.Errorf(\"duplicate workflow name %q\", wf.Name)\n    90→\t\t}\n    91→\t\tworkflows[wf.Name] = wf\n    92→\t}\n    93→\n    94→\tif len(workflows) == 0 {\n    95→\t\treturn nil, fmt.Errorf(\"no workflows found\")\n    96→\t}\n    97→\n    98→\treturn workflows, nil\n    99→}\n   100→\n   101→func (p *Parser) advance() {\n   102→\tp.current = p.peek\n   103→\tp.peek = p.lexer.NextToken()\n   104→}\n   105→\n   106→func (p *Parser) expect(typ TokenType) (Token, error) {\n   107→\tif p.current.Type != typ {\n   108→\t\treturn p.current, fmt.Errorf(\"line %d col %d: expected %v, got %v (%q)\",\n   109→\t\t\tp.current.Line, p.current.Col, typ, p.current.Type, p.current.Literal)\n   110→\t}\n   111→\ttok := p.current\n   112→\tp.advance()\n   113→\treturn tok, nil\n   114→}\n   115→\n   116→func (p *Parser) expectIdent(value string) (Token, error) {\n   117→\tif p.current.Type != TokenIdent || p.current.Literal != value {\n   118→\t\treturn p.current, fmt.Errorf(\"line %d col %d: expected %q, got %q\",\n   119→\t\t\tp.current.Line, p.current.Col, value, p.current.Literal)\n   120→\t}\n   121→\ttok := p.current\n   122→\tp.advance()\n   123→\treturn tok, nil\n   124→}\n   125→\n   126→func (p *Parser) parseWorkflow() (*domain.Workflow, error) {\n   127→\tif _, err := p.expectIdent(\"workflow\"); err != nil {\n   128→\t\treturn nil, err\n   129→\t}\n   130→\n   131→\tnameTok, err := p.expect(TokenString)\n   132→\tif err != nil {\n   133→\t\treturn nil, fmt.Errorf(\"expected workflow name string: %w\", err)\n   134→\t}\n   135→\n   136→\tif _, err := p.expect(TokenLBrace); err != nil {\n   137→\t\treturn nil, err\n   138→\t}\n   139→\n   140→\twf := &domain.Workflow{\n   141→\t\tName:     nameTok.Literal,\n   142→\t\tLocation: p.location,\n   143→\t\tSteps:    make(map[string]*domain.Step),\n   144→\t\tConfig:   make(map[string]string),\n   145→\t}\n   146→\n   147→\tfor p.current.Type != TokenRBrace && p.current.Type != TokenEOF {\n   148→\t\tif p.current.Type == TokenIdent && p.current.Literal == \"step\" {\n   149→\t\t\tstep, err := p.parseStep()\n   150→\t\t\tif err != nil {\n   151→\t\t\t\treturn nil, err\n   152→\t\t\t}\n   153→\t\t\twf.Steps[step.Name] = step\n   154→\t\t\tif wf.EntryStep == \"\" {\n   155→\t\t\t\twf.EntryStep = step.Name\n   156→\t\t\t}\n   157→\t\t} else if p.current.Type == TokenIdent && p.current.Literal == \"collect\" {\n   158→\t\t\tcollect, err := p.parseCollect()\n   159→\t\t\tif err != nil {\n   160→\t\t\t\treturn nil, err\n   161→\t\t\t}\n   162→\t\t\twf.Collects = append(wf.Collects, collect)\n   163→\t\t} else if p.current.Type == TokenIdent && p.peek.Type == TokenLBrace {\n   164→\t\t\tif err := p.parseWorkflowConfig(wf); err != nil {\n   165→\t\t\t\treturn nil, err\n   166→\t\t\t}\n   167→\t\t} else if p.current.Type == TokenIdent && p.peek.Type == TokenColon {\n   168→\t\t\twire, err := p.parseWire()\n   169→\t\t\tif err != nil {\n   170→\t\t\t\treturn nil, err\n   171→\t\t\t}\n   172→\t\t\twf.Wiring = append(wf.Wiring, wire)\n   173→\t\t} else {\n   174→\t\t\treturn nil, fmt.Errorf(\"line %d col %d: unexpected token %q\", p.current.Line, p.current.Col, p.current.Literal)\n   175→\t\t}\n   176→\t}\n   177→\n   178→\tif _, err := p.expect(TokenRBrace); err != nil {\n   179→\t\treturn nil, err\n   180→\t}\n   181→\n   182→\tif wf.Location != \"\" {\n   183→\t\tif err := wf.ValidateLocation(); err != nil {\n   184→\t\t\treturn nil, err\n   185→\t\t}\n   186→\t}\n   187→\n   188→\treturn wf, nil\n   189→}\n   190→\n   191→func (p *Parser) parseWorkflowConfig(wf *domain.Workflow) error {\n   192→\tprefix := p.current.Literal // e.g. \"host\", \"container\"\n   193→\tline, col := p.current.Line, p.current.Col\n   194→\tp.advance() // consume prefix ident\n   195→\n   196→\t// Reject conflicting location blocks.\n   197→\tif prefix == \"host\" && wf.Config[\"_location_block\"] == \"container\" {\n   198→\t\treturn fmt.Errorf(\"line %d col %d: workflow %q has both \\\"host\\\" and \\\"container\\\" blocks\", line, col, wf.Name)\n   199→\t}\n   200→\tif prefix == \"container\" && wf.Config[\"_location_block\"] == \"host\" {\n   201→\t\treturn fmt.Errorf(\"line %d col %d: workflow %q has both \\\"host\\\" and \\\"container\\\" blocks\", line, col, wf.Name)\n   202→\t}\n   203→\n   204→\t// A \"host { ... }\" block marks this workflow as a host workflow.\n   205→\tif prefix == \"host\" {\n   206→\t\twf.Location = domain.LocationHost\n   207→\t}\n   208→\tif prefix == \"host\" || prefix == \"container\" {\n   209→\t\twf.Config[\"_location_block\"] = prefix\n   210→\t}\n   211→\n   212→\tif _, err := p.expect(TokenLBrace); err != nil {\n   213→\t\treturn err\n   214→\t}\n   215→\n   216→\tfor p.current.Type != TokenRBrace && p.current.Type != TokenEOF {\n   217→\t\tkeyTok, err := p.expect(TokenIdent)\n   218→\t\tif err != nil {\n   219→\t\t\treturn fmt.Errorf(\"expected field name: %w\", err)\n   220→\t\t}\n   221→\n   222→\t\tif _, err := p.expect(TokenEquals); err != nil {\n   223→\t\t\treturn err\n   224→\t\t}\n   225→\n   226→\t\tval, err := p.parseValue()\n   227→\t\tif err != nil {\n   228→\t\t\treturn err\n   229→\t\t}\n   230→\n   231→\t\twf.Config[prefix+\".\"+keyTok.Literal] = val\n   232→\t}\n   233→\n   234→\tif _, err := p.expect(TokenRBrace); err != nil {\n   235→\t\treturn err\n   236→\t}\n   237→\n   238→\treturn nil\n   239→}\n   240→\n   241→func (p *Parser) parseStep() (*domain.Step, error) {\n   242→\tp.advance() // consume \"step\"\n   243→\n   244→\tnameTok, err := p.expect(TokenIdent)\n   245→\tif err != nil {\n   246→\t\treturn nil, fmt.Errorf(\"expected step name: %w\", err)\n   247→\t}\n   248→\n   249→\tif _, err := p.expect(TokenLBrace); err != nil {\n   250→\t\treturn nil, err\n   251→\t}\n   252→\n   253→\tstep := &domain.Step{\n   254→\t\tName:   nameTok.Literal,\n   255→\t\tConfig: make(map[string]string),\n   256→\t}\n   257→\n   258→\tfor p.current.Type != TokenRBrace && p.current.Type != TokenEOF {\n   259→\t\tif err := p.parseStepField(step, \"\"); err != nil {\n   260→\t\t\treturn nil, err\n   261→\t\t}\n   262→\t}\n   263→\n   264→\tif _, err := p.expect(TokenRBrace); err != nil {\n   265→\t\treturn nil, err\n   266→\t}\n   267→\n   268→\t// Infer step type from content\n   269→\t_, hasPrompt := step.Config[\"prompt\"]\n   270→\t_, hasRun := step.Config[\"run\"]\n   271→\t_, hasWorkflowName := step.Config[\"workflow_name\"]\n   272→\n   273→\tcount := 0\n   274→\tif hasPrompt {\n   275→\t\tcount++\n   276→\t}\n   277→\tif hasRun {\n   278→\t\tcount++\n   279→\t}\n   280→\tif hasWorkflowName {\n   281→\t\tcount++\n   282→\t}\n   283→\n   284→\tif count > 1 {\n   285→\t\treturn nil, fmt.Errorf(\"step %q has multiple of 'prompt', 'run', 'workflow_name'; must have exactly one\", step.Name)\n   286→\t}\n   287→\n   288→\tswitch {\n   289→\tcase hasPrompt:\n   290→\t\tstep.Type = domain.StepTypeAgent\n   291→\tcase hasRun:\n   292→\t\tstep.Type = domain.StepTypeScript\n   293→\tcase hasWorkflowName:\n   294→\t\tstep.Type = domain.StepTypeWorkflow\n   295→\tdefault:\n   296→\t\treturn nil, fmt.Errorf(\"step %q has none of 'prompt', 'run', or 'workflow_name'; must have exactly one\", step.Name)\n   297→\t}\n   298→\n   299→\treturn step, nil\n   300→}\n   301→\n   302→func (p *Parser) parseStepField(step *domain.Step, prefix string) error {\n   303→\tkeyTok, err := p.expect(TokenIdent)\n   304→\tif err != nil {\n   305→\t\treturn fmt.Errorf(\"expected field name: %w\", err)\n   306→\t}\n   307→\n   308→\tkey := keyTok.Literal\n   309→\tif prefix != \"\" {\n   310→\t\tkey = prefix + \".\" + key\n   311→\t}\n   312→\n   313→\t// Sub-block (e.g., container { ... })\n   314→\tif p.current.Type == TokenLBrace {\n   315→\t\tp.advance() // consume {\n   316→\t\tfor p.current.Type != TokenRBrace && p.current.Type != TokenEOF {\n   317→\t\t\tif err := p.parseStepField(step, key); err != nil {\n   318→\t\t\t\treturn err\n   319→\t\t\t}\n   320→\t\t}\n   321→\t\tp.advance() // consume }\n   322→\t\treturn nil\n   323→\t}\n   324→\n   325→\tif _, err := p.expect(TokenEquals); err != nil {\n   326→\t\treturn err\n   327→\t}\n   328→\n   329→\tif key == \"results\" {\n   330→\t\tresults, err := p.parseIdentList()\n   331→\t\tif err != nil {\n   332→\t\t\treturn err\n   333→\t\t}\n   334→\t\tstep.Results = results\n   335→\t} else if p.current.Type == TokenLBracket {\n   336→\t\tvalues, err := p.parseStringList()\n   337→\t\tif err != nil {\n   338→\t\t\treturn err\n   339→\t\t}\n   340→\t\tstep.Config[key] = strings.Join(values, \",\")\n   341→\t} else {\n   342→\t\tval, err := p.parseValue()\n   343→\t\tif err != nil {\n   344→\t\t\treturn err\n   345→\t\t}\n   346→\t\tstep.Config[key] = val\n   347→\t}\n   348→\n   349→\treturn nil\n   350→}\n   351→\n   352→func (p *Parser) parseIdentList() ([]string, error) {\n   353→\tif _, err := p.expect(TokenLBracket); err != nil {\n   354→\t\treturn nil, err\n   355→\t}\n   356→\n   357→\tvar items []string\n   358→\tfor p.current.Type != TokenRBracket && p.current.Type != TokenEOF {\n   359→\t\ttok, err := p.expect(TokenIdent)\n   360→\t\tif err != nil {\n   361→\t\t\treturn nil, err\n   362→\t\t}\n   363→\t\titems = append(items, tok.Literal)\n   364→\t\tif p.current.Type == TokenComma {\n   365→\t\t\tp.advance()\n   366→\t\t}\n   367→\t}\n   368→\n   369→\tif _, err := p.expect(TokenRBracket); err != nil {\n   370→\t\treturn nil, err\n   371→\t}\n   372→\n   373→\treturn items, nil\n   374→}\n   375→\n   376→func (p *Parser) parseStringList() ([]string, error) {\n   377→\tif _, err := p.expect(TokenLBracket); err != nil {\n   378→\t\treturn nil, err\n   379→\t}\n   380→\n   381→\tvar items []string\n   382→\tfor p.current.Type != TokenRBracket && p.current.Type != TokenEOF {\n   383→\t\ttok, err := p.expect(TokenString)\n   384→\t\tif err != nil {\n   385→\t\t\treturn nil, err\n   386→\t\t}\n   387→\t\titems = append(items, tok.Literal)\n   388→\t\tif p.current.Type == TokenComma {\n   389→\t\t\tp.advance()\n   390→\t\t}\n   391→\t}\n   392→\n   393→\tif _, err := p.expect(TokenRBracket); err != nil {\n   394→\t\treturn nil, err\n   395→\t}\n   396→\n   397→\treturn items, nil\n   398→}\n   399→\n   400→func (p *Parser) parseValue() (string, error) {\n   401→\tif p.current.Type == TokenString {\n   402→\t\ttok := p.current\n   403→\t\tp.advance()\n   404→\t\treturn tok.Literal, nil\n   405→\t}\n   406→\n   407→\tif p.current.Type == TokenIdent {\n   408→\t\tvar buf strings.Builder\n   409→\t\tbuf.WriteString(p.current.Literal)\n   410→\t\tp.advance()\n   411→\n   412→\t\t// Function call: file(\"...\")\n   413→\t\tif p.current.Type == TokenLParen {\n   414→\t\t\tbuf.WriteRune('(')\n   415→\t\t\tp.advance()\n   416→\t\t\tfor p.current.Type != TokenRParen && p.current.Type != TokenEOF {\n   417→\t\t\t\tif p.current.Type == TokenString {\n   418→\t\t\t\t\tbuf.WriteRune('\"')\n   419→\t\t\t\t\tbuf.WriteString(p.current.Literal)\n   420→\t\t\t\t\tbuf.WriteRune('\"')\n   421→\t\t\t\t} else {\n   422→\t\t\t\t\tbuf.WriteString(p.current.Literal)\n   423→\t\t\t\t}\n   424→\t\t\t\tp.advance()\n   425→\t\t\t}\n   426→\t\t\tbuf.WriteRune(')')\n   427→\t\t\tp.advance() // consume )\n   428→\t\t}\n   429→\n   430→\t\t// Dotted path: step.code.output\n   431→\t\tfor p.current.Type == TokenDot {\n   432→\t\t\tbuf.WriteRune('.')\n   433→\t\t\tp.advance()\n   434→\t\t\tif p.current.Type == TokenIdent {\n   435→\t\t\t\tbuf.WriteString(p.current.Literal)\n   436→\t\t\t\tp.advance()\n   437→\t\t\t}\n   438→\t\t}\n   439→\n   440→\t\treturn buf.String(), nil\n   441→\t}\n   442→\n   443→\treturn \"\", fmt.Errorf(\"line %d col %d: expected value, got %q\", p.current.Line, p.current.Col, p.current.Literal)\n   444→}\n   445→\n   446→func (p *Parser) parseWire() (domain.Wire, error) {\n   447→\tfromTok := p.current\n   448→\tp.advance()\n   449→\n   450→\tif _, err := p.expect(TokenColon); err != nil {\n   451→\t\treturn domain.Wire{}, err\n   452→\t}\n   453→\n   454→\tresultTok, err := p.expect(TokenIdent)\n   455→\tif err != nil {\n   456→\t\treturn domain.Wire{}, err\n   457→\t}\n   458→\n   459→\tif _, err := p.expect(TokenArrow); err != nil {\n   460→\t\treturn domain.Wire{}, err\n   461→\t}\n   462→\n   463→\ttoTok, err := p.expect(TokenIdent)\n   464→\tif err != nil {\n   465→\t\treturn domain.Wire{}, err\n   466→\t}\n   467→\n   468→\tvar mappings []domain.OutputMapping\n   469→\tif p.current.Type == TokenLBracket {\n   470→\t\tmappings, err = p.parseOutputMappings()\n   471→\t\tif err != nil {\n   472→\t\t\treturn domain.Wire{}, err\n   473→\t\t}\n   474→\t}\n   475→\n   476→\treturn d