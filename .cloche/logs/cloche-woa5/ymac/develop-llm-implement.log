{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SSTPNQoQ5H1dJ1KnwaBu65","type":"tool_result","content":"     1→package host\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"fmt\"\n     6→\t\"log\"\n     7→\t\"os\"\n     8→\t\"os/exec\"\n     9→\t\"path/filepath\"\n    10→\t\"strings\"\n    11→\t\"time\"\n    12→\n    13→\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    14→\t\"github.com/cloche-dev/cloche/internal/adapters/agents/prompt\"\n    15→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    16→\t\"github.com/cloche-dev/cloche/internal/engine\"\n    17→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    18→\t\"github.com/cloche-dev/cloche/internal/protocol\"\n    19→\t\"github.com/cloche-dev/cloche/internal/runcontext\"\n    20→)\n    21→\n    22→// resolveOutputMappings finds all wires targeting stepName that have output mappings,\n    23→// reads the source step's output, evaluates each mapping path, and returns KEY=value\n    24→// strings suitable for adding to a command's environment.\n    25→func (e *Executor) resolveOutputMappings(stepName string, wires []domain.Wire) ([]string, error) {\n    26→\tvar env []string\n    27→\tfor _, w := range wires {\n    28→\t\tif w.To != stepName || len(w.OutputMap) == 0 {\n    29→\t\t\tcontinue\n    30→\t\t}\n    31→\t\tdata, err := os.ReadFile(e.stepOutputPath(w.From))\n    32→\t\tif err != nil {\n    33→\t\t\treturn nil, fmt.Errorf(\"reading output of %s: %w\", w.From, err)\n    34→\t\t}\n    35→\t\tfor _, m := range w.OutputMap {\n    36→\t\t\tval, err := m.Path.Evaluate(data)\n    37→\t\t\tif err != nil {\n    38→\t\t\t\treturn nil, fmt.Errorf(\"mapping %s for step %s: %w\", m.EnvVar, stepName, err)\n    39→\t\t\t}\n    40→\t\t\tenv = append(env, m.EnvVar+\"=\"+val)\n    41→\t\t}\n    42→\t}\n    43→\treturn env, nil\n    44→}\n    45→\n    46→// RunDispatcher dispatches a container workflow run and returns the run ID.\n    47→type RunDispatcher interface {\n    48→\tRunWorkflow(ctx context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error)\n    49→}\n    50→\n    51→// Executor implements engine.StepExecutor for host workflow steps.\n    52→type Executor struct {\n    53→\tProjectDir    string\n    54→\tMainDir       string         // main branch worktree dir; scripts execute from here\n    55→\tDispatcher    RunDispatcher\n    56→\tStore         ports.RunStore\n    57→\tOutputDir     string         // directory for step output files\n    58→\tWires         []domain.Wire  // workflow wiring (for output mappings)\n    59→\tHostRunID     string         // ID of the parent host run (set on child runs)\n    60→\tAgentCommands []string       // workflow-level agent command fallback chain\n    61→\tAgentArgs     []string       // workflow-level explicit agent args (overrides defaults)\n    62→\tTaskID        string         // optional task ID assigned by the daemon loop\n    63→\tExtraEnv      []string       // additional KEY=VALUE env vars for all steps\n    64→\tResumeStep    string         // step being resumed (for prompt conversation resume)\n    65→}\n    66→\n    67→// scriptDir returns the directory from which scripts should execute.\n    68→// Uses MainDir if set, otherwise falls back to ProjectDir.\n    69→func (e *Executor) scriptDir() string {\n    70→\tif e.MainDir != \"\" {\n    71→\t\treturn e.MainDir\n    72→\t}\n    73→\treturn e.ProjectDir\n    74→}\n    75→\n    76→var _ engine.StepExecutor = (*Executor)(nil)\n    77→\n    78→// Execute runs a single host workflow step.\n    79→func (e *Executor) Execute(ctx context.Context, step *domain.Step) (string, error) {\n    80→\tswitch step.Type {\n    81→\tcase domain.StepTypeScript:\n    82→\t\treturn e.executeScript(ctx, step)\n    83→\tcase domain.StepTypeWorkflow:\n    84→\t\treturn e.executeWorkflow(ctx, step)\n    85→\tcase domain.StepTypeAgent:\n    86→\t\treturn e.executeAgent(ctx, step)\n    87→\tdefault:\n    88→\t\treturn \"\", fmt.Errorf(\"unsupported step type %q in host workflow\", step.Type)\n    89→\t}\n    90→}\n    91→\n    92→// executeScript runs a shell command on the host.\n    93→func (e *Executor) executeScript(ctx context.Context, step *domain.Step) (string, error) {\n    94→\tcmdStr := step.Config[\"run\"]\n    95→\tcmd := exec.CommandContext(ctx, \"sh\", \"-c\", cmdStr)\n    96→\tcmd.Dir = e.scriptDir()\n    97→\tcmd.Env = append(os.Environ(),\n    98→\t\t\"CLOCHE_PROJECT_DIR=\"+e.ProjectDir,\n    99→\t\t\"CLOCHE_STEP_OUTPUT=\"+e.stepOutputPath(step.Name),\n   100→\t)\n   101→\n   102→\t// Pass run ID so steps can access .cloche/<run-id>/ and context.json\n   103→\tif e.HostRunID != \"\" {\n   104→\t\tcmd.Env = append(cmd.Env, \"CLOCHE_RUN_ID=\"+e.HostRunID)\n   105→\t}\n   106→\n   107→\t// Pass daemon-assigned task ID if available\n   108→\tif e.TaskID != \"\" {\n   109→\t\tcmd.Env = append(cmd.Env, \"CLOCHE_TASK_ID=\"+e.TaskID)\n   110→\t}\n   111→\n   112→\t// Pass extra env vars (e.g. finalize phase outcome vars)\n   113→\tif len(e.ExtraEnv) > 0 {\n   114→\t\tcmd.Env = append(cmd.Env, e.ExtraEnv...)\n   115→\t}\n   116→\n   117→\t// Pass previous step output if available\n   118→\tif prevOutput := e.findPrevOutput(step); prevOutput != \"\" {\n   119→\t\tcmd.Env = append(cmd.Env, \"CLOCHE_PREV_OUTPUT=\"+prevOutput)\n   120→\t}\n   121→\n   122→\t// Resolve output mappings from wires and add as env vars\n   123→\tif len(e.Wires) > 0 {\n   124→\t\tmapped, err := e.resolveOutputMappings(step.Name, e.Wires)\n   125→\t\tif err != nil {\n   126→\t\t\treturn \"\", fmt.Errorf(\"resolving output mappings for step %q: %w\", step.Name, err)\n   127→\t\t}\n   128→\t\tcmd.Env = append(cmd.Env, mapped...)\n   129→\t}\n   130→\n   131→\toutput, err := cmd.CombinedOutput()\n   132→\n   133→\t// Extract result marker\n   134→\tmarkerResult, cleanOutput, found := protocol.ExtractResult(output)\n   135→\n   136→\t// Write output to file\n   137→\tif mkErr := os.MkdirAll(e.OutputDir, 0755); mkErr == nil {\n   138→\t\t_ = os.WriteFile(e.stepOutputPath(step.Name), cleanOutput, 0644)\n   139→\t}\n   140→\n   141→\tif err != nil {\n   142→\t\tif _, ok := err.(*exec.ExitError); ok {\n   143→\t\t\tresult := \"fail\"\n   144→\t\t\tif found {\n   145→\t\t\t\tresult = markerResult\n   146→\t\t\t}\n   147→\t\t\treturn result, nil\n   148→\t\t}\n   149→\t\treturn \"\", err\n   150→\t}\n   151→\n   152→\tresult := \"success\"\n   153→\tif found {\n   154→\t\tresult = markerResult\n   155→\t}\n   156→\treturn result, nil\n   157→}\n   158→\n   159→// executeWorkflow dispatches a container workflow run and blocks until it completes.\n   160→func (e *Executor) executeWorkflow(ctx context.Context, step *domain.Step) (string, error) {\n   161→\tworkflowName := step.Config[\"workflow_name\"]\n   162→\tif workflowName == \"\" {\n   163→\t\treturn \"\", fmt.Errorf(\"workflow step %q missing workflow_name\", step.Name)\n   164→\t}\n   165→\n   166→\t// Read prompt from previous step output or prompt_step override\n   167→\tvar promptContent string\n   168→\tpromptSource := step.Config[\"prompt_step\"]\n   169→\tif promptSource != \"\" {\n   170→\t\tdata, err := os.ReadFile(e.stepOutputPath(promptSource))\n   171→\t\tif err == nil {\n   172→\t\t\tpromptContent = string(data)\n   173→\t\t}\n   174→\t} else if prev := e.findPrevOutput(step); prev != \"\" {\n   175→\t\tdata, err := os.ReadFile(prev)\n   176→\t\tif err == nil {\n   177→\t\t\tpromptContent = string(data)\n   178→\t\t}\n   179→\t}\n   180→\n   181→\tresp, err := e.Dispatcher.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n   182→\t\tWorkflowName: workflowName,\n   183→\t\tProjectDir:   e.ProjectDir,\n   184→\t\tPrompt:       promptContent,\n   185→\t})\n   186→\tif err != nil {\n   187→\t\treturn \"\", fmt.Errorf(\"dispatching workflow %q: %w\", workflowName, err)\n   188→\t}\n   189→\n   190→\tlog.Printf(\"host executor: dispatched container workflow %q as run %s\", workflowName, resp.RunId)\n   191→\n   192→\t// Link child run to parent host run and store in run context\n   193→\tif e.HostRunID != \"\" {\n   194→\t\tif childRun, err := e.Store.GetRun(ctx, resp.RunId); err == nil {\n   195→\t\t\tchildRun.ParentRunID = e.HostRunID\n   196→\t\t\tchildRun.TaskID = e.TaskID\n   197→\t\t\t_ = e.Store.UpdateRun(ctx, childRun)\n   198→\t\t}\n   199→\t\t// Store child run ID in context so downstream steps can retrieve it\n   200→\t\t// via \"cloche get child_run_id\""}]},"parent_tool_use_id":"toolu_01DCUWZ1DtbXeq6Dw9EEqkBm","session_id":"4704652e-bf3d-4290-bbe9-3b856a038a11","uuid":"76567e52-ddde-4e18-86e3-cdb161091138"}
