{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SBSjGMCQt4jHftaUT6wun5","type":"tool_result","content":"     1→package prompt\n     2→\n     3→import (\n     4→\t\"bufio\"\n     5→\t\"bytes\"\n     6→\t\"context\"\n     7→\t\"encoding/json\"\n     8→\t\"fmt\"\n     9→\t\"os\"\n    10→\t\"os/exec\"\n    11→\t\"path/filepath\"\n    12→\t\"strconv\"\n    13→\t\"strings\"\n    14→\n    15→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    16→\t\"github.com/cloche-dev/cloche/internal/protocol\"\n    17→)\n    18→\n    19→// defaultAgentArgs maps known agent commands to their default arguments.\n    20→// Commands not in this map receive no default arguments (prompt on stdin only).\n    21→var defaultAgentArgs = map[string][]string{\n    22→\t\"claude\": {\"-p\", \"--output-format\", \"stream-json\", \"--verbose\", \"--dangerously-skip-permissions\"},\n    23→}\n    24→\n    25→type Adapter struct {\n    26→\tCommands           []string // ordered fallback chain of agent commands\n    27→\tExplicitArgs       []string // if non-nil, overrides default args for all commands\n    28→\tRunID              string\n    29→\tStatusWriter       *protocol.StatusWriter // optional: streams live output lines\n    30→\tResumeConversation bool                   // when true, resume previous conversation instead of starting new one\n    31→}\n    32→\n    33→func New() *Adapter {\n    34→\treturn &Adapter{\n    35→\t\tCommands: []string{\"claude\"},\n    36→\t}\n    37→}\n    38→\n    39→func (a *Adapter) Name() string {\n    40→\treturn \"prompt\"\n    41→}\n    42→\n    43→// argsFor returns the arguments for the given command. If ExplicitArgs is set,\n    44→// it is used for all commands. Otherwise, known agents get their default args.\n    45→func (a *Adapter) argsFor(command string) []string {\n    46→\tif a.ExplicitArgs != nil {\n    47→\t\treturn a.ExplicitArgs\n    48→\t}\n    49→\tif args, ok := defaultAgentArgs[command]; ok {\n    50→\t\treturn args\n    51→\t}\n    52→\treturn nil\n    53→}\n    54→\n    55→// ParseCommands splits a comma-separated agent_command string into individual\n    56→// command names, trimming whitespace from each entry.\n    57→func ParseCommands(s string) []string {\n    58→\tparts := strings.Split(s, \",\")\n    59→\tvar cmds []string\n    60→\tfor _, p := range parts {\n    61→\t\tp = strings.TrimSpace(p)\n    62→\t\tif p != \"\" {\n    63→\t\t\tcmds = append(cmds, p)\n    64→\t\t}\n    65→\t}\n    66→\treturn cmds\n    67→}\n    68→\n    69→func (a *Adapter) Execute(ctx context.Context, step *domain.Step, workDir string) (string, error) {\n    70→\t// Check attempt count for retry limiting\n    71→\tif maxStr, ok := step.Config[\"max_attempts\"]; ok {\n    72→\t\tmax, err := strconv.Atoi(maxStr)\n    73→\t\tif err == nil {\n    74→\t\t\tcount := readAttemptCount(workDir, step.Name)\n    75→\t\t\tif count >= max {\n    76→\t\t\t\treturn \"give-up\", nil\n    77→\t\t\t}\n    78→\t\t}\n    79→\t}\n    80→\tincrementAttemptCount(workDir, step.Name)\n    81→\n    82→\t// Build the full prompt\n    83→\tvar fullPrompt string\n    84→\tif a.ResumeConversation {\n    85→\t\tfullPrompt = \"retry\"\n    86→\t} else {\n    87→\t\tvar err error\n    88→\t\tfullPrompt, err = assemblePrompt(step, workDir, a.RunID)\n    89→\t\tif err != nil {\n    90→\t\t\treturn \"\", fmt.Errorf(\"assembling prompt: %w\", err)\n    91→\t\t}\n    92→\t}\n    93→\n    94→\t// Try each command in the fallback chain\n    95→\tvar lastResult string\n    96→\tvar lastStdout []byte\n    97→\tvar lastErr error\n    98→\tran := false\n    99→\n   100→\tfor _, command := range a.Commands {\n   101→\t\tresult, stdout, fallbackErr := a.tryCommand(ctx, command, fullPrompt, workDir, step.Name)\n   102→\t\tlastResult = result\n   103→\t\tlastStdout = stdout\n   104→\t\tlastErr = fallbackErr\n   105→\n   106→\t\tif fallbackErr == nil {\n   107→\t\t\t// Definitive result — agent completed (exit 0 or exit non-zero with marker)\n   108→\t\t\tbreak\n   109→\t\t}\n   110→\t\tif stdout != nil {\n   111→\t\t\tran = true\n   112→\t\t}\n   113→\t\t// Fallback-eligible — try next command\n   114→\t}\n   115→\n   116→\tif lastErr != nil && !ran && lastStdout == nil {\n   117→\t\t// All commands failed to produce any output (e.g., all not found)\n   118→\t\treturn \"\", lastErr\n   119→\t}\n   120→\n   121→\tresult := lastResult\n   122→\tif lastErr != nil {\n   123→\t\t// Last command in chain crashed without a result marker\n   124→\t\tresult = \"fail\"\n   125→\t}\n   126→\n   127→\t// Reset attempt counter on success so give-up only triggers after\n   128→\t// consecutive failures, not after successful fixes whose downstream\n   129→\t// tests fail for unrelated reasons.\n   130→\tif result == \"success\" {\n   131→\t\tresetAttemptCount(workDir, step.Name)\n   132→\t}\n   133→\n   134→\t// Write output file\n   135→\toutputDir := filepath.Join(workDir, \".cloche\", \"output\")\n   136→\tif mkErr := os.MkdirAll(outputDir, 0755); mkErr == nil {\n   137→\t\t_ = os.WriteFile(filepath.Join(outputDir, step.Name+\".log\"), lastStdout, 0644)\n   138→\t}\n   139→\tprotocol.AppendHistory(workDir, step.Name, result, true, nil)\n   140→\treturn result, nil\n   141→}\n   142→\n   143→// tryCommand executes a single agent command and returns:\n   144→//   - result: the step result name (e.g. \"success\", \"fail\")\n   145→//   - stdout: captured stdout bytes\n   146→//   - fallbackErr: nil if the result is definitive, non-nil if fallback-eligible\n   147→//\n   148→// Fallback-eligible conditions:\n   149→//   - Command not found or failed to start (stdout will be nil)\n   150→//   - Command exited non-zero without a CLOCHE_RESULT marker\n   151→//\n   152→// Definitive (non-fallback) conditions:\n   153→//   - Command exited 0\n   154→//   - Command exited non-zero but produced a CLOCHE_RESULT marker\n   155→func (a *Adapter) tryCommand(ctx context.Context, command string, prompt string, workDir string, stepName string) (result string, stdout []byte, fallbackErr error) {\n   156→\targs := a.argsFor(command)\n   157→\t// Resume mode: add -c flag to resume previous conversation\n   158→\tif a.ResumeConversation {\n   159→\t\targs = append([]string{\"-c\"}, args...)\n   160→\t}\n   161→\tcmd := exec.CommandContext(ctx, command, args...)\n   162→\tcmd.Dir = workDir\n   163→\tcmd.Stdin = strings.NewReader(prompt)\n   164→\n   165→\t// If we have a StatusWriter, stream stdout line-by-line; otherwise buffer.\n   166→\tif a.StatusWriter == nil {\n   167→\t\tvar stdoutBuf, stderrBuf bytes.Buffer\n   168→\t\tcmd.Stdout = &stdoutBuf\n   169→\t\tcmd.Stderr = &stderrBuf\n   170→\n   171→\t\trunErr := cmd.Run()\n   172→\t\tstdoutBytes := stdoutBuf.Bytes()\n   173→\t\treturn a.classifyResult(command, stdoutBytes, runErr)\n   174→\t}\n   175→\n   176→\t// Streaming path: pipe stdout through a scanner so we can emit lines live.\n   177→\tpipe, err := cmd.StdoutPipe()\n   178→\tif err != nil {\n   179→\t\treturn \"\", nil, fmt.Errorf(\"command %q stdout pipe: %w\", command, err)\n   180→\t}\n   181→\tcmd.Stderr = nil // discard stderr\n   182→\n   183→\tif err := cmd.Start(); err != nil {\n   184→\t\treturn \"\", nil, fmt.Errorf(\"command %q failed to start: %w\", command, err)\n   185→\t}\n   186→\n   187→\t// textBuf accumulates extracted text content for result extraction.\n   188→\t// rawBuf accumulates raw stdout for the output log file.\n   189→\tvar textBuf, rawBuf bytes.Buffer\n   190→\t// lineBuf accumulates text deltas into lines for streaming.\n   191→\tvar lineBuf strings.Builder\n   192→\n   193→\tscanner := bufio.NewScanner(pipe)\n   194→\tscanner.Buffer(make([]byte, 0, 256*1024), 1024*1024)\n   195→\tfor scanner.Scan() {\n   196→\t\traw := scanner.Bytes()\n   197→\t\trawBuf.Write(raw)\n   198→\t\trawBuf.WriteByte('\\n')\n   199→\n   200→\t\ttext := extractStreamText(raw)"}]},"parent_tool_use_id":"toolu_01DCUWZ1DtbXeq6Dw9EEqkBm","session_id":"4704652e-bf3d-4290-bbe9-