}, fmt.Errorf(\"expected field name after '.': %w\", err)\n   536→\t\t\t}\n   537→\t\t\tsegments = append(segments, domain.PathSegment{Kind: domain.SegmentField, Field: fieldTok.Literal})\n   538→\t\t} else if p.current.Type == TokenLBracket {\n   539→\t\t\tp.advance() // consume \"[\"\n   540→\t\t\tidxTok, err := p.expect(TokenInt)\n   541→\t\t\tif err != nil {\n   542→\t\t\t\treturn domain.OutputPath{}, fmt.Errorf(\"expected integer index: %w\", err)\n   543→\t\t\t}\n   544→\t\t\tidx, _ := strconv.Atoi(idxTok.Literal)\n   545→\t\t\tif _, err := p.expect(TokenRBracket); err != nil {\n   546→\t\t\t\treturn domain.OutputPath{}, err\n   547→\t\t\t}\n   548→\t\t\tsegments = append(segments, domain.PathSegment{Kind: domain.SegmentIndex, Index: idx})\n   549→\t\t} else {\n   550→\t\t\tbreak\n   551→\t\t}\n   552→\t}\n   553→\n   554→\treturn domain.OutputPath{Segments: segments}, nil\n   555→}\n   556→\n   557→func (p *Parser) parseCollect() (domain.Collect, error) {\n   558→\tp.advance() // consume \"collect\"\n   559→\n   560→\tmodeTok, err := p.expect(TokenIdent)\n   561→\tif err != nil {\n   562→\t\treturn domain.Collect{}, fmt.Errorf(\"expected 'all' or 'any': %w\", err)\n   563→\t}\n   564→\n   565→\tvar mode domain.CollectMode\n   566→\tswitch modeTok.Literal {\n   567→\tcase \"all\":\n   568→\t\tmode = domain.CollectAll\n   569→\tcase \"any\":\n   570→\t\tmode = domain.CollectAny\n   571→\tdefault:\n   572→\t\treturn domain.Collect{}, fmt.Errorf(\"line %d col %d: expected 'all' or 'any', got %q\",\n   573→\t\t\tmodeTok.Line, modeTok.Col, modeTok.Literal)\n   574→\t}\n   575→\n   576→\tif _, err := p.expect(TokenLParen); err != nil {\n   577→\t\treturn domain.Collect{}, err\n   578→\t}\n   579→\n   580→\tvar conditions []domain.WireCondition\n   581→\tfor p.current.Type != TokenRParen && p.current.Type != TokenEOF {\n   582→\t\tstepTok, err := p.expect(TokenIdent)\n   583→\t\tif err != nil {\n   584→\t\t\treturn domain.Collect{}, fmt.Errorf(\"expected step name in