ted);font-size:0.85rem\">No content</p>';\n                    }\n                    if (pf.history && pf.history.length > 0) {\n                        html += '<details style=\"margin:0.25rem 0\"><summary style=\"font-size:0.85rem;color:var(--text-muted);cursor:pointer\">History (' + pf.history.length + ' commits)</summary>';\n                        html += '<div style=\"margin:0.5rem 0\">';\n                        pf.history.forEach(function(h) {\n                            html += '<div class=\"prompt-commit\" data-file=\"' + pf.path + '\" data-sha=\"' + h.sha + '\" onclick=\"toggleDiff(this)\" style=\"cursor:pointer;padding:0.25rem 0;font-size:0.85rem\">';\n                            html += '<span class=\"mono\" style=\"color:var(--link)\">' + h.sha + '</span> ';\n                            html += '<span style=\"color:var(--text-muted)\">' + h.date + '</span> ';\n                            html += h.message;\n                            html += '</div>';\n                        });\n                        html += '</div></details>';\n                    }\n                    html += '</details>';"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":348,"cache_read_input_tokens":17190,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":348},"output_tokens":6,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"fc3b4be9-dd65-41ee-b4f5-ecd52ac62138","uuid":"2a926a06-90b6-470f-8ac0-e99991e221b2"}
