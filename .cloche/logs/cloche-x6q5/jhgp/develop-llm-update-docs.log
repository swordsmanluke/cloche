{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RvueJutSBzZ45zMnzswB7o","type":"tool_result","content":"     1→package main\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"encoding/json\"\n     6→\t\"errors\"\n     7→\t\"fmt\"\n     8→\t\"io\"\n     9→\t\"net/http\"\n    10→\t\"os\"\n    11→\t\"os/exec\"\n    12→\t\"path/filepath\"\n    13→\t\"strconv\"\n    14→\t\"strings\"\n    15→\t\"text/tabwriter\"\n    16→\t\"time\"\n    17→\n    18→\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    19→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    20→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    21→\t\"github.com/cloche-dev/cloche/internal/runcontext\"\n    22→\t\"github.com/cloche-dev/cloche/internal/version\"\n    23→\t\"google.golang.org/grpc\"\n    24→\t\"google.golang.org/grpc/credentials/insecure\"\n    25→\t\"google.golang.org/grpc/metadata\"\n    26→)\n    27→\n    28→func main() {\n    29→\tif len(os.Args) < 2 {\n    30→\t\tprintTopLevelHelp()\n    31→\t\tos.Exit(1)\n    32→\t}\n    33→\n    34→\t// Handle version flags before anything else\n    35→\tif os.Args[1] == \"-v\" || os.Args[1] == \"--version\" {\n    36→\t\tcmdVersion()\n    37→\t\treturn\n    38→\t}\n    39→\n    40→\t// Handle top-level help: \"cloche help\", \"cloche --help\", \"cloche -h\"\n    41→\tswitch os.Args[1] {\n    42→\tcase \"help\":\n    43→\t\tprintHelp(os.Args[2:])\n    44→\t\treturn\n    45→\tcase \"--help\", \"-h\":\n    46→\t\tprintTopLevelHelp()\n    47→\t\treturn\n    48→\t}\n    49→\n    50→\t// Commands that don't need a daemon connection\n    51→\tswitch os.Args[1] {\n    52→\tcase \"init\":\n    53→\t\tif hasHelpFlag(os.Args[2:]) {\n    54→\t\t\tprintSubcommandHelp(\"init\")\n    55→\t\t\treturn\n    56→\t\t}\n    57→\t\tcmdInit(os.Args[2:])\n    58→\t\treturn\n    59→\tcase \"health\":\n    60→\t\tif hasHelpFlag(os.Args[2:]) {\n    61→\t\t\tprintSubcommandHelp(\"health\")\n    62→\t\t\treturn\n    63→\t\t}\n    64→\t\tcmdHealth(os.Args[2:])\n    65→\t\treturn\n    66→\tcase \"get\":\n    67→\t\tif hasHelpFlag(os.Args[2:]) {\n    68→\t\t\tprintSubcommandHelp(\"get\")\n    69→\t\t\treturn\n    70→\t\t}\n    71→\t\tcmdGet(os.Args[2:])\n    72→\t\treturn\n    73→\tcase \"set\":\n    74→\t\tif hasHelpFlag(os.Args[2:]) {\n    75→\t\t\tprintSubcommandHelp(\"set\")\n    76→\t\t\treturn\n    77→\t\t}\n    78→\t\tcmdSet(os.Args[2:])\n    79→\t\treturn\n    80→\tcase \"tasks\":\n    81→\t\tif hasHelpFlag(os.Args[2:]) {\n    82→\t\t\tprintSubcommandHelp(\"tasks\")\n    83→\t\t\treturn\n    84→\t\t}\n    85→\t\tcmdTasks(os.Args[2:])\n    86→\t\treturn\n    87→\tcase \"workflow\":\n    88→\t\tif hasHelpFlag(os.Args[2:]) {\n    89→\t\t\tprintSubcommandHelp(\"workflow\")\n    90→\t\t\treturn\n    91→\t\t}\n    92→\t\tcmdWorkflow(os.Args[2:])\n    93→\t\treturn\n    94→\tcase \"project\":\n    95→\t\tif hasHelpFlag(os.Args[2:]) {\n    96→\t\t\tprintSubcommandHelp(\"project\")\n    97→\t\t\treturn\n    98→\t\t}\n    99→\t\tcmdProject(os.Args[2:])\n   100→\t\treturn\n   101→\tcase \"validate\":\n   102→\t\tif hasHelpFlag(os.Args[2:]) {\n   103→\t\t\tprintSubcommandHelp(\"validate\")\n   104→\t\t\treturn\n   105→\t\t}\n   106→\t\tcmdValidate(os.Args[2:])\n   107→\t\treturn\n   108→\t}\n   109→\n   110→\t// Handle --help for daemon commands before connecting\n   111→\tdaemonCmds := map[string]bool{\n   112→\t\t\"run\": true, \"status\": true, \"logs\": true, \"poll\": true,\n   113→\t\t\"list\": true, \"stop\": true, \"delete\": true, \"loop\": true, \"shutdown\": true,\n   114→\t}\n   115→\tif daemonCmds[os.Args[1]] && hasHelpFlag(os.Args[2:]) {\n   116→\t\tprintSubcommandHelp(os.Args[1])\n   117→\t\treturn\n   118→\t}\n   119→\n   120→\t// Commands that need a daemon connection\n   121→\taddr := os.Getenv(\"CLOCHE_ADDR\")\n   122→\tif addr == \"\" {\n   123→\t\taddr = \"unix:///tmp/cloche.sock\"\n   124→\t}\n   125→\n   126→\tconn, err := grpc.NewClient(addr, grpc.WithTransportCredentials(insecure.NewCredentials()))\n   127→\tif err != nil {\n   128→\t\tfmt.Fprintf(os.Stderr, \"failed to connect: %v\\n\", err)\n   129→\t\tos.Exit(1)\n   130→\t}\n   131→\tdefer conn.Close()\n   132→\n   133→\tclient := pb.NewClocheServiceClient(conn)\n   134→\tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n   135→\tdefer cancel()\n   136→\n   137→\tswitch os.Args[1] {\n   138→\tcase \"run\":\n   139→\t\tcmdRun(ctx, client, os.Args[2:])\n   140→\tcase \"status\":\n   141→\t\tcmdStatus(ctx, client, os.Args[2:])\n   142→\tcase \"logs\":\n   143→\t\tcmdLogs(client, os.Args[2:])\n   144→\tcase \"poll\":\n   145→\t\tcmdPoll(client, os.Args[2:])\n   146→\tcase \"list\":\n   147→\t\tcmdList(ctx, client, os.Args[2:])\n   148→\tcase \"stop\":\n   149→\t\tcmdStop(ctx, client, os.Args[2:])\n   150→\tcase \"delete\":\n   151→\t\tcmdDelete(ctx, client, os.Args[2:])\n   152→\tcase \"loop\":\n   153→\t\tcmdLoop(ctx, client, os.Args[2:])\n   154→\tcase \"shutdown\":\n   155→\t\tcmdShutdown(ctx, client, os.Args[2:])\n   156→\tdefault:\n   157→\t\tfmt.Fprintf(os.Stderr, \"unknown command: %s\\n\\n\", os.Args[1])\n   158→\t\tprintTopLevelHelp()\n   159→\t\tos.Exit(1)\n   160→\t}\n   161→}\n   162→\n   163→\n   164→func cmdRun(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   165→\tvar workflow, prompt, title, issueID string\n   166→\tvar keepContainer bool\n   167→\n   168→\tfor i := 0; i < len(args); i++ {\n   169→\t\tswitch args[i] {\n   170→\t\tcase \"--workflow\":\n   171→\t\t\tif i+1 < len(args) {\n   172→\t\t\t\ti++\n   173→\t\t\t\tworkflow = args[i]\n   174→\t\t\t}\n   175→\t\tcase \"--prompt\", \"-p\":\n   176→\t\t\tif i+1 < len(args) {\n   177→\t\t\t\ti++\n   178→\t\t\t\tprompt = args[i]\n   179→\t\t\t}\n   180→\t\tcase \"--title\":\n   181→\t\t\tif i+1 < len(args) {\n   182→\t\t\t\ti++\n   183→\t\t\t\ttitle = args[i]\n   184→\t\t\t}\n   185→\t\tcase \"--issue\", \"-i\":\n   186→\t\t\tif i+1 < len(args) {\n   187→\t\t\t\ti++\n   188→\t\t\t\tissueID = args[i]\n   189→\t\t\t}\n   190→\t\tcase \"--keep-container\":\n   191→\t\t\tkeepContainer = true\n   192→\t\tdefault:\n   193→\t\t\t// Support bare positional arg as workflow name for backwards compat\n   194→\t\t\tif workflow == \"\" && !strings.HasPrefix(args[i], \"-\") {\n   195→\t\t\t\tworkflow = args[i]\n   196→\t\t\t}\n   197→\t\t}\n   198→\t}\n   199→\n   200→\tif workflow == \"\" {\n   201→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche run --workflow <name> [--prompt \\\"...\\\"] [--title \\\"...\\\"] [--issue ID]\\n\")\n   202→\t\tos.Exit(1)\n   203→\t}\n   204→\n   205→\tcwd, _ := os.Getwd()\n   206→\n   207→\t// Resolve image from workflow file (soft failure — fall back to daemon default).\n   208→\t// Try loading from any .cloche file; only extract image for container workflows.\n   209→\tvar image string\n   210→\tif wf, err := loadWorkflow(cwd, workflow); err == nil && wf.Location == domain.LocationContainer {\n   211→\t\timage = wf.Config[\"container.image\"]\n   212→\t}\n   213→\n   214→\tresp, err := client.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n   215→\t\tWorkflowName:  workflow,\n   216→\t\tProjectDir:    cwd,\n   217→\t\tImage:         image,\n   218→\t\tPrompt:        prompt,\n   219→\t\tKeepContainer: keepContainer,\n   220→\t\tTitle:         title,\n   221→\t\tIssueId:       issueID,\n   222→\t})\n   223→\tif err != nil {\n   224→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   225→\t\tos.Exit(1)\n   226→\t}\n   227→\tfmt.Printf(\"Started run: %s\\n\", resp.RunId)\n   228→}\n   229→\n   230→func cmdStatus(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   231→\tif len(args) < 1 {\n   232→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche status <run-id>\\n\")\n   233→\t\tos.Exit(1)\n   234→\t}\n   235→\n   236→\tresp, err := client.GetStatus(ctx, &pb.GetStatusRequest{RunId: args[0]})\n   237→\tif err != nil {\n   238→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   239→\t\tos.Exit(1)\n   240→\t}\n   241→\n   242→\tfmt.Printf(\"Run:       %s\\n\", resp.RunId)\n   243→\tif resp.Title != \"\" {\n   244→\t\tfmt.Printf(\"Title:     %s\\n\", resp.Title)\n   245→\t}\n   246→\tfmt.Printf(\"Workflow:  %s\\n\", resp.WorkflowName)\n   247→\tif resp.IsHost {\n   248→\t\tfmt.Printf(\"Type:      host\\n\")\n   249→\t} else {\n   250→\t\tfmt.Printf(\"Type:      container\\n\")\n   251→\t}\n   252→\tfmt.Printf(\"State:     %s\\n\", resp.State)\n   253→\tif resp.ContainerId != \"\" {\n   254→\t\tcid := resp.ContainerId\n   255→\t\tif len(cid) > 12 {\n   256→\t\t\tcid = cid[:12]\n   257→\t\t}\n   258→\t\tfmt.Printf(\"Container: %s\\n\", cid)\n   259→\t}\n   260→\tif resp.ErrorMessage != \"\" {\n   261→\t\tfmt.Printf(\"Error:     %s\\n\", resp.ErrorMessage)\n   262→\t}\n   263→\tfmt.Printf(\"Active:    %s\\n\", resp.CurrentStep)\n   264→\tfor _, exec := range resp.StepExecutions {\n   265→\t\tfmt.Printf(\"  %s: %s (%s -> %s)\\n\", exec.StepName, exec.Result, exec.StartedAt, exec.CompletedAt)\n   266→\t}\n   267→}\n   268→\n   269→func cmdList(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   270→\tvar all bool\n   271→\tvar projectDir, stateFilter, issueFilter string\n   272→\tvar limit int32\n   273→\n   274→\tfor i := 0; i < len(args); i++ {\n   275→\t\tswitch args[i] {\n   276→\t\tcase \"--all\":\n   277→\t\t\tall = true\n   278→\t\tcase \"--project\", \"-p\":\n   279→\t\t\tif i+1 < len(args) {\n   280→\t\t\t\ti++\n   281→\t\t\t\tprojectDir = args[i]\n   282→\t\t\t}\n   283→\t\tcase \"--state\", \"-s\":\n   284→\t\t\tif i+1 < len(args) {\n   285→\t\t\t\ti++\n   286→\t\t\t\tstateFilter = args[i]\n   287→\t\t\t}\n   288→\t\tcase \"--limit\", \"-n\":\n   289→\t\t\tif i+1 < len(args) {\n   290→\t\t\t\ti++\n   291→\t\t\t\tn, err := strconv.Atoi(args[i])\n   292→\t\t\t\tif err != nil {\n   293→\t\t\t\t\tfmt.Fprintf(os.Stderr, \"error: invalid --limit value: %s\\n\", args[i])\n   294→\t\t\t\t\tos.Exit(1)\n   295→\t\t\t\t}\n   296→\t\t\t\tlimit = int32(n)\n   297→\t\t\t}\n   298→\t\tcase \"--issue\", \"-i\":\n   299→\t\t\tif i+1 < len(args) {\n   300→\t\t\t\ti++\n   301→\t\t\t\tissueFilter = args[i]\n   302→\t\t\t}\n   303→\t\t}\n   304→\t}\n   305→\n   306→\treq := &pb.ListRunsRequest{\n   307→\t\tState:  stateFilter,\n   308→\t\tLimit:  limit,\n   309→\t\tTaskId: issueFilter,\n   310→\t}\n   311→\tif projectDir != \"\" {\n   312→\t\treq.ProjectDir = projectDir\n   313→\t} else if all {\n   314→\t\treq.All = true\n   315→\t} else {\n   316→\t\t// Default: filter to current project\n   317→\t\tcwd, _ := os.Getwd()\n   318→\t\treq.ProjectDir = cwd\n   319→\t}\n   320→\n   321→\tresp, err := client.ListRuns(ctx, req)\n   322→\tif err != nil {\n   323→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   324→\t\tos.Exit(1)\n   325→\t}\n   326→\n   327→\tif len(resp.Runs) == 0 {\n   328→\t\tfmt.Println(\"No runs found.\")\n   329→\t\treturn\n   330→\t}\n   331→\n   332→\tw := tabwriter.NewWriter(os.Stdout, 0, 0, 2, ' ', 0)\n   333→\tfmt.Fprintln(w, \"RUN ID\\tWORKFLOW\\tSTATE\\tTYPE\\tTASK ID\\tTITLE\\tCONTAINER\\tERROR\")\n   334→\tfor _, run := range resp.Runs {\n   335→\t\trunType := \"container\"\n   336→\t\tif run.IsHost {\n   337→\t\t\trunType = \"host\"\n   338→\t\t}\n   339→\t\ttitle := run.Title\n   340→\t\tif len(title) > 40 {\n   341→\t\t\ttitle = title[:37] + \"...\"\n   342→\t\t}\n   343→\t\terrMsg := run.ErrorMessage\n   344→\t\tif len(errMsg) > 60 {\n   345→\t\t\terrMsg = errMsg[:57] + \"...\"\n   346→\t\t}\n   347→\t\tfmt.Fprintf(w, \"%s\\t%s\\t%s\\t%s\\t%s\\t%s\\t%s\\t%s\\n\",\n   348→\t\t\trun.RunId, run.WorkflowName, run.State, runType,\n   349→\t\t\trun.TaskId, title, run.ContainerId, errMsg)\n   350→\t}\n   351→\tw.Flush()\n   352→}\n   353→\n   354→func cmdLogs(client pb.ClocheServiceClient, args []string) {\n   355→\tif len(args) < 1 {\n   356→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche logs <run-id> [-s <name>] [--type <full|script|llm>] [-f] [-l <n>]\\n\")\n   357→\t\tos.Exit(1)\n   358→\t}\n   359→\n   360→\tvar stepFilter, typeFilter string\n   361→\tvar follow bool\n   362→\tvar limit int\n   363→\trunID := args[0]\n   364→\n   365→\tfor i := 1; i < len(args); i++ {\n   366→\t\tswitch args[i] {\n   367→\t\tcase \"--step\", \"-s\":\n   368→\t\t\tif i+1 < len(args) {\n   369→\t\t\t\ti++\n   370→\t\t\t\tstepFilter = args[i]\n   371→\t\t\t}\n   372→\t\tcase \"--type\":\n   373→\t\t\tif i+1 < len(args) {\n   374→\t\t\t\ti++\n   375→\t\t\t\ttypeFilter = args[i]\n   376→\t\t\t}\n   377→\t\tcase \"--follow\", \"-f\":\n   378→\t\t\tfollow = true\n   379→\t\tcase \"--limit\", \"-l\":\n   380→\t\t\tif i+1 < len(args) {\n   381→\t\t\t\ti++\n   382→\t\t\t\tn, err := strconv.Atoi(args[i])\n   383→\t\t\t\tif err != nil || n < 0 {\n   384→\t\t\t\t\tfmt.Fprintf(os.Stderr, \"error: --limit requires a positive integer\\n\")\n   385→\t\t\t\t\tos.Exit(1)\n   386→\t\t\t\t}\n   387→\t\t\t\tlimit = n\n   388→\t\t\t}\n   389→\t\t}\n   390→\t}\n   391→\n   392→\t// Use background context — log output can be large and follow mode blocks.\n   393→\tctx := context.Background()\n   394→\tvar mdPairs []string\n   395→\tif follow {\n   396→\t\tmdPairs = append(mdPairs, \"x-cloche-follow\", \"true\")\n   397→\t}\n   398→\tif limit > 0 {\n   399→\t\tmdPairs = append(mdPairs, \"x-cloche-limit\", strconv.Itoa(limit))\n   400→\t}\n   401→\tif len(mdPairs) > 0 {\n   402→\t\tmd := metadata.Pairs(mdPairs...)\n   403→\t\tctx = metadata.NewOutgoingContext(ctx, md)\n   404→\t}\n   405→\n   406→\tstream, err := client.StreamLogs(ctx, &pb.StreamLogsRequest{\n   407→\t\tRunId:    runID,\n   408→\t\tStepName: stepFilter,\n   409→\t\tLogType:  typeFilter,\n   410→\t})\n   411→\tif err != nil {\n   412→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   413→\t\tos.Exit(1)\n   414→\t}\n   415→\n   416→\tfor {\n   417→\t\tentry, err := stream.Recv()\n   418→\t\tif err != nil {\n   419→\t\t\tif errors.Is(err, io.EOF) {\n   420→\t\t\t\tbreak\n   421→\t\t\t}\n   422→\t\t\tfmt.Fprintf(os.Stderr, \"error reading logs: %v\\n\", err)\n   423→\t\t\tos.Exit(1)\n   424→\t\t}\n   425→\n   426→\t\tswitch entry.Type {\n   427→\t\tcase \"step_started\":\n   428→\t\t\tfmt.Printf(\"--- %s started ---\\n\", entry.StepName)\n   429→\t\t\tif entry.Message != \"\" {\n   430→\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n   431→\t\t\t}\n   432→\t\tcase \"step_completed\":\n   433→\t\t\tfmt.Printf(\"--- %s: %s ---\\n\", entry.StepName, entry.Result)\n   434→\t\t\tif entry.Message != \"\" {\n   435→\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n   436→\t\t\t}\n   437→\t\tcase \"run_completed\":\n   438→\t\t\tfmt.Printf(\"\\nRun result: %s\\n\", entry.Result)\n   439→\t\t\tif entry.Message != \"\" {\n   440→\t\t\t\tfmt.Printf(\"Error:      %s\\n\", entry.Message)\n   441→\t\t\t}\n   442→\t\tcase \"full_log\":\n   443→\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n   444→\t\tcase \"log\":\n   445→\t\t\t// Live-streamed log line from an active run.\n   446→\t\t\tfmt.Println(entry.Message)\n   447→\t\tdefault:\n   448→\t\t\t// Handles filtered log entries like \"script_log\", \"llm_log\", \"step_log\"\n   449→\t\t\tif entry.StepName != \"\" {\n   450→\t\t\t\tfmt.Printf(\"--- %s ---\\n\", entry.StepName)\n   451→\t\t\t}\n   452→\t\t\tif entry.Message != \"\" {\n   453→\t\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n   454→\t\t\t}\n   455→\t\t}\n   456→\t}\n   457→}\n   458→\n   459→func cmdStop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   460→\tif len(args) < 1 {\n   461→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche stop <run-id>\\n\")\n   462→\t\tos.Exit(1)\n   463→\t}\n   464→\n   465→\t_, err := client.StopRun(ctx, &pb.StopRunRequest{RunId: args[0]})\n   466→\tif err != nil {\n   467→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   468→\t\tos.Exit(1)\n   469→\t}\n   470→\tfmt.Printf(\"Stopped run: %s\\n\", args[0])\n   471→}\n   472→\n   473→func cmdDelete(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   474→\tif len(args) < 1 {\n   475→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche delete <container-or-run-id>\\n\")\n   476→\t\tos.Exit(1)\n   477→\t}\n   478→\n   479→\t_, err := client.DeleteContainer(ctx, &pb.DeleteContainerRequest{Id: args[0]})\n   480→\tif err != nil {\n   481→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   482→\t\tos.Exit(1)\n   483→\t}\n   484→\tfmt.Printf(\"Deleted container: %s\\n\", args[0])\n   485→}\n   486→\n   487→func cmdLoop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   488→\tcwd, _ := os.Getwd()\n   489→\n   490→\t// Check for \"stop\" subcommand\n   491→\tif len(args) > 0 && args[0] == \"stop\" {\n   492→\t\t_, err := client.DisableLoop(ctx, &pb.DisableLoopRequest{ProjectDir: cwd})\n   493→\t\tif err != nil {\n   494→\t\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   495→\t\t\tos.Exit(1)\n   496→\t\t}\n   497→\t\tfmt.Println(\"Orchestration loop stopped.\")\n   498→\t\treturn\n   499→\t}\n   500→\n   501→\t// Check for \"resume\" subcommand\n   502→\tif len(args) > 0 && args[0] == \"resume\" {\n   503→\t\t_, err := client.ResumeLoop(ctx, &pb.ResumeLoopRequest{ProjectDir: cwd})\n   504→\t\tif err != nil {\n   505→\t\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   506→\t\t\tos.Exit(1)\n   507→\t\t}\n   508→\t\tfmt.Println(\"Orchestration loop resumed.\")\n   509→\t\treturn\n   510→\t}\n   511→\n   512→\t// Default: 0 means \"use config value\" (server reads .cloche/config.toml).\n   513→\tvar maxConcurrent int32\n   514→\tfor i := 0; i < len(args); i++ {\n   515→\t\tswitch args[i] {\n   516→\t\tcase \"--max\":\n   517→\t\t\tif i+1 < len(args) {\n   518→\t\t\t\ti++\n   519→\t\t\t\tn, err := fmt.Sscanf(args[i], \"%d\", &maxConcurrent)\n   520→\t\t\t\tif n != 1 || err != nil {\n   521→\t\t\t\t\tfmt.Fprintf(os.Stderr, \"invalid --max value: %s\\n\", args[i])\n   522→\t\t\t\t\tos.Exit(1)\n   523→\t\t\t\t}\n   524→\t\t\t}\n   525→\t\t}\n   526→\t}\n   527→\n   528→\t_, err := client.EnableLoop(ctx, &pb.EnableLoopRequest{\n   529→\t\tProjectDir:    cwd,\n   530→\t\tMaxConcurrent: maxConcurrent,\n   531→\t})\n   532→\tif err != nil {\n   533→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   534→\t\tos.Exit(1)\n   535→\t}\n   536→\tif maxConcurrent > 0 {\n   537→\t\tfmt.Printf(\"Orchestration loop started (max_concurrent=%d).\\n\", maxConcurrent)\n   538→\t} else {\n   539→\t\tfmt.Println(\"Orchestration loop started (using config defaults).\")\n   540→\t}\n   541→}\n   542→\n   543→func cmdTasks(args []string) {\n   544→\t// Determine HTTP address from env\n   545→\thttpAddr := os.Getenv(\"CLOCHE_HTTP\")\n   546→\tif httpAddr == \"\" {\n   547→\t\thttpAddr = \"localhost:8080\"\n   548→\t}\n   549→\thttpAddr = strings.TrimPrefix(httpAddr, \"http://\")\n   550→\n   551→\t// Determine project label from --project flag or current directory\n   552→\tprojectDir := \"\"\n   553→\tfor i := 0; i < len(args); i++ {\n   554→\t\tswitch args[i] {\n   555→\t\tcase \"--project\":\n   556→\t\t\tif i+1 < len(args) {\n   557→\t\t\t\ti++\n   558→\t\t\t\tprojectDir = args[i]\n   559→\t\t\t}\n   560→\t\t}\n   561→\t}\n   562→\n   563→\tif projectDir == \"\" {\n   564→\t\tcwd, _ := os.Getwd()\n   565→\t\tprojectDir = filepath.Base(cwd)\n   566→\t}\n   567→\n   568→\ttasksURL := fmt.Sprintf(\"http://%s/api/projects/%s/tasks\", httpAddr, projectDir)\n   569→\tresp, err := http.Get(tasksURL)\n   570→\tif err != nil {\n   571→\t\tfmt.Fprintf(os.Stderr, \"error connecting to daemon web API: %v\\n\", err)\n   572→\t\tfmt.Fprintf(os.Stderr, \"hint: ensure CLOCHE_HTTP is set and the daemon is running with --http\\n\")\n   573→\t\tos.Exit(1)\n   574→\t}\n   575→\tdefer resp.Body.Close()\n   576→\n   577→\tif resp.StatusCode != 200 {\n   578→\t\tbody, _ := io.ReadAll(resp.Body)\n   579→\t\tfmt.Fprintf(os.Stderr, \"error: HTTP %d: %s\\n\", resp.StatusCode, strings.TrimSpace(string(body)))\n   580→\t\tos.Exit(1)\n   581→\t}\n   582→\n   583→\ttype taskEntry struct {\n   584→\t\tID          string `json:\"id\"`\n   585→\t\tStatus      string `json:\"status\"`\n   586→\t\tTitle       string `json:\"title\"`\n   587→\t\tDescription string `json:\"description\"`\n   588→\t\tAssigned    bool   `json:\"assigned\"`\n   589→\t\tAssignedAt  string `json:\"assigned_at\"`\n   590→\t\tRunID       string `json:\"run_id\"`\n   591→\t}\n   592→\n   593→\tvar tasks []taskEntry\n   594→\tif err := json.NewDecoder(resp.Body).Decode(&tasks); err != nil {\n   595→\t\tfmt.Fprintf(os.Stderr, \"error parsing response: %v\\n\", err)\n   596→\t\tos.Exit(1)\n   597→\t}\n   598→\n   599→\tif len(tasks) == 0 {\n   600→\t\tfmt.Println(\"No tasks found. (Is the orchestration loop running?)\")\n   601→\t\treturn\n   602→\t}\n   603→\n   604→\tfmt.Printf(\"%-20s  %-12s  %-10s  %-30s  %s\\n\", \"ID\", \"STATUS\", \"ASSIGNED\", \"RUN\", \"TITLE\")\n   605→\tfor _, t := range tasks {\n   606→\t\tstatus := t.Status\n   607→\t\tif status == \"\" {\n   608→\t\t\tstatus = \"open\"\n   609→\t\t}\n   610→\t\tassigned := \"-\"\n   611→\t\tif t.Assigned {\n   612→\t\t\tassigned = \"yes\"\n   613→\t\t}\n   614→\t\trunID := \"\"\n   615→\t\tif t.RunID != \"\" {\n   616→\t\t\trunID = t.RunID\n   617→\t\t\tif len(runID) > 30 {\n   618→\t\t\t\trunID = runID[:27] + \"...\"\n   619→\t\t\t}\n   620→\t\t}\n   621→\t\ttitle := t.Title\n   622→\t\tif len(title) > 40 {\n   623→\t\t\ttitle = title[:37] + \"...\"\n   624→\t\t}\n   625→\t\tfmt.Printf(\"%-20s  %-12s  %-10s  %-30s  %s\\n\", t.ID, status, assigned, runID, title)\n   626→\t}\n   627→}\n   628→\n   629→func cmdShutdown(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   630→\tvar force bool\n   631→\tfor _, a := range args {\n   632→\t\tif a == \"-f\" || a == \"--force\" {\n   633→\t\t\tforce = true\n   634→\t\t}\n   635→\t}\n   636→\t_, err := client.Shutdown(ctx, &pb.ShutdownRequest{Force: force})\n   637→\tif err != nil {\n   638→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   639→\t\tos.Exit(1)\n   640→\t}\n   641→\tfmt.Println(\"Daemon shutting down.\")\n   642→}\n   643→\n   644→// resolveRunContext returns the project directory and run ID for context\n   645→// commands. The run ID comes from CLOCHE_RUN_ID and the project directory\n   646→// from CLOCHE_PROJECT_DIR (falling back to cwd).\n   647→func resolveRunContext() (projectDir, runID string, err error) {\n   648→\trunID = os.Getenv(\"CLOCHE_RUN_ID\")\n   649→\tif runID == \"\" {\n   650→\t\treturn \"\", \"\", fmt.Errorf(\"CLOCHE_RUN_ID environment variable is not set\")\n   651→\t}\n   652→\tprojectDir = os.Getenv(\"CLOCHE_PROJECT_DIR\")\n   653→\tif projectDir == \"\" {\n   654→\t\tprojectDir, err = os.Getwd()\n   655→\t\tif err != nil {\n   656→\t\t\treturn \"\", \"\", fmt.Errorf(\"getting working directory: %w\", err)\n   657→\t\t}\n   658→\t}\n   659→\treturn projectDir, runID, nil\n   660→}\n   661→\n   662→func cmdGet(args []string) {\n   663→\tif len(args) < 1 {\n   664→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche get <key>\\n\")\n   665→\t\tos.Exit(1)\n   666→\t}\n   667→\n   668→\tprojectDir, runID, err := resolveRunContext()\n   669→\tif err != nil {\n   670→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   671→\t\tos.Exit(1)\n   672→\t}\n   673→\n   674→\tval, ok, err := runcontext.Get(projectDir, runID, args[0])\n   675→\tif err != nil {\n   676→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   677→\t\tos.Exit(1)\n   678→\t}\n   679→\tif !ok {\n   680→\t\tos.Exit(1)\n   681→\t}\n   682→\tfmt.Println(val)\n   683→}\n   684→\n   685→func cmdSet(args []string) {\n   686→\tif len(args) < 2 {\n   687→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche set <key> <value>\\n\")\n   688→\t\tfmt.Fprintf(os.Stderr, \"       cloche set <key> -     (read value from stdin)\\n\")\n   689→\t\tos.Exit(1)\n   690→\t}\n   691→\n   692→\tprojectDir, runID, err := resolveRunContext()\n   693→\tif err != nil {\n   694→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   695→\t\tos.Exit(1)\n   696→\t}\n   697→\n   698→\tvalue := args[1]\n   699→\tif value == \"-\" {\n   700→\t\tdata, err := io.ReadAll(os.Stdin)\n   701→\t\tif err != nil {\n   702→\t\t\tfmt.Fprintf(os.Stderr, \"error reading stdin: %v\\n\", err)\n   703→\t\t\tos.Exit(1)\n   704→\t\t}\n   705→\t\tvalue = strings.TrimRight(string(data), \"\\n\")\n   706→\t}\n   707→\n   708→\tif err := runcontext.Set(projectDir, runID, args[0], value); err != nil {\n   709→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   710→\t\tos.Exit(1)\n   711→\t}\n   712→}\n   713→\n   714→func cmdVersion() {\n   715→\tcliVersion := version.Version()\n   716→\tfmt.Printf(\"cloche %s\\n\", cliVersion)\n   717→\n   718→\t// Try to get daemon version via gRPC\n   719→\tdaemonVersion := \"<unavailable>\"\n   720→\taddr := os.Getenv(\"CLOCHE_ADDR\")\n   721→\tif addr == \"\" {\n   722→\t\taddr = \"unix:///tmp/cloche.sock\"\n   723→\t}\n   724→\tconn, err := grpc.NewClient(addr, grpc.WithTransportCredentials(insecure.NewCredentials()))\n   725→\tif err == nil {\n   726→\t\tdefer conn.Close()\n   727→\t\tclient := pb.NewClocheServiceClient(conn)\n   728→\t\tctx, cancel := context.WithTimeout(context.Background(), 3*time.Second)\n   729→\t\tdefer cancel()\n   730→\t\tresp, err := client.GetVersion(ctx, &pb.GetVersionRequest{})\n   731→\t\tif err == nil {\n   732→\t\t\tdaemonVersion = resp.Version\n   733→\t\t}\n   734→\t}\n   735→\tfmt.Printf(\"cloched %s\\n\", daemonVersion)\n   736→\n   737→\t// Try to get agent version by running: docker run --rm <image> cloche-agent -v\n   738→\tagentVersion := \"<unavailable>\"\n   739→\timage := os.Getenv(\"CLOCHE_IMAGE\")\n   740→\tif image == \"\" {\n   741→\t\timage = \"cloche-agent:latest\"\n   742→\t}\n   743→\tout, err := exec.CommandContext(\n   744→\t\tcontext.Background(),\n   745→\t\t\"docker\", \"run\", \"--rm\", \"--entrypoint\", \"cloche-agent\", image, \"-v\",\n   746→\t).Output()\n   747→\tif err == nil {\n   748→\t\tagentVersion = strings.TrimSpace(string(out))\n   749→\t\t// Strip \"cloche-agent \" prefix if present\n   750→\t\tagentVersion = strings.TrimPrefix(agentVersion, \"cloche-agent \")\n   751→\t}\n   752→\tfmt.Printf(\"cloche-agent %s\\n\", agentVersion)\n   753→\n   754→\t// Warn about version mismatches\n   755→\tif daemonVersion != \"<unavailable>\" && daemonVersion != cliVersion {\n   756→\t\tfmt.Fprintf(os.Stderr, \"warning: CLI version (%s) differs from daemon version (%s)\\n\", cliVersion, daemonVersion)\n   757→\t}\n   758→\tif agentVersion != \"<unavailable>\" && agentVersion != cliVersion {\n   759→\t\tfmt.Fprintf(os.Stderr, \"warning: CLI version (%s) differs from agent version (%s)\\n\", cliVersion, agentVersion)\n   760→\t}\n   761→}\n   762→"}]},"parent_tool_use_id":null,"session_id":"a8ef55fe-e043-486b-af98-cfac190da691","uuid":"1d51f434-eb5a-4454-947e-cb4a55d0c4ed","tool_use_result":{"type":"text","file":{"filePath":"/workspace/cmd/cloche/main.go","content":"package main\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"errors\"\n\t\"fmt\"\n\t\"io\"\n\t\"net/http\"\n\t\"os\"\n\t\"os/exec\"\n\t\"path/filepath\"\n\t\"strconv\"\n\t\"strings\"\n\t\"text/tabwriter\"\n\t\"time\"\n\n\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/logstream\"\n\t\"github.com/cloche-dev/cloche/internal/runcontext\"\n\t\"github.com/cloche-dev/cloche/internal/version\"\n\t\"google.golang.org/grpc\"\n\t\"google.golang.org/grpc/credentials/insecure\"\n\t\"google.golang.org/grpc/metadata\"\n)\n\nfunc main() {\n\tif len(os.Args) < 2 {\n\t\tprintTopLevelHelp()\n\t\tos.Exit(1)\n\t}\n\n\t// Handle version flags before anything else\n\tif os.Args[1] == \"-v\" || os.Args[1] == \"--version\" {\n\t\tcmdVersion()\n\t\treturn\n\t}\n\n\t// Handle top-level help: \"cloche help\", \"cloche --help\", \"cloche -h\"\n\tswitch os.Args[1] {\n\tcase \"help\":\n\t\tprintHelp(os.Args[2:])\n\t\treturn\n\tcase \"--help\", \"-h\":\n\t\tprintTopLevelHelp()\n\t\treturn\n\t}\n\n\t// Commands that don't need a daemon connection\n\tswitch os.Args[1] {\n\tcase \"init\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"init\")\n\t\t\treturn\n\t\t}\n\t\tcmdInit(os.Args[2:])\n\t\treturn\n\tcase \"health\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"health\")\n\t\t\treturn\n\t\t}\n\t\tcmdHealth(os.Args[2:])\n\t\treturn\n\tcase \"get\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"get\")\n\t\t\treturn\n\t\t}\n\t\tcmdGet(os.Args[2:])\n\t\treturn\n\tcase \"set\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"set\")\n\t\t\treturn\n\t\t}\n\t\tcmdSet(os.Args[2:])\n\t\treturn\n\tcase \"tasks\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"tasks\")\n\t\t\treturn\n\t\t}\n\t\tcmdTasks(os.Args[2:])\n\t\treturn\n\tcase \"workflow\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"workflow\")\n\t\t\treturn\n\t\t}\n\t\tcmdWorkflow(os.Args[2:])\n\t\treturn\n\tcase \"project\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"project\")\n\t\t\treturn\n\t\t}\n\t\tcmdProject(os.Args[2:])\n\t\treturn\n\tcase \"validate\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"validate\")\n\t\t\treturn\n\t\t}\n\t\tcmdValidate(os.Args[2:])\n\t\treturn\n\t}\n\n\t// Handle --help for daemon commands before connecting\n\tdaemonCmds := map[string]bool{\n\t\t\"run\": true, \"status\": true, \"logs\": true, \"poll\": true,\n\t\t\"list\": true, \"stop\": true, \"delete\": true, \"loop\": true, \"shutdown\": true,\n\t}\n\tif daemonCmds[os.Args[1]] && hasHelpFlag(os.Args[2:]) {\n\t\tprintSubcommandHelp(os.Args[1])\n\t\treturn\n\t}\n\n\t// Commands that need a daemon connection\n\taddr := os.Getenv(\"CLOCHE_ADDR\")\n\tif addr == \"\" {\n\t\taddr = \"unix:///tmp/cloche.sock\"\n\t}\n\n\tconn, err := grpc.NewClient(addr, grpc.WithTransportCredentials(insecure.NewCredentials()))\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"failed to connect: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tdefer conn.Close()\n\n\tclient := pb.NewClocheServiceClient(conn)\n\tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n\tdefer cancel()\n\n\tswitch os.Args[1] {\n\tcase \"run\":\n\t\tcmdRun(ctx, client, os.Args[2:])\n\tcase \"status\":\n\t\tcmdStatus(ctx, client, os.Args[2:])\n\tcase \"logs\":\n\t\tcmdLogs(client, os.Args[2:])\n\tcase \"poll\":\n\t\tcmdPoll(client, os.Args[2:])\n\tcase \"list\":\n\t\tcmdList(ctx, client, os.Args[2:])\n\tcase \"stop\":\n\t\tcmdStop(ctx, client, os.Args[2:])\n\tcase \"delete\":\n\t\tcmdDelete(ctx, client, os.Args[2:])\n\tcase \"loop\":\n\t\tcmdLoop(ctx, client, os.Args[2:])\n\tcase \"shutdown\":\n\t\tcmdShutdown(ctx, client, os.Args[2:])\n\tdefault:\n\t\tfmt.Fprintf(os.Stderr, \"unknown command: %s\\n\\n\", os.Args[1])\n\t\tprintTopLevelHelp()\n\t\tos.Exit(1)\n\t}\n}\n\n\nfunc cmdRun(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tvar workflow, prompt, title, issueID string\n\tvar keepContainer bool\n\n\tfor i := 0; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--workflow\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tworkflow = args[i]\n\t\t\t}\n\t\tcase \"--prompt\", \"-p\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tprompt = args[i]\n\t\t\t}\n\t\tcase \"--title\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\ttitle = args[i]\n\t\t\t}\n\t\tcase \"--issue\", \"-i\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tissueID = args[i]\n\t\t\t}\n\t\tcase \"--keep-container\":\n\t\t\tkeepContainer = true\n\t\tdefault:\n\t\t\t// Support bare positional arg as workflow name for backwards compat\n\t\t\tif workflow == \"\" && !strings.HasPrefix(args[i], \"-\") {\n\t\t\t\tworkflow = args[i]\n\t\t\t}\n\t\t}\n\t}\n\n\tif workflow == \"\" {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche run --workflow <name> [--prompt \\\"...\\\"] [--title \\\"...\\\"] [--issue ID]\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tcwd, _ := os.Getwd()\n\n\t// Resolve image from workflow file (soft failure — fall back to daemon default).\n\t// Try loading from any .cloche file; only extract image for container workflows.\n\tvar image string\n\tif wf, err := loadWorkflow(cwd, workflow); err == nil && wf.Location == domain.LocationContainer {\n\t\timage = wf.Config[\"container.image\"]\n\t}\n\n\tresp, err := client.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n\t\tWorkflowName:  workflow,\n\t\tProjectDir:    cwd,\n\t\tImage:         image,\n\t\tPrompt:        prompt,\n\t\tKeepContainer: keepContainer,\n\t\tTitle:         title,\n\t\tIssueId:       issueID,\n\t})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Printf(\"Started run: %s\\n\", resp.RunId)\n}\n\nfunc cmdStatus(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche status <run-id>\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tresp, err := client.GetStatus(ctx, &pb.GetStatusRequest{RunId: args[0]})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tfmt.Printf(\"Run:       %s\\n\", resp.RunId)\n\tif resp.Title != \"\" {\n\t\tfmt.Printf(\"Title:     %s\\n\", resp.Title)\n\t}\n\tfmt.Printf(\"Workflow:  %s\\n\", resp.WorkflowName)\n\tif resp.IsHost {\n\t\tfmt.Printf(\"Type:      host\\n\")\n\t} else {\n\t\tfmt.Printf(\"Type:      container\\n\")\n\t}\n\tfmt.Printf(\"State:     %s\\n\", resp.State)\n\tif resp.ContainerId != \"\" {\n\t\tcid := resp.ContainerId\n\t\tif len(cid) > 12 {\n\t\t\tcid = cid[:12]\n\t\t}\n\t\tfmt.Printf(\"Container: %s\\n\", cid)\n\t}\n\tif resp.ErrorMessage != \"\" {\n\t\tfmt.Printf(\"Error:     %s\\n\", resp.ErrorMessage)\n\t}\n\tfmt.Printf(\"Active:    %s\\n\", resp.CurrentStep)\n\tfor _, exec := range resp.StepExecutions {\n\t\tfmt.Printf(\"  %s: %s (%s -> %s)\\n\", exec.StepName, exec.Result, exec.StartedAt, exec.CompletedAt)\n\t}\n}\n\nfunc cmdList(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tvar all bool\n\tvar projectDir, stateFilter, issueFilter string\n\tvar limit int32\n\n\tfor i := 0; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--all\":\n\t\t\tall = true\n\t\tcase \"--project\", \"-p\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tprojectDir = args[i]\n\t\t\t}\n\t\tcase \"--state\", \"-s\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tstateFilter = args[i]\n\t\t\t}\n\t\tcase \"--limit\", \"-n\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tn, err := strconv.Atoi(args[i])\n\t\t\t\tif err != nil {\n\t\t\t\t\tfmt.Fprintf(os.Stderr, \"error: invalid --limit value: %s\\n\", args[i])\n\t\t\t\t\tos.Exit(1)\n\t\t\t\t}\n\t\t\t\tlimit = int32(n)\n\t\t\t}\n\t\tcase \"--issue\", \"-i\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tissueFilter = args[i]\n\t\t\t}\n\t\t}\n\t}\n\n\treq := &pb.ListRunsRequest{\n\t\tState:  stateFilter,\n\t\tLimit:  limit,\n\t\tTaskId: issueFilter,\n\t}\n\tif projectDir != \"\" {\n\t\treq.ProjectDir = projectDir\n\t} else if all {\n\t\treq.All = true\n\t} else {\n\t\t// Default: filter to current project\n\t\tcwd, _ := os.Getwd()\n\t\treq.ProjectDir = cwd\n\t}\n\n\tresp, err := client.ListRuns(ctx, req)\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tif len(resp.Runs) == 0 {\n\t\tfmt.Println(\"No runs found.\")\n\t\treturn\n\t}\n\n\tw := tabwriter.NewWriter(os.Stdout, 0, 0, 2, ' ', 0)\n\tfmt.Fprintln(w, \"RUN ID\\tWORKFLOW\\tSTATE\\tTYPE\\tTASK ID\\tTITLE\\tCONTAINER\\tERROR\")\n\tfor _, run := range resp.Runs {\n\t\trunType := \"container\"\n\t\tif run.IsHost {\n\t\t\trunType = \"host\"\n\t\t}\n\t\ttitle := run.Title\n\t\tif len(title) > 40 {\n\t\t\ttitle = title[:37] + \"...\"\n\t\t}\n\t\terrMsg := run.ErrorMessage\n\t\tif len(errMsg) > 60 {\n\t\t\terrMsg = errMsg[:57] + \"...\"\n\t\t}\n\t\tfmt.Fprintf(w, \"%s\\t%s\\t%s\\t%s\\t%s\\t%s\\t%s\\t%s\\n\",\n\t\t\trun.RunId, run.WorkflowName, run.State, runType,\n\t\t\trun.TaskId, title, run.ContainerId, errMsg)\n\t}\n\tw.Flush()\n}\n\nfunc cmdLogs(client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche logs <run-id> [-s <name>] [--type <full|script|llm>] [-f] [-l <n>]\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tvar stepFilter, typeFilter string\n\tvar follow bool\n\tvar limit int\n\trunID := args[0]\n\n\tfor i := 1; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--step\", \"-s\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tstepFilter = args[i]\n\t\t\t}\n\t\tcase \"--type\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\ttypeFilter = args[i]\n\t\t\t}\n\t\tcase \"--follow\", \"-f\":\n\t\t\tfollow = true\n\t\tcase \"--limit\", \"-l\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tn, err := strconv.Atoi(args[i])\n\t\t\t\tif err != nil || n < 0 {\n\t\t\t\t\tfmt.Fprintf(os.Stderr, \"error: --limit requires a positive integer\\n\")\n\t\t\t\t\tos.Exit(1)\n\t\t\t\t}\n\t\t\t\tlimit = n\n\t\t\t}\n\t\t}\n\t}\n\n\t// Use background context — log output can be large and follow mode blocks.\n\tctx := context.Background()\n\tvar mdPairs []string\n\tif follow {\n\t\tmdPairs = append(mdPairs, \"x-cloche-follow\", \"true\")\n\t}\n\tif limit > 0 {\n\t\tmdPairs = append(mdPairs, \"x-cloche-limit\", strconv.Itoa(limit))\n\t}\n\tif len(mdPairs) > 0 {\n\t\tmd := metadata.Pairs(mdPairs...)\n\t\tctx = metadata.NewOutgoingContext(ctx, md)\n\t}\n\n\tstream, err := client.StreamLogs(ctx, &pb.StreamLogsRequest{\n\t\tRunId:    runID,\n\t\tStepName: stepFilter,\n\t\tLogType:  typeFilter,\n\t})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tfor {\n\t\tentry, err := stream.Recv()\n\t\tif err != nil {\n\t\t\tif errors.Is(err, io.EOF) {\n\t\t\t\tbreak\n\t\t\t}\n\t\t\tfmt.Fprintf(os.Stderr, \"error reading logs: %v\\n\", err)\n\t\t\tos.Exit(1)\n\t\t}\n\n\t\tswitch entry.Type {\n\t\tcase \"step_started\":\n\t\t\tfmt.Printf(\"--- %s started ---\\n\", entry.StepName)\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n\t\t\t}\n\t\tcase \"step_completed\":\n\t\t\tfmt.Printf(\"--- %s: %s ---\\n\", entry.StepName, entry.Result)\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n\t\t\t}\n\t\tcase \"run_completed\":\n\t\t\tfmt.Printf(\"\\nRun result: %s\\n\", entry.Result)\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Printf(\"Error:      %s\\n\", entry.Message)\n\t\t\t}\n\t\tcase \"full_log\":\n\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n\t\tcase \"log\":\n\t\t\t// Live-streamed log line from an active run.\n\t\t\tfmt.Println(entry.Message)\n\t\tdefault:\n\t\t\t// Handles filtered log entries like \"script_log\", \"llm_log\", \"step_log\"\n\t\t\tif entry.StepName != \"\" {\n\t\t\t\tfmt.Printf(\"--- %s ---\\n\", entry.StepName)\n\t\t\t}\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n\t\t\t}\n\t\t}\n\t}\n}\n\nfunc cmdStop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche stop <run-id>\\n\")\n\t\tos.Exit(1)\n\t}\n\n\t_, err := client.StopRun(ctx, &pb.StopRunRequest{RunId: args[0]})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Printf(\"Stopped run: %s\\n\", args[0])\n}\n\nfunc cmdDelete(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche delete <container-or-run-id>\\n\")\n\t\tos.Exit(1)\n\t}\n\n\t_, err := client.DeleteContainer(ctx, &pb.DeleteContainerRequest{Id: args[0]})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Printf(\"Deleted container: %s\\n\", args[0])\n}\n\nfunc cmdLoop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tcwd, _ := os.Getwd()\n\n\t// Check for \"stop\" subcommand\n\tif len(args) > 0 && args[0] == \"stop\" {\n\t\t_, err := client.DisableLoop(ctx, &pb.DisableLoopRequest{ProjectDir: cwd})\n\t\tif err != nil {\n\t\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\t\tos.Exit(1)\n\t\t}\n\t\tfmt.Println(\"Orchestration loop stopped.\")\n\t\treturn\n\t}\n\n\t// Check for \"resume\" subcommand\n\tif len(args) > 0 && args[0] == \"resume\" {\n\t\t_, err := client.ResumeLoop(ctx, &pb.ResumeLoopRequest{ProjectDir: cwd})\n\t\tif err != nil {\n\t\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\t\tos.Exit(1)\n\t\t}\n\t\tfmt.Println(\"Orchestration loop resumed.\")\n\t\treturn\n\t}\n\n\t// Default: 0 means \"use config value\" (server reads .cloche/config.toml).\n\tvar maxConcurrent int32\n\tfor i := 0; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--max\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tn, err := fmt.Sscanf(args[i], \"%d\", &maxConcurrent)\n\t\t\t\tif n != 1 || err != nil {\n\t\t\t\t\tfmt.Fprintf(os.Stderr, \"invalid --max value: %s\\n\", args[i])\n\t\t\t\t\tos.Exit(1)\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\t_, err := client.EnableLoop(ctx, &pb.EnableLoopRequest{\n\t\tProjectDir:    cwd,\n\t\tMaxConcurrent: maxConcurrent,\n\t})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tif maxConcurrent > 0 {\n\t\tfmt.Printf(\"Orchestration loop started (max_concurrent=%d).\\n\", maxConcurrent)\n\t} else {\n\t\tfmt.Println(\"Orchestration loop started (using config defaults).\")\n\t}\n}\n\nfunc cmdTasks(args []string) {\n\t// Determine HTTP address from env\n\thttpAddr := os.Getenv(\"CLOCHE_HTTP\")\n\tif httpAddr == \"\" {\n\t\thttpAddr = \"localhost:8080\"\n\t}\n\thttpAddr = strings.TrimPrefix(httpAddr, \"http://\")\n\n\t// Determine project label from --project flag or current directory\n\tprojectDir := \"\"\n\tfor i := 0; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--project\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tprojectDir = args[i]\n\t\t\t}\n\t\t}\n\t}\n\n\tif projectDir == \"\" {\n\t\tcwd, _ := os.Getwd()\n\t\tprojectDir = filepath.Base(cwd)\n\t}\n\n\ttasksURL := fmt.Sprintf(\"http://%s/api/projects/%s/tasks\", httpAddr, projectDir)\n\tresp, err := http.Get(tasksURL)\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error connecting to daemon web API: %v\\n\", err)\n\t\tfmt.Fprintf(os.Stderr, \"hint: ensure CLOCHE_HTTP is set and the daemon is running with --http\\n\")\n\t\tos.Exit(1)\n\t}\n\tdefer resp.Body.Close()\n\n\tif resp.StatusCode != 200 {\n\t\tbody, _ := io.ReadAll(resp.Body)\n\t\tfmt.Fprintf(os.Stderr, \"error: HTTP %d: %s\\n\", resp.StatusCode, strings.TrimSpace(string(body)))\n\t\tos.Exit(1)\n\t}\n\n\ttype taskEntry struct {\n\t\tID          string `json:\"id\"`\n\t\tStatus      string `json:\"status\"`\n\t\tTitle       string `json:\"title\"`\n\t\tDescription string `json:\"description\"`\n\t\tAssigned    bool   `json:\"assigned\"`\n\t\tAssignedAt  string `json:\"assigned_at\"`\n\t\tRunID       string `json:\"run_id\"`\n\t}\n\n\tvar tasks []taskEntry\n\tif err := json.NewDecoder(resp.Body).Decode(&tasks); err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error parsing response: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tif len(tasks) == 0 {\n\t\tfmt.Println(\"No tasks found. (Is the orchestration loop running?)\")\n\t\treturn\n\t}\n\n\tfmt.Printf(\"%-20s  %-12s  %-10s  %-30s  %s\\n\", \"ID\", \"STATUS\", \"ASSIGNED\", \"RUN\", \"TITLE\")\n\tfor _, t := range tasks {\n\t\tstatus := t.Status\n\t\tif status == \"\" {\n\t\t\tstatus = \"open\"\n\t\t}\n\t\tassigned := \"-\"\n\t\tif t.Assigned {\n\t\t\tassigned = \"yes\"\n\t\t}\n\t\trunID := \"\"\n\t\tif t.RunID != \"\" {\n\t\t\trunID = t.RunID\n\t\t\tif len(runID) > 30 {\n\t\t\t\trunID = runID[:27] + \"...\"\n\t\t\t}\n\t\t}\n\t\ttitle := t.Title\n\t\tif len(title) > 40 {\n\t\t\ttitle = title[:37] + \"...\"\n\t\t}\n\t\tfmt.Printf(\"%-20s  %-12s  %-10s  %-30s  %s\\n\", t.ID, status, assigned, runID, title)\n\t}\n}\n\nfunc cmdShutdown(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tvar force bool\n\tfor _, a := range args {\n\t\tif a == \"-f\" || a == \"--force\" {\n\t\t\tforce = true\n\t\t}\n\t}\n\t_, err := client.Shutdown(ctx, &pb.ShutdownRequest{Force: force})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Println(\"Daemon shutting down.\")\n}\n\n// resolveRunContext returns the project directory and run ID for context\n// commands. The run ID comes from CLOCHE_RUN_ID and the project directory\n// from CLOCHE_PROJECT_DIR (falling back to cwd).\nfunc resolveRunContext() (projectDir, runID string, err error) {\n\trunID = os.Getenv(\"CLOCHE_RUN_ID\")\n\tif runID == \"\" {\n\t\treturn \"\", \"\", fmt.Errorf(\"CLOCHE_RUN_ID environment variable is not set\")\n\t}\n\tprojectDir = os.Getenv(\"CLOCHE_PROJECT_DIR\")\n\tif projectDir == \"\" {\n\t\tprojectDir, err = os.Getwd()\n\t\tif err != nil {\n\t\t\treturn \"\", \"\", fmt.Errorf(\"getting working directory: %w\", err)\n\t\t}\n\t}\n\treturn projectDir, runID, nil\n}\n\nfunc cmdGet(args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche get <key>\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tprojectDir, runID, err := resolveRunContext()\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tval, ok, err := runcontext.Get(projectDir, runID, args[0])\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tif !ok {\n\t\tos.Exit(1)\n\t}\n\tfmt.Println(val)\n}\n\nfunc cmdSet(args []string) {\n\tif len(args) < 2 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche set <key> <value>\\n\")\n\t\tfmt.Fprintf(os.Stderr, \"       cloche set <key> -     (read value from stdin)\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tprojectDir, runID, err := resolveRunContext()\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tvalue := args[1]\n\tif value == \"-\" {\n\t\tdata, err := io.ReadAll(os.Stdin)\n\t\tif err != nil {\n\t\t\tfmt.Fprintf(os.Stderr, \"error reading stdin: %v\\n\", err)\n\t\t\tos.Exit(1)\n\t\t}\n\t\tvalue = strings.TrimRight(string(data), \"\\n\")\n\t}\n\n\tif err := runcontext.Set(projectDir, runID, args[0], value); err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n}\n\nfunc cmdVersion() {\n\tcliVersion := version.Version()\n\tfmt.Printf(\"cloche %s\\n\", cliVersion)\n\n\t// Try to get daemon version via gRPC\n\tdaemonVersion := \"<unavailable>\"\n\taddr := os.Getenv(\"CLOCHE_ADDR\")\n\tif addr == \"\" {\n\t\taddr = \"unix:///tmp/cloche.sock\"\n\t}\n\tconn, err := grpc.NewClient(addr, grpc.WithTransportCredentials(insecure.NewCredentials()))\n\tif err == nil {\n\t\tdefer conn.Close()\n\t\tclient := pb.NewClocheServiceClient(conn)\n\t\tctx, cancel := context.WithTimeout(context.Background(), 3*time.Second)\n\t\tdefer cancel()\n\t\tresp, err := client.GetVersion(ctx, &pb.GetVersionRequest{})\n\t\tif err == nil {\n\t\t\tdaemonVersion = resp.Version\n\t\t}\n\t}\n\tfmt.Printf(\"cloched %s\\n\", daemonVersion)\n\n\t// Try to get agent version by running: docker run --rm <image> cloche-agent -v\n\tagentVersion := \"<unavailable>\"\n\timage := os.Getenv(\"CLOCHE_IMAGE\")\n\tif image == \"\" {\n\t\timage = \"cloche-agent:latest\"\n\t}\n\tout, err := exec.CommandContext(\n\t\tcontext.Background(),\n\t\t\"docker\", \"run\", \"--rm\", \"--entrypoint\", \"cloche-agent\", image, \"-v\",\n\t).Output()\n\tif err == nil {\n\t\tagentVersion = strings.TrimSpace(string(out))\n\t\t// Strip \"cloche-agent \" prefix if present\n\t\tagentVersion = strings.TrimPrefix(agentVersion, \"cloche-agent \")\n\t}\n\tfmt.Printf(\"cloche-agent %s\\n\", agentVersion)\n\n\t// Warn about version mismatches\n\tif daemonVersion != \"<unavailable>\" && daemonVersion != cliVersion {\n\t\tfmt.Fprintf(os.Stderr, \"warning: CLI version (%s) differs from daemon version (%s)\\n\", cliVersion, daemonVersion)\n\t}\n\tif agentVersion != \"<unavailable>\" && agentVersion != cliVersion {\n\t\tfmt.Fprintf(os.Stderr, \"warning: CLI version (%s) differs from agent version (%s)\\n\", cliVersion, agentVersion)\n\t}\n}\n","numLines":762,"startLine":1,"totalLines":762}}}
