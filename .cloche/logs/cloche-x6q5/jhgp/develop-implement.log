unc TestServer_ListRuns_IncludesTaskId(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\trun := domain.NewRun(\"taskid-list-1\", \"develop\")\n\trun.Start()\n\trun.TaskID = \"ISSUE-99\"\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\n\tsrv := server.NewClocheServer(store, nil)\n\tresp, err := srv.ListRuns(ctx, &pb.ListRunsRequest{All: true})\n\trequire.NoError(t, err)\n\trequire.Len(t, resp.Runs, 1)\n\tassert.Equal(t, \"ISSUE-99\", resp.Runs[0].TaskId)\n}\n\nfunc TestServer_RunWorkflow_CapturesStepMetadata(t *testing.T) {"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":758,"cache_read_input_tokens":75539,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":758},"output_tokens":3,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"f29cf043-1251-4213-84f2-becb34ef1768","uuid":"ddb293d9-486a-4bcb-9338-80d55bf6fe61"}
