586→\t\tAssigned    bool   `json:\"assigned\"`\n   587→\t\tAssignedAt  string `json:\"assigned_at\"`\n   588→\t\tRunID       string `json:\"run_id\"`\n   589→\t}\n   590→\n   591→\tvar tasks []taskEntry\n   592→\tif err := json.NewDecoder(resp.Body).Decode(&tasks); err != nil {\n   593→\t\tfmt.Fprintf(os.Stderr, \"error parsing response: %v\\n\", err)\n   594→\t\tos.Exit(1)\n   595→\t}\n   596→\n   597→\tif len(tasks) == 0 {\n   598→\t\tfmt.Println(\"No tasks found. (Is the orchestration loop running?)\")\n   599→\t\treturn\n   600→\t}\n   601→\n   602→\tfmt.Printf(\"%-20s  %-12s  %-10s  %-30s  %s\\n\", \"ID\", \"STATUS\", \"ASSIGNED\", \"RUN\", \"TITLE\")\n   603→\tfor _, t := range tasks {\n   604→\t\tstatus := t.Status\n   605→\t\tif status == \"\" {\n   606→\t\t\tstatus = \"open\"\n   607→\t\t}\n   608→\t\tassigned := \"-\"\n   609→\t\tif t.Assigned {\n   610→\t\t\tassigned = \"yes\"\n   611→\t\t}\n   612→\t\trunID := \"\"\n   613→\t\tif t.RunID != \"\" {\n   614→\t\t\trunID = t.RunID\n   615→\t\t\tif len(runID) > 30 {\n   616→\t\t\t\trunID = runID[:27] + \"...\"\n   617→\t\t\t}\n   618→\t\t}\n   619→\t\ttitle := t.Title\n   620→\t\tif len(title) > 40 {\n   621→\t\t\ttitle = title[:37] + \"...\"\n   622→\t\t}\n   623→\t\tfmt.Printf(\"%-20s  %-12s  %-10s  %-30s  %s\\n\", t.ID, status, assigned, runID, title)\n   624→\t}\n   625→}\n   626→\n   627→func cmdShutdown(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   628→\tvar force bool\n   629→\tfor _, a := range args {\n   630→\t\tif a == \"-f\" || a == \"--force\" {\n   631→\t\t\tforce = true\n   632→\t\t}\n   633→\t}\n   634→\t_, err := client.Shutdown(ctx, &pb.ShutdownRequest{Force: force})\n   635→\tif err != nil {\n   636→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   637→\t\tos.Exit(1)\n   638→\t}\n   639→\tfmt.Println(\"Daemon shutting down.\")\n   640→}\n   641→\n   642→// resolveRunContext returns the project directory and run ID for context\n   643→// commands. The run ID comes from CLOCHE_RUN_ID and the project directory\n   644→// from CLOCHE_PROJECT_DIR (falling back to cwd).\n   645→func resolveRunContext() (projectDir, runID string, err error) {\n   646→\trunID = os.Getenv(\"CLOCHE_RUN_ID\")\n   647→\tif runID == \"\" {\n   648→\t\treturn \"\", \"\", fmt.Errorf(\"CLOCHE_RUN_ID environment variable is not set\")\n   649→\t}\n   650→\tprojectDir = os.Getenv(\"CLOCHE_PROJECT_DIR\")\n   651→\tif projectDir == \"\" {\n   652→\t\tprojectDir, err = os.Getwd()\n   653→\t\tif err != nil {\n   654→\t\t\treturn \"\", \"\", fmt.Errorf(\"getting working directory: %w\", err)\n   655→\t\t}\n   656→\t}\n   657→\treturn projectDir, runID, nil\n   658→}\n   659→\n   660→func cmdGet(args []string) {\n   661→\tif len(args) < 1 {\n   662→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche get <key>\\n\")\n   663→\t\tos.Exit(1)\n   664→\t}\n   665→\n   666→\tprojectDir, runID, err := resolveRunContext()\n   667→\tif err != nil {\n   668→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   669→\t\tos.Exit(1)\n   670→\t}\n   671→\n   672→\tval, ok, err := runcontext.Get(projectDir, runID, args[0])\n   673→\tif err != nil {\n   674→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   675→\t\tos.Exit(1)\n   676→\t}\n   677→\tif !ok {\n   678→\t\tos.Exit(1)\n   679→\t}\n   680→\tfmt.Println(val)\n   681→}\n   682→\n   683→func cmdSet(args []string) {\n   684→\tif len(args) < 2 {\n   685→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche set <key> <value>\\n\")\n   686→\t\tfmt.Fprintf(os.Stderr, \"       cloche set <key> -     (read value from stdin)\\n\")\n   687→\t\tos.Exit(1)\n   688→\t}\n   689→\n   690→\tprojectDir, runID, err := resolveRunContext()\n   691→\tif err != nil {\n   692→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   693→\t\tos.Exit(1)\n   694→\t}\n   695→\n   696→\tvalue := args[1]\n   697→\tif value == \"-\" {\n   698→\t\tdata, err := io.ReadAll(os.Stdin)\n   699→\t\tif err != nil {\n   700→\t\t\tfmt.Fprintf(os.Stderr, \"error reading stdin: %v\\n\", err)\n   701→\t\t\tos.Exit(1)\n   702→\t\t}\n   703→\t\tvalue = strings.TrimRight(string(data), \"\\n\")\n   704→\t}\n   705→\n   706→\tif err := runcontext.Set(projectDir, runID, args[0], value); err != nil {\n   707→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   708→\t\tos.Exit(1)\n   709→\t}\n   710→}\n   711→\n   712→func cmdVersion() {\n   713→\tcliVersion := version.Version()\n   714→\tfmt.Printf(\"cloche %s\\n\", cliVersion)\n   715→\n   716→\t// Try to get daemon version via gRPC\n   717→\tdaemonVersion := \"<unavailable>\"\n   718→\taddr := os.Getenv(\"CLOCHE_ADDR\")\n   719→\tif addr == \"\" {\n   720→\t\taddr = \"unix:///tmp/cloche.sock\"\n   721→\t}\n   722→\tconn, err := grpc.NewClient(addr, grpc.WithTransportCredentials(insecure.NewCredentials()))\n   723→\tif err == nil {\n   724→\t\tdefer conn.Close()\n   725→\t\tclient := pb.NewClocheServiceClient(conn)\n   726→\t\tctx, cancel := context.WithTimeout(context.Background(), 3*time.Second)\n   727→\t\tdefer cancel()\n   728→\t\tresp, err := client.GetVersion(ctx, &pb.GetVersionRequest{})\n   729→\t\tif err == nil {\n   730→\t\t\tdaemonVersion = resp.Version\n   731→\t\t}\n   732→\t}\n   733→\tfmt.Printf(\"cloched %s\\n\", daemonVersion)\n   734→\n   735→\t// Try to get agent version by running: docker run --rm <image> cloche-agent -v\n   736→\tagentVersion := \"<unavailable>\"\n   737→\timage := os.Getenv(\"CLOCHE_IMAGE\")\n   738→\tif image == \"\" {\n   739→\t\timage = \"cloche-agent:latest\"\n   740→\t}\n   741→\tout, err := exec.CommandContext(\n   742→\t\tcontext.Background(),\n   743→\t\t\"docker\", \"run\", \"--rm\", \"--entrypoint\", \"cloche-agent\", image, \"-v\",\n   744→\t).Output()\n   745→\tif err == nil {\n   746→\t\tagentVersion = strings.TrimSpace(string(out))\n   747→\t\t// Strip \"cloche-agent \" prefix if present\n   748→\t\tagentVersion = strings.TrimPrefix(agentVersion, \"cloche-agent \")\n   749→\t}\n   750→\tfmt.Printf(\"cloche-agent %s\\n\", agentVersion)\n   751→\n  