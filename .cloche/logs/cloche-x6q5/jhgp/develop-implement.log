{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019hE2V5zyDxmifg1wUcifMi","type":"tool_result","content":"     1→package grpc\n     2→\n     3→import (\n     4→\t\"bufio\"\n     5→\t\"context\"\n     6→\t\"encoding/json\"\n     7→\t\"fmt\"\n     8→\t\"log\"\n     9→\t\"os\"\n    10→\t\"os/exec\"\n    11→\t\"path/filepath\"\n    12→\t\"sort\"\n    13→\t\"strconv\"\n    14→\t\"strings\"\n    15→\t\"sync\"\n    16→\t\"time\"\n    17→\n    18→\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    19→\t\"github.com/cloche-dev/cloche/internal/adapters/docker\"\n    20→\t\"github.com/cloche-dev/cloche/internal/adapters/web\"\n    21→\t\"github.com/cloche-dev/cloche/internal/config\"\n    22→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    23→\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    24→\t\"github.com/cloche-dev/cloche/internal/evolution\"\n    25→\t\"github.com/cloche-dev/cloche/internal/host\"\n    26→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    27→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    28→\t\"github.com/cloche-dev/cloche/internal/protocol\"\n    29→\t\"github.com/cloche-dev/cloche/internal/version\"\n    30→\trpcgrpc \"google.golang.org/grpc\"\n    31→\t\"google.golang.org/grpc/metadata\"\n    32→)\n    33→\n    34→type ClocheServer struct {\n    35→\tpb.UnimplementedClocheServiceServer\n    36→\tstore        ports.RunStore\n    37→\tcaptures     ports.CaptureStore\n    38→\tlogStore     ports.LogStore\n    39→\tcontainer    ports.ContainerRuntime\n    40→\tdefaultImage string\n    41→\tevolution    *evolution.Trigger\n    42→\tlogBroadcast *logstream.Broadcaster\n    43→\tshutdownFn   func()\n    44→\tmu           sync.Mutex\n    45→\trunIDs       map[string]string      // run_id -> container_id\n    46→\tloops        map[string]*host.Loop  // project_dir -> orchestration loop\n    47→}\n    48→\n    49→func NewClocheServer(store ports.RunStore, container ports.ContainerRuntime) *ClocheServer {\n    50→\treturn &ClocheServer{\n    51→\t\tstore:     store,\n    52→\t\tcontainer: container,\n    53→\t\trunIDs:    make(map[string]string),\n    54→\t\tloops:     make(map[string]*host.Loop),\n    55→\t}\n    56→}\n    57→\n    58→func NewClocheServerWithCaptures(store ports.RunStore, captures ports.CaptureStore, container ports.ContainerRuntime, defaultImage string) *ClocheServer {\n    59→\treturn &ClocheServer{\n    60→\t\tstore:        store,\n    61→\t\tcaptures:     captures,\n    62→\t\tcontainer:    container,\n    63→\t\tdefaultImage: defaultImage,\n    64→\t\trunIDs:       make(map[string]string),\n    65→\t\tloops:        make(map[string]*host.Loop),\n    66→\t}\n    67→}\n    68→\n    69→// SetLogStore attaches a log store to the server for indexing extracted log files.\n    70→func (s *ClocheServer) SetLogStore(ls ports.LogStore) {\n    71→\ts.logStore = ls\n    72→}\n    73→\n    74→\n    75→// SetEvolution attaches an evolution trigger to the server.\n    76→func (s *ClocheServer) SetEvolution(trigger *evolution.Trigger) {\n    77→\ts.evolution = trigger\n    78→}\n    79→\n    80→// SetLogBroadcaster attaches a log broadcaster for live-streaming LLM output.\n    81→func (s *ClocheServer) SetLogBroadcaster(b *logstream.Broadcaster) {\n    82→\ts.logBroadcast = b\n    83→}\n    84→\n    85→// SetShutdownFunc sets the callback invoked when the Shutdown RPC is called.\n    86→func (s *ClocheServer) SetShutdownFunc(fn func()) {\n    87→\ts.shutdownFn = fn\n    88→}\n    89→\n    90→func (s *ClocheServer) RunWorkflow(ctx context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error) {\n    91→\t// Check if this is a host workflow (has host {} block).\n    92→\tif hostWFs, err := host.FindHostWorkflows(req.ProjectDir); err == nil {\n    93→\t\tif _, isHost := hostWFs[req.WorkflowName]; isHost {\n    94→\t\t\treturn s.runHostWorkflow(ctx, req)\n    95→\t\t}\n    96→\t}\n    97→\n    98→\tif s.container == nil {\n    99→\t\treturn nil, fmt.Errorf(\"no container runtime configured\")\n   100→\t}\n   101→\n   102→\t// Generate a unique run ID, retrying on collision\n   103→\tvar runID string\n   104→\tfor attempts := 0; attempts < 10; attempts++ {\n   105→\t\trunID = domain.GenerateRunID(req.WorkflowName)\n   106→\t\texisting, err := s.store.GetRun(ctx, runID)\n   107→\t\tif err != nil {\n   108→\t\t\tbreak // ID is free\n   109→\t\t}\n   110→\t\t// Reuse if completed more than 1 hour ago\n   111→\t\tif !existing.CompletedAt.IsZero() && time.Since(existing.CompletedAt) > time.Hour {\n   112→\t\t\t_ = s.store.DeleteRun(ctx, runID)\n   113→\t\t\tbreak\n   114→\t\t}\n   115→\t}\n   116→\n   117→\t// Write prompt to .cloche/<run-id>/prompt.txt (run-specific to avoid conflicts)\n   118→\tif req.Prompt != \"\" {\n   119→\t\tclocheDir := filepath.Join(req.ProjectDir, \".cloche\", runID)\n   120→\t\tif err := os.MkdirAll(clocheDir, 0755); err != nil {\n   121→\t\t\treturn nil, fmt.Errorf(\"creating .cloche dir: %w\", err)\n   122→\t\t}\n   123→\t\tif err := os.WriteFile(filepath.Join(clocheDir, \"prompt.txt\"), []byte(req.Prompt), 0644); err != nil {\n   124→\t\t\treturn nil, fmt.Errorf(\"writing prompt: %w\", err)\n   125→\t\t}\n   126→\t}\n   127→\trun := domain.NewRun(runID, req.WorkflowName)\n   128→\trun.ProjectDir = req.ProjectDir\n   129→\trun.Title = req.Title\n   130→\tif err := s.store.CreateRun(ctx, run); err != nil {\n   131→\t\treturn nil, fmt.Errorf(\"creating run: %w\", err)\n   132→\t}\n   133→\n   134→\t// Resolve image: request-level override, then server default\n   135→\timage := req.Image\n   136→\tif image == \"\" {\n   137→\t\timage = s.defaultImage\n   138→\t}\n   139→\n   140→\t// Launch container start + tracking in background so the RPC returns immediately.\n   141→\t// The run stays in \"pending\" state until the container is up.\n   142→\tgo s.launchAndTrack(runID, image, req.KeepContainer, req)\n   143→\n   144→\treturn &pb.RunWorkflowResponse{RunId: runID}, nil\n   145→}\n   146→\n   147→// runHostWorkflow dispatches a host workflow via the host runner, returning\n   148→// immediately while the workflow runs in a background goroutine.\n   149→func (s *ClocheServer) runHostWorkflow(ctx context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error) {\n   150→\trunID := domain.GenerateRunID(req.WorkflowName)\n   151→\n   152→\trunner := &host.Runner{\n   153→\t\tDispatcher:   s,\n   154→\t\tStore:        s.store,\n   155→\t\tCaptures:     s.captures,\n   156→\t\tLogBroadcast: s.logBroadcast,\n   157→\t}\n   158→\n   159→\tgo func() {\n   160→\t\trunner.RunNamedWithID(context.Background(), req.ProjectDir, req.WorkflowName, runID)\n   161→\t}()\n   162→\n   163→\treturn &pb.RunWorkflowResponse{RunId: runID}, nil\n   164→}\n   165→\n   166→// launchAndTrack starts the container and then tracks it to completion.\n   167→// It runs in a background goroutine with its own context, independent of the\n   168→// RPC context which may be cancelled after RunWorkflow returns.\n   169→func (s *ClocheServer) launchAndTrack(runID, image string, keepContainer bool, req *pb.RunWorkflowRequest) {\n   170→\tctx := context.Background()\n   171→\n   172→\t// Auto-rebuild image if the project Dockerfile has changed since last build.\n   173→\tif ensurer, ok := s.container.(ports.ImageEnsurer); ok {\n   174→\t\tif err := ensurer.EnsureImage(ctx, req.ProjectDir, image); err != nil {\n   175→\t\t\trun, _ := s.store.GetRun(ctx, runID)\n   176→\t\t\tif run != nil {\n   177→\t\t\t\trun.Fail(fmt.Sprintf(\"failed to ensure image: %v\", err))\n   178→\t\t\t\t_ = s.store.UpdateRun(ctx, run)\n   179→\t\t\t}\n   180→\t\t\tlog.Printf(\"run %s: failed to ensure image: %v\", runID, err)\n   181→\t\t\t\treturn\n   182→\t\t}\n   183→\t}\n   184→\n   185→\tbaseSHA := gitHEAD(req.ProjectDir)\n   186→\n   187→\tcontainerID, err := s.container.Start(ctx, ports.ContainerConfig{\n   188→\t\tImage:        image,\n   189→\t\tWorkflowName: req.WorkflowName,\n   190→\t\tProjectDir:   req.ProjectDir,\n   191→\t\tRunID:        runID,\n   192→\t\tNetworkAllow: []string{\"*\"},\n   193→\t})\n   194→\tif err != nil {\n   195→\t\trun, _ := s.store.GetRun(ctx, runID)\n   196→\t\tif run != nil {\n   197→\t\t\trun.Fail(fmt.Sprintf(\"failed to start container: %v\", err))\n   198→\t\t\t_ = s.store.UpdateRun(ctx, run)\n   199→\t\t}\n   200→\t\tlog.Printf(\"run %s: failed to start container: %v\", runID, err)\n   201→\t\treturn\n   202→\t}\n   203→\n   204→\ts.mu.Lock()\n   205→\ts.runIDs[runID] = containerID\n   206→\ts.mu.Unlock()\n   207→\n   208→\trun, _ := s.store.GetRun(ctx, runID)\n   209→\tif run != nil {\n   210→\t\trun.Start()\n   211→\t\trun.ContainerID = containerID\n   212→\t\trun.BaseSHA = baseSHA\n   213→\t\t_ = s.store.UpdateRun(ctx, run)\n   214→\t}\n   215→\n   216→\ts.trackRun(runID, containerID, req.ProjectDir, req.WorkflowName, keepContainer)\n   217→}\n   218→\n   219→func (s *ClocheServer) trackRun(runID, containerID, projectDir, workflowName string, keepContainer bool) {\n   220→\tctx := context.Background()\n   221→\n   222→\t// Attach to agent output\n   223→\treader, err := s.container.AttachOutput(ctx, containerID)\n   224→\tif err != nil {\n   225→\t\tlog.Printf(\"failed to attach to output for run %s: %v\", runID, err)\n   226→\t\t\treturn\n   227→\t}\n   228→\n   229→\t// Parse JSON-lines status messages\n   230→\tvar reportedResult string // captured from MsgRunCompleted, persisted after branch extraction\n   231→\tvar reportedError string  // captured from MsgError, used to set ErrorMessage on failed runs\n   232→\tscanner := bufio.NewScanner(reader)\n   233→\tscanner.Buffer(make([]byte, 0, 256*1024), 1024*1024) // 1MB max to handle large log messages\n   234→\tfor scanner.Scan() {\n   235→\t\tvar msg protocol.StatusMessage\n   236→\t\tif err := json.Unmarshal(scanner.Bytes(), &msg); err != nil {\n   237→\t\t\tcontinue\n   238→\t\t}\n   239→\n   240→\t\t// Fast path: log messages don't need store interaction.\n   241→\t\tif msg.Type == protocol.MsgLog {\n   242→\t\t\tif s.logBroadcast != nil {\n   243→\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n   244→\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n   245→\t\t\t\t\tType:      \"llm\",\n   246→\t\t\t\t\tContent:   msg.Message,\n   247→\t\t\t\t\tStepName:  msg.StepName,\n   248→\t\t\t\t})\n   249→\t\t\t}\n   250→\t\t\tcontinue\n   251→\t\t}\n   252→\n   253→\t\trun, err := s.store.GetRun(ctx, runID)\n   254→\t\tif err != nil {\n   255→\t\t\tcontinue\n   256→\t\t}\n   257→\n   258→\t\tswitch msg.Type {\n   259→\t\tcase protocol.MsgStepStarted:\n   260→\t\t\trun.RecordStepStart(msg.StepName)\n   261→\t\t\tif s.captures != nil {\n   262→\t\t\t\t_ = s.captures.SaveCapture(ctx, runID, &domain.StepExecution{\n   263→\t\t\t\t\tStepName:  msg.StepName,\n   264→\t\t\t\t\tStartedAt: msg.Timestamp,\n   265→\t\t\t\t})\n   266→\t\t\t}\n   267→\t\t\tif s.logBroadcast != nil {\n   268→\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n   269→\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n   270→\t\t\t\t\tType:      \"status\",\n   271→\t\t\t\t\tContent:   \"step_started: \" + msg.StepName,\n   272→\t\t\t\t\tStepName:  msg.StepName,\n   273→\t\t\t\t})\n   274→\t\t\t}\n   275→\t\tcase protocol.MsgStepCompleted:\n   276→\t\t\trun.RecordStepComplete(msg.StepName, msg.Result)\n   277→\t\t\tif s.captures != nil {\n   278→\t\t\t\t_ = s.captures.SaveCapture(ctx, runID, &domain.StepExecution{\n   279→\t\t\t\t\tStepName:    msg.StepName,\n   280→\t\t\t\t\tResult:      msg.Result,\n   281→\t\t\t\t\tCompletedAt: msg.Timestamp,\n   282→\t\t\t\t})\n   283→\t\t\t}\n   284→\t\t\tif s.logBroadcast != nil {\n   285→\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n   286→\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n   287→\t\t\t\t\tType:      \"status\",\n   288→\t\t\t\t\tContent:   \"step_completed: \" + msg.StepName + \" -> \" + msg.Result,\n   289→\t\t\t\t\tStepName:  msg.StepName,\n   290→\t\t\t\t})\n   291→\t\t\t}\n   292→\t\tcase protocol.MsgRunTitle:\n   293→\t\t\tif run.Title == \"\" {\n   294→\t\t\t\trun.Title = msg.Message\n   295→\t\t\t}\n   296→\t\tcase protocol.MsgError:\n   297→\t\t\treportedError = msg.Message\n   298→\t\t\tcontinue // Don't persist; used during finalization\n   299→\t\tcase protocol.MsgRunCompleted:\n   300→\t\t\treportedResult = msg.Result\n   301→\t\t\tcontinue // Don't persist terminal state yet; branch extraction must finish first\n   302→\t\t}\n   303→\n   304→\t\t_ = s.store.UpdateRun(ctx, run)\n   305→\t}\n   306→\treader.Close()\n   307→\n   308→\t// Signal live-stream subscribers that this run is done.\n   309→\tif s.logBroadcast != nil {\n   310→\t\ts.logBroadcast.Finish(runID)\n   311→\t}\n   312→\n   313→\t// Wait for process exit\n   314→\texitCode, err := s.container.Wait(ctx, containerID)\n   315→\tif err != nil {\n   316→\t\tlog.Printf(\"error waiting for run %s: %v\", runID, err)\n   317→\t}\n   318→\n   319→\t// Extract step output files from container before it's removed\n   320→\toutputDst := filepath.Join(projectDir, \".cloche\", runID, \"output\")\n   321→\tif err := os.MkdirAll(outputDst, 0755); err == nil {\n   322→\t\tif cpErr := s.container.CopyFrom(ctx, containerID, \"/workspace/.cloche/output/.\", outputDst); cpErr != nil {\n   323→\t\t\tlog.Printf(\"run %s: failed to extract output: %v\", runID, cpErr)\n   324→\t\t}\n   325→\t}\n   326→\n   327→\t// Capture full container stdout/stderr before the container is removed\n   328→\tif logs, logErr := s.container.Logs(ctx, containerID); logErr == nil && logs != \"\" {\n   329→\t\tcontainerLogPath := filepath.Join(outputDst, \"container.log\")\n   330→\t\tif writeErr := os.WriteFile(containerLogPath, []byte(logs), 0644); writeErr != nil {\n   331→\t\t\tlog.Printf(\"run %s: failed to write container.log: %v\", runID, writeErr)\n   332→\t\t}\n   333→\t}\n   334→\n   335→\t// Index extracted log files in the log store\n   336→\tif s.logStore != nil {\n   337→\t\ts.indexLogFiles(ctx, runID, outputDst)\n   338→\t}\n   339→\n   340→\t// Extract results to git branch BEFORE finalizing state, so that\n   341→\t// WaitRun callers (e.g. host workflow merge step) see branches exist\n   342→\t// before the run is marked complete.\n   343→\tresultLabel := reportedResult\n   344→\tif resultLabel == \"\" {\n   345→\t\tif exitCode == 0 {\n   346→\t\t\tresultLabel = \"succeeded\"\n   347→\t\t} else {\n   348→\t\t\tresultLabel = \"failed\"\n   349→\t\t}\n   350→\t}\n   351→\t{\n   352→\t\textractRun, _ := s.store.GetRun(ctx, runID)\n   353→\t\tif extractRun != nil && extractRun.BaseSHA != \"\" {\n   354→\t\t\tlog.Printf(\"run %s: extracting results to branch cloche/%s (baseSHA=%s)\", runID, runID, extractRun.BaseSHA)\n   355→\t\t\tif err := docker.ExtractResults(ctx, containerID, extractRun.ProjectDir, runID, extractRun.BaseSHA, workflowName, resultLabel); err != nil {\n   356→\t\t\t\tlog.Printf(\"run %s: failed to extract results to branch: %v\", runID, err)\n   357→\t\t\t} else {\n   358→\t\t\t\tlog.Printf(\"run %s: branch cloche/%s created successfully\", runID, runID)\n   359→\t\t\t}\n   360→\t\t} else {\n   361→\t\t\tlog.Printf(\"run %s: skipping branch extraction (baseSHA empty or run not found)\", runID)\n   362→\t\t}\n   363→\t}\n   364→\n   365→\t// Now finalize run state\n   366→\trun, err := s.store.GetRun(ctx, runID)\n   367→\tif err != nil {\n   368→\t\treturn\n   369→\t}\n   370→\tif run.State == domain.RunStateRunning {\n   371→\t\tif reportedResult == \"succeeded\" {\n   372→\t\t\trun.Complete(domain.RunStateSucceeded)\n   373→\t\t} else if reportedResult != \"\" {\n   374→\t\t\tif reportedError != \"\" {\n   375→\t\t\t\trun.Fail(reportedError)\n   376→\t\t\t} else {\n   377→\t\t\t\trun.Complete(domain.RunStateFailed)\n   378→\t\t\t}\n   379→\t\t} else if exitCode == 0 {\n   380→\t\t\trun.Complete(domain.RunStateSucceeded)\n   381→\t\t} else {\n   382→\t\t\trun.Fail(fmt.Sprintf(\"container exited with code %d\", exitCode))\n   383→\t\t}\n   384→\t\t_ = s.store.UpdateRun(ctx, run)\n   385→\t}\n   386→\n   387→\t// Fire evolution trigger if configured\n   388→\tif s.evolution != nil {\n   389→\t\ts.evolution.Fire(projectDir, workflowName, runID)\n   390→\t}\n   391→\n   392→\t// Merge is handled as a workflow step in host.cloche, not here.\n   393→\n   394→\t// Container retention policy:\n   395→\t// - Failed runs: always keep the container for debugging\n   396→\t// - Successful runs + --keep-container: keep the container\n   397→\t// - Successful runs without --keep-container: remove the container\n   398→\trunFinal, _ := s.store.GetRun(ctx, runID)\n   399→\trunFailed := runFinal != nil && (runFinal.State == domain.RunStateFailed || runFinal.State == domain.RunStateCancelled)\n   400→\n   401→\tif keepContainer || runFailed {\n   402→\t\treason := \"--keep-container\"\n   403→\t\tif runFailed {\n   404→\t\t\treason = \"run failed\"\n   405→\t\t}\n   406→\t\tlog.Printf(\"run %s: keeping container %s (%s)\", runID, containerID, reason)\n   407→\t\tif runFinal != nil {\n   408→\t\t\trunFinal.ContainerKept = true\n   409→\t\t\t_ = s.store.UpdateRun(ctx, runFinal)\n   410→\t\t}\n   411→\t} else {\n   412→\t\tif err := s.container.Remove(ctx, containerID); err != nil {\n   413→\t\t\tlog.Printf(\"run %s: failed to remove container %s: %v\", runID, containerID, err)\n   414→\t\t} else {\n   415→\t\t\tlog.Printf(\"run %s: removed container %s\", runID, containerID)\n   416→\t\t}\n   417→\t}\n   418→\n   419→\t// Cleanup mapping\n   420→\ts.mu.Lock()\n   421→\tdelete(s.runIDs, runID)\n   422→\ts.mu.Unlock()\n   423→}\n   424→\n   425→func (s *ClocheServer) ListRuns(ctx context.Context, req *pb.ListRunsRequest) (*pb.ListRunsResponse, error) {\n   426→\tfilter := domain.RunListFilter{\n   427→\t\tProjectDir: req.ProjectDir,\n   428→\t\tState:      domain.RunState(req.State),\n   429→\t\tTaskID:     req.TaskId,\n   430→\t\tLimit:      int(req.Limit),\n   431→\t}\n   432→\n   433→\t// When no project filter and not --all, default to last hour\n   434→\tif filter.ProjectDir == \"\" && !req.All {\n   435→\t\tfilter.Since = time.Now().Add(-1 * time.Hour)\n   436→\t}\n   437→\n   438→\truns, err := s.store.ListRunsFiltered(ctx, filter)\n   439→\tif err != nil {\n   440→\t\treturn nil, fmt.Errorf(\"listing runs: %w\", err)\n   441→\t}\n   442→\n   443→\tresp := &pb.ListRunsResponse{}\n   444→\tfor _, run := range runs {\n   445→\t\tresp.Runs = append(resp.Runs, &pb.RunSummary{\n   446→\t\t\tRunId:        run.ID,\n   447→\t\t\tWorkflowName: run.WorkflowName,\n   448→\t\t\tState:        string(run.State),\n   449→\t\t\tStartedAt:    run.StartedAt.String(),\n   450→\t\t\tErrorMessage: run.ErrorMessage,\n   451→\t\t\tContainerId:  run.ContainerID,\n   452→\t\t\tTitle:        run.Title,\n   453→\t\t\tIsHost:       run.IsHost,\n   454→\t\t\tProjectDir:   run.ProjectDir,\n   455→\t\t})\n   456→\t}\n   457→\treturn resp, nil\n   458→}\n   459→\n   460→func (s *ClocheServer) GetStatus(ctx context.Context, req *pb.GetStatusRequest) (*pb.GetStatusResponse, error) {\n   461→\trun, err := s.store.GetRun(ctx, req.RunId)\n   462→\tif err != nil {\n   463→\t\treturn nil, fmt.Errorf(\"getting run: %w\", err)\n   464→\t}\n   465→\n   466→\tresp := &pb.GetStatusResponse{\n   467→\t\tRunId:        run.ID,\n   468→\t\tWorkflowName: run.WorkflowName,\n   469→\t\tState:        string(run.State),\n   470→\t\tCurrentStep:  strings.Join(run.ActiveSteps, \",\"),\n   471→\t\tErrorMessage: run.ErrorMessage,\n   472→\t\tContainerId:  run.ContainerID,\n   473→\t\tTitle:        run.Title,\n   474→\t\tIsHost:       run.IsHost,\n   475→\t}\n   476→\n   477→\t// Check container liveness\n   478→\tif run.ContainerID != \"\" && s.container != nil {\n   479→\t\tif cs, err := s.container.Inspect(ctx, run.ContainerID); err == nil {\n   480→\t\t\tresp.ContainerAlive = cs.Running\n   481→\t\t\tif !cs.Running && !cs.FinishedAt.IsZero() {\n   482→\t\t\t\tresp.ContainerDeadSince = cs.FinishedAt.Format(time.RFC3339Nano)\n   483→\t\t\t}\n   484→\t\t}\n   485→\t}\n   486→\n   487→\t// Load step executions from captures store if available\n   488→\tif s.captures != nil {\n   489→\t\tcaptures, err := s.captures.GetCaptures(ctx, req.RunId)\n   490→\t\tif err == nil {\n   491→\t\t\tfor _, exec := range captures {\n   492→\t\t\t\tresp.StepExecutions = append(resp.StepExecutions, &pb.StepExecutionStatus{\n   493→\t\t\t\t\tStepName:    exec.StepName,\n   494→\t\t\t\t\tResult:      exec.Result,\n   495→\t\t\t\t\tStartedAt:   exec.StartedAt.String(),\n   496→\t\t\t\t\tCompletedAt: exec.CompletedAt.String(),\n   497→\t\t\t\t})\n   498→\t\t\t}\n   499→\t\t}\n   500→\t} else {\n   501→\t\tfor _, exec := range run.StepExecutions {\n   502→\t\t\tresp.StepExecutions = append(resp.StepExecutions, &pb.StepExecutionStatus{\n   503→\t\t\t\tStepName:    exec.StepName,\n   504→\t\t\t\tResult:      exec.Result,\n   505→\t\t\t\tStartedAt:   exec.StartedAt.String(),\n   506→\t\t\t\tCompletedAt: exec.CompletedAt.String(),\n   507→\t\t\t})\n   508→\t\t}\n   509→\t}\n   510→\n   511→\treturn resp, nil\n   512→}\n   513→\n   514→func (s *ClocheServer) StreamLogs(req *pb.StreamLogsRequest, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n   515→\tctx := stream.Context()\n   516→\n   517→\t_ = followFromContext(ctx) // follow is implicit for active runs\n   518→\tlimit := limitFromContext(ctx)\n   519→\n   520→\t// Verify run exists\n   521→\trun, err := s.store.GetRun(ctx, req.RunId)\n   522→\tif err != nil {\n   523→\t\treturn fmt.Errorf(\"run %q not found: %w\", req.RunId, err)\n   524→\t}\n   525→\n   526→\t// If step_name or log_type filter is set, serve content directly from the log index\n   527→\tif req.StepName != \"\" || req.LogType != \"\" {\n   528→\t\treturn s.streamFilteredLogs(ctx, req, run, stream, limit)\n   529→\t}\n   530→\n   531→\tisActive := run.State == domain.RunStateRunning || run.State == domain.RunStatePending\n   532→\n   533→\t// Active runs always stream live output (follow mode is implicit).\n   534→\t// The -f flag is accepted but redundant for active runs.\n   535→\tif isActive && s.logBroadcast != nil {\n   536→\t\treturn s.streamFollowLogs(req.RunId, run, stream, limit)\n   537→\t}\n   538→\n   539→\t// Check for full.log first — if it exists, serve it as the unified log\n   540→\tfullLogPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", \"full.log\")\n   541→\tif data, readErr := os.ReadFile(fullLogPath); readErr == nil && len(data) > 0 {\n   542→\t\tmsg := applyLimit(string(data), limit)\n   543→\t\tif err := stream.Send(&pb.LogEntry{\n   544→\t\t\tType:    \"full_log\",\n   545→\t\t\tMessage: msg,\n   546→\t\t}); err != nil {\n   547→\t\t\treturn err\n   548→\t\t}\n   549→\t\tif !isActive {\n   550→\t\t\tif err := stream.Send(&pb.LogEntry{\n   551→\t\t\t\tType:      \"run_completed\",\n   552→\t\t\t\tResult:    string(run.State),\n   553→\t\t\t\tTimestamp: run.CompletedAt.String(),\n   554→\t\t\t\tMessage:   run.ErrorMessage,\n   555→\t\t\t}); err != nil {\n   556→\t\t\t\treturn err\n   557→\t\t\t}\n   558→\t\t}\n   559→\t\treturn nil\n   560→\t}\n   561→\n   562→\tif s.captures == nil {\n   563→\t\treturn fmt.Errorf(\"captures store not configured\")\n   564→\t}\n   565→\n   566→\t// Fall back to capture-based streaming\n   567→\tcaptures, err := s.captures.GetCaptures(ctx, req.RunId)\n   568→\tif err != nil {\n   569→\t\treturn fmt.Errorf(\"getting captures: %w\", err)\n   570→\t}\n   571→\n   572→\tfor _, exec := range captures {\n   573→\t\t// Captures are stored as separate rows: one for step_started (no Result)\n   574→\t\t// and one for step_completed (has Result).\n   575→\t\tif exec.Result == \"\" {\n   576→\t\t\tentry := &pb.LogEntry{\n   577→\t\t\t\tType:      \"step_started\",\n   578→\t\t\t\tStepName:  exec.StepName,\n   579→\t\t\t\tTimestamp: exec.StartedAt.String(),\n   580→\t\t\t}\n   581→\t\t\tif err := stream.Send(entry); err != nil {\n   582→\t\t\t\treturn err\n   583→\t\t\t}\n   584→\t\t} else {\n   585→\t\t\t// Read step output from per-step output file.\n   586→\t\t\t// Container runs write .log, host runs write .out — try both.\n   587→\t\t\tvar output string\n   588→\t\t\tfor _, ext := range []string{\".log\", \".out\"} {\n   589→\t\t\t\toutputPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", exec.StepName+ext)\n   590→\t\t\t\tif data, err := os.ReadFile(outputPath); err == nil && len(data) > 0 {\n   591→\t\t\t\t\toutput = string(data)\n   592→\t\t\t\t\tbreak\n   593→\t\t\t\t}\n   594→\t\t\t}\n   595→\t\t\tentry := &pb.LogEntry{\n   596→\t\t\t\tType:      \"step_completed\",\n   597→\t\t\t\tStepName:  exec.StepName,\n   598→\t\t\t\tResult:    exec.Result,\n   599→\t\t\t\tTimestamp: exec.CompletedAt.String(),\n   600→\t\t\t\tMessage:   applyLimit(output, limit),\n   601→\t\t\t}\n   602→\t\t\tif err := stream.Send(entry); err != nil {\n   603→\t\t\t\treturn err\n   604→\t\t\t}\n   605→\t\t}\n   606→\t}\n   607→\n   608→\t// Send run completion entry\n   609→\tif !isActive {\n   610→\t\tif err := stream.Send(&pb.LogEntry{\n   611→\t\t\tType:      \"run_completed\",\n   612→\t\t\tResult:    string(run.State),\n   613→\t\t\tTimestamp: run.CompletedAt.String(),\n   614→\t\t\tMessage:   run.ErrorMessage,\n   615→\t\t}); err != nil {\n   616→\t\t\treturn err\n   617→\t\t}\n   618→\t}\n   619→\n   620→\treturn nil\n   621→}\n   622→\n   623→// followFromContext checks for the follow flag in gRPC metadata.\n   624→func followFromContext(ctx context.Context) bool {\n   625→\tmd, ok := metadata.FromIncomingContext(ctx)\n   626→\tif !ok {\n   627→\t\treturn false\n   628→\t}\n   629→\tvals := md.Get(\"x-cloche-follow\")\n   630→\treturn len(vals) > 0 && vals[0] == \"true\"\n   631→}\n   632→\n   633→// limitFromContext reads the line limit from gRPC metadata.\n   634→// Returns 0 when no limit is set.\n   635→func limitFromContext(ctx context.Context) int {\n   636→\tmd, ok := metadata.FromIncomingContext(ctx)\n   637→\tif !ok {\n   638→\t\treturn 0\n   639→\t}\n   640→\tvals := md.Get(\"x-cloche-limit\")\n   641→\tif len(vals) == 0 {\n   642→\t\treturn 0\n   643→\t}\n   644→\tn, err := strconv.Atoi(vals[0])\n   645→\tif err != nil || n <= 0 {\n   646→\t\treturn 0\n   647→\t}\n   648→\treturn n\n   649→}\n   650→\n   651→// applyLimit returns the last n lines of content. If n <= 0, returns content unchanged.\n   652→func applyLimit(content string, n int) string {\n   653→\tif n <= 0 {\n   654→\t\treturn content\n   655→\t}\n   656→\tlines := strings.Split(content, \"\\n\")\n   657→\t// Remove trailing empty line from final newline\n   658→\tif len(lines) > 0 && lines[len(lines)-1] == \"\" {\n   659→\t\tlines = lines[:len(lines)-1]\n   660→\t}\n   661→\tif len(lines) <= n {\n   662→\t\treturn content\n   663→\t}\n   664→\treturn strings.Join(lines[len(lines)-n:], \"\\n\") + \"\\n\"\n   665→}\n   666→\n   667→// streamFollowLogs sends existing log content then tails live output from the\n   668→// broadcaster. It combines snapshot + live streaming (like tail -f).\n   669→func (s *ClocheServer) streamFollowLogs(runID string, run *domain.Run, stream rpcgrpc.ServerStreamingServer[pb.LogEntry], limit int) error {\n   670→\t// Subscribe first so we don't miss lines written between read and subscribe.\n   671→\tsub := s.logBroadcast.Subscribe(runID)\n   672→\tdefer s.logBroadcast.Unsubscribe(runID, sub)\n   673→\n   674→\t// Send existing full.log content if available.\n   675→\tfullLogPath := filepath.Join(run.ProjectDir, \".cloche\", runID, \"output\", \"full.log\")\n   676→\tif data, err := os.ReadFile(fullLogPath); err == nil && len(data) > 0 {\n   677→\t\tmsg := applyLimit(string(data), limit)\n   678→\t\tif err := stream.Send(&pb.LogEntry{\n   679→\t\t\tType:    \"full_log\",\n   680→\t\t\tMessage: msg,\n   681→\t\t}); err != nil {\n   682→\t\t\treturn err\n   683→\t\t}\n   684→\t}\n   685→\n   686→\t// Now tail live output from the broadcaster.\n   687→\tctx := stream.Context()\n   688→\tfor {\n   689→\t\tselect {\n   690→\t\tcase <-ctx.Done():\n   691→\t\t\treturn ctx.Err()\n   692→\t\tcase line, ok := <-sub.C:\n   693→\t\t\tif !ok {\n   694→\t\t\t\t// Run completed — send terminal entry.\n   695→\t\t\t\tr, err := s.store.GetRun(context.Background(), runID)\n   696→\t\t\t\tif err == nil && r.State != domain.RunStateRunning && r.State != domain.RunStatePending {\n   697→\t\t\t\t\t_ = stream.Send(&pb.LogEntry{\n   698→\t\t\t\t\t\tType:      \"run_completed\",\n   699→\t\t\t\t\t\tResult:    string(r.State),\n   700→\t\t\t\t\t\tTimestamp: r.CompletedAt.String(),\n   701→\t\t\t\t\t\tMessage:   r.ErrorMessage,\n   702→\t\t\t\t\t})\n   703→\t\t\t\t}\n   704→\t\t\t\treturn nil\n   705→\t\t\t}\n   706→\t\t\tif err := stream.Send(&pb.LogEntry{\n   707→\t\t\t\tType:      \"log\",\n   708→\t\t\t\tStepName:  line.StepName,\n   709→\t\t\t\tMessage:   line.Content,\n   710→\t\t\t\tTimestamp: line.Timestamp,\n   711→\t\t\t}); err != nil {\n   712→\t\t\t\treturn err\n   713→\t\t\t}\n   714→\t\t}\n   715→\t}\n   716→}\n   717→\n   718→// streamFilteredLogs serves log content filtered by step name and/or log type.\n   719→// It uses the log index when available, falling back to file path conventions.\n   720→func (s *ClocheServer) streamFilteredLogs(ctx context.Context, req *pb.StreamLogsRequest, run *domain.Run, stream rpcgrpc.ServerStreamingServer[pb.LogEntry], limit int) error {\n   721→\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\")\n   722→\n   723→\t// Try log index first\n   724→\tif s.logStore != nil {\n   725→\t\tvar logFiles []*ports.LogFileEntry\n   726→\t\tvar err error\n   727→\n   728→\t\tif req.StepName != \"\" && req.LogType != \"\" {\n   729→\t\t\t// Filter by both step and type\n   730→\t\t\tlogFiles, err = s.logStore.GetLogFilesByStep(ctx, req.RunId, req.StepName)\n   731→\t\t\tif err == nil {\n   732→\t\t\t\tfiltered := logFiles[:0]\n   733→\t\t\t\tfor _, lf := range logFiles {\n   734→\t\t\t\t\tif lf.FileType == req.LogType {\n   735→\t\t\t\t\t\tfiltered = append(filtered, lf)\n   736→\t\t\t\t\t}\n   737→\t\t\t\t}\n   738→\t\t\t\tlogFiles = filtered\n   739→\t\t\t}\n   740→\t\t} else if req.StepName != \"\" {\n   741→\t\t\tlogFiles, err = s.logStore.GetLogFilesByStep(ctx, req.RunId, req.StepName)\n   742→\t\t} else {\n   743→\t\t\tlogFiles, err = s.logStore.GetLogFileByType(ctx, req.RunId, req.LogType)\n   744→\t\t}\n   745→\n   746→\t\tif err == nil && len(logFiles) > 0 {\n   747→\t\t\tfor _, lf := range logFiles {\n   748→\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n   749→\t\t\t\tif readErr != nil {\n   750→\t\t\t\t\tcontinue\n   751→\t\t\t\t}\n   752→\t\t\t\tif err := stream.Send(&pb.LogEntry{\n   753→\t\t\t\t\tType:     lf.FileType + \"_log\",\n   754→\t\t\t\t\tStepName: lf.StepName,\n   755→\t\t\t\t\tMessage:  applyLimit(string(data), limit),\n   756→\t\t\t\t}); err != nil {\n   757→\t\t\t\t\treturn err\n   758→\t\t\t\t}\n   759→\t\t\t}\n   760→\t\t\treturn nil\n   761→\t\t}\n   762→\t}\n   763→\n   764→\t// Fall back to file path conventions\n   765→\tif req.StepName != \"\" {\n   766→\t\tvar logPath string\n   767→\t\tswitch req.LogType {\n   768→\t\tcase \"llm\":\n   769→\t\t\tlogPath = filepath.Join(outputDir, \"llm-\"+req.StepName+\".log\")\n   770→\t\tdefault:\n   771→\t\t\tlogPath = filepath.Join(outputDir, req.StepName+\".log\")\n   772→\t\t}\n   773→\n   774→\t\tdata, err := os.ReadFile(logPath)\n   775→\t\tif err != nil {\n   776→\t\t\treturn fmt.Errorf(\"log file not found for step %q: %w\", req.StepName, err)\n   777→\t\t}\n   778→\t\treturn stream.Send(&pb.LogEntry{\n   779→\t\t\tType:     \"step_log\",\n   780→\t\t\tStepName: req.StepName,\n   781→\t\t\tMessage:  applyLimit(string(data), limit),\n   782→\t\t})\n   783→\t}\n   784→\n   785→\treturn fmt.Errorf(\"no log files found matching filter\")\n   786→}\n   787→\n   788→// streamLiveLogs subscribes to the broadcaster and streams log lines in real\n   789→// time for an active run. The stream closes when the run completes or the\n   790→// client disconnects.\n   791→func (s *ClocheServer) streamLiveLogs(runID string, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n   792→\tsub := s.logBroadcast.Subscribe(runID)\n   793→\tdefer s.logBroadcast.Unsubscribe(runID, sub)\n   794→\n   795→\tctx := stream.Context()\n   796→\tfor {\n   797→\t\tselect {\n   798→\t\tcase <-ctx.Done():\n   799→\t\t\treturn ctx.Err()\n   800→\t\tcase line, ok := <-sub.C:\n   801→\t\t\tif !ok {\n   802→\t\t\t\t// Run completed — send terminal entry.\n   803→\t\t\t\trun, err := s.store.GetRun(context.Background(), runID)\n   804→\t\t\t\tif err == nil && run.State != domain.RunStateRunning && run.State != domain.RunStatePending {\n   805→\t\t\t\t\t_ = stream.Send(&pb.LogEntry{\n   806→\t\t\t\t\t\tType:      \"run_completed\",\n   807→\t\t\t\t\t\tResult:    string(run.State),\n   808→\t\t\t\t\t\tTimestamp: run.CompletedAt.String(),\n   809→\t\t\t\t\t\tMessage:   run.ErrorMessage,\n   810→\t\t\t\t\t})\n   811→\t\t\t\t}\n   812→\t\t\t\treturn nil\n   813→\t\t\t}\n   814→\t\t\tif err := stream.Send(&pb.LogEntry{\n   815→\t\t\t\tType:      \"log\",\n   816→\t\t\t\tStepName:  line.StepName,\n   817→\t\t\t\tMessage:   line.Content,\n   818→\t\t\t\tTimestamp: line.Timestamp,\n   819→\t\t\t}); err != nil {\n   820→\t\t\t\treturn err\n   821→\t\t\t}\n   822→\t\t}\n   823→\t}\n   824→}\n   825→\n   826→func (s *ClocheServer) StopRun(ctx context.Context, req *pb.StopRunRequest) (*pb.StopRunResponse, error) {\n   827→\ts.mu.Lock()\n   828→\tcontainerID, ok := s.runIDs[req.RunId]\n   829→\ts.mu.Unlock()\n   830→\n   831→\tif !ok {\n   832→\t\treturn nil, fmt.Errorf(\"run %q not found or already completed\", req.RunId)\n   833→\t}\n   834→\n   835→\tif err := s.container.Stop(ctx, containerID); err != nil {\n   836→\t\treturn nil, fmt.Errorf(\"stopping run: %w\", err)\n   837→\t}\n   838→\n   839→\t// Mark as cancelled in store\n   840→\trun, err := s.store.GetRun(ctx, req.RunId)\n   841→\tif err == nil {\n   842→\t\trun.Complete(domain.RunStateCancelled)\n   843→\t\t_ = s.store.UpdateRun(ctx, run)\n   844→\t}\n   845→\n   846→\treturn &pb.StopRunResponse{}, nil\n   847→}\n   848→\n   849→func (s *ClocheServer) DeleteContainer(ctx context.Context, req *pb.DeleteContainerRequest) (*pb.DeleteContainerResponse, error) {\n   850→\tif s.container == nil {\n   851→\t\treturn nil, fmt.Errorf(\"no container runtime configured\")\n   852→\t}\n   853→\n   854→\tid := req.Id\n   855→\tif id == \"\" {\n   856→\t\treturn nil, fmt.Errorf(\"id is required\")\n   857→\t}\n   858→\n   859→\t// Try to resolve as a run ID first\n   860→\tcontainerID := id\n   861→\trun, err := s.store.GetRun(ctx, id)\n   862→\tif err == nil {\n   863→\t\t// It's a run ID — use the container ID from the run record\n   864→\t\tif run.ContainerID == \"\" {\n   865→\t\t\treturn nil, fmt.Errorf(\"run %q has no associated container\", id)\n   866→\t\t}\n   867→\t\tcontainerID = run.ContainerID\n   868→\t}\n   869→\n   870→\t// Remove the container\n   871→\tif err := s.container.Remove(ctx, containerID); err != nil {\n   872→\t\treturn nil, fmt.Errorf(\"removing container: %w\", err)\n   873→\t}\n   874→\n   875→\t// If we resolved a run, clear the container_kept flag\n   876→\tif run != nil {\n   877→\t\trun.ContainerKept = false\n   878→\t\t_ = s.store.UpdateRun(ctx, run)\n   879→\t}\n   880→\n   881→\treturn &pb.DeleteContainerResponse{}, nil\n   882→}\n   883→\n   884→func (s *ClocheServer) EnableLoop(ctx context.Context, req *pb.EnableLoopRequest) (*pb.EnableLoopResponse, error) {\n   885→\tprojectDir := req.ProjectDir\n   886→\tif projectDir == \"\" {\n   887→\t\treturn nil, fmt.Errorf(\"project_dir is required\")\n   888→\t}\n   889→\n   890→\t// Verify at least one host workflow exists in the project.\n   891→\thostWorkflows, err := host.FindHostWorkflows(projectDir)\n   892→\tif err != nil || len(hostWorkflows) == 0 {\n   893→\t\treturn nil, fmt.Errorf(\"no host workflows found in %s/.cloche/\", projectDir)\n   894→\t}\n   895→\n   896→\t// Load project config for defaults.\n   897→\tprojCfg, _ := config.Load(projectDir)\n   898→\n   899→\tmaxConc := int(req.MaxConcurrent)\n   900→\tif maxConc <= 0 {\n   901→\t\tmaxConc = projCfg.Orchestration.Concurrency\n   902→\t}\n   903→\tif maxConc <= 0 {\n   904→\t\tmaxConc = 1\n   905→\t}\n   906→\n   907→\tstagger := time.Duration(float64(time.Second) * projCfg.Orchestration.StaggerSeconds)\n   908→\n   909→\t// Compute dedup timeout from config (default 5 minutes).\n   910→\tdedupTimeout := time.Duration(float64(time.Second) * projCfg.Orchestration.DedupSeconds)\n   911→\n   912→\tloopCfg := host.LoopConfig{\n   913→\t\tProjectDir:    projectDir,\n   914→\t\tMaxConcurrent: maxConc,\n   915→\t\tStaggerDelay:  stagger,\n   916→\t\tDedupTimeout:  dedupTimeout,\n   917→\t\tStopOnError:   projCfg.Orchestration.StopOnError,\n   918→\t}\n   919→\n   920→\ts.mu.Lock()\n   921→\tdefer s.mu.Unlock()\n   922→\n   923→\t// Stop existing loop if running.\n   924→\tif existing, ok := s.loops[projectDir]; ok {\n   925→\t\texisting.Stop()\n   926→\t}\n   927→\n   928→\t// Check if project defines a list-tasks workflow for three-phase mode.\n   929→\tvar loop *host.Loop\n   930→\tif _, hasListTasks := hostWorkflows[\"list-tasks\"]; hasListTasks {\n   931→\t\tloop = s.createPhaseLoop(loopCfg, projectDir, dedupTimeout)\n   932→\t} else {\n   933→\t\tloop = s.createLegacyLoop(loopCfg, projectDir, projCfg, dedupTimeout)\n   934→\t}\n   935→\n   936→\ts.loops[projectDir] = loop\n   937→\tloop.Start()\n   938→\n   939→\treturn &pb.EnableLoopResponse{}, nil\n   940→}\n   941→\n   942→// createPhaseLoop creates a three-phase orchestration loop using list-tasks,\n   943→// main, and finalize host workflows from any .cloche file.\n   944→func (s *ClocheServer) createPhaseLoop(loopCfg host.LoopConfig, projectDir string, dedupTimeout time.Duration) *host.Loop {\n   945→\t// Phase 1: list-tasks function\n   946→\tlistTasksFn := func(ctx context.Context, projDir string) ([]host.Task, error) {\n   947→\t\trunner := &host.Runner{\n   948→\t\t\tDispatcher: s,\n   949→\t\t\tStore:      s.store,\n   950→\t\t}\n   951→\t\ttasks, _, err := host.RunListTasksWorkflow(ctx, runner, projDir)\n   952→\t\treturn tasks, err\n   953→\t}\n   954→\n   955→\t// Phase 2: main function\n   956→\tmainFn := func(ctx context.Context, projDir string, taskID string) (*host.RunResult, error) {\n   957→\t\trunner := &host.Runner{\n   958→\t\t\tDispatcher:   s,\n   959→\t\t\tStore:        s.store,\n   960→\t\t\tCaptures:     s.captures,\n   961→\t\t\tLogBroadcast: s.logBroadcast,\n   962→\t\t\tTaskID:       taskID,\n   963→\t\t}\n   964→\t\treturn runner.RunNamed(ctx, projDir, \"main\")\n   965→\t}\n   966→\n   967→\t// Phase 3: finalize function (optional — only if a finalize host workflow exists)\n   968→\tvar finalizeFn host.FinalizeFunc\n   969→\tif hostWFs, err := host.FindHostWorkflows(projectDir); err == nil {\n   970→\t\tif _, hasFinalize := hostWFs[\"finalize\"]; hasFinalize {\n   971→\t\t\tfinalizeFn = func(ctx context.Context, projDir string, taskID string, mainResult *host.RunResult) (*host.RunResult, error) {\n   972→\t\t\t\tmainRunID := \"\"\n   973→\t\t\t\tmainOutcome := \"failed\"\n   974→\t\t\t\tif mainResult != nil {\n   975→\t\t\t\t\tmainRunID = mainResult.RunID\n   976→\t\t\t\t\tmainOutcome = string(mainResult.State)\n   977→\t\t\t\t}\n   978→\t\t\t\trunner := &host.Runner{\n   979→\t\t\t\t\tDispatcher:   s,\n   980→\t\t\t\t\tStore:        s.store,\n   981→\t\t\t\t\tCaptures:     s.captures,\n   982→\t\t\t\t\tLogBroadcast: s.logBroadcast,\n   983→\t\t\t\t\tTaskID:       taskID,\n   984→\t\t\t\t\tExtraEnv: []string{\n   985→\t\t\t\t\t\t\"CLOCHE_MAIN_RUN_ID=\" + mainRunID,\n   986→\t\t\t\t\t\t\"CLOCHE_MAIN_OUTCOME=\" + mainOutcome,\n   987→\t\t\t\t\t},\n   988→\t\t\t\t}\n   989→\t\t\t\treturn runner.RunNamed(ctx, projDir, \"finalize\")\n   990→\t\t\t}\n   991→\t\t}\n   992→\t}\n   993→\n   994→\tlog.Printf(\"orchestration loop: three-phase mode enabled for %s (list-tasks + main + finalize, dedup=%s)\", projectDir, dedupTimeout)\n   995→\treturn host.NewPhaseLoop(loopCfg, s.store, listTasksFn, mainFn, finalizeFn)\n   996→}\n   997→\n   998→// createLegacyLoop creates a legacy single-function orchestration loop.\n   999→func (s *ClocheServer) createLegacyLoop(loopCfg host.LoopConfig, projectDir string, projCfg *config.Config, dedupTimeout time.Duration) *host.Loop {\n  1000→\trunFn := func(ctx context.Context, projDir string, taskID string) (*host.RunResult, error) {\n  1001→\t\trunner := &host.Runner{\n  1002→\t\t\tDispatcher:   s,\n  1003→\t\t\tStore:        s.store,\n  1004→\t\t\tCaptures:     s.captures,\n  1005→\t\t\tLogBroadcast: s.logBroadcast,\n  1006→\t\t\tTaskID:       taskID,\n  1007→\t\t}\n  1008→\t\treturn runner.Run(ctx, projDir)\n  1009→\t}\n  1010→\n  1011→\tloop := host.NewLoop(loopCfg, s.store, runFn)\n  1012→\n  1013→\t// Configure daemon-managed task assignment if a list-tasks command is set.\n  1014→\tif cmd := projCfg.Orchestration.ListTasksCommand; cmd != \"\" {\n  1015→\t\tloop.SetTaskAssigner(&host.ScriptTaskAssigner{Command: cmd})\n  1016→\t\tlog.Printf(\"orchestration loop: task assignment enabled for %s (command=%q, dedup=%s)\", projectDir, cmd, dedupTimeout)\n  1017→\t}\n  1018→\n  1019→\treturn loop\n  1020→}\n  1021→\n  1022→// GetLoopTasks returns the current task pipeline state for a project's\n  1023→// orchestration loop, formatted as web.TaskEntry values. Returns nil if no\n  1024→// loop is active for the project.\n  1025→func (s *ClocheServer) GetLoopTasks(projectDir string) []web.TaskEntry {\n  1026→\ts.mu.Lock()\n  1027→\tloop, ok := s.loops[projectDir]\n  1028→\ts.mu.Unlock()\n  1029→\tif !ok {\n  1030→\t\treturn nil\n  1031→\t}\n  1032→\tsnapshot := loop.GetTaskSnapshot()\n  1033→\n  1034→\t// Build a set of task IDs that have active (pending/running) runs.\n  1035→\tactiveTaskIDs := make(map[string]bool)\n  1036→\tctx := context.Background()\n  1037→\tallRuns, _ := s.store.ListRunsByProject(ctx, projectDir, time.Time{})\n  1038→\tfor _, r := range allRuns {\n  1039→\t\tif r.TaskID != \"\" && (r.State == domain.RunStatePending || r.State == domain.RunStateRunning) {\n  1040→\t\t\tactiveTaskIDs[r.TaskID] = true\n  1041→\t\t}\n  1042→\t}\n  1043→\n  1044→\tentries := make([]web.TaskEntry, len(snapshot))\n  1045→\tfor i, e := range snapshot {\n  1046→\t\tentry := web.TaskEntry{\n  1047→\t\t\tID:          e.Task.ID,\n  1048→\t\t\tStatus:      e.Task.Status,\n  1049→\t\t\tTitle:       e.Task.Title,\n  1050→\t\t\tDescription: e.Task.Description,\n  1051→\t\t\tMetadata:    e.Task.Metadata,\n  1052→\t\t\tAssigned:    e.Assigned,\n  1053→\t\t\tRunID:       e.RunID,\n  1054→\t\t}\n  1055→\t\tif !e.AssignedAt.IsZero() {\n  1056→\t\t\tentry.AssignedAt = e.AssignedAt.Format(time.RFC3339)\n  1057→\t\t}\n  1058→\t\t// Stale: task is in_progress but has no active worker.\n  1059→\t\tif host.TaskStatus(e.Task.Status) == host.TaskStatusInProgress && !activeTaskIDs[e.Task.ID] {\n  1060→\t\t\tentry.Stale = true\n  1061→\t\t}\n  1062→\t\tentries[i] = entry\n  1063→\t}\n  1064→\treturn entries\n  1065→}\n  1066→\n  1067→// ReleaseTask runs the release-task host workflow for a specific task,\n  1068→// returning it to open status.\n  1069→func (s *ClocheServer) ReleaseTask(ctx context.Context, projectDir string, taskID string) error {\n  1070→\trunner := &host.Runner{\n  1071→\t\tDispatcher:   s,\n  1072→\t\tStore:        s.store,\n  1073→\t\tCaptures:     s.captures,\n  1074→\t\tLogBroadcast: s.logBroadcast,\n  1075→\t\tTaskID:       taskID,\n  1076→\t}\n  1077→\tresult, err := runner.RunNamed(ctx, projectDir, \"release-task\")\n  1078→\tif err != nil {\n  1079→\t\treturn fmt.Errorf(\"release-task workflow failed: %w\", err)\n  1080→\t}\n  1081→\tif result.State != domain.RunStateSucceeded {\n  1082→\t\treturn fmt.Errorf(\"release-task workflow finished with state %s\", result.State)\n  1083→\t}\n  1084→\treturn nil\n  1085→}\n  1086→\n  1087→func (s *ClocheServer) DisableLoop(ctx context.Context, req *pb.DisableLoopRequest) (*pb.DisableLoopResponse, error) {\n  1088→\tprojectDir := req.ProjectDir\n  1089→\tif projectDir == \"\" {\n  1090→\t\treturn nil, fmt.Errorf(\"project_dir is required\")\n  1091→\t}\n  1092→\n  1093→\ts.mu.Lock()\n  1094→\tdefer s.mu.Unlock()\n  1095→\n  1096→\tif loop, ok := s.loops[projectDir]; ok {\n  1097→\t\tloop.Stop()\n  1098→\t\tdelete(s.loops, projectDir)\n  1099→\t}\n  1100→\n  1101→\treturn &pb.DisableLoopResponse{}, nil\n  1102→}\n  1103→\n  1104→func (s *ClocheServer) ResumeLoop(ctx context.Context, req *pb.ResumeLoopRequest) (*pb.ResumeLoopResponse, error) {\n  1105→\tprojectDir := req.ProjectDir\n  1106→\tif projectDir == \"\" {\n  1107→\t\treturn nil, fmt.Errorf(\"project_dir is required\")\n  1108→\t}\n  1109→\n  1110→\ts.mu.Lock()\n  1111→\tloop, ok := s.loops[projectDir]\n  1112→\ts.mu.Unlock()\n  1113→\n  1114→\tif !ok || loop == nil {\n  1115→\t\treturn nil, fmt.Errorf(\"no orchestration loop for %s\", projectDir)\n  1116→\t}\n  1117→\n  1118→\tloop.Resume()\n  1119→\treturn &pb.ResumeLoopResponse{}, nil\n  1120→}\n  1121→\n  1122→func (s *ClocheServer) GetProjectInfo(ctx context.Context, req *pb.GetProjectInfoRequest) (*pb.GetProjectInfoResponse, error) {\n  1123→\tprojectDir := req.ProjectDir\n  1124→\n  1125→\t// Resolve by name if provided.\n  1126→\tif req.Name != \"\" && projectDir == \"\" {\n  1127→\t\tprojects, err := s.store.ListProjects(ctx)\n  1128→\t\tif err != nil {\n  1129→\t\t\treturn nil, fmt.Errorf(\"listing projects: %w\", err)\n  1130→\t\t}\n  1131→\t\tlabels := projectLabels(projects)\n  1132→\t\tfound := false\n  1133→\t\tfor dir, label := range labels {\n  1134→\t\t\tif label == req.Name {\n  1135→\t\t\t\tprojectDir = dir\n  1136→\t\t\t\tfound = true\n  1137→\t\t\t\tbreak\n  1138→\t\t\t}\n  1139→\t\t}\n  1140→\t\tif !found {\n  1141→\t\t\treturn nil, fmt.Errorf(\"project %q not found\", req.Name)\n  1142→\t\t}\n  1143→\t}\n  1144→\n  1145→\tif projectDir == \"\" {\n  1146→\t\treturn nil, fmt.Errorf(\"project_dir or name is required\")\n  1147→\t}\n  1148→\n  1149→\t// Derive project label.\n  1150→\tprojects, _ := s.store.ListProjects(ctx)\n  1151→\tlabels := projectLabels(projects)\n  1152→\tlabel := labels[projectDir]\n  1153→\tif label == \"\" {\n  1154→\t\tlabel = filepath.Base(projectDir)\n  1155→\t}\n  1156→\n  1157→\t// Load config.\n  1158→\tcfg, _ := config.Load(projectDir)\n  1159→\n  1160→\t// Check loop state.\n  1161→\ts.mu.Lock()\n  1162→\tloop, loopExists := s.loops[projectDir]\n  1163→\ts.mu.Unlock()\n  1164→\tloopRunning := loopExists && loop != nil && loop.Running()\n  1165→\n  1166→\t// Get active runs.\n  1167→\tallRuns, _ := s.store.ListRunsByProject(ctx, projectDir, time.Time{})\n  1168→\tvar activeRuns []*pb.RunSummary\n  1169→\tfor _, run := range allRuns {\n  1170→\t\tif run.State == domain.RunStatePending || run.State == domain.RunStateRunning {\n  1171→\t\t\tactiveRuns = append(activeRuns, &pb.RunSummary{\n  1172→\t\t\t\tRunId:        run.ID,\n  1173→\t\t\t\tWorkflowName: run.WorkflowName,\n  1174→\t\t\t\tState:        string(run.State),\n  1175→\t\t\t\tStartedAt:    run.StartedAt.String(),\n  1176→\t\t\t\tTitle:        run.Title,\n  1177→\t\t\t\tIsHost:       run.IsHost,\n  1178→\t\t\t\tContainerId:  run.ContainerID,\n  1179→\t\t\t})\n  1180→\t\t}\n  1181→\t}\n  1182→\n  1183→\t// Discover workflows.\n  1184→\tvar containerWorkflows, hostWorkflows []string\n  1185→\tclocheDir := filepath.Join(projectDir, \".cloche\")\n  1186→\tentries, _ := filepath.Glob(filepath.Join(clocheDir, \"*.cloche\"))\n  1187→\tfor _, path := range entries {\n  1188→\t\tbase := filepath.Base(path)\n  1189→\t\tdata, err := os.ReadFile(path)\n  1190→\t\tif err != nil {\n  1191→\t\t\tcontinue\n  1192→\t\t}\n  1193→\t\tif base == \"host.cloche\" {\n  1194→\t\t\twfs, err := dsl.ParseAllForHost(string(data))\n  1195→\t\t\tif err != nil {\n  1196→\t\t\t\tcontinue\n  1197→\t\t\t}\n  1198→\t\t\tfor name := range wfs {\n  1199→\t\t\t\thostWorkflows = append(hostWorkflows, name)\n  1200→\t\t\t}\n  1201→\t\t} else {\n  1202→\t\t\twf, err := dsl.ParseForContainer(string(data))\n  1203→\t\t\tif err != nil {\n  1204→\t\t\t\tcontinue\n  1205→\t\t\t}\n  1206→\t\t\tcontainerWorkflows = append(containerWorkflows, wf.Name)\n  1207→\t\t}\n  1208→\t}\n  1209→\n  1210→\tsort.Strings(containerWorkflows)\n  1211→\tsort.Strings(hostWorkflows)\n  1212→\n  1213→\t// Check if loop is halted due to an error.\n  1214→\tvar errorHalted bool\n  1215→\tvar haltError string\n  1216→\tif loopExists && loop != nil {\n  1217→\t\terrorHalted, haltError = loop.Halted()\n  1218→\t}\n  1219→\n  1220→\treturn &pb.GetProjectInfoResponse{\n  1221→\t\tProjectDir:         projectDir,\n  1222→\t\tName:               label,\n  1223→\t\tActive:             cfg.Active,\n  1224→\t\tConcurrency:        int32(cfg.Orchestration.Concurrency),\n  1225→\t\tStaggerSeconds:     cfg.Orchestration.StaggerSeconds,\n  1226→\t\tDedupSeconds:       cfg.Orchestration.DedupSeconds,\n  1227→\t\tEvolutionEnabled:   cfg.Evolution.Enabled,\n  1228→\t\tLoopRunning:        loopRunning,\n  1229→\t\tActiveRuns:         activeRuns,\n  1230→\t\tContainerWorkflows: containerWorkflows,\n  1231→\t\tHostWorkflows:      hostWorkflows,\n  1232→\t\tStopOnError:        cfg.Orchestration.StopOnError,\n  1233→\t\tErrorHalted:        errorHalted,\n  1234→\t\tHaltError:          haltError,\n  1235→\t}, nil\n  1236→}\n  1237→\n  1238→// projectLabels maps each project directory to a short display label.\n  1239→// Uses basename unless there are conflicts, in which case parent/basename is used.\n  1240→func projectLabels(dirs []string) map[string]string {\n  1241→\tlabels := make(map[string]string, len(dirs))\n  1242→\tbyBase := map[string][]string{}\n  1243→\tfor _, d := range dirs {\n  1244→\t\tbase := filepath.Base(d)\n  1245→\t\tbyBase[base] = append(byBase[base], d)\n  1246→\t}\n  1247→\tfor base, paths := range byBase {\n  1248→\t\tif len(paths) == 1 {\n  1249→\t\t\tlabels[paths[0]] = base\n  1250→\t\t} else {\n  1251→\t\t\tfor _, p := range paths {\n  1252→\t\t\t\tparent := filepath.Base(filepath.Dir(p))\n  1253→\t\t\t\tlabels[p] = parent + \"/\" + base\n  1254→\t\t\t}\n  1255→\t\t}\n  1256→\t}\n  1257→\treturn labels\n  1258→}\n  1259→\n  1260→func (s *ClocheServer) GetVersion(ctx context.Context, req *pb.GetVersionRequest) (*pb.GetVersionResponse, error) {\n  1261→\treturn &pb.GetVersionResponse{Version: version.Version()}, nil\n  1262→}\n  1263→\n  1264→func (s *ClocheServer) Shutdown(ctx context.Context, req *pb.ShutdownRequest) (*pb.ShutdownResponse, error) {\n  1265→\tif !req.Force {\n  1266→\t\t// Check for active container runs.\n  1267→\t\ts.mu.Lock()\n  1268→\t\tactiveRuns := len(s.runIDs)\n  1269→\t\ts.mu.Unlock()\n  1270→\t\tif activeRuns > 0 {\n  1271→\t\t\treturn nil, fmt.Errorf(\"cannot shutdown: %d run(s) still active (use --force to override)\", activeRuns)\n  1272→\t\t}\n  1273→\t}\n  1274→\n  1275→\t// Stop all orchestration loops.\n  1276→\ts.mu.Lock()\n  1277→\tfor _, loop := range s.loops {\n  1278→\t\tloop.Stop()\n  1279→\t}\n  1280→\ts.loops = make(map[string]*host.Loop)\n  1281→\ts.mu.Unlock()\n  1282→\n  1283→\tif s.shutdownFn == nil {\n  1284→\t\treturn nil, fmt.Errorf(\"shutdown not configured\")\n  1285→\t}\n  1286→\tgo s.shutdownFn()\n  1287→\treturn &pb.ShutdownResponse{}, nil\n  1288→}\n  1289→\n  1290→// indexLogFiles scans the extracted output directory and creates log_files index entries.\n  1291→func (s *ClocheServer) indexLogFiles(ctx context.Context, runID, outputDir string) {\n  1292→\tentries, err := os.ReadDir(outputDir)\n  1293→\tif err != nil {\n  1294→\t\tlog.Printf(\"run %s: failed to read output dir for indexing: %v\", runID, err)\n  1295→\t\treturn\n  1296→\t}\n  1297→\n  1298→\tnow := time.Now()\n  1299→\tfor _, entry := range entries {\n  1300→\t\tif entry.IsDir() {\n  1301→\t\t\tcontinue\n  1302→\t\t}\n  1303→\t\tname := entry.Name()\n  1304→\t\tif !strings.HasSuffix(name, \".log\") {\n  1305→\t\t\tcontinue\n  1306→\t\t}\n  1307→\n  1308→\t\tvar fileType, stepName string\n  1309→\t\tbase := strings.TrimSuffix(name, \".log\")\n  1310→\n  1311→\t\tswitch {\n  1312→\t\tcase name == \"full.log\":\n  1313→\t\t\tfileType = \"full\"\n  1314→\t\tcase name == \"container.log\":\n  1315→\t\t\t// container.log is internal, not indexed as a user-facing log type\n  1316→\t\t\tcontinue\n  1317→\t\tcase strings.HasPrefix(name, \"llm-\"):\n  1318→\t\t\tfileType = \"llm\"\n  1319→\t\t\tstepName = strings.TrimPrefix(base, \"llm-\")\n  1320→\t\tdefault:\n  1321→\t\t\tfileType = \"script\"\n  1322→\t\t\tstepName = base\n  1323→\t\t}\n  1324→\n  1325→\t\tinfo, _ := entry.Info()\n  1326→\t\tvar fileSize int64\n  1327→\t\tif info != nil {\n  1328→\t\t\tfileSize = info.Size()\n  1329→\t\t}\n  1330→\n  1331→\t\tlogEntry := &ports.LogFileEntry{\n  1332→\t\t\tRunID:     runID,\n  1333→\t\t\tStepName:  stepName,\n  1334→\t\t\tFileType:  fileType,\n  1335→\t\t\tFilePath:  filepath.Join(outputDir, name),\n  1336→\t\t\tFileSize:  fileSize,\n  1337→\t\t\tCreatedAt: now,\n  1338→\t\t}\n  1339→\t\tif err := s.logStore.SaveLogFile(ctx, logEntry); err != nil {\n  1340→\t\t\tlog.Printf(\"run %s: failed to index log file %s: %v\", runID, name, err)\n  1341→\t\t}\n  1342→\t}\n  1343→}\n  1344→\n  1345→func gitHEAD(dir string) string {\n  1346→\tcmd := exec.Command(\"git\", \"rev-parse\", \"HEAD\")\n  1347→\tcmd.Dir = dir\n  1348→\tout, err := cmd.Output()\n  1349→\tif err != nil {\n  1350→\t\treturn \"\"\n  1351→\t}\n  1352→\treturn strings.TrimSpace(string(out))\n  1353→}\n  1354→"}]},"parent_tool_use_id":"toolu_01Hx8s7aitb3QT6sN4LQiG7X","session_id":"f29cf043-1251-4213-84f2-becb34ef1768","uuid":"9b5f95e3-221f-4baa-a60f-d06162da897e"}
