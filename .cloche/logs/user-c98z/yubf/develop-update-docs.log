{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016fASgxR7797ZNtcXugx3yg","type":"tool_result","content":"     1→package ports\n     2→\n     3→import \"context\"\n     4→\n     5→// TrackerTask represents a task from an external task tracker.\n     6→type TrackerTask struct {\n     7→\tID          string\n     8→\tTitle       string\n     9→\tDescription string\n    10→\tAcceptance  string\n    11→\tLabels      []string\n    12→\tPriority    int\n    13→}\n    14→\n    15→// TaskTracker provides access to an external task tracking system.\n    16→type TaskTracker interface {\n    17→\tListReady(ctx context.Context, project string) ([]TrackerTask, error)\n    18→\tClaim(ctx context.Context, taskID string) error\n    19→\tComplete(ctx context.Context, taskID string) error\n    20→\tFail(ctx context.Context, taskID string) error\n    21→}\n    22→"}]},"parent_tool_use_id":"toolu_01YDrwufo4EVasQfVLwbPGNy","session_id":"4fdefc21-58a5-4b42-a6f6-efcac5882b09","uuid":"889ce73c-d60b-4ed1-91de-879132485bc1"}
