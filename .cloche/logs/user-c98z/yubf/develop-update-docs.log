{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012sHZM2KmTmYjSWYLwhPLaq","type":"tool_result","content":"     1→package main\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"fmt\"\n     6→\t\"net\"\n     7→\t\"net/http\"\n     8→\t\"os\"\n     9→\t\"os/signal\"\n    10→\t\"path/filepath\"\n    11→\t\"syscall\"\n    12→\n    13→\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    14→\t\"github.com/cloche-dev/cloche/internal/adapters/docker\"\n    15→\tadaptgrpc \"github.com/cloche-dev/cloche/internal/adapters/grpc\"\n    16→\t\"github.com/cloche-dev/cloche/internal/adapters/local\"\n    17→\t\"github.com/cloche-dev/cloche/internal/adapters/sqlite\"\n    18→\t\"github.com/cloche-dev/cloche/internal/adapters/web\"\n    19→\t\"github.com/cloche-dev/cloche/internal/config\"\n    20→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    21→\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    22→\t\"github.com/cloche-dev/cloche/internal/evolution\"\n    23→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    24→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    25→\t\"google.golang.org/grpc\"\n    26→)\n    27→\n    28→func main() {\n    29→\t// Load global config file (~/.config/cloche/config)\n    30→\tglobalCfg, err := config.LoadGlobal()\n    31→\tif err != nil {\n    32→\t\tfmt.Fprintf(os.Stderr, \"warning: failed to load global config: %v\\n\", err)\n    33→\t\tdefaults := config.Config{}\n    34→\t\tglobalCfg = &defaults\n    35→\t}\n    36→\n    37→\tdbPath := envOrConfig(\"CLOCHE_DB\", globalCfg.Daemon.DB, \"cloche.db\")\n    38→\tlistenAddr := envOrConfig(\"CLOCHE_LISTEN\", globalCfg.Daemon.Listen, \"unix:///tmp/cloche.sock\")\n    39→\n    40→\tstore, err := sqlite.NewStore(dbPath)\n    41→\tif err != nil {\n    42→\t\tfmt.Fprintf(os.Stderr, \"failed to open store: %v\\n\", err)\n    43→\t\tos.Exit(1)\n    44→\t}\n    45→\tdefer store.Close()\n    46→\n    47→\t// Sweep stale runs from a previous daemon crash (pending or running with no live goroutine).\n    48→\tif n, err := store.FailStaleRuns(context.Background()); err != nil {\n    49→\t\tfmt.Fprintf(os.Stderr, \"warning: failed to sweep stale runs: %v\\n\", err)\n    50→\t} else if n > 0 {\n    51→\t\tfmt.Fprintf(os.Stderr, \"startup: marked %d stale run(s) as failed\\n\", n)\n    52→\t}\n    53→\n    54→\truntime, err := initRuntime(globalCfg)\n    55→\tif err != nil {\n    56→\t\tfmt.Fprintf(os.Stderr, \"failed to init runtime: %v\\n\", err)\n    57→\t\tos.Exit(1)\n    58→\t}\n    59→\n    60→\tdefaultImage := envOrConfig(\"CLOCHE_IMAGE\", globalCfg.Daemon.Image, \"cloche-agent:latest\")\n    61→\n    62→\tbroadcaster := logstream.NewBroadcaster()\n    63→\n    64→\tsrv := adaptgrpc.NewClocheServerWithCaptures(store, store, runtime, defaultImage)\n    65→\tsrv.SetLogStore(store)\n    66→\tsrv.SetLogBroadcaster(broadcaster)\n    67→\n    68→\t// Set up evolution trigger\n    69→\tevoTrigger := initEvolution(globalCfg, store, store)\n    70→\tif evoTrigger != nil {\n    71→\t\tsrv.SetEvolution(evoTrigger)\n    72→\t}\n    73→\n    74→\tgrpcServer := grpc.NewServer()\n    75→\tpb.RegisterClocheServiceServer(grpcServer, srv)\n    76→\n    77→\tsrv.SetShutdownFunc(func() { grpcServer.GracefulStop() })\n    78→\n    79→\tlis, err := listen(listenAddr)\n    80→\tif err != nil {\n    81→\t\tfmt.Fprintf(os.Stderr, \"failed to listen on %s: %v\\n\", listenAddr, err)\n    82→\t\tos.Exit(1)\n    83→\t}\n    84→\n    85→\tvar httpServer *http.Server\n    86→\tif httpAddr := envOrConfig(\"CLOCHE_HTTP\", globalCfg.Daemon.HTTP, \"\"); httpAddr != \"\" {\n    87→\t\twebOpts := []web.HandlerOption{\n    88→\t\t\tweb.WithContainerLogger(runtime),\n    89→\t\t\tweb.WithLogStore(store),\n    90→\t\t\tweb.WithLogBroadcaster(broadcaster),\n    91→\t\t}\n    92→\t\twebHandler, err := web.NewHandler(store, store, webOpts...)\n    93→\t\tif err != nil {\n    94→\t\t\tfmt.Fprintf(os.Stderr, \"failed to create web handler: %v\\n\", err)\n    95→\t\t\tos.Exit(1)\n    96→\t\t}\n    97→\t\thttpServer = &http.Server{Addr: httpAddr, Handler: webHandler}\n    98→\t\tgo func() {\n    99→\t\t\tfmt.Fprintf(os.Stderr, \"cloched web dashboard on http://%s\\n\", httpAddr)\n   100→\t\t\tif err := httpServer.ListenAndServe(); err != nil && err != http.ErrServerClosed {\n   101→\t\t\t\tfmt.Fprintf(os.Stderr, \"http server error: %v\\n\", err)\n   102→\t\t\t}\n   103→\t\t}()\n   104→\t}\n   105→\n   106→\t// Auto-execute main workflow for active projects\n   107→\tautoRunActiveProjects(store, srv)\n   108→\n   109→\tsigCh := make(chan os.Signal, 1)\n   110→\tsignal.Notify(sigCh, syscall.SIGTERM, syscall.SIGINT)\n   111→\tgo func() {\n   112→\t\t<-sigCh\n   113→\t\tif httpServer != nil {\n   114→\t\t\thttpServer.Close()\n   115→\t\t}\n   116→\t\tgrpcServer.GracefulStop()\n   117→\t}()\n   118→\n   119→\tfmt.Fprintf(os.Stderr, \"cloched listening on %s\\n\", listenAddr)\n   120→\tif err := grpcServer.Serve(lis); err != nil {\n   121→\t\tfmt.Fprintf(os.Stderr, \"server error: %v\\n\", err)\n   122→\t\tos.Exit(1)\n   123→\t}\n   124→}\n   125→\n   126→func initRuntime(cfg *config.Config) (ports.ContainerRuntime, error) {\n   127→\truntimeType := envOrConfig(\"CLOCHE_RUNTIME\", cfg.Daemon.Runtime, \"docker\")\n   128→\n   129→\tswitch runtimeType {\n   130→\tcase \"local\":\n   131→\t\tagentPath := envOrConfig(\"CLOCHE_AGENT_PATH\", cfg.Daemon.AgentPath, \"\")\n   132→\t\tif agentPath == \"\" {\n   133→\t\t\t// Look for cloche-agent next to this binary\n   134→\t\t\texe, err := os.Executable()\n   135→\t\t\tif err == nil {\n   136→\t\t\t\tagentPath = filepath.Join(filepath.Dir(exe), \"cloche-agent\")\n   137→\t\t\t} else {\n   138→\t\t\t\tagentPath = \"cloche-agent\"\n   139→\t\t\t}\n   140→\t\t}\n   141→\t\treturn local.NewRuntime(agentPath), nil\n   142→\tcase \"docker\":\n   143→\t\treturn docker.NewRuntime()\n   144→\tdefault:\n   145→\t\treturn nil, fmt.Errorf(\"unknown runtime: %s\", runtimeType)\n   146→\t}\n   147→}\n   148→\n   149→func initEvolution(globalCfg *config.Config, evoStore ports.EvolutionStore, capStore ports.CaptureStore) *evolution.Trigger {\n   150→\t// Load config from working directory (daemon-level defaults)"}]},"parent_tool_use_id":"toolu_01YDrwufo4EVasQfVLwbPGNy","session_id":"4fdefc21-58a5-4b42-a6f6-efcac5882b09","uuid":"99856621-ace4-4556-90a7-b8e9cb8e21d9"}
