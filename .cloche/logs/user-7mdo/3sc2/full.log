ns yet.</td></tr>\n    43→    {{end}}\n    44→    </tbody>\n    45→</table>\n    46→{{end}}\n    47→\n    48→{{define \"scripts\"}}\n    49→<script>\n    50→(function() {\n    51→    var currentProject = '{{.ProjectFilter}}';\n    52→\n    53→    function filterByProject(dir) {\n    54→        if (dir) {\n    55→            window.location.href = '/runs?project=' + encodeURIComponent(dir);\n    56→        } else {\n    57→            window.location.href = '/runs';\n    58→        }\n    59→    }\n    60→    window.filterByProject = filterByProject;\n    61→\n    62→    function poll() {\n    63→        var url = '/api/runs';\n    64→        if (currentProject) {\n    65→            url += '?project=' + encodeURIComponent(currentProject);\n    66→        }\n    67→        fetch(url)\n    68→            .then(function(r) { return r.json(); })\n    69→            .then(function(runs) {\n    70→                var tbody = document.getElementById('runs-body');\n    71→                if (!runs || runs.length === 0) {\n    72→                    tbody.innerHTML = '<tr><td colspan=\"8\" class=\"empty\">No runs yet.</td></tr>';\n    73→                    return;\n    74→                }\n    75→                var html = '';\n    76→                for (var i = 0; i < runs.length; i++) {\n    77→                    var r = runs[i];\n    78→                    var cid = r.container_id || '';\n    79→                    if (cid.length > 12) cid = cid.substring(0, 12);\n    80→                    var err = r.error_message || '';\n    81→                    if (err.length > 80) err = err.substring(0, 80) + '...';\n    82→                    var proj = r.project_label || '';\n    83→                    html += '<tr>' +\n    84→                        '<td><a href=\"/runs/' + r.id + '\">' + r.id + '</a></td>' +\n    85→                        '<td>' + escapeHtml(proj) + '</td>' +\n    86→                        '<td>' + r.workflow_name + '</td>' +\n    87→                        '<td><span class=\"badge badge-' + r.state + '\">' + r.state + '</span></td>' +\n    88→                        '<td>' + r.started_at + '</td>' +\n    89→                        '<td>' + r.completed_at + '</td>' +\n    90→                        '<td class=\"mono\">' + cid + '</td>' +\n    91→                        '<td class=\"error-cell\">' + escapeHtml(err) + '</td>' +\n    92→                        '</tr>';\n    93→                }\n    94→                tbody.innerHTML = html;\n    95→            })\n    96→            .catch(function() {});\n    97→    }\n    98→    function escapeHtml(s) {\n    99→        var d = document.createElement('div');\n   100→        d.appendChild(document.createTextNode(s));\n   101→        return d.innerHTML;\n   102→    }\n   103→    setInterval(poll, 3000);\n   104→})();\n   105→</script>\n   106→{{end}}\n   107→"}]},"parent_tool_use_id":null,"session_id":"5f6f5120-10f5-44b7-8c12-97c0d3f4d294","uuid":"713077e3-8fe8-41be-94c2-23316cf9e09e","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/web/templates/runs.html","content":"{{define \"content\"}}\n<h1>Runs</h1>\n{{if .Projects}}\n<div class=\"project-filter\">\n    <label for=\"project-select\">Project:</label>\n    <select id=\"project-select\" onchange=\"filterByProject(this.value)\">\n        <option value=\"\">All projects</option>\n        {{range .Projects}}\n        <option value=\"{{.Dir}}\"{{if eq .Dir $.ProjectFilter}} selected{{end}}>{{.Label}}{{if .ContainerCount}} ({{.ContainerCount}} container{{if gt .ContainerCount 1}}s{{end}}){{end}}</option>\n        {{end}}\n    </select>\n</div>\n{{end}}\n<table class=\"runs-table\">\n    <thead>\n        <tr>\n            <th>Run ID</th>\n            <th>Project</th>\n            <th>Workflow</th>\n            <th>State</th>\n            <th>Started</th>\n            <th>Completed</th>\n            <th>Container</th>\n            <th>Error</th>\n        </tr>\n    </thead>\n    <tbody id=\"runs-body\">\n    {{if .Runs}}\n        {{range .Runs}}\n        <tr>\n            <td><a href=\"/runs/{{.ID}}\">{{.ID}}</a></td>\n            <td>{{index $.ProjectLabels .ProjectDir}}</td>\n            <td>{{.WorkflowName}}</td>\n            <td><span class=\"badge badge-{{stateColor .State}}\">{{.State}}</span></td>\n            <td>{{formatTime .StartedAt}}</td>\n            <td>{{formatTime .CompletedAt}}</td>\n            <td class=\"mono\">{{shortContainerID .ContainerID}}</td>\n            <td class=\"error-cell\">{{truncate .ErrorMessage 80}}</td>\n        </tr>\n        {{end}}\n    {{else}}\n        <tr><td colspan=\"8\" class=\"empty\">No runs yet.</td></tr>\n    {{end}}\n    </tbody>\n</table>\n{{end}}\n\n{{define \"scripts\"}}\n<script>\n(function() {\n    var currentProject = '{{.ProjectFilter}}';\n\n    function filterByProject(dir) {\n        if (dir) {\n            window.location.href = '/runs?project=' + encodeURIComponent(dir);\n        } else {\n            window.location.href = '/runs';\n        }\n    }\n    window.filterByProject = filterByProject;\n\n    function poll() {\n        var url = '/api/runs';\n        if (currentProject) {\n            url += '?project=' + encodeURIComponent(currentProject);\n        }\n        fetch(url)\n            .then(function(r) { return r.json(); })\n            .then(function(runs) {\n                var tbody = document.getElementById('runs-body');\n                if (!runs || runs.length === 0) {\n                    tbody.innerHTML = '<tr><td colspan=\"8\" class=\"empty\">No runs yet.</td></tr>';\n                    return;\n                }\n                var html = '';\n                for (var i = 0; i < runs.length; i++) {\n                    var r = runs[i];\n                    var cid = r.container_id || '';\n                    if (cid.length > 12) cid = cid.substring(0, 12);\n                    var err = r.error_message || '';\n                    if (err.length > 80) err = err.substring(0, 80) + '...';\n                    var proj = r.project_label || '';\n                    html += '<tr>' +\n                        '<td><a href=\"/runs/' + r.id + '\">' + r.id + '</a></td>' +\n                        '<td>' + escapeHtml(proj) + '</td>' +\n                        '<td>' + r.workflow_name + '</td>' +\n                        '<td><span class=\"badge badge-' + r.state + '\">' + r.state + '</span></td>' +\n                        '<td>' + r.started_at + '</td>' +\n                        '<td>' + r.completed_at + '</td>' +\n                        '<td class=\"mono\">' + cid + '</td>' +\n                        '<td class=\"error-cell\">' + escapeHtml(err) + '</td>' +\n                        '</tr>';\n                }\n                tbody.innerHTML = html;\n            })\n            .catch(function() {});\n    }\n    function escapeHtml(s) {\n        var d = document.createElement('div');\n        d.appendChild(document.createTextNode(s));\n        return d.innerHTML;\n    }\n    setInterval(poll, 3000);\n})();\n</script>\n{{end}}\n","numLines":107,"startLine":1,"totalLines":107}}}
