"8\" class=\"empty\">No runs yet.</td></tr>\n    43→    {{end}}\n    44→    </tbody>\n    45→</table>\n    46→{{end}}\n    47→\n    48→{{define \"scripts\"}}\n    49→<script>\n    50→(function() {\n    51→    var currentProject = '{{.ProjectFilter}}';\n    52→\n    53→    function filterByProject(dir) {\n    54→        if (dir) {\n    55→            // Find label for this dir from the select options\n    56→            var sel = document.getElementById('project-select');\n    57→            var opt = sel.options[sel.selectedIndex];\n    58→            var label = opt ? opt.getAttribute('data-label') : '';\n    59→            if (label) {\n    60→                window.location.href = '/projects/' + encodeURIComponent(label) + '/runs';\n    61→            } else {\n    62→                window.location.href = '/runs?project=' + encodeURIComponent(dir);\n    63→            }\n    64→        } else {\n    65→            window.location.href = '/runs';\n    66→        }\n    67→    }\n    68→    window.filterByProject = filterByProject;\n    69→\n    70→    function poll() {\n    71→        var url = '/api/runs';\n    72→        if (currentProject) {\n    73→            url += '?project=' + encodeURIComponent(currentProject);\n    74→        }\n    75→        fetch(url)\n    76→            .then(function(r) { return r.json(); })\n    77→            .then(function(runs) {\n    78→                var tbody = document.getElementById('runs-body');\n    79→                if (!runs || runs.length === 0) {\n    80→                    tbody.innerHTML = '<tr><td colspan=\"8\" class=\"empty\">No runs yet.</td></tr>';\n    81→                    return;\n    82→                }\n    83→                var html = '';\n    84→                for (var i = 0; i < runs.length; i++) {\n    85→                    var r = runs[i];\n    86→                    var cid = r.container_id || '';\n    87→                    if (cid.length > 12) cid = cid.substring(0, 12);\n    88→                    var err = r.error_message || '';\n    89→                    if (err.length > 80) err = err.substring(0, 80) + '...';\n    90→                    var proj = r.project_label || '';\n    91→                    html += '<tr>' +\n    92→                        '<td><a href=\"/runs/' + r.id + '\">' + r.id + '</a></td>' +\n    93→                        '<td>' + escapeHtml(proj) + '</td>' +\n    94→                        '<td>' + r.workflow_name + '</td>' +\n    95→                        '<td><span class=\"badge badge-' + r.state + '\">' + r.state + '</span></td>' +\n    96→                        '<td>' + r.started_at + '</td>' +\n    97→                        '<td>' + r.completed_at + '</td>' +\n    98→                        '<td class=\"mono\">' + cid + '</td>' +\n    99→                        '<td class=\"error-cell\">' + escapeHtml(err) + '</td>' +\n   100→                        '</tr>';\n   101→                }\n   102→                tbody.innerHTML = html;\n   103→            })\n   104→            .catch(function() {});\n   105→    }\n   106→    function escapeHtml(s) {\n   107→        var d = document.createElement('div');\n   108→        d.appendChild(document.createTextNode(s));\n   109→        return d.innerHTML;\n   110→    }\n   111→    setInterval(poll, 3000);\n   112→})();\n   113→</script>\n   114→{{end}}\n   115→"}]},"parent_tool_use_id":null,"session_id":"dffb66df-dd3b-46a5-aba4-3641e6ad0853","uuid":"f3e9a2a3-921a-4ef6-9340-f740b5179214","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/web/templates/runs.html","content":"{{define \"content\"}}\n<h1>Runs</h1>\n{{if .Projects}}\n<div class=\"project-filter\">\n    <label for=\"project-select\">Project:</label>\n    <select id=\"project-select\" onchange=\"filterByProject(this.value)\">\n        <option value=\"\">All projects</option>\n        {{range .Projects}}\n        <option value=\"{{.Dir}}\" data-label=\"{{.Label}}\"{{if eq .Dir $.ProjectFilter}} selected{{end}}>{{.Label}}{{if .ContainerCount}} ({{.ContainerCount}} container{{if gt .ContainerCount 1}}s{{end}}){{end}}</option>\n        {{end}}\n    </select>\n</div>\n{{end}}\n<table class=\"runs-table\">\n    <thead>\n        <tr>\n            <th>Run ID</th>\n            <th>Project</th>\n            <th>Workflow</th>\n            <th>State</th>\n            <th>Started</th>\n            <th>Completed</th>\n            <th>Container</th>\n            <th>Error</th>\n        </tr>\n    </thead>\n    <tbody id=\"runs-body\">\n    {{if .Runs}}\n        {{range .Runs}}\n        <tr>\n            <td><a href=\"/runs/{{.ID}}\">{{.ID}}</a></td>\n            <td>{{index $.ProjectLabels .ProjectDir}}</td>\n            <td>{{.WorkflowName}}</td>\n            <td><span class=\"badge badge-{{stateColor .State}}\">{{.State}}</span></td>\n            <td>{{formatTime .StartedAt}}</td>\n            <td>{{formatTime .CompletedAt}}</td>\n            <td class=\"mono\">{{shortContainerID .ContainerID}}</td>\n            <td class=\"error-cell\">{{truncate .ErrorMessage 80}}</td>\n        </tr>\n        {{end}}\n    {{else}}\n        <tr><td colspan=\"8\" class=\"empty\">No runs yet.</td></tr>\n    {{end}}\n    </tbody>\n</table>\n{{end}}\n\n{{define \"scripts\"}}\n<script>\n(function() {\n    var currentProject = '{{.ProjectFilter}}';\n\n    function filterByProject(dir) {\n        if (dir) {\n            // Find label for this dir from the select options\n            var sel = document.getElementById('project-select');\n            var opt = sel.options[sel.selectedIndex];\n            var label = opt ? opt.getAttribute('data-label') : '';\n            if (label) {\n                window.location.href = '/projects/' + encodeURIComponent(label) + '/runs';\n            } else {\n                window.location.href = '/runs?project=' + encodeURIComponent(dir);\n            }\n        } else {\n            window.location.href = '/runs';\n        }\n    }\n    window.filterByProject = filterByProject;\n\n    function poll() {\n        var url = '/api/runs';\n        if (currentProject) {\n            url += '?project=' + encodeURIComponent(currentProject);\n        }\n        fetch(url)\n            .then(function(r) { return r.json(); })\n            .then(function(runs) {\n                var tbody = document.getElementById('runs-body');\n                if (!runs || runs.length === 0) {\n                    tbody.innerHTML = '<tr><td colspan=\"8\" class=\"empty\">No runs yet.</td></tr>';\n                    return;\n                }\n                var html = '';\n                for (var i = 0; i < runs.length; i++) {\n                    var r = runs[i];\n                    var cid = r.container_id || '';\n                    if (cid.length > 12) cid = cid.substring(0, 12);\n                    var err = r.error_message || '';\n                    if (err.length > 80) err = err.substring(0, 80) + '...';\n                    var proj = r.project_label || '';\n                    html += '<tr>' +\n                        '<td><a href=\"/runs/' + r.id + '\">' + r.id + '</a></td>' +\n                        '<td>' + escapeHtml(proj) + '</td>' +\n                        '<td>' + r.workflow_name + '</td>' +\n                        '<td><span class=\"badge badge-' + r.state + '\">' + r.state + '</span></td>' +\n                        '<td>' + r.started_at + '</td>' +\n                        '<td>' + r.completed_at + '</td>' +\n                        '<td class=\"mono\">' + cid + '</td>' +\n                        '<td class=\"error-cell\">' + escapeHtml(err) + '</td>' +\n                        '</tr>';\n                }\n                tbody.innerHTML = html;\n            })\n            .catch(function() {});\n    }\n    function escapeHtml(s) {\n        var d = document.createElement('div');\n        d.appendChild(document.createTextNode(s));\n        return d.innerHTML;\n    }\n    setInterval(poll, 3000);\n})();\n</script>\n{{end}}\n","numLines":115,"startLine":1,"totalLines":115}}}
