rator</button>\n        </div>\n    </div>\n    {{end}}\n</div>\n{{else}}\n<p class=\"empty\">No projects yet. Start a workflow run to see projects here.</p>\n{{end}}\n{{end}}\n\n{{define \"scripts\"}}\n<script>\nfunction triggerOrchestrator(label, dir) {\n    var btn = event.target;\n    btn.disabled = true;\n    btn.textContent = 'Triggering...';\n    fetch('/api/projects/' + encodeURIComponent(label) + '/trigger', {method: 'POST'})\n        .then(function(r) {\n            if (r.ok) {\n                r.json().then(function(data) {\n                    if (data.dispatched > 0) {\n                        btn.textContent = 'Dispatched ' + data.dispatched;\n                    } else {\n                        btn.textContent = 'No tasks ready';\n                    }\n                    setTimeout(function() {\n                        btn.disabled = false;\n                        btn.textContent = 'Trigger Orchestrator';\n                    }, 2000);\n                });\n            } else {\n                r.json().then(function(data) {\n                    btn.textContent = 'Failed: ' + (data.error || 'unknown');\n                }).catch(function() {\n                    btn.textContent = 'Failed';\n                });\n                setTimeout(function() {\n                    btn.disabled = false;\n                    btn.textContent = 'Trigger Orchestrator';\n                }, 4000);\n            }\n        })\n        .catch(function() {\n            btn.textContent = 'Failed';\n            setTimeout(function() {\n                btn.disabled = false;\n                btn.textContent = 'Trigger Orchestrator';\n            }, 2000);\n        });\n}\n</script>\n{{end}}\n","structuredPatch":[{"oldStart":24,"oldLines":7,"newStart":24,"newLines":7,"lines":["             {{end}}","         </div>","         <div class=\"project-actions\">","-            <a href=\"/runs?project={{.Dir}}\" class=\"btn btn-secondary\">View Runs</a>","+            <a href=\"/projects/{{.Label}}/runs\" class=\"btn btn-secondary\">View Runs</a>","             <button class=\"btn btn-primary\" onclick=\"triggerOrchestrator('{{.Label}}', '{{.Dir}}')\">Trigger Orchestrator</button>","         </div>","     </div>"]}],"userModified":false,"replaceAll":false}}
