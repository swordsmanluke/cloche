[2026-03-09T15:40:18Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VG7DtCKrftRq4MmVquTdSx","type":"tool_result","content":"     1→package web\n     2→\n     3→import (\n     4→\t\"bufio\"\n     5→\t\"context\"\n     6→\t\"embed\"\n     7→\t\"encoding/json\"\n     8→\t\"fmt\"\n     9→\t\"html/template\"\n    10→\t\"io/fs\"\n    11→\t\"net/http\"\n    12→\t\"os\"\n    13→\t\"os/exec\"\n    14→\t\"path/filepath\"\n    15→\t\"regexp\"\n    16→\t\"sort\"\n    17→\t\"strconv\"\n    18→\t\"strings\"\n    19→\t\"time\"\n    20→\n    21→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    22→\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    23→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    24→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    25→)\n    26→\n    27→// HandlerOption configures optional Handler dependencies.\n    28→type HandlerOption func(*Handler)\n    29→\n    30→// WithContainerLogger sets the container runtime for fetching live logs.\n    31→func WithContainerLogger(c ContainerLogger) HandlerOption {\n    32→\treturn func(h *Handler) { h.container = c }\n    33→}\n    34→\n    35→// WithContainerManager sets a full container manager (logs, inspect, remove).\n    36→func WithContainerManager(c ContainerManager) HandlerOption {\n    37→\treturn func(h *Handler) { h.container = c }\n    38→}\n    39→\n    40→// WithLogBroadcaster sets the log broadcaster for SSE streaming.\n    41→func WithLogBroadcaster(b *logstream.Broadcaster) HandlerOption {\n    42→\treturn func(h *Handler) { h.logBroadcast = b }\n    43→}\n    44→\n    45→// WithLogStore sets the log store for indexed log file lookups.\n    46→func WithLogStore(ls ports.LogStore) HandlerOption {\n    47→\treturn func(h *Handler) { h.logStore = ls }\n    48→}\n    49→\n    50→// WithOrchestrateFunc sets the function called when the orchestrator is triggered.\n    51→func WithOrchestrateFunc(fn func(ctx context.Context, projectDir string) (int, error)) HandlerOption {\n    52→\treturn func(h *Handler) { h.orchestrateFn = fn }\n    53→}\n    54→\n    55→// OrchestratorController provides per-project orchestrator control.\n    56→type OrchestratorController interface {\n    57→\tStatus(dir string) (enabled bool, inFlight int, concurrency int)\n    58→\tSetEnabled(dir string, enabled bool)\n    59→\tSetConcurrency(dir string, concurrency int)\n    60→}\n    61→\n    62→// WithOrchestrator sets the orchestrator controller for project-level control.\n    63→func WithOrchestrator(oc OrchestratorController) HandlerOption {\n    64→\treturn func(h *Handler) { h.orchestrator = oc }\n    65→}\n    66→\n    67→//go:embed templates/*.html static/*\n    68→var content embed.FS\n    69→\n    70→// Handler serves the web dashboard.\n    71→// ContainerLogger can retrieve logs from a container by ID.\n    72→type ContainerLogger interface {\n    73→\tLogs(ctx context.Context, containerID string) (string, error)\n    74→}\n    75→\n    76→// ContainerManager extends ContainerLogger with container lifecycle operations.\n    77→type ContainerManager interface {\n    78→\tContainerLogger\n    79→\tRemove(ctx context.Context, containerID string) error\n    80→\tInspect(ctx context.Context, containerID string) (*ports.ContainerStatus, error)\n    81→}\n    82→\n    83→type Handler struct {\n    84→\tstore         ports.RunStore\n    85→\tcaptures      ports.CaptureStore\n    86→\tlogStore      ports.LogStore\n    87→\tcontainer     ContainerLogger\n    88→\tlogBroadcast  *logstream.Broadcaster\n    89→\torchestrateFn func(ctx context.Context, projectDir string) (int, error)\n    90→\torchestrator  OrchestratorController\n    91→\tpages         map[string]*template.Template\n    92→\tmux           *http.ServeMux\n    93→}\n    94→\n    95→// NewHandler creates a web dashboard handler.\n    96→func NewHandler(store ports.RunStore, captures ports.CaptureStore, opts ...HandlerOption) (*Handler, error) {\n    97→\tfuncMap := template.FuncMap{\n    98→\t\t\"stateColor\":       stateColor,\n    99→\t\t\"healthColor\":      healthColor,\n   100→\t\t\"formatTime\":       formatTime,\n   101→\t\t\"formatDuration\":   formatDuration,\n   102→\t\t\"truncate\":         truncate,\n   103→\t\t\"shortContainerID\": shortContainerID,\n   104→\t}\n   105→\n   106→\tbase, err := template.New(\"\").Funcs(funcMap).ParseFS(content, \"templates/layout.html\")\n   107→\tif err != nil {\n   108→\t\treturn nil, fmt.Errorf(\"parse layout: %w\", err)\n   109→\t}\n   110→\n   111→\tpages := map[string]*template.Template{}\n   112→\tfor _, page := range []string{\"projects\", \"runs\", \"run_detail\", \"project_detail\"} {\n   113→\t\tclone, err := base.Clone()\n   114→\t\tif err != nil {\n   115→\t\t\treturn nil, fmt.Errorf(\"clone layout for %s: %w\", page, err)\n   116→\t\t}\n   117→\t\t_, err = clone.ParseFS(content, \"templates/\"+page+\".html\")\n   118→\t\tif err != nil {\n   119→\t\t\treturn nil, fmt.Errorf(\"parse %s: %w\", page, err)\n   120→\t\t}\n   121→\t\tpages[page] = clone\n   122→\t}\n   123→\n   124→\th := &Handler{\n   125→\t\tstore:    store,\n   126→\t\tcaptures: captures,\n   127→\t\tpages:    pages,\n   128→\t\tmux:      http.NewServeMux(),\n   129→\t}\n   130→\tfor _, opt := range opts {\n   131→\t\topt(h)\n   132→\t}\n   133→\n   134→\tstaticFS, err := fs.Sub(content, \"static\")\n   135→\tif err != nil {\n   136→\t\treturn nil, fmt.Errorf(\"static sub-fs: %w\", err)\n   137→\t}\n   138→\n   139→\th.mux.HandleFunc(\"GET /{$}\", h.handleProjectOverview)\n   140→\th.mux.HandleFunc(\"GET /runs\", h.handleRunsList)\n   141→\th.mux.HandleFunc(\"GET /runs/{id}\", h.handleRunDetail)\n   142→\th.mux.HandleFunc(\"GET /projects/{name}/runs\", h.handleProjectRuns)\n   143→\th.mux.HandleFunc(\"GET /projects/{name}\", h.handleProjectDetail)\n   144→\th.mux.HandleFunc(\"GET /api/projects\", h.handleAPIProjects)\n   145→\th.mux.HandleFunc(\"GET /api/runs\", h.handleAPIRuns)\n   146→\th.mux.HandleFunc(\"GET /api/runs/{id}\", h.handleAPIRunDetail)\n   147→\th.mux.HandleFunc(\"GET /api/runs/{id}/steps/{step}/output\", h.handleAPIStepOutput)\n   148→\th.mux.HandleFunc(\"DELETE /api/runs/{id}/container\", h.handleAPIDeleteContainer)\n   149→\th.mux.HandleFunc(\"POST /api/projects/{name}/trigger\", h.handleAPITriggerOrchestrator)\n   150→\th.mux.HandleFunc(\"GET /api/projects/{name}/orchestrator\", h.handleAPIOrchestratorStatus)\n   151→\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/start\", h.handleAPIOrchestratorStart)\n   152→\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/stop\", h.handleAPIOrchestratorStop)\n   153→\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/concurrency\", h.handleAPIOrchestratorConcurrency)\n   154→\th.mux.HandleFunc(\"GET /api/projects/{name}/info\", h.handleAPIProjectInfo)\n   155→\th.mux.HandleFunc(\"GET /api/projects/{name}/info/prompt-diff\", h.handleAPIPromptDiff)\n   156→\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows\", h.handleAPIWorkflows)\n   157→\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows/{workflow}/steps/{step}/content\", h.handleAPIStepContent)\n   158→\th.mux.HandleFunc(\"GET /api/runs/{id}/stream\", h.handleAPIStream)\n   159→\th.mux.Handle(\"GET /static/\", http.StripPrefix(\"/static/\", http.FileServerFS(staticFS)))\n   160→\n   161→\treturn h, nil\n   162→}\n   163→\n   164→func (h *Handler) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n   165→\th.mux.ServeHTTP(w, r)\n   166→}\n   167→\n   168→// --- HTML handlers ---\n   169→\n   170→// projectOverviewEntry holds data for a single project card on the landing page.\n   171→type projectOverviewEntry struct {\n   172→\tDir         string\n   173→\tLabel       string\n   174→\tHealth      domain.HealthResult\n   175→\tRecentRuns  []recentRunDot\n   176→\tActiveCount int\n   177→}\n   178→\n   179→// recentRunDot is a minimal representation of a run for the mini history display.\n   180→type recentRunDot struct {\n   181→\tID    string\n   182→\tState string\n   183→}\n   184→\n   185→const healthWindowSize = 10\n   186→\n   187→func (h *Handler) handleProjectOverview(w http.ResponseWriter, r *http.Request) {\n   188→\tprojects, _ := h.store.ListProjects(r.Context())\n   189→\tlabels := projectLabels(projects)\n   190→\n   191→\tvar entries []projectOverviewEntry\n   192→\tfor _, dir := range projects {\n   193→\t\truns, err := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   194→\t\tif err != nil {\n   195→\t\t\tcontinue\n   196→\t\t}\n   197→\n   198→\t\t// Convert []*domain.Run to []domain.Run for CalculateHealth.\n   199→\t\trunValues := make([]domain.Run, len(runs))\n   200→\t\tfor i, rr := range runs {\n   201→\t\t\trunValues[i] = *rr\n   202→\t\t}\n   203→\n   204→\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n   205→\n   206→\t\t// Take the last N runs for the mini history (most recent first).\n   207→\t\tn := healthWindowSize\n   208→\t\tif n > len(runs) {\n   209→\t\t\tn = len(runs)\n   210→\t\t}\n   211→\t\tdots := make([]recentRunDot, n)\n   212→\t\tfor i := 0; i < n; i++ {\n   213→\t\t\tdots[i] = recentRunDot{\n   214→\t\t\t\tID:    runs[i].ID,\n   215→\t\t\t\tState: string(runs[i].State),\n   216→\t\t\t}\n   217→\t\t}\n   218→\n   219→\t\tvar activeCount int\n   220→\t\tfor _, rr := range runs {\n   221→\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n   222→\t\t\t\tactiveCount++\n   223→\t\t\t}\n   224→\t\t}\n   225→\n   226→\t\tentries = append(entries, projectOverviewEntry{\n   227→\t\t\tDir:         dir,\n   228→\t\t\tLabel:       labels[dir],\n   229→\t\t\tHealth:      health,\n   230→\t\t\tRecentRuns:  dots,\n   231→\t\t\tActiveCount: activeCount,\n   232→\t\t})\n   233→\t}\n   234→\n   235→\tsort.Slice(entries, func(i, j int) bool {\n   236→\t\treturn entries[i].Label < entries[j].Label\n   237→\t})\n   238→\n   239→\tdata := map[string]any{\n   240→\t\t\"Title\":    \"Projects\",\n   241→\t\t\"Projects\": entries,\n   242→\t}\n   243→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   244→\tif err := h.pages[\"projects\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   245→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   246→\t}\n   247→}\n   248→\n   249→func (h *Handler) handleRunsList(w http.ResponseWriter, r *http.Request) {\n   250→\tprojectFilter := r.URL.Query().Get(\"project\")\n   251→\n   252→\tvar runs []*domain.Run\n   253→\tvar err error\n   254→\tif projectFilter != \"\" {\n   255→\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n   256→\t} else {\n   257→\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n   258→\t}\n   259→\tif err != nil {\n   260→\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n   261→\t\treturn\n   262→\t}\n   263→\n   264→\tprojects, _ := h.store.ListProjects(r.Context())\n   265→\tlabels := projectLabels(projects)\n   266→\n   267→\t// Count retained containers per project\n   268→\tcontainerCounts := map[string]int{}\n   269→\tallRuns, _ := h.store.ListRuns(r.Context(), time.Time{})\n   270→\tfor _, run := range allRuns {\n   271→\t\tif run.ContainerKept {\n   272→\t\t\tcontainerCounts[run.ProjectDir]++\n   273→\t\t}\n   274→\t}\n   275→\n   276→\tvar projectList []projectEntry\n   277→\tfor _, dir := range projects {\n   278→\t\tprojectList = append(projectList, projectEntry{Dir: dir, Label: labels[dir], ContainerCount: containerCounts[dir]})\n   279→\t}\n   280→\tsort.Slice(projectList, func(i, j int) bool {\n   281→\t\treturn projectList[i].Label < projectList[j].Label\n   282→\t})\n   283→\n   284→\tdata := map[string]any{\n   285→\t\t\"Title\":         \"Runs\",\n   286→\t\t\"Runs\":          runs,\n   287→\t\t\"Projects\":      projectList,\n   288→\t\t\"ProjectFilter\": projectFilter,\n   289→\t\t\"ProjectLabels\": labels,\n   290→\t}\n   291→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   292→\tif err := h.pages[\"runs\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   293→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   294→\t}\n   295→}\n   296→\n   297→func (h *Handler) handleProjectRuns(w http.ResponseWriter, r *http.Request) {\n   298→\tlabel := r.PathValue(\"name\")\n   299→\n   300→\tprojects, _ := h.store.ListProjects(r.Context())\n   301→\tlabels := projectLabels(projects)\n   302→\n   303→\t// Resolve label to project directory.\n   304→\tvar projectDir string\n   305→\tfor dir, l := range labels {\n   306→\t\tif l == label {\n   307→\t\t\tprojectDir = dir\n   308→\t\t\tbreak\n   309→\t\t}\n   310→\t}\n   311→\tif projectDir == \"\" {\n   312→\t\thttp.Error(w, \"project not found\", http.StatusNotFound)\n   313→\t\treturn\n   314→\t}\n   315→\n   316→\truns, err := h.store.ListRunsByProject(r.Context(), projectDir, time.Time{})\n   317→\tif err != nil {\n   318→\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n   319→\t\treturn\n   320→\t}\n   321→\n   322→\t// Count retained containers per project\n   323→\tcontainerCounts := map[string]int{}\n   324→\tallRuns, _ := h.store.ListRuns(r.Context(), time.Time{})\n   325→\tfor _, run := range allRuns {\n   326→\t\tif run.ContainerKept {\n   327→\t\t\tcontainerCounts[run.ProjectDir]++\n   328→\t\t}\n   329→\t}\n   330→\n   331→\tvar projectList []projectEntry\n   332→\tfor _, dir := range projects {\n   333→\t\tprojectList = append(projectList, projectEntry{Dir: dir, Label: labels[dir], ContainerCount: containerCounts[dir]})\n   334→\t}\n   335→\tsort.Slice(projectList, func(i, j int) bool {\n   336→\t\treturn projectList[i].Label < projectList[j].Label\n   337→\t})\n   338→\n   339→\tdata := map[string]any{\n   340→\t\t\"Title\":         \"Runs\",\n   341→\t\t\"Runs\":          runs,\n   342→\t\t\"Projects\":      projectList,\n   343→\t\t\"ProjectFilter\": projectDir,\n   344→\t\t\"ProjectLabel\":  label,\n   345→\t\t\"ProjectLabels\": labels,\n   346→\t}\n   347→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   348→\tif err := h.pages[\"runs\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   349→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   350→\t}\n   351→}\n   352→\n   353→// stepEntry is a merged view of a step execution for the template.\n   354→type stepEntry struct {\n   355→\tIndex     int\n   356→\tStepName  string\n   357→\tResult    string\n   358→\tStartedAt time.Time\n   359→\tDuration  string\n   360→}\n   361→\n   362→// mergeCaptures collapses started/completed capture pairs into single entries.\n   363→func mergeCaptures(caps []*domain.StepExecution) []stepEntry {\n   364→\tvar entries []stepEntry\n   365→\t// Track pending started rows by step name (LIFO for retries)\n   366→\tpending := map[string]*domain.StepExecution{}\n   367→\n   368→\tfor _, c := range caps {\n   369→\t\tif c.Result == \"\" {\n   370→\t\t\t// step_started row\n   371→\t\t\tpending[c.StepName] = c\n   372→\t\t\tcontinue\n   373→\t\t}\n   374→\t\t// step_completed row — merge with pending started if available\n   375→\t\tstartedAt := c.StartedAt\n   376→\t\tif started := pending[c.StepName]; started != nil {\n   377→\t\t\tstartedAt = started.StartedAt\n   378→\t\t\tdelete(pending, c.StepName)\n   379→\t\t}\n   380→\t\tentries = append(entries, stepEntry{\n   381→\t\t\tIndex:     len(entries),\n   382→\t\t\tStepName:  c.StepName,\n   383→\t\t\tResult:    c.Result,\n   384→\t\t\tStartedAt: startedAt,\n   385→\t\t\tDuration:  formatDuration(startedAt, c.CompletedAt),\n   386→\t\t})\n   387→\t}\n   388→\n   389→\t// Append any started-but-not-completed steps (still running)\n   390→\tfor _, c := range caps {\n   391→\t\tif c.Result == \"\" {\n   392→\t\t\tif _, used := pending[c.StepName]; !used {\n   393→\t\t\t\tcontinue\n   394→\t\t\t}\n   395→\t\t\tentries = append(entries, stepEntry{\n   396→\t\t\t\tIndex:     len(entries),\n   397→\t\t\t\tStepName:  c.StepName,\n   398→\t\t\t\tStartedAt: c.StartedAt,\n   399→\t\t\t})\n   400→\t\t\tdelete(pending, c.StepName)\n   401→\t\t}\n   402→\t}\n   403→\n   404→\treturn entries\n   405→}\n   406→\n   407→// containerState inspects the container for a run and returns one of:\n   408→//   - \"running\"   – container exists and is running\n   409→//   - \"stopped\"   – container exists, not running, not kept\n   410→//   - \"available\" – container exists, not running, kept (can be deleted)\n   411→//   - \"removed\"   – no container ID, no manager, or inspect failed\n   412→func (h *Handler) containerState(ctx context.Context, run *domain.Run) string {\n   413→\tif run.ContainerID == \"\" {\n   414→\t\treturn \"removed\"\n   415→\t}\n   416→\tmgr, ok := h.container.(ContainerManager)\n   417→\tif !ok {\n   418→\t\treturn \"removed\"\n   419→\t}\n   420→\tstatus, err := mgr.Inspect(ctx, run.ContainerID)\n   421→\tif err != nil {\n   422→\t\treturn \"removed\"\n   423→\t}\n   424→\tif status.Running {\n   425→\t\treturn \"running\"\n   426→\t}\n   427→\tif run.ContainerKept {\n   428→\t\treturn \"available\"\n   429→\t}\n   430→\treturn \"stopped\"\n   431→}\n   432→\n   433→func (h *Handler) handleRunDetail(w http.ResponseWriter, r *http.Request) {\n   434→\tid := r.PathValue(\"id\")\n   435→\n   436→\trun, err := h.store.GetRun(r.Context(), id)\n   437→\tif err != nil {\n   438→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   439→\t\treturn\n   440→\t}\n   441→\n   442→\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n   443→\tif err != nil {\n   444→\t\tcaps = nil // non-fatal\n   445→\t}\n   446→\n   447→\tsteps := mergeCaptures(caps)\n   448→\n   449→\tdata := map[string]any{\n   450→\t\t\"Title\":          \"Run \" + run.ID,\n   451→\t\t\"Run\":            run,\n   452→\t\t\"Steps\":          steps,\n   453→\t\t\"Page\":           \"detail\",\n   454→\t\t\"ContainerState\": h.containerState(r.Context(), run),\n   455→\t}\n   456→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   457→\tif err := h.pages[\"run_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   458→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   459→\t}\n   460→}\n   461→\n   462→// --- JSON API handlers ---\n   463→\n   464→type apiRun struct {\n   465→\tID           string `json:\"id\"`\n   466→\tWorkflowName string `json:\"workflow_name\"`\n   467→\tProjectDir   string `json:\"project_dir\"`\n   468→\tProjectLabel string `json:\"project_label\"`\n   469→\tState        string `json:\"state\"`\n   470→\tStartedAt    string `json:\"started_at\"`\n   471→\tCompletedAt  string `json:\"completed_at\"`\n   472→\tContainerID  string `json:\"container_id\"`\n   473→\tErrorMessage string `json:\"error_message\"`\n   474→}\n   475→\n   476→type apiStep struct {\n   477→\tStepName    string `json:\"step_name\"`\n   478→\tResult      string `json:\"result\"`\n   479→\tStartedAt   string `json:\"started_at\"`\n   480→\tCompletedAt string `json:\"completed_at\"`\n   481→\tDuration    string `json:\"duration\"`\n   482→}\n   483→\n   484→type apiRunDetail struct {\n   485→\tapiRun\n   486→\tContainerState string    `json:\"container_state\"`\n   487→\tSteps          []apiStep `json:\"steps\"`\n   488→}\n   489→\n   490→func toAPIRun(r *domain.Run, labels map[string]string) apiRun {\n   491→\treturn apiRun{\n   492→\t\tID:           r.ID,\n   493→\t\tWorkflowName: r.WorkflowName,\n   494→\t\tProjectDir:   r.ProjectDir,\n   495→\t\tProjectLabel: labels[r.ProjectDir],\n   496→\t\tState:        string(r.State),\n   497→\t\tStartedAt:    formatTime(r.StartedAt),\n   498→\t\tCompletedAt:  formatTime(r.CompletedAt),\n   499→\t\tContainerID:  r.ContainerID,\n   500→\t\tErrorMessage: r.ErrorMessage,\n   501→\t}\n   502→}\n   503→\n   504→func (h *Handler) handleAPIRuns(w http.ResponseWriter, r *http.Request) {\n   505→\tprojectFilter := r.URL.Query().Get(\"project\")\n   506→\n   507→\tvar runs []*domain.Run\n   508→\tvar err error\n   509→\tif projectFilter != \"\" {\n   510→\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n   511→\t} else {\n   512→\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n   513→\t}\n   514→\tif err != nil {\n   515→\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n   516→\t\treturn\n   517→\t}\n   518→\n   519→\tprojects, _ := h.store.ListProjects(r.Context())\n   520→\tlabels := projectLabels(projects)\n   521→\n   522→\tresult := make([]apiRun, len(runs))\n   523→\tfor i, run := range runs {\n   524→\t\tresult[i] = toAPIRun(run, labels)\n   525→\t}\n   526→\n   527→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   528→\tjson.NewEncoder(w).Encode(result)\n   529→}\n   530→\n   531→func (h *Handler) handleAPIProjects(w http.ResponseWriter, r *http.Request) {\n   532→\tprojects, err := h.store.ListProjects(r.Context())\n   533→\tif err != nil {\n   534→\t\thttp.Error(w, \"failed to list projects\", http.StatusInternalServerError)\n   535→\t\treturn\n   536→\t}\n   537→\tlabels := projectLabels(projects)\n   538→\n   539→\ttype apiHealth struct {\n   540→\t\tStatus string `json:\"status\"`\n   541→\t\tPassed int    `json:\"passed\"`\n   542→\t\tFailed int    `json:\"failed\"`\n   543→\t\tTotal  int    `json:\"total\"`\n   544→\t}\n   545→\ttype apiProject struct {\n   546→\t\tDir         string    `json:\"dir\"`\n   547→\t\tLabel       string    `json:\"label\"`\n   548→\t\tHealth      apiHealth `json:\"health\"`\n   549→\t\tActiveCount int       `json:\"active_count\"`\n   550→\t}\n   551→\tresult := make([]apiProject, len(projects))\n   552→\tfor i, dir := range projects {\n   553→\t\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   554→\t\trunValues := make([]domain.Run, len(runs))\n   555→\t\tfor j, rr := range runs {\n   556→\t\t\trunValues[j] = *rr\n   557→\t\t}\n   558→\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n   559→\t\tvar activeCount int\n   560→\t\tfor _, rr := range runs {\n   561→\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n   562→\t\t\t\tactiveCount++\n   563→\t\t\t}\n   564→\t\t}\n   565→\t\tresult[i] = apiProject{\n   566→\t\t\tDir:   dir,\n   567→\t\t\tLabel: labels[dir],\n   568→\t\t\tHealth: apiHealth{\n   569→\t\t\t\tStatus: string(health.Status),\n   570→\t\t\t\tPassed: health.Passed,\n   571→\t\t\t\tFailed: health.Failed,\n   572→\t\t\t\tTotal:  health.Total,\n   573→\t\t\t},\n   574→\t\t\tActiveCount: activeCount,\n   575→\t\t}\n   576→\t}\n   577→\n   578→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   579→\tjson.NewEncoder(w).Encode(result)\n   580→}\n   581→\n   582→func (h *Handler) handleAPIRunDetail(w http.ResponseWriter, r *http.Request) {\n   583→\tid := r.PathValue(\"id\")\n   584→\n   585→\trun, err := h.store.GetRun(r.Context(), id)\n   586→\tif err != nil {\n   587→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   588→\t\treturn\n   589→\t}\n   590→\n   591→\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n   592→\tif err != nil {\n   593→\t\tcaps = nil\n   594→\t}\n   595→\n   596→\tprojects, _ := h.store.ListProjects(r.Context())\n   597→\tlabels := projectLabels(projects)\n   598→\n   599→\tmerged := mergeCaptures(caps)\n   600→\tsteps := make([]apiStep, len(merged))\n   601→\tfor i, e := range merged {\n   602→\t\tsteps[i] = apiStep{\n   603→\t\t\tStepName:  e.StepName,\n   604→\t\t\tResult:    e.Result,\n   605→\t\t\tStartedAt: formatTime(e.StartedAt),\n   606→\t\t\tDuration:  e.Duration,\n   607→\t\t}\n   608→\t}\n   609→\n   610→\tdetail := apiRunDetail{\n   611→\t\tapiRun:         toAPIRun(run, labels),\n   612→\t\tContainerState: h.containerState(r.Context(), run),\n   613→\t\tSteps:          steps,\n   614→\t}\n   615→\n   616→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   617→\tjson.NewEncoder(w).Encode(detail)\n   618→}\n   619→\n   620→func (h *Handler) handleAPIStepOutput(w http.ResponseWriter, r *http.Request) {\n   621→\tid := r.PathValue(\"id\")\n   622→\tstep := r.PathValue(\"step\")\n   623→\tlogType := r.URL.Query().Get(\"type\") // optional: \"script\", \"llm\"\n   624→\n   625→\trun, err := h.store.GetRun(r.Context(), id)\n   626→\tif err != nil {\n   627→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   628→\t\treturn\n   629→\t}\n   630→\n   631→\t// Try log index first for fast lookup\n   632→\tif h.logStore != nil {\n   633→\t\tlogFiles, err := h.logStore.GetLogFilesByStep(r.Context(), id, step)\n   634→\t\tif err == nil && len(logFiles) > 0 {\n   635→\t\t\t// If type filter specified, narrow results\n   636→\t\t\tfor _, lf := range logFiles {\n   637→\t\t\t\tif logType != \"\" && lf.FileType != logType {\n   638→\t\t\t\t\tcontinue\n   639→\t\t\t\t}\n   640→\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n   641→\t\t\t\tif readErr == nil && len(data) > 0 {\n   642→\t\t\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   643→\t\t\t\t\tw.Write(data)\n   644→\t\t\t\t\treturn\n   645→\t\t\t\t}\n   646→\t\t\t}\n   647→\t\t}\n   648→\t}\n   649→\n   650→\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", id, \"output\")\n   651→\n   652→\t// Fall back to file path conventions\n   653→\t// If type is \"llm\", try llm-<step>.log\n   654→\tif logType == \"llm\" {\n   655→\t\tllmPath := filepath.Join(outputDir, \"llm-\"+step+\".log\")\n   656→\t\tdata, err := os.ReadFile(llmPath)\n   657→\t\tif err == nil && len(data) > 0 {\n   658→\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   659→\t\t\tw.Write(data)\n   660→\t\t\treturn\n   661→\t\t}\n   662→\t}\n   663→\n   664→\t// Try per-step output first, fall back to container.log, then live docker logs\n   665→\toutputPath := filepath.Join(outputDir, step+\".log\")\n   666→\tdata, err := os.ReadFile(outputPath)\n   667→\tif err == nil && len(data) > 0 {\n   668→\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   669→\t\tw.Write(data)\n   670→\t\treturn\n   671→\t}\n   672→\n   673→\tcontainerLog := filepath.Join(outputDir, \"container.log\")\n   674→\tdata, err = os.ReadFile(containerLog)\n   675→\tif err == nil && len(data) > 0 {\n   676→\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   677→\t\tw.Write(data)\n   678→\t\treturn\n   679→\t}\n   680→\n   681→\t// Last resort: try live docker logs from still-existing container\n   682→\tif h.container != nil && run.ContainerID != \"\" {\n   683→\t\tif logs, logErr := h.container.Logs(r.Context(), run.ContainerID); logErr == nil && logs != \"\" {\n   684→\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   685→\t\t\tw.Write([]byte(logs))\n   686→\t\t\treturn\n   687→\t\t}\n   688→\t}\n   689→\n   690→\thttp.Error(w, \"step output not found\", http.StatusNotFound)\n   691→}\n   692→\n   693→func (h *Handler) handleAPIDeleteContainer(w http.ResponseWriter, r *http.Request) {\n   694→\tid := r.PathValue(\"id\")\n   695→\n   696→\trun, err := h.store.GetRun(r.Context(), id)\n   697→\tif err != nil {\n   698→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   699→\t\tw.WriteHeader(http.StatusNotFound)\n   700→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"run not found\"})\n   701→\t\treturn\n   702→\t}\n   703→\n   704→\tmgr, ok := h.container.(ContainerManager)\n   705→\tif !ok || run.ContainerID == \"\" {\n   706→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   707→\t\tw.WriteHeader(http.StatusBadRequest)\n   708→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"container management not available\"})\n   709→\t\treturn\n   710→\t}\n   711→\n   712→\tif err := mgr.Remove(r.Context(), run.ContainerID); err != nil {\n   713→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   714→\t\tw.WriteHeader(http.StatusInternalServerError)\n   715→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to remove container: %v\", err)})\n   716→\t\treturn\n   717→\t}\n   718→\n   719→\trun.ContainerKept = false\n   720→\tif err := h.store.UpdateRun(r.Context(), run); err != nil {\n   721→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   722→\t\tw.WriteHeader(http.StatusInternalServerError)\n   723→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to update run: %v\", err)})\n   724→\t\treturn\n   725→\t}\n   726→\n   727→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   728→\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n   729→}\n   730→\n   731→func (h *Handler) handleAPITriggerOrchestrator(w http.ResponseWriter, r *http.Request) {\n   732→\tlabel := r.PathValue(\"name\")\n   733→\n   734→\t// Resolve label back to project directory via the store.\n   735→\tprojects, _ := h.store.ListProjects(r.Context())\n   736→\tlabels := projectLabels(projects)\n   737→\tvar projectDir string\n   738→\tfor dir, l := range labels {\n   739→\t\tif l == label {\n   740→\t\t\tprojectDir = dir\n   741→\t\t\tbreak\n   742→\t\t}\n   743→\t}\n   744→\tif projectDir == \"\" {\n   745→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   746→\t\tw.WriteHeader(http.StatusNotFound)\n   747→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"project not found\"})\n   748→\t\treturn\n   749→\t}\n   750→\n   751→\tif h.orchestrateFn == nil {\n   752→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   753→\t\tw.WriteHeader(http.StatusNotImplemented)\n   754→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n   755→\t\treturn\n   756→\t}\n   757→\n   758→\tdispatched, err := h.orchestrateFn(r.Context(), projectDir)\n   759→\tif err != nil {\n   760→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   761→\t\tw.WriteHeader(http.StatusInternalServerError)\n   762→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": err.Error()})\n   763→\t\treturn\n   764→\t}\n   765→\n   766→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   767→\tjson.NewEncoder(w).Encode(map[string]any{\"status\": \"ok\", \"project\": label, \"dispatched\": dispatched})\n   768→}\n   769→\n   770→// handleAPIStream serves an SSE stream of log lines for a run.\n   771→// For active runs, it subscribes to the live broadcaster.\n   772→// For completed runs, it serves the archived full.log then closes.\n   773→func (h *Handler) handleAPIStream(w http.ResponseWriter, r *http.Request) {\n   774→\tid := r.PathValue(\"id\")\n   775→\n   776→\trun, err := h.store.GetRun(r.Context(), id)\n   777→\tif err != nil {\n   778→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   779→\t\treturn\n   780→\t}\n   781→\n   782→\tflusher, ok := w.(http.Flusher)\n   783→\tif !ok {\n   784→\t\thttp.Error(w, \"streaming not supported\", http.StatusInternalServerError)\n   785→\t\treturn\n   786→\t}\n   787→\n   788→\tw.Header().Set(\"Content-Type\", \"text/event-stream\")\n   789→\tw.Header().Set(\"Cache-Control\", \"no-cache\")\n   790→\tw.Header().Set(\"Connection\", \"keep-alive\")\n   791→\tw.Header().Set(\"X-Accel-Buffering\", \"no\")\n   792→\n   793→\tisComplete := run.State == domain.RunStateSucceeded ||\n   794→\t\trun.State == domain.RunStateFailed ||\n   795→\t\trun.State == domain.RunStateCancelled\n   796→\n   797→\tif isComplete {\n   798→\t\t// Serve archived full.log\n   799→\t\th.streamFullLog(w, flusher, run)\n   800→\t\t// Send done event\n   801→\t\tfmt.Fprintf(w, \"event: done\\ndata: %s\\n\\n\", string(run.State))\n   802→\t\tflusher.Flush()\n   803→\t\treturn\n   804→\t}\n   805→\n   806→\t// Active run: subscribe to live broadcaster\n   807→\tif h.logBroadcast == nil {\n   808→\t\thttp.Error(w, \"log streaming not available\", http.StatusServiceUnavailable)\n   809→\t\treturn\n   810→\t}\n   811→\n   812→\tsub := h.logBroadcast.Subscribe(id)\n   813→\tdefer h.logBroadcast.Unsubscribe(id, sub)\n   814→\n   815→\tctx := r.Context()\n   816→\tfor {\n   817→\t\tselect {\n   818→\t\tcase <-ctx.Done():\n   819→\t\t\treturn\n   820→\t\tcase line, ok := <-sub.C:\n   821→\t\t\tif !ok {\n   822→\t\t\t\t// Stream finished (run completed)\n   823→\t\t\t\tfmt.Fprintf(w, \"event: done\\ndata: completed\\n\\n\")\n   824→\t\t\t\tflusher.Flush()\n   825→\t\t\t\treturn\n   826→\t\t\t}\n   827→\t\t\tdata, _ := json.Marshal(line)\n   828→\t\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n   829→\t\t\tflusher.Flush()\n   830→\t\t}\n   831→\t}\n   832→}\n   833→\n   834→// logLineRegex parses \"[timestamp] [type] content\" format from full.log.\n   835→var logLineRegex = regexp.MustCompile(`^\\[([^\\]]+)\\] \\[([^\\]]+)\\] (.*)$`)\n   836→\n   837→// streamFullLog reads the archived full.log file and sends its entries as SSE events.\n   838→func (h *Handler) streamFullLog(w http.ResponseWriter, flusher http.Flusher, run *domain.Run) {\n   839→\tlogPath := filepath.Join(run.ProjectDir, \".cloche\", run.ID, \"output\", \"full.log\")\n   840→\tf, err := os.Open(logPath)\n   841→\tif err != nil {\n   842→\t\treturn\n   843→\t}\n   844→\tdefer f.Close()\n   845→\n   846→\tscanner := bufio.NewScanner(f)\n   847→\tfor scanner.Scan() {\n   848→\t\ttext := scanner.Text()\n   849→\t\tline := parseFullLogLine(text)\n   850→\t\tdata, _ := json.Marshal(line)\n   851→\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n   852→\t\tflusher.Flush()\n   853→\t}\n   854→}\n   855→\n   856→// parseFullLogLine parses a \"[timestamp] [type] content\" line into a LogLine.\n   857→func parseFullLogLine(text string) logstream.LogLine {\n   858→\tm := logLineRegex.FindStringSubmatch(text)\n   859→\tif m == nil {\n   860→\t\treturn logstream.LogLine{\n   861→\t\t\tTimestamp: time.Now().UTC().Format(time.RFC3339),\n   862→\t\t\tType:      \"script\",\n   863→\t\t\tContent:   text,\n   864→\t\t}\n   865→\t}\n   866→\treturn logstream.LogLine{\n   867→\t\tTimestamp: m[1],\n   868→\t\tType:      m[2],\n   869→\t\tContent:   m[3],\n   870→\t}\n   871→}\n   872→\n   873→// --- Project detail handlers ---\n   874→\n   875→// resolveProjectDir resolves a project label from the URL to its directory path.\n   876→// Returns (dir, label, ok). Writes a JSON error response if not found.\n   877→func (h *Handler) resolveProjectDir(w http.ResponseWriter, r *http.Request) (string, string, bool) {\n   878→\tlabel := r.PathValue(\"name\")\n   879→\tprojects, _ := h.store.ListProjects(r.Context())\n   880→\tlabels := projectLabels(projects)\n   881→\tfor dir, l := range labels {\n   882→\t\tif l == label {\n   883→\t\t\treturn dir, label, true\n   884→\t\t}\n   885→\t}\n   886→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   887→\tw.WriteHeader(http.StatusNotFound)\n   888→\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"project not found\"})\n   889→\treturn \"\", \"\", false\n   890→}\n   891→\n   892→func (h *Handler) handleProjectDetail(w http.ResponseWriter, r *http.Request) {\n   893→\tdir, label, ok := h.resolveProjectDir(w, r)\n   894→\tif !ok {\n   895→\t\treturn\n   896→\t}\n   897→\n   898→\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   899→\tn := 10\n   900→\tif n > len(runs) {\n   901→\t\tn = len(runs)\n   902→\t}\n   903→\tdots := make([]recentRunDot, n)\n   904→\tfor i := 0; i < n; i++ {\n   905→\t\tdots[i] = recentRunDot{ID: runs[i].ID, State: string(runs[i].State)}\n   906→\t}\n   907→\n   908→\tdata := map[string]any{\n   909→\t\t\"Title\":      label,\n   910→\t\t\"Label\":      label,\n   911→\t\t\"Dir\":        dir,\n   912→\t\t\"RecentRuns\": dots,\n   913→\t}\n   914→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   915→\tif err := h.pages[\"project_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   916→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   917→\t}\n   918→}\n   919→\n   920→func (h *Handler) handleAPIOrchestratorStatus(w http.ResponseWriter, r *http.Request) {\n   921→\tdir, _, ok := h.resolveProjectDir(w, r)\n   922→\tif !ok {\n   923→\t\treturn\n   924→\t}\n   925→\tif h.orchestrator == nil {\n   926→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   927→\t\tjson.NewEncoder(w).Encode(map[string]any{\"enabled\": false, \"in_flight\": 0, \"concurrency\": 0})\n   928→\t\treturn\n   929→\t}\n   930→\tenabled, inFlight, concurrency := h.orchestrator.Status(dir)\n   931→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   932→\tjson.NewEncoder(w).Encode(map[string]any{\n   933→\t\t\"enabled\":     enabled,\n   934→\t\t\"in_flight\":   inFlight,\n   935→\t\t\"concurrency\": concurrency,\n   936→\t})\n   937→}\n   938→\n   939→func (h *Handler) handleAPIOrchestratorStart(w http.ResponseWriter, r *http.Request) {\n   940→\tdir, _, ok := h.resolveProjectDir(w, r)\n   941→\tif !ok {\n   942→\t\treturn\n   943→\t}\n   944→\tif h.orchestrator == nil {\n   945→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   946→\t\tw.WriteHeader(http.StatusNotImplemented)\n   947→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n   948→\t\treturn\n   949→\t}\n   950→\th.orchestrator.SetEnabled(dir, true)\n   951→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   952→\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n   953→}\n   954→\n   955→func (h *Handler) handleAPIOrchestratorStop(w http.ResponseWriter, r *http.Request) {\n   956→\tdir, _, ok := h.resolveProjectDir(w, r)\n   957→\tif !ok {\n   958→\t\treturn\n   959→\t}\n   960→\tif h.orchestrator == nil {\n   961→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   962→\t\tw.WriteHeader(http.StatusNotImplemented)\n   963→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n   964→\t\treturn\n   965→\t}\n   966→\th.orchestrator.SetEnabled(dir, false)\n   967→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   968→\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n   969→}\n   970→\n   971→func (h *Handler) handleAPIOrchestratorConcurrency(w http.ResponseWriter, r *http.Request) {\n   972→\tdir, _, ok := h.resolveProjectDir(w, r)\n   973→\tif !ok {\n   974→\t\treturn\n   975→\t}\n   976→\tif h.orchestrator == nil {\n   977→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   978→\t\tw.WriteHeader(http.StatusNotImplemented)\n   979→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n   980→\t\treturn\n   981→\t}\n   982→\tvar body struct {\n   983→\t\tConcurrency int `json:\"concurrency\"`\n   984→\t}\n   985→\tif err := json.NewDecoder(r.Body).Decode(&body); err != nil || body.Concurrency < 1 {\n   986→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   987→\t\tw.WriteHeader(http.StatusBadRequest)\n   988→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"concurrency must be a positive integer\"})\n   989→\t\treturn\n   990→\t}\n   991→\th.orchestrator.SetConcurrency(dir, body.Concurrency)\n   992→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   993→\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n   994→}\n   995→\n   996→func (h *Handler) handleAPIProjectInfo(w http.ResponseWriter, r *http.Request) {\n   997→\tdir, _, ok := h.resolveProjectDir(w, r)\n   998→\tif !ok {\n   999→\t\treturn\n  1000→\t}\n  1001→\n  1002→\t// Docker image: read FROM line from Dockerfile\n  1003→\tdockerImage := \"\"\n  1004→\tdockerfilePath := filepath.Join(dir, \".cloche\", \"Dockerfile\")\n  1005→\tif data, err := os.ReadFile(dockerfilePath); err == nil {\n  1006→\t\t// Find the last FROM line (final stage)\n  1007→\t\tfor _, line := range strings.Split(string(data), \"\\n\") {\n  1008→\t\t\ttrimmed := strings.TrimSpace(line)\n  1009→\t\t\tif strings.HasPrefix(strings.ToUpper(trimmed), \"FROM \") {\n  1010→\t\t\t\tparts := strings.Fields(trimmed)\n  1011→\t\t\t\tif len(parts) >= 2 {\n  1012→\t\t\t\t\tdockerImage = parts[1]\n  1013→\t\t\t\t}\n  1014→\t\t\t}\n  1015→\t\t}\n  1016→\t}\n  1017→\n  1018→\t// Version\n  1019→\tversion := 0\n  1020→\tversionPath := filepath.Join(dir, \".cloche\", \"version\")\n  1021→\tif data, err := os.ReadFile(versionPath); err == nil {\n  1022→\t\tif v, err := strconv.Atoi(strings.TrimSpace(string(data))); err == nil {\n  1023→\t\t\tversion = v\n  1024→\t\t}\n  1025→\t}\n  1026→\n  1027→\t// Prompt files history\n  1028→\ttype commitEntry struct {\n  1029→\t\tSHA     string `json:\"sha\"`\n  1030→\t\tDate    string `json:\"date\"`\n  1031→\t\tMessage string `json:\"message\"`\n  1032→\t}\n  1033→\ttype promptFile struct {\n  1034→\t\tPath    string        `json:\"path\"`\n  1035→\t\tHistory []commitEntry `json:\"history\"`\n  1036→\t}\n  1037→\n  1038→\tvar promptFiles []promptFile\n  1039→\tpromptsDir := filepath.Join(dir, \".cloche\", \"prompts\")\n  1040→\tif entries, err := os.ReadDir(promptsDir); err == nil {\n  1041→\t\tfor _, e := range entries {\n  1042→\t\t\tif e.IsDir() {\n  1043→\t\t\t\tcontinue\n  1044→\t\t\t}\n  1045→\t\t\trelPath := filepath.Join(\".cloche\", \"prompts\", e.Name())\n  1046→\t\t\tcmd := exec.Command(\"git\", \"log\", \"--follow\", \"--format=%H %aI %s\", \"--\", relPath)\n  1047→\t\t\tcmd.Dir = dir\n  1048→\t\t\tout, err := cmd.Output()\n  1049→\t\t\tif err != nil {\n  1050→\t\t\t\tcontinue\n  1051→\t\t\t}\n  1052→\t\t\tvar history []commitEntry\n  1053→\t\t\tfor _, line := range strings.Split(strings.TrimSpace(string(out)), \"\\n\") {\n  1054→\t\t\t\tif line == \"\" {\n  1055→\t\t\t\t\tcontinue\n  1056→\t\t\t\t}\n  1057→\t\t\t\tparts := strings.SplitN(line, \" \", 3)\n  1058→\t\t\t\tif len(parts) < 3 {\n  1059→\t\t\t\t\tcontinue\n  1060→\t\t\t\t}\n  1061→\t\t\t\t// Parse date to short form\n  1062→\t\t\t\tdateStr := parts[1]\n  1063→\t\t\t\tif t, err := time.Parse(time.RFC3339, dateStr); err == nil {\n  1064→\t\t\t\t\tdateStr = t.Format(\"2006-01-02\")\n  1065→\t\t\t\t}\n  1066→\t\t\t\thistory = append(history, commitEntry{\n  1067→\t\t\t\t\tSHA:     parts[0][:7],\n  1068→\t\t\t\t\tDate:    dateStr,\n  1069→\t\t\t\t\tMessage: parts[2],\n  1070→\t\t\t\t})\n  1071→\t\t\t}\n  1072→\t\t\tpromptFiles = append(promptFiles, promptFile{Path: relPath, History: history})\n  1073→\t\t}\n  1074→\t}\n  1075→\n  1076→\tw.Header().Set(\"Content-Type\", \"application/json\")\n  1077→\tjson.NewEncoder(w).Encode(map[string]any{\n  1078→\t\t\"docker_image\": dockerImage,\n  1079→\t\t\"version\":      version,\n  1080→\t\t\"prompt_files\": promptFiles,\n  1081→\t})\n  1082→}\n  1083→\n  1084→func (h *Handler) handleAPIPromptDiff(w http.ResponseWriter, r *http.Request) {\n  1085→\tdir, _, ok := h.resolveProjectDir(w, r)\n  1086→\tif !ok {\n  1087→\t\treturn\n  1088→\t}\n  1089→\tfile := r.URL.Query().Get(\"file\")\n  1090→\tsha := r.URL.Query().Get(\"sha\")\n  1091→\tif file == \"\" || sha == \"\" {\n  1092→\t\thttp.Error(w, \"file and sha required\", http.StatusBadRequest)\n  1093→\t\treturn\n  1094→\t}\n  1095→\n  1096→\t// Validate sha is alphanumeric to prevent injection\n  1097→\tfor _, c := range sha {\n  1098→\t\tif !((c >= '0' && c <= '9') || (c >= 'a' && c <= 'f') || (c >= 'A' && c <= 'F')) {\n  1099→\t\t\thttp.Error(w, \"invalid sha\", http.StatusBadRequest)\n  1100→\t\t\treturn\n  1101→\t\t}\n  1102→\t}\n  1103→\n  1104→\tcmd := exec.Command(\"git\", \"diff\", sha+\"^..\"+sha, \"--\", file)\n  1105→\tcmd.Dir = dir\n  1106→\tout, err := cmd.Output()\n  1107→\tif err != nil {\n  1108→\t\thttp.Error(w, \"diff not available\", http.StatusNotFound)\n  1109→\t\treturn\n  1110→\t}\n  1111→\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n  1112→\tw.Write(out)\n  1113→}\n  1114→\n  1115→func (h *Handler) handleAPIWorkflows(w http.ResponseWriter, r *http.Request) {\n  1116→\tdir, _, ok := h.resolveProjectDir(w, r)\n  1117→\tif !ok {\n  1118→\t\treturn\n  1119→\t}\n  1120→\n  1121→\tclocheDir := filepath.Join(dir, \".cloche\")\n  1122→\tentries, err := os.ReadDir(clocheDir)\n  1123→\tif err != nil {\n  1124→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n  1125→\t\tjson.NewEncoder(w).Encode([]any{})\n  1126→\t\treturn\n  1127→\t}\n  1128→\n  1129→\ttype apiWire struct {\n  1130→\t\tFrom   string `json:\"from\"`\n  1131→\t\tResult string `json:\"result\"`\n  1132→\t\tTo     string `json:\"to\"`\n  1133→\t}\n  1134→\ttype apiStepDef struct {\n  1135→\t\tName    string            `json:\"name\"`\n  1136→\t\tType    string            `json:\"type\"`\n  1137→\t\tResults []string          `json:\"results\"`\n  1138→\t\tConfig  map[string]string `json:\"config\"`\n  1139→\t}\n  1140→\ttype apiWorkflow struct {\n  1141→\t\tName      string       `json:\"name\"`\n  1142→\t\tFile      string       `json:\"file\"`\n  1143→\t\tSteps     []apiStepDef `json:\"steps\"`\n  1144→\t\tWires     []apiWire    `json:\"wires\"`\n  1145→\t\tEntryStep string       `json:\"entry_step\"`\n  1146→\t}\n  1147→\n  1148→\tvar workflows []apiWorkflow\n  1149→\tfor _, e := range entries {\n  1150→\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n  1151→\t\t\tcontinue\n  1152→\t\t}\n  1153→\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n  1154→\t\tif err != nil {\n  1155→\t\t\tcontinue\n  1156→\t\t}\n  1157→\t\twf, err := dsl.Parse(string(data))\n  1158→\t\tif err != nil {\n  1159→\t\t\tcontinue\n  1160→\t\t}\n  1161→\t\tvar steps []apiStepDef\n  1162→\t\tfor _, s := range wf.Steps {\n  1163→\t\t\tsteps = append(steps, apiStepDef{\n  1164→\t\t\t\tName:    s.Name,\n  1165→\t\t\t\tType:    string(s.Type),\n  1166→\t\t\t\tResults: s.Results,\n  1167→\t\t\t\tConfig:  s.Config,\n  1168→\t\t\t})\n  1169→\t\t}\n  1170→\t\t// Sort steps by name for consistent ordering\n  1171→\t\tsort.Slice(steps, func(i, j int) bool { return steps[i].Name < steps[j].Name })\n  1172→\n  1173→\t\tvar wires []apiWire\n  1174→\t\tfor _, wire := range wf.Wiring {\n  1175→\t\t\twires = append(wires, apiWire{From: wire.From, Result: wire.Result, To: wire.To})\n  1176→\t\t}\n  1177→\n  1178→\t\tworkflows = append(workflows, apiWorkflow{\n  1179→\t\t\tName:      wf.Name,\n  1180→\t\t\tFile:      filepath.Join(\".cloche\", e.Name()),\n  1181→\t\t\tSteps:     steps,\n  1182→\t\t\tWires:     wires,\n  1183→\t\t\tEntryStep: wf.EntryStep,\n  1184→\t\t})\n  1185→\t}\n  1186→\n  1187→\tw.Header().Set(\"Content-Type\", \"application/json\")\n  1188→\tjson.NewEncoder(w).Encode(workflows)\n  1189→}\n  1190→\n  1191→func (h *Handler) handleAPIStepContent(w http.ResponseWriter, r *http.Request) {\n  1192→\tdir, _, ok := h.resolveProjectDir(w, r)\n  1193→\tif !ok {\n  1194→\t\treturn\n  1195→\t}\n  1196→\tworkflowName := r.PathValue(\"workflow\")\n  1197→\tstepName := r.PathValue(\"step\")\n  1198→\n  1199→\t// Find the workflow file\n  1200→\tclocheDir := filepath.Join(dir, \".cloche\")\n  1201→\tvar wf *domain.Workflow\n  1202→\tentries, _ := os.ReadDir(clocheDir)\n  1203→\tfor _, e := range entries {\n  1204→\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n  1205→\t\t\tcontinue\n  1206→\t\t}\n  1207→\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n  1208→\t\tif err != nil {\n  1209→\t\t\tcontinue\n  1210→\t\t}\n  1211→\t\tparsed, err := dsl.Parse(string(data))\n  1212→\t\tif err != nil {\n  1213→\t\t\tcontinue\n  1214→\t\t}\n  1215→\t\tif parsed.Name == workflowName {\n  1216→\t\t\twf = parsed\n  1217→\t\t\tbreak\n  1218→\t\t}\n  1219→\t}\n  1220→\tif wf == nil {\n  1221→\t\thttp.Error(w, \"workflow not found\", http.StatusNotFound)\n  1222→\t\treturn\n  1223→\t}\n  1224→\n  1225→\tstep, ok := wf.Steps[stepName]\n  1226→\tif !ok {\n  1227→\t\thttp.Error(w, \"step not found\", http.StatusNotFound)\n  1228→\t\treturn\n  1229→\t}\n  1230→\n  1231→\t// Try to read the referenced file from step config\n  1232→\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n  1233→\n  1234→\tif prompt := step.Config[\"prompt\"]; prompt != \"\" {\n  1235→\t\tdata, err := os.ReadFile(filepath.Join(dir, prompt))\n  1236→\t\tif err == nil {\n  1237→\t\t\tw.Write(data)\n  1238→\t\t\treturn\n  1239→\t\t}\n  1240→\t}\n  1241→\tif script := step.Config[\"command\"]; script != \"\" {\n  1242→\t\tw.Write([]byte(script))\n  1243→\t\treturn\n  1244→\t}\n  1245→\tif script := step.Config[\"script\"]; script != \"\" {\n  1246→\t\tdata, err := os.ReadFile(filepath.Join(dir, script))\n  1247→\t\tif err == nil {\n  1248→\t\t\tw.Write(data)\n  1249→\t\t\treturn\n  1250→\t\t}\n  1251→\t\tw.Write([]byte(script))\n  1252→\t\treturn\n  1253→\t}\n  1254→\n  1255→\thttp.Error(w, \"no content available\", http.StatusNotFound)\n  1256→}\n  1257→\n  1258→// --- Template helpers ---\n  1259→\n  1260→func stateColor(state domain.RunState) string {\n  1261→\tswitch state {\n  1262→\tcase domain.RunStatePending:\n  1263→\t\treturn \"pending\"\n  1264→\tcase domain.RunStateRunning:\n  1265→\t\treturn \"running\"\n  1266→\tcase domain.RunStateSucceeded:\n  1267→\t\treturn \"succeeded\"\n  1268→\tcase domain.RunStateFailed:\n  1269→\t\treturn \"failed\"\n  1270→\tcase domain.RunStateCancelled:\n  1271→\t\treturn \"cancelled\"\n  1272→\tdefault:\n  1273→\t\treturn \"pending\"\n  1274→\t}\n  1275→}\n  1276→\n  1277→func healthColor(status domain.HealthStatus) string {\n  1278→\tswitch status {\n  1279→\tcase domain.HealthGreen:\n  1280→\t\treturn \"green\"\n  1281→\tcase domain.HealthYellow:\n  1282→\t\treturn \"yellow\"\n  1283→\tcase domain.HealthRed:\n  1284→\t\treturn \"red\"\n  1285→\tcase domain.HealthBlue:\n  1286→\t\treturn \"blue\"\n  1287→\tdefault:\n  1288→\t\treturn \"grey\"\n  1289→\t}\n  1290→}\n  1291→\n  1292→func formatTime(t time.Time) string {\n  1293→\tif t.IsZero() {\n  1294→\t\treturn \"\"\n  1295→\t}\n  1296→\treturn t.Format(\"2006-01-02 15:04:05\")\n  1297→}\n  1298→\n  1299→func formatDuration(start, end time.Time) string {\n  1300→\tif start.IsZero() || end.IsZero() {\n  1301→\t\treturn \"\"\n  1302→\t}\n  1303→\td := end.Sub(start)\n  1304→\tif d < time.Second {\n  1305→\t\treturn fmt.Sprintf(\"%dms\", d.Milliseconds())\n  1306→\t}\n  1307→\tif d < time.Minute {\n  1308→\t\treturn fmt.Sprintf(\"%.1fs\", d.Seconds())\n  1309→\t}\n  1310→\treturn fmt.Sprintf(\"%dm%ds\", int(d.Minutes()), int(d.Seconds())%60)\n  1311→}\n  1312→\n  1313→func truncate(s string, n int) string {\n  1314→\tif len(s) <= n {\n  1315→\t\treturn s\n  1316→\t}\n  1317→\treturn s[:n] + \"...\"\n  1318→}\n  1319→\n  1320→func shortContainerID(id string) string {\n  1321→\tif len(id) > 12 {\n  1322→\t\treturn id[:12]\n  1323→\t}\n  1324→\treturn id\n  1325→}\n  1326→\n  1327→// projectLabels builds a mapping from full project directory paths to short\n  1328→// display labels. Each label is the final directory component (e.g.\n  1329→// \"myproject\" from \"/home/user/workspace/myproject\"). When two projects share\n  1330→// the same final name, the parent directory is prepended to disambiguate\n  1331→// (e.g. \"foo/bar\" vs \"baz/bar\").\n  1332→func projectLabels(dirs []string) map[string]string {\n  1333→\tlabels := make(map[string]string, len(dirs))\n  1334→\t// Group dirs by their base name to detect conflicts.\n  1335→\tbyBase := map[string][]string{}\n  1336→\tfor _, d := range dirs {\n  1337→\t\tbase := filepath.Base(d)\n  1338→\t\tbyBase[base] = append(byBase[base], d)\n  1339→\t}\n  1340→\tfor base, paths := range byBase {\n  1341→\t\tif len(paths) == 1 {\n  1342→\t\t\tlabels[paths[0]] = base\n  1343→\t\t} else {\n  1344→\t\t\tfor _, p := range paths {\n  1345→\t\t\t\tparent := filepath.Base(filepath.Dir(p))\n  1346→\t\t\t\tlabels[p] = parent + \"/\" + base\n  1347→\t\t\t}\n  1348→\t\t}\n  1349→\t}\n  1350→\treturn labels\n  1351→}\n  1352→\n  1353→type projectEntry struct {\n  1354→\tDir            string\n  1355→\tLabel          string\n  1356→\tContainerCount int\n  1357→}\n  1358→"}]},"parent_tool_use_id":null,"session_id":"dffb66df-dd3b-46a5-aba4-3641e6ad0853","uuid":"2fd9003a-69ae-47d2-bf82-a55fb9227ac7","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/web/handler.go","content":"package web\n\nimport (\n\t\"bufio\"\n\t\"context\"\n\t\"embed\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"html/template\"\n\t\"io/fs\"\n\t\"net/http\"\n\t\"os\"\n\t\"os/exec\"\n\t\"path/filepath\"\n\t\"regexp\"\n\t\"sort\"\n\t\"strconv\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/dsl\"\n\t\"github.com/cloche-dev/cloche/internal/logstream\"\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n)\n\n// HandlerOption configures optional Handler dependencies.\ntype HandlerOption func(*Handler)\n\n// WithContainerLogger sets the container runtime for fetching live logs.\nfunc WithContainerLogger(c ContainerLogger) HandlerOption {\n\treturn func(h *Handler) { h.container = c }\n}\n\n// WithContainerManager sets a full container manager (logs, inspect, remove).\nfunc WithContainerManager(c ContainerManager) HandlerOption {\n\treturn func(h *Handler) { h.container = c }\n}\n\n// WithLogBroadcaster sets the log broadcaster for SSE streaming.\nfunc WithLogBroadcaster(b *logstream.Broadcaster) HandlerOption {\n\treturn func(h *Handler) { h.logBroadcast = b }\n}\n\n// WithLogStore sets the log store for indexed log file lookups.\nfunc WithLogStore(ls ports.LogStore) HandlerOption {\n\treturn func(h *Handler) { h.logStore = ls }\n}\n\n// WithOrchestrateFunc sets the function called when the orchestrator is triggered.\nfunc WithOrchestrateFunc(fn func(ctx context.Context, projectDir string) (int, error)) HandlerOption {\n\treturn func(h *Handler) { h.orchestrateFn = fn }\n}\n\n// OrchestratorController provides per-project orchestrator control.\ntype OrchestratorController interface {\n\tStatus(dir string) (enabled bool, inFlight int, concurrency int)\n\tSetEnabled(dir string, enabled bool)\n\tSetConcurrency(dir string, concurrency int)\n}\n\n// WithOrchestrator sets the orchestrator controller for project-level control.\nfunc WithOrchestrator(oc OrchestratorController) HandlerOption {\n\treturn func(h *Handler) { h.orchestrator = oc }\n}\n\n//go:embed templates/*.html static/*\nvar content embed.FS\n\n// Handler serves the web dashboard.\n// ContainerLogger can retrieve logs from a container by ID.\ntype ContainerLogger interface {\n\tLogs(ctx context.Context, containerID string) (string, error)\n}\n\n// ContainerManager extends ContainerLogger with container lifecycle operations.\ntype ContainerManager interface {\n\tContainerLogger\n\tRemove(ctx context.Context, containerID string) error\n\tInspect(ctx context.Context, containerID string) (*ports.ContainerStatus, error)\n}\n\ntype Handler struct {\n\tstore         ports.RunStore\n\tcaptures      ports.CaptureStore\n\tlogStore      ports.LogStore\n\tcontainer     ContainerLogger\n\tlogBroadcast  *logstream.Broadcaster\n\torchestrateFn func(ctx context.Context, projectDir string) (int, error)\n\torchestrator  OrchestratorController\n\tpages         map[string]*template.Template\n\tmux           *http.ServeMux\n}\n\n// NewHandler creates a web dashboard handler.\nfunc NewHandler(store ports.RunStore, captures ports.CaptureStore, opts ...HandlerOption) (*Handler, error) {\n\tfuncMap := template.FuncMap{\n\t\t\"stateColor\":       stateColor,\n\t\t\"healthColor\":      healthColor,\n\t\t\"formatTime\":       formatTime,\n\t\t\"formatDuration\":   formatDuration,\n\t\t\"truncate\":         truncate,\n\t\t\"shortContainerID\": shortContainerID,\n\t}\n\n\tbase, err := template.New(\"\").Funcs(funcMap).ParseFS(content, \"templates/layout.html\")\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"parse layout: %w\", err)\n\t}\n\n\tpages := map[string]*template.Template{}\n\tfor _, page := range []string{\"projects\", \"runs\", \"run_detail\", \"project_detail\"} {\n\t\tclone, err := base.Clone()\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"clone layout for %s: %w\", page, err)\n\t\t}\n\t\t_, err = clone.ParseFS(content, \"templates/\"+page+\".html\")\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"parse %s: %w\", page, err)\n\t\t}\n\t\tpages[page] = clone\n\t}\n\n\th := &Handler{\n\t\tstore:    store,\n\t\tcaptures: captures,\n\t\tpages:    pages,\n\t\tmux:      http.NewServeMux(),\n\t}\n\tfor _, opt := range opts {\n\t\topt(h)\n\t}\n\n\tstaticFS, err := fs.Sub(content, \"static\")\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"static sub-fs: %w\", err)\n\t}\n\n\th.mux.HandleFunc(\"GET /{$}\", h.handleProjectOverview)\n\th.mux.HandleFunc(\"GET /runs\", h.handleRunsList)\n\th.mux.HandleFunc(\"GET /runs/{id}\", h.handleRunDetail)\n\th.mux.HandleFunc(\"GET /projects/{name}/runs\", h.handleProjectRuns)\n\th.mux.HandleFunc(\"GET /projects/{name}\", h.handleProjectDetail)\n\th.mux.HandleFunc(\"GET /api/projects\", h.handleAPIProjects)\n\th.mux.HandleFunc(\"GET /api/runs\", h.handleAPIRuns)\n\th.mux.HandleFunc(\"GET /api/runs/{id}\", h.handleAPIRunDetail)\n\th.mux.HandleFunc(\"GET /api/runs/{id}/steps/{step}/output\", h.handleAPIStepOutput)\n\th.mux.HandleFunc(\"DELETE /api/runs/{id}/container\", h.handleAPIDeleteContainer)\n\th.mux.HandleFunc(\"POST /api/projects/{name}/trigger\", h.handleAPITriggerOrchestrator)\n\th.mux.HandleFunc(\"GET /api/projects/{name}/orchestrator\", h.handleAPIOrchestratorStatus)\n\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/start\", h.handleAPIOrchestratorStart)\n\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/stop\", h.handleAPIOrchestratorStop)\n\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/concurrency\", h.handleAPIOrchestratorConcurrency)\n\th.mux.HandleFunc(\"GET /api/projects/{name}/info\", h.handleAPIProjectInfo)\n\th.mux.HandleFunc(\"GET /api/projects/{name}/info/prompt-diff\", h.handleAPIPromptDiff)\n\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows\", h.handleAPIWorkflows)\n\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows/{workflow}/steps/{step}/content\", h.handleAPIStepContent)\n\th.mux.HandleFunc(\"GET /api/runs/{id}/stream\", h.handleAPIStream)\n\th.mux.Handle(\"GET /static/\", http.StripPrefix(\"/static/\", http.FileServerFS(staticFS)))\n\n\treturn h, nil\n}\n\nfunc (h *Handler) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n\th.mux.ServeHTTP(w, r)\n}\n\n// --- HTML handlers ---\n\n// projectOverviewEntry holds data for a single project card on the landing page.\ntype projectOverviewEntry struct {\n\tDir         string\n\tLabel       string\n\tHealth      domain.HealthResult\n\tRecentRuns  []recentRunDot\n\tActiveCount int\n}\n\n// recentRunDot is a minimal representation of a run for the mini history display.\ntype recentRunDot struct {\n\tID    string\n\tState string\n}\n\nconst healthWindowSize = 10\n\nfunc (h *Handler) handleProjectOverview(w http.ResponseWriter, r *http.Request) {\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\tvar entries []projectOverviewEntry\n\tfor _, dir := range projects {\n\t\truns, err := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\n\t\t// Convert []*domain.Run to []domain.Run for CalculateHealth.\n\t\trunValues := make([]domain.Run, len(runs))\n\t\tfor i, rr := range runs {\n\t\t\trunValues[i] = *rr\n\t\t}\n\n\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n\n\t\t// Take the last N runs for the mini history (most recent first).\n\t\tn := healthWindowSize\n\t\tif n > len(runs) {\n\t\t\tn = len(runs)\n\t\t}\n\t\tdots := make([]recentRunDot, n)\n\t\tfor i := 0; i < n; i++ {\n\t\t\tdots[i] = recentRunDot{\n\t\t\t\tID:    runs[i].ID,\n\t\t\t\tState: string(runs[i].State),\n\t\t\t}\n\t\t}\n\n\t\tvar activeCount int\n\t\tfor _, rr := range runs {\n\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n\t\t\t\tactiveCount++\n\t\t\t}\n\t\t}\n\n\t\tentries = append(entries, projectOverviewEntry{\n\t\t\tDir:         dir,\n\t\t\tLabel:       labels[dir],\n\t\t\tHealth:      health,\n\t\t\tRecentRuns:  dots,\n\t\t\tActiveCount: activeCount,\n\t\t})\n\t}\n\n\tsort.Slice(entries, func(i, j int) bool {\n\t\treturn entries[i].Label < entries[j].Label\n\t})\n\n\tdata := map[string]any{\n\t\t\"Title\":    \"Projects\",\n\t\t\"Projects\": entries,\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n\tif err := h.pages[\"projects\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n\t}\n}\n\nfunc (h *Handler) handleRunsList(w http.ResponseWriter, r *http.Request) {\n\tprojectFilter := r.URL.Query().Get(\"project\")\n\n\tvar runs []*domain.Run\n\tvar err error\n\tif projectFilter != \"\" {\n\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n\t} else {\n\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n\t}\n\tif err != nil {\n\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\t// Count retained containers per project\n\tcontainerCounts := map[string]int{}\n\tallRuns, _ := h.store.ListRuns(r.Context(), time.Time{})\n\tfor _, run := range allRuns {\n\t\tif run.ContainerKept {\n\t\t\tcontainerCounts[run.ProjectDir]++\n\t\t}\n\t}\n\n\tvar projectList []projectEntry\n\tfor _, dir := range projects {\n\t\tprojectList = append(projectList, projectEntry{Dir: dir, Label: labels[dir], ContainerCount: containerCounts[dir]})\n\t}\n\tsort.Slice(projectList, func(i, j int) bool {\n\t\treturn projectList[i].Label < projectList[j].Label\n\t})\n\n\tdata := map[string]any{\n\t\t\"Title\":         \"Runs\",\n\t\t\"Runs\":          runs,\n\t\t\"Projects\":      projectList,\n\t\t\"ProjectFilter\": projectFilter,\n\t\t\"ProjectLabels\": labels,\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n\tif err := h.pages[\"runs\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n\t}\n}\n\nfunc (h *Handler) handleProjectRuns(w http.ResponseWriter, r *http.Request) {\n\tlabel := r.PathValue(\"name\")\n\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\t// Resolve label to project directory.\n\tvar projectDir string\n\tfor dir, l := range labels {\n\t\tif l == label {\n\t\t\tprojectDir = dir\n\t\t\tbreak\n\t\t}\n\t}\n\tif projectDir == \"\" {\n\t\thttp.Error(w, \"project not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\truns, err := h.store.ListRunsByProject(r.Context(), projectDir, time.Time{})\n\tif err != nil {\n\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\t// Count retained containers per project\n\tcontainerCounts := map[string]int{}\n\tallRuns, _ := h.store.ListRuns(r.Context(), time.Time{})\n\tfor _, run := range allRuns {\n\t\tif run.ContainerKept {\n\t\t\tcontainerCounts[run.ProjectDir]++\n\t\t}\n\t}\n\n\tvar projectList []projectEntry\n\tfor _, dir := range projects {\n\t\tprojectList = append(projectList, projectEntry{Dir: dir, Label: labels[dir], ContainerCount: containerCounts[dir]})\n\t}\n\tsort.Slice(projectList, func(i, j int) bool {\n\t\treturn projectList[i].Label < projectList[j].Label\n\t})\n\n\tdata := map[string]any{\n\t\t\"Title\":         \"Runs\",\n\t\t\"Runs\":          runs,\n\t\t\"Projects\":      projectList,\n\t\t\"ProjectFilter\": projectDir,\n\t\t\"ProjectLabel\":  label,\n\t\t\"ProjectLabels\": labels,\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n\tif err := h.pages[\"runs\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n\t}\n}\n\n// stepEntry is a merged view of a step execution for the template.\ntype stepEntry struct {\n\tIndex     int\n\tStepName  string\n\tResult    string\n\tStartedAt time.Time\n\tDuration  string\n}\n\n// mergeCaptures collapses started/completed capture pairs into single entries.\nfunc mergeCaptures(caps []*domain.StepExecution) []stepEntry {\n\tvar entries []stepEntry\n\t// Track pending started rows by step name (LIFO for retries)\n\tpending := map[string]*domain.StepExecution{}\n\n\tfor _, c := range caps {\n\t\tif c.Result == \"\" {\n\t\t\t// step_started row\n\t\t\tpending[c.StepName] = c\n\t\t\tcontinue\n\t\t}\n\t\t// step_completed row — merge with pending started if available\n\t\tstartedAt := c.StartedAt\n\t\tif started := pending[c.StepName]; started != nil {\n\t\t\tstartedAt = started.StartedAt\n\t\t\tdelete(pending, c.StepName)\n\t\t}\n\t\tentries = append(entries, stepEntry{\n\t\t\tIndex:     len(entries),\n\t\t\tStepName:  c.StepName,\n\t\t\tResult:    c.Result,\n\t\t\tStartedAt: startedAt,\n\t\t\tDuration:  formatDuration(startedAt, c.CompletedAt),\n\t\t})\n\t}\n\n\t// Append any started-but-not-completed steps (still running)\n\tfor _, c := range caps {\n\t\tif c.Result == \"\" {\n\t\t\tif _, used := pending[c.StepName]; !used {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tentries = append(entries, stepEntry{\n\t\t\t\tIndex:     len(entries),\n\t\t\t\tStepName:  c.StepName,\n\t\t\t\tStartedAt: c.StartedAt,\n\t\t\t})\n\t\t\tdelete(pending, c.StepName)\n\t\t}\n\t}\n\n\treturn entries\n}\n\n// containerState inspects the container for a run and returns one of:\n//   - \"running\"   – container exists and is running\n//   - \"stopped\"   – container exists, not running, not kept\n//   - \"available\" – container exists, not running, kept (can be deleted)\n//   - \"removed\"   – no container ID, no manager, or inspect failed\nfunc (h *Handler) containerState(ctx context.Context, run *domain.Run) string {\n\tif run.ContainerID == \"\" {\n\t\treturn \"removed\"\n\t}\n\tmgr, ok := h.container.(ContainerManager)\n\tif !ok {\n\t\treturn \"removed\"\n\t}\n\tstatus, err := mgr.Inspect(ctx, run.ContainerID)\n\tif err != nil {\n\t\treturn \"removed\"\n\t}\n\tif status.Running {\n\t\treturn \"running\"\n\t}\n\tif run.ContainerKept {\n\t\treturn \"available\"\n\t}\n\treturn \"stopped\"\n}\n\nfunc (h *Handler) handleRunDetail(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n\tif err != nil {\n\t\tcaps = nil // non-fatal\n\t}\n\n\tsteps := mergeCaptures(caps)\n\n\tdata := map[string]any{\n\t\t\"Title\":          \"Run \" + run.ID,\n\t\t\"Run\":            run,\n\t\t\"Steps\":          steps,\n\t\t\"Page\":           \"detail\",\n\t\t\"ContainerState\": h.containerState(r.Context(), run),\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n\tif err := h.pages[\"run_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n\t}\n}\n\n// --- JSON API handlers ---\n\ntype apiRun struct {\n\tID           string `json:\"id\"`\n\tWorkflowName string `json:\"workflow_name\"`\n\tProjectDir   string `json:\"project_dir\"`\n\tProjectLabel string `json:\"project_label\"`\n\tState        string `json:\"state\"`\n\tStartedAt    string `json:\"started_at\"`\n\tCompletedAt  string `json:\"completed_at\"`\n\tContainerID  string `json:\"container_id\"`\n\tErrorMessage string `json:\"error_message\"`\n}\n\ntype apiStep struct {\n\tStepName    string `json:\"step_name\"`\n\tResult      string `json:\"result\"`\n\tStartedAt   string `json:\"started_at\"`\n\tCompletedAt string `json:\"completed_at\"`\n\tDuration    string `json:\"duration\"`\n}\n\ntype apiRunDetail struct {\n\tapiRun\n\tContainerState string    `json:\"container_state\"`\n\tSteps          []apiStep `json:\"steps\"`\n}\n\nfunc toAPIRun(r *domain.Run, labels map[string]string) apiRun {\n\treturn apiRun{\n\t\tID:           r.ID,\n\t\tWorkflowName: r.WorkflowName,\n\t\tProjectDir:   r.ProjectDir,\n\t\tProjectLabel: labels[r.ProjectDir],\n\t\tState:        string(r.State),\n\t\tStartedAt:    formatTime(r.StartedAt),\n\t\tCompletedAt:  formatTime(r.CompletedAt),\n\t\tContainerID:  r.ContainerID,\n\t\tErrorMessage: r.ErrorMessage,\n\t}\n}\n\nfunc (h *Handler) handleAPIRuns(w http.ResponseWriter, r *http.Request) {\n\tprojectFilter := r.URL.Query().Get(\"project\")\n\n\tvar runs []*domain.Run\n\tvar err error\n\tif projectFilter != \"\" {\n\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n\t} else {\n\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n\t}\n\tif err != nil {\n\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\tresult := make([]apiRun, len(runs))\n\tfor i, run := range runs {\n\t\tresult[i] = toAPIRun(run, labels)\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(result)\n}\n\nfunc (h *Handler) handleAPIProjects(w http.ResponseWriter, r *http.Request) {\n\tprojects, err := h.store.ListProjects(r.Context())\n\tif err != nil {\n\t\thttp.Error(w, \"failed to list projects\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\tlabels := projectLabels(projects)\n\n\ttype apiHealth struct {\n\t\tStatus string `json:\"status\"`\n\t\tPassed int    `json:\"passed\"`\n\t\tFailed int    `json:\"failed\"`\n\t\tTotal  int    `json:\"total\"`\n\t}\n\ttype apiProject struct {\n\t\tDir         string    `json:\"dir\"`\n\t\tLabel       string    `json:\"label\"`\n\t\tHealth      apiHealth `json:\"health\"`\n\t\tActiveCount int       `json:\"active_count\"`\n\t}\n\tresult := make([]apiProject, len(projects))\n\tfor i, dir := range projects {\n\t\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n\t\trunValues := make([]domain.Run, len(runs))\n\t\tfor j, rr := range runs {\n\t\t\trunValues[j] = *rr\n\t\t}\n\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n\t\tvar activeCount int\n\t\tfor _, rr := range runs {\n\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n\t\t\t\tactiveCount++\n\t\t\t}\n\t\t}\n\t\tresult[i] = apiProject{\n\t\t\tDir:   dir,\n\t\t\tLabel: labels[dir],\n\t\t\tHealth: apiHealth{\n\t\t\t\tStatus: string(health.Status),\n\t\t\t\tPassed: health.Passed,\n\t\t\t\tFailed: health.Failed,\n\t\t\t\tTotal:  health.Total,\n\t\t\t},\n\t\t\tActiveCount: activeCount,\n\t\t}\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(result)\n}\n\nfunc (h *Handler) handleAPIRunDetail(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n\tif err != nil {\n\t\tcaps = nil\n\t}\n\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\tmerged := mergeCaptures(caps)\n\tsteps := make([]apiStep, len(merged))\n\tfor i, e := range merged {\n\t\tsteps[i] = apiStep{\n\t\t\tStepName:  e.StepName,\n\t\t\tResult:    e.Result,\n\t\t\tStartedAt: formatTime(e.StartedAt),\n\t\t\tDuration:  e.Duration,\n\t\t}\n\t}\n\n\tdetail := apiRunDetail{\n\t\tapiRun:         toAPIRun(run, labels),\n\t\tContainerState: h.containerState(r.Context(), run),\n\t\tSteps:          steps,\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(detail)\n}\n\nfunc (h *Handler) handleAPIStepOutput(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\tstep := r.PathValue(\"step\")\n\tlogType := r.URL.Query().Get(\"type\") // optional: \"script\", \"llm\"\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\t// Try log index first for fast lookup\n\tif h.logStore != nil {\n\t\tlogFiles, err := h.logStore.GetLogFilesByStep(r.Context(), id, step)\n\t\tif err == nil && len(logFiles) > 0 {\n\t\t\t// If type filter specified, narrow results\n\t\t\tfor _, lf := range logFiles {\n\t\t\t\tif logType != \"\" && lf.FileType != logType {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n\t\t\t\tif readErr == nil && len(data) > 0 {\n\t\t\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\t\t\t\t\tw.Write(data)\n\t\t\t\t\treturn\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", id, \"output\")\n\n\t// Fall back to file path conventions\n\t// If type is \"llm\", try llm-<step>.log\n\tif logType == \"llm\" {\n\t\tllmPath := filepath.Join(outputDir, \"llm-\"+step+\".log\")\n\t\tdata, err := os.ReadFile(llmPath)\n\t\tif err == nil && len(data) > 0 {\n\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\t\t\tw.Write(data)\n\t\t\treturn\n\t\t}\n\t}\n\n\t// Try per-step output first, fall back to container.log, then live docker logs\n\toutputPath := filepath.Join(outputDir, step+\".log\")\n\tdata, err := os.ReadFile(outputPath)\n\tif err == nil && len(data) > 0 {\n\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\t\tw.Write(data)\n\t\treturn\n\t}\n\n\tcontainerLog := filepath.Join(outputDir, \"container.log\")\n\tdata, err = os.ReadFile(containerLog)\n\tif err == nil && len(data) > 0 {\n\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\t\tw.Write(data)\n\t\treturn\n\t}\n\n\t// Last resort: try live docker logs from still-existing container\n\tif h.container != nil && run.ContainerID != \"\" {\n\t\tif logs, logErr := h.container.Logs(r.Context(), run.ContainerID); logErr == nil && logs != \"\" {\n\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\t\t\tw.Write([]byte(logs))\n\t\t\treturn\n\t\t}\n\t}\n\n\thttp.Error(w, \"step output not found\", http.StatusNotFound)\n}\n\nfunc (h *Handler) handleAPIDeleteContainer(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusNotFound)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"run not found\"})\n\t\treturn\n\t}\n\n\tmgr, ok := h.container.(ContainerManager)\n\tif !ok || run.ContainerID == \"\" {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusBadRequest)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"container management not available\"})\n\t\treturn\n\t}\n\n\tif err := mgr.Remove(r.Context(), run.ContainerID); err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to remove container: %v\", err)})\n\t\treturn\n\t}\n\n\trun.ContainerKept = false\n\tif err := h.store.UpdateRun(r.Context(), run); err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to update run: %v\", err)})\n\t\treturn\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n}\n\nfunc (h *Handler) handleAPITriggerOrchestrator(w http.ResponseWriter, r *http.Request) {\n\tlabel := r.PathValue(\"name\")\n\n\t// Resolve label back to project directory via the store.\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\tvar projectDir string\n\tfor dir, l := range labels {\n\t\tif l == label {\n\t\t\tprojectDir = dir\n\t\t\tbreak\n\t\t}\n\t}\n\tif projectDir == \"\" {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusNotFound)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"project not found\"})\n\t\treturn\n\t}\n\n\tif h.orchestrateFn == nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusNotImplemented)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n\t\treturn\n\t}\n\n\tdispatched, err := h.orchestrateFn(r.Context(), projectDir)\n\tif err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": err.Error()})\n\t\treturn\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]any{\"status\": \"ok\", \"project\": label, \"dispatched\": dispatched})\n}\n\n// handleAPIStream serves an SSE stream of log lines for a run.\n// For active runs, it subscribes to the live broadcaster.\n// For completed runs, it serves the archived full.log then closes.\nfunc (h *Handler) handleAPIStream(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\tflusher, ok := w.(http.Flusher)\n\tif !ok {\n\t\thttp.Error(w, \"streaming not supported\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"text/event-stream\")\n\tw.Header().Set(\"Cache-Control\", \"no-cache\")\n\tw.Header().Set(\"Connection\", \"keep-alive\")\n\tw.Header().Set(\"X-Accel-Buffering\", \"no\")\n\n\tisComplete := run.State == domain.RunStateSucceeded ||\n\t\trun.State == domain.RunStateFailed ||\n\t\trun.State == domain.RunStateCancelled\n\n\tif isComplete {\n\t\t// Serve archived full.log\n\t\th.streamFullLog(w, flusher, run)\n\t\t// Send done event\n\t\tfmt.Fprintf(w, \"event: done\\ndata: %s\\n\\n\", string(run.State))\n\t\tflusher.Flush()\n\t\treturn\n\t}\n\n\t// Active run: subscribe to live broadcaster\n\tif h.logBroadcast == nil {\n\t\thttp.Error(w, \"log streaming not available\", http.StatusServiceUnavailable)\n\t\treturn\n\t}\n\n\tsub := h.logBroadcast.Subscribe(id)\n\tdefer h.logBroadcast.Unsubscribe(id, sub)\n\n\tctx := r.Context()\n\tfor {\n\t\tselect {\n\t\tcase <-ctx.Done():\n\t\t\treturn\n\t\tcase line, ok := <-sub.C:\n\t\t\tif !ok {\n\t\t\t\t// Stream finished (run completed)\n\t\t\t\tfmt.Fprintf(w, \"event: done\\ndata: completed\\n\\n\")\n\t\t\t\tflusher.Flush()\n\t\t\t\treturn\n\t\t\t}\n\t\t\tdata, _ := json.Marshal(line)\n\t\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n\t\t\tflusher.Flush()\n\t\t}\n\t}\n}\n\n// logLineRegex parses \"[timestamp] [type] content\" format from full.log.\nvar logLineRegex = regexp.MustCompile(`^\\[([^\\]]+)\\] \\[([^\\]]+)\\] (.*)$`)\n\n// streamFullLog reads the archived full.log file and sends its entries as SSE events.\nfunc (h *Handler) streamFullLog(w http.ResponseWriter, flusher http.Flusher, run *domain.Run) {\n\tlogPath := filepath.Join(run.ProjectDir, \".cloche\", run.ID, \"output\", \"full.log\")\n\tf, err := os.Open(logPath)\n\tif err != nil {\n\t\treturn\n\t}\n\tdefer f.Close()\n\n\tscanner := bufio.NewScanner(f)\n\tfor scanner.Scan() {\n\t\ttext := scanner.Text()\n\t\tline := parseFullLogLine(text)\n\t\tdata, _ := json.Marshal(line)\n\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n\t\tflusher.Flush()\n\t}\n}\n\n// parseFullLogLine parses a \"[timestamp] [type] content\" line into a LogLine.\nfunc parseFullLogLine(text string) logstream.LogLine {\n\tm := logLineRegex.FindStringSubmatch(text)\n\tif m == nil {\n\t\treturn logstream.LogLine{\n\t\t\tTimestamp: time.Now().UTC().Format(time.RFC3339),\n\t\t\tType:      \"script\",\n\t\t\tContent:   text,\n\t\t}\n\t}\n\treturn logstream.LogLine{\n\t\tTimestamp: m[1],\n\t\tType:      m[2],\n\t\tContent:   m[3],\n\t}\n}\n\n// --- Project detail handlers ---\n\n// resolveProjectDir resolves a project label from the URL to its directory path.\n// Returns (dir, label, ok). Writes a JSON error response if not found.\nfunc (h *Handler) resolveProjectDir(w http.ResponseWriter, r *http.Request) (string, string, bool) {\n\tlabel := r.PathValue(\"name\")\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\tfor dir, l := range labels {\n\t\tif l == label {\n\t\t\treturn dir, label, true\n\t\t}\n\t}\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tw.WriteHeader(http.StatusNotFound)\n\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"project not found\"})\n\treturn \"\", \"\", false\n}\n\nfunc (h *Handler) handleProjectDetail(w http.ResponseWriter, r *http.Request) {\n\tdir, label, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\n\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n\tn := 10\n\tif n > len(runs) {\n\t\tn = len(runs)\n\t}\n\tdots := make([]recentRunDot, n)\n\tfor i := 0; i < n; i++ {\n\t\tdots[i] = recentRunDot{ID: runs[i].ID, State: string(runs[i].State)}\n\t}\n\n\tdata := map[string]any{\n\t\t\"Title\":      label,\n\t\t\"Label\":      label,\n\t\t\"Dir\":        dir,\n\t\t\"RecentRuns\": dots,\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n\tif err := h.pages[\"project_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n\t}\n}\n\nfunc (h *Handler) handleAPIOrchestratorStatus(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\tif h.orchestrator == nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tjson.NewEncoder(w).Encode(map[string]any{\"enabled\": false, \"in_flight\": 0, \"concurrency\": 0})\n\t\treturn\n\t}\n\tenabled, inFlight, concurrency := h.orchestrator.Status(dir)\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]any{\n\t\t\"enabled\":     enabled,\n\t\t\"in_flight\":   inFlight,\n\t\t\"concurrency\": concurrency,\n\t})\n}\n\nfunc (h *Handler) handleAPIOrchestratorStart(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\tif h.orchestrator == nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusNotImplemented)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n\t\treturn\n\t}\n\th.orchestrator.SetEnabled(dir, true)\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n}\n\nfunc (h *Handler) handleAPIOrchestratorStop(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\tif h.orchestrator == nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusNotImplemented)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n\t\treturn\n\t}\n\th.orchestrator.SetEnabled(dir, false)\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n}\n\nfunc (h *Handler) handleAPIOrchestratorConcurrency(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\tif h.orchestrator == nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusNotImplemented)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n\t\treturn\n\t}\n\tvar body struct {\n\t\tConcurrency int `json:\"concurrency\"`\n\t}\n\tif err := json.NewDecoder(r.Body).Decode(&body); err != nil || body.Concurrency < 1 {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusBadRequest)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"concurrency must be a positive integer\"})\n\t\treturn\n\t}\n\th.orchestrator.SetConcurrency(dir, body.Concurrency)\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n}\n\nfunc (h *Handler) handleAPIProjectInfo(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\n\t// Docker image: read FROM line from Dockerfile\n\tdockerImage := \"\"\n\tdockerfilePath := filepath.Join(dir, \".cloche\", \"Dockerfile\")\n\tif data, err := os.ReadFile(dockerfilePath); err == nil {\n\t\t// Find the last FROM line (final stage)\n\t\tfor _, line := range strings.Split(string(data), \"\\n\") {\n\t\t\ttrimmed := strings.TrimSpace(line)\n\t\t\tif strings.HasPrefix(strings.ToUpper(trimmed), \"FROM \") {\n\t\t\t\tparts := strings.Fields(trimmed)\n\t\t\t\tif len(parts) >= 2 {\n\t\t\t\t\tdockerImage = parts[1]\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\t// Version\n\tversion := 0\n\tversionPath := filepath.Join(dir, \".cloche\", \"version\")\n\tif data, err := os.ReadFile(versionPath); err == nil {\n\t\tif v, err := strconv.Atoi(strings.TrimSpace(string(data))); err == nil {\n\t\t\tversion = v\n\t\t}\n\t}\n\n\t// Prompt files history\n\ttype commitEntry struct {\n\t\tSHA     string `json:\"sha\"`\n\t\tDate    string `json:\"date\"`\n\t\tMessage string `json:\"message\"`\n\t}\n\ttype promptFile struct {\n\t\tPath    string        `json:\"path\"`\n\t\tHistory []commitEntry `json:\"history\"`\n\t}\n\n\tvar promptFiles []promptFile\n\tpromptsDir := filepath.Join(dir, \".cloche\", \"prompts\")\n\tif entries, err := os.ReadDir(promptsDir); err == nil {\n\t\tfor _, e := range entries {\n\t\t\tif e.IsDir() {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\trelPath := filepath.Join(\".cloche\", \"prompts\", e.Name())\n\t\t\tcmd := exec.Command(\"git\", \"log\", \"--follow\", \"--format=%H %aI %s\", \"--\", relPath)\n\t\t\tcmd.Dir = dir\n\t\t\tout, err := cmd.Output()\n\t\t\tif err != nil {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tvar history []commitEntry\n\t\t\tfor _, line := range strings.Split(strings.TrimSpace(string(out)), \"\\n\") {\n\t\t\t\tif line == \"\" {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tparts := strings.SplitN(line, \" \", 3)\n\t\t\t\tif len(parts) < 3 {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\t// Parse date to short form\n\t\t\t\tdateStr := parts[1]\n\t\t\t\tif t, err := time.Parse(time.RFC3339, dateStr); err == nil {\n\t\t\t\t\tdateStr = t.Format(\"2006-01-02\")\n\t\t\t\t}\n\t\t\t\thistory = append(history, commitEntry{\n\t\t\t\t\tSHA:     parts[0][:7],\n\t\t\t\t\tDate:    dateStr,\n\t\t\t\t\tMessage: parts[2],\n\t\t\t\t})\n\t\t\t}\n\t\t\tpromptFiles = append(promptFiles, promptFile{Path: relPath, History: history})\n\t\t}\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]any{\n\t\t\"docker_image\": dockerImage,\n\t\t\"version\":      version,\n\t\t\"prompt_files\": promptFiles,\n\t})\n}\n\nfunc (h *Handler) handleAPIPromptDiff(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\tfile := r.URL.Query().Get(\"file\")\n\tsha := r.URL.Query().Get(\"sha\")\n\tif file == \"\" || sha == \"\" {\n\t\thttp.Error(w, \"file and sha required\", http.StatusBadRequest)\n\t\treturn\n\t}\n\n\t// Validate sha is alphanumeric to prevent injection\n\tfor _, c := range sha {\n\t\tif !((c >= '0' && c <= '9') || (c >= 'a' && c <= 'f') || (c >= 'A' && c <= 'F')) {\n\t\t\thttp.Error(w, \"invalid sha\", http.StatusBadRequest)\n\t\t\treturn\n\t\t}\n\t}\n\n\tcmd := exec.Command(\"git\", \"diff\", sha+\"^..\"+sha, \"--\", file)\n\tcmd.Dir = dir\n\tout, err := cmd.Output()\n\tif err != nil {\n\t\thttp.Error(w, \"diff not available\", http.StatusNotFound)\n\t\treturn\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\tw.Write(out)\n}\n\nfunc (h *Handler) handleAPIWorkflows(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\n\tclocheDir := filepath.Join(dir, \".cloche\")\n\tentries, err := os.ReadDir(clocheDir)\n\tif err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tjson.NewEncoder(w).Encode([]any{})\n\t\treturn\n\t}\n\n\ttype apiWire struct {\n\t\tFrom   string `json:\"from\"`\n\t\tResult string `json:\"result\"`\n\t\tTo     string `json:\"to\"`\n\t}\n\ttype apiStepDef struct {\n\t\tName    string            `json:\"name\"`\n\t\tType    string            `json:\"type\"`\n\t\tResults []string          `json:\"results\"`\n\t\tConfig  map[string]string `json:\"config\"`\n\t}\n\ttype apiWorkflow struct {\n\t\tName      string       `json:\"name\"`\n\t\tFile      string       `json:\"file\"`\n\t\tSteps     []apiStepDef `json:\"steps\"`\n\t\tWires     []apiWire    `json:\"wires\"`\n\t\tEntryStep string       `json:\"entry_step\"`\n\t}\n\n\tvar workflows []apiWorkflow\n\tfor _, e := range entries {\n\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n\t\t\tcontinue\n\t\t}\n\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\twf, err := dsl.Parse(string(data))\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tvar steps []apiStepDef\n\t\tfor _, s := range wf.Steps {\n\t\t\tsteps = append(steps, apiStepDef{\n\t\t\t\tName:    s.Name,\n\t\t\t\tType:    string(s.Type),\n\t\t\t\tResults: s.Results,\n\t\t\t\tConfig:  s.Config,\n\t\t\t})\n\t\t}\n\t\t// Sort steps by name for consistent ordering\n\t\tsort.Slice(steps, func(i, j int) bool { return steps[i].Name < steps[j].Name })\n\n\t\tvar wires []apiWire\n\t\tfor _, wire := range wf.Wiring {\n\t\t\twires = append(wires, apiWire{From: wire.From, Result: wire.Result, To: wire.To})\n\t\t}\n\n\t\tworkflows = append(workflows, apiWorkflow{\n\t\t\tName:      wf.Name,\n\t\t\tFile:      filepath.Join(\".cloche\", e.Name()),\n\t\t\tSteps:     steps,\n\t\t\tWires:     wires,\n\t\t\tEntryStep: wf.EntryStep,\n\t\t})\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(workflows)\n}\n\nfunc (h *Handler) handleAPIStepContent(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\tworkflowName := r.PathValue(\"workflow\")\n\tstepName := r.PathValue(\"step\")\n\n\t// Find the workflow file\n\tclocheDir := filepath.Join(dir, \".cloche\")\n\tvar wf *domain.Workflow\n\tentries, _ := os.ReadDir(clocheDir)\n\tfor _, e := range entries {\n\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n\t\t\tcontinue\n\t\t}\n\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tparsed, err := dsl.Parse(string(data))\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tif parsed.Name == workflowName {\n\t\t\twf = parsed\n\t\t\tbreak\n\t\t}\n\t}\n\tif wf == nil {\n\t\thttp.Error(w, \"workflow not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\tstep, ok := wf.Steps[stepName]\n\tif !ok {\n\t\thttp.Error(w, \"step not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\t// Try to read the referenced file from step config\n\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\n\tif prompt := step.Config[\"prompt\"]; prompt != \"\" {\n\t\tdata, err := os.ReadFile(filepath.Join(dir, prompt))\n\t\tif err == nil {\n\t\t\tw.Write(data)\n\t\t\treturn\n\t\t}\n\t}\n\tif script := step.Config[\"command\"]; script != \"\" {\n\t\tw.Write([]byte(script))\n\t\treturn\n\t}\n\tif script := step.Config[\"script\"]; script != \"\" {\n\t\tdata, err := os.ReadFile(filepath.Join(dir, script))\n\t\tif err == nil {\n\t\t\tw.Write(data)\n\t\t\treturn\n\t\t}\n\t\tw.Write([]byte(script))\n\t\treturn\n\t}\n\n\thttp.Error(w, \"no content available\", http.StatusNotFound)\n}\n\n// --- Template helpers ---\n\nfunc stateColor(state domain.RunState) string {\n\tswitch state {\n\tcase domain.RunStatePending:\n\t\treturn \"pending\"\n\tcase domain.RunStateRunning:\n\t\treturn \"running\"\n\tcase domain.RunStateSucceeded:\n\t\treturn \"succeeded\"\n\tcase domain.RunStateFailed:\n\t\treturn \"failed\"\n\tcase domain.RunStateCancelled:\n\t\treturn \"cancelled\"\n\tdefault:\n\t\treturn \"pending\"\n\t}\n}\n\nfunc healthColor(status domain.HealthStatus) string {\n\tswitch status {\n\tcase domain.HealthGreen:\n\t\treturn \"green\"\n\tcase domain.HealthYellow:\n\t\treturn \"yellow\"\n\tcase domain.HealthRed:\n\t\treturn \"red\"\n\tcase domain.HealthBlue:\n\t\treturn \"blue\"\n\tdefault:\n\t\treturn \"grey\"\n\t}\n}\n\nfunc formatTime(t time.Time) string {\n\tif t.IsZero() {\n\t\treturn \"\"\n\t}\n\treturn t.Format(\"2006-01-02 15:04:05\")\n}\n\nfunc formatDuration(start, end time.Time) string {\n\tif start.IsZero() || end.IsZero() {\n\t\treturn \"\"\n\t}\n\td := end.Sub(start)\n\tif d < time.Second {\n\t\treturn fmt.Sprintf(\"%dms\", d.Milliseconds())\n\t}\n\tif d < time.Minute {\n\t\treturn fmt.Sprintf(\"%.1fs\", d.Seconds())\n\t}\n\treturn fmt.Sprintf(\"%dm%ds\", int(d.Minutes()), int(d.Seconds())%60)\n}\n\nfunc truncate(s string, n int) string {\n\tif len(s) <= n {\n\t\treturn s\n\t}\n\treturn s[:n] + \"...\"\n}\n\nfunc shortContainerID(id string) string {\n\tif len(id) > 12 {\n\t\treturn id[:12]\n\t}\n\treturn id\n}\n\n// projectLabels builds a mapping from full project directory paths to short\n// display labels. Each label is the final directory component (e.g.\n// \"myproject\" from \"/home/user/workspace/myproject\"). When two projects share\n// the same final name, the parent directory is prepended to disambiguate\n// (e.g. \"foo/bar\" vs \"baz/bar\").\nfunc projectLabels(dirs []string) map[string]string {\n\tlabels := make(map[string]string, len(dirs))\n\t// Group dirs by their base name to detect conflicts.\n\tbyBase := map[string][]string{}\n\tfor _, d := range dirs {\n\t\tbase := filepath.Base(d)\n\t\tbyBase[base] = append(byBase[base], d)\n\t}\n\tfor base, paths := range byBase {\n\t\tif len(paths) == 1 {\n\t\t\tlabels[paths[0]] = base\n\t\t} else {\n\t\t\tfor _, p := range paths {\n\t\t\t\tparent := filepath.Base(filepath.Dir(p))\n\t\t\t\tlabels[p] = parent + \"/\" + base\n\t\t\t}\n\t\t}\n\t}\n\treturn labels\n}\n\ntype projectEntry struct {\n\tDir            string\n\tLabel          string\n\tContainerCount int\n}\n","numLines":1358,"startLine":1,"totalLines":1358}}}
