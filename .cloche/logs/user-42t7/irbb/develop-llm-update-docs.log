 w.Code)\n+\tbody := w.Body.String()\n+\tassert.Contains(t, body, `id=\"cancel-run-btn\"`)\n+\tassert.Contains(t, body, \"Cancel\")\n+}\n+\n+func TestRunDetail_CancelButton_HiddenForTerminalRuns(t *testing.T) {\n+\th, store, mgr := setupHandlerWithContainerManager(t)\n+\tseedRunWithContainer(t, store, mgr, \"run-no-cancel\", \"develop\", \"/proj\", \"cid-terminal\", false)\n+\n+\treq := httptest.NewRequest(\"GET\", \"/runs/run-no-cancel\", nil)\n+\tw := httptest.NewRecorder()\n+\th.ServeHTTP(w, req)\n+\n+\tassert.Equal(t, http.StatusOK, w.Code)\n+\tbody := w.Body.String()\n+\t// The cancel button ID should not appear in the HTML header section\n+\t// (it may appear in the JS as a string literal, so check the h1 area)\n+\th1Start := strings.Index(body, \"<h1>\")\n+\th1End := strings.Index(body, \"</h1>\")\n+\trequire.NotEqual(t, -1, h1Start)\n+\trequire.NotEqual(t, -1, h1End)\n+\th1Section := body[h1Start : h1End+len(\"</h1>\")]\n+\tassert.NotContains(t, h1Section, `id=\"cancel-run-btn\"`)\n+}\n+\n func TestAPIProjects_HealthNoRuns(t *testing.T) {\n \th, _ := setupHandler(t)\n \ndiff --git a/internal/adapters/web/templates/run_detail.html b/internal/adapters/web/templates/run_detail.html\nindex 458917c..6a60fac 100644\n--- a/internal/adapters/web/templates/run_detail.html\n+++ b/internal/adapters/web/templates/run_detail.html\n@@ -2,6 +2,9 @@\n <h1>\n     <a href=\"/runs\">Runs</a> / {{.Run.ID}}\n     <span class=\"badge badge-{{stateColor .Run.State}}\">{{.Run.State}}</span>\n+    {{if or (eq .Run.State \"pending\") (eq .Run.State \"running\")}}\n+    <button class=\"btn btn-danger btn-sm\" id=\"cancel-run-btn\" onclick=\"cancelRun('{{.Run.ID}}')\" style=\"margin-left:0.5rem;\">Cancel</button>\n+    {{end}}\n </h1>\n \n <div class=\"run-meta\">\n@@ -248,6 +251,26 @@\n     }\n })();\n \n+// Cancel run\n+    window.cancelRun = function(runID) {\n+        var btn = document.getElementById('cancel-run-btn');\n+        if (btn) btn.disabled = true;\n+        fetch('/api/runs/' + runID + '/stop', { method: 'POST' })\n+            .then(function(r) { return r.json().then(function(d) { return {ok: r.ok, data: d}; }); })\n+            .then(function(res) {\n+                if (res.ok) {\n+                    location.reload();\n+                } else {\n+                    if (btn) btn.disabled = false;\n+                    alert('Failed to cancel run: ' + (res.data.error || 'unknown error'));\n+                }\n+            })\n+            .catch(function() {\n+                if (btn) btn.disabled = false;\n+                alert('Failed to cancel run');\n+            });\n+    };\n+\n // Delete container\n     window.deleteContainer = function(runID) {\n         var btn = document.getElementById('delete-container-btn');","stderr":"","interrupted":false,"isImage":false,"noOutputExpected":false}}
