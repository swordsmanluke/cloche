{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KFitwPGfd6BxX1LG7HZxM5","type":"tool_result","content":"     1→package grpc\n     2→\n     3→import (\n     4→\t\"bufio\"\n     5→\t\"context\"\n     6→\t\"encoding/json\"\n     7→\t\"fmt\"\n     8→\t\"log\"\n     9→\t\"os\"\n    10→\t\"os/exec\"\n    11→\t\"path/filepath\"\n    12→\t\"strings\"\n    13→\t\"sync\"\n    14→\t\"time\"\n    15→\n    16→\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    17→\t\"github.com/cloche-dev/cloche/internal/adapters/docker\"\n    18→\t\"github.com/cloche-dev/cloche/internal/config\"\n    19→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    20→\t\"github.com/cloche-dev/cloche/internal/evolution\"\n    21→\t\"github.com/cloche-dev/cloche/internal/host\"\n    22→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    23→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    24→\t\"github.com/cloche-dev/cloche/internal/protocol\"\n    25→\trpcgrpc \"google.golang.org/grpc\"\n    26→)\n    27→\n    28→type ClocheServer struct {\n    29→\tpb.UnimplementedClocheServiceServer\n    30→\tstore        ports.RunStore\n    31→\tcaptures     ports.CaptureStore\n    32→\tlogStore     ports.LogStore\n    33→\tcontainer    ports.ContainerRuntime\n    34→\tdefaultImage string\n    35→\tevolution    *evolution.Trigger\n    36→\tlogBroadcast *logstream.Broadcaster\n    37→\tshutdownFn   func()\n    38→\tmu           sync.Mutex\n    39→\trunIDs       map[string]string      // run_id -> container_id\n    40→\tloops        map[string]*host.Loop  // project_dir -> orchestration loop\n    41→}\n    42→\n    43→func NewClocheServer(store ports.RunStore, container ports.ContainerRuntime) *ClocheServer {\n    44→\treturn &ClocheServer{\n    45→\t\tstore:     store,\n    46→\t\tcontainer: container,\n    47→\t\trunIDs:    make(map[string]string),\n    48→\t\tloops:     make(map[string]*host.Loop),\n    49→\t}\n    50→}\n    51→\n    52→func NewClocheServerWithCaptures(store ports.RunStore, captures ports.CaptureStore, container ports.ContainerRuntime, defaultImage string) *ClocheServer {\n    53→\treturn &ClocheServer{\n    54→\t\tstore:        store,\n    55→\t\tcaptures:     captures,\n    56→\t\tcontainer:    container,\n    57→\t\tdefaultImage: defaultImage,\n    58→\t\trunIDs:       make(map[string]string),\n    59→\t\tloops:        make(map[string]*host.Loop),\n    60→\t}\n    61→}\n    62→\n    63→// SetLogStore attaches a log store to the server for indexing extracted log files.\n    64→func (s *ClocheServer) SetLogStore(ls ports.LogStore) {\n    65→\ts.logStore = ls\n    66→}\n    67→\n    68→\n    69→// SetEvolution attaches an evolution trigger to the server.\n    70→func (s *ClocheServer) SetEvolution(trigger *evolution.Trigger) {\n    71→\ts.evolution = trigger\n    72→}\n    73→\n    74→// SetLogBroadcaster attaches a log broadcaster for live-streaming LLM output.\n    75→func (s *ClocheServer) SetLogBroadcaster(b *logstream.Broadcaster) {\n    76→\ts.logBroadcast = b\n    77→}\n    78→\n    79→// SetShutdownFunc sets the callback invoked when the Shutdown RPC is called.\n    80→func (s *ClocheServer) SetShutdownFunc(fn func()) {\n    81→\ts.shutdownFn = fn\n    82→}\n    83→\n    84→func (s *ClocheServer) RunWorkflow(ctx context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error) {\n    85→\tif s.container == nil {\n    86→\t\treturn nil, fmt.Errorf(\"no container runtime configured\")\n    87→\t}\n    88→\n    89→\t// Generate a unique run ID, retrying on collision\n    90→\tvar runID string\n    91→\tfor attempts := 0; attempts < 10; attempts++ {\n    92→\t\trunID = domain.GenerateRunID(req.WorkflowName)\n    93→\t\texisting, err := s.store.GetRun(ctx, runID)\n    94→\t\tif err != nil {\n    95→\t\t\tbreak // ID is free\n    96→\t\t}\n    97→\t\t// Reuse if completed more than 1 hour ago\n    98→\t\tif !existing.CompletedAt.IsZero() && time.Since(existing.CompletedAt) > time.Hour {\n    99→\t\t\t_ = s.store.DeleteRun(ctx, runID)\n   100→\t\t\tbreak\n   101→\t\t}\n   102→\t}\n   103→\n   104→\t// Write prompt to .cloche/<run-id>/prompt.txt (run-specific to avoid conflicts)\n   105→\tif req.Prompt != \"\" {\n   106→\t\tclocheDir := filepath.Join(req.ProjectDir, \".cloche\", runID)\n   107→\t\tif err := os.MkdirAll(clocheDir, 0755); err != nil {\n   108→\t\t\treturn nil, fmt.Errorf(\"creating .cloche dir: %w\", err)\n   109→\t\t}\n   110→\t\tif err := os.WriteFile(filepath.Join(clocheDir, \"prompt.txt\"), []byte(req.Prompt), 0644); err != nil {\n   111→\t\t\treturn nil, fmt.Errorf(\"writing prompt: %w\", err)\n   112→\t\t}\n   113→\t}\n   114→\trun := domain.NewRun(runID, req.WorkflowName)\n   115→\trun.ProjectDir = req.ProjectDir\n   116→\trun.Title = req.Title\n   117→\tif err := s.store.CreateRun(ctx, run); err != nil {\n   118→\t\treturn nil, fmt.Errorf(\"creating run: %w\", err)\n   119→\t}\n   120→\n   121→\t// Resolve image: request-level override, then server default\n   122→\timage := req.Image\n   123→\tif image == \"\" {\n   124→\t\timage = s.defaultImage\n   125→\t}\n   126→\n   127→\t// Launch container start + tracking in background so the RPC returns immediately.\n   128→\t// The run stays in \"pending\" state until the container is up.\n   129→\tgo s.launchAndTrack(runID, image, req.KeepContainer, req)\n   130→\n   131→\treturn &pb.RunWorkflowResponse{RunId: runID}, nil\n   132→}\n   133→\n   134→// launchAndTrack starts the container and then tracks it to completion.\n   135→// It runs in a background goroutine with its own context, independent of the\n   136→// RPC context which may be cancelled after RunWorkflow returns.\n   137→func (s *ClocheServer) launchAndTrack(runID, image string, keepContainer bool, req *pb.RunWorkflowRequest) {\n   138→\tctx := context.Background()\n   139→\n   140→\t// Auto-rebuild image if the project Dockerfile has changed since last build.\n   141→\tif ensurer, ok := s.container.(ports.ImageEnsurer); ok {\n   142→\t\tif err := ensurer.EnsureImage(ctx, req.ProjectDir, image); err != nil {\n   143→\t\t\trun, _ := s.store.GetRun(ctx, runID)\n   144→\t\t\tif run != nil {\n   145→\t\t\t\trun.Fail(fmt.Sprintf(\"failed to ensure image: %v\", err))\n   146→\t\t\t\t_ = s.store.UpdateRun(ctx, run)\n   147→\t\t\t}\n   148→\t\t\tlog.Printf(\"run %s: failed to ensure image: %v\", runID, err)\n   149→\t\t\t\treturn\n   150→\t\t}\n   151→\t}\n   152→\n   153→\tbaseSHA := gitHEAD(req.ProjectDir)\n   154→\n   155→\tcontainerID, err := s.container.Start(ctx, ports.ContainerConfig{\n   156→\t\tImage:        image,\n   157→\t\tWorkflowName: req.WorkflowName,\n   158→\t\tProjectDir:   req.ProjectDir,\n   159→\t\tRunID:        runID,\n   160→\t\tNetworkAllow: []string{\"*\"},\n   161→\t})\n   162→\tif err != nil {\n   163→\t\trun, _ := s.store.GetRun(ctx, runID)\n   164→\t\tif run != nil {\n   165→\t\t\trun.Fail(fmt.Sprintf(\"failed to start container: %v\", err))\n   166→\t\t\t_ = s.store.UpdateRun(ctx, run)\n   167→\t\t}\n   168→\t\tlog.Printf(\"run %s: failed to start container: %v\", runID, err)\n   169→\t\treturn\n   170→\t}\n   171→\n   172→\ts.mu.Lock()\n   173→\ts.runIDs[runID] = containerID\n   174→\ts.mu.Unlock()\n   175→\n   176→\trun, _ := s.store.GetRun(ctx, runID)\n   177→\tif run != nil {\n   178→\t\trun.Start()\n   179→\t\trun.ContainerID = containerID\n   180→\t\trun.BaseSHA = baseSHA\n   181→\t\t_ = s.store.UpdateRun(ctx, run)\n   182→\t}\n   183→\n   184→\ts.trackRun(runID, containerID, req.ProjectDir, req.WorkflowName, keepContainer)\n   185→}\n   186→\n   187→func (s *ClocheServer) trackRun(runID, containerID, projectDir, workflowName string, keepContainer bool) {\n   188→\tctx := context.Background()\n   189→\n   190→\t// Attach to agent output\n   191→\treader, err := s.container.AttachOutput(ctx, containerID)\n   192→\tif err != nil {\n   193→\t\tlog.Printf(\"failed to attach to output for run %s: %v\", runID, err)\n   194→\t\t\treturn\n   195→\t}\n   196→\n   197→\t// Parse JSON-lines status messages\n   198→\tvar reportedResult string // captured from MsgRunCompleted, persisted after branch extraction\n   199→\tscanner := bufio.NewScanner(reader)\n   200→\tfor scanner.Scan() {\n   201→\t\tvar msg protocol.StatusMessage\n   202→\t\tif err := json.Unmarshal(scanner.Bytes(), &msg); err != nil {\n   203→\t\t\tcontinue\n   204→\t\t}\n   205→\n   206→\t\t// Fast path: log messages don't need store interaction.\n   207→\t\tif msg.Type == protocol.MsgLog {\n   208→\t\t\tif s.logBroadcast != nil {\n   209→\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n   210→\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n   211→\t\t\t\t\tType:      \"llm\",\n   212→\t\t\t\t\tContent:   msg.Message,\n   213→\t\t\t\t})\n   214→\t\t\t}\n   215→\t\t\tcontinue\n   216→\t\t}\n   217→\n   218→\t\trun, err := s.store.GetRun(ctx, runID)\n   219→\t\tif err != nil {\n   220→\t\t\tcontinue\n   221→\t\t}\n   222→\n   223→\t\tswitch msg.Type {\n   224→\t\tcase protocol.MsgStepStarted:\n   225→\t\t\trun.RecordStepStart(msg.StepName)\n   226→\t\t\tif s.captures != nil {\n   227→\t\t\t\t_ = s.captures.SaveCapture(ctx, runID, &domain.StepExecution{\n   228→\t\t\t\t\tStepName:  msg.StepName,\n   229→\t\t\t\t\tStartedAt: msg.Timestamp,\n   230→\t\t\t\t})\n   231→\t\t\t}\n   232→\t\tcase protocol.MsgStepCompleted:\n   233→\t\t\trun.RecordStepComplete(msg.StepName, msg.Result)\n   234→\t\t\tif s.captures != nil {\n   235→\t\t\t\t_ = s.captures.SaveCapture(ctx, runID, &domain.StepExecution{\n   236→\t\t\t\t\tStepName:    msg.StepName,\n   237→\t\t\t\t\tResult:      msg.Result,\n   238→\t\t\t\t\tCompletedAt: msg.Timestamp,\n   239→\t\t\t\t})\n   240→\t\t\t}\n   241→\t\tcase protocol.MsgRunTitle:\n   242→\t\t\tif run.Title == \"\" {\n   243→\t\t\t\trun.Title = msg.Message\n   244→\t\t\t}\n   245→\t\tcase protocol.MsgRunCompleted:\n   246→\t\t\treportedResult = msg.Result\n   247→\t\t\tcontinue // Don't persist terminal state yet; branch extraction must finish first\n   248→\t\t}\n   249→\n   250→\t\t_ = s.store.UpdateRun(ctx, run)\n   251→\t}\n   252→\treader.Close()\n   253→\n   254→\t// Signal live-stream subscribers that this run is done.\n   255→\tif s.logBroadcast != nil {\n   256→\t\ts.logBroadcast.Finish(runID)\n   257→\t}\n   258→\n   259→\t// Wait for process exit\n   260→\texitCode, err := s.container.Wait(ctx, containerID)\n   261→\tif err != nil {\n   262→\t\tlog.Printf(\"error waiting for run %s: %v\", runID, err)\n   263→\t}\n   264→\n   265→\t// Extract step output files from container before it's removed\n   266→\toutputDst := filepath.Join(projectDir, \".cloche\", runID, \"output\")\n   267→\tif err := os.MkdirAll(outputDst, 0755); err == nil {\n   268→\t\tif cpErr := s.container.CopyFrom(ctx, containerID, \"/workspace/.cloche/output/.\", outputDst); cpErr != nil {\n   269→\t\t\tlog.Printf(\"run %s: failed to extract output: %v\", runID, cpErr)\n   270→\t\t}\n   271→\t}\n   272→\n   273→\t// Capture full container stdout/stderr before the container is removed\n   274→\tif logs, logErr := s.container.Logs(ctx, containerID); logErr == nil && logs != \"\" {\n   275→\t\tcontainerLogPath := filepath.Join(outputDst, \"container.log\")\n   276→\t\tif writeErr := os.WriteFile(containerLogPath, []byte(logs), 0644); writeErr != nil {\n   277→\t\t\tlog.Printf(\"run %s: failed to write container.log: %v\", runID, writeErr)\n   278→\t\t}\n   279→\t}\n   280→\n   281→\t// Index extracted log files in the log store\n   282→\tif s.logStore != nil {\n   283→\t\ts.indexLogFiles(ctx, runID, outputDst)\n   284→\t}\n   285→\n   286→\t// Extract results to git branch BEFORE finalizing state, so that\n   287→\t// WaitRun callers (e.g. host workflow merge step) see branches exist\n   288→\t// before the run is marked complete.\n   289→\tresultLabel := reportedResult\n   290→\tif resultLabel == \"\" {\n   291→\t\tif exitCode == 0 {\n   292→\t\t\tresultLabel = \"succeeded\"\n   293→\t\t} else {\n   294→\t\t\tresultLabel = \"failed\"\n   295→\t\t}\n   296→\t}\n   297→\t{\n   298→\t\textractRun, _ := s.store.GetRun(ctx, runID)\n   299→\t\tif extractRun != nil && extractRun.BaseSHA != \"\" {\n   300→\t\t\tlog.Printf(\"run %s: extracting results to branch cloche/%s (baseSHA=%s)\", runID, runID, extractRun.BaseSHA)\n   301→\t\t\tif err := docker.ExtractResults(ctx, containerID, extractRun.ProjectDir, runID, extractRun.BaseSHA, workflowName, resultLabel); err != nil {\n   302→\t\t\t\tlog.Printf(\"run %s: failed to extract results to branch: %v\", runID, err)\n   303→\t\t\t} else {\n   304→\t\t\t\tlog.Printf(\"run %s: branch cloche/%s created successfully\", runID, runID)\n   305→\t\t\t}\n   306→\t\t} else {\n   307→\t\t\tlog.Printf(\"run %s: skipping branch extraction (baseSHA empty or run not found)\", runID)\n   308→\t\t}\n   309→\t}\n   310→\n   311→\t// Now finalize run state\n   312→\trun, err := s.store.GetRun(ctx, runID)\n   313→\tif err != nil {\n   314→\t\treturn\n   315→\t}\n   316→\tif run.State == domain.RunStateRunning {\n   317→\t\tif reportedResult == \"succeeded\" {\n   318→\t\t\trun.Complete(domain.RunStateSucceeded)\n   319→\t\t} else if reportedResult != \"\" {\n   320→\t\t\trun.Complete(domain.RunStateFailed)\n   321→\t\t} else if exitCode == 0 {\n   322→\t\t\trun.Complete(domain.RunStateSucceeded)\n   323→\t\t} else {\n   324→\t\t\trun.Fail(fmt.Sprintf(\"container exited with code %d\", exitCode))\n   325→\t\t}\n   326→\t\t_ = s.store.UpdateRun(ctx, run)\n   327→\t}\n   328→\n   329→\t// Fire evolution trigger if configured\n   330→\tif s.evolution != nil {\n   331→\t\ts.evolution.Fire(projectDir, workflowName, runID)\n   332→\t}\n   333→\n   334→\t// Merge is handled as a workflow step in host.cloche, not here.\n   335→\n   336→\t// Container retention policy:\n   337→\t// - Failed runs: always keep the container for debugging\n   338→\t// - Successful runs + --keep-container: keep the container\n   339→\t// - Successful runs without --keep-container: remove the container\n   340→\trunFinal, _ := s.store.GetRun(ctx, runID)\n   341→\trunFailed := runFinal != nil && (runFinal.State == domain.RunStateFailed || runFinal.State == domain.RunStateCancelled)\n   342→\n   343→\tif keepContainer || runFailed {\n   344→\t\treason := \"--keep-container\"\n   345→\t\tif runFailed {\n   346→\t\t\treason = \"run failed\"\n   347→\t\t}\n   348→\t\tlog.Printf(\"run %s: keeping container %s (%s)\", runID, containerID, reason)\n   349→\t\tif runFinal != nil {\n   350→\t\t\trunFinal.ContainerKept = true\n   351→\t\t\t_ = s.store.UpdateRun(ctx, runFinal)\n   352→\t\t}\n   353→\t} else {\n   354→\t\tif err := s.container.Remove(ctx, containerID); err != nil {\n   355→\t\t\tlog.Printf(\"run %s: failed to remove container %s: %v\", runID, containerID, err)\n   356→\t\t} else {\n   357→\t\t\tlog.Printf(\"run %s: removed container %s\", runID, containerID)\n   358→\t\t}\n   359→\t}\n   360→\n   361→\t// Cleanup mapping\n   362→\ts.mu.Lock()\n   363→\tdelete(s.runIDs, runID)\n   364→\ts.mu.Unlock()\n   365→}\n   366→\n   367→func (s *ClocheServer) ListRuns(ctx context.Context, req *pb.ListRunsRequest) (*pb.ListRunsResponse, error) {\n   368→\tvar since time.Time\n   369→\tif !req.All {\n   370→\t\tsince = time.Now().Add(-1 * time.Hour)\n   371→\t}\n   372→\truns, err := s.store.ListRuns(ctx, since)\n   373→\tif err != nil {\n   374→\t\treturn nil, fmt.Errorf(\"listing runs: %w\", err)\n   375→\t}\n   376→\n   377→\tresp := &pb.ListRunsResponse{}\n   378→\tfor _, run := range runs {\n   379→\t\tresp.Runs = append(resp.Runs, &pb.RunSummary{\n   380→\t\t\tRunId:        run.ID,\n   381→\t\t\tWorkflowName: run.WorkflowName,\n   382→\t\t\tState:        string(run.State),\n   383→\t\t\tStartedAt:    run.StartedAt.String(),\n   384→\t\t\tErrorMessage: run.ErrorMessage,\n   385→\t\t\tContainerId:  run.ContainerID,\n   386→\t\t\tTitle:        run.Title,\n   387→\t\t\tIsHost:       run.IsHost,\n   388→\t\t})\n   389→\t}\n   390→\treturn resp, nil\n   391→}\n   392→\n   393→func (s *ClocheServer) GetStatus(ctx context.Context, req *pb.GetStatusRequest) (*pb.GetStatusResponse, error) {\n   394→\trun, err := s.store.GetRun(ctx, req.RunId)\n   395→\tif err != nil {\n   396→\t\treturn nil, fmt.Errorf(\"getting run: %w\", err)\n   397→\t}\n   398→\n   399→\tresp := &pb.GetStatusResponse{\n   400→\t\tRunId:        run.ID,\n   401→\t\tWorkflowName: run.WorkflowName,\n   402→\t\tState:        string(run.State),\n   403→\t\tCurrentStep:  strings.Join(run.ActiveSteps, \",\"),\n   404→\t\tErrorMessage: run.ErrorMessage,\n   405→\t\tContainerId:  run.ContainerID,\n   406→\t\tTitle:        run.Title,\n   407→\t\tIsHost:       run.IsHost,\n   408→\t}\n   409→\n   410→\t// Check container liveness\n   411→\tif run.ContainerID != \"\" && s.container != nil {\n   412→\t\tif cs, err := s.container.Inspect(ctx, run.ContainerID); err == nil {\n   413→\t\t\tresp.ContainerAlive = cs.Running\n   414→\t\t\tif !cs.Running && !cs.FinishedAt.IsZero() {\n   415→\t\t\t\tresp.ContainerDeadSince = cs.FinishedAt.Format(time.RFC3339Nano)\n   416→\t\t\t}\n   417→\t\t}\n   418→\t}\n   419→\n   420→\t// Load step executions from captures store if available\n   421→\tif s.captures != nil {\n   422→\t\tcaptures, err := s.captures.GetCaptures(ctx, req.RunId)\n   423→\t\tif err == nil {\n   424→\t\t\tfor _, exec := range captures {\n   425→\t\t\t\tresp.StepExecutions = append(resp.StepExecutions, &pb.StepExecutionStatus{\n   426→\t\t\t\t\tStepName:    exec.StepName,\n   427→\t\t\t\t\tResult:      exec.Result,\n   428→\t\t\t\t\tStartedAt:   exec.StartedAt.String(),\n   429→\t\t\t\t\tCompletedAt: exec.CompletedAt.String(),\n   430→\t\t\t\t})\n   431→\t\t\t}\n   432→\t\t}\n   433→\t} else {\n   434→\t\tfor _, exec := range run.StepExecutions {\n   435→\t\t\tresp.StepExecutions = append(resp.StepExecutions, &pb.StepExecutionStatus{\n   436→\t\t\t\tStepName:    exec.StepName,\n   437→\t\t\t\tResult:      exec.Result,\n   438→\t\t\t\tStartedAt:   exec.StartedAt.String(),\n   439→\t\t\t\tCompletedAt: exec.CompletedAt.String(),\n   440→\t\t\t})\n   441→\t\t}\n   442→\t}\n   443→\n   444→\treturn resp, nil\n   445→}\n   446→\n   447→func (s *ClocheServer) StreamLogs(req *pb.StreamLogsRequest, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n   448→\tctx := stream.Context()\n   449→\n   450→\t// Verify run exists\n   451→\trun, err := s.store.GetRun(ctx, req.RunId)\n   452→\tif err != nil {\n   453→\t\treturn fmt.Errorf(\"run %q not found: %w\", req.RunId, err)\n   454→\t}\n   455→\n   456→\t// If step_name or log_type filter is set, serve content directly from the log index\n   457→\tif req.StepName != \"\" || req.LogType != \"\" {\n   458→\t\treturn s.streamFilteredLogs(ctx, req, run, stream)\n   459→\t}\n   460→\n   461→\tif s.captures == nil {\n   462→\t\treturn fmt.Errorf(\"captures store not configured\")\n   463→\t}\n   464→\n   465→\t// Check for full.log first — if it exists, serve it as the unified log\n   466→\tfullLogPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", \"full.log\")\n   467→\tif data, readErr := os.ReadFile(fullLogPath); readErr == nil && len(data) > 0 {\n   468→\t\tif err := stream.Send(&pb.LogEntry{\n   469→\t\t\tType:    \"full_log\",\n   470→\t\t\tMessage: string(data),\n   471→\t\t}); err != nil {\n   472→\t\t\treturn err\n   473→\t\t}\n   474→\t\t// Still send run completion entry\n   475→\t\tif run.State != domain.RunStateRunning && run.State != domain.RunStatePending {\n   476→\t\t\tif err := stream.Send(&pb.LogEntry{\n   477→\t\t\t\tType:      \"run_completed\",\n   478→\t\t\t\tResult:    string(run.State),\n   479→\t\t\t\tTimestamp: run.CompletedAt.String(),\n   480→\t\t\t\tMessage:   run.ErrorMessage,\n   481→\t\t\t}); err != nil {\n   482→\t\t\t\treturn err\n   483→\t\t\t}\n   484→\t\t}\n   485→\t\treturn nil\n   486→\t}\n   487→\n   488→\t// Fall back to capture-based streaming\n   489→\tcaptures, err := s.captures.GetCaptures(ctx, req.RunId)\n   490→\tif err != nil {\n   491→\t\treturn fmt.Errorf(\"getting captures: %w\", err)\n   492→\t}\n   493→\n   494→\tfor _, exec := range captures {\n   495→\t\t// Captures are stored as separate rows: one for step_started (no Result)\n   496→\t\t// and one for step_completed (has Result).\n   497→\t\tif exec.Result == \"\" {\n   498→\t\t\tentry := &pb.LogEntry{\n   499→\t\t\t\tType:      \"step_started\",\n   500→\t\t\t\tStepName:  exec.StepName,\n   501→\t\t\t\tTimestamp: exec.StartedAt.String(),\n   502→\t\t\t}\n   503→\t\t\tif err := stream.Send(entry); err != nil {\n   504→\t\t\t\treturn err\n   505→\t\t\t}\n   506→\t\t} else {\n   507→\t\t\t// Read step output from file, falling back to container.log\n   508→\t\t\tvar output string\n   509→\t\t\toutputPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", exec.StepName+\".log\")\n   510→\t\t\tif data, err := os.ReadFile(outputPath); err == nil && len(data) > 0 {\n   511→\t\t\t\toutput = string(data)\n   512→\t\t\t} else {\n   513→\t\t\t\tcontainerLogPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", \"container.log\")\n   514→\t\t\t\tif data, err := os.ReadFile(containerLogPath); err == nil {\n   515→\t\t\t\t\toutput = string(data)\n   516→\t\t\t\t}\n   517→\t\t\t}\n   518→\t\t\tentry := &pb.LogEntry{\n   519→\t\t\t\tType:      \"step_completed\",\n   520→\t\t\t\tStepName:  exec.StepName,\n   521→\t\t\t\tResult:    exec.Result,\n   522→\t\t\t\tTimestamp: exec.CompletedAt.String(),\n   523→\t\t\t\tMessage:   output,\n   524→\t\t\t}\n   525→\t\t\tif err := stream.Send(entry); err != nil {\n   526→\t\t\t\treturn err\n   527→\t\t\t}\n   528→\t\t}\n   529→\t}\n   530→\n   531→\t// Send run completion entry\n   532→\tif run.State != domain.RunStateRunning && run.State != domain.RunStatePending {\n   533→\t\tif err := stream.Send(&pb.LogEntry{\n   534→\t\t\tType:      \"run_completed\",\n   535→\t\t\tResult:    string(run.State),\n   536→\t\t\tTimestamp: run.CompletedAt.String(),\n   537→\t\t\tMessage:   run.ErrorMessage,\n   538→\t\t}); err != nil {\n   539→\t\t\treturn err\n   540→\t\t}\n   541→\t}\n   542→\n   543→\treturn nil\n   544→}\n   545→\n   546→// streamFilteredLogs serves log content filtered by step name and/or log type.\n   547→// It uses the log index when available, falling back to file path conventions.\n   548→func (s *ClocheServer) streamFilteredLogs(ctx context.Context, req *pb.StreamLogsRequest, run *domain.Run, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n   549→\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\")\n   550→\n   551→\t// Try log index first\n   552→\tif s.logStore != nil {\n   553→\t\tvar logFiles []*ports.LogFileEntry\n   554→\t\tvar err error\n   555→\n   556→\t\tif req.StepName != \"\" && req.LogType != \"\" {\n   557→\t\t\t// Filter by both step and type\n   558→\t\t\tlogFiles, err = s.logStore.GetLogFilesByStep(ctx, req.RunId, req.StepName)\n   559→\t\t\tif err == nil {\n   560→\t\t\t\tfiltered := logFiles[:0]\n   561→\t\t\t\tfor _, lf := range logFiles {\n   562→\t\t\t\t\tif lf.FileType == req.LogType {\n   563→\t\t\t\t\t\tfiltered = append(filtered, lf)\n   564→\t\t\t\t\t}\n   565→\t\t\t\t}\n   566→\t\t\t\tlogFiles = filtered\n   567→\t\t\t}\n   568→\t\t} else if req.StepName != \"\" {\n   569→\t\t\tlogFiles, err = s.logStore.GetLogFilesByStep(ctx, req.RunId, req.StepName)\n   570→\t\t} else {\n   571→\t\t\tlogFiles, err = s.logStore.GetLogFileByType(ctx, req.RunId, req.LogType)\n   572→\t\t}\n   573→\n   574→\t\tif err == nil && len(logFiles) > 0 {\n   575→\t\t\tfor _, lf := range logFiles {\n   576→\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n   577→\t\t\t\tif readErr != nil {\n   578→\t\t\t\t\tcontinue\n   579→\t\t\t\t}\n   580→\t\t\t\tif err := stream.Send(&pb.LogEntry{\n   581→\t\t\t\t\tType:     lf.FileType + \"_log\",\n   582→\t\t\t\t\tStepName: lf.StepName,\n   583→\t\t\t\t\tMessage:  string(data),\n   584→\t\t\t\t}); err != nil {\n   585→\t\t\t\t\treturn err\n   586→\t\t\t\t}\n   587→\t\t\t}\n   588→\t\t\treturn nil\n   589→\t\t}\n   590→\t}\n   591→\n   592→\t// Fall back to file path conventions\n   593→\tif req.StepName != \"\" {\n   594→\t\tvar logPath string\n   595→\t\tswitch req.LogType {\n   596→\t\tcase \"llm\":\n   597→\t\t\tlogPath = filepath.Join(outputDir, \"llm-\"+req.StepName+\".log\")\n   598→\t\tdefault:\n   599→\t\t\tlogPath = filepath.Join(outputDir, req.StepName+\".log\")\n   600→\t\t}\n   601→\n   602→\t\tdata, err := os.ReadFile(logPath)\n   603→\t\tif err != nil {\n   604→\t\t\treturn fmt.Errorf(\"log file not found for step %q: %w\", req.StepName, err)\n   605→\t\t}\n   606→\t\treturn stream.Send(&pb.LogEntry{\n   607→\t\t\tType:     \"step_log\",\n   608→\t\t\tStepName: req.StepName,\n   609→\t\t\tMessage:  string(data),\n   610→\t\t})\n   611→\t}\n   612→\n   613→\treturn fmt.Errorf(\"no log files found matching filter\")\n   614→}\n   615→\n   616→func (s *ClocheServer) StopRun(ctx context.Context, req *pb.StopRunRequest) (*pb.StopRunResponse, error) {\n   617→\ts.mu.Lock()\n   618→\tcontainerID, ok := s.runIDs[req.RunId]\n   619→\ts.mu.Unlock()\n   620→\n   621→\tif !ok {\n   622→\t\treturn nil, fmt.Errorf(\"run %q not found or already completed\", req.RunId)\n   623→\t}\n   624→\n   625→\tif err := s.container.Stop(ctx, containerID); err != nil {\n   626→\t\treturn nil, fmt.Errorf(\"stopping run: %w\", err)\n   627→\t}\n   628→\n   629→\t// Mark as cancelled in store\n   630→\trun, err := s.store.GetRun(ctx, req.RunId)\n   631→\tif err == nil {\n   632→\t\trun.Complete(domain.RunStateCancelled)\n   633→\t\t_ = s.store.UpdateRun(ctx, run)\n   634→\t}\n   635→\n   636→\treturn &pb.StopRunResponse{}, nil\n   637→}\n   638→\n   639→func (s *ClocheServer) DeleteContainer(ctx context.Context, req *pb.DeleteContainerRequest) (*pb.DeleteContainerResponse, error) {\n   640→\tif s.container == nil {\n   641→\t\treturn nil, fmt.Errorf(\"no container runtime configured\")\n   642→\t}\n   643→\n   644→\tid := req.Id\n   645→\tif id == \"\" {\n   646→\t\treturn nil, fmt.Errorf(\"id is required\")\n   647→\t}\n   648→\n   649→\t// Try to resolve as a run ID first\n   650→\tcontainerID := id\n   651→\trun, err := s.store.GetRun(ctx, id)\n   652→\tif err == nil {\n   653→\t\t// It's a run ID — use the container ID from the run record\n   654→\t\tif run.ContainerID == \"\" {\n   655→\t\t\treturn nil, fmt.Errorf(\"run %q has no associated container\", id)\n   656→\t\t}\n   657→\t\tcontainerID = run.ContainerID\n   658→\t}\n   659→\n   660→\t// Remove the container\n   661→\tif err := s.container.Remove(ctx, containerID); err != nil {\n   662→\t\treturn nil, fmt.Errorf(\"removing container: %w\", err)\n   663→\t}\n   664→\n   665→\t// If we resolved a run, clear the container_kept flag\n   666→\tif run != nil {\n   667→\t\trun.ContainerKept = false\n   668→\t\t_ = s.store.UpdateRun(ctx, run)\n   669→\t}\n   670→\n   671→\treturn &pb.DeleteContainerResponse{}, nil\n   672→}\n   673→\n   674→func (s *ClocheServer) EnableLoop(ctx context.Context, req *pb.EnableLoopRequest) (*pb.EnableLoopResponse, error) {\n   675→\tprojectDir := req.ProjectDir\n   676→\tif projectDir == \"\" {\n   677→\t\treturn nil, fmt.Errorf(\"project_dir is required\")\n   678→\t}\n   679→\n   680→\t// Verify host.cloche exists\n   681→\thostPath := filepath.Join(projectDir, \".cloche\", \"host.cloche\")\n   682→\tif _, err := os.Stat(hostPath); err != nil {\n   683→\t\treturn nil, fmt.Errorf(\"host.cloche not found in %s: %w\", projectDir, err)\n   684→\t}\n   685→\n   686→\t// Load project config for defaults.\n   687→\tprojCfg, _ := config.Load(projectDir)\n   688→\n   689→\tmaxConc := int(req.MaxConcurrent)\n   690→\tif maxConc <= 0 {\n   691→\t\tmaxConc = projCfg.Orchestration.Concurrency\n   692→\t}\n   693→\tif maxConc <= 0 {\n   694→\t\tmaxConc = 1\n   695→\t}\n   696→\n   697→\tstagger := time.Duration(float64(time.Second) * projCfg.Orchestration.StaggerSeconds)\n   698→\n   699→\ts.mu.Lock()\n   700→\tdefer s.mu.Unlock()\n   701→\n   702→\t// Stop existing loop if running.\n   703→\tif existing, ok := s.loops[projectDir]; ok {\n   704→\t\texisting.Stop()\n   705→\t}\n   706→\n   707→\trunFn := func(ctx context.Context, projDir string) (*host.RunResult, error) {\n   708→\t\trunner := &host.Runner{\n   709→\t\t\tDispatcher: s,\n   710→\t\t\tStore:      s.store,\n   711→\t\t}\n   712→\t\treturn runner.Run(ctx, projDir)\n   713→\t}\n   714→\n   715→\tloop := host.NewLoop(host.LoopConfig{\n   716→\t\tProjectDir:    projectDir,\n   717→\t\tMaxConcurrent: maxConc,\n   718→\t\tStaggerDelay:  stagger,\n   719→\t}, s.store, runFn)\n   720→\ts.loops[projectDir] = loop\n   721→\tloop.Start()\n   722→\n   723→\treturn &pb.EnableLoopResponse{}, nil\n   724→}\n   725→\n   726→func (s *ClocheServer) DisableLoop(ctx context.Context, req *pb.DisableLoopRequest) (*pb.DisableLoopResponse, error) {\n   727→\tprojectDir := req.ProjectDir\n   728→\tif projectDir == \"\" {\n   729→\t\treturn nil, fmt.Errorf(\"project_dir is required\")\n   730→\t}\n   731→\n   732→\ts.mu.Lock()\n   733→\tdefer s.mu.Unlock()\n   734→\n   735→\tif loop, ok := s.loops[projectDir]; ok {\n   736→\t\tloop.Stop()\n   737→\t\tdelete(s.loops, projectDir)\n   738→\t}\n   739→\n   740→\treturn &pb.DisableLoopResponse{}, nil\n   741→}\n   742→\n   743→func (s *ClocheServer) Shutdown(ctx context.Context, req *pb.ShutdownRequest) (*pb.ShutdownResponse, error) {\n   744→\t// Stop all orchestration loops.\n   745→\ts.mu.Lock()\n   746→\tfor _, loop := range s.loops {\n   747→\t\tloop.Stop()\n   748→\t}\n   749→\ts.loops = make(map[string]*host.Loop)\n   750→\ts.mu.Unlock()\n   751→\n   752→\tif s.shutdownFn == nil {\n   753→\t\treturn nil, fmt.Errorf(\"shutdown not configured\")\n   754→\t}\n   755→\tgo s.shutdownFn()\n   756→\treturn &pb.ShutdownResponse{}, nil\n   757→}\n   758→\n   759→// indexLogFiles scans the extracted output directory and creates log_files index entries.\n   760→func (s *ClocheServer) indexLogFiles(ctx context.Context, runID, outputDir string) {\n   761→\tentries, err := os.ReadDir(outputDir)\n   762→\tif err != nil {\n   763→\t\tlog.Printf(\"run %s: failed to read output dir for indexing: %v\", runID, err)\n   764→\t\treturn\n   765→\t}\n   766→\n   767→\tnow := time.Now()\n   768→\tfor _, entry := range entries {\n   769→\t\tif entry.IsDir() {\n   770→\t\t\tcontinue\n   771→\t\t}\n   772→\t\tname := entry.Name()\n   773→\t\tif !strings.HasSuffix(name, \".log\") {\n   774→\t\t\tcontinue\n   775→\t\t}\n   776→\n   777→\t\tvar fileType, stepName string\n   778→\t\tbase := strings.TrimSuffix(name, \".log\")\n   779→\n   780→\t\tswitch {\n   781→\t\tcase name == \"full.log\":\n   782→\t\t\tfileType = \"full\"\n   783→\t\tcase name == \"container.log\":\n   784→\t\t\t// container.log is internal, not indexed as a user-facing log type\n   785→\t\t\tcontinue\n   786→\t\tcase strings.HasPrefix(name, \"llm-\"):\n   787→\t\t\tfileType = \"llm\"\n   788→\t\t\tstepName = strings.TrimPrefix(base, \"llm-\")\n   789→\t\tdefault:\n   790→\t\t\tfileType = \"script\"\n   791→\t\t\tstepName = base\n   792→\t\t}\n   793→\n   794→\t\tinfo, _ := entry.Info()\n   795→\t\tvar fileSize int64\n   796→\t\tif info != nil {\n   797→\t\t\tfileSize = info.Size()\n   798→\t\t}\n   799→\n   800→\t\tlogEntry := &ports.LogFileEntry{\n   801→\t\t\tRunID:     runID,\n   802→\t\t\tStepName:  stepName,\n   803→\t\t\tFileType:  fileType,\n   804→\t\t\tFilePath:  filepath.Join(outputDir, name),\n   805→\t\t\tFileSize:  fileSize,\n   806→\t\t\tCreatedAt: now,\n   807→\t\t}\n   808→\t\tif err := s.logStore.SaveLogFile(ctx, logEntry); err != nil {\n   809→\t\t\tlog.Printf(\"run %s: failed to index log file %s: %v\", runID, name, err)\n   810→\t\t}\n   811→\t}\n   812→}\n   813→\n   814→func gitHEAD(dir string) string {\n   815→\tcmd := exec.Command(\"git\", \"rev-parse\", \"HEAD\")\n   816→\tcmd.Dir = dir\n   817→\tout, err := cmd.Output()\n   818→\tif err != nil {\n   819→\t\treturn \"\"\n   820→\t}\n   821→\treturn strings.TrimSpace(string(out))\n   822→}\n   823→"}]},"parent_tool_use_id":"toolu_01CsVRDLvL6pm6iru4Cs5mLy","session_id":"508569cd-e03d-4249-9b5e-689a8c858cef","uuid":"f1117924-3dba-4464-b23f-ee36d0d3d145"}
