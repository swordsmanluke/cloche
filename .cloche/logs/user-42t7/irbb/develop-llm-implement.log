{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PYNzfAwh2WW92SfMFSxLuR","type":"tool_result","content":"     1→package web\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"encoding/json\"\n     6→\t\"fmt\"\n     7→\t\"net/http\"\n     8→\t\"net/http/httptest\"\n     9→\t\"os\"\n    10→\t\"path/filepath\"\n    11→\t\"strings\"\n    12→\t\"testing\"\n    13→\t\"time\"\n    14→\n    15→\t\"github.com/cloche-dev/cloche/internal/adapters/sqlite\"\n    16→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    17→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    18→\t\"github.com/stretchr/testify/assert\"\n    19→\t\"github.com/stretchr/testify/require\"\n    20→)\n    21→\n    22→// mockContainerManager implements ContainerManager for testing.\n    23→type mockContainerManager struct {\n    24→\tcontainers map[string]bool // containerID -> exists\n    25→\trunning    map[string]bool // containerID -> running\n    26→\tremoved    []string\n    27→}\n    28→\n    29→func newMockContainerManager() *mockContainerManager {\n    30→\treturn &mockContainerManager{\n    31→\t\tcontainers: map[string]bool{},\n    32→\t\trunning:    map[string]bool{},\n    33→\t}\n    34→}\n    35→\n    36→func (m *mockContainerManager) Logs(_ context.Context, containerID string) (string, error) {\n    37→\treturn \"mock logs\", nil\n    38→}\n    39→\n    40→func (m *mockContainerManager) Remove(_ context.Context, containerID string) error {\n    41→\tif !m.containers[containerID] {\n    42→\t\treturn fmt.Errorf(\"container %s not found\", containerID)\n    43→\t}\n    44→\tdelete(m.containers, containerID)\n    45→\tm.removed = append(m.removed, containerID)\n    46→\treturn nil\n    47→}\n    48→\n    49→func (m *mockContainerManager) Inspect(_ context.Context, containerID string) (*ports.ContainerStatus, error) {\n    50→\tif !m.containers[containerID] {\n    51→\t\treturn nil, fmt.Errorf(\"container %s not found\", containerID)\n    52→\t}\n    53→\treturn &ports.ContainerStatus{Running: m.running[containerID], ExitCode: 0}, nil\n    54→}\n    55→\n    56→func setupHandler(t *testing.T) (*Handler, *sqlite.Store) {\n    57→\tt.Helper()\n    58→\tstore, err := sqlite.NewStore(\":memory:\")\n    59→\trequire.NoError(t, err)\n    60→\tt.Cleanup(func() { store.Close() })\n    61→\n    62→\th, err := NewHandler(store, store)\n    63→\trequire.NoError(t, err)\n    64→\treturn h, store\n    65→}\n    66→\n    67→func seedRun(t *testing.T, store *sqlite.Store, id, workflow string, state domain.RunState) {\n    68→\tt.Helper()\n    69→\tseedRunWithProject(t, store, id, workflow, state, \"\")\n    70→}\n    71→\n    72→func seedRunWithProject(t *testing.T, store *sqlite.Store, id, workflow string, state domain.RunState, projectDir string) {\n    73→\tt.Helper()\n    74→\tctx := context.Background()\n    75→\trun := domain.NewRun(id, workflow)\n    76→\trun.ProjectDir = projectDir\n    77→\tif state != domain.RunStatePending {\n    78→\t\trun.Start()\n    79→\t\trun.ContainerID = \"abc123def456789\"\n    80→\t}\n    81→\tif state == domain.RunStateSucceeded || state == domain.RunStateFailed {\n    82→\t\trun.Complete(state)\n    83→\t}\n    84→\tif state == domain.RunStateFailed {\n    85→\t\trun.ErrorMessage = \"something went wrong\"\n    86→\t}\n    87→\trequire.NoError(t, store.CreateRun(ctx, run))\n    88→}\n    89→\n    90→func TestRunsList_WithRuns(t *testing.T) {\n    91→\th, store := setupHandler(t)\n    92→\tseedRun(t, store, \"test-run-1\", \"develop\", domain.RunStateRunning)\n    93→\tseedRun(t, store, \"test-run-2\", \"deploy\", domain.RunStateSucceeded)\n    94→\n    95→\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n    96→\tw := httptest.NewRecorder()\n    97→\th.ServeHTTP(w, req)\n    98→\n    99→\tassert.Equal(t, http.StatusOK, w.Code)\n   100→\tassert.Contains(t, w.Header().Get(\"Content-Type\"), \"text/html\")\n   101→\tbody := w.Body.String()\n   102→\tassert.Contains(t, body, \"test-run-1\")\n   103→\tassert.Contains(t, body, \"test-run-2\")\n   104→\tassert.Contains(t, body, \"badge-running\")\n   105→\tassert.Contains(t, body, \"badge-succeeded\")\n   106→\tassert.Contains(t, body, \"develop\")\n   107→\tassert.Contains(t, body, \"deploy\")\n   108→}\n   109→\n   110→func TestRunsList_Empty(t *testing.T) {\n   111→\th, _ := setupHandler(t)\n   112→\n   113→\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n   114→\tw := httptest.NewRecorder()\n   115→\th.ServeHTTP(w, req)\n   116→\n   117→\tassert.Equal(t, http.StatusOK, w.Code)\n   118→\tassert.Contains(t, w.Body.String(), \"No runs yet.\")\n   119→}\n   120→\n   121→func TestRunDetail_WithCaptures(t *testing.T) {\n   122→\th, store := setupHandler(t)\n   123→\tseedRun(t, store, \"run-detail-1\", \"develop\", domain.RunStateRunning)\n   124→\n   125→\tctx := context.Background()\n   126→\trequire.NoError(t, store.SaveCapture(ctx, \"run-detail-1\", &domain.StepExecution{\n   127→\t\tStepName:    \"implement\",\n   128→\t\tResult:      \"success\",\n   129→\t\tStartedAt:   time.Now().Add(-5 * time.Minute),\n   130→\t\tCompletedAt: time.Now(),\n   131→\t}))\n   132→\n   133→\treq := httptest.NewRequest(\"GET\", \"/runs/run-detail-1\", nil)\n   134→\tw := httptest.NewRecorder()\n   135→\th.ServeHTTP(w, req)\n   136→\n   137→\tassert.Equal(t, http.StatusOK, w.Code)\n   138→\tbody := w.Body.String()\n   139→\tassert.Contains(t, body, \"run-detail-1\")\n   140→\tassert.Contains(t, body, \"implement\")\n   141→}\n   142→\n   143→func TestRunDetail_AccordionStatePreserved(t *testing.T) {\n   144→\t// Verify the rendered page includes JavaScript that preserves accordion state\n   145→\t// during SSE polling updates (captures open/closed state before DOM rebuild).\n   146→\th, store := setupHandler(t)\n   147→\tseedRun(t, store, \"run-accordion-1\", \"develop\", domain.RunStateRunning)\n   148→\n   149→\tctx := context.Background()\n   150→\trequire.NoError(t, store.SaveCapture(ctx, \"run-accordion-1\", &domain.StepExecution{\n   151→\t\tStepName:    \"build\",\n   152→\t\tResult:      \"success\",\n   153→\t\tStartedAt:   time.Now().Add(-5 * time.Minute),\n   154→\t\tCompletedAt: time.Now(),\n   155→\t}))\n   156→\n   157→\treq := httptest.NewRequest(\"GET\", \"/runs/run-accordion-1\", nil)\n   158→\tw := httptest.NewRecorder()\n   159→\th.ServeHTTP(w, req)\n   160→\n   161→\tassert.Equal(t, http.StatusOK, w.Code)\n   162→\tbody := w.Body.String()\n   163→\n   164→\t// The poll function should capture accordion state before rebuilding the DOM\n   165→\tassert.Contains(t, body, \"openAccordions\")\n   166→\tassert.Contains(t, body, \"loadedOutputs\")\n   167→\t// Verify it restores loaded output content after DOM rebuild\n   168→\tassert.Contains(t, body, \"loadedOutputs[key]\")\n   169→}\n   170→\n   171→func TestRunDetail_NotFound(t *testing.T) {\n   172→\th, _ := setupHandler(t)\n   173→\n   174→\treq := httptest.NewRequest(\"GET\", \"/runs/nonexistent\", nil)\n   175→\tw := httptest.NewRecorder()\n   176→\th.ServeHTTP(w, req)\n   177→\n   178→\tassert.Equal(t, http.StatusNotFound, w.Code)\n   179→}\n   180→\n   181→func TestAPIRuns(t *testing.T) {\n   182→\th, store := setupHandler(t)\n   183→\tseedRun(t, store, \"api-run-1\", \"develop\", domain.RunStateRunning)\n   184→\tseedRun(t, store, \"api-run-2\", \"deploy\", domain.RunStateSucceeded)\n   185→\n   186→\treq := httptest.NewRequest(\"GET\", \"/api/runs\", nil)\n   187→\tw := httptest.NewRecorder()\n   188→\th.ServeHTTP(w, req)\n   189→\n   190→\tassert.Equal(t, http.StatusOK, w.Code)\n   191→\tassert.Contains(t, w.Header().Get(\"Content-Type\"), \"application/json\")\n   192→\n   193→\tvar runs []apiRun\n   194→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &runs))\n   195→\tassert.Len(t, runs, 2)\n   196→\n   197→\tids := map[string]bool{}\n   198→\tfor _, r := range runs {\n   199→\t\tids[r.ID] = true\n   200→\t}\n   201→\tassert.True(t, ids[\"api-run-1\"])\n   202→\tassert.True(t, ids[\"api-run-2\"])\n   203→}\n   204→\n   205→func TestAPIRunDetail(t *testing.T) {\n   206→\th, store := setupHandler(t)\n   207→\tseedRun(t, store, \"api-detail-1\", \"develop\", domain.RunStateRunning)\n   208→\n   209→\tctx := context.Background()\n   210→\trequire.NoError(t, store.SaveCapture(ctx, \"api-detail-1\", &domain.StepExecution{\n   211→\t\tStepName:    \"build\",\n   212→\t\tResult:      \"success\",\n   213→\t\tStartedAt:   time.Now().Add(-10 * time.Second),\n   214→\t\tCompletedAt: time.Now(),\n   215→\t}))\n   216→\n   217→\treq := httptest.NewRequest(\"GET\", \"/api/runs/api-detail-1\", nil)\n   218→\tw := httptest.NewRecorder()\n   219→\th.ServeHTTP(w, req)\n   220→\n   221→\tassert.Equal(t, http.StatusOK, w.Code)\n   222→\n   223→\tvar detail apiRunDetail\n   224→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &detail))\n   225→\tassert.Equal(t, \"api-detail-1\", detail.ID)\n   226→\tassert.Equal(t, \"running\", detail.State)\n   227→\tassert.Len(t, detail.Steps, 1)\n   228→\tassert.Equal(t, \"build\", detail.Steps[0].StepName)\n   229→\tassert.NotEmpty(t, detail.Steps[0].Duration)\n   230→}\n   231→\n   232→func TestStaticCSS(t *testing.T) {\n   233→\th, _ := setupHandler(t)\n   234→\n   235→\treq := httptest.NewRequest(\"GET\", \"/static/style.css\", nil)\n   236→\tw := httptest.NewRecorder()\n   237→\th.ServeHTTP(w, req)\n   238→\n   239→\tassert.Equal(t, http.StatusOK, w.Code)\n   240→\tassert.Contains(t, w.Body.String(), \":root\")\n   241→\tassert.Contains(t, w.Body.String(), \"badge-running\")\n   242→}\n   243→\n   244→func TestHelpers(t *testing.T) {\n   245→\tt.Run(\"stateColor\", func(t *testing.T) {\n   246→\t\tassert.Equal(t, \"pending\", stateColor(domain.RunStatePending))\n   247→\t\tassert.Equal(t, \"running\", stateColor(domain.RunStateRunning))\n   248→\t\tassert.Equal(t, \"succeeded\", stateColor(domain.RunStateSucceeded))\n   249→\t\tassert.Equal(t, \"failed\", stateColor(domain.RunStateFailed))\n   250→\t\tassert.Equal(t, \"cancelled\", stateColor(domain.RunStateCancelled))\n   251→\t})\n   252→\n   253→\tt.Run(\"formatTime\", func(t *testing.T) {\n   254→\t\tassert.Equal(t, \"\", formatTime(time.Time{}))\n   255→\t\tts := time.Date(2026, 2, 26, 14, 30, 0, 0, time.UTC)\n   256→\t\tassert.Equal(t, \"2026-02-26 14:30:00\", formatTime(ts))\n   257→\t})\n   258→\n   259→\tt.Run(\"formatDuration\", func(t *testing.T) {\n   260→\t\tnow := time.Now()\n   261→\t\tassert.Equal(t, \"\", formatDuration(time.Time{}, now))\n   262→\t\tassert.Equal(t, \"\", formatDuration(now, time.Time{}))\n   263→\t\tassert.Equal(t, \"500ms\", formatDuration(now, now.Add(500*time.Millisecond)))\n   264→\t\tassert.Equal(t, \"5.0s\", formatDuration(now, now.Add(5*time.Second)))\n   265→\t\tassert.Equal(t, \"2m30s\", formatDuration(now, now.Add(2*time.Minute+30*time.Second)))\n   266→\t})\n   267→\n   268→\tt.Run(\"truncate\", func(t *testing.T) {\n   269→\t\tassert.Equal(t, \"hello\", truncate(\"hello\", 10))\n   270→\t\tassert.Equal(t, \"hel...\", truncate(\"hello world\", 3))\n   271→\t})\n   272→\n   273→\tt.Run(\"shortContainerID\", func(t *testing.T) {\n   274→\t\tassert.Equal(t, \"abc123def456\", shortContainerID(\"abc123def456789abcdef\"))\n   275→\t\tassert.Equal(t, \"short\", shortContainerID(\"short\"))\n   276→\t})\n   277→\n   278→\tt.Run(\"projectLabels\", func(t *testing.T) {\n   279→\t\t// No conflict: show base name only\n   280→\t\tlabels := projectLabels([]string{\"/home/user/alpha\", \"/home/user/beta\"})\n   281→\t\tassert.Equal(t, \"alpha\", labels[\"/home/user/alpha\"])\n   282→\t\tassert.Equal(t, \"beta\", labels[\"/home/user/beta\"])\n   283→\n   284→\t\t// Conflict: two dirs share the same base name\n   285→\t\tlabels = projectLabels([]string{\"/home/foo/bar\", \"/home/baz/bar\"})\n   286→\t\tassert.Equal(t, \"foo/bar\", labels[\"/home/foo/bar\"])\n   287→\t\tassert.Equal(t, \"baz/bar\", labels[\"/home/baz/bar\"])\n   288→\n   289→\t\t// Mixed: some conflict, some don't\n   290→\t\tlabels = projectLabels([]string{\"/a/bar\", \"/b/bar\", \"/c/unique\"})\n   291→\t\tassert.Equal(t, \"a/bar\", labels[\"/a/bar\"])\n   292→\t\tassert.Equal(t, \"b/bar\", labels[\"/b/bar\"])\n   293→\t\tassert.Equal(t, \"unique\", labels[\"/c/unique\"])\n   294→\n   295→\t\t// Empty list\n   296→\t\tlabels = projectLabels(nil)\n   297→\t\tassert.Empty(t, labels)\n   298→\t})\n   299→}\n   300→\n   301→func TestRunsList_ProjectFilter(t *testing.T) {\n   302→\th, store := setupHandler(t)\n   303→\tseedRunWithProject(t, store, \"run-a1\", \"develop\", domain.RunStateRunning, \"/home/user/alpha\")\n   304→\tseedRunWithProject(t, store, \"run-a2\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n   305→\tseedRunWithProject(t, store, \"run-b1\", \"deploy\", domain.RunStateRunning, \"/home/user/beta\")\n   306→\n   307→\t// Without filter: all runs shown\n   308→\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n   309→\tw := httptest.NewRecorder()\n   310→\th.ServeHTTP(w, req)\n   311→\tassert.Equal(t, http.StatusOK, w.Code)\n   312→\tbody := w.Body.String()\n   313→\tassert.Contains(t, body, \"run-a1\")\n   314→\tassert.Contains(t, body, \"run-b1\")\n   315→\n   316→\t// With project filter: only matching runs\n   317→\treq = httptest.NewRequest(\"GET\", \"/runs?project=/home/user/alpha\", nil)\n   318→\tw = httptest.NewRecorder()\n   319→\th.ServeHTTP(w, req)\n   320→\tassert.Equal(t, http.StatusOK, w.Code)\n   321→\tbody = w.Body.String()\n   322→\tassert.Contains(t, body, \"run-a1\")\n   323→\tassert.Contains(t, body, \"run-a2\")\n   324→\tassert.NotContains(t, body, \"run-b1\")\n   325→}\n   326→\n   327→func TestRunsList_ProjectColumn(t *testing.T) {\n   328→\th, store := setupHandler(t)\n   329→\tseedRunWithProject(t, store, \"run-p1\", \"develop\", domain.RunStateRunning, \"/home/user/myproject\")\n   330→\n   331→\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n   332→\tw := httptest.NewRecorder()\n   333→\th.ServeHTTP(w, req)\n   334→\tassert.Equal(t, http.StatusOK, w.Code)\n   335→\tbody := w.Body.String()\n   336→\tassert.Contains(t, body, \"myproject\")\n   337→\tassert.Contains(t, body, \"Project\")\n   338→}\n   339→\n   340→func TestAPIRuns_ProjectFilter(t *testing.T) {\n   341→\th, store := setupHandler(t)\n   342→\tseedRunWithProject(t, store, \"api-a1\", \"develop\", domain.RunStateRunning, \"/home/user/alpha\")\n   343→\tseedRunWithProject(t, store, \"api-b1\", \"deploy\", domain.RunStateRunning, \"/home/user/beta\")\n   344→\n   345→\t// Without filter: all runs\n   346→\treq := httptest.NewRequest(\"GET\", \"/api/runs\", nil)\n   347→\tw := httptest.NewRecorder()\n   348→\th.ServeHTTP(w, req)\n   349→\tassert.Equal(t, http.StatusOK, w.Code)\n   350→\n   351→\tvar allRuns []apiRun\n   352→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &allRuns))\n   353→\tassert.Len(t, allRuns, 2)\n   354→\n   355→\t// With filter: only matching\n   356→\treq = httptest.NewRequest(\"GET\", \"/api/runs?project=/home/user/alpha\", nil)\n   357→\tw = httptest.NewRecorder()\n   358→\th.ServeHTTP(w, req)\n   359→\tassert.Equal(t, http.StatusOK, w.Code)\n   360→\n   361→\tvar filtered []apiRun\n   362→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &filtered))\n   363→\tassert.Len(t, filtered, 1)\n   364→\tassert.Equal(t, \"api-a1\", filtered[0].ID)\n   365→\tassert.Equal(t, \"/home/user/alpha\", filtered[0].ProjectDir)\n   366→\tassert.Equal(t, \"alpha\", filtered[0].ProjectLabel)\n   367→}\n   368→\n   369→func setupHandlerWithContainerManager(t *testing.T) (*Handler, *sqlite.Store, *mockContainerManager) {\n   370→\tt.Helper()\n   371→\tstore, err := sqlite.NewStore(\":memory:\")\n   372→\trequire.NoError(t, err)\n   373→\tt.Cleanup(func() { store.Close() })\n   374→\n   375→\tmgr := newMockContainerManager()\n   376→\th, err := NewHandler(store, store, WithContainerManager(mgr))\n   377→\trequire.NoError(t, err)\n   378→\treturn h, store, mgr\n   379→}\n   380→\n   381→func seedRunWithContainer(t *testing.T, store *sqlite.Store, mgr *mockContainerManager, id, workflow, projectDir, containerID string, kept bool) {\n   382→\tt.Helper()\n   383→\tctx := context.Background()\n   384→\trun := domain.NewRun(id, workflow)\n   385→\trun.ProjectDir = projectDir\n   386→\trun.Start()\n   387→\trun.ContainerID = containerID\n   388→\trun.ContainerKept = kept\n   389→\trun.Complete(domain.RunStateSucceeded)\n   390→\trequire.NoError(t, store.CreateRun(ctx, run))\n   391→\tif kept {\n   392→\t\tmgr.containers[containerID] = true\n   393→\t}\n   394→}\n   395→\n   396→func TestRunDetail_ContainerRunning(t *testing.T) {\n   397→\th, store, mgr := setupHandlerWithContainerManager(t)\n   398→\n   399→\tctx := context.Background()\n   400→\trun := domain.NewRun(\"run-cr\", \"develop\")\n   401→\trun.ProjectDir = \"/proj\"\n   402→\trun.Start()\n   403→\trun.ContainerID = \"cid-running\"\n   404→\trequire.NoError(t, store.CreateRun(ctx, run))\n   405→\tmgr.containers[\"cid-running\"] = true\n   406→\tmgr.running[\"cid-running\"] = true\n   407→\n   408→\treq := httptest.NewRequest(\"GET\", \"/runs/run-cr\", nil)\n   409→\tw := httptest.NewRecorder()\n   410→\th.ServeHTTP(w, req)\n   411→\n   412→\tassert.Equal(t, http.StatusOK, w.Code)\n   413→\tbody := w.Body.String()\n   414→\tassert.Contains(t, body, \"Container running\")\n   415→\tassert.Contains(t, body, `badge-running\">Container running`)\n   416→}\n   417→\n   418→func TestRunDetail_ContainerStopped(t *testing.T) {\n   419→\th, store, mgr := setupHandlerWithContainerManager(t)\n   420→\n   421→\tctx := context.Background()\n   422→\trun := domain.NewRun(\"run-cs\", \"develop\")\n   423→\trun.ProjectDir = \"/proj\"\n   424→\trun.Start()\n   425→\trun.ContainerID = \"cid-stopped\"\n   426→\trun.ContainerKept = false\n   427→\trun.Complete(domain.RunStateSucceeded)\n   428→\trequire.NoError(t, store.CreateRun(ctx, run))\n   429→\tmgr.containers[\"cid-stopped\"] = true // container exists but not running, not kept\n   430→\n   431→\treq := httptest.NewRequest(\"GET\", \"/runs/run-cs\", nil)\n   432→\tw := httptest.NewRecorder()\n   433→\th.ServeHTTP(w, req)\n   434→\n   435→\tassert.Equal(t, http.StatusOK, w.Code)\n   436→\tbody := w.Body.String()\n   437→\tassert.Contains(t, body, \"Container stopped\")\n   438→\tassert.Contains(t, body, `badge-stopped\">Container stopped`)\n   439→}\n   440→\n   441→func TestRunDetail_ContainerStoppedTerminal_ShowsDeleteButton(t *testing.T) {\n   442→\th, store, mgr := setupHandlerWithContainerManager(t)\n   443→\n   444→\tfor _, state := range []domain.RunState{domain.RunStateSucceeded, domain.RunStateFailed, domain.RunStateCancelled} {\n   445→\t\tt.Run(string(state), func(t *testing.T) {\n   446→\t\t\tid := \"run-cst-\" + string(state)\n   447→\t\t\tctx := context.Background()\n   448→\t\t\trun := domain.NewRun(id, \"develop\")\n   449→\t\t\trun.ProjectDir = \"/proj\"\n   450→\t\t\trun.Start()\n   451→\t\t\trun.ContainerID = \"cid-stopped-\" + string(state)\n   452→\t\t\trun.ContainerKept = false\n   453→\t\t\trun.Complete(state)\n   454→\t\t\trequire.NoError(t, store.CreateRun(ctx, run))\n   455→\t\t\tmgr.containers[run.ContainerID] = true // container exists but not running, not kept\n   456→\n   457→\t\t\treq := httptest.NewRequest(\"GET\", \"/runs/\"+id, nil)\n   458→\t\t\tw := httptest.NewRecorder()\n   459→\t\t\th.ServeHTTP(w, req)\n   460→\n   461→\t\t\tassert.Equal(t, http.StatusOK, w.Code)\n   462→\t\t\tbody := w.Body.String()\n   463→\t\t\tassert.Contains(t, body, \"Container stopped\")\n   464→\t\t\tassert.Contains(t, body, `id=\"delete-container-btn\"`, \"should show delete button for terminal run with stopped container\")\n   465→\t\t})\n   466→\t}\n   467→}\n   468→\n   469→func TestRunDetail_ContainerStoppedRunning_NoDeleteButton(t *testing.T) {\n   470→\th, store, mgr := setupHandlerWithContainerManager(t)\n   471→\n   472→\tctx := context.Background()\n   473→\trun := domain.NewRun(\"run-csr\", \"develop\")\n   474→\trun.ProjectDir = \"/proj\"\n   475→\trun.Start()\n   476→\trun.ContainerID = \"cid-stopped-running\"\n   477→\trun.ContainerKept = false\n   478→\trequire.NoError(t, store.CreateRun(ctx, run))\n   479→\tmgr.containers[\"cid-stopped-running\"] = true\n   480→\t// container not running, but run state is still \"running\" (not terminal)\n   481→\t// containerState will return \"stopped\" since ContainerKept=false\n   482→\n   483→\treq := httptest.NewRequest(\"GET\", \"/runs/run-csr\", nil)\n   484→\tw := httptest.NewRecorder()\n   485→\th.ServeHTTP(w, req)\n   486→\n   487→\tassert.Equal(t, http.StatusOK, w.Code)\n   488→\tbody := w.Body.String()\n   489→\tassert.Contains(t, body, \"Container stopped\")\n   490→\t// The HTML container-status section should NOT have the delete button.\n   491→\t// We check the dd#container-status block specifically, not the full body\n   492→\t// (which includes JS that references the button ID as string literals).\n   493→\tstatusStart := \"container-status\"\n   494→\tstatusEnd := \"</dd>\"\n   495→\tidx := strings.Index(body, statusStart)\n   496→\trequire.NotEqual(t, -1, idx, \"container-status element must exist\")\n   497→\tendIdx := strings.Index(body[idx:], statusEnd)\n   498→\trequire.NotEqual(t, -1, endIdx, \"closing </dd> must exist\")\n   499→\tstatusSection := body[idx : idx+endIdx+len(statusEnd)]\n   500→\tassert.NotContains(t, statusSection, \"Delete Container\", \"should NOT show delete button for non-terminal run\")\n   501→}\n   502→\n   503→func TestRunDetail_ContainerAvailable(t *testing.T) {\n   504→\th, store, mgr := setupHandlerWithContainerManager(t)\n   505→\tseedRunWithContainer(t, store, mgr, \"run-c1\", \"develop\", \"/proj\", \"cid-1234567890ab\", true)\n   506→\n   507→\treq := httptest.NewRequest(\"GET\", \"/runs/run-c1\", nil)\n   508→\tw := httptest.NewRecorder()\n   509→\th.ServeHTTP(w, req)\n   510→\n   511→\tassert.Equal(t, http.StatusOK, w.Code)\n   512→\tbody := w.Body.String()\n   513→\tassert.Contains(t, body, \"Container available\")\n   514→\tassert.Contains(t, body, `badge-succeeded\">Container available`)\n   515→\tassert.Contains(t, body, `id=\"delete-container-btn\"`)\n   516→}\n   517→\n   518→func TestRunDetail_ContainerRemoved(t *testing.T) {\n   519→\th, store, _ := setupHandlerWithContainerManager(t)\n   520→\n   521→\tctx := context.Background()\n   522→\trun := domain.NewRun(\"run-c2\", \"develop\")\n   523→\trun.ProjectDir = \"/proj\"\n   524→\trun.Start()\n   525→\trun.ContainerID = \"cid-gone\"\n   526→\trun.ContainerKept = false\n   527→\trun.Complete(domain.RunStateSucceeded)\n   528→\trequire.NoError(t, store.CreateRun(ctx, run))\n   529→\t// container NOT in mock's containers map → Inspect will fail → \"removed\"\n   530→\n   531→\treq := httptest.NewRequest(\"GET\", \"/runs/run-c2\", nil)\n   532→\tw := httptest.NewRecorder()\n   533→\th.ServeHTTP(w, req)\n   534→\n   535→\tassert.Equal(t, http.StatusOK, w.Code)\n   536→\tbody := w.Body.String()\n   537→\tassert.Contains(t, body, \"Container removed\")\n   538→\tassert.Contains(t, body, `badge-pending\">Container removed`)\n   539→}\n   540→\n   541→func TestAPIDeleteContainer_Success(t *testing.T) {\n   542→\th, store, mgr := setupHandlerWithContainerManager(t)\n   543→\tseedRunWithContainer(t, store, mgr, \"run-del1\", \"develop\", \"/proj\", \"cid-to-delete\", true)\n   544→\n   545→\treq := httptest.NewRequest(\"DELETE\", \"/api/runs/run-del1/container\", nil)\n   546→\tw := httptest.NewRecorder()\n   547→\th.ServeHTTP(w, req)\n   548→\n   549→\tassert.Equal(t, http.StatusOK, w.Code)\n   550→\n   551→\tvar resp map[string]string\n   552→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n   553→\tassert.Equal(t, \"ok\", resp[\"status\"])\n   554→\n   555→\t// Verify container was removed\n   556→\tassert.Contains(t, mgr.removed, \"cid-to-delete\")\n   557→\n   558→\t// Verify run was updated\n   559→\trun, err := store.GetRun(context.Background(), \"run-del1\")\n   560→\trequire.NoError(t, err)\n   561→\tassert.False(t, run.ContainerKept)\n   562→}\n   563→\n   564→func TestAPIDeleteContainer_StoppedContainer(t *testing.T) {\n   565→\th, store, mgr := setupHandlerWithContainerManager(t)\n   566→\n   567→\tctx := context.Background()\n   568→\trun := domain.NewRun(\"run-del-stopped\", \"develop\")\n   569→\trun.ProjectDir = \"/proj\"\n   570→\trun.Start()\n   571→\trun.ContainerID = \"cid-stopped-del\"\n   572→\trun.ContainerKept = false\n   573→\trun.Complete(domain.RunStateFailed)\n   574→\trequire.NoError(t, store.CreateRun(ctx, run))\n   575→\tmgr.containers[\"cid-stopped-del\"] = true\n   576→\n   577→\treq := httptest.NewRequest(\"DELETE\", \"/api/runs/run-del-stopped/container\", nil)\n   578→\tw := httptest.NewRecorder()\n   579→\th.ServeHTTP(w, req)\n   580→\n   581→\tassert.Equal(t, http.StatusOK, w.Code)\n   582→\n   583→\tvar resp map[string]string\n   584→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n   585→\tassert.Equal(t, \"ok\", resp[\"status\"])\n   586→\tassert.Contains(t, mgr.removed, \"cid-stopped-del\")\n   587→}\n   588→\n   589→func TestAPIDeleteContainer_RunNotFound(t *testing.T) {\n   590→\th, _, _ := setupHandlerWithContainerManager(t)\n   591→\n   592→\treq := httptest.NewRequest(\"DELETE\", \"/api/runs/nonexistent/container\", nil)\n   593→\tw := httptest.NewRecorder()\n   594→\th.ServeHTTP(w, req)\n   595→\n   596→\tassert.Equal(t, http.StatusNotFound, w.Code)\n   597→}\n   598→\n   599→func TestAPIDeleteContainer_NoManager(t *testing.T) {\n   600→\th, store := setupHandler(t) // no container manager\n   601→\tseedRun(t, store, \"run-noman\", \"develop\", domain.RunStateSucceeded)\n   602→\n   603→\treq := httptest.NewRequest(\"DELETE\", \"/api/runs/run-noman/container\", nil)\n   604→\tw := httptest.NewRecorder()\n   605→\th.ServeHTTP(w, req)\n   606→\n   607→\tassert.Equal(t, http.StatusBadRequest, w.Code)\n   608→}\n   609→\n   610→func TestAPIRunDetail_ContainerState(t *testing.T) {\n   611→\th, store, mgr := setupHandlerWithContainerManager(t)\n   612→\n   613→\t// Seed a running container\n   614→\tctx := context.Background()\n   615→\trun := domain.NewRun(\"api-cs1\", \"develop\")\n   616→\trun.ProjectDir = \"/proj\"\n   617→\trun.Start()\n   618→\trun.ContainerID = \"cid-api-running\"\n   619→\trequire.NoError(t, store.CreateRun(ctx, run))\n   620→\tmgr.containers[\"cid-api-running\"] = true\n   621→\tmgr.running[\"cid-api-running\"] = true\n   622→\n   623→\treq := httptest.NewRequest(\"GET\", \"/api/runs/api-cs1\", nil)\n   624→\tw := httptest.NewRecorder()\n   625→\th.ServeHTTP(w, req)\n   626→\n   627→\tassert.Equal(t, http.StatusOK, w.Code)\n   628→\n   629→\tvar detail apiRunDetail\n   630→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &detail))\n   631→\tassert.Equal(t, \"running\", detail.ContainerState)\n   632→\n   633→\t// Now stop it\n   634→\tmgr.running[\"cid-api-running\"] = false\n   635→\n   636→\tw = httptest.NewRecorder()\n   637→\th.ServeHTTP(w, httptest.NewRequest(\"GET\", \"/api/runs/api-cs1\", nil))\n   638→\n   639→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &detail))\n   640→\tassert.Equal(t, \"stopped\", detail.ContainerState)\n   641→}\n   642→\n   643→func TestRunsList_ContainerCount(t *testing.T) {\n   644→\th, store, mgr := setupHandlerWithContainerManager(t)\n   645→\tseedRunWithContainer(t, store, mgr, \"run-cc1\", \"develop\", \"/home/user/alpha\", \"cid-1\", true)\n   646→\tseedRunWithContainer(t, store, mgr, \"run-cc2\", \"develop\", \"/home/user/alpha\", \"cid-2\", true)\n   647→\tseedRunWithContainer(t, store, mgr, \"run-cc3\", \"deploy\", \"/home/user/beta\", \"cid-3\", false)\n   648→\n   649→\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n   650→\tw := httptest.NewRecorder()\n   651→\th.ServeHTTP(w, req)\n   652→\n   653→\tassert.Equal(t, http.StatusOK, w.Code)\n   654→\tbody := w.Body.String()\n   655→\t// alpha has 2 retained containers\n   656→\tassert.Contains(t, body, \"2 containers\")\n   657→\t// beta has 0, so no count should appear\n   658→\tassert.NotContains(t, body, \"0 container\")\n   659→}\n   660→\n   661→func TestAPIProjects(t *testing.T) {\n   662→\th, store := setupHandler(t)\n   663→\tseedRunWithProject(t, store, \"p1\", \"develop\", domain.RunStateRunning, \"/home/user/alpha\")\n   664→\tseedRunWithProject(t, store, \"p2\", \"develop\", domain.RunStateRunning, \"/home/user/beta\")\n   665→\tseedRunWithProject(t, store, \"p3\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n   666→\n   667→\treq := httptest.NewRequest(\"GET\", \"/api/projects\", nil)\n   668→\tw := httptest.NewRecorder()\n   669→\th.ServeHTTP(w, req)\n   670→\tassert.Equal(t, http.StatusOK, w.Code)\n   671→\n   672→\ttype apiHealth struct {\n   673→\t\tStatus string `json:\"status\"`\n   674→\t\tPassed int    `json:\"passed\"`\n   675→\t\tFailed int    `json:\"failed\"`\n   676→\t\tTotal  int    `json:\"total\"`\n   677→\t}\n   678→\ttype project struct {\n   679→\t\tDir         string    `json:\"dir\"`\n   680→\t\tLabel       string    `json:\"label\"`\n   681→\t\tHealth      apiHealth `json:\"health\"`\n   682→\t\tActiveCount int       `json:\"active_count\"`\n   683→\t}\n   684→\tvar projects []project\n   685→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &projects))\n   686→\tassert.Len(t, projects, 2)\n   687→\n   688→\tbyDir := map[string]project{}\n   689→\tfor _, p := range projects {\n   690→\t\tbyDir[p.Dir] = p\n   691→\t}\n   692→\tassert.Equal(t, \"alpha\", byDir[\"/home/user/alpha\"].Label)\n   693→\tassert.Equal(t, \"beta\", byDir[\"/home/user/beta\"].Label)\n   694→\t// alpha has 1 running + 1 succeeded = yellow health (mix), 1 active\n   695→\tassert.Equal(t, 1, byDir[\"/home/user/alpha\"].ActiveCount)\n   696→\tassert.NotEmpty(t, byDir[\"/home/user/alpha\"].Health.Status)\n   697→\t// beta has 1 running = blue (all in-progress), 1 active\n   698→\tassert.Equal(t, \"blue\", byDir[\"/home/user/beta\"].Health.Status)\n   699→\tassert.Equal(t, 1, byDir[\"/home/user/beta\"].ActiveCount)\n   700→}\n   701→\n   702→func TestProjectOverview_WithProjects(t *testing.T) {\n   703→\th, store := setupHandler(t)\n   704→\tseedRunWithProject(t, store, \"ov-1\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n   705→\tseedRunWithProject(t, store, \"ov-2\", \"develop\", domain.RunStateFailed, \"/home/user/alpha\")\n   706→\tseedRunWithProject(t, store, \"ov-3\", \"develop\", domain.RunStateRunning, \"/home/user/beta\")\n   707→\n   708→\treq := httptest.NewRequest(\"GET\", \"/\", nil)\n   709→\tw := httptest.NewRecorder()\n   710→\th.ServeHTTP(w, req)\n   711→\n   712→\tassert.Equal(t, http.StatusOK, w.Code)\n   713→\tassert.Contains(t, w.Header().Get(\"Content-Type\"), \"text/html\")\n   714→\tbody := w.Body.String()\n   715→\t// Project cards should be present\n   716→\tassert.Contains(t, body, \"project-card\")\n   717→\tassert.Contains(t, body, \"alpha\")\n   718→\tassert.Contains(t, body, \"beta\")\n   719→\t// Health dots\n   720→\tassert.Contains(t, body, \"health-dot\")\n   721→\t// Run history dots\n   722→\tassert.Contains(t, body, \"run-dot\")\n   723→\t// Quick actions\n   724→\tassert.Contains(t, body, \"View Runs\")\n   725→}\n   726→\n   727→func TestProjectOverview_Empty(t *testing.T) {\n   728→\th, _ := setupHandler(t)\n   729→\n   730→\treq := httptest.NewRequest(\"GET\", \"/\", nil)\n   731→\tw := httptest.NewRecorder()\n   732→\th.ServeHTTP(w, req)\n   733→\n   734→\tassert.Equal(t, http.StatusOK, w.Code)\n   735→\tassert.Contains(t, w.Body.String(), \"No projects yet\")\n   736→}\n   737→\n   738→func TestHealthColor(t *testing.T) {\n   739→\tassert.Equal(t, \"green\", healthColor(domain.HealthGreen))\n   740→\tassert.Equal(t, \"yellow\", healthColor(domain.HealthYellow))\n   741→\tassert.Equal(t, \"red\", healthColor(domain.HealthRed))\n   742→\tassert.Equal(t, \"blue\", healthColor(domain.HealthBlue))\n   743→\tassert.Equal(t, \"grey\", healthColor(domain.HealthGrey))\n   744→\tassert.Equal(t, \"grey\", healthColor(\"unknown\"))\n   745→}\n   746→\n   747→func TestAPIProjects_HealthData(t *testing.T) {\n   748→\th, store := setupHandler(t)\n   749→\t// alpha: 3 succeeded, 1 failed → yellow\n   750→\tseedRunWithProject(t, store, \"h1\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n   751→\tseedRunWithProject(t, store, \"h2\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n   752→\tseedRunWithProject(t, store, \"h3\", \"develop\", domain.RunStateFailed, \"/home/user/alpha\")\n   753→\tseedRunWithProject(t, store, \"h4\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n   754→\n   755→\t// beta: all succeeded → green\n   756→\tseedRunWithProject(t, store, \"h5\", \"develop\", domain.RunStateSucceeded, \"/home/user/beta\")\n   757→\tseedRunWithProject(t, store, \"h6\", \"develop\", domain.RunStateSucceeded, \"/home/user/beta\")\n   758→\n   759→\treq := httptest.NewRequest(\"GET\", \"/api/projects\", nil)\n   760→\tw := httptest.NewRecorder()\n   761→\th.ServeHTTP(w, req)\n   762→\tassert.Equal(t, http.StatusOK, w.Code)\n   763→\n   764→\ttype health struct {\n   765→\t\tStatus string `json:\"status\"`\n   766→\t\tPassed int    `json:\"passed\"`\n   767→\t\tFailed int    `json:\"failed\"`\n   768→\t\tTotal  int    `json:\"total\"`\n   769→\t}\n   770→\ttype project struct {\n   771→\t\tDir    string `json:\"dir\"`\n   772→\t\tLabel  string `json:\"label\"`\n   773→\t\tHealth health `json:\"health\"`\n   774→\t}\n   775→\tvar projects []project\n   776→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &projects))\n   777→\tassert.Len(t, projects, 2)\n   778→\n   779→\tbyDir := map[string]project{}\n   780→\tfor _, p := range projects {\n   781→\t\tbyDir[p.Dir] = p\n   782→\t}\n   783→\n   784→\talpha := byDir[\"/home/user/alpha\"]\n   785→\tassert.Equal(t, \"yellow\", alpha.Health.Status)\n   786→\tassert.Equal(t, 3, alpha.Health.Passed)\n   787→\tassert.Equal(t, 1, alpha.Health.Failed)\n   788→\tassert.Equal(t, 4, alpha.Health.Total)\n   789→\n   790→\tbeta := byDir[\"/home/user/beta\"]\n   791→\tassert.Equal(t, \"green\", beta.Health.Status)\n   792→\tassert.Equal(t, 2, beta.Health.Passed)\n   793→\tassert.Equal(t, 0, beta.Health.Failed)\n   794→\tassert.Equal(t, 2, beta.Health.Total)\n   795→}\n   796→\n   797→func TestResolveFileRef(t *testing.T) {\n   798→\t// Create a temp directory with a test file\n   799→\tdir := t.TempDir()\n   800→\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \"prompts\"), 0o755))\n   801→\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \"prompts\", \"implement.md\"), []byte(\"# Implement\\nDo the thing.\"), 0o644))\n   802→\n   803→\tt.Run(\"file() reference resolves to contents\", func(t *testing.T) {\n   804→\t\tcontent, err := resolveFileRef(`file(\"prompts/implement.md\")`, dir)\n   805→\t\trequire.NoError(t, err)\n   806→\t\tassert.Equal(t, \"# Implement\\nDo the thing.\", content)\n   807→\t})\n   808→\n   809→\tt.Run(\"file() reference with missing file returns error\", func(t *testing.T) {\n   810→\t\t_, err := resolveFileRef(`file(\"prompts/nonexistent.md\")`, dir)\n   811→\t\tassert.Error(t, err)\n   812→\t})\n   813→\n   814→\tt.Run(\"plain string returned as-is\", func(t *testing.T) {\n   815→\t\tcontent, err := resolveFileRef(\"echo hello\", dir)\n   816→\t\trequire.NoError(t, err)\n   817→\t\tassert.Equal(t, \"echo hello\", content)\n   818→\t})\n   819→\n   820→\tt.Run(\"quoted string returned as-is\", func(t *testing.T) {\n   821→\t\tcontent, err := resolveFileRef(`\"some value\"`, dir)\n   822→\t\trequire.NoError(t, err)\n   823→\t\tassert.Equal(t, `\"some value\"`, content)\n   824→\t})\n   825→}\n   826→\n   827→func TestAPIStepContent_FileRef(t *testing.T) {\n   828→\th, store := setupHandler(t)\n   829→\n   830→\t// Create a temp project directory with a workflow and prompt file\n   831→\tdir := t.TempDir()\n   832→\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0o755))\n   833→\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"), []byte(\"Build the feature.\"), 0o644))\n   834→\n   835→\tworkflowContent := `workflow \"develop\" {\n   836→    step implement {\n   837→        prompt = file(\".cloche/prompts/implement.md\")\n   838→        results = [success, fail]\n   839→    }\n   840→    implement:success -> done\n   841→    implement:fail -> abort\n   842→}\n   843→`\n   844→\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"), []byte(workflowContent), 0o644))\n   845→\n   846→\t// Seed a run so the project is known\n   847→\tseedRunWithProject(t, store, \"sc-1\", \"develop\", domain.RunStateRunning, dir)\n   848→\n   849→\t// Request step content\n   850→\treq := httptest.NewRequest(\"GET\", \"/api/projects/\"+filepath.Base(dir)+\"/workflows/develop/steps/implement/content\", nil)\n   851→\tw := httptest.NewRecorder()\n   852→\th.ServeHTTP(w, req)\n   853→\n   854→\tassert.Equal(t, http.StatusOK, w.Code)\n   855→\tassert.Equal(t, \"Build the feature.\", w.Body.String())\n   856→}\n   857→\n   858→func TestAPIProjects_HealthNoRuns(t *testing.T) {\n   859→\th, _ := setupHandler(t)\n   860→\n   861→\treq := httptest.NewRequest(\"GET\", \"/api/projects\", nil)\n   862→\tw := httptest.NewRecorder()\n   863→\th.ServeHTTP(w, req)\n   864→\tassert.Equal(t, http.StatusOK, w.Code)\n   865→\n   866→\t// No projects means empty array\n   867→\ttype project struct {\n   868→\t\tDir   string `json:\"dir\"`\n   869→\t\tLabel string `json:\"label\"`\n   870→\t}\n   871→\tvar projects []project\n   872→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &projects))\n   873→\tassert.Empty(t, projects)\n   874→}\n   875→"}]},"parent_tool_use_id":null,"session_id":"508569cd-e03d-4249-9b5e-689a8c858cef","uuid":"9ac332f6-b08f-4582-b9f1-2d30371a5a84","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/web/handler_test.go","content":"package web\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"strings\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/cloche-dev/cloche/internal/adapters/sqlite\"\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n)\n\n// mockContainerManager implements ContainerManager for testing.\ntype mockContainerManager struct {\n\tcontainers map[string]bool // containerID -> exists\n\trunning    map[string]bool // containerID -> running\n\tremoved    []string\n}\n\nfunc newMockContainerManager() *mockContainerManager {\n\treturn &mockContainerManager{\n\t\tcontainers: map[string]bool{},\n\t\trunning:    map[string]bool{},\n\t}\n}\n\nfunc (m *mockContainerManager) Logs(_ context.Context, containerID string) (string, error) {\n\treturn \"mock logs\", nil\n}\n\nfunc (m *mockContainerManager) Remove(_ context.Context, containerID string) error {\n\tif !m.containers[containerID] {\n\t\treturn fmt.Errorf(\"container %s not found\", containerID)\n\t}\n\tdelete(m.containers, containerID)\n\tm.removed = append(m.removed, containerID)\n\treturn nil\n}\n\nfunc (m *mockContainerManager) Inspect(_ context.Context, containerID string) (*ports.ContainerStatus, error) {\n\tif !m.containers[containerID] {\n\t\treturn nil, fmt.Errorf(\"container %s not found\", containerID)\n\t}\n\treturn &ports.ContainerStatus{Running: m.running[containerID], ExitCode: 0}, nil\n}\n\nfunc setupHandler(t *testing.T) (*Handler, *sqlite.Store) {\n\tt.Helper()\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tt.Cleanup(func() { store.Close() })\n\n\th, err := NewHandler(store, store)\n\trequire.NoError(t, err)\n\treturn h, store\n}\n\nfunc seedRun(t *testing.T, store *sqlite.Store, id, workflow string, state domain.RunState) {\n\tt.Helper()\n\tseedRunWithProject(t, store, id, workflow, state, \"\")\n}\n\nfunc seedRunWithProject(t *testing.T, store *sqlite.Store, id, workflow string, state domain.RunState, projectDir string) {\n\tt.Helper()\n\tctx := context.Background()\n\trun := domain.NewRun(id, workflow)\n\trun.ProjectDir = projectDir\n\tif state != domain.RunStatePending {\n\t\trun.Start()\n\t\trun.ContainerID = \"abc123def456789\"\n\t}\n\tif state == domain.RunStateSucceeded || state == domain.RunStateFailed {\n\t\trun.Complete(state)\n\t}\n\tif state == domain.RunStateFailed {\n\t\trun.ErrorMessage = \"something went wrong\"\n\t}\n\trequire.NoError(t, store.CreateRun(ctx, run))\n}\n\nfunc TestRunsList_WithRuns(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRun(t, store, \"test-run-1\", \"develop\", domain.RunStateRunning)\n\tseedRun(t, store, \"test-run-2\", \"deploy\", domain.RunStateSucceeded)\n\n\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tassert.Contains(t, w.Header().Get(\"Content-Type\"), \"text/html\")\n\tbody := w.Body.String()\n\tassert.Contains(t, body, \"test-run-1\")\n\tassert.Contains(t, body, \"test-run-2\")\n\tassert.Contains(t, body, \"badge-running\")\n\tassert.Contains(t, body, \"badge-succeeded\")\n\tassert.Contains(t, body, \"develop\")\n\tassert.Contains(t, body, \"deploy\")\n}\n\nfunc TestRunsList_Empty(t *testing.T) {\n\th, _ := setupHandler(t)\n\n\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tassert.Contains(t, w.Body.String(), \"No runs yet.\")\n}\n\nfunc TestRunDetail_WithCaptures(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRun(t, store, \"run-detail-1\", \"develop\", domain.RunStateRunning)\n\n\tctx := context.Background()\n\trequire.NoError(t, store.SaveCapture(ctx, \"run-detail-1\", &domain.StepExecution{\n\t\tStepName:    \"implement\",\n\t\tResult:      \"success\",\n\t\tStartedAt:   time.Now().Add(-5 * time.Minute),\n\t\tCompletedAt: time.Now(),\n\t}))\n\n\treq := httptest.NewRequest(\"GET\", \"/runs/run-detail-1\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody := w.Body.String()\n\tassert.Contains(t, body, \"run-detail-1\")\n\tassert.Contains(t, body, \"implement\")\n}\n\nfunc TestRunDetail_AccordionStatePreserved(t *testing.T) {\n\t// Verify the rendered page includes JavaScript that preserves accordion state\n\t// during SSE polling updates (captures open/closed state before DOM rebuild).\n\th, store := setupHandler(t)\n\tseedRun(t, store, \"run-accordion-1\", \"develop\", domain.RunStateRunning)\n\n\tctx := context.Background()\n\trequire.NoError(t, store.SaveCapture(ctx, \"run-accordion-1\", &domain.StepExecution{\n\t\tStepName:    \"build\",\n\t\tResult:      \"success\",\n\t\tStartedAt:   time.Now().Add(-5 * time.Minute),\n\t\tCompletedAt: time.Now(),\n\t}))\n\n\treq := httptest.NewRequest(\"GET\", \"/runs/run-accordion-1\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody := w.Body.String()\n\n\t// The poll function should capture accordion state before rebuilding the DOM\n\tassert.Contains(t, body, \"openAccordions\")\n\tassert.Contains(t, body, \"loadedOutputs\")\n\t// Verify it restores loaded output content after DOM rebuild\n\tassert.Contains(t, body, \"loadedOutputs[key]\")\n}\n\nfunc TestRunDetail_NotFound(t *testing.T) {\n\th, _ := setupHandler(t)\n\n\treq := httptest.NewRequest(\"GET\", \"/runs/nonexistent\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusNotFound, w.Code)\n}\n\nfunc TestAPIRuns(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRun(t, store, \"api-run-1\", \"develop\", domain.RunStateRunning)\n\tseedRun(t, store, \"api-run-2\", \"deploy\", domain.RunStateSucceeded)\n\n\treq := httptest.NewRequest(\"GET\", \"/api/runs\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tassert.Contains(t, w.Header().Get(\"Content-Type\"), \"application/json\")\n\n\tvar runs []apiRun\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &runs))\n\tassert.Len(t, runs, 2)\n\n\tids := map[string]bool{}\n\tfor _, r := range runs {\n\t\tids[r.ID] = true\n\t}\n\tassert.True(t, ids[\"api-run-1\"])\n\tassert.True(t, ids[\"api-run-2\"])\n}\n\nfunc TestAPIRunDetail(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRun(t, store, \"api-detail-1\", \"develop\", domain.RunStateRunning)\n\n\tctx := context.Background()\n\trequire.NoError(t, store.SaveCapture(ctx, \"api-detail-1\", &domain.StepExecution{\n\t\tStepName:    \"build\",\n\t\tResult:      \"success\",\n\t\tStartedAt:   time.Now().Add(-10 * time.Second),\n\t\tCompletedAt: time.Now(),\n\t}))\n\n\treq := httptest.NewRequest(\"GET\", \"/api/runs/api-detail-1\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\n\tvar detail apiRunDetail\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &detail))\n\tassert.Equal(t, \"api-detail-1\", detail.ID)\n\tassert.Equal(t, \"running\", detail.State)\n\tassert.Len(t, detail.Steps, 1)\n\tassert.Equal(t, \"build\", detail.Steps[0].StepName)\n\tassert.NotEmpty(t, detail.Steps[0].Duration)\n}\n\nfunc TestStaticCSS(t *testing.T) {\n\th, _ := setupHandler(t)\n\n\treq := httptest.NewRequest(\"GET\", \"/static/style.css\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tassert.Contains(t, w.Body.String(), \":root\")\n\tassert.Contains(t, w.Body.String(), \"badge-running\")\n}\n\nfunc TestHelpers(t *testing.T) {\n\tt.Run(\"stateColor\", func(t *testing.T) {\n\t\tassert.Equal(t, \"pending\", stateColor(domain.RunStatePending))\n\t\tassert.Equal(t, \"running\", stateColor(domain.RunStateRunning))\n\t\tassert.Equal(t, \"succeeded\", stateColor(domain.RunStateSucceeded))\n\t\tassert.Equal(t, \"failed\", stateColor(domain.RunStateFailed))\n\t\tassert.Equal(t, \"cancelled\", stateColor(domain.RunStateCancelled))\n\t})\n\n\tt.Run(\"formatTime\", func(t *testing.T) {\n\t\tassert.Equal(t, \"\", formatTime(time.Time{}))\n\t\tts := time.Date(2026, 2, 26, 14, 30, 0, 0, time.UTC)\n\t\tassert.Equal(t, \"2026-02-26 14:30:00\", formatTime(ts))\n\t})\n\n\tt.Run(\"formatDuration\", func(t *testing.T) {\n\t\tnow := time.Now()\n\t\tassert.Equal(t, \"\", formatDuration(time.Time{}, now))\n\t\tassert.Equal(t, \"\", formatDuration(now, time.Time{}))\n\t\tassert.Equal(t, \"500ms\", formatDuration(now, now.Add(500*time.Millisecond)))\n\t\tassert.Equal(t, \"5.0s\", formatDuration(now, now.Add(5*time.Second)))\n\t\tassert.Equal(t, \"2m30s\", formatDuration(now, now.Add(2*time.Minute+30*time.Second)))\n\t})\n\n\tt.Run(\"truncate\", func(t *testing.T) {\n\t\tassert.Equal(t, \"hello\", truncate(\"hello\", 10))\n\t\tassert.Equal(t, \"hel...\", truncate(\"hello world\", 3))\n\t})\n\n\tt.Run(\"shortContainerID\", func(t *testing.T) {\n\t\tassert.Equal(t, \"abc123def456\", shortContainerID(\"abc123def456789abcdef\"))\n\t\tassert.Equal(t, \"short\", shortContainerID(\"short\"))\n\t})\n\n\tt.Run(\"projectLabels\", func(t *testing.T) {\n\t\t// No conflict: show base name only\n\t\tlabels := projectLabels([]string{\"/home/user/alpha\", \"/home/user/beta\"})\n\t\tassert.Equal(t, \"alpha\", labels[\"/home/user/alpha\"])\n\t\tassert.Equal(t, \"beta\", labels[\"/home/user/beta\"])\n\n\t\t// Conflict: two dirs share the same base name\n\t\tlabels = projectLabels([]string{\"/home/foo/bar\", \"/home/baz/bar\"})\n\t\tassert.Equal(t, \"foo/bar\", labels[\"/home/foo/bar\"])\n\t\tassert.Equal(t, \"baz/bar\", labels[\"/home/baz/bar\"])\n\n\t\t// Mixed: some conflict, some don't\n\t\tlabels = projectLabels([]string{\"/a/bar\", \"/b/bar\", \"/c/unique\"})\n\t\tassert.Equal(t, \"a/bar\", labels[\"/a/bar\"])\n\t\tassert.Equal(t, \"b/bar\", labels[\"/b/bar\"])\n\t\tassert.Equal(t, \"unique\", labels[\"/c/unique\"])\n\n\t\t// Empty list\n\t\tlabels = projectLabels(nil)\n\t\tassert.Empty(t, labels)\n\t})\n}\n\nfunc TestRunsList_ProjectFilter(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRunWithProject(t, store, \"run-a1\", \"develop\", domain.RunStateRunning, \"/home/user/alpha\")\n\tseedRunWithProject(t, store, \"run-a2\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n\tseedRunWithProject(t, store, \"run-b1\", \"deploy\", domain.RunStateRunning, \"/home/user/beta\")\n\n\t// Without filter: all runs shown\n\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody := w.Body.String()\n\tassert.Contains(t, body, \"run-a1\")\n\tassert.Contains(t, body, \"run-b1\")\n\n\t// With project filter: only matching runs\n\treq = httptest.NewRequest(\"GET\", \"/runs?project=/home/user/alpha\", nil)\n\tw = httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody = w.Body.String()\n\tassert.Contains(t, body, \"run-a1\")\n\tassert.Contains(t, body, \"run-a2\")\n\tassert.NotContains(t, body, \"run-b1\")\n}\n\nfunc TestRunsList_ProjectColumn(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRunWithProject(t, store, \"run-p1\", \"develop\", domain.RunStateRunning, \"/home/user/myproject\")\n\n\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody := w.Body.String()\n\tassert.Contains(t, body, \"myproject\")\n\tassert.Contains(t, body, \"Project\")\n}\n\nfunc TestAPIRuns_ProjectFilter(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRunWithProject(t, store, \"api-a1\", \"develop\", domain.RunStateRunning, \"/home/user/alpha\")\n\tseedRunWithProject(t, store, \"api-b1\", \"deploy\", domain.RunStateRunning, \"/home/user/beta\")\n\n\t// Without filter: all runs\n\treq := httptest.NewRequest(\"GET\", \"/api/runs\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\tassert.Equal(t, http.StatusOK, w.Code)\n\n\tvar allRuns []apiRun\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &allRuns))\n\tassert.Len(t, allRuns, 2)\n\n\t// With filter: only matching\n\treq = httptest.NewRequest(\"GET\", \"/api/runs?project=/home/user/alpha\", nil)\n\tw = httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\tassert.Equal(t, http.StatusOK, w.Code)\n\n\tvar filtered []apiRun\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &filtered))\n\tassert.Len(t, filtered, 1)\n\tassert.Equal(t, \"api-a1\", filtered[0].ID)\n\tassert.Equal(t, \"/home/user/alpha\", filtered[0].ProjectDir)\n\tassert.Equal(t, \"alpha\", filtered[0].ProjectLabel)\n}\n\nfunc setupHandlerWithContainerManager(t *testing.T) (*Handler, *sqlite.Store, *mockContainerManager) {\n\tt.Helper()\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tt.Cleanup(func() { store.Close() })\n\n\tmgr := newMockContainerManager()\n\th, err := NewHandler(store, store, WithContainerManager(mgr))\n\trequire.NoError(t, err)\n\treturn h, store, mgr\n}\n\nfunc seedRunWithContainer(t *testing.T, store *sqlite.Store, mgr *mockContainerManager, id, workflow, projectDir, containerID string, kept bool) {\n\tt.Helper()\n\tctx := context.Background()\n\trun := domain.NewRun(id, workflow)\n\trun.ProjectDir = projectDir\n\trun.Start()\n\trun.ContainerID = containerID\n\trun.ContainerKept = kept\n\trun.Complete(domain.RunStateSucceeded)\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\tif kept {\n\t\tmgr.containers[containerID] = true\n\t}\n}\n\nfunc TestRunDetail_ContainerRunning(t *testing.T) {\n\th, store, mgr := setupHandlerWithContainerManager(t)\n\n\tctx := context.Background()\n\trun := domain.NewRun(\"run-cr\", \"develop\")\n\trun.ProjectDir = \"/proj\"\n\trun.Start()\n\trun.ContainerID = \"cid-running\"\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\tmgr.containers[\"cid-running\"] = true\n\tmgr.running[\"cid-running\"] = true\n\n\treq := httptest.NewRequest(\"GET\", \"/runs/run-cr\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody := w.Body.String()\n\tassert.Contains(t, body, \"Container running\")\n\tassert.Contains(t, body, `badge-running\">Container running`)\n}\n\nfunc TestRunDetail_ContainerStopped(t *testing.T) {\n\th, store, mgr := setupHandlerWithContainerManager(t)\n\n\tctx := context.Background()\n\trun := domain.NewRun(\"run-cs\", \"develop\")\n\trun.ProjectDir = \"/proj\"\n\trun.Start()\n\trun.ContainerID = \"cid-stopped\"\n\trun.ContainerKept = false\n\trun.Complete(domain.RunStateSucceeded)\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\tmgr.containers[\"cid-stopped\"] = true // container exists but not running, not kept\n\n\treq := httptest.NewRequest(\"GET\", \"/runs/run-cs\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody := w.Body.String()\n\tassert.Contains(t, body, \"Container stopped\")\n\tassert.Contains(t, body, `badge-stopped\">Container stopped`)\n}\n\nfunc TestRunDetail_ContainerStoppedTerminal_ShowsDeleteButton(t *testing.T) {\n\th, store, mgr := setupHandlerWithContainerManager(t)\n\n\tfor _, state := range []domain.RunState{domain.RunStateSucceeded, domain.RunStateFailed, domain.RunStateCancelled} {\n\t\tt.Run(string(state), func(t *testing.T) {\n\t\t\tid := \"run-cst-\" + string(state)\n\t\t\tctx := context.Background()\n\t\t\trun := domain.NewRun(id, \"develop\")\n\t\t\trun.ProjectDir = \"/proj\"\n\t\t\trun.Start()\n\t\t\trun.ContainerID = \"cid-stopped-\" + string(state)\n\t\t\trun.ContainerKept = false\n\t\t\trun.Complete(state)\n\t\t\trequire.NoError(t, store.CreateRun(ctx, run))\n\t\t\tmgr.containers[run.ContainerID] = true // container exists but not running, not kept\n\n\t\t\treq := httptest.NewRequest(\"GET\", \"/runs/\"+id, nil)\n\t\t\tw := httptest.NewRecorder()\n\t\t\th.ServeHTTP(w, req)\n\n\t\t\tassert.Equal(t, http.StatusOK, w.Code)\n\t\t\tbody := w.Body.String()\n\t\t\tassert.Contains(t, body, \"Container stopped\")\n\t\t\tassert.Contains(t, body, `id=\"delete-container-btn\"`, \"should show delete button for terminal run with stopped container\")\n\t\t})\n\t}\n}\n\nfunc TestRunDetail_ContainerStoppedRunning_NoDeleteButton(t *testing.T) {\n\th, store, mgr := setupHandlerWithContainerManager(t)\n\n\tctx := context.Background()\n\trun := domain.NewRun(\"run-csr\", \"develop\")\n\trun.ProjectDir = \"/proj\"\n\trun.Start()\n\trun.ContainerID = \"cid-stopped-running\"\n\trun.ContainerKept = false\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\tmgr.containers[\"cid-stopped-running\"] = true\n\t// container not running, but run state is still \"running\" (not terminal)\n\t// containerState will return \"stopped\" since ContainerKept=false\n\n\treq := httptest.NewRequest(\"GET\", \"/runs/run-csr\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody := w.Body.String()\n\tassert.Contains(t, body, \"Container stopped\")\n\t// The HTML container-status section should NOT have the delete button.\n\t// We check the dd#container-status block specifically, not the full body\n\t// (which includes JS that references the button ID as string literals).\n\tstatusStart := \"container-status\"\n\tstatusEnd := \"</dd>\"\n\tidx := strings.Index(body, statusStart)\n\trequire.NotEqual(t, -1, idx, \"container-status element must exist\")\n\tendIdx := strings.Index(body[idx:], statusEnd)\n\trequire.NotEqual(t, -1, endIdx, \"closing </dd> must exist\")\n\tstatusSection := body[idx : idx+endIdx+len(statusEnd)]\n\tassert.NotContains(t, statusSection, \"Delete Container\", \"should NOT show delete button for non-terminal run\")\n}\n\nfunc TestRunDetail_ContainerAvailable(t *testing.T) {\n\th, store, mgr := setupHandlerWithContainerManager(t)\n\tseedRunWithContainer(t, store, mgr, \"run-c1\", \"develop\", \"/proj\", \"cid-1234567890ab\", true)\n\n\treq := httptest.NewRequest(\"GET\", \"/runs/run-c1\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody := w.Body.String()\n\tassert.Contains(t, body, \"Container available\")\n\tassert.Contains(t, body, `badge-succeeded\">Container available`)\n\tassert.Contains(t, body, `id=\"delete-container-btn\"`)\n}\n\nfunc TestRunDetail_ContainerRemoved(t *testing.T) {\n\th, store, _ := setupHandlerWithContainerManager(t)\n\n\tctx := context.Background()\n\trun := domain.NewRun(\"run-c2\", \"develop\")\n\trun.ProjectDir = \"/proj\"\n\trun.Start()\n\trun.ContainerID = \"cid-gone\"\n\trun.ContainerKept = false\n\trun.Complete(domain.RunStateSucceeded)\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\t// container NOT in mock's containers map → Inspect will fail → \"removed\"\n\n\treq := httptest.NewRequest(\"GET\", \"/runs/run-c2\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody := w.Body.String()\n\tassert.Contains(t, body, \"Container removed\")\n\tassert.Contains(t, body, `badge-pending\">Container removed`)\n}\n\nfunc TestAPIDeleteContainer_Success(t *testing.T) {\n\th, store, mgr := setupHandlerWithContainerManager(t)\n\tseedRunWithContainer(t, store, mgr, \"run-del1\", \"develop\", \"/proj\", \"cid-to-delete\", true)\n\n\treq := httptest.NewRequest(\"DELETE\", \"/api/runs/run-del1/container\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\n\tvar resp map[string]string\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n\tassert.Equal(t, \"ok\", resp[\"status\"])\n\n\t// Verify container was removed\n\tassert.Contains(t, mgr.removed, \"cid-to-delete\")\n\n\t// Verify run was updated\n\trun, err := store.GetRun(context.Background(), \"run-del1\")\n\trequire.NoError(t, err)\n\tassert.False(t, run.ContainerKept)\n}\n\nfunc TestAPIDeleteContainer_StoppedContainer(t *testing.T) {\n\th, store, mgr := setupHandlerWithContainerManager(t)\n\n\tctx := context.Background()\n\trun := domain.NewRun(\"run-del-stopped\", \"develop\")\n\trun.ProjectDir = \"/proj\"\n\trun.Start()\n\trun.ContainerID = \"cid-stopped-del\"\n\trun.ContainerKept = false\n\trun.Complete(domain.RunStateFailed)\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\tmgr.containers[\"cid-stopped-del\"] = true\n\n\treq := httptest.NewRequest(\"DELETE\", \"/api/runs/run-del-stopped/container\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\n\tvar resp map[string]string\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n\tassert.Equal(t, \"ok\", resp[\"status\"])\n\tassert.Contains(t, mgr.removed, \"cid-stopped-del\")\n}\n\nfunc TestAPIDeleteContainer_RunNotFound(t *testing.T) {\n\th, _, _ := setupHandlerWithContainerManager(t)\n\n\treq := httptest.NewRequest(\"DELETE\", \"/api/runs/nonexistent/container\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusNotFound, w.Code)\n}\n\nfunc TestAPIDeleteContainer_NoManager(t *testing.T) {\n\th, store := setupHandler(t) // no container manager\n\tseedRun(t, store, \"run-noman\", \"develop\", domain.RunStateSucceeded)\n\n\treq := httptest.NewRequest(\"DELETE\", \"/api/runs/run-noman/container\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusBadRequest, w.Code)\n}\n\nfunc TestAPIRunDetail_ContainerState(t *testing.T) {\n\th, store, mgr := setupHandlerWithContainerManager(t)\n\n\t// Seed a running container\n\tctx := context.Background()\n\trun := domain.NewRun(\"api-cs1\", \"develop\")\n\trun.ProjectDir = \"/proj\"\n\trun.Start()\n\trun.ContainerID = \"cid-api-running\"\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\tmgr.containers[\"cid-api-running\"] = true\n\tmgr.running[\"cid-api-running\"] = true\n\n\treq := httptest.NewRequest(\"GET\", \"/api/runs/api-cs1\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\n\tvar detail apiRunDetail\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &detail))\n\tassert.Equal(t, \"running\", detail.ContainerState)\n\n\t// Now stop it\n\tmgr.running[\"cid-api-running\"] = false\n\n\tw = httptest.NewRecorder()\n\th.ServeHTTP(w, httptest.NewRequest(\"GET\", \"/api/runs/api-cs1\", nil))\n\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &detail))\n\tassert.Equal(t, \"stopped\", detail.ContainerState)\n}\n\nfunc TestRunsList_ContainerCount(t *testing.T) {\n\th, store, mgr := setupHandlerWithContainerManager(t)\n\tseedRunWithContainer(t, store, mgr, \"run-cc1\", \"develop\", \"/home/user/alpha\", \"cid-1\", true)\n\tseedRunWithContainer(t, store, mgr, \"run-cc2\", \"develop\", \"/home/user/alpha\", \"cid-2\", true)\n\tseedRunWithContainer(t, store, mgr, \"run-cc3\", \"deploy\", \"/home/user/beta\", \"cid-3\", false)\n\n\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody := w.Body.String()\n\t// alpha has 2 retained containers\n\tassert.Contains(t, body, \"2 containers\")\n\t// beta has 0, so no count should appear\n\tassert.NotContains(t, body, \"0 container\")\n}\n\nfunc TestAPIProjects(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRunWithProject(t, store, \"p1\", \"develop\", domain.RunStateRunning, \"/home/user/alpha\")\n\tseedRunWithProject(t, store, \"p2\", \"develop\", domain.RunStateRunning, \"/home/user/beta\")\n\tseedRunWithProject(t, store, \"p3\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n\n\treq := httptest.NewRequest(\"GET\", \"/api/projects\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\tassert.Equal(t, http.StatusOK, w.Code)\n\n\ttype apiHealth struct {\n\t\tStatus string `json:\"status\"`\n\t\tPassed int    `json:\"passed\"`\n\t\tFailed int    `json:\"failed\"`\n\t\tTotal  int    `json:\"total\"`\n\t}\n\ttype project struct {\n\t\tDir         string    `json:\"dir\"`\n\t\tLabel       string    `json:\"label\"`\n\t\tHealth      apiHealth `json:\"health\"`\n\t\tActiveCount int       `json:\"active_count\"`\n\t}\n\tvar projects []project\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &projects))\n\tassert.Len(t, projects, 2)\n\n\tbyDir := map[string]project{}\n\tfor _, p := range projects {\n\t\tbyDir[p.Dir] = p\n\t}\n\tassert.Equal(t, \"alpha\", byDir[\"/home/user/alpha\"].Label)\n\tassert.Equal(t, \"beta\", byDir[\"/home/user/beta\"].Label)\n\t// alpha has 1 running + 1 succeeded = yellow health (mix), 1 active\n\tassert.Equal(t, 1, byDir[\"/home/user/alpha\"].ActiveCount)\n\tassert.NotEmpty(t, byDir[\"/home/user/alpha\"].Health.Status)\n\t// beta has 1 running = blue (all in-progress), 1 active\n\tassert.Equal(t, \"blue\", byDir[\"/home/user/beta\"].Health.Status)\n\tassert.Equal(t, 1, byDir[\"/home/user/beta\"].ActiveCount)\n}\n\nfunc TestProjectOverview_WithProjects(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRunWithProject(t, store, \"ov-1\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n\tseedRunWithProject(t, store, \"ov-2\", \"develop\", domain.RunStateFailed, \"/home/user/alpha\")\n\tseedRunWithProject(t, store, \"ov-3\", \"develop\", domain.RunStateRunning, \"/home/user/beta\")\n\n\treq := httptest.NewRequest(\"GET\", \"/\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tassert.Contains(t, w.Header().Get(\"Content-Type\"), \"text/html\")\n\tbody := w.Body.String()\n\t// Project cards should be present\n\tassert.Contains(t, body, \"project-card\")\n\tassert.Contains(t, body, \"alpha\")\n\tassert.Contains(t, body, \"beta\")\n\t// Health dots\n\tassert.Contains(t, body, \"health-dot\")\n\t// Run history dots\n\tassert.Contains(t, body, \"run-dot\")\n\t// Quick actions\n\tassert.Contains(t, body, \"View Runs\")\n}\n\nfunc TestProjectOverview_Empty(t *testing.T) {\n\th, _ := setupHandler(t)\n\n\treq := httptest.NewRequest(\"GET\", \"/\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tassert.Contains(t, w.Body.String(), \"No projects yet\")\n}\n\nfunc TestHealthColor(t *testing.T) {\n\tassert.Equal(t, \"green\", healthColor(domain.HealthGreen))\n\tassert.Equal(t, \"yellow\", healthColor(domain.HealthYellow))\n\tassert.Equal(t, \"red\", healthColor(domain.HealthRed))\n\tassert.Equal(t, \"blue\", healthColor(domain.HealthBlue))\n\tassert.Equal(t, \"grey\", healthColor(domain.HealthGrey))\n\tassert.Equal(t, \"grey\", healthColor(\"unknown\"))\n}\n\nfunc TestAPIProjects_HealthData(t *testing.T) {\n\th, store := setupHandler(t)\n\t// alpha: 3 succeeded, 1 failed → yellow\n\tseedRunWithProject(t, store, \"h1\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n\tseedRunWithProject(t, store, \"h2\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n\tseedRunWithProject(t, store, \"h3\", \"develop\", domain.RunStateFailed, \"/home/user/alpha\")\n\tseedRunWithProject(t, store, \"h4\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n\n\t// beta: all succeeded → green\n\tseedRunWithProject(t, store, \"h5\", \"develop\", domain.RunStateSucceeded, \"/home/user/beta\")\n\tseedRunWithProject(t, store, \"h6\", \"develop\", domain.RunStateSucceeded, \"/home/user/beta\")\n\n\treq := httptest.NewRequest(\"GET\", \"/api/projects\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\tassert.Equal(t, http.StatusOK, w.Code)\n\n\ttype health struct {\n\t\tStatus string `json:\"status\"`\n\t\tPassed int    `json:\"passed\"`\n\t\tFailed int    `json:\"failed\"`\n\t\tTotal  int    `json:\"total\"`\n\t}\n\ttype project struct {\n\t\tDir    string `json:\"dir\"`\n\t\tLabel  string `json:\"label\"`\n\t\tHealth health `json:\"health\"`\n\t}\n\tvar projects []project\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &projects))\n\tassert.Len(t, projects, 2)\n\n\tbyDir := map[string]project{}\n\tfor _, p := range projects {\n\t\tbyDir[p.Dir] = p\n\t}\n\n\talpha := byDir[\"/home/user/alpha\"]\n\tassert.Equal(t, \"yellow\", alpha.Health.Status)\n\tassert.Equal(t, 3, alpha.Health.Passed)\n\tassert.Equal(t, 1, alpha.Health.Failed)\n\tassert.Equal(t, 4, alpha.Health.Total)\n\n\tbeta := byDir[\"/home/user/beta\"]\n\tassert.Equal(t, \"green\", beta.Health.Status)\n\tassert.Equal(t, 2, beta.Health.Passed)\n\tassert.Equal(t, 0, beta.Health.Failed)\n\tassert.Equal(t, 2, beta.Health.Total)\n}\n\nfunc TestResolveFileRef(t *testing.T) {\n\t// Create a temp directory with a test file\n\tdir := t.TempDir()\n\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \"prompts\"), 0o755))\n\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \"prompts\", \"implement.md\"), []byte(\"# Implement\\nDo the thing.\"), 0o644))\n\n\tt.Run(\"file() reference resolves to contents\", func(t *testing.T) {\n\t\tcontent, err := resolveFileRef(`file(\"prompts/implement.md\")`, dir)\n\t\trequire.NoError(t, err)\n\t\tassert.Equal(t, \"# Implement\\nDo the thing.\", content)\n\t})\n\n\tt.Run(\"file() reference with missing file returns error\", func(t *testing.T) {\n\t\t_, err := resolveFileRef(`file(\"prompts/nonexistent.md\")`, dir)\n\t\tassert.Error(t, err)\n\t})\n\n\tt.Run(\"plain string returned as-is\", func(t *testing.T) {\n\t\tcontent, err := resolveFileRef(\"echo hello\", dir)\n\t\trequire.NoError(t, err)\n\t\tassert.Equal(t, \"echo hello\", content)\n\t})\n\n\tt.Run(\"quoted string returned as-is\", func(t *testing.T) {\n\t\tcontent, err := resolveFileRef(`\"some value\"`, dir)\n\t\trequire.NoError(t, err)\n\t\tassert.Equal(t, `\"some value\"`, content)\n\t})\n}\n\nfunc TestAPIStepContent_FileRef(t *testing.T) {\n\th, store := setupHandler(t)\n\n\t// Create a temp project directory with a workflow and prompt file\n\tdir := t.TempDir()\n\trequire.NoError(t, os.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0o755))\n\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"), []byte(\"Build the feature.\"), 0o644))\n\n\tworkflowContent := `workflow \"develop\" {\n    step implement {\n        prompt = file(\".cloche/prompts/implement.md\")\n        results = [success, fail]\n    }\n    implement:success -> done\n    implement:fail -> abort\n}\n`\n\trequire.NoError(t, os.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"), []byte(workflowContent), 0o644))\n\n\t// Seed a run so the project is known\n\tseedRunWithProject(t, store, \"sc-1\", \"develop\", domain.RunStateRunning, dir)\n\n\t// Request step content\n\treq := httptest.NewRequest(\"GET\", \"/api/projects/\"+filepath.Base(dir)+\"/workflows/develop/steps/implement/content\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tassert.Equal(t, \"Build the feature.\", w.Body.String())\n}\n\nfunc TestAPIProjects_HealthNoRuns(t *testing.T) {\n\th, _ := setupHandler(t)\n\n\treq := httptest.NewRequest(\"GET\", \"/api/projects\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\tassert.Equal(t, http.StatusOK, w.Code)\n\n\t// No projects means empty array\n\ttype project struct {\n\t\tDir   string `json:\"dir\"`\n\t\tLabel string `json:\"label\"`\n\t}\n\tvar projects []project\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &projects))\n\tassert.Empty(t, projects)\n}\n","numLines":875,"startLine":1,"totalLines":875}}}
