{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0173di1nUFhAGdUpURF9YeeG","type":"tool_result","content":"     1→{{define \"content\"}}\n     2→<h1>Projects</h1>\n     3→{{if .Projects}}\n     4→<div class=\"project-cards\">\n     5→    {{range .Projects}}\n     6→    <div class=\"project-card\">\n     7→        <div class=\"project-header\">\n     8→            <span class=\"health-dot health-{{healthColor .Health.Status}}\" title=\"{{.Health.Status}}\"></span>\n     9→            <a href=\"/projects/{{.Label}}\" class=\"project-name\">{{.Label}}</a>\n    10→        </div>\n    11→        <div class=\"project-stats\">\n    12→            <div class=\"stat\">\n    13→                <span class=\"stat-value\">{{.Health.Passed}}/{{.Health.Total}}</span>\n    14→                <span class=\"stat-label\">recent passed</span>\n    15→            </div>\n    16→            <div class=\"stat\">\n    17→                <span class=\"stat-value\">{{.ActiveCount}}</span>\n    18→                <span class=\"stat-label\">active</span>\n    19→            </div>\n    20→        </div>\n    21→        <div class=\"run-history\">\n    22→            {{range .RecentRuns}}\n    23→            <span class=\"run-dot run-dot-{{.State}}\" title=\"{{.ID}}: {{.State}}\"></span>\n    24→            {{end}}\n    25→        </div>\n    26→        <div class=\"project-actions\">\n    27→            <a href=\"/projects/{{.Label}}/runs\" class=\"btn btn-secondary\">View Runs</a>\n    28→        </div>\n    29→    </div>\n    30→    {{end}}\n    31→</div>\n    32→{{else}}\n    33→<p class=\"empty\">No projects yet. Start a workflow run to see projects here.</p>\n    34→{{end}}\n    35→{{end}}\n    36→\n    37→{{define \"scripts\"}}\n    38→{{end}}\n    39→"}]},"parent_tool_use_id":"toolu_01KxSmpApK5xnCTuSmWZ7Zh8","session_id":"b2566a3c-e8d8-43a6-bf93-08a9f5a6e841","uuid":"3ad45fa8-cd7c-453f-9cc4-1831d32d35dc"}
