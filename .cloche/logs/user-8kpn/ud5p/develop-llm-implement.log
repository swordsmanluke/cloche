{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016gcWE3p1xjDeJLd4oKu6fe","type":"tool_result","content":"     1→syntax = \"proto3\";\n     2→\n     3→package cloche.v1;\n     4→\n     5→option go_package = \"github.com/cloche-dev/cloche/api/clochepb\";\n     6→\n     7→service ClocheService {\n     8→  rpc RunWorkflow(RunWorkflowRequest) returns (RunWorkflowResponse);\n     9→  rpc GetStatus(GetStatusRequest) returns (GetStatusResponse);\n    10→  rpc StreamLogs(StreamLogsRequest) returns (stream LogEntry);\n    11→  rpc StopRun(StopRunRequest) returns (StopRunResponse);\n    12→  rpc ListRuns(ListRunsRequest) returns (ListRunsResponse);\n    13→  rpc Shutdown(ShutdownRequest) returns (ShutdownResponse);\n    14→  rpc DeleteContainer(DeleteContainerRequest) returns (DeleteContainerResponse);\n    15→}\n    16→\n    17→message RunWorkflowRequest {\n    18→  string workflow_name = 1;\n    19→  string project_dir = 2;\n    20→  string image = 3;\n    21→  string prompt = 4;\n    22→  bool keep_container = 5;\n    23→}\n    24→\n    25→message RunWorkflowResponse {\n    26→  string run_id = 1;\n    27→}\n    28→\n    29→message GetStatusRequest {\n    30→  string run_id = 1;\n    31→}\n    32→\n    33→message GetStatusResponse {\n    34→  string run_id = 1;\n    35→  string workflow_name = 2;\n    36→  string state = 3;\n    37→  string current_step = 4;\n    38→  repeated StepExecutionStatus step_executions = 5;\n    39→  string error_message = 6;\n    40→  string container_id = 7;\n    41→  bool container_alive = 8;\n    42→  string container_dead_since = 9;\n    43→}\n    44→\n    45→message StepExecutionStatus {\n    46→  string step_name = 1;\n    47→  string result = 2;\n    48→  string started_at = 3;\n    49→  string completed_at = 4;\n    50→}\n    51→\n    52→message StreamLogsRequest {\n    53→  string run_id = 1;\n    54→  string step_name = 2;\n    55→  string log_type = 3;\n    56→}\n    57→\n    58→message LogEntry {\n    59→  string type = 1;\n    60→  string step_name = 2;\n    61→  string result = 3;\n    62→  string message = 4;\n    63→  string timestamp = 5;\n    64→}\n    65→\n    66→message StopRunRequest {\n    67→  string run_id = 1;\n    68→}\n    69→\n    70→message StopRunResponse {}\n    71→\n    72→message ShutdownRequest {}\n    73→\n    74→message ShutdownResponse {}\n    75→\n    76→message DeleteContainerRequest {\n    77→  string id = 1;\n    78→}\n    79→\n    80→message DeleteContainerResponse {}\n    81→\n    82→message ListRunsRequest {\n    83→  bool all = 1;\n    84→}\n    85→\n    86→message ListRunsResponse {\n    87→  repeated RunSummary runs = 1;\n    88→}\n    89→\n    90→message RunSummary {\n    91→  string run_id = 1;\n    92→  string workflow_name = 2;\n    93→  string state = 3;\n    94→  string started_at = 4;\n    95→  string error_message = 5;\n    96→  string container_id = 6;\n    97→}\n    98→"}]},"parent_tool_use_id":"toolu_01KxSmpApK5xnCTuSmWZ7Zh8","session_id":"b2566a3c-e8d8-43a6-bf93-08a9f5a6e841","uuid":"4456e693-7ba3-480b-be88-7e7b77a0bce9"}
