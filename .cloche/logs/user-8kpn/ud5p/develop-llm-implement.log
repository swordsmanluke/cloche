{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016QzcUWK2bnDLMWDTKB9udn","type":"tool_result","content":"     1→{{define \"content\"}}\n     2→<h1>\n     3→    <a href=\"/runs\">Runs</a> / {{.Run.ID}}\n     4→    <span class=\"badge badge-{{stateColor .Run.State}}\">{{.Run.State}}</span>\n     5→</h1>\n     6→\n     7→<div class=\"run-meta\">\n     8→    <dl>\n     9→        <dt>Workflow</dt><dd>{{.Run.WorkflowName}}</dd>\n    10→        <dt>Started</dt><dd>{{formatTime .Run.StartedAt}}</dd>\n    11→        <dt>Completed</dt><dd>{{formatTime .Run.CompletedAt}}</dd>\n    12→        <dt>Container</dt><dd class=\"mono\">{{.Run.ContainerID}}</dd>\n    13→        <dt>Container Status</dt>\n    14→        <dd id=\"container-status\">\n    15→            {{if eq .ContainerState \"running\"}}\n    16→                <span class=\"badge badge-running\">Container running</span>\n    17→            {{else if eq .ContainerState \"stopped\"}}\n    18→                <span class=\"badge badge-stopped\">Container stopped</span>\n    19→                {{if or (eq .Run.State \"succeeded\") (eq .Run.State \"failed\") (eq .Run.State \"cancelled\")}}\n    20→                <button class=\"btn btn-danger btn-sm\" id=\"delete-container-btn\" onclick=\"deleteContainer('{{.Run.ID}}')\">Delete Container</button>\n    21→                {{end}}\n    22→            {{else if eq .ContainerState \"available\"}}\n    23→                <span class=\"badge badge-succeeded\">Container available</span>\n    24→                <button class=\"btn btn-danger btn-sm\" id=\"delete-container-btn\" onclick=\"deleteContainer('{{.Run.ID}}')\">Delete Container</button>\n    25→            {{else}}\n    26→                <span class=\"badge badge-pending\">Container removed</span>\n    27→            {{end}}\n    28→        </dd>\n    29→    </dl>\n    30→</div>\n    31→\n    32→{{if .Run.ErrorMessage}}\n    33→<div class=\"error-box\">{{.Run.ErrorMessage}}</div>\n    34→{{end}}\n    35→\n    36→<h2>Steps</h2>\n    37→<table class=\"runs-table\">\n    38→    <thead>\n    39→        <tr>\n    40→            <th>Step</th>\n    41→            <th>Result</th>\n    42→            <th>Started</th>\n    43→            <th>Duration</th>\n    44→        </tr>\n    45→    </thead>\n    46→    <tbody id=\"steps-body\">\n    47→    {{if .Steps}}\n    48→        {{range .Steps}}\n    49→        <tr class=\"step-row\" data-run-id=\"{{$.Run.ID}}\" data-step=\"{{.StepName}}\" data-index=\"{{.Index}}\">\n    50→            <td>{{.StepName}}</td>\n    51→            <td>{{if .Result}}<span class=\"badge badge-{{if eq .Result \"success\"}}succeeded{{else if eq .Result \"fail\"}}failed{{else}}pending{{end}}\">{{.Result}}</span>{{else}}<span class=\"badge badge-running\">running</span>{{end}}</td>\n    52→            <td>{{formatTime .StartedAt}}</td>\n    53→            <td>{{.Duration}}</td>\n    54→        </tr>\n    55→        <tr class=\"output-row\" id=\"output-{{.Index}}\" style=\"display:none\">\n    56→            <td colspan=\"4\"><pre class=\"step-output\">Loading...</pre></td>\n    57→        </tr>\n    58→        {{end}}\n    59→    {{else}}\n    60→        <tr><td colspan=\"4\" class=\"empty\">No step executions recorded.</td></tr>\n    61→    {{end}}\n    62→    </tbody>\n    63→</table>\n    64→\n    65→<h2>\n    66→    Log\n    67→    <span id=\"log-status\" class=\"badge badge-running\" style=\"font-size:0.7rem; margin-left:0.5rem;\">Live</span>\n    68→</h2>\n    69→<div id=\"log-viewer\" class=\"log-viewer\"><pre id=\"log-content\"></pre></div>\n    70→{{end}}\n    71→\n    72→{{define \"scripts\"}}\n    73→<script>\n    74→(function() {\n    75→    var runState = '{{.Run.State}}';\n    76→    var runID = '{{.Run.ID}}';\n    77→\n    78→    // --- Log Viewer ---\n    79→    var logContent = document.getElementById('log-content');\n    80→    var logViewer = document.getElementById('log-viewer');\n    81→    var logStatus = document.getElementById('log-status');\n    82→    var autoScroll = true;\n    83→\n    84→    // Track scroll position to enable/disable auto-scroll\n    85→    logViewer.addEventListener('scroll', function() {\n    86→        var atBottom = logViewer.scrollHeight - logViewer.scrollTop - logViewer.clientHeight < 40;\n    87→        autoScroll = atBottom;\n    88→    });\n    89→\n    90→    function appendLogLine(line) {\n    91→        var span = document.createElement('span');\n    92→        span.className = 'log-line log-type-' + (line.type || 'script');\n    93→        span.textContent = '[' + line.timestamp + '] [' + line.type + '] ' + line.content + '\\n';\n    94→        logContent.appendChild(span);\n    95→        if (autoScroll) {\n    96→            logViewer.scrollTop = logViewer.scrollHeight;\n    97→        }\n    98→    }\n    99→\n   100→    function markComplete() {\n   101→        logStatus.textContent = 'Complete';\n   102→        logStatus.className = 'badge badge-succeeded';\n   103→    }\n   104→\n   105→    // Connect to SSE stream\n   106→    var source = new EventSource('/api/runs/' + runID + '/stream');\n   107→    source.onmessage = function(e) {\n   108→        try {\n   109→            var line = JSON.parse(e.data);\n   110→            appendLogLine(line);\n   111→        } catch(err) {}\n   112→    };\n   113→    source.addEventListener('done', function(e) {\n   114→        markComplete();\n   115→        source.close();\n   116→    });\n   117→    source.onerror = function() {\n   118→        markComplete();\n   119→        source.close();\n   120→    };\n   121→\n   122→    // If already complete, mark the badge immediately\n   123→    if (runState === 'succeeded' || runState === 'failed' || runState === 'cancelled') {\n   124→        logStatus.textContent = 'Complete';\n   125→        logStatus.className = 'badge badge-succeeded';\n   126→    }\n   127→\n   128→    // --- Steps Polling (for active runs) ---\n   129→    if (runState !== 'succeeded' && runState !== 'failed' && runState !== 'cancelled') {\n   130→        function poll() {\n   131→            fetch('/api/runs/' + runID)\n   132→                .then(function(r) { return r.json(); })\n   133→                .then(function(data) {\n   134→                    if (data.state !== runState) {\n   135→                        location.reload();\n   136→                        return;\n   137→                    }\n   138→                    // Update container status\n   139→                    var statusEl = document.getElementById('container-status');\n   140→                    if (statusEl && data.container_state) {\n   141→                        var cs = data.container_state;\n   142→                        if (cs === 'running') {\n   143→                            statusEl.innerHTML = '<span class=\"badge badge-running\">Container running</span>';\n   144→                        } else if (cs === 'stopped') {\n   145→                            var stoppedHtml = '<span class=\"badge badge-stopped\">Container stopped</span>';\n   146→                            if (data.state === 'succeeded' || data.state === 'failed' || data.state === 'cancelled') {\n   147→                                stoppedHtml += ' <button class=\"btn btn-danger btn-sm\" id=\"delete-container-btn\" onclick=\"deleteContainer(\\'' + escapeHtml(runID) + '\\')\">Delete Container</button>';\n   148→                            }\n   149→                            statusEl.innerHTML = stoppedHtml;\n   150→                        } else if (cs === 'available') {\n   151→                            statusEl.innerHTML = '<span class=\"badge badge-succeeded\">Container available</span>' +\n   152→                                ' <button class=\"btn btn-danger btn-sm\" id=\"delete-container-btn\" onclick=\"deleteContainer(\\'' + escapeHtml(runID) + '\\')\">Delete Container</button>';\n   153→                        } else {\n   154→                            statusEl.innerHTML = '<span class=\"badge badge-pending\">Container removed</span>';\n   155→                        }\n   156→                    }\n   157→                    var tbody = document.getElementById('steps-body');\n   158→                    if (!data.steps || data.steps.length === 0) {\n   159→                        tbody.innerHTML = '<tr><td colspan=\"4\" class=\"empty\">No step executions recorded.</td></tr>';\n   160→                        return;\n   161→                    }\n   162→\n   163→                    // Capture current accordion state before updating\n   164→                    var openAccordions = {};\n   165→                    var loadedOutputs = {};\n   166→                    var outputRows = tbody.querySelectorAll('.output-row');\n   167→                    for (var j = 0; j < outputRows.length; j++) {\n   168→                        var id = outputRows[j].id;\n   169→                        if (outputRows[j].style.display !== 'none') {\n   170→                            openAccordions[id] = true;\n   171→                        }\n   172→                        var pre = outputRows[j].querySelector('.step-output');\n   173→                        if (pre && pre.textContent !== 'Loading...') {\n   174→                            loadedOutputs[id] = pre.textContent;\n   175→                        }\n   176→                    }\n   177→\n   178→                    // Build updated step rows, preserving accordion state\n   179→                    var html = '';\n   180→                    for (var i = 0; i < data.steps.length; i++) {\n   181→                        var s = data.steps[i];\n   182→                        var badge = '';\n   183→                        if (s.result) {\n   184→                            var cls = s.result === 'success' ? 'succeeded' : s.result === 'fail' ? 'failed' : 'pending';\n   185→                            badge = '<span class=\"badge badge-' + cls + '\">' + escapeHtml(s.result) + '</span>';\n   186→                        } else {\n   187→                            badge = '<span class=\"badge badge-running\">running</span>';\n   188→                        }\n   189→                        var outputId = 'output-' + i;\n   190→                        var isOpen = openAccordions[outputId];\n   191→                        html += '<tr class=\"step-row\" data-run-id=\"' + escapeHtml(runID) + '\" data-step=\"' + escapeHtml(s.step_name) + '\" data-index=\"' + i + '\">' +\n   192→                            '<td>' + escapeHtml(s.step_name) + '</td>' +\n   193→                            '<td>' + badge + '</td>' +\n   194→                            '<td>' + s.started_at + '</td>' +\n   195→                            '<td>' + s.duration + '</td>' +\n   196→                            '</tr>' +\n   197→                            '<tr class=\"output-row\" id=\"' + outputId + '\"' + (isOpen ? '' : ' style=\"display:none\"') + '>' +\n   198→                            '<td colspan=\"4\"><pre class=\"step-output\">Loading...</pre></td>' +\n   199→                            '</tr>';\n   200→                    }\n   201→                    tbody.innerHTML = html;\n   202→\n   203→                    // Restore loaded output content for open accordions\n   204→                    for (var key in loadedOutputs) {\n   205→                        var row = document.getElementById(key);\n   206→                        if (row) {\n   207→                            var pre = row.querySelector('.step-output');\n   208→                            if (pre) {\n   209→                                pre.textContent = loadedOutputs[key];\n   210→                            }\n   211→                        }\n   212→                    }\n   213→\n   214→                    // Re-fetch output for accordions that were open but had no cached content\n   215→                    for (var key in openAccordions) {\n   216→                        if (!loadedOutputs[key]) {\n   217→                            var row = document.getElementById(key);\n   218→                            if (row) {\n   219→                                var stepRow = row.previousElementSibling;\n   220→                                if (stepRow && stepRow.dataset.runId && stepRow.dataset.step) {\n   221→                                    (function(r, rid, sname) {\n   222→                                        var pre = r.querySelector('.step-output');\n   223→                                        fetch('/api/runs/' + rid + '/steps/' + sname + '/output')\n   224→                                            .then(function(resp) {\n   225→                                                if (!resp.ok) return 'No output available.';\n   226→                                                return resp.text();\n   227→                                            })\n   228→                                            .then(function(text) { pre.textContent = text; })\n   229→                                            .catch(function() { pre.textContent = 'Failed to load output.'; });\n   230→                                    })(row, stepRow.dataset.runId, stepRow.dataset.step);\n   231→                                }\n   232→                            }\n   233→                        }\n   234→                    }\n   235→                })\n   236→                .catch(function() {});\n   237→        }\n   238→        setInterval(poll, 2000);\n   239→    }\n   240→\n   241→    function escapeHtml(s) {\n   242→        if (!s) return '';\n   243→        var d = document.createElement('div');\n   244→        d.appendChild(document.createTextNode(s));\n   245→        return d.innerHTML;\n   246→    }\n   247→})();\n   248→\n   249→// Delete container\n   250→    window.deleteContainer = function(runID) {\n   251→        var btn = document.getElementById('delete-container-btn');\n   252→        if (btn) btn.disabled = true;\n   253→        fetch('/api/runs/' + runID + '/container', { method: 'DELETE' })\n   254→            .then(function(r) { return r.json().then(function(d) { return {ok: r.ok, data: d}; }); })\n   255→            .then(function(res) {\n   256→                var statusEl = document.getElementById('container-status');\n   257→                if (res.ok) {\n   258→                    statusEl.innerHTML = '<span class=\"badge badge-pending\">Container removed</span>';\n   259→                } else {\n   260→                    if (btn) btn.disabled = false;\n   261→                    alert('Failed to delete container: ' + (res.data.error || 'unknown error'));\n   262→                }\n   263→            })\n   264→            .catch(function() {\n   265→                if (btn) btn.disabled = false;\n   266→                alert('Failed to delete container');\n   267→            });\n   268→    };\n   269→\n   270→    // Toggle step output rows\n   271→document.addEventListener('click', function(e) {\n   272→    var row = e.target.closest('.step-row');\n   273→    if (!row) return;\n   274→    var idx = row.dataset.index;\n   275→    var outputRow = document.getElementById('output-' + idx);\n   276→    if (!outputRow) return;\n   277→\n   278→    if (outputRow.style.display === 'none') {\n   279→        outputRow.style.display = '';\n   280→        var pre = outputRow.querySelector('.step-output');\n   281→        if (pre.textContent === 'Loading...') {\n   282→            var runId = row.dataset.runId;\n   283→            var step = row.dataset.step;\n   284→            fetch('/api/runs/' + runId + '/steps/' + step + '/output')\n   285→                .then(function(r) {\n   286→                    if (!r.ok) return 'No output available.';\n   287→                    return r.text();\n   288→                })\n   289→                .then(function(text) { pre.textContent = text; })\n   290→                .catch(function() { pre.textContent = 'Failed to load output.'; });\n   291→        }\n   292→    } else {\n   293→        outputRow.style.display = 'none';\n   294→    }\n   295→});\n   296→</script>\n   297→{{end}}\n   298→"}]},"parent_tool_use_id":"toolu_01KxSmpApK5xnCTuSmWZ7Zh8","session_id":"b2566a3c-e8d8-43a6-bf93-08a9f5a6e841","uuid":"d44999d1-fd10-47f1-8251-a17ea9743090"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01N43suqawHjBMEvePs92r2t","type":"tool_result","content":"     1→package web\n     2→\n     3→import (\n     4→\t\"bufio\"\n     5→\t\"context\"\n     6→\t\"embed\"\n     7→\t\"encoding/json\"\n     8→\t\"fmt\"\n     9→\t\"html/template\"\n    10→\t\"io/fs\"\n    11→\t\"net/http\"\n    12→\t\"net/url\"\n    13→\t\"os\"\n    14→\t\"os/exec\"\n    15→\t\"path/filepath\"\n    16→\t\"regexp\"\n    17→\t\"sort\"\n    18→\t\"strconv\"\n    19→\t\"strings\"\n    20→\t\"time\"\n    21→\n    22→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    23→\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    24→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    25→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    26→)\n    27→\n    28→// HandlerOption configures optional Handler dependencies.\n    29→type HandlerOption func(*Handler)\n    30→\n    31→// WithContainerLogger sets the container runtime for fetching live logs.\n    32→func WithContainerLogger(c ContainerLogger) HandlerOption {\n    33→\treturn func(h *Handler) { h.container = c }\n    34→}\n    35→\n    36→// WithContainerManager sets a full container manager (logs, inspect, remove).\n    37→func WithContainerManager(c ContainerManager) HandlerOption {\n    38→\treturn func(h *Handler) { h.container = c }\n    39→}\n    40→\n    41→// WithLogBroadcaster sets the log broadcaster for SSE streaming.\n    42→func WithLogBroadcaster(b *logstream.Broadcaster) HandlerOption {\n    43→\treturn func(h *Handler) { h.logBroadcast = b }\n    44→}\n    45→\n    46→// WithLogStore sets the log store for indexed log file lookups.\n    47→func WithLogStore(ls ports.LogStore) HandlerOption {\n    48→\treturn func(h *Handler) { h.logStore = ls }\n    49→}\n    50→\n    51→//go:embed templates/*.html static/*\n    52→var content embed.FS\n    53→\n    54→// Handler serves the web dashboard.\n    55→// ContainerLogger can retrieve logs from a container by ID.\n    56→type ContainerLogger interface {\n    57→\tLogs(ctx context.Context, containerID string) (string, error)\n    58→}\n    59→\n    60→// ContainerManager extends ContainerLogger with container lifecycle operations.\n    61→type ContainerManager interface {\n    62→\tContainerLogger\n    63→\tRemove(ctx context.Context, containerID string) error\n    64→\tInspect(ctx context.Context, containerID string) (*ports.ContainerStatus, error)\n    65→}\n    66→\n    67→type Handler struct {\n    68→\tstore        ports.RunStore\n    69→\tcaptures     ports.CaptureStore\n    70→\tlogStore     ports.LogStore\n    71→\tcontainer    ContainerLogger\n    72→\tlogBroadcast *logstream.Broadcaster\n    73→\tpages        map[string]*template.Template\n    74→\tmux          *http.ServeMux\n    75→}\n    76→\n    77→// NewHandler creates a web dashboard handler.\n    78→func NewHandler(store ports.RunStore, captures ports.CaptureStore, opts ...HandlerOption) (*Handler, error) {\n    79→\tfuncMap := template.FuncMap{\n    80→\t\t\"stateColor\":       stateColor,\n    81→\t\t\"healthColor\":      healthColor,\n    82→\t\t\"formatTime\":       formatTime,\n    83→\t\t\"formatDuration\":   formatDuration,\n    84→\t\t\"truncate\":         truncate,\n    85→\t\t\"shortContainerID\": shortContainerID,\n    86→\t}\n    87→\n    88→\tbase, err := template.New(\"\").Funcs(funcMap).ParseFS(content, \"templates/layout.html\")\n    89→\tif err != nil {\n    90→\t\treturn nil, fmt.Errorf(\"parse layout: %w\", err)\n    91→\t}\n    92→\n    93→\tpages := map[string]*template.Template{}\n    94→\tfor _, page := range []string{\"projects\", \"runs\", \"run_detail\", \"project_detail\"} {\n    95→\t\tclone, err := base.Clone()\n    96→\t\tif err != nil {\n    97→\t\t\treturn nil, fmt.Errorf(\"clone layout for %s: %w\", page, err)\n    98→\t\t}\n    99→\t\t_, err = clone.ParseFS(content, \"templates/\"+page+\".html\")\n   100→\t\tif err != nil {\n   101→\t\t\treturn nil, fmt.Errorf(\"parse %s: %w\", page, err)\n   102→\t\t}\n   103→\t\tpages[page] = clone\n   104→\t}\n   105→\n   106→\th := &Handler{\n   107→\t\tstore:    store,\n   108→\t\tcaptures: captures,\n   109→\t\tpages:    pages,\n   110→\t\tmux:      http.NewServeMux(),\n   111→\t}\n   112→\tfor _, opt := range opts {\n   113→\t\topt(h)\n   114→\t}\n   115→\n   116→\tstaticFS, err := fs.Sub(content, \"static\")\n   117→\tif err != nil {\n   118→\t\treturn nil, fmt.Errorf(\"static sub-fs: %w\", err)\n   119→\t}\n   120→\n   121→\th.mux.HandleFunc(\"GET /{$}\", h.handleProjectOverview)\n   122→\th.mux.HandleFunc(\"GET /projects/{name}/runs\", h.handleProjectRuns)\n   123→\th.mux.HandleFunc(\"GET /runs\", h.handleRunsList)\n   124→\th.mux.HandleFunc(\"GET /runs/{id}\", h.handleRunDetail)\n   125→\th.mux.HandleFunc(\"GET /projects/{name}\", h.handleProjectDetail)\n   126→\th.mux.HandleFunc(\"GET /api/projects\", h.handleAPIProjects)\n   127→\th.mux.HandleFunc(\"GET /api/runs\", h.handleAPIRuns)\n   128→\th.mux.HandleFunc(\"GET /api/runs/{id}\", h.handleAPIRunDetail)\n   129→\th.mux.HandleFunc(\"GET /api/runs/{id}/steps/{step}/output\", h.handleAPIStepOutput)\n   130→\th.mux.HandleFunc(\"DELETE /api/runs/{id}/container\", h.handleAPIDeleteContainer)\n   131→\th.mux.HandleFunc(\"GET /api/projects/{name}/info\", h.handleAPIProjectInfo)\n   132→\th.mux.HandleFunc(\"GET /api/projects/{name}/info/prompt-diff\", h.handleAPIPromptDiff)\n   133→\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows\", h.handleAPIWorkflows)\n   134→\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows/{workflow}/steps/{step}/content\", h.handleAPIStepContent)\n   135→\th.mux.HandleFunc(\"GET /api/runs/{id}/stream\", h.handleAPIStream)\n   136→\th.mux.Handle(\"GET /static/\", http.StripPrefix(\"/static/\", http.FileServerFS(staticFS)))\n   137→\n   138→\treturn h, nil\n   139→}\n   140→\n   141→func (h *Handler) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n   142→\th.mux.ServeHTTP(w, r)\n   143→}\n   144→\n   145→// --- HTML handlers ---\n   146→\n   147→// projectOverviewEntry holds data for a single project card on the landing page.\n   148→type projectOverviewEntry struct {\n   149→\tDir         string\n   150→\tLabel       string\n   151→\tHealth      domain.HealthResult\n   152→\tRecentRuns  []recentRunDot\n   153→\tActiveCount int\n   154→}\n   155→\n   156→// recentRunDot is a minimal representation of a run for the mini history display.\n   157→type recentRunDot struct {\n   158→\tID    string\n   159→\tState string\n   160→}\n   161→\n   162→const healthWindowSize = 10\n   163→\n   164→func (h *Handler) handleProjectOverview(w http.ResponseWriter, r *http.Request) {\n   165→\tprojects, _ := h.store.ListProjects(r.Context())\n   166→\tlabels := projectLabels(projects)\n   167→\n   168→\tvar entries []projectOverviewEntry\n   169→\tfor _, dir := range projects {\n   170→\t\truns, err := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   171→\t\tif err != nil {\n   172→\t\t\tcontinue\n   173→\t\t}\n   174→\n   175→\t\t// Convert []*domain.Run to []domain.Run for CalculateHealth.\n   176→\t\trunValues := make([]domain.Run, len(runs))\n   177→\t\tfor i, rr := range runs {\n   178→\t\t\trunValues[i] = *rr\n   179→\t\t}\n   180→\n   181→\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n   182→\n   183→\t\t// Take the last N runs for the mini history (most recent first).\n   184→\t\tn := healthWindowSize\n   185→\t\tif n > len(runs) {\n   186→\t\t\tn = len(runs)\n   187→\t\t}\n   188→\t\tdots := make([]recentRunDot, n)\n   189→\t\tfor i := 0; i < n; i++ {\n   190→\t\t\tdots[i] = recentRunDot{\n   191→\t\t\t\tID:    runs[i].ID,\n   192→\t\t\t\tState: string(runs[i].State),\n   193→\t\t\t}\n   194→\t\t}\n   195→\n   196→\t\tvar activeCount int\n   197→\t\tfor _, rr := range runs {\n   198→\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n   199→\t\t\t\tactiveCount++\n   200→\t\t\t}\n   201→\t\t}\n   202→\n   203→\t\tentries = append(entries, projectOverviewEntry{\n   204→\t\t\tDir:         dir,\n   205→\t\t\tLabel:       labels[dir],\n   206→\t\t\tHealth:      health,\n   207→\t\t\tRecentRuns:  dots,\n   208→\t\t\tActiveCount: activeCount,\n   209→\t\t})\n   210→\t}\n   211→\n   212→\tsort.Slice(entries, func(i, j int) bool {\n   213→\t\treturn entries[i].Label < entries[j].Label\n   214→\t})\n   215→\n   216→\tdata := map[string]any{\n   217→\t\t\"Title\":    \"Projects\",\n   218→\t\t\"Projects\": entries,\n   219→\t}\n   220→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   221→\tif err := h.pages[\"projects\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   222→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   223→\t}\n   224→}\n   225→\n   226→func (h *Handler) handleRunsList(w http.ResponseWriter, r *http.Request) {\n   227→\tprojectFilter := r.URL.Query().Get(\"project\")\n   228→\n   229→\tvar runs []*domain.Run\n   230→\tvar err error\n   231→\tif projectFilter != \"\" {\n   232→\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n   233→\t} else {\n   234→\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n   235→\t}\n   236→\tif err != nil {\n   237→\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n   238→\t\treturn\n   239→\t}\n   240→\n   241→\tprojects, _ := h.store.ListProjects(r.Context())\n   242→\tlabels := projectLabels(projects)\n   243→\n   244→\t// Count retained containers per project\n   245→\tcontainerCounts := map[string]int{}\n   246→\tallRuns, _ := h.store.ListRuns(r.Context(), time.Time{})\n   247→\tfor _, run := range allRuns {\n   248→\t\tif run.ContainerKept {\n   249→\t\t\tcontainerCounts[run.ProjectDir]++\n   250→\t\t}\n   251→\t}\n   252→\n   253→\tvar projectList []projectEntry\n   254→\tfor _, dir := range projects {\n   255→\t\tprojectList = append(projectList, projectEntry{Dir: dir, Label: labels[dir], ContainerCount: containerCounts[dir]})\n   256→\t}\n   257→\tsort.Slice(projectList, func(i, j int) bool {\n   258→\t\treturn projectList[i].Label < projectList[j].Label\n   259→\t})\n   260→\n   261→\tdata := map[string]any{\n   262→\t\t\"Title\":         \"Runs\",\n   263→\t\t\"Runs\":          runs,\n   264→\t\t\"Projects\":      projectList,\n   265→\t\t\"ProjectFilter\": projectFilter,\n   266→\t\t\"ProjectLabels\": labels,\n   267→\t}\n   268→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   269→\tif err := h.pages[\"runs\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   270→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   271→\t}\n   272→}\n   273→\n   274→// handleProjectRuns redirects /projects/{name}/runs to /runs?project=<dir>.\n   275→func (h *Handler) handleProjectRuns(w http.ResponseWriter, r *http.Request) {\n   276→\tdir, _, ok := h.resolveProjectDir(w, r)\n   277→\tif !ok {\n   278→\t\treturn\n   279→\t}\n   280→\thttp.Redirect(w, r, \"/runs?project=\"+url.QueryEscape(dir), http.StatusFound)\n   281→}\n   282→\n   283→// stepEntry is a merged view of a step execution for the template.\n   284→type stepEntry struct {\n   285→\tIndex     int\n   286→\tStepName  string\n   287→\tResult    string\n   288→\tStartedAt time.Time\n   289→\tDuration  string\n   290→}\n   291→\n   292→// mergeCaptures collapses started/completed capture pairs into single entries.\n   293→func mergeCaptures(caps []*domain.StepExecution) []stepEntry {\n   294→\tvar entries []stepEntry\n   295→\t// Track pending started rows by step name (LIFO for retries)\n   296→\tpending := map[string]*domain.StepExecution{}\n   297→\n   298→\tfor _, c := range caps {\n   299→\t\tif c.Result == \"\" {\n   300→\t\t\t// step_started row\n   301→\t\t\tpending[c.StepName] = c\n   302→\t\t\tcontinue\n   303→\t\t}\n   304→\t\t// step_completed row — merge with pending started if available\n   305→\t\tstartedAt := c.StartedAt\n   306→\t\tif started := pending[c.StepName]; started != nil {\n   307→\t\t\tstartedAt = started.StartedAt\n   308→\t\t\tdelete(pending, c.StepName)\n   309→\t\t}\n   310→\t\tentries = append(entries, stepEntry{\n   311→\t\t\tIndex:     len(entries),\n   312→\t\t\tStepName:  c.StepName,\n   313→\t\t\tResult:    c.Result,\n   314→\t\t\tStartedAt: startedAt,\n   315→\t\t\tDuration:  formatDuration(startedAt, c.CompletedAt),\n   316→\t\t})\n   317→\t}\n   318→\n   319→\t// Append any started-but-not-completed steps (still running)\n   320→\tfor _, c := range caps {\n   321→\t\tif c.Result == \"\" {\n   322→\t\t\tif _, used := pending[c.StepName]; !used {\n   323→\t\t\t\tcontinue\n   324→\t\t\t}\n   325→\t\t\tentries = append(entries, stepEntry{\n   326→\t\t\t\tIndex:     len(entries),\n   327→\t\t\t\tStepName:  c.StepName,\n   328→\t\t\t\tStartedAt: c.StartedAt,\n   329→\t\t\t})\n   330→\t\t\tdelete(pending, c.StepName)\n   331→\t\t}\n   332→\t}\n   333→\n   334→\treturn entries\n   335→}\n   336→\n   337→// containerState inspects the container for a run and returns one of:\n   338→//   - \"running\"   – container exists and is running\n   339→//   - \"stopped\"   – container exists, not running, not kept\n   340→//   - \"available\" – container exists, not running, kept (can be deleted)\n   341→//   - \"removed\"   – no container ID, no manager, or inspect failed\n   342→func (h *Handler) containerState(ctx context.Context, run *domain.Run) string {\n   343→\tif run.ContainerID == \"\" {\n   344→\t\treturn \"removed\"\n   345→\t}\n   346→\tmgr, ok := h.container.(ContainerManager)\n   347→\tif !ok {\n   348→\t\treturn \"removed\"\n   349→\t}\n   350→\tstatus, err := mgr.Inspect(ctx, run.ContainerID)\n   351→\tif err != nil {\n   352→\t\treturn \"removed\"\n   353→\t}\n   354→\tif status.Running {\n   355→\t\treturn \"running\"\n   356→\t}\n   357→\tif run.ContainerKept {\n   358→\t\treturn \"available\"\n   359→\t}\n   360→\treturn \"stopped\"\n   361→}\n   362→\n   363→func (h *Handler) handleRunDetail(w http.ResponseWriter, r *http.Request) {\n   364→\tid := r.PathValue(\"id\")\n   365→\n   366→\trun, err := h.store.GetRun(r.Context(), id)\n   367→\tif err != nil {\n   368→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   369→\t\treturn\n   370→\t}\n   371→\n   372→\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n   373→\tif err != nil {\n   374→\t\tcaps = nil // non-fatal\n   375→\t}\n   376→\n   377→\tsteps := mergeCaptures(caps)\n   378→\n   379→\tdata := map[string]any{\n   380→\t\t\"Title\":          \"Run \" + run.ID,\n   381→\t\t\"Run\":            run,\n   382→\t\t\"Steps\":          steps,\n   383→\t\t\"Page\":           \"detail\",\n   384→\t\t\"ContainerState\": h.containerState(r.Context(), run),\n   385→\t}\n   386→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   387→\tif err := h.pages[\"run_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   388→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   389→\t}\n   390→}\n   391→\n   392→// --- JSON API handlers ---\n   393→\n   394→type apiRun struct {\n   395→\tID           string `json:\"id\"`\n   396→\tWorkflowName string `json:\"workflow_name\"`\n   397→\tProjectDir   string `json:\"project_dir\"`\n   398→\tProjectLabel string `json:\"project_label\"`\n   399→\tState        string `json:\"state\"`\n   400→\tStartedAt    string `json:\"started_at\"`\n   401→\tCompletedAt  string `json:\"completed_at\"`\n   402→\tContainerID  string `json:\"container_id\"`\n   403→\tErrorMessage string `json:\"error_message\"`\n   404→}\n   405→\n   406→type apiStep struct {\n   407→\tStepName    string `json:\"step_name\"`\n   408→\tResult      string `json:\"result\"`\n   409→\tStartedAt   string `json:\"started_at\"`\n   410→\tCompletedAt string `json:\"completed_at\"`\n   411→\tDuration    string `json:\"duration\"`\n   412→}\n   413→\n   414→type apiRunDetail struct {\n   415→\tapiRun\n   416→\tContainerState string    `json:\"container_state\"`\n   417→\tSteps          []apiStep `json:\"steps\"`\n   418→}\n   419→\n   420→func toAPIRun(r *domain.Run, labels map[string]string) apiRun {\n   421→\treturn apiRun{\n   422→\t\tID:           r.ID,\n   423→\t\tWorkflowName: r.WorkflowName,\n   424→\t\tProjectDir:   r.ProjectDir,\n   425→\t\tProjectLabel: labels[r.ProjectDir],\n   426→\t\tState:        string(r.State),\n   427→\t\tStartedAt:    formatTime(r.StartedAt),\n   428→\t\tCompletedAt:  formatTime(r.CompletedAt),\n   429→\t\tContainerID:  r.ContainerID,\n   430→\t\tErrorMessage: r.ErrorMessage,\n   431→\t}\n   432→}\n   433→\n   434→func (h *Handler) handleAPIRuns(w http.ResponseWriter, r *http.Request) {\n   435→\tprojectFilter := r.URL.Query().Get(\"project\")\n   436→\n   437→\tvar runs []*domain.Run\n   438→\tvar err error\n   439→\tif projectFilter != \"\" {\n   440→\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n   441→\t} else {\n   442→\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n   443→\t}\n   444→\tif err != nil {\n   445→\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n   446→\t\treturn\n   447→\t}\n   448→\n   449→\tprojects, _ := h.store.ListProjects(r.Context())\n   450→\tlabels := projectLabels(projects)\n   451→\n   452→\tresult := make([]apiRun, len(runs))\n   453→\tfor i, run := range runs {\n   454→\t\tresult[i] = toAPIRun(run, labels)\n   455→\t}\n   456→\n   457→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   458→\tjson.NewEncoder(w).Encode(result)\n   459→}\n   460→\n   461→func (h *Handler) handleAPIProjects(w http.ResponseWriter, r *http.Request) {\n   462→\tprojects, err := h.store.ListProjects(r.Context())\n   463→\tif err != nil {\n   464→\t\thttp.Error(w, \"failed to list projects\", http.StatusInternalServerError)\n   465→\t\treturn\n   466→\t}\n   467→\tlabels := projectLabels(projects)\n   468→\n   469→\ttype apiHealth struct {\n   470→\t\tStatus string `json:\"status\"`\n   471→\t\tPassed int    `json:\"passed\"`\n   472→\t\tFailed int    `json:\"failed\"`\n   473→\t\tTotal  int    `json:\"total\"`\n   474→\t}\n   475→\ttype apiProject struct {\n   476→\t\tDir         string    `json:\"dir\"`\n   477→\t\tLabel       string    `json:\"label\"`\n   478→\t\tHealth      apiHealth `json:\"health\"`\n   479→\t\tActiveCount int       `json:\"active_count\"`\n   480→\t}\n   481→\tresult := make([]apiProject, len(projects))\n   482→\tfor i, dir := range projects {\n   483→\t\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   484→\t\trunValues := make([]domain.Run, len(runs))\n   485→\t\tfor j, rr := range runs {\n   486→\t\t\trunValues[j] = *rr\n   487→\t\t}\n   488→\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n   489→\t\tvar activeCount int\n   490→\t\tfor _, rr := range runs {\n   491→\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n   492→\t\t\t\tactiveCount++\n   493→\t\t\t}\n   494→\t\t}\n   495→\t\tresult[i] = apiProject{\n   496→\t\t\tDir:   dir,\n   497→\t\t\tLabel: labels[dir],\n   498→\t\t\tHealth: apiHealth{\n   499→\t\t\t\tStatus: string(health.Status),\n   500→\t\t\t\tPassed: health.Passed,\n   501→\t\t\t\tFailed: health.Failed,\n   502→\t\t\t\tTotal:  health.Total,\n   503→\t\t\t},\n   504→\t\t\tActiveCount: activeCount,\n   505→\t\t}\n   506→\t}\n   507→\n   508→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   509→\tjson.NewEncoder(w).Encode(result)\n   510→}\n   511→\n   512→func (h *Handler) handleAPIRunDetail(w http.ResponseWriter, r *http.Request) {\n   513→\tid := r.PathValue(\"id\")\n   514→\n   515→\trun, err := h.store.GetRun(r.Context(), id)\n   516→\tif err != nil {\n   517→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   518→\t\treturn\n   519→\t}\n   520→\n   521→\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n   522→\tif err != nil {\n   523→\t\tcaps = nil\n   524→\t}\n   525→\n   526→\tprojects, _ := h.store.ListProjects(r.Context())\n   527→\tlabels := projectLabels(projects)\n   528→\n   529→\tmerged := mergeCaptures(caps)\n   530→\tsteps := make([]apiStep, len(merged))\n   531→\tfor i, e := range merged {\n   532→\t\tsteps[i] = apiStep{\n   533→\t\t\tStepName:  e.StepName,\n   534→\t\t\tResult:    e.Result,\n   535→\t\t\tStartedAt: formatTime(e.StartedAt),\n   536→\t\t\tDuration:  e.Duration,\n   537→\t\t}\n   538→\t}\n   539→\n   540→\tdetail := apiRunDetail{\n   541→\t\tapiRun:         toAPIRun(run, labels),\n   542→\t\tContainerState: h.containerState(r.Context(), run),\n   543→\t\tSteps:          steps,\n   544→\t}\n   545→\n   546→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   547→\tjson.NewEncoder(w).Encode(detail)\n   548→}\n   549→\n   550→func (h *Handler) handleAPIStepOutput(w http.ResponseWriter, r *http.Request) {\n   551→\tid := r.PathValue(\"id\")\n   552→\tstep := r.PathValue(\"step\")\n   553→\tlogType := r.URL.Query().Get(\"type\")   // optional: \"script\", \"llm\"\n   554→\tformat := r.URL.Query().Get(\"format\")  // optional: \"raw\" to skip parsing\n   555→\n   556→\trun, err := h.store.GetRun(r.Context(), id)\n   557→\tif err != nil {\n   558→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   559→\t\treturn\n   560→\t}\n   561→\n   562→\twriteOutput := func(data []byte) {\n   563→\t\tif format != \"raw\" {\n   564→\t\t\tdata = logstream.ParseClaudeStream(data)\n   565→\t\t}\n   566→\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   567→\t\tw.Write(data)\n   568→\t}\n   569→\n   570→\t// Try log index first for fast lookup\n   571→\tif h.logStore != nil {\n   572→\t\tlogFiles, err := h.logStore.GetLogFilesByStep(r.Context(), id, step)\n   573→\t\tif err == nil && len(logFiles) > 0 {\n   574→\t\t\t// If type filter specified, narrow results\n   575→\t\t\tfor _, lf := range logFiles {\n   576→\t\t\t\tif logType != \"\" && lf.FileType != logType {\n   577→\t\t\t\t\tcontinue\n   578→\t\t\t\t}\n   579→\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n   580→\t\t\t\tif readErr == nil && len(data) > 0 {\n   581→\t\t\t\t\twriteOutput(data)\n   582→\t\t\t\t\treturn\n   583→\t\t\t\t}\n   584→\t\t\t}\n   585→\t\t}\n   586→\t}\n   587→\n   588→\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", id, \"output\")\n   589→\n   590→\t// Fall back to file path conventions\n   591→\t// If type is \"llm\", try llm-<step>.log\n   592→\tif logType == \"llm\" {\n   593→\t\tllmPath := filepath.Join(outputDir, \"llm-\"+step+\".log\")\n   594→\t\tdata, err := os.ReadFile(llmPath)\n   595→\t\tif err == nil && len(data) > 0 {\n   596→\t\t\twriteOutput(data)\n   597→\t\t\treturn\n   598→\t\t}\n   599→\t}\n   600→\n   601→\t// Try per-step output first, fall back to container.log, then live docker logs\n   602→\toutputPath := filepath.Join(outputDir, step+\".log\")\n   603→\tdata, err := os.ReadFile(outputPath)\n   604→\tif err == nil && len(data) > 0 {\n   605→\t\twriteOutput(data)\n   606→\t\treturn\n   607→\t}\n   608→\n   609→\tcontainerLog := filepath.Join(outputDir, \"container.log\")\n   610→\tdata, err = os.ReadFile(containerLog)\n   611→\tif err == nil && len(data) > 0 {\n   612→\t\twriteOutput(data)\n   613→\t\treturn\n   614→\t}\n   615→\n   616→\t// Last resort: try live docker logs from still-existing container\n   617→\tif h.container != nil && run.ContainerID != \"\" {\n   618→\t\tif logs, logErr := h.container.Logs(r.Context(), run.ContainerID); logErr == nil && logs != \"\" {\n   619→\t\t\twriteOutput([]byte(logs))\n   620→\t\t\treturn\n   621→\t\t}\n   622→\t}\n   623→\n   624→\thttp.Error(w, \"step output not found\", http.StatusNotFound)\n   625→}\n   626→\n   627→func (h *Handler) handleAPIDeleteContainer(w http.ResponseWriter, r *http.Request) {\n   628→\tid := r.PathValue(\"id\")\n   629→\n   630→\trun, err := h.store.GetRun(r.Context(), id)\n   631→\tif err != nil {\n   632→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   633→\t\tw.WriteHeader(http.StatusNotFound)\n   634→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"run not found\"})\n   635→\t\treturn\n   636→\t}\n   637→\n   638→\tmgr, ok := h.container.(ContainerManager)\n   639→\tif !ok || run.ContainerID == \"\" {\n   640→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   641→\t\tw.WriteHeader(http.StatusBadRequest)\n   642→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"container management not available\"})\n   643→\t\treturn\n   644→\t}\n   645→\n   646→\tif err := mgr.Remove(r.Context(), run.ContainerID); err != nil {\n   647→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   648→\t\tw.WriteHeader(http.StatusInternalServerError)\n   649→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to remove container: %v\", err)})\n   650→\t\treturn\n   651→\t}\n   652→\n   653→\trun.ContainerKept = false\n   654→\tif err := h.store.UpdateRun(r.Context(), run); err != nil {\n   655→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   656→\t\tw.WriteHeader(http.StatusInternalServerError)\n   657→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to update run: %v\", err)})\n   658→\t\treturn\n   659→\t}\n   660→\n   661→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   662→\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n   663→}\n   664→\n   665→// handleAPIStream serves an SSE stream of log lines for a run.\n   666→// For active runs, it subscribes to the live broadcaster.\n   667→// For completed runs, it serves the archived full.log then closes.\n   668→func (h *Handler) handleAPIStream(w http.ResponseWriter, r *http.Request) {\n   669→\tid := r.PathValue(\"id\")\n   670→\n   671→\trun, err := h.store.GetRun(r.Context(), id)\n   672→\tif err != nil {\n   673→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   674→\t\treturn\n   675→\t}\n   676→\n   677→\tflusher, ok := w.(http.Flusher)\n   678→\tif !ok {\n   679→\t\thttp.Error(w, \"streaming not supported\", http.StatusInternalServerError)\n   680→\t\treturn\n   681→\t}\n   682→\n   683→\tw.Header().Set(\"Content-Type\", \"text/event-stream\")\n   684→\tw.Header().Set(\"Cache-Control\", \"no-cache\")\n   685→\tw.Header().Set(\"Connection\", \"keep-alive\")\n   686→\tw.Header().Set(\"X-Accel-Buffering\", \"no\")\n   687→\n   688→\tisComplete := run.State == domain.RunStateSucceeded ||\n   689→\t\trun.State == domain.RunStateFailed ||\n   690→\t\trun.State == domain.RunStateCancelled\n   691→\n   692→\tif isComplete {\n   693→\t\t// Serve archived full.log\n   694→\t\th.streamFullLog(w, flusher, run)\n   695→\t\t// Send done event\n   696→\t\tfmt.Fprintf(w, \"event: done\\ndata: %s\\n\\n\", string(run.State))\n   697→\t\tflusher.Flush()\n   698→\t\treturn\n   699→\t}\n   700→\n   701→\t// Active run: subscribe to live broadcaster\n   702→\tif h.logBroadcast == nil {\n   703→\t\thttp.Error(w, \"log streaming not available\", http.StatusServiceUnavailable)\n   704→\t\treturn\n   705→\t}\n   706→\n   707→\tsub := h.logBroadcast.Subscribe(id)\n   708→\tdefer h.logBroadcast.Unsubscribe(id, sub)\n   709→\n   710→\tctx := r.Context()\n   711→\tfor {\n   712→\t\tselect {\n   713→\t\tcase <-ctx.Done():\n   714→\t\t\treturn\n   715→\t\tcase line, ok := <-sub.C:\n   716→\t\t\tif !ok {\n   717→\t\t\t\t// Stream finished (run completed)\n   718→\t\t\t\tfmt.Fprintf(w, \"event: done\\ndata: completed\\n\\n\")\n   719→\t\t\t\tflusher.Flush()\n   720→\t\t\t\treturn\n   721→\t\t\t}\n   722→\t\t\tline = parseLLMLogLine(line)\n   723→\t\t\tif line.Type == \"\" {\n   724→\t\t\t\tcontinue // skip protocol-only llm lines\n   725→\t\t\t}\n   726→\t\t\tdata, _ := json.Marshal(line)\n   727→\t\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n   728→\t\t\tflusher.Flush()\n   729→\t\t}\n   730→\t}\n   731→}\n   732→\n   733→// logLineRegex parses \"[timestamp] [type] content\" format from full.log.\n   734→var logLineRegex = regexp.MustCompile(`^\\[([^\\]]+)\\] \\[([^\\]]+)\\] (.*)$`)\n   735→\n   736→// streamFullLog reads the archived full.log file and sends its entries as SSE events.\n   737→// LLM-type lines are parsed from raw Claude JSON into human-readable text.\n   738→func (h *Handler) streamFullLog(w http.ResponseWriter, flusher http.Flusher, run *domain.Run) {\n   739→\tlogPath := filepath.Join(run.ProjectDir, \".cloche\", run.ID, \"output\", \"full.log\")\n   740→\tf, err := os.Open(logPath)\n   741→\tif err != nil {\n   742→\t\treturn\n   743→\t}\n   744→\tdefer f.Close()\n   745→\n   746→\tscanner := bufio.NewScanner(f)\n   747→\tfor scanner.Scan() {\n   748→\t\ttext := scanner.Text()\n   749→\t\tline := parseFullLogLine(text)\n   750→\t\tline = parseLLMLogLine(line)\n   751→\t\tif line.Type == \"\" {\n   752→\t\t\tcontinue // skip protocol-only llm lines\n   753→\t\t}\n   754→\t\tdata, _ := json.Marshal(line)\n   755→\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n   756→\t\tflusher.Flush()\n   757→\t}\n   758→}\n   759→\n   760→// parseLLMLogLine parses a LogLine whose type is \"llm\". If the content is\n   761→// Claude stream JSON, it extracts the human-readable text. Protocol-only\n   762→// events return a LogLine with an empty Type (caller should skip it).\n   763→// Non-llm lines are returned unchanged.\n   764→func parseLLMLogLine(line logstream.LogLine) logstream.LogLine {\n   765→\tif line.Type != \"llm\" {\n   766→\t\treturn line\n   767→\t}\n   768→\ttext, ok := logstream.ParseClaudeLine([]byte(line.Content))\n   769→\tif !ok {\n   770→\t\treturn logstream.LogLine{} // signal to skip\n   771→\t}\n   772→\tline.Content = text\n   773→\treturn line\n   774→}\n   775→\n   776→// parseFullLogLine parses a \"[timestamp] [type] content\" line into a LogLine.\n   777→func parseFullLogLine(text string) logstream.LogLine {\n   778→\tm := logLineRegex.FindStringSubmatch(text)\n   779→\tif m == nil {\n   780→\t\treturn logstream.LogLine{\n   781→\t\t\tTimestamp: time.Now().UTC().Format(time.RFC3339),\n   782→\t\t\tType:      \"script\",\n   783→\t\t\tContent:   text,\n   784→\t\t}\n   785→\t}\n   786→\treturn logstream.LogLine{\n   787→\t\tTimestamp: m[1],\n   788→\t\tType:      m[2],\n   789→\t\tContent:   m[3],\n   790→\t}\n   791→}\n   792→\n   793→// --- Project detail handlers ---\n   794→\n   795→// resolveProjectDir resolves a project label from the URL to its directory path.\n   796→// Returns (dir, label, ok). Writes a JSON error response if not found.\n   797→func (h *Handler) resolveProjectDir(w http.ResponseWriter, r *http.Request) (string, string, bool) {\n   798→\tlabel := r.PathValue(\"name\")\n   799→\tprojects, _ := h.store.ListProjects(r.Context())\n   800→\tlabels := projectLabels(projects)\n   801→\tfor dir, l := range labels {\n   802→\t\tif l == label {\n   803→\t\t\treturn dir, label, true\n   804→\t\t}\n   805→\t}\n   806→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   807→\tw.WriteHeader(http.StatusNotFound)\n   808→\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"project not found\"})\n   809→\treturn \"\", \"\", false\n   810→}\n   811→\n   812→func (h *Handler) handleProjectDetail(w http.ResponseWriter, r *http.Request) {\n   813→\tdir, label, ok := h.resolveProjectDir(w, r)\n   814→\tif !ok {\n   815→\t\treturn\n   816→\t}\n   817→\n   818→\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   819→\tn := 10\n   820→\tif n > len(runs) {\n   821→\t\tn = len(runs)\n   822→\t}\n   823→\tdots := make([]recentRunDot, n)\n   824→\tfor i := 0; i < n; i++ {\n   825→\t\tdots[i] = recentRunDot{ID: runs[i].ID, State: string(runs[i].State)}\n   826→\t}\n   827→\n   828→\tdata := map[string]any{\n   829→\t\t\"Title\":      label,\n   830→\t\t\"Label\":      label,\n   831→\t\t\"Dir\":        dir,\n   832→\t\t\"RecentRuns\": dots,\n   833→\t}\n   834→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   835→\tif err := h.pages[\"project_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   836→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   837→\t}\n   838→}\n   839→\n   840→func (h *Handler) handleAPIProjectInfo(w http.ResponseWriter, r *http.Request) {\n   841→\tdir, _, ok := h.resolveProjectDir(w, r)\n   842→\tif !ok {\n   843→\t\treturn\n   844→\t}\n   845→\n   846→\t// Docker image: read FROM line from Dockerfile\n   847→\tdockerImage := \"\"\n   848→\tdockerfilePath := filepath.Join(dir, \".cloche\", \"Dockerfile\")\n   849→\tif data, err := os.ReadFile(dockerfilePath); err == nil {\n   850→\t\t// Find the last FROM line (final stage)\n   851→\t\tfor _, line := range strings.Split(string(data), \"\\n\") {\n   852→\t\t\ttrimmed := strings.TrimSpace(line)\n   853→\t\t\tif strings.HasPrefix(strings.ToUpper(trimmed), \"FROM \") {\n   854→\t\t\t\tparts := strings.Fields(trimmed)\n   855→\t\t\t\tif len(parts) >= 2 {\n   856→\t\t\t\t\tdockerImage = parts[1]\n   857→\t\t\t\t}\n   858→\t\t\t}\n   859→\t\t}\n   860→\t}\n   861→\n   862→\t// Version\n   863→\tversion := 0\n   864→\tversionPath := filepath.Join(dir, \".cloche\", \"version\")\n   865→\tif data, err := os.ReadFile(versionPath); err == nil {\n   866→\t\tif v, err := strconv.Atoi(strings.TrimSpace(string(data))); err == nil {\n   867→\t\t\tversion = v\n   868→\t\t}\n   869→\t}\n   870→\n   871→\t// Prompt files history\n   872→\ttype commitEntry struct {\n   873→\t\tSHA     string `json:\"sha\"`\n   874→\t\tDate    string `json:\"date\"`\n   875→\t\tMessage string `json:\"message\"`\n   876→\t}\n   877→\ttype promptFile struct {\n   878→\t\tPath    string        `json:\"path\"`\n   879→\t\tHistory []commitEntry `json:\"history\"`\n   880→\t}\n   881→\n   882→\tvar promptFiles []promptFile\n   883→\tpromptsDir := filepath.Join(dir, \".cloche\", \"prompts\")\n   884→\tif entries, err := os.ReadDir(promptsDir); err == nil {\n   885→\t\tfor _, e := range entries {\n   886→\t\t\tif e.IsDir() {\n   887→\t\t\t\tcontinue\n   888→\t\t\t}\n   889→\t\t\trelPath := filepath.Join(\".cloche\", \"prompts\", e.Name())\n   890→\t\t\tcmd := exec.Command(\"git\", \"log\", \"--follow\", \"--format=%H %aI %s\", \"--\", relPath)\n   891→\t\t\tcmd.Dir = dir\n   892→\t\t\tout, err := cmd.Output()\n   893→\t\t\tif err != nil {\n   894→\t\t\t\tcontinue\n   895→\t\t\t}\n   896→\t\t\tvar history []commitEntry\n   897→\t\t\tfor _, line := range strings.Split(strings.TrimSpace(string(out)), \"\\n\") {\n   898→\t\t\t\tif line == \"\" {\n   899→\t\t\t\t\tcontinue\n   900→\t\t\t\t}\n   901→\t\t\t\tparts := strings.SplitN(line, \" \", 3)\n   902→\t\t\t\tif len(parts) < 3 {\n   903→\t\t\t\t\tcontinue\n   904→\t\t\t\t}\n   905→\t\t\t\t// Parse date to short form\n   906→\t\t\t\tdateStr := parts[1]\n   907→\t\t\t\tif t, err := time.Parse(time.RFC3339, dateStr); err == nil {\n   908→\t\t\t\t\tdateStr = t.Format(\"2006-01-02\")\n   909→\t\t\t\t}\n   910→\t\t\t\thistory = append(history, commitEntry{\n   911→\t\t\t\t\tSHA:     parts[0][:7],\n   912→\t\t\t\t\tDate:    dateStr,\n   913→\t\t\t\t\tMessage: parts[2],\n   914→\t\t\t\t})\n   915→\t\t\t}\n   916→\t\t\tpromptFiles = append(promptFiles, promptFile{Path: relPath, History: history})\n   917→\t\t}\n   918→\t}\n   919→\n   920→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   921→\tjson.NewEncoder(w).Encode(map[string]any{\n   922→\t\t\"docker_image\": dockerImage,\n   923→\t\t\"version\":      version,\n   924→\t\t\"prompt_files\": promptFiles,\n   925→\t})\n   926→}\n   927→\n   928→func (h *Handler) handleAPIPromptDiff(w http.ResponseWriter, r *http.Request) {\n   929→\tdir, _, ok := h.resolveProjectDir(w, r)\n   930→\tif !ok {\n   931→\t\treturn\n   932→\t}\n   933→\tfile := r.URL.Query().Get(\"file\")\n   934→\tsha := r.URL.Query().Get(\"sha\")\n   935→\tif file == \"\" || sha == \"\" {\n   936→\t\thttp.Error(w, \"file and sha required\", http.StatusBadRequest)\n   937→\t\treturn\n   938→\t}\n   939→\n   940→\t// Validate sha is alphanumeric to prevent injection\n   941→\tfor _, c := range sha {\n   942→\t\tif !((c >= '0' && c <= '9') || (c >= 'a' && c <= 'f') || (c >= 'A' && c <= 'F')) {\n   943→\t\t\thttp.Error(w, \"invalid sha\", http.StatusBadRequest)\n   944→\t\t\treturn\n   945→\t\t}\n   946→\t}\n   947→\n   948→\tcmd := exec.Command(\"git\", \"diff\", sha+\"^..\"+sha, \"--\", file)\n   949→\tcmd.Dir = dir\n   950→\tout, err := cmd.Output()\n   951→\tif err != nil {\n   952→\t\thttp.Error(w, \"diff not available\", http.StatusNotFound)\n   953→\t\treturn\n   954→\t}\n   955→\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   956→\tw.Write(out)\n   957→}\n   958→\n   959→func (h *Handler) handleAPIWorkflows(w http.ResponseWriter, r *http.Request) {\n   960→\tdir, _, ok := h.resolveProjectDir(w, r)\n   961→\tif !ok {\n   962→\t\treturn\n   963→\t}\n   964→\n   965→\tclocheDir := filepath.Join(dir, \".cloche\")\n   966→\tentries, err := os.ReadDir(clocheDir)\n   967→\tif err != nil {\n   968→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   969→\t\tjson.NewEncoder(w).Encode([]any{})\n   970→\t\treturn\n   971→\t}\n   972→\n   973→\ttype apiWire struct {\n   974→\t\tFrom   string `json:\"from\"`\n   975→\t\tResult string `json:\"result\"`\n   976→\t\tTo     string `json:\"to\"`\n   977→\t}\n   978→\ttype apiStepDef struct {\n   979→\t\tName    string            `json:\"name\"`\n   980→\t\tType    string            `json:\"type\"`\n   981→\t\tResults []string          `json:\"results\"`\n   982→\t\tConfig  map[string]string `json:\"config\"`\n   983→\t}\n   984→\ttype apiWorkflow struct {\n   985→\t\tName      string       `json:\"name\"`\n   986→\t\tFile      string       `json:\"file\"`\n   987→\t\tSteps     []apiStepDef `json:\"steps\"`\n   988→\t\tWires     []apiWire    `json:\"wires\"`\n   989→\t\tEntryStep string       `json:\"entry_step\"`\n   990→\t}\n   991→\n   992→\tvar workflows []apiWorkflow\n   993→\tfor _, e := range entries {\n   994→\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n   995→\t\t\tcontinue\n   996→\t\t}\n   997→\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n   998→\t\tif err != nil {\n   999→\t\t\tcontinue\n  1000→\t\t}\n  1001→\t\twf, err := dsl.ParseForContainer(string(data))\n  1002→\t\tif err != nil {\n  1003→\t\t\tcontinue\n  1004→\t\t}\n  1005→\t\tvar steps []apiStepDef\n  1006→\t\tfor _, s := range wf.Steps {\n  1007→\t\t\tsteps = append(steps, apiStepDef{\n  1008→\t\t\t\tName:    s.Name,\n  1009→\t\t\t\tType:    string(s.Type),\n  1010→\t\t\t\tResults: s.Results,\n  1011→\t\t\t\tConfig:  s.Config,\n  1012→\t\t\t})\n  1013→\t\t}\n  1014→\t\t// Sort steps by name for consistent ordering\n  1015→\t\tsort.Slice(steps, func(i, j int) bool { return steps[i].Name < steps[j].Name })\n  1016→\n  1017→\t\tvar wires []apiWire\n  1018→\t\tfor _, wire := range wf.Wiring {\n  1019→\t\t\twires = append(wires, apiWire{From: wire.From, Result: wire.Result, To: wire.To})\n  1020→\t\t}\n  1021→\n  1022→\t\tworkflows = append(workflows, apiWorkflow{\n  1023→\t\t\tName:      wf.Name,\n  1024→\t\t\tFile:      filepath.Join(\".cloche\", e.Name()),\n  1025→\t\t\tSteps:     steps,\n  1026→\t\t\tWires:     wires,\n  1027→\t\t\tEntryStep: wf.EntryStep,\n  1028→\t\t})\n  1029→\t}\n  1030→\n  1031→\tw.Header().Set(\"Content-Type\", \"application/json\")\n  1032→\tjson.NewEncoder(w).Encode(workflows)\n  1033→}\n  1034→\n  1035→func (h *Handler) handleAPIStepContent(w http.ResponseWriter, r *http.Request) {\n  1036→\tdir, _, ok := h.resolveProjectDir(w, r)\n  1037→\tif !ok {\n  1038→\t\treturn\n  1039→\t}\n  1040→\tworkflowName := r.PathValue(\"workflow\")\n  1041→\tstepName := r.PathValue(\"step\")\n  1042→\n  1043→\t// Find the workflow file\n  1044→\tclocheDir := filepath.Join(dir, \".cloche\")\n  1045→\tvar wf *domain.Workflow\n  1046→\tentries, _ := os.ReadDir(clocheDir)\n  1047→\tfor _, e := range entries {\n  1048→\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n  1049→\t\t\tcontinue\n  1050→\t\t}\n  1051→\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n  1052→\t\tif err != nil {\n  1053→\t\t\tcontinue\n  1054→\t\t}\n  1055→\t\tparsed, err := dsl.ParseForContainer(string(data))\n  1056→\t\tif err != nil {\n  1057→\t\t\tcontinue\n  1058→\t\t}\n  1059→\t\tif parsed.Name == workflowName {\n  1060→\t\t\twf = parsed\n  1061→\t\t\tbreak\n  1062→\t\t}\n  1063→\t}\n  1064→\tif wf == nil {\n  1065→\t\thttp.Error(w, \"workflow not found\", http.StatusNotFound)\n  1066→\t\treturn\n  1067→\t}\n  1068→\n  1069→\tstep, ok := wf.Steps[stepName]\n  1070→\tif !ok {\n  1071→\t\thttp.Error(w, \"step not found\", http.StatusNotFound)\n  1072→\t\treturn\n  1073→\t}\n  1074→\n  1075→\t// Try to read the referenced file from step config\n  1076→\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n  1077→\n  1078→\tif prompt := step.Config[\"prompt\"]; prompt != \"\" {\n  1079→\t\tcontent, err := resolveFileRef(prompt, dir)\n  1080→\t\tif err == nil {\n  1081→\t\t\tw.Write([]byte(content))\n  1082→\t\t\treturn\n  1083→\t\t}\n  1084→\t}\n  1085→\tif cmd := step.Config[\"command\"]; cmd != \"\" {\n  1086→\t\tcontent, _ := resolveFileRef(cmd, dir)\n  1087→\t\tw.Write([]byte(content))\n  1088→\t\treturn\n  1089→\t}\n  1090→\tif script := step.Config[\"script\"]; script != \"\" {\n  1091→\t\tcontent, _ := resolveFileRef(script, dir)\n  1092→\t\tw.Write([]byte(content))\n  1093→\t\treturn\n  1094→\t}\n  1095→\n  1096→\thttp.Error(w, \"no content available\", http.StatusNotFound)\n  1097→}\n  1098→\n  1099→// --- Template helpers ---\n  1100→\n  1101→// resolveFileRef resolves file(\"path\") DSL syntax to actual file contents.\n  1102→// If the value uses file() syntax, the referenced file is read from disk.\n  1103→// Otherwise the value is returned as-is.\n  1104→func resolveFileRef(value, baseDir string) (string, error) {\n  1105→\tif strings.HasPrefix(value, `file(\"`) && strings.HasSuffix(value, `\")`) {\n  1106→\t\tpath := value[6 : len(value)-2]\n  1107→\t\tdata, err := os.ReadFile(filepath.Join(baseDir, path))\n  1108→\t\tif err != nil {\n  1109→\t\t\treturn \"\", err\n  1110→\t\t}\n  1111→\t\treturn string(data), nil\n  1112→\t}\n  1113→\treturn value, nil\n  1114→}\n  1115→\n  1116→func stateColor(state domain.RunState) string {\n  1117→\tswitch state {\n  1118→\tcase domain.RunStatePending:\n  1119→\t\treturn \"pending\"\n  1120→\tcase domain.RunStateRunning:\n  1121→\t\treturn \"running\"\n  1122→\tcase domain.RunStateSucceeded:\n  1123→\t\treturn \"succeeded\"\n  1124→\tcase domain.RunStateFailed:\n  1125→\t\treturn \"failed\"\n  1126→\tcase domain.RunStateCancelled:\n  1127→\t\treturn \"cancelled\"\n  1128→\tdefault:\n  1129→\t\treturn \"pending\"\n  1130→\t}\n  1131→}\n  1132→\n  1133→func healthColor(status domain.HealthStatus) string {\n  1134→\tswitch status {\n  1135→\tcase domain.HealthGreen:\n  1136→\t\treturn \"green\"\n  1137→\tcase domain.HealthYellow:\n  1138→\t\treturn \"yellow\"\n  1139→\tcase domain.HealthRed:\n  1140→\t\treturn \"red\"\n  1141→\tcase domain.HealthBlue:\n  1142→\t\treturn \"blue\"\n  1143→\tdefault:\n  1144→\t\treturn \"grey\"\n  1145→\t}\n  1146→}\n  1147→\n  1148→func formatTime(t time.Time) string {\n  1149→\tif t.IsZero() {\n  1150→\t\treturn \"\"\n  1151→\t}\n  1152→\treturn t.Format(\"2006-01-02 15:04:05\")\n  1153→}\n  1154→\n  1155→func formatDuration(start, end time.Time) string {\n  1156→\tif start.IsZero() || end.IsZero() {\n  1157→\t\treturn \"\"\n  1158→\t}\n  1159→\td := end.Sub(start)\n  1160→\tif d < time.Second {\n  1161→\t\treturn fmt.Sprintf(\"%dms\", d.Milliseconds())\n  1162→\t}\n  1163→\tif d < time.Minute {\n  1164→\t\treturn fmt.Sprintf(\"%.1fs\", d.Seconds())\n  1165→\t}\n  1166→\treturn fmt.Sprintf(\"%dm%ds\", int(d.Minutes()), int(d.Seconds())%60)\n  1167→}\n  1168→\n  1169→func truncate(s string, n int) string {\n  1170→\tif len(s) <= n {\n  1171→\t\treturn s\n  1172→\t}\n  1173→\treturn s[:n] + \"...\"\n  1174→}\n  1175→\n  1176→func shortContainerID(id string) string {\n  1177→\tif len(id) > 12 {\n  1178→\t\treturn id[:12]\n  1179→\t}\n  1180→\treturn id\n  1181→}\n  1182→\n  1183→// projectLabels builds a mapping from full project directory paths to short\n  1184→// display labels. Each label is the final directory component (e.g.\n  1185→// \"myproject\" from \"/home/user/workspace/myproject\"). When two projects share\n  1186→// the same final name, the parent directory is prepended to disambiguate\n  1187→// (e.g. \"foo/bar\" vs \"baz/bar\").\n  1188→func projectLabels(dirs []string) map[string]string {\n  1189→\tlabels := make(map[string]string, len(dirs))\n  1190→\t// Group dirs by their base name to detect conflicts.\n  1191→\tbyBase := map[string][]string{}\n  1192→\tfor _, d := range dirs {\n  1193→\t\tbase := filepath.Base(d)\n  1194→\t\tbyBase[base] = append(byBase[base], d)\n  1195→\t}\n  1196→\tfor base, paths := range byBase {\n  1197→\t\tif len(paths) == 1 {\n  1198→\t\t\tlabels[paths[0]] = base\n  1199→\t\t} else {\n  1200→\t\t\tfor _, p := range paths {\n  1201→\t\t\t\tparent := filepath.Base(filepath.Dir(p))\n  1202→\t\t\t\tlabels[p] = parent + \"/\" + base\n  1203→\t\t\t}\n  1204→\t\t}\n  1205→\t}\n  1206→\treturn labels\n  1207→}\n  1208→\n  1209→type projectEntry struct {\n  1210→\tDir            string\n  1211→\tLabel          string\n  1212→\tContainerCount int\n  1213→}\n  1214→"}]},"parent_tool_use_id":"toolu_01KxSmpApK5xnCTuSmWZ7Zh8","session_id":"b2566a3c-e8d8-43a6-bf93-08a9f5a6e841","uuid":"a876a9e4-ff57-4535-bc47-2f9bb29e44e3"}
