 for full.log first — if it exists, serve it as the unified log\n   452→\tfullLogPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", \"full.log\")\n   453→\tif data, readErr := os.ReadFile(fullLogPath); readErr == nil && len(data) > 0 {\n   454→\t\tif err := stream.Send(&pb.LogEntry{\n   455→\t\t\tType:    \"full_log\",\n   456→\t\t\tMessage: string(data),\n   457→\t\t}); err != nil {\n   458→\t\t\treturn err\n   459→\t\t}\n   460→\t\t// Still send run completion entry\n   461→\t\tif run.State != domain.RunStateRunning && run.State != domain.RunStatePending {\n   462→\t\t\tif err := stream.Send(&pb.LogEntry{\n   463→\t\t\t\tType:      \"run_completed\",\n   464→\t\t\t\tResult:    string(run.State),\n   465→\t\t\t\tTimestamp: run.CompletedAt.String(),\n   466→\t\t\t\tMessage:   run.ErrorMessage,\n   467→\t\t\t}); err != nil {\n   468→\t\t\t\treturn err\n   469→\t\t\t}\n   470→\t\t}\n   471→\t\treturn nil\n   472→\t}\n   473→\n   474→\t// Fall back to capture-based streaming\n   475→\tcaptures, err := s.captures.GetCaptures(ctx, req.RunId)\n   476→\tif err != nil {\n   477→\t\treturn fmt.Errorf(\"getting captures: %w\", err)\n   478→\t}\n   479→\n   480→\tfor _, exec := range captures {\n   481→\t\t// Captures are stored as separate rows: one for step_started (no Result)\n   482→\t\t// and one for step_completed (has Result).\n   483→\t\tif exec.Result == \"\" {\n   484→\t\t\tentry := &pb.LogEntry{\n   485→\t\t\t\tType:      \"step_started\",\n   486→\t\t\t\tStepName:  exec.StepName,\n   487→\t\t\t\tTimestamp: exec.StartedAt.String(),\n   488→\t\t\t}\n   489→\t\t\tif err := stream.Send(entry); err != nil {\n   490→\t\t\t\treturn err\n   491→\t\t\t}\n   492→\t\t} else {\n   493→\t\t\t// Read step output from file, falling back to container.log\n   494→\t\t\tvar output string\n   495→\t\t\toutputPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", exec.StepName+\".log\")\n   496→\t\t\tif data, err := os.ReadFile(outputPath); err == nil && len(data) > 0 {\n   497→\t\t\t\toutput = string(data)\n   498→\t\t\t} else {\n   499→\t\t\t\tcontainerLogPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", \"container.log\")\n   500→\t\t\t\tif data, err := os.ReadFile(containerLogPath); err == nil {\n   501→\t\t\t\t\toutput = string(data)\n   502→\t\t\t\t}\n   503→\t\t\t}\n   504→\t\t\tentry := &pb.LogEntry{\n   505→\t\t\t\tType:      \"step_completed\",\n   506→\t\t\t\tStepName:  exec.StepName,\n   507→\t\t\t\tResult:    exec.Result,\n   508→\t\t\t\tTimestamp: exec.CompletedAt.String(),\n   509→\t\t\t\tMessage:   output,\n   510→\t\t\t}\n   511→\t\t\tif err := stream.Send(entry); err != nil {\n   512→\t\t\t\treturn err\n   513→\t\t\t}\n   514→\t\t}\n   515→\t}\n   516→\n   517→\t// Send run completion entry\n   518→\tif run.State != domain.RunStateRunning && run.State != domain.RunStatePending {\n   519→\t\tif err := stream.Send(&pb.LogEntry{\n   520→\t\t\tType:      \"run_completed\",\n   521→\t\t\tResult:    string(run.State),\n   522→\t\t\tTimestamp: run.CompletedAt.String(),\n   523→\t\t\tMessage:   run.ErrorMessage,\n   524→\t\t}); err != nil {\n   525→\t\t\treturn err\n   526→\t\t}\n   527→\t}\n   528→\n   529→\treturn nil\n   530→}\n   531→\n   532→// streamFilteredLogs serves log content filtered by step name and/or log type.\n   533→// It uses the log index when available, falling back to file path conventions.\n   534→func (s *ClocheServer) streamFilteredLogs(ctx context.Context, req *pb.StreamLogsRequest, run *domain.Run, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n   535→\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\")\n   536→\n   537→\t// Try log index first\n   538→\tif s.logStore != nil {\n   539→\t\tvar logFiles []*ports.LogFileEntry\n   540→\t\tvar err error\n   541→\n   542→\t\tif req.StepName != \"\" && req.LogType != \"\" {\n   543→\t\t\t// Filter by both step and type\n   544→\t\t\tlogFiles, err = s.logStore.GetLogFilesByStep(ctx, req.RunId, req.StepName)\n   545→\t\t\tif err == nil {\n   546→\t\t\t\tfiltered := logFiles[:0]\n   547→\t\t\t\tfor _, lf := range logFiles {\n   548→\t\t\t\t\tif lf.FileType == req.LogType {\n   549→\t\t\t\t\t\tfiltered = append(filtered, lf)"}]},"parent_tool_use_id":"toolu_01KxSmpApK5xnCTuSmWZ7Zh8","session_id":"b2566a3c-e8d8-43a6-bf93-08a9f5a6e841","uuid":"9574129d-31eb-4416-964f-77c1fff018b5"}
