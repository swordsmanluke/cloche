[2026-03-10T00:24:05Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01M6eKPxikQomKzWYVtDUBis","type":"tool_result","content":"     1→package domain\n     2→\n     3→// HealthStatus represents the overall health of a project based on recent runs.\n     4→type HealthStatus string\n     5→\n     6→const (\n     7→\tHealthGreen  HealthStatus = \"green\"\n     8→\tHealthYellow HealthStatus = \"yellow\"\n     9→\tHealthRed    HealthStatus = \"red\"\n    10→\tHealthGrey   HealthStatus = \"grey\"\n    11→\tHealthBlue   HealthStatus = \"blue\"\n    12→)\n    13→\n    14→// HealthResult holds the computed health status along with pass/fail counts.\n    15→type HealthResult struct {\n    16→\tStatus HealthStatus\n    17→\tPassed int\n    18→\tFailed int\n    19→\tTotal  int\n    20→}\n    21→\n    22→// CalculateHealth determines project health from the most recent runs.\n    23→// It considers the last windowSize runs (or fewer if not enough exist).\n    24→//\n    25→// Status rules:\n    26→//   - Grey: no runs provided\n    27→//   - Blue: all runs in the window are still in-progress (pending/running)\n    28→//   - Green: all completed runs passed (succeeded)\n    29→//   - Red: all completed runs failed (failed/cancelled)\n    30→//   - Yellow: mix of passed and failed completed runs\n    31→func CalculateHealth(runs []Run, windowSize int) HealthResult {\n    32→\tif len(runs) == 0 {\n    33→\t\treturn HealthResult{Status: HealthGrey}\n    34→\t}\n    35→\n    36→\tn := windowSize\n    37→\tif n > len(runs) {\n    38→\t\tn = len(runs)\n    39→\t}\n    40→\n    41→\t// Take the most recent n runs (assumes runs are ordered most-recent first).\n    42→\twindow := runs[:n]\n    43→\n    44→\tvar passed, failed int\n    45→\tfor _, r := range window {\n    46→\t\tswitch r.State {\n    47→\t\tcase RunStateSucceeded:\n    48→\t\t\tpassed++\n    49→\t\tcase RunStateFailed, RunStateCancelled:\n    50→\t\t\tfailed++\n    51→\t\t// pending, running — neither passed nor failed\n    52→\t\t}\n    53→\t}\n    54→\n    55→\ttotal := len(window)\n    56→\tcompleted := passed + failed\n    57→\n    58→\tvar status HealthStatus\n    59→\tswitch {\n    60→\tcase completed == 0:\n    61→\t\tstatus = HealthBlue\n    62→\tcase failed == 0:\n    63→\t\tstatus = HealthGreen\n    64→\tcase passed == 0:\n    65→\t\tstatus = HealthRed\n    66→\tdefault:\n    67→\t\tstatus = HealthYellow\n    68→\t}\n    69→\n    70→\treturn HealthResult{\n    71→\t\tStatus: status,\n    72→\t\tPassed: passed,\n    73→\t\tFailed: failed,\n    74→\t\tTotal:  total,\n    75→\t}\n    76→}\n    77→"}]},"parent_tool_use_id":"toolu_01KxSmpApK5xnCTuSmWZ7Zh8","session_id":"b2566a3c-e8d8-43a6-bf93-08a9f5a6e841","uuid":"b6d2cb08-a207-494b-b348-3c31973458c4"}
