{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CzkAfEwuYPksPb732me47v","type":"tool_result","content":"     1в†’package main\n     2в†’\n     3в†’import (\n     4в†’\t\"bufio\"\n     5в†’\t\"context\"\n     6в†’\t\"encoding/json\"\n     7в†’\t\"errors\"\n     8в†’\t\"fmt\"\n     9в†’\t\"io\"\n    10в†’\t\"net/http\"\n    11в†’\t\"os\"\n    12в†’\t\"path/filepath\"\n    13в†’\t\"strings\"\n    14в†’\t\"time\"\n    15в†’\n    16в†’\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    17в†’\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    18в†’\t\"google.golang.org/grpc\"\n    19в†’\t\"google.golang.org/grpc/credentials/insecure\"\n    20в†’)\n    21в†’\n    22в†’func main() {\n    23в†’\tif len(os.Args) < 2 {\n    24в†’\t\tusage()\n    25в†’\t\tos.Exit(1)\n    26в†’\t}\n    27в†’\n    28в†’\t// Commands that don't need a daemon connection\n    29в†’\tswitch os.Args[1] {\n    30в†’\tcase \"init\":\n    31в†’\t\tcmdInit(os.Args[2:])\n    32в†’\t\treturn\n    33в†’\tcase \"health\":\n    34в†’\t\tcmdHealth(os.Args[2:])\n    35в†’\t\treturn\n    36в†’\t}\n    37в†’\n    38в†’\t// Commands that need a daemon connection\n    39в†’\taddr := os.Getenv(\"CLOCHE_ADDR\")\n    40в†’\tif addr == \"\" {\n    41в†’\t\taddr = \"unix:///tmp/cloche.sock\"\n    42в†’\t}\n    43в†’\n    44в†’\tconn, err := grpc.NewClient(addr, grpc.WithTransportCredentials(insecure.NewCredentials()))\n    45в†’\tif err != nil {\n    46в†’\t\tfmt.Fprintf(os.Stderr, \"failed to connect: %v\\n\", err)\n    47в†’\t\tos.Exit(1)\n    48в†’\t}\n    49в†’\tdefer conn.Close()\n    50в†’\n    51в†’\tclient := pb.NewClocheServiceClient(conn)\n    52в†’\tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n    53в†’\tdefer cancel()\n    54в†’\n    55в†’\tswitch os.Args[1] {\n    56в†’\tcase \"run\":\n    57в†’\t\tcmdRun(ctx, client, os.Args[2:])\n    58в†’\tcase \"status\":\n    59в†’\t\tcmdStatus(ctx, client, os.Args[2:])\n    60в†’\tcase \"logs\":\n    61в†’\t\tcmdLogs(client, os.Args[2:])\n    62в†’\tcase \"poll\":\n    63в†’\t\tcmdPoll(client, os.Args[2:])\n    64в†’\tcase \"list\":\n    65в†’\t\tcmdList(ctx, client, os.Args[2:])\n    66в†’\tcase \"stop\":\n    67в†’\t\tcmdStop(ctx, client, os.Args[2:])\n    68в†’\tcase \"delete\":\n    69в†’\t\tcmdDelete(ctx, client, os.Args[2:])\n    70в†’\tcase \"orchestrate\":\n    71в†’\t\tcmdOrchestrate(ctx, client)\n    72в†’\tcase \"shutdown\":\n    73в†’\t\tcmdShutdown(ctx, client)\n    74в†’\tdefault:\n    75в†’\t\tusage()\n    76в†’\t\tos.Exit(1)\n    77в†’\t}\n    78в†’}\n    79в†’\n    80в†’func usage() {\n    81в†’\tfmt.Fprintf(os.Stderr, `usage: cloche <command> [args]\n    82в†’\n    83в†’Commands:\n    84в†’  init [--workflow <name>] [--image <base>]  Initialize a Cloche project\n    85в†’  health                                   Show project health summary\n    86в†’  run --workflow <name> [--prompt \"...\"] [--keep-container]\n    87в†’                                             Launch a workflow run\n    88в†’  status <run-id>                            Check run status\n    89в†’  logs <run-id> [--step <name>] [--type <full|script|llm>] [--follow]\n    90в†’                                             Show logs for a run\n    91в†’  poll <run-id>                              Wait for a run to finish\n    92в†’  list [--all]                                List runs (last hour by default)\n    93в†’  stop <run-id>                              Stop a running workflow\n    94в†’  delete <container-or-run-id>               Delete a retained container\n    95в†’  orchestrate                                Dispatch ready workflow runs\n    96в†’  shutdown                                   Shut down the daemon\n    97в†’`)\n    98в†’}\n    99в†’\n   100в†’func cmdRun(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   101в†’\tvar workflow, prompt string\n   102в†’\tvar keepContainer bool\n   103в†’\n   104в†’\tfor i := 0; i < len(args); i++ {\n   105в†’\t\tswitch args[i] {\n   106в†’\t\tcase \"--workflow\":\n   107в†’\t\t\tif i+1 < len(args) {\n   108в†’\t\t\t\ti++\n   109в†’\t\t\t\tworkflow = args[i]\n   110в†’\t\t\t}\n   111в†’\t\tcase \"--prompt\", \"-p\":\n   112в†’\t\t\tif i+1 < len(args) {\n   113в†’\t\t\t\ti++\n   114в†’\t\t\t\tprompt = args[i]\n   115в†’\t\t\t}\n   116в†’\t\tcase \"--keep-container\":\n   117в†’\t\t\tkeepContainer = true\n   118в†’\t\tdefault:\n   119в†’\t\t\t// Support bare positional arg as workflow name for backwards compat\n   120в†’\t\t\tif workflow == \"\" && !strings.HasPrefix(args[i], \"-\") {\n   121в†’\t\t\t\tworkflow = args[i]\n   122в†’\t\t\t}\n   123в†’\t\t}\n   124в†’\t}\n   125в†’\n   126в†’\tif workflow == \"\" {\n   127в†’\t\tfmt.Fprintf(os.Stderr, \"usage: cloche run --workflow <name> [--prompt \\\"...\\\"]\\n\")\n   128в†’\t\tos.Exit(1)\n   129в†’\t}\n   130в†’\n   131в†’\tcwd, _ := os.Getwd()\n   132в†’\n   133в†’\t// Resolve image from workflow file (soft failure вЂ” fall back to daemon default)\n   134в†’\tvar image string\n   135в†’\twfPath := filepath.Join(cwd, \".cloche\", workflow+\".cloche\")\n   136в†’\tif data, err := os.ReadFile(wfPath); err == nil {\n   137в†’\t\tif wf, err := dsl.Parse(string(data)); err == nil {\n   138в†’\t\t\timage = wf.Config[\"container.image\"]\n   139в†’\t\t}\n   140в†’\t}\n   141в†’\n   142в†’\tresp, err := client.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n   143в†’\t\tWorkflowName:  workflow,\n   144в†’\t\tProjectDir:    cwd,\n   145в†’\t\tImage:         image,\n   146в†’\t\tPrompt:        prompt,\n   147в†’\t\tKeepContainer: keepContainer,\n   148в†’\t})\n   149в†’\tif err != nil {\n   150в†’\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   151в†’\t\tos.Exit(1)\n   152в†’\t}\n   153в†’\tfmt.Printf(\"Started run: %s\\n\", resp.RunId)\n   154в†’}\n   155в†’\n   156в†’func cmdStatus(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   157в†’\tif len(args) < 1 {\n   158в†’\t\tfmt.Fprintf(os.Stderr, \"usage: cloche status <run-id>\\n\")\n   159в†’\t\tos.Exit(1)\n   160в†’\t}\n   161в†’\n   162в†’\tresp, err := client.GetStatus(ctx, &pb.GetStatusRequest{RunId: args[0]})\n   163в†’\tif err != nil {\n   164в†’\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   165в†’\t\tos.Exit(1)\n   166в†’\t}\n   167в†’\n   168в†’\tfmt.Printf(\"Run:       %s\\n\", resp.RunId)\n   169в†’\tfmt.Printf(\"Workflow:  %s\\n\", resp.WorkflowName)\n   170в†’\tfmt.Printf(\"State:     %s\\n\", resp.State)\n   171в†’\tif resp.ContainerId != \"\" {\n   172в†’\t\tcid := resp.ContainerId\n   173в†’\t\tif len(cid) > 12 {\n   174в†’\t\t\tcid = cid[:12]\n   175в†’\t\t}\n   176в†’\t\tfmt.Printf(\"Container: %s\\n\", cid)\n   177в†’\t}\n   178в†’\tif resp.ErrorMessage != \"\" {\n   179в†’\t\tfmt.Printf(\"Error:     %s\\n\", resp.ErrorMessage)\n   180в†’\t}\n   181в†’\tfmt.Printf(\"Active:    %s\\n\", resp.CurrentStep)\n   182в†’\tfor _, exec := range resp.StepExecutions {\n   183в†’\t\tfmt.Printf(\"  %s: %s (%s -> %s)\\n\", exec.StepName, exec.Result, exec.StartedAt, exec.CompletedAt)\n   184в†’\t}\n   185в†’}\n   186в†’\n   187в†’func cmdList(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   188в†’\tvar all bool\n   189в†’\tfor _, arg := range args {\n   190в†’\t\tif arg == \"--all\" {\n   191в†’\t\t\tall = true\n   192в†’\t\t}\n   193в†’\t}\n   194в†’\n   195в†’\tresp, err := client.ListRuns(ctx, &pb.ListRunsRequest{All: all})\n   196в†’\tif err != nil {\n   197в†’\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   198в†’\t\tos.Exit(1)\n   199в†’\t}\n   200в†’\n   201в†’\tif len(resp.Runs) == 0 {\n   202в†’\t\tfmt.Println(\"No runs found.\")\n   203в†’\t\treturn\n   204в†’\t}\n   205в†’\n   206в†’\tfor _, run := range resp.Runs {\n   207в†’\t\tline := fmt.Sprintf(\"%s  %-20s  %-10s\", run.RunId, run.WorkflowName, run.State)\n   208в†’\t\tif run.ContainerId != \"\" {\n   209в†’\t\t\tline += \"  \" + run.ContainerId\n   210в†’\t\t}\n   211в†’\t\tif run.ErrorMessage != \"\" {\n   212в†’\t\t\terrMsg := run.ErrorMessage\n   213в†’\t\t\tif len(errMsg) > 60 {\n   214в†’\t\t\t\terrMsg = errMsg[:57] + \"...\"\n   215в†’\t\t\t}\n   216в†’\t\t\tline += \"  \" + errMsg\n   217в†’\t\t}\n   218в†’\t\tfmt.Println(line)\n   219в†’\t}\n   220в†’}\n   221в†’\n   222в†’func cmdLogs(client pb.ClocheServiceClient, args []string) {\n   223в†’\tif len(args) < 1 {\n   224в†’\t\tfmt.Fprintf(os.Stderr, \"usage: cloche logs <run-id> [--step <name>] [--type <full|script|llm>] [--follow]\\n\")\n   225в†’\t\tos.Exit(1)\n   226в†’\t}\n   227в†’\n   228в†’\tvar stepFilter, typeFilter string\n   229в†’\tvar follow bool\n   230в†’\trunID := args[0]\n   231в†’\n   232в†’\tfor i := 1; i < len(args); i++ {\n   233в†’\t\tswitch args[i] {\n   234в†’\t\tcase \"--step\":\n   235в†’\t\t\tif i+1 < len(args) {\n   236в†’\t\t\t\ti++\n   237в†’\t\t\t\tstepFilter = args[i]\n   238в†’\t\t\t}\n   239в†’\t\tcase \"--type\":\n   240в†’\t\t\tif i+1 < len(args) {\n   241в†’\t\t\t\ti++\n   242в†’\t\t\t\ttypeFilter = args[i]\n   243в†’\t\t\t}\n   244в†’\t\tcase \"--follow\", \"-f\":\n   245в†’\t\t\tfollow = true\n   246в†’\t\t}\n   247в†’\t}\n   248в†’\n   249в†’\tif follow {\n   250в†’\t\tcmdLogsFollow(runID)\n   251в†’\t\treturn\n   252в†’\t}\n   253в†’\n   254в†’\t// Use background context вЂ” log output can be large\n   255в†’\tstream, err := client.StreamLogs(context.Background(), &pb.StreamLogsRequest{\n   256в†’\t\tRunId:    runID,\n   257в†’\t\tStepName: stepFilter,\n   258в†’\t\tLogType:  typeFilter,\n   259в†’\t})\n   260в†’\tif err != nil {\n   261в†’\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   262в†’\t\tos.Exit(1)\n   263в†’\t}\n   264в†’\n   265в†’\tfor {\n   266в†’\t\tentry, err := stream.Recv()\n   267в†’\t\tif err != nil {\n   268в†’\t\t\tif errors.Is(err, io.EOF) {\n   269в†’\t\t\t\tbreak\n   270в†’\t\t\t}\n   271в†’\t\t\tfmt.Fprintf(os.Stderr, \"error reading logs: %v\\n\", err)\n   272в†’\t\t\tos.Exit(1)\n   273в†’\t\t}\n   274в†’\n   275в†’\t\tswitch entry.Type {\n   276в†’\t\tcase \"step_started\":\n   277в†’\t\t\tfmt.Printf(\"--- %s started ---\\n\", entry.StepName)\n   278в†’\t\t\tif entry.Message != \"\" {\n   279в†’\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n   280в†’\t\t\t}\n   281в†’\t\tcase \"step_completed\":\n   282в†’\t\t\tfmt.Printf(\"--- %s: %s ---\\n\", entry.StepName, entry.Result)\n   283в†’\t\t\tif entry.Message != \"\" {\n   284в†’\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n   285в†’\t\t\t}\n   286в†’\t\tcase \"run_completed\":\n   287в†’\t\t\tfmt.Printf(\"\\nRun result: %s\\n\", entry.Result)\n   288в†’\t\t\tif entry.Message != \"\" {\n   289в†’\t\t\t\tfmt.Printf(\"Error:      %s\\n\", entry.Message)\n   290в†’\t\t\t}\n   291в†’\t\tcase \"full_log\":\n   292в†’\t\t\tfmt.Print(entry.Message)\n   293в†’\t\tdefault:\n   294в†’\t\t\t// Handles filtered log entries like \"script_log\", \"llm_log\", \"step_log\"\n   295в†’\t\t\tif entry.StepName != \"\" {\n   296в†’\t\t\t\tfmt.Printf(\"--- %s ---\\n\", entry.StepName)\n   297в†’\t\t\t}\n   298в†’\t\t\tif entry.Message != \"\" {\n   299в†’\t\t\t\tfmt.Print(entry.Message)\n   300в†’\t\t\t}\n   301в†’\t\t}\n   302в†’\t}\n   303в†’}\n   304в†’\n   305в†’func cmdLogsFollow(runID string) {\n   306в†’\t// Determine HTTP address from env\n   307в†’\thttpAddr := os.Getenv(\"CLOCHE_HTTP\")\n   308в†’\tif httpAddr == \"\" {\n   309в†’\t\thttpAddr = \"localhost:8080\"\n   310в†’\t}\n   311в†’\t// Strip protocol prefix if present\n   312в†’\thttpAddr = strings.TrimPrefix(httpAddr, \"http://\")\n   313в†’\n   314в†’\tsseURL := fmt.Sprintf(\"http://%s/api/runs/%s/stream\", httpAddr, runID)\n   315в†’\treq, err := http.NewRequest(\"GET\", sseURL, nil)\n   316в†’\tif err != nil {\n   317в†’\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   318в†’\t\tos.Exit(1)\n   319в†’\t}\n   320в†’\treq.Header.Set(\"Accept\", \"text/event-stream\")\n   321в†’\n   322в†’\tresp, err := http.DefaultClient.Do(req)\n   323в†’\tif err != nil {\n   324в†’\t\tfmt.Fprintf(os.Stderr, \"error connecting to SSE stream: %v\\n\", err)\n   325в†’\t\tos.Exit(1)\n   326в†’\t}\n   327в†’\tdefer resp.Body.Close()\n   328в†’\n   329в†’\tif resp.StatusCode != 200 {\n   330в†’\t\tbody, _ := io.ReadAll(resp.Body)\n   331в†’\t\tfmt.Fprintf(os.Stderr, \"error: HTTP %d: %s\\n\", resp.StatusCode, strings.TrimSpace(string(body)))\n   332в†’\t\tos.Exit(1)\n   333в†’\t}\n   334в†’\n   335в†’\tscanner := bufio.NewScanner(resp.Body)\n   336в†’\tfor scanner.Scan() {\n   337в†’\t\tline := scanner.Text()\n   338в†’\t\tif strings.HasPrefix(line, \"event: done\") {\n   339в†’\t\t\tbreak\n   340в†’\t\t}\n   341в†’\t\tif !strings.HasPrefix(line, \"data: \") {\n   342в†’\t\t\tcontinue\n   343в†’\t\t}\n   344в†’\t\tdata := strings.TrimPrefix(line, \"data: \")\n   345в†’\n   346в†’\t\tvar entry struct {\n   347в†’\t\t\tTimestamp string `json:\"timestamp\"`\n   348в†’\t\t\tType      string `json:\"type\"`\n   349в†’\t\t\tContent   string `json:\"content\"`\n   350в†’\t\t}\n   351в†’\t\tif err := json.Unmarshal([]byte(data), &entry); err != nil {\n   352в†’\t\t\tcontinue\n   353в†’\t\t}\n   354в†’\n   355в†’\t\t// Color-code by type\n   356в†’\t\tswitch entry.Type {\n   357в†’\t\tcase \"status\":\n   358в†’\t\t\tfmt.Printf(\"\\033[34m[%s] [%s] %s\\033[0m\\n\", entry.Timestamp, entry.Type, entry.Content)\n   359в†’\t\tcase \"llm\":\n   360в†’\t\t\tfmt.Printf(\"\\033[32m[%s] [%s] %s\\033[0m\\n\", entry.Timestamp, entry.Type, entry.Content)\n   361в†’\t\tdefault:\n   362в†’\t\t\tfmt.Printf(\"[%s] [%s] %s\\n\", entry.Timestamp, entry.Type, entry.Content)\n   363в†’\t\t}\n   364в†’\t}\n   365в†’}\n   366в†’\n   367в†’func cmdStop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   368в†’\tif len(args) < 1 {\n   369в†’\t\tfmt.Fprintf(os.Stderr, \"usage: cloche stop <run-id>\\n\")\n   370в†’\t\tos.Exit(1)\n   371в†’\t}\n   372в†’\n   373в†’\t_, err := client.StopRun(ctx, &pb.StopRunRequest{RunId: args[0]})\n   374в†’\tif err != nil {\n   375в†’\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   376в†’\t\tos.Exit(1)\n   377в†’\t}\n   378в†’\tfmt.Printf(\"Stopped run: %s\\n\", args[0])\n   379в†’}\n   380в†’\n   381в†’func cmdDelete(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   382в†’\tif len(args) < 1 {\n   383в†’\t\tfmt.Fprintf(os.Stderr, \"usage: cloche delete <container-or-run-id>\\n\")\n   384в†’\t\tos.Exit(1)\n   385в†’\t}\n   386в†’\n   387в†’\t_, err := client.DeleteContainer(ctx, &pb.DeleteContainerRequest{Id: args[0]})\n   388в†’\tif err != nil {\n   389в†’\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   390в†’\t\tos.Exit(1)\n   391в†’\t}\n   392в†’\tfmt.Printf(\"Deleted container: %s\\n\", args[0])\n   393в†’}\n   394в†’\n   395в†’func cmdOrchestrate(ctx context.Context, client pb.ClocheServiceClient) {\n   396в†’\tcwd, _ := os.Getwd()\n   397в†’\tresp, err := client.Orchestrate(ctx, &pb.OrchestrateRequest{ProjectDir: cwd})\n   398в†’\tif err != nil {\n   399в†’\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   400в†’\t\tos.Exit(1)\n   401в†’\t}\n   402в†’\tif resp.Dispatched == 0 {\n   403в†’\t\tfmt.Println(\"No ready work found.\")\n   404в†’\t} else {\n   405в†’\t\tfmt.Printf(\"Dispatched %d run(s).\\n\", resp.Dispatched)\n   406в†’\t}\n   407в†’}\n   408в†’\n   409в†’func cmdShutdown(ctx context.Context, client pb.ClocheServiceClient) {\n   410в†’\t_, err := client.Shutdown(ctx, &pb.ShutdownRequest{})\n   411в†’\tif err != nil {\n   412в†’\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   413в†’\t\tos.Exit(1)\n   414в†’\t}\n   415в†’\tfmt.Println(\"Daemon shutting down.\")\n   416в†’}\n   417в†’"}]},"parent_tool_use_id":null,"session_id":"9cfeee3f-a672-42d2-aba9-acde9fa5975c","uuid":"4e9afa1d-c2a4-4cda-bd7d-c7eb98d1170c","tool_use_result":{"type":"text","file":{"filePath":"/workspace/cmd/cloche/main.go","content":"package main\n\nimport (\n\t\"bufio\"\n\t\"context\"\n\t\"encoding/json\"\n\t\"errors\"\n\t\"fmt\"\n\t\"io\"\n\t\"net/http\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"strings\"\n\t\"time\"\n\n\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n\t\"github.com/cloche-dev/cloche/internal/dsl\"\n\t\"google.golang.org/grpc\"\n\t\"google.golang.org/grpc/credentials/insecure\"\n)\n\nfunc main() {\n\tif len(os.Args) < 2 {\n\t\tusage()\n\t\tos.Exit(1)\n\t}\n\n\t// Commands that don't need a daemon connection\n\tswitch os.Args[1] {\n\tcase \"init\":\n\t\tcmdInit(os.Args[2:])\n\t\treturn\n\tcase \"health\":\n\t\tcmdHealth(os.Args[2:])\n\t\treturn\n\t}\n\n\t// Commands that need a daemon connection\n\taddr := os.Getenv(\"CLOCHE_ADDR\")\n\tif addr == \"\" {\n\t\taddr = \"unix:///tmp/cloche.sock\"\n\t}\n\n\tconn, err := grpc.NewClient(addr, grpc.WithTransportCredentials(insecure.NewCredentials()))\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"failed to connect: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tdefer conn.Close()\n\n\tclient := pb.NewClocheServiceClient(conn)\n\tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n\tdefer cancel()\n\n\tswitch os.Args[1] {\n\tcase \"run\":\n\t\tcmdRun(ctx, client, os.Args[2:])\n\tcase \"status\":\n\t\tcmdStatus(ctx, client, os.Args[2:])\n\tcase \"logs\":\n\t\tcmdLogs(client, os.Args[2:])\n\tcase \"poll\":\n\t\tcmdPoll(client, os.Args[2:])\n\tcase \"list\":\n\t\tcmdList(ctx, client, os.Args[2:])\n\tcase \"stop\":\n\t\tcmdStop(ctx, client, os.Args[2:])\n\tcase \"delete\":\n\t\tcmdDelete(ctx, client, os.Args[2:])\n\tcase \"orchestrate\":\n\t\tcmdOrchestrate(ctx, client)\n\tcase \"shutdown\":\n\t\tcmdShutdown(ctx, client)\n\tdefault:\n\t\tusage()\n\t\tos.Exit(1)\n\t}\n}\n\nfunc usage() {\n\tfmt.Fprintf(os.Stderr, `usage: cloche <command> [args]\n\nCommands:\n  init [--workflow <name>] [--image <base>]  Initialize a Cloche project\n  health                                   Show project health summary\n  run --workflow <name> [--prompt \"...\"] [--keep-container]\n                                             Launch a workflow run\n  status <run-id>                            Check run status\n  logs <run-id> [--step <name>] [--type <full|script|llm>] [--follow]\n                                             Show logs for a run\n  poll <run-id>                              Wait for a run to finish\n  list [--all]                                List runs (last hour by default)\n  stop <run-id>                              Stop a running workflow\n  delete <container-or-run-id>               Delete a retained container\n  orchestrate                                Dispatch ready workflow runs\n  shutdown                                   Shut down the daemon\n`)\n}\n\nfunc cmdRun(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tvar workflow, prompt string\n\tvar keepContainer bool\n\n\tfor i := 0; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--workflow\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tworkflow = args[i]\n\t\t\t}\n\t\tcase \"--prompt\", \"-p\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tprompt = args[i]\n\t\t\t}\n\t\tcase \"--keep-container\":\n\t\t\tkeepContainer = true\n\t\tdefault:\n\t\t\t// Support bare positional arg as workflow name for backwards compat\n\t\t\tif workflow == \"\" && !strings.HasPrefix(args[i], \"-\") {\n\t\t\t\tworkflow = args[i]\n\t\t\t}\n\t\t}\n\t}\n\n\tif workflow == \"\" {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche run --workflow <name> [--prompt \\\"...\\\"]\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tcwd, _ := os.Getwd()\n\n\t// Resolve image from workflow file (soft failure вЂ” fall back to daemon default)\n\tvar image string\n\twfPath := filepath.Join(cwd, \".cloche\", workflow+\".cloche\")\n\tif data, err := os.ReadFile(wfPath); err == nil {\n\t\tif wf, err := dsl.Parse(string(data)); err == nil {\n\t\t\timage = wf.Config[\"container.image\"]\n\t\t}\n\t}\n\n\tresp, err := client.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n\t\tWorkflowName:  workflow,\n\t\tProjectDir:    cwd,\n\t\tImage:         image,\n\t\tPrompt:        prompt,\n\t\tKeepContainer: keepContainer,\n\t})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Printf(\"Started run: %s\\n\", resp.RunId)\n}\n\nfunc cmdStatus(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche status <run-id>\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tresp, err := client.GetStatus(ctx, &pb.GetStatusRequest{RunId: args[0]})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tfmt.Printf(\"Run:       %s\\n\", resp.RunId)\n\tfmt.Printf(\"Workflow:  %s\\n\", resp.WorkflowName)\n\tfmt.Printf(\"State:     %s\\n\", resp.State)\n\tif resp.ContainerId != \"\" {\n\t\tcid := resp.ContainerId\n\t\tif len(cid) > 12 {\n\t\t\tcid = cid[:12]\n\t\t}\n\t\tfmt.Printf(\"Container: %s\\n\", cid)\n\t}\n\tif resp.ErrorMessage != \"\" {\n\t\tfmt.Printf(\"Error:     %s\\n\", resp.ErrorMessage)\n\t}\n\tfmt.Printf(\"Active:    %s\\n\", resp.CurrentStep)\n\tfor _, exec := range resp.StepExecutions {\n\t\tfmt.Printf(\"  %s: %s (%s -> %s)\\n\", exec.StepName, exec.Result, exec.StartedAt, exec.CompletedAt)\n\t}\n}\n\nfunc cmdList(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tvar all bool\n\tfor _, arg := range args {\n\t\tif arg == \"--all\" {\n\t\t\tall = true\n\t\t}\n\t}\n\n\tresp, err := client.ListRuns(ctx, &pb.ListRunsRequest{All: all})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tif len(resp.Runs) == 0 {\n\t\tfmt.Println(\"No runs found.\")\n\t\treturn\n\t}\n\n\tfor _, run := range resp.Runs {\n\t\tline := fmt.Sprintf(\"%s  %-20s  %-10s\", run.RunId, run.WorkflowName, run.State)\n\t\tif run.ContainerId != \"\" {\n\t\t\tline += \"  \" + run.ContainerId\n\t\t}\n\t\tif run.ErrorMessage != \"\" {\n\t\t\terrMsg := run.ErrorMessage\n\t\t\tif len(errMsg) > 60 {\n\t\t\t\terrMsg = errMsg[:57] + \"...\"\n\t\t\t}\n\t\t\tline += \"  \" + errMsg\n\t\t}\n\t\tfmt.Println(line)\n\t}\n}\n\nfunc cmdLogs(client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche logs <run-id> [--step <name>] [--type <full|script|llm>] [--follow]\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tvar stepFilter, typeFilter string\n\tvar follow bool\n\trunID := args[0]\n\n\tfor i := 1; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--step\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tstepFilter = args[i]\n\t\t\t}\n\t\tcase \"--type\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\ttypeFilter = args[i]\n\t\t\t}\n\t\tcase \"--follow\", \"-f\":\n\t\t\tfollow = true\n\t\t}\n\t}\n\n\tif follow {\n\t\tcmdLogsFollow(runID)\n\t\treturn\n\t}\n\n\t// Use background context вЂ” log output can be large\n\tstream, err := client.StreamLogs(context.Background(), &pb.StreamLogsRequest{\n\t\tRunId:    runID,\n\t\tStepName: stepFilter,\n\t\tLogType:  typeFilter,\n\t})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tfor {\n\t\tentry, err := stream.Recv()\n\t\tif err != nil {\n\t\t\tif errors.Is(err, io.EOF) {\n\t\t\t\tbreak\n\t\t\t}\n\t\t\tfmt.Fprintf(os.Stderr, \"error reading logs: %v\\n\", err)\n\t\t\tos.Exit(1)\n\t\t}\n\n\t\tswitch entry.Type {\n\t\tcase \"step_started\":\n\t\t\tfmt.Printf(\"--- %s started ---\\n\", entry.StepName)\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n\t\t\t}\n\t\tcase \"step_completed\":\n\t\t\tfmt.Printf(\"--- %s: %s ---\\n\", entry.StepName, entry.Result)\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n\t\t\t}\n\t\tcase \"run_completed\":\n\t\t\tfmt.Printf(\"\\nRun result: %s\\n\", entry.Result)\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Printf(\"Error:      %s\\n\", entry.Message)\n\t\t\t}\n\t\tcase \"full_log\":\n\t\t\tfmt.Print(entry.Message)\n\t\tdefault:\n\t\t\t// Handles filtered log entries like \"script_log\", \"llm_log\", \"step_log\"\n\t\t\tif entry.StepName != \"\" {\n\t\t\t\tfmt.Printf(\"--- %s ---\\n\", entry.StepName)\n\t\t\t}\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Print(entry.Message)\n\t\t\t}\n\t\t}\n\t}\n}\n\nfunc cmdLogsFollow(runID string) {\n\t// Determine HTTP address from env\n\thttpAddr := os.Getenv(\"CLOCHE_HTTP\")\n\tif httpAddr == \"\" {\n\t\thttpAddr = \"localhost:8080\"\n\t}\n\t// Strip protocol prefix if present\n\thttpAddr = strings.TrimPrefix(httpAddr, \"http://\")\n\n\tsseURL := fmt.Sprintf(\"http://%s/api/runs/%s/stream\", httpAddr, runID)\n\treq, err := http.NewRequest(\"GET\", sseURL, nil)\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\treq.Header.Set(\"Accept\", \"text/event-stream\")\n\n\tresp, err := http.DefaultClient.Do(req)\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error connecting to SSE stream: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tdefer resp.Body.Close()\n\n\tif resp.StatusCode != 200 {\n\t\tbody, _ := io.ReadAll(resp.Body)\n\t\tfmt.Fprintf(os.Stderr, \"error: HTTP %d: %s\\n\", resp.StatusCode, strings.TrimSpace(string(body)))\n\t\tos.Exit(1)\n\t}\n\n\tscanner := bufio.NewScanner(resp.Body)\n\tfor scanner.Scan() {\n\t\tline := scanner.Text()\n\t\tif strings.HasPrefix(line, \"event: done\") {\n\t\t\tbreak\n\t\t}\n\t\tif !strings.HasPrefix(line, \"data: \") {\n\t\t\tcontinue\n\t\t}\n\t\tdata := strings.TrimPrefix(line, \"data: \")\n\n\t\tvar entry struct {\n\t\t\tTimestamp string `json:\"timestamp\"`\n\t\t\tType      string `json:\"type\"`\n\t\t\tContent   string `json:\"content\"`\n\t\t}\n\t\tif err := json.Unmarshal([]byte(data), &entry); err != nil {\n\t\t\tcontinue\n\t\t}\n\n\t\t// Color-code by type\n\t\tswitch entry.Type {\n\t\tcase \"status\":\n\t\t\tfmt.Printf(\"\\033[34m[%s] [%s] %s\\033[0m\\n\", entry.Timestamp, entry.Type, entry.Content)\n\t\tcase \"llm\":\n\t\t\tfmt.Printf(\"\\033[32m[%s] [%s] %s\\033[0m\\n\", entry.Timestamp, entry.Type, entry.Content)\n\t\tdefault:\n\t\t\tfmt.Printf(\"[%s] [%s] %s\\n\", entry.Timestamp, entry.Type, entry.Content)\n\t\t}\n\t}\n}\n\nfunc cmdStop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche stop <run-id>\\n\")\n\t\tos.Exit(1)\n\t}\n\n\t_, err := client.StopRun(ctx, &pb.StopRunRequest{RunId: args[0]})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Printf(\"Stopped run: %s\\n\", args[0])\n}\n\nfunc cmdDelete(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche delete <container-or-run-id>\\n\")\n\t\tos.Exit(1)\n\t}\n\n\t_, err := client.DeleteContainer(ctx, &pb.DeleteContainerRequest{Id: args[0]})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Printf(\"Deleted container: %s\\n\", args[0])\n}\n\nfunc cmdOrchestrate(ctx context.Context, client pb.ClocheServiceClient) {\n\tcwd, _ := os.Getwd()\n\tresp, err := client.Orchestrate(ctx, &pb.OrchestrateRequest{ProjectDir: cwd})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tif resp.Dispatched == 0 {\n\t\tfmt.Println(\"No ready work found.\")\n\t} else {\n\t\tfmt.Printf(\"Dispatched %d run(s).\\n\", resp.Dispatched)\n\t}\n}\n\nfunc cmdShutdown(ctx context.Context, client pb.ClocheServiceClient) {\n\t_, err := client.Shutdown(ctx, &pb.ShutdownRequest{})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Println(\"Daemon shutting down.\")\n}\n","numLines":417,"startLine":1,"totalLines":417}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TVwLxihqz3beZrXwZPV18a","type":"tool_result","content":"     1в†’# Usage\n     2в†’\n     3в†’Cloche runs containerized workflows for autonomous coding agents. You write a\n     4в†’workflow graph in the `.cloche` DSL, point Cloche at a project directory, and it\n     5в†’handles execution, retry logic, and status tracking.\n     6в†’\n     7в†’## Prerequisites\n     8в†’\n     9в†’- Go 1.25+\n    10в†’- Docker\n    11в†’- Git\n    12в†’- An `ANTHROPIC_API_KEY` (for agent steps using Claude Code)\n    13в†’\n    14в†’For detailed installation options (pre-built binaries, `go install`, Homebrew,\n    15в†’Docker-based usage), see [INSTALL.md](INSTALL.md).\n    16в†’\n    17в†’## Quick Start\n    18в†’\n    19в†’### 1. Build everything\n    20в†’\n    21в†’```\n    22в†’make build\n    23в†’make docker-build\n    24в†’```\n    25в†’\n    26в†’This produces `bin/cloche`, `bin/cloched`, `bin/cloche-agent`, and the\n    27в†’`cloche-agent:latest` Docker image.\n    28в†’\n    29в†’### 2. Start the daemon\n    30в†’\n    31в†’```\n    32в†’bin/cloched\n    33в†’```\n    34в†’\n    35в†’The daemon listens on a Unix socket at `/tmp/cloche.sock` by default. It\n    36в†’manages Docker containers, tracks run state in SQLite, and handles\n    37в†’container cleanup. Containers are automatically removed after successful\n    38в†’runs unless `--keep-container` is set. Failed runs always keep their\n    39в†’container for debugging.\n    40в†’\n    41в†’To enable the web dashboard, set `CLOCHE_HTTP` (e.g.\n    42в†’`CLOCHE_HTTP=:8080 bin/cloched`). The dashboard is not started unless\n    43в†’this variable is set.\n    44в†’\n    45в†’### 3. Run a workflow\n    46в†’\n    47в†’From your project directory (must be inside a git repository):\n    48в†’\n    49в†’```\n    50в†’cd my-project\n    51в†’cloche run --workflow develop --prompt \"Add user authentication\"\n    52в†’```\n    53в†’\n    54в†’This will:\n    55в†’1. Write your prompt to `.cloche/<run-id>/prompt.txt`\n    56в†’2. Create a Docker container and copy your entire project into it (no bind mounts)\n    57в†’3. Apply any override files from `.cloche/overrides/` on top\n    58в†’4. Start the container, which runs `cloche-agent` to walk the workflow graph\n    59в†’5. When the workflow finishes, the daemon extracts results to a `cloche/<run-id>` branch\n    60в†’\n    61в†’### 4. Monitor progress\n    62в†’\n    63в†’```\n    64в†’cloche status <run-id>\n    65в†’cloche list\n    66в†’```\n    67в†’\n    68в†’### 5. Get the results\n    69в†’\n    70в†’When the run completes, the agent's work is on a git branch:\n    71в†’\n    72в†’```\n    73в†’git branch | grep cloche/\n    74в†’git diff main..cloche/<run-id>\n    75в†’```\n    76в†’\n    77в†’To merge results into your working branch:\n    78в†’\n    79в†’```\n    80в†’git merge cloche/<run-id>\n    81в†’# or cherry-pick, rebase, etc.\n    82в†’```\n    83в†’\n    84в†’To clean up run branches:\n    85в†’\n    86в†’```\n    87в†’git branch -D cloche/<run-id>\n    88в†’```\n    89в†’\n    90в†’## Container Isolation Model\n    91в†’\n    92в†’Cloche provides **total filesystem isolation** between the host and container:\n    93в†’\n    94в†’- **Files in**: `docker cp` copies the entire project root into the container at\n    95в†’  `/workspace/`. No bind mounts for project files. Override files from\n    96в†’  `.cloche/overrides/` are then copied on top (e.g., a container-specific\n    97в†’  `CLAUDE.md`). The `.git/` directory is included so agents have git context.\n    98в†’- **Files out**: When the workflow completes, the daemon extracts results from\n    99в†’  the container via `docker cp` into a git worktree and commits them to a\n   100в†’  `cloche/<run-id>` branch.\n   101в†’- **Auth mounts**: `~/.claude` and `~/.claude.json` are bind-mounted read-only\n   102в†’  for Claude Code OAuth session reuse. `ANTHROPIC_API_KEY` is passed as an\n   103в†’  environment variable.\n   104в†’- **Network**: Containers have network access (needed for API calls).\n   105в†’\n   106в†’Your project directory is never modified by the container. All changes live\n   107в†’on the run branch until you explicitly merge them.\n   108в†’\n   109в†’## CLI Reference\n   110в†’\n   111в†’### `cloche init`\n   112в†’\n   113в†’Scaffold a new Cloche project in the current directory.\n   114в†’\n   115в†’```\n   116в†’cloche init [--workflow <name>] [--image <base>]\n   117в†’```\n   118в†’\n   119в†’| Flag | Default | Description |\n   120в†’|------|---------|-------------|\n   121в†’| `--workflow <name>` | `develop` | Workflow name. Creates `.cloche/<name>.cloche`. |\n   122в†’| `--image <base>` | `ubuntu:24.04` | Base Docker image for the generated Dockerfile. |\n   123в†’\n   124в†’Creates `.cloche/` with a workflow file, Dockerfile, and prompt templates\n   125в†’(`implement.md`, `fix.md`, `update-docs.md`). Skips files that already exist.\n   126в†’Also adds gitignore entries for runtime state directories.\n   127в†’\n   128в†’### `cloche health`\n   129в†’\n   130в†’Show project health summary based on recent run results.\n   131в†’\n   132в†’```\n   133в†’cloche health\n   134в†’```\n   135в†’\n   136в†’Requires `CLOCHE_HTTP` to be set (e.g. `export CLOCHE_HTTP=localhost:8080`).\n   137в†’Fetches health data from the daemon's HTTP API (`GET /api/projects`) and\n   138в†’displays a table with per-project pass/fail counts:\n   139в†’\n   140в†’```\n   141в†’PROJECT          STATUS    PASSED  FAILED  TOTAL\n   142в†’my-project       green     5       0       5\n   143в†’other-project    yellow    3       2       5\n   144в†’```\n   145в†’\n   146в†’Status is colored (green/yellow/red) when output is a TTY.\n   147в†’\n   148в†’### `cloche run`\n   149в†’\n   150в†’Launch a workflow run.\n   151в†’\n   152в†’```\n   153в†’cloche run --workflow <name> [--prompt \"...\"] [--keep-container]\n   154в†’```\n   155в†’\n   156в†’| Flag | Description |\n   157в†’|------|-------------|\n   158в†’| `--workflow <name>` | Workflow name. Resolves to `.cloche/<name>.cloche` in the project directory. |\n   159в†’| `--prompt \"...\"`, `-p` | Inline prompt written to `.cloche/<run-id>/prompt.txt` and injected into agent steps. |\n   160в†’| `--keep-container` | Keep the Docker container even on success (default: remove on success). Failed runs always keep their container for debugging. |\n   161в†’\n   162в†’The current working directory is used as the project directory. It must be\n   163в†’inside a git repository (Cloche needs the repo root for result extraction\n   164в†’via git worktrees).\n   165в†’\n   166в†’When starting a run, the daemon checks whether the Docker image is up-to-date\n   167в†’with the project's `.cloche/Dockerfile`. If the Dockerfile has changed since\n   168в†’the last build (tracked via a SHA-256 label on the image), the daemon rebuilds\n   169в†’the image automatically before launching the container.\n   170в†’\n   171в†’### `cloche status`\n   172в†’\n   173в†’Check the status of a run.\n   174в†’\n   175в†’```\n   176в†’cloche status <run-id>\n   177в†’```\n   178в†’\n   179в†’Output includes the run state, active steps, and per-step results with timestamps.\n   180в†’\n   181в†’### `cloche list`\n   182в†’\n   183в†’List runs (last hour by default).\n   184в†’\n   185в†’```\n   186в†’cloche list [--all]\n   187в†’```\n   188в†’\n   189в†’| Flag | Description |\n   190в†’|------|-------------|\n   191в†’| `--all` | Show all runs, not just the last hour. |\n   192в†’\n   193в†’Columns: run ID, workflow name, state, container ID (if running), error message (if failed).\n   194в†’\n   195в†’### `cloche logs`\n   196в†’\n   197в†’Show logs for a run.\n   198в†’\n   199в†’```\n   200в†’cloche logs <run-id> [--step <name>] [--type <full|script|llm>] [--follow]\n   201в†’```\n   202в†’\n   203в†’| Flag | Description |\n   204в†’|------|-------------|\n   205в†’| `--step <name>` | Show only logs for the specified step. |\n   206в†’| `--type <full\\|script\\|llm>` | Show only logs of the specified type (`full` = unified log, `script` = script output, `llm` = LLM conversation). |\n   207в†’| `--follow`, `-f` | Stream live log lines via SSE. Color-coded by type: status (blue), LLM (green), script (default). Exits when the run completes. Connects to the daemon's HTTP endpoint (see `CLOCHE_HTTP` in Client Configuration). |\n   208в†’\n   209в†’Without flags, shows the unified log (`full.log`) if available, otherwise streams\n   210в†’step start/completion events and run results.\n   211в†’With `--follow`, connects to the SSE endpoint and prints log lines in real-time.\n   212в†’\n   213в†’### `cloche poll`\n   214в†’\n   215в†’Wait for a run to finish, printing progress updates.\n   216в†’\n   217в†’```\n   218в†’cloche poll <run-id>\n   219в†’```\n   220в†’\n   221в†’Polls every 2 seconds. Exits 0 on success, 1 on failure or if the container\n   222в†’dies unexpectedly.\n   223в†’\n   224в†’### `cloche stop`\n   225в†’\n   226в†’Cancel a running workflow.\n   227в†’\n   228в†’```\n   229в†’cloche stop <run-id>\n   230в†’```\n   231в†’\n   232в†’### `cloche delete`\n   233в†’\n   234в†’Delete a retained Docker container. Accepts either a Docker container name/ID\n   235в†’or a Cloche run ID. If given a run ID, the daemon looks up the associated\n   236в†’container.\n   237в†’\n   238в†’```\n   239в†’cloche delete <container-or-run-id>\n   240в†’```\n   241в†’\n   242в†’### `cloche orchestrate`\n   243в†’\n   244в†’Dispatch ready workflow runs for the current project. Checks the project's\n   245в†’issue tracker for unclaimed tasks, generates prompts, and launches runs.\n   246в†’\n   247в†’```\n   248в†’cloche orchestrate\n   249в†’```\n   250в†’\n   251в†’Uses the current working directory as the project directory. Prints \"No ready\n   252в†’work found.\" if there are no tasks to dispatch, or \"Dispatched N run(s).\"\n   253в†’with the count.\n   254в†’\n   255в†’### `cloche shutdown`\n   256в†’\n   257в†’Shut down the daemon.\n   258в†’\n   259в†’```\n   260в†’cloche shutdown\n   261в†’```\n   262в†’\n   263в†’## Setting Up a New Project\n   264в†’\n   265в†’### 1. Scaffold the project\n   266в†’\n   267в†’Run `cloche init` from your project root to create the `.cloche/` directory with\n   268в†’default workflow, Dockerfile, and prompt templates:\n   269в†’\n   270в†’```\n   271в†’cd my-project\n   272в†’cloche init\n   273в†’```\n   274в†’\n   275в†’Or create the structure manually:\n   276в†’\n   277в†’### 2. Create a workflow file\n   278в†’\n   279в†’Add `.cloche/<name>.cloche`:\n   280в†’\n   281в†’```\n   282в†’workflow \"develop\" {\n   283в†’  step implement {\n   284в†’    prompt = file(\".cloche/prompts/implement.md\")\n   285в†’    results = [success, fail]\n   286в†’  }\n   287в†’\n   288в†’  step test {\n   289в†’    run = \"make test 2>&1\"\n   290в†’    results = [success, fail]\n   291в†’  }\n   292в†’\n   293в†’  step fix {\n   294в†’    prompt = file(\".cloche/prompts/fix.md\")\n   295в†’    max_attempts = \"2\"\n   296в†’    results = [success, fail, give-up]\n   297в†’  }\n   298в†’\n   299в†’  step update-docs {\n   300в†’    prompt = file(\".cloche/prompts/update-docs.md\")\n   301в†’    results = [success, fail]\n   302в†’  }\n   303в†’\n   304в†’  implement:success -> test\n   305в†’  implement:fail -> abort\n   306в†’\n   307в†’  test:success -> update-docs\n   308в†’  test:fail -> fix\n   309в†’\n   310в†’  fix:success -> test\n   311в†’  fix:fail -> abort\n   312в†’  fix:give-up -> abort\n   313в†’\n   314в†’  update-docs:success -> done\n   315в†’  update-docs:fail -> done\n   316в†’}\n   317в†’```\n   318в†’\n   319в†’### 3. Write prompt templates\n   320в†’\n   321в†’Create `.cloche/prompts/` with markdown files:\n   322в†’\n   323в†’**`.cloche/prompts/implement.md`** вЂ” Instructions for the initial implementation:\n   324в†’```markdown\n   325в†’You are working on a project. Implement the following change:\n   326в†’\n   327в†’## User Request\n   328в†’(The user prompt is injected automatically by the agent adapter)\n   329в†’\n   330в†’## Guidelines\n   331в†’- Follow existing project conventions\n   332в†’- Write tests for new functionality\n   333в†’- Run tests locally before declaring success\n   334в†’```\n   335в†’\n   336в†’**`.cloche/prompts/fix.md`** вЂ” Instructions for fixing failures:\n   337в†’```markdown\n   338в†’The previous attempt had failures. Review the output logs in .cloche/output/\n   339в†’and fix the issues.\n   340в†’\n   341в†’## Guidelines\n   342в†’- Read the test/lint output carefully\n   343в†’- Fix the root cause, not the symptoms\n   344в†’- Run tests again to verify your fix\n   345в†’```\n   346в†’\n   347в†’**`.cloche/prompts/update-docs.md`** вЂ” Instructions for keeping docs in sync:\n   348в†’```markdown\n   349в†’Review the CLI source code and update usage documentation to reflect any changes.\n   350в†’```\n   351в†’\n   352в†’### 4. Add overrides (optional)\n   353в†’\n   354в†’Files in `.cloche/overrides/` are copied on top of `/workspace/` in the\n   355в†’container. Use this for container-specific configuration:\n   356в†’\n   357в†’```\n   358в†’.cloche/overrides/\n   359в†’  CLAUDE.md              # Container-specific CLAUDE.md (replaces host version)\n   360в†’```\n   361в†’\n   362в†’### 5. Make sure your project builds in the container\n   363в†’\n   364в†’The default Dockerfile generated by `cloche init` uses `ubuntu:24.04` as its\n   365в†’base image (configurable via `--image`). If your project needs different\n   366в†’dependencies, edit `.cloche/Dockerfile`:\n   367в†’\n   368в†’```dockerfile\n   369в†’FROM golang:1.25 AS builder\n   370в†’WORKDIR /src\n   371в†’COPY go.mod go.sum ./\n   372в†’RUN go mod download\n   373в†’COPY . .\n   374в†’RUN CGO_ENABLED=0 go build -o /cloche-agent ./cmd/cloche-agent\n   375в†’\n   376в†’FROM ubuntu:24.04\n   377в†’RUN apt-get update && apt-get install -y git <your-deps> && rm -rf /var/lib/apt/lists/*\n   378в†’RUN npm install -g @anthropic-ai/claude-code\n   379в†’COPY --from=builder /cloche-agent /usr/local/bin/cloche-agent\n   380в†’RUN useradd -m -s /bin/bash agent\n   381в†’WORKDIR /workspace\n   382в†’RUN chown agent:agent /workspace\n   383в†’USER agent\n   384в†’```\n   385в†’\n   386в†’Key requirements for the image:\n   387в†’- `cloche-agent` binary at `/usr/local/bin/cloche-agent`\n   388в†’- `git` installed (for pushing results back)\n   389в†’- An `agent` user (cloche wraps the command with `chown` + `su agent`)\n   390в†’- `/workspace` as the working directory\n   391в†’- Your project's build dependencies\n   392в†’\n   393в†’The daemon automatically rebuilds the image when `.cloche/Dockerfile` changes\n   394в†’(see `cloche run` above). To build manually:\n   395в†’```\n   396в†’docker build -t my-project-agent -f .cloche/Dockerfile .\n   397в†’CLOCHE_IMAGE=my-project-agent:latest bin/cloched\n   398в†’```\n   399в†’\n   400в†’### 6. Run it\n   401в†’\n   402в†’```\n   403в†’cd my-project\n   404в†’cloche run --workflow develop --prompt \"Add feature X\"\n   405в†’```\n   406в†’\n   407в†’## Writing Workflows\n   408в†’\n   409в†’Workflow files use the `.cloche` extension and live in the `.cloche/` directory. See\n   410в†’[workflows.md](workflows.md) for full DSL reference.\n   411в†’\n   412в†’### Step Types\n   413в†’\n   414в†’**Agent steps** (has `prompt`) вЂ” Invokes a coding agent autonomously:\n   415в†’\n   416в†’```\n   417в†’step implement {\n   418в†’  prompt = file(\".cloche/prompts/implement.md\")\n   419в†’  results = [success, fail]\n   420в†’}\n   421в†’```\n   422в†’\n   423в†’**Script steps** (has `run`) вЂ” Runs a shell command:\n   424в†’\n   425в†’```\n   426в†’step test {\n   427в†’  run = \"make test 2>&1\"\n   428в†’  results = [success, fail]\n   429в†’}\n   430в†’```\n   431в†’\n   432в†’### Wiring\n   433в†’\n   434в†’Connect steps with `step:result -> next_step`:\n   435в†’\n   436в†’```\n   437в†’implement:success -> test\n   438в†’implement:fail -> abort\n   439в†’test:success -> done\n   440в†’test:fail -> fix\n   441в†’```\n   442в†’\n   443в†’`done` and `abort` are built-in terminals for success and failure.\n   444в†’\n   445в†’### Retry Loops\n   446в†’\n   447в†’Wire failures back to earlier steps:\n   448в†’\n   449в†’```\n   450в†’test:fail -> fix\n   451в†’fix:success -> test    // retry the test\n   452в†’fix:fail -> abort\n   453в†’```\n   454в†’\n   455в†’### Max Attempts\n   456в†’\n   457в†’Limit retries on agent steps. When exhausted, the step returns `give-up`:\n   458в†’\n   459в†’```\n   460в†’step fix {\n   461в†’  prompt = file(\".cloche/prompts/fix.md\")\n   462в†’  max_attempts = \"2\"\n   463в†’  results = [success, fail, give-up]\n   464в†’}\n   465в†’```\n   466в†’\n   467в†’### Parallel Branches\n   468в†’\n   469в†’Wire one result to multiple targets for concurrent execution:\n   470в†’\n   471в†’```\n   472в†’test:success -> lint\n   473в†’test:success -> quality\n   474в†’```\n   475в†’\n   476в†’### Collect (Join)\n   477в†’\n   478в†’Synchronize parallel branches:\n   479в†’\n   480в†’```\n   481в†’collect all(lint:success, quality:success) -> done\n   482в†’```\n   483в†’\n   484в†’`all` fires when every condition is met. `any` fires when at least one is.\n   485в†’\n   486в†’### Agent Command Override\n   487в†’\n   488в†’Agent steps use Claude Code by default. Override per-step:\n   489в†’\n   490в†’```\n   491в†’step implement {\n   492в†’  prompt = \"...\"\n   493в†’  agent_command = \"aider\"\n   494в†’  results = [success, fail]\n   495в†’}\n   496в†’```\n   497в†’\n   498в†’Or at the workflow level via a `container` block:\n   499в†’\n   500в†’```\n   501в†’workflow \"develop\" {\n   502в†’  container {\n   503в†’    agent_command = \"gemini\"\n   504в†’  }\n   505в†’  ...\n   506в†’}\n   507в†’```\n   508в†’\n   509в†’Or globally via `CLOCHE_AGENT_COMMAND` environment variable.\n   510в†’\n   511в†’Priority (highest to lowest): step-level `agent_command`, workflow-level\n   512в†’`container { agent_command }`, `CLOCHE_AGENT_COMMAND` env var, default (`claude`).\n   513в†’\n   514в†’### Agent Fallback Chains\n   515в†’\n   516в†’Use a comma-separated list in `agent_command` to configure fallback chains. If\n   517в†’the first agent errors without reporting a result, the system tries the next:\n   518в†’\n   519в†’```\n   520в†’step implement {\n   521в†’  prompt = \"...\"\n   522в†’  agent_command = \"claude,gemini,codex\"\n   523в†’  results = [success, fail]\n   524в†’}\n   525в†’```\n   526в†’\n   527в†’Fallback rules:\n   528в†’- **Command not found or failed to start** вЂ” fall back to next command\n   529в†’- **Exit non-zero without `CLOCHE_RESULT` marker** вЂ” fall back to next command\n   530в†’- **Exit non-zero with `CLOCHE_RESULT` marker** вЂ” use that result (no fallback)\n   531в†’- **Exit 0** вЂ” use result (no fallback)\n   532в†’- **All commands fail to start** вЂ” step returns an error\n   533в†’- **Last command crashes without marker** вЂ” step returns `fail`\n   534в†’\n   535в†’Known agents have default arguments (e.g., Claude gets\n   536в†’`-p --output-format text --dangerously-skip-permissions`). Other agents receive\n   537в†’the prompt on stdin with no extra flags. Override with `agent_args` at the step\n   538в†’or workflow level.\n   539в†’\n   540в†’## Result Protocol\n   541в†’\n   542в†’Steps report results by writing a marker to stdout:\n   543в†’\n   544в†’```\n   545в†’CLOCHE_RESULT:<name>\n   546в†’```\n   547в†’\n   548в†’For script steps, if no marker is written, the exit code determines the result:\n   549в†’0 = `success`, non-zero = `fail`. Agent steps follow the same convention.\n   550в†’\n   551в†’## Prompt Assembly\n   552в†’\n   553в†’When an agent step runs, Cloche assembles a prompt from multiple sources:\n   554в†’\n   555в†’1. The step's `prompt` content (inline or from `file()`)\n   556в†’2. The user prompt from `.cloche/<run-id>/prompt.txt` (set via `--prompt`)\n   557в†’3. Validation output from `.cloche/<run-id>/output/*.log` (output from previous script steps)\n   558в†’4. Result selection instructions listing the step's declared results\n   559в†’\n   560в†’## Project Directory Layout\n   561в†’\n   562в†’```\n   563в†’my-project/\n   564в†’в”њв”Ђв”Ђ .cloche/\n   565в†’в”‚   в”њв”Ђв”Ђ develop.cloche        # Workflow definition\n   566в†’в”‚   в”њв”Ђв”Ђ Dockerfile            # Container image\n   567в†’в”‚   в”њв”Ђв”Ђ prompts/\n   568в†’в”‚   в”‚   в”њв”Ђв”Ђ implement.md      # Prompt templates\n   569в†’в”‚   в”‚   в”њв”Ђв”Ђ fix.md\n   570в†’в”‚   в”‚   в””в”Ђв”Ђ update-docs.md\n   571в†’в”‚   в”њв”Ђв”Ђ overrides/            # Files copied on top of /workspace/ in container\n   572в†’в”‚   в”‚   в””в”Ђв”Ђ CLAUDE.md         # Container-specific CLAUDE.md (optional)\n   573в†’в”‚   в””в”Ђв”Ђ <run-id>/             # Runtime state (gitignored)\n   574в†’в”‚       в”њв”Ђв”Ђ prompt.txt        # User prompt (from --prompt flag)\n   575в†’в”‚       в”њв”Ђв”Ђ output/\n   576в†’в”‚       в”‚   в”њв”Ђв”Ђ full.log      # Unified chronological log (status + script + LLM)\n   577в†’в”‚       в”‚   в”њв”Ђв”Ђ test.log      # Per-step script output\n   578в†’в”‚       в”‚   в””в”Ђв”Ђ llm-impl.log  # Per-step LLM conversation output\n   579в†’в”‚       в”њв”Ђв”Ђ attempt_count/\n   580в†’в”‚       в”‚   в””в”Ђв”Ђ fix           # Retry counter for max_attempts\n   581в†’в”‚       в””в”Ђв”Ђ history.log       # Step execution log\n   582в†’в”њв”Ђв”Ђ src/                      # Existing project source (untouched)\n   583в†’в”њв”Ђв”Ђ CLAUDE.md                 # Host CLAUDE.md\n   584в†’в””в”Ђв”Ђ .git/\n   585в†’```\n   586в†’\n   587в†’## Daemon Configuration\n   588в†’\n   589в†’| Variable | Default | Description |\n   590в†’|----------|---------|-------------|\n   591в†’| `CLOCHE_LISTEN` | `unix:///tmp/cloche.sock` | Listen address (unix socket or TCP) |\n   592в†’| `CLOCHE_DB` | `cloche.db` | SQLite database path |\n   593в†’| `CLOCHE_RUNTIME` | `docker` | `docker` (container) or `local` (subprocess, for dev) |\n   594в†’| `CLOCHE_IMAGE` | `cloche-agent:latest` | Default Docker image |\n   595в†’| `CLOCHE_HTTP` | вЂ” | HTTP address for the web dashboard. Not started unless set. |\n   596в†’| `CLOCHE_AGENT_PATH` | (auto-detected) | Path to `cloche-agent` binary (local runtime) |\n   597в†’| `CLOCHE_LLM_COMMAND` | вЂ” | Command for LLM calls вЂ” evolution and merge conflict resolution (e.g. `claude`) |\n   598в†’| `ANTHROPIC_API_KEY` | вЂ” | Passed into Docker containers |\n   599в†’| `CLOCHE_EXTRA_MOUNTS` | вЂ” | Extra bind mounts (comma-separated `host:container`) |\n   600в†’| `CLOCHE_EXTRA_ENV` | вЂ” | Extra env vars (comma-separated `KEY=VALUE`) |\n   601в†’\n   602в†’### Client Configuration\n   603в†’\n   604в†’| Variable | Default | Description |\n   605в†’|----------|---------|-------------|\n   606в†’| `CLOCHE_ADDR` | `unix:///tmp/cloche.sock` | Daemon address (gRPC) |\n   607в†’| `CLOCHE_HTTP` | `localhost:8080` | Daemon HTTP address (web dashboard, `cloche logs --follow`) |\n   608в†’\n   609в†’## Build Commands\n   610в†’\n   611в†’```\n   612в†’make build          # Build all binaries to bin/\n   613в†’make test           # Run all tests\n   614в†’make test-short     # Run tests (skip slow ones)\n   615в†’make lint           # Run go vet\n   616в†’make proto          # Regenerate gRPC code from protobuf\n   617в†’make docker-build   # Build the cloche-agent Docker image\n   618в†’make install        # Build, install to ~/.local/bin/, restart daemon\n   619в†’make clean          # Remove bin/\n   620в†’```\n   621в†’"}]},"parent_tool_use_id":null,"session_id":"9cfeee3f-a672-42d2-aba9-acde9fa5975c","uuid":"2ca6d804-6a33-4831-a3cc-7b8c3c51b348","tool_use_result":{"type":"text","file":{"filePath":"/workspace/docs/USAGE.md","content":"# Usage\n\nCloche runs containerized workflows for autonomous coding agents. You write a\nworkflow graph in the `.cloche` DSL, point Cloche at a project directory, and it\nhandles execution, retry logic, and status tracking.\n\n## Prerequisites\n\n- Go 1.25+\n- Docker\n- Git\n- An `ANTHROPIC_API_KEY` (for agent steps using Claude Code)\n\nFor detailed installation options (pre-built binaries, `go install`, Homebrew,\nDocker-based usage), see [INSTALL.md](INSTALL.md).\n\n## Quick Start\n\n### 1. Build everything\n\n```\nmake build\nmake docker-build\n```\n\nThis produces `bin/cloche`, `bin/cloched`, `bin/cloche-agent`, and the\n`cloche-agent:latest` Docker image.\n\n### 2. Start the daemon\n\n```\nbin/cloched\n```\n\nThe daemon listens on a Unix socket at `/tmp/cloche.sock` by default. It\nmanages Docker containers, tracks run state in SQLite, and handles\ncontainer cleanup. Containers are automatically removed after successful\nruns unless `--keep-container` is set. Failed runs always keep their\ncontainer for debugging.\n\nTo enable the web dashboard, set `CLOCHE_HTTP` (e.g.\n`CLOCHE_HTTP=:8080 bin/cloched`). The dashboard is not started unless\nthis variable is set.\n\n### 3. Run a workflow\n\nFrom your project directory (must be inside a git repository):\n\n```\ncd my-project\ncloche run --workflow develop --prompt \"Add user authentication\"\n```\n\nThis will:\n1. Write your prompt to `.cloche/<run-id>/prompt.txt`\n2. Create a Docker container and copy your entire project into it (no bind mounts)\n3. Apply any override files from `.cloche/overrides/` on top\n4. Start the container, which runs `cloche-agent` to walk the workflow graph\n5. When the workflow finishes, the daemon extracts results to a `cloche/<run-id>` branch\n\n### 4. Monitor progress\n\n```\ncloche status <run-id>\ncloche list\n```\n\n### 5. Get the results\n\nWhen the run completes, the agent's work is on a git branch:\n\n```\ngit branch | grep cloche/\ngit diff main..cloche/<run-id>\n```\n\nTo merge results into your working branch:\n\n```\ngit merge cloche/<run-id>\n# or cherry-pick, rebase, etc.\n```\n\nTo clean up run branches:\n\n```\ngit branch -D cloche/<run-id>\n```\n\n## Container Isolation Model\n\nCloche provides **total filesystem isolation** between the host and container:\n\n- **Files in**: `docker cp` copies the entire project root into the container at\n  `/workspace/`. No bind mounts for project files. Override files from\n  `.cloche/overrides/` are then copied on top (e.g., a container-specific\n  `CLAUDE.md`). The `.git/` directory is included so agents have git context.\n- **Files out**: When the workflow completes, the daemon extracts results from\n  the container via `docker cp` into a git worktree and commits them to a\n  `cloche/<run-id>` branch.\n- **Auth mounts**: `~/.claude` and `~/.claude.json` are bind-mounted read-only\n  for Claude Code OAuth session reuse. `ANTHROPIC_API_KEY` is passed as an\n  environment variable.\n- **Network**: Containers have network access (needed for API calls).\n\nYour project directory is never modified by the container. All changes live\non the run branch until you explicitly merge them.\n\n## CLI Reference\n\n### `cloche init`\n\nScaffold a new Cloche project in the current directory.\n\n```\ncloche init [--workflow <name>] [--image <base>]\n```\n\n| Flag | Default | Description |\n|------|---------|-------------|\n| `--workflow <name>` | `develop` | Workflow name. Creates `.cloche/<name>.cloche`. |\n| `--image <base>` | `ubuntu:24.04` | Base Docker image for the generated Dockerfile. |\n\nCreates `.cloche/` with a workflow file, Dockerfile, and prompt templates\n(`implement.md`, `fix.md`, `update-docs.md`). Skips files that already exist.\nAlso adds gitignore entries for runtime state directories.\n\n### `cloche health`\n\nShow project health summary based on recent run results.\n\n```\ncloche health\n```\n\nRequires `CLOCHE_HTTP` to be set (e.g. `export CLOCHE_HTTP=localhost:8080`).\nFetches health data from the daemon's HTTP API (`GET /api/projects`) and\ndisplays a table with per-project pass/fail counts:\n\n```\nPROJECT          STATUS    PASSED  FAILED  TOTAL\nmy-project       green     5       0       5\nother-project    yellow    3       2       5\n```\n\nStatus is colored (green/yellow/red) when output is a TTY.\n\n### `cloche run`\n\nLaunch a workflow run.\n\n```\ncloche run --workflow <name> [--prompt \"...\"] [--keep-container]\n```\n\n| Flag | Description |\n|------|-------------|\n| `--workflow <name>` | Workflow name. Resolves to `.cloche/<name>.cloche` in the project directory. |\n| `--prompt \"...\"`, `-p` | Inline prompt written to `.cloche/<run-id>/prompt.txt` and injected into agent steps. |\n| `--keep-container` | Keep the Docker container even on success (default: remove on success). Failed runs always keep their container for debugging. |\n\nThe current working directory is used as the project directory. It must be\ninside a git repository (Cloche needs the repo root for result extraction\nvia git worktrees).\n\nWhen starting a run, the daemon checks whether the Docker image is up-to-date\nwith the project's `.cloche/Dockerfile`. If the Dockerfile has changed since\nthe last build (tracked via a SHA-256 label on the image), the daemon rebuilds\nthe image automatically before launching the container.\n\n### `cloche status`\n\nCheck the status of a run.\n\n```\ncloche status <run-id>\n```\n\nOutput includes the run state, active steps, and per-step results with timestamps.\n\n### `cloche list`\n\nList runs (last hour by default).\n\n```\ncloche list [--all]\n```\n\n| Flag | Description |\n|------|-------------|\n| `--all` | Show all runs, not just the last hour. |\n\nColumns: run ID, workflow name, state, container ID (if running), error message (if failed).\n\n### `cloche logs`\n\nShow logs for a run.\n\n```\ncloche logs <run-id> [--step <name>] [--type <full|script|llm>] [--follow]\n```\n\n| Flag | Description |\n|------|-------------|\n| `--step <name>` | Show only logs for the specified step. |\n| `--type <full\\|script\\|llm>` | Show only logs of the specified type (`full` = unified log, `script` = script output, `llm` = LLM conversation). |\n| `--follow`, `-f` | Stream live log lines via SSE. Color-coded by type: status (blue), LLM (green), script (default). Exits when the run completes. Connects to the daemon's HTTP endpoint (see `CLOCHE_HTTP` in Client Configuration). |\n\nWithout flags, shows the unified log (`full.log`) if available, otherwise streams\nstep start/completion events and run results.\nWith `--follow`, connects to the SSE endpoint and prints log lines in real-time.\n\n### `cloche poll`\n\nWait for a run to finish, printing progress updates.\n\n```\ncloche poll <run-id>\n```\n\nPolls every 2 seconds. Exits 0 on success, 1 on failure or if the container\ndies unexpectedly.\n\n### `cloche stop`\n\nCancel a running workflow.\n\n```\ncloche stop <run-id>\n```\n\n### `cloche delete`\n\nDelete a retained Docker container. Accepts either a Docker container name/ID\nor a Cloche run ID. If given a run ID, the daemon looks up the associated\ncontainer.\n\n```\ncloche delete <container-or-run-id>\n```\n\n### `cloche orchestrate`\n\nDispatch ready workflow runs for the current project. Checks the project's\nissue tracker for unclaimed tasks, generates prompts, and launches runs.\n\n```\ncloche orchestrate\n```\n\nUses the current working directory as the project directory. Prints \"No ready\nwork found.\" if there are no tasks to dispatch, or \"Dispatched N run(s).\"\nwith the count.\n\n### `cloche shutdown`\n\nShut down the daemon.\n\n```\ncloche shutdown\n```\n\n## Setting Up a New Project\n\n### 1. Scaffold the project\n\nRun `cloche init` from your project root to create the `.cloche/` directory with\ndefault workflow, Dockerfile, and prompt templates:\n\n```\ncd my-project\ncloche init\n```\n\nOr create the structure manually:\n\n### 2. Create a workflow file\n\nAdd `.cloche/<name>.cloche`:\n\n```\nworkflow \"develop\" {\n  step implement {\n    prompt = file(\".cloche/prompts/implement.md\")\n    results = [success, fail]\n  }\n\n  step test {\n    run = \"make test 2>&1\"\n    results = [success, fail]\n  }\n\n  step fix {\n    prompt = file(\".cloche/prompts/fix.md\")\n    max_attempts = \"2\"\n    results = [success, fail, give-up]\n  }\n\n  step update-docs {\n    prompt = file(\".cloche/prompts/update-docs.md\")\n    results = [success, fail]\n  }\n\n  implement:success -> test\n  implement:fail -> abort\n\n  test:success -> update-docs\n  test:fail -> fix\n\n  fix:success -> test\n  fix:fail -> abort\n  fix:give-up -> abort\n\n  update-docs:success -> done\n  update-docs:fail -> done\n}\n```\n\n### 3. Write prompt templates\n\nCreate `.cloche/prompts/` with markdown files:\n\n**`.cloche/prompts/implement.md`** вЂ” Instructions for the initial implementation:\n```markdown\nYou are working on a project. Implement the following change:\n\n## User Request\n(The user prompt is injected automatically by the agent adapter)\n\n## Guidelines\n- Follow existing project conventions\n- Write tests for new functionality\n- Run tests locally before declaring success\n```\n\n**`.cloche/prompts/fix.md`** вЂ” Instructions for fixing failures:\n```markdown\nThe previous attempt had failures. Review the output logs in .cloche/output/\nand fix the issues.\n\n## Guidelines\n- Read the test/lint output carefully\n- Fix the root cause, not the symptoms\n- Run tests again to verify your fix\n```\n\n**`.cloche/prompts/update-docs.md`** вЂ” Instructions for keeping docs in sync:\n```markdown\nReview the CLI source code and update usage documentation to reflect any changes.\n```\n\n### 4. Add overrides (optional)\n\nFiles in `.cloche/overrides/` are copied on top of `/workspace/` in the\ncontainer. Use this for container-specific configuration:\n\n```\n.cloche/overrides/\n  CLAUDE.md              # Container-specific CLAUDE.md (replaces host version)\n```\n\n### 5. Make sure your project builds in the container\n\nThe default Dockerfile generated by `cloche init` uses `ubuntu:24.04` as its\nbase image (configurable via `--image`). If your project needs different\ndependencies, edit `.cloche/Dockerfile`:\n\n```dockerfile\nFROM golang:1.25 AS builder\nWORKDIR /src\nCOPY go.mod go.sum ./\nRUN go mod download\nCOPY . .\nRUN CGO_ENABLED=0 go build -o /cloche-agent ./cmd/cloche-agent\n\nFROM ubuntu:24.04\nRUN apt-get update && apt-get install -y git <your-deps> && rm -rf /var/lib/apt/lists/*\nRUN npm install -g @anthropic-ai/claude-code\nCOPY --from=builder /cloche-agent /usr/local/bin/cloche-agent\nRUN useradd -m -s /bin/bash agent\nWORKDIR /workspace\nRUN chown agent:agent /workspace\nUSER agent\n```\n\nKey requirements for the image:\n- `cloche-agent` binary at `/usr/local/bin/cloche-agent`\n- `git` installed (for pushing results back)\n- An `agent` user (cloche wraps the command with `chown` + `su agent`)\n- `/workspace` as the working directory\n- Your project's build dependencies\n\nThe daemon automatically rebuilds the image when `.cloche/Dockerfile` changes\n(see `cloche run` above). To build manually:\n```\ndocker build -t my-project-agent -f .cloche/Dockerfile .\nCLOCHE_IMAGE=my-project-agent:latest bin/cloched\n```\n\n### 6. Run it\n\n```\ncd my-project\ncloche run --workflow develop --prompt \"Add feature X\"\n```\n\n## Writing Workflows\n\nWorkflow files use the `.cloche` extension and live in the `.cloche/` directory. See\n[workflows.md](workflows.md) for full DSL reference.\n\n### Step Types\n\n**Agent steps** (has `prompt`) вЂ” Invokes a coding agent autonomously:\n\n```\nstep implement {\n  prompt = file(\".cloche/prompts/implement.md\")\n  results = [success, fail]\n}\n```\n\n**Script steps** (has `run`) вЂ” Runs a shell command:\n\n```\nstep test {\n  run = \"make test 2>&1\"\n  results = [success, fail]\n}\n```\n\n### Wiring\n\nConnect steps with `step:result -> next_step`:\n\n```\nimplement:success -> test\nimplement:fail -> abort\ntest:success -> done\ntest:fail -> fix\n```\n\n`done` and `abort` are built-in terminals for success and failure.\n\n### Retry Loops\n\nWire failures back to earlier steps:\n\n```\ntest:fail -> fix\nfix:success -> test    // retry the test\nfix:fail -> abort\n```\n\n### Max Attempts\n\nLimit retries on agent steps. When exhausted, the step returns `give-up`:\n\n```\nstep fix {\n  prompt = file(\".cloche/prompts/fix.md\")\n  max_attempts = \"2\"\n  results = [success, fail, give-up]\n}\n```\n\n### Parallel Branches\n\nWire one result to multiple targets for concurrent execution:\n\n```\ntest:success -> lint\ntest:success -> quality\n```\n\n### Collect (Join)\n\nSynchronize parallel branches:\n\n```\ncollect all(lint:success, quality:success) -> done\n```\n\n`all` fires when every condition is met. `any` fires when at least one is.\n\n### Agent Command Override\n\nAgent steps use Claude Code by default. Override per-step:\n\n```\nstep implement {\n  prompt = \"...\"\n  agent_command = \"aider\"\n  results = [success, fail]\n}\n```\n\nOr at the workflow level via a `container` block:\n\n```\nworkflow \"develop\" {\n  container {\n    agent_command = \"gemini\"\n  }\n  ...\n}\n```\n\nOr globally via `CLOCHE_AGENT_COMMAND` environment variable.\n\nPriority (highest to lowest): step-level `agent_command`, workflow-level\n`container { agent_command }`, `CLOCHE_AGENT_COMMAND` env var, default (`claude`).\n\n### Agent Fallback Chains\n\nUse a comma-separated list in `agent_command` to configure fallback chains. If\nthe first agent errors without reporting a result, the system tries the next:\n\n```\nstep implement {\n  prompt = \"...\"\n  agent_command = \"claude,gemini,codex\"\n  results = [success, fail]\n}\n```\n\nFallback rules:\n- **Command not found or failed to start** вЂ” fall back to next command\n- **Exit non-zero without `CLOCHE_RESULT` marker** вЂ” fall back to next command\n- **Exit non-zero with `CLOCHE_RESULT` marker** вЂ” use that result (no fallback)\n- **Exit 0** вЂ” use result (no fallback)\n- **All commands fail to start** вЂ” step returns an error\n- **Last command crashes without marker** вЂ” step returns `fail`\n\nKnown agents have default arguments (e.g., Claude gets\n`-p --output-format text --dangerously-skip-permissions`). Other agents receive\nthe prompt on stdin with no extra flags. Override with `agent_args` at the step\nor workflow level.\n\n## Result Protocol\n\nSteps report results by writing a marker to stdout:\n\n```\nCLOCHE_RESULT:<name>\n```\n\nFor script steps, if no marker is written, the exit code determines the result:\n0 = `success`, non-zero = `fail`. Agent steps follow the same convention.\n\n## Prompt Assembly\n\nWhen an agent step runs, Cloche assembles a prompt from multiple sources:\n\n1. The step's `prompt` content (inline or from `file()`)\n2. The user prompt from `.cloche/<run-id>/prompt.txt` (set via `--prompt`)\n3. Validation output from `.cloche/<run-id>/output/*.log` (output from previous script steps)\n4. Result selection instructions listing the step's declared results\n\n## Project Directory Layout\n\n```\nmy-project/\nв”њв”Ђв”Ђ .cloche/\nв”‚   в”њв”Ђв”Ђ develop.cloche        # Workflow definition\nв”‚   в”њв”Ђв”Ђ Dockerfile            # Container image\nв”‚   в”њв”Ђв”Ђ prompts/\nв”‚   в”‚   в”њв”Ђв”Ђ implement.md      # Prompt templates\nв”‚   в”‚   в”њв”Ђв”Ђ fix.md\nв”‚   в”‚   в””в”Ђв”Ђ update-docs.md\nв”‚   в”њв”Ђв”Ђ overrides/            # Files copied on top of /workspace/ in container\nв”‚   в”‚   в””в”Ђв”Ђ CLAUDE.md         # Container-specific CLAUDE.md (optional)\nв”‚   в””в”Ђв”Ђ <run-id>/             # Runtime state (gitignored)\nв”‚       в”њв”Ђв”Ђ prompt.txt        # User prompt (from --prompt flag)\nв”‚       в”њв”Ђв”Ђ output/\nв”‚       в”‚   в”њв”Ђв”Ђ full.log      # Unified chronological log (status + script + LLM)\nв”‚       в”‚   в”њв”Ђв”Ђ test.log      # Per-step script output\nв”‚       в”‚   в””в”Ђв”Ђ llm-impl.log  # Per-step LLM conversation output\nв”‚       в”њв”Ђв”Ђ attempt_count/\nв”‚       в”‚   в””в”Ђв”Ђ fix           # Retry counter for max_attempts\nв”‚       в””в”Ђв”Ђ history.log       # Step execution log\nв”њв”Ђв”Ђ src/                      # Existing project source (untouched)\nв”њв”Ђв”Ђ CLAUDE.md                 # Host CLAUDE.md\nв””в”Ђв”Ђ .git/\n```\n\n## Daemon Configuration\n\n| Variable | Default | Description |\n|----------|---------|-------------|\n| `CLOCHE_LISTEN` | `unix:///tmp/cloche.sock` | Listen address (unix socket or TCP) |\n| `CLOCHE_DB` | `cloche.db` | SQLite database path |\n| `CLOCHE_RUNTIME` | `docker` | `docker` (container) or `local` (subprocess, for dev) |\n| `CLOCHE_IMAGE` | `cloche-agent:latest` | Default Docker image |\n| `CLOCHE_HTTP` | вЂ” | HTTP address for the web dashboard. Not started unless set. |\n| `CLOCHE_AGENT_PATH` | (auto-detected) | Path to `cloche-agent` binary (local runtime) |\n| `CLOCHE_LLM_COMMAND` | вЂ” | Command for LLM calls вЂ” evolution and merge conflict resolution (e.g. `claude`) |\n| `ANTHROPIC_API_KEY` | вЂ” | Passed into Docker containers |\n| `CLOCHE_EXTRA_MOUNTS` | вЂ” | Extra bind mounts (comma-separated `host:container`) |\n| `CLOCHE_EXTRA_ENV` | вЂ” | Extra env vars (comma-separated `KEY=VALUE`) |\n\n### Client Configuration\n\n| Variable | Default | Description |\n|----------|---------|-------------|\n| `CLOCHE_ADDR` | `unix:///tmp/cloche.sock` | Daemon address (gRPC) |\n| `CLOCHE_HTTP` | `localhost:8080` | Daemon HTTP address (web dashboard, `cloche logs --follow`) |\n\n## Build Commands\n\n```\nmake build          # Build all binaries to bin/\nmake test           # Run all tests\nmake test-short     # Run tests (skip slow ones)\nmake lint           # Run go vet\nmake proto          # Regenerate gRPC code from protobuf\nmake docker-build   # Build the cloche-agent Docker image\nmake install        # Build, install to ~/.local/bin/, restart daemon\nmake clean          # Remove bin/\n```\n","numLines":621,"startLine":1,"totalLines":621}}}
