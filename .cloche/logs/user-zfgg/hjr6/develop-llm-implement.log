ted successfully\n\tcompletedSteps := map[string]bool{}\n\tfor _, msg := range msgs {\n\t\tif msg.Type == protocol.MsgStepCompleted {\n\t\t\tcompletedSteps[msg.StepName] = true\n\t\t}\n\t}\n\tassert.True(t, completedSteps[\"impl_a\"], \"impl_a should have completed\")\n\tassert.True(t, completedSteps[\"impl_b\"], \"impl_b should have completed\")\n\n\tlast := msgs[len(msgs)-1]\n\tassert.Equal(t, protocol.MsgRunCompleted, last.Type)\n\tassert.Equal(t, \"succeeded\", last.Result)\n\n\t// Verify each agent ran by checking output files\n\toutputA, err := os.ReadFile(filepath.Join(dir, \".cloche\", \"output\", \"impl_a.log\"))\n\trequire.NoError(t, err)\n\tassert.Contains(t, string(outputA), \"agent-a ran\")\n\n\toutputB, err := os.ReadFile(filepath.Join(dir, \".cloche\", \"output\", \"impl_b.log\"))\n\trequire.NoError(t, err)\n\tassert.Contains(t, string(outputB), \"agent-b ran\")\n}\n\nfunc TestRunner_UnifiedLogScriptSteps(t *testing.T) {"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":183,"cache_read_input_tokens":50534,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":183},"output_tokens":2,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"46174c86-2501-486a-9678-0ff3d3a9d495","uuid":"86fc08e1-1a35-4894-8bda-4c7d1e95e16f"}
