{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018LjDUHopSsHspPoeTifQVz","type":"tool_result","content":"     1→package dsl\n     2→\n     3→import (\n     4→\t\"fmt\"\n     5→\t\"strings\"\n     6→\n     7→\t\"github.com/cloche-dev/cloche/internal/domain\"\n     8→)\n     9→\n    10→type Parser struct {\n    11→\tlexer   *Lexer\n    12→\tcurrent Token\n    13→\tpeek    Token\n    14→}\n    15→\n    16→func Parse(input string) (*domain.Workflow, error) {\n    17→\tp := &Parser{lexer: NewLexer(input)}\n    18→\tp.advance() // load current\n    19→\tp.advance() // load peek\n    20→\treturn p.parseWorkflow()\n    21→}\n    22→\n    23→func (p *Parser) advance() {\n    24→\tp.current = p.peek\n    25→\tp.peek = p.lexer.NextToken()\n    26→}\n    27→\n    28→func (p *Parser) expect(typ TokenType) (Token, error) {\n    29→\tif p.current.Type != typ {\n    30→\t\treturn p.current, fmt.Errorf(\"line %d col %d: expected %v, got %v (%q)\",\n    31→\t\t\tp.current.Line, p.current.Col, typ, p.current.Type, p.current.Literal)\n    32→\t}\n    33→\ttok := p.current\n    34→\tp.advance()\n    35→\treturn tok, nil\n    36→}\n    37→\n    38→func (p *Parser) expectIdent(value string) (Token, error) {\n    39→\tif p.current.Type != TokenIdent || p.current.Literal != value {\n    40→\t\treturn p.current, fmt.Errorf(\"line %d col %d: expected %q, got %q\",\n    41→\t\t\tp.current.Line, p.current.Col, value, p.current.Literal)\n    42→\t}\n    43→\ttok := p.current\n    44→\tp.advance()\n    45→\treturn tok, nil\n    46→}\n    47→\n    48→func (p *Parser) parseWorkflow() (*domain.Workflow, error) {\n    49→\tif _, err := p.expectIdent(\"workflow\"); err != nil {\n    50→\t\treturn nil, err\n    51→\t}\n    52→\n    53→\tnameTok, err := p.expect(TokenString)\n    54→\tif err != nil {\n    55→\t\treturn nil, fmt.Errorf(\"expected workflow name string: %w\", err)\n    56→\t}\n    57→\n    58→\tif _, err := p.expect(TokenLBrace); err != nil {\n    59→\t\treturn nil, err\n    60→\t}\n    61→\n    62→\twf := &domain.Workflow{\n    63→\t\tName:   nameTok.Literal,\n    64→\t\tSteps:  make(map[string]*domain.Step),\n    65→\t\tConfig: make(map[string]string),\n    66→\t}\n    67→\n    68→\tfor p.current.Type != TokenRBrace && p.current.Type != TokenEOF {\n    69→\t\tif p.current.Type == TokenIdent && p.current.Literal == \"step\" {\n    70→\t\t\tstep, err := p.parseStep()\n    71→\t\t\tif err != nil {\n    72→\t\t\t\treturn nil, err\n    73→\t\t\t}\n    74→\t\t\twf.Steps[step.Name] = step\n    75→\t\t\tif wf.EntryStep == \"\" {\n    76→\t\t\t\twf.EntryStep = step.Name\n    77→\t\t\t}\n    78→\t\t} else if p.current.Type == TokenIdent && p.current.Literal == \"collect\" {\n    79→\t\t\tcollect, err := p.parseCollect()\n    80→\t\t\tif err != nil {\n    81→\t\t\t\treturn nil, err\n    82→\t\t\t}\n    83→\t\t\twf.Collects = append(wf.Collects, collect)\n    84→\t\t} else if p.current.Type == TokenIdent && p.peek.Type == TokenLBrace {\n    85→\t\t\tif err := p.parseWorkflowConfig(wf); err != nil {\n    86→\t\t\t\treturn nil, err\n    87→\t\t\t}\n    88→\t\t} else if p.current.Type == TokenIdent && p.peek.Type == TokenColon {\n    89→\t\t\twire, err := p.parseWire()\n    90→\t\t\tif err != nil {\n    91→\t\t\t\treturn nil, err\n    92→\t\t\t}\n    93→\t\t\twf.Wiring = append(wf.Wiring, wire)\n    94→\t\t} else {\n    95→\t\t\treturn nil, fmt.Errorf(\"line %d col %d: unexpected token %q\", p.current.Line, p.current.Col, p.current.Literal)\n    96→\t\t}\n    97→\t}\n    98→\n    99→\tif _, err := p.expect(TokenRBrace); err != nil {\n   100→\t\treturn nil, err\n   101→\t}\n   102→\n   103→\treturn wf, nil\n   104→}\n   105→\n   106→func (p *Parser) parseWorkflowConfig(wf *domain.Workflow) error {\n   107→\tprefix := p.current.Literal // e.g. \"container\"\n   108→\tp.advance()                 // consume prefix ident\n   109→\n   110→\tif _, err := p.expect(TokenLBrace); err != nil {\n   111→\t\treturn err\n   112→\t}\n   113→\n   114→\tfor p.current.Type != TokenRBrace && p.current.Type != TokenEOF {\n   115→\t\tkeyTok, err := p.expect(TokenIdent)\n   116→\t\tif err != nil {\n   117→\t\t\treturn fmt.Errorf(\"expected field name: %w\", err)\n   118→\t\t}\n   119→\n   120→\t\tif _, err := p.expect(TokenEquals); err != nil {\n   121→\t\t\treturn err\n   122→\t\t}\n   123→\n   124→\t\tval, err := p.parseValue()\n   125→\t\tif err != nil {\n   126→\t\t\treturn err\n   127→\t\t}\n   128→\n   129→\t\twf.Config[prefix+\".\"+keyTok.Literal] = val\n   130→\t}\n   131→\n   132→\tif _, err := p.expect(TokenRBrace); err != nil {\n   133→\t\treturn err\n   134→\t}\n   135→\n   136→\treturn nil\n   137→}\n   138→\n   139→func (p *Parser) parseStep() (*domain.Step, error) {\n   140→\tp.advance() // consume \"step\"\n   141→\n   142→\tnameTok, err := p.expect(TokenIdent)\n   143→\tif err != nil {\n   144→\t\treturn nil, fmt.Errorf(\"expected step name: %w\", err)\n   145→\t}\n   146→\n   147→\tif _, err := p.expect(TokenLBrace); err != nil {\n   148→\t\treturn nil, err\n   149→\t}\n   150→\n   151→\tstep := &domain.Step{\n   152→\t\tName:   nameTok.Literal,\n   153→\t\tConfig: make(map[string]string),\n   154→\t}\n   155→\n   156→\tfor p.current.Type != TokenRBrace && p.current.Type != TokenEOF {\n   157→\t\tif err := p.parseStepField(step, \"\"); err != nil {\n   158→\t\t\treturn nil, err\n   159→\t\t}\n   160→\t}\n   161→\n   162→\tif _, err := p.expect(TokenRBrace); err != nil {\n   163→\t\treturn nil, err\n   164→\t}\n   165→\n   166→\t// Infer step type from content\n   167→\t_, hasPrompt := step.Config[\"prompt\"]\n   168→\t_, hasRun := step.Config[\"run\"]\n   169→\t_, hasWorkflowName := step.Config[\"workflow_name\"]\n   170→\n   171→\tcount := 0\n   172→\tif hasPrompt {\n   173→\t\tcount++\n   174→\t}\n   175→\tif hasRun {\n   176→\t\tcount++\n   177→\t}\n   178→\tif hasWorkflowName {\n   179→\t\tcount++\n   180→\t}\n   181→\n   182→\tif count > 1 {\n   183→\t\treturn nil, fmt.Errorf(\"step %q has multiple of 'prompt', 'run', 'workflow_name'; must have exactly one\", step.Name)\n   184→\t}\n   185→\n   186→\tswitch {\n   187→\tcase hasPrompt:\n   188→\t\tstep.Type = domain.StepTypeAgent\n   189→\tcase hasRun:\n   190→\t\tstep.Type = domain.StepTypeScript\n   191→\tcase hasWorkflowName:\n   192→\t\tstep.Type = domain.StepTypeWorkflow\n   193→\tdefault:\n   194→\t\treturn nil, fmt.Errorf(\"step %q has none of 'prompt', 'run', or 'workflow_name'; must have exactly one\", step.Name)\n   195→\t}\n   196→\n   197→\treturn step, nil\n   198→}\n   199→\n   200→func (p *Parser) parseStepField(step *domain.Step, prefix string) error {\n   201→\tkeyTok, err := p.expect(TokenIdent)\n   202→\tif err != nil {\n   203→\t\treturn fmt.Errorf(\"expected field name: %w\", err)\n   204→\t}\n   205→\n   206→\tkey := keyTok.Literal\n   207→\tif prefix != \"\" {\n   208→\t\tkey = prefix + \".\" + key\n   209→\t}\n   210→\n   211→\t// Sub-block (e.g., container { ... })\n   212→\tif p.current.Type == TokenLBrace {\n   213→\t\tp.advance() // consume {\n   214→\t\tfor p.current.Type != TokenRBrace && p.current.Type != TokenEOF {\n   215→\t\t\tif err := p.parseStepField(step, key); err != nil {\n   216→\t\t\t\treturn err\n   217→\t\t\t}\n   218→\t\t}\n   219→\t\tp.advance() // consume }\n   220→\t\treturn nil\n   221→\t}\n   222→\n   223→\tif _, err := p.expect(TokenEquals); err != nil {\n   224→\t\treturn err\n   225→\t}\n   226→\n   227→\tif key == \"results\" {\n   228→\t\tresults, err := p.parseIdentList()\n   229→\t\tif err != nil {\n   230→\t\t\treturn err\n   231→\t\t}\n   232→\t\tstep.Results = results\n   233→\t} else if p.current.Type == TokenLBracket {\n   234→\t\tvalues, err := p.parseStringList()\n   235→\t\tif err != nil {\n   236→\t\t\treturn err\n   237→\t\t}\n   238→\t\tstep.Config[key] = strings.Join(values, \",\")\n   239→\t} else {\n   240→\t\tval, err := p.parseValue()\n   241→\t\tif err != nil {\n   242→\t\t\treturn err\n   243→\t\t}\n   244→\t\tstep.Config[key] = val\n   245→\t}\n   246→\n   247→\treturn nil\n   248→}\n   249→\n   250→func (p *Parser) parseIdentList() ([]string, error) {\n   251→\tif _, err := p.expect(TokenLBracket); err != nil {\n   252→\t\treturn nil, err\n   253→\t}\n   254→\n   255→\tvar items []string\n   256→\tfor p.current.Type != TokenRBracket && p.current.Type != TokenEOF {\n   257→\t\ttok, err := p.expect(TokenIdent)\n   258→\t\tif err != nil {\n   259→\t\t\treturn nil, err\n   260→\t\t}\n   261→\t\titems = append(items, tok.Literal)\n   262→\t\tif p.current.Type == TokenComma {\n   263→\t\t\tp.advance()\n   264→\t\t}\n   265→\t}\n   266→\n   267→\tif _, err := p.expect(TokenRBracket); err != nil {\n   268→\t\treturn nil, err\n   269→\t}\n   270→\n   271→\treturn items, nil\n   272→}\n   273→\n   274→func (p *Parser) parseStringList() ([]string, error) {\n   275→\tif _, err := p.expect(TokenLBracket); err != nil {\n   276→\t\treturn nil, err\n   277→\t}\n   278→\n   279→\tvar items []string\n   280→\tfor p.current.Type != TokenRBracket && p.current.Type != TokenEOF {\n   281→\t\ttok, err := p.expect(TokenString)\n   282→\t\tif err != nil {\n   283→\t\t\treturn nil, err\n   284→\t\t}\n   285→\t\titems = append(items, tok.Literal)\n   286→\t\tif p.current.Type == TokenComma {\n   287→\t\t\tp.advance()\n   288→\t\t}\n   289→\t}\n   290→\n   291→\tif _, err := p.expect(TokenRBracket); err != nil {\n   292→\t\treturn nil, err\n   293→\t}\n   294→\n   295→\treturn items, nil\n   296→}\n   297→\n   298→func (p *Parser) parseValue() (string, error) {\n   299→\tif p.current.Type == TokenString {\n   300→\t\ttok := p.current\n   301→\t\tp.advance()\n   302→\t\treturn tok.Literal, nil\n   303→\t}\n   304→\n   305→\tif p.current.Type == TokenIdent {\n   306→\t\tvar buf strings.Builder\n   307→\t\tbuf.WriteString(p.current.Literal)\n   308→\t\tp.advance()\n   309→\n   310→\t\t// Function call: file(\"...\")\n   311→\t\tif p.current.Type == TokenLParen {\n   312→\t\t\tbuf.WriteRune('(')\n   313→\t\t\tp.advance()\n   314→\t\t\tfor p.current.Type != TokenRParen && p.current.Type != TokenEOF {\n   315→\t\t\t\tif p.current.Type == TokenString {\n   316→\t\t\t\t\tbuf.WriteRune('\"')\n   317→\t\t\t\t\tbuf.WriteString(p.current.Literal)\n   318→\t\t\t\t\tbuf.WriteRune('\"')\n   319→\t\t\t\t} else {\n   320→\t\t\t\t\tbuf.WriteString(p.current.Literal)\n   321→\t\t\t\t}\n   322→\t\t\t\tp.advance()\n   323→\t\t\t}\n   324→\t\t\tbuf.WriteRune(')')\n   325→\t\t\tp.advance() // consume )\n   326→\t\t}\n   327→\n   328→\t\t// Dotted path: step.code.output\n   329→\t\tfor p.current.Type == TokenDot {\n   330→\t\t\tbuf.WriteRune('.')\n   331→\t\t\tp.advance()\n   332→\t\t\tif p.current.Type == TokenIdent {\n   333→\t\t\t\tbuf.WriteString(p.current.Literal)\n   334→\t\t\t\tp.advance()\n   335→\t\t\t}\n   336→\t\t}\n   337→\n   338→\t\treturn buf.String(), nil\n   339→\t}\n   340→\n   341→\treturn \"\", fmt.Errorf(\"line %d col %d: expected value, got %q\", p.current.Line, p.current.Col, p.current.Literal)\n   342→}\n   343→\n   344→func (p *Parser) parseWire() (domain.Wire, error) {\n   345→\tfromTok := p.current\n   346→\tp.advance()\n   347→\n   348→\tif _, err := p.expect(TokenColon); err != nil {\n   349→\t\treturn domain.Wire{}, err\n   350→\t}\n   351→\n   352→\tresultTok, err := p.expect(TokenIdent)\n   353→\tif err != nil {\n   354→\t\treturn domain.Wire{}, err\n   355→\t}\n   356→\n   357→\tif _, err := p.expect(TokenArrow); err != nil {\n   358→\t\treturn domain.Wire{}, err\n   359→\t}\n   360→\n   361→\ttoTok, err := p.expect(TokenIdent)\n   362→\tif err != nil {\n   363→\t\treturn domain.Wire{}, err\n   364→\t}\n   365→\n   366→\treturn domain.Wire{\n   367→\t\tFrom:   fromTok.Literal,\n   368→\t\tResult: resultTok.Literal,\n   369→\t\tTo:     toTok.Literal,\n   370→\t}, nil\n   371→}\n   372→\n   373→func (p *Parser) parseCollect() (domain.Collect, error) {\n   374→\tp.advance() // consume \"collect\"\n   375→\n   376→\tmodeTok, err := p.expect(TokenIdent)\n   377→\tif err != nil {\n   378→\t\treturn domain.Collect{}, fmt.Errorf(\"expected 'all' or 'any': %w\", err)\n   379→\t}\n   380→\n   381→\tvar mode domain.CollectMode\n   382→\tswitch modeTok.Literal {\n   383→\tcase \"all\":\n   384→\t\tmode = domain.CollectAll\n   385→\tcase \"any\":\n   386→\t\tmode = domain.CollectAny\n   387→\tdefault:\n   388→\t\treturn domain.Collect{}, fmt.Errorf(\"line %d col %d: expected 'all' or 'any', got %q\",\n   389→\t\t\tmodeTok.Line, modeTok.Col, modeTok.Literal)\n   390→\t}\n   391→\n   392→\tif _, err := p.expect(TokenLParen); err != nil {\n   393→\t\treturn domain.Collect{}, err\n   394→\t}\n   395→\n   396→\tvar conditions []domain.WireCondition\n   397→\tfor p.current.Type != TokenRParen && p.current.Type != TokenEOF {\n   398→\t\tstepTok, err := p.expect(TokenIdent)\n   399→\t\tif err != nil {\n   400→\t\t\treturn domain.Collect{}, fmt.Errorf(\"expected step name in collect: %w\", err)\n   401→\t\t}\n   402→\t\tif _, err := p.expect(TokenColon); err != nil {\n   403→\t\t\treturn domain.Collect{}, err\n   404→\t\t}\n   405→\t\tresultTok, err := p.expect(TokenIdent)\n   406→\t\tif err != nil {\n   407→\t\t\treturn domain.Collect{}, fmt.Errorf(\"expected result name in collect: %w\", err)\n   408→\t\t}\n   409→\t\tconditions = append(conditions, domain.WireCondition{Step: stepTok.Literal, Result: resultTok.Literal})\n   410→\t\tif p.current.Type == TokenComma {\n   411→\t\t\tp.advance()\n   412→\t\t}\n   413→\t}\n   414→\n   415→\tif _, err := p.expect(TokenRParen); err != nil {\n   416→\t\treturn domain.Collect{}, err\n   417→\t}\n   418→\tif _, err := p.expect(TokenArrow); err != nil {\n   419→\t\treturn domain.Collect{}, err\n   420→\t}\n   421→\n   422→\ttoTok, err := p.expect(TokenIdent)\n   423→\tif err != nil {\n   424→\t\treturn domain.Collect{}, fmt.Errorf(\"expected target step: %w\", err)\n   425→\t}\n   426→\n   427→\treturn domain.Collect{\n   428→\t\tMode:       mode,\n   429→\t\tConditions: conditions,\n   430→\t\tTo:         toTok.Literal,\n   431→\t}, nil\n   432→}\n   433→"}]},"parent_tool_use_id":"toolu_01DjKJiL3pnVwWRgKQMqGBx3","session_id":"46174c86-2501-486a-9678-0ff3d3a9d495","uuid":"ea51e878-8404-4c70-98a6-e980c566d871"}
