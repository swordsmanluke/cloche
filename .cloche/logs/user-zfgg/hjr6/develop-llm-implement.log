{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KzEvkmcTwCXXc7xDiLHCN1","type":"tool_result","content":"   417→func TestPromptAdapter_DefaultArgsForClaude(t *testing.T) {\n   418→\t// Verify New() creates an adapter with \"claude\" as the default command\n   419→\tadapter := prompt.New()\n   420→\tassert.Equal(t, []string{\"claude\"}, adapter.Commands)\n   421→\tassert.Nil(t, adapter.ExplicitArgs)\n   422→}\n   423→\n   424→func TestPromptAdapter_DefaultArgsForKnownAgents(t *testing.T) {\n   425→\tadapter := prompt.New()\n   426→\n   427→\t// Claude should have stream-json args\n   428→\tclaudeArgs := adapter.ArgsFor(\"claude\")\n   429→\tassert.Contains(t, claudeArgs, \"--output-format\")\n   430→\n   431→\t// Gemini and codex should have their own defaults\n   432→\tgeminiArgs := adapter.ArgsFor(\"gemini\")\n   433→\tassert.NotNil(t, geminiArgs)\n   434→\tassert.Contains(t, geminiArgs, \"-p\")\n   435→\n   436→\tcodexArgs := adapter.ArgsFor(\"codex\")\n   437→\tassert.NotNil(t, codexArgs)\n   438→\tassert.Contains(t, codexArgs, \"-q\")\n   439→\n   440→\t// Unknown agent should get no args\n   441→\tunknownArgs := adapter.ArgsFor(\"some-unknown-agent\")\n   442→\tassert.Nil(t, unknownArgs)\n   443→}\n   444→\n   445→func TestPromptAdapter_FallbackOnEmptyOutput(t *testing.T) {\n   446→\tdir := t.TempDir()\n   447→\n   448→\t// First command exits 0 but produces no output (auth/config issue)\n   449→\temptyAgent := filepath.Join(dir, \"empty-agent.sh\")\n   450→\trequire.NoError(t, os.WriteFile(emptyAgent, []byte(\"#!/bin/sh\\ncat > /dev/null\\n\"), 0755))\n   451→\n   452→\t// Second command works fine\n   453→\tgoodAgent := filepath.Join(dir, \"good-agent.sh\")\n   454→\trequire.NoError(t, os.WriteFile(goodAgent, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'good output'\\n\"), 0755))\n   455→\n   456→\tadapter := &prompt.Adapter{\n   457→\t\tCommands: []string{emptyAgent, goodAgent},\n   458→\t}\n   459→\n   460→\tstep := &domain.Step{\n   461→\t\tName:    \"implement\",\n   462→\t\tType:    domain.StepTypeAgent,\n   463→\t\tResults: []string{\"success\", \"fail\"},\n   464→\t\tConfig:  map[string]string{\"prompt\": \"Do something.\"},\n   465→\t}\n   466→\n   467→\tresult, err := adapter.Execute(context.Background(), step, dir)\n   468→\trequire.NoError(t, err)\n   469→\tassert.Equal(t, \"success\", result)\n   470→\n   471→\t// Verify the good agent's output was captured\n   472→\toutputPath := filepath.Join(dir, \".cloche\", \"output\", \"implement.log\")\n   473→\tdata, err := os.ReadFile(outputPath)\n   474→\trequire.NoError(t, err)\n   475→\tassert.Contains(t, string(data), \"good output\")\n   476→}\n   477→\n   478→func TestParseCommands(t *testing.T) {\n   479→\ttests := []struct {\n   480→\t\tinput    string\n   481→\t\texpected []string\n   482→\t}{\n   483→\t\t{\"claude\", []string{\"claude\"}},\n   484→\t\t{\"claude,gemini\", []string{\"claude\", \"gemini\"}},\n   485→\t\t{\"claude, gemini, codex\", []string{\"claude\", \"gemini\", \"codex\"}},\n   486→\t\t{\" claude , gemini , codex \", []string{\"claude\", \"gemini\", \"codex\"}},\n   487→\t\t{\"claude,,gemini\", []string{\"claude\", \"gemini\"}},\n   488→\t\t{\"\", nil},\n   489→\t}\n   490→\tfor _, tc := range tests {\n   491→\t\tt.Run(tc.input, func(t *testing.T) {\n   492→\t\t\tresult := prompt.ParseCommands(tc.input)\n   493→\t\t\tassert.Equal(t, tc.expected, result)\n   494→\t\t})\n   495→\t}\n   496→}\n   497→"}]},"parent_tool_use_id":null,"session_id":"46174c86-2501-486a-9678-0ff3d3a9d495","uuid":"bcbd4f1e-d4e7-48c7-a264-c5fa45a4f1cf","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/agents/prompt/prompt_test.go","content":"func TestPromptAdapter_DefaultArgsForClaude(t *testing.T) {\n\t// Verify New() creates an adapter with \"claude\" as the default command\n\tadapter := prompt.New()\n\tassert.Equal(t, []string{\"claude\"}, adapter.Commands)\n\tassert.Nil(t, adapter.ExplicitArgs)\n}\n\nfunc TestPromptAdapter_DefaultArgsForKnownAgents(t *testing.T) {\n\tadapter := prompt.New()\n\n\t// Claude should have stream-json args\n\tclaudeArgs := adapter.ArgsFor(\"claude\")\n\tassert.Contains(t, claudeArgs, \"--output-format\")\n\n\t// Gemini and codex should have their own defaults\n\tgeminiArgs := adapter.ArgsFor(\"gemini\")\n\tassert.NotNil(t, geminiArgs)\n\tassert.Contains(t, geminiArgs, \"-p\")\n\n\tcodexArgs := adapter.ArgsFor(\"codex\")\n\tassert.NotNil(t, codexArgs)\n\tassert.Contains(t, codexArgs, \"-q\")\n\n\t// Unknown agent should get no args\n\tunknownArgs := adapter.ArgsFor(\"some-unknown-agent\")\n\tassert.Nil(t, unknownArgs)\n}\n\nfunc TestPromptAdapter_FallbackOnEmptyOutput(t *testing.T) {\n\tdir := t.TempDir()\n\n\t// First command exits 0 but produces no output (auth/config issue)\n\temptyAgent := filepath.Join(dir, \"empty-agent.sh\")\n\trequire.NoError(t, os.WriteFile(emptyAgent, []byte(\"#!/bin/sh\\ncat > /dev/null\\n\"), 0755))\n\n\t// Second command works fine\n\tgoodAgent := filepath.Join(dir, \"good-agent.sh\")\n\trequire.NoError(t, os.WriteFile(goodAgent, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'good output'\\n\"), 0755))\n\n\tadapter := &prompt.Adapter{\n\t\tCommands: []string{emptyAgent, goodAgent},\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"implement\",\n\t\tType:    domain.StepTypeAgent,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"prompt\": \"Do something.\"},\n\t}\n\n\tresult, err := adapter.Execute(context.Background(), step, dir)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"success\", result)\n\n\t// Verify the good agent's output was captured\n\toutputPath := filepath.Join(dir, \".cloche\", \"output\", \"implement.log\")\n\tdata, err := os.ReadFile(outputPath)\n\trequire.NoError(t, err)\n\tassert.Contains(t, string(data), \"good output\")\n}\n\nfunc TestParseCommands(t *testing.T) {\n\ttests := []struct {\n\t\tinput    string\n\t\texpected []string\n\t}{\n\t\t{\"claude\", []string{\"claude\"}},\n\t\t{\"claude,gemini\", []string{\"claude\", \"gemini\"}},\n\t\t{\"claude, gemini, codex\", []string{\"claude\", \"gemini\", \"codex\"}},\n\t\t{\" claude , gemini , codex \", []string{\"claude\", \"gemini\", \"codex\"}},\n\t\t{\"claude,,gemini\", []string{\"claude\", \"gemini\"}},\n\t\t{\"\", nil},\n\t}\n\tfor _, tc := range tests {\n\t\tt.Run(tc.input, func(t *testing.T) {\n\t\t\tresult := prompt.ParseCommands(tc.input)\n\t\t\tassert.Equal(t, tc.expected, result)\n\t\t})\n\t}\n}\n","numLines":81,"startLine":417,"totalLines":497}}}
