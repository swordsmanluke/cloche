{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RMWpsm3GEYfCX2VLS6RJHz","type":"tool_result","content":"     1→package protocol\n     2→\n     3→import (\n     4→\t\"bytes\"\n     5→\t\"encoding/json\"\n     6→\t\"fmt\"\n     7→\t\"io\"\n     8→\t\"time\"\n     9→)\n    10→\n    11→type MessageType string\n    12→\n    13→const (\n    14→\tMsgStepStarted  MessageType = \"step_started\"\n    15→\tMsgStepCompleted MessageType = \"step_completed\"\n    16→\tMsgRunCompleted  MessageType = \"run_completed\"\n    17→\tMsgLog           MessageType = \"log\"\n    18→\tMsgError         MessageType = \"error\"\n    19→)\n    20→\n    21→type StatusMessage struct {\n    22→\tType      MessageType `json:\"type\"`\n    23→\tStepName  string      `json:\"step_name,omitempty\"`\n    24→\tResult    string      `json:\"result,omitempty\"`\n    25→\tMessage   string      `json:\"message,omitempty\"`\n    26→\tTimestamp time.Time   `json:\"timestamp\"`\n    27→}\n    28→\n    29→type StatusWriter struct {\n    30→\tw   io.Writer\n    31→\tenc *json.Encoder\n    32→}\n    33→\n    34→func NewStatusWriter(w io.Writer) *StatusWriter {\n    35→\treturn &StatusWriter{w: w, enc: json.NewEncoder(w)}\n    36→}\n    37→\n    38→func (s *StatusWriter) StepStarted(stepName string) {\n    39→\ts.write(StatusMessage{Type: MsgStepStarted, StepName: stepName})\n    40→}\n    41→\n    42→func (s *StatusWriter) StepCompleted(stepName, result string) {\n    43→\ts.write(StatusMessage{Type: MsgStepCompleted, StepName: stepName, Result: result})\n    44→}\n    45→\n    46→func (s *StatusWriter) RunCompleted(result string) {\n    47→\ts.write(StatusMessage{Type: MsgRunCompleted, Result: result})\n    48→}\n    49→\n    50→func (s *StatusWriter) Log(stepName, message string) {\n    51→\ts.write(StatusMessage{Type: MsgLog, StepName: stepName, Message: message})\n    52→}\n    53→\n    54→func (s *StatusWriter) Error(stepName, message string) {\n    55→\ts.write(StatusMessage{Type: MsgError, StepName: stepName, Message: message})\n    56→}\n    57→\n    58→func (s *StatusWriter) write(msg StatusMessage) {\n    59→\tmsg.Timestamp = time.Now()\n    60→\t_ = s.enc.Encode(msg)\n    61→}\n    62→\n    63→func ParseStatusStream(data []byte) ([]StatusMessage, error) {\n    64→\tvar msgs []StatusMessage\n    65→\tdec := json.NewDecoder(bytes.NewReader(data))\n    66→\tfor dec.More() {\n    67→\t\tvar msg StatusMessage\n    68→\t\tif err := dec.Decode(&msg); err != nil {\n    69→\t\t\treturn msgs, fmt.Errorf(\"failed to decode status message: %w\", err)\n    70→\t\t}\n    71→\t\tmsgs = append(msgs, msg)\n    72→\t}\n    73→\treturn msgs, nil\n    74→}\n    75→"}]},"parent_tool_use_id":"toolu_01DjKJiL3pnVwWRgKQMqGBx3","session_id":"46174c86-2501-486a-9678-0ff3d3a9d495","uuid":"87c0b428-c738-4bc2-8349-6c4302522dec"}
