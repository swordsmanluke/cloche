{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VqSUCqh7QBuXFoBuxSQadS","type":"tool_result","content":"     1→package generic_test\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"os\"\n     6→\t\"path/filepath\"\n     7→\t\"testing\"\n     8→\n     9→\t\"github.com/cloche-dev/cloche/internal/adapters/agents/generic\"\n    10→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    11→\t\"github.com/stretchr/testify/assert\"\n    12→\t\"github.com/stretchr/testify/require\"\n    13→)\n    14→\n    15→func TestGenericAdapter_ScriptSuccess(t *testing.T) {\n    16→\tadapter := generic.New()\n    17→\tstep := &domain.Step{\n    18→\t\tName:    \"build\",\n    19→\t\tType:    domain.StepTypeScript,\n    20→\t\tResults: []string{\"success\", \"fail\"},\n    21→\t\tConfig:  map[string]string{\"run\": \"echo hello\"},\n    22→\t}\n    23→\n    24→\tresult, err := adapter.Execute(context.Background(), step, t.TempDir())\n    25→\trequire.NoError(t, err)\n    26→\tassert.Equal(t, \"success\", result)\n    27→}\n    28→\n    29→func TestGenericAdapter_ScriptFailure(t *testing.T) {\n    30→\tadapter := generic.New()\n    31→\tstep := &domain.Step{\n    32→\t\tName:    \"build\",\n    33→\t\tType:    domain.StepTypeScript,\n    34→\t\tResults: []string{\"success\", \"fail\"},\n    35→\t\tConfig:  map[string]string{\"run\": \"exit 1\"},\n    36→\t}\n    37→\n    38→\tresult, err := adapter.Execute(context.Background(), step, t.TempDir())\n    39→\trequire.NoError(t, err)\n    40→\tassert.Equal(t, \"fail\", result)\n    41→}\n    42→\n    43→func TestGenericAdapter_ScriptModifiesFiles(t *testing.T) {\n    44→\tdir := t.TempDir()\n    45→\tadapter := generic.New()\n    46→\tstep := &domain.Step{\n    47→\t\tName:    \"generate\",\n    48→\t\tType:    domain.StepTypeScript,\n    49→\t\tResults: []string{\"success\", \"fail\"},\n    50→\t\tConfig:  map[string]string{\"run\": \"echo 'generated' > output.txt\"},\n    51→\t}\n    52→\n    53→\tresult, err := adapter.Execute(context.Background(), step, dir)\n    54→\trequire.NoError(t, err)\n    55→\tassert.Equal(t, \"success\", result)\n    56→\n    57→\tcontent, err := os.ReadFile(filepath.Join(dir, \"output.txt\"))\n    58→\trequire.NoError(t, err)\n    59→\tassert.Contains(t, string(content), \"generated\")\n    60→}\n    61→\n    62→func TestGenericAdapter_CapturesOutput(t *testing.T) {\n    63→\tdir := t.TempDir()\n    64→\tadapter := generic.New()\n    65→\tstep := &domain.Step{\n    66→\t\tName:    \"test\",\n    67→\t\tType:    domain.StepTypeScript,\n    68→\t\tResults: []string{\"success\", \"fail\"},\n    69→\t\tConfig:  map[string]string{\"run\": \"echo 'hello from test'; echo 'error msg' >&2\"},\n    70→\t}\n    71→\n    72→\tresult, err := adapter.Execute(context.Background(), step, dir)\n    73→\trequire.NoError(t, err)\n    74→\tassert.Equal(t, \"success\", result)\n    75→\n    76→\tlogPath := filepath.Join(dir, \".cloche\", \"output\", \"test.log\")\n    77→\tcontent, err := os.ReadFile(logPath)\n    78→\trequire.NoError(t, err)\n    79→\tassert.Contains(t, string(content), \"hello from test\")\n    80→\tassert.Contains(t, string(content), \"error msg\")\n    81→}\n    82→\n    83→func TestGenericAdapter_CapturesOutputOnFailure(t *testing.T) {\n    84→\tdir := t.TempDir()\n    85→\tadapter := generic.New()\n    86→\tstep := &domain.Step{\n    87→\t\tName:    \"lint\",\n    88→\t\tType:    domain.StepTypeScript,\n    89→\t\tResults: []string{\"success\", \"fail\"},\n    90→\t\tConfig:  map[string]string{\"run\": \"echo 'lint error: bad style'; exit 1\"},\n    91→\t}\n    92→\n    93→\tresult, err := adapter.Execute(context.Background(), step, dir)\n    94→\trequire.NoError(t, err)\n    95→\tassert.Equal(t, \"fail\", result)\n    96→\n    97→\tlogPath := filepath.Join(dir, \".cloche\", \"output\", \"lint.log\")\n    98→\tcontent, err := os.ReadFile(logPath)\n    99→\trequire.NoError(t, err)\n   100→\tassert.Contains(t, string(content), \"lint error: bad style\")\n   101→}\n   102→\n   103→func TestGenericAdapter_StdoutMarkerOverridesExitCode(t *testing.T) {\n   104→\tdir := t.TempDir()\n   105→\tadapter := generic.New()\n   106→\tstep := &domain.Step{\n   107→\t\tName:    \"analyze\",\n   108→\t\tType:    domain.StepTypeScript,\n   109→\t\tResults: []string{\"success\", \"fail\", \"needs_research\"},\n   110→\t\tConfig:  map[string]string{\"run\": \"echo 'analyzing...' && echo 'CLOCHE_RESULT:needs_research'\"},\n   111→\t}\n   112→\n   113→\tresult, err := adapter.Execute(context.Background(), step, dir)\n   114→\trequire.NoError(t, err)\n   115→\tassert.Equal(t, \"needs_research\", result)\n   116→\n   117→\t// Verify marker is stripped from log\n   118→\tlogPath := filepath.Join(dir, \".cloche\", \"output\", \"analyze.log\")\n   119→\tcontent, err := os.ReadFile(logPath)\n   120→\trequire.NoError(t, err)\n   121→\tassert.NotContains(t, string(content), \"CLOCHE_RESULT\")\n   122→\tassert.Contains(t, string(content), \"analyzing...\")\n   123→}\n   124→\n   125→func TestGenericAdapter_MarkerOverridesFailExitCode(t *testing.T) {\n   126→\tdir := t.TempDir()\n   127→\tadapter := generic.New()\n   128→\tstep := &domain.Step{\n   129→\t\tName:    \"triage\",\n   130→\t\tType:    domain.StepTypeScript,\n   131→\t\tResults: []string{\"bug_fix\", \"feature_request\"},\n   132→\t\tConfig:  map[string]string{\"run\": \"echo 'CLOCHE_RESULT:bug_fix' && exit 1\"},\n   133→\t}\n   134→\n   135→\tresult, err := adapter.Execute(context.Background(), step, dir)\n   136→\trequire.NoError(t, err)\n   137→\tassert.Equal(t, \"bug_fix\", result)\n   138→}\n   139→"}]},"parent_tool_use_id":"toolu_01DjKJiL3pnVwWRgKQMqGBx3","session_id":"46174c86-2501-486a-9678-0ff3d3a9d495","uuid":"a1d22cd9-c6ab-4f16-b53d-adf302c570ad"}
