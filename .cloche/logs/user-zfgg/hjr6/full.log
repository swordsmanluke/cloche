[2026-03-07T16:39:30Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DE5x9ssPh6ppJGeuYXiDVR","type":"tool_result","content":"     1→package agent\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"fmt\"\n     6→\t\"io\"\n     7→\t\"os\"\n     8→\t\"path/filepath\"\n     9→\t\"strings\"\n    10→\n    11→\t\"github.com/cloche-dev/cloche/internal/adapters/agents/generic\"\n    12→\t\"github.com/cloche-dev/cloche/internal/adapters/agents/prompt\"\n    13→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    14→\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    15→\t\"github.com/cloche-dev/cloche/internal/engine\"\n    16→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    17→\t\"github.com/cloche-dev/cloche/internal/protocol\"\n    18→)\n    19→\n    20→type RunnerConfig struct {\n    21→\tWorkflowPath string\n    22→\tWorkDir      string\n    23→\tStatusOutput io.Writer\n    24→\tRunID        string\n    25→}\n    26→\n    27→type Runner struct {\n    28→\tcfg RunnerConfig\n    29→}\n    30→\n    31→func NewRunner(cfg RunnerConfig) *Runner {\n    32→\treturn &Runner{\n    33→\t\tcfg: cfg,\n    34→\t}\n    35→}\n    36→\n    37→func (r *Runner) Run(ctx context.Context) error {\n    38→\tdata, err := os.ReadFile(r.cfg.WorkflowPath)\n    39→\tif err != nil {\n    40→\t\treturn fmt.Errorf(\"reading workflow file: %w\", err)\n    41→\t}\n    42→\n    43→\twf, err := dsl.Parse(string(data))\n    44→\tif err != nil {\n    45→\t\treturn fmt.Errorf(\"parsing workflow: %w\", err)\n    46→\t}\n    47→\n    48→\tstatusWriter := protocol.NewStatusWriter(r.cfg.StatusOutput)\n    49→\tgenericAdapter := generic.New()\n    50→\tpromptAdapter := prompt.New()\n    51→\tpromptAdapter.RunID = r.cfg.RunID\n    52→\tpromptAdapter.StatusWriter = statusWriter\n    53→\tif cmd, ok := os.LookupEnv(\"CLOCHE_AGENT_COMMAND\"); ok {\n    54→\t\tpromptAdapter.Commands = prompt.ParseCommands(cmd)\n    55→\t}\n    56→\tif cmd := wf.Config[\"container.agent_command\"]; cmd != \"\" {\n    57→\t\tpromptAdapter.Commands = prompt.ParseCommands(cmd)\n    58→\t}\n    59→\tif args := wf.Config[\"container.agent_args\"]; args != \"\" {\n    60→\t\tpromptAdapter.ExplicitArgs = strings.Fields(args)\n    61→\t}\n    62→\n    63→\t// Reset per-run state from any previous run\n    64→\t_ = os.RemoveAll(filepath.Join(r.cfg.WorkDir, \".cloche\", \"attempt_count\"))\n    65→\t_ = os.RemoveAll(filepath.Join(r.cfg.WorkDir, \".cloche\", \"output\"))\n    66→\n    67→\t// Create unified log writer\n    68→\tulog, err := logstream.New(r.cfg.WorkDir)\n    69→\tif err != nil {\n    70→\t\treturn fmt.Errorf(\"creating unified log: %w\", err)\n    71→\t}\n    72→\tdefer ulog.Close()\n    73→\n    74→\texecutor := &stepExecutor{\n    75→\t\tworkDir:   r.cfg.WorkDir,\n    76→\t\tgeneric:   genericAdapter,\n    77→\t\tprompt:    promptAdapter,\n    78→\t\tlogStream: ulog,\n    79→\t}\n    80→\n    81→\teng := engine.New(executor)\n    82→\teng.SetStatusHandler(&statusReporter{writer: statusWriter, logStream: ulog})\n    83→\n    84→\tprotocol.AppendHistoryMarker(r.cfg.WorkDir, \"workflow:start \"+wf.Name)\n    85→\n    86→\trun, runErr := eng.Run(ctx, wf)\n    87→\tif runErr != nil {\n    88→\t\tprotocol.AppendHistoryMarker(r.cfg.WorkDir, \"workflow:end \"+wf.Name+\" result:failed\")\n    89→\t\tulog.Log(logstream.TypeStatus, \"error: \"+runErr.Error())\n    90→\t\tulog.Log(logstream.TypeStatus, \"run_completed: failed\")\n    91→\t\tstatusWriter.Error(\"\", runErr.Error())\n    92→\t\tstatusWriter.RunCompleted(\"failed\")\n    93→\t\treturn runErr\n    94→\t}\n    95→\n    96→\tprotocol.AppendHistoryMarker(r.cfg.WorkDir, \"workflow:end \"+wf.Name+\" result:\"+string(run.State))\n    97→\n    98→\tulog.Log(logstream.TypeStatus, \"run_completed: \"+string(run.State))\n    99→\tstatusWriter.RunCompleted(string(run.State))\n   100→\treturn nil\n   101→}\n   102→\n   103→type stepExecutor struct {\n   104→\tworkDir   string\n   105→\tgeneric   *generic.Adapter\n   106→\tprompt    *prompt.Adapter\n   107→\tlogStream *logstream.Writer\n   108→}\n   109→\n   110→func (e *stepExecutor) Execute(ctx context.Context, step *domain.Step) (string, error) {\n   111→\tswitch step.Type {\n   112→\tcase domain.StepTypeScript:\n   113→\t\tresult, err := e.generic.Execute(ctx, step, e.workDir)\n   114→\t\te.logStepOutput(step.Name, logstream.TypeScript)\n   115→\t\treturn result, err\n   116→\tcase domain.StepTypeAgent:\n   117→\t\tif _, ok := step.Config[\"run\"]; ok {\n   118→\t\t\tresult, err := e.generic.Execute(ctx, step, e.workDir)\n   119→\t\t\te.logStepOutput(step.Name, logstream.TypeScript)\n   120→\t\t\treturn result, err\n   121→\t\t}\n   122→\t\tif _, ok := step.Config[\"prompt\"]; ok {\n   123→\t\t\tadapter := e.promptAdapterForStep(step)\n   124→\t\t\tresult, err := adapter.Execute(ctx, step, e.workDir)\n   125→\t\t\te.copyToLLMLog(step.Name)\n   126→\t\t\te.logStepOutput(step.Name, logstream.TypeLLM)\n   127→\t\t\treturn result, err\n   128→\t\t}\n   129→\t\treturn \"\", fmt.Errorf(\"agent step %q requires either 'run' or 'prompt' config\", step.Name)\n   130→\tdefault:\n   131→\t\treturn \"\", fmt.Errorf(\"unknown step type: %s\", step.Type)\n   132→\t}\n   133→}\n   134→\n   135→// promptAdapterForStep returns a prompt adapter configured for the given step.\n   136→// If the step has agent_command or agent_args overrides, a copy of the base\n   137→// adapter is returned with those overrides applied, avoiding mutation of the\n   138→// shared adapter (which would be a race condition for parallel steps).\n   139→func (e *stepExecutor) promptAdapterForStep(step *domain.Step) *prompt.Adapter {\n   140→\tcmd := step.Config[\"agent_command\"]\n   141→\targs := step.Config[\"agent_args\"]\n   142→\tif cmd == \"\" && args == \"\" {\n   143→\t\treturn e.prompt\n   144→\t}\n   145→\t// Create a shallow copy with overrides\n   146→\tcp := *e.prompt\n   147→\tif cmd != \"\" {\n   148→\t\tcp.Commands = prompt.ParseCommands(cmd)\n   149→\t}\n   150→\tif args != \"\" {\n   151→\t\tcp.ExplicitArgs = strings.Fields(args)\n   152→\t}\n   153→\treturn &cp\n   154→}\n   155→\n   156→// logStepOutput reads the per-step log file and writes its contents to the unified log.\n   157→func (e *stepExecutor) logStepOutput(stepName string, typ logstream.EntryType) {\n   158→\tpath := filepath.Join(e.workDir, \".cloche\", \"output\", stepName+\".log\")\n   159→\tdata, err := os.ReadFile(path)\n   160→\tif err != nil || len(data) == 0 {\n   161→\t\treturn\n   162→\t}\n   163→\te.logStream.Log(typ, string(data))\n   164→}\n   165→\n   166→// copyToLLMLog copies <step>.log to llm-<step>.log for agent prompt steps.\n   167→func (e *stepExecutor) copyToLLMLog(stepName string) {\n   168→\tsrc := filepath.Join(e.workDir, \".cloche\", \"output\", stepName+\".log\")\n   169→\tdst := filepath.Join(e.workDir, \".cloche\", \"output\", \"llm-\"+stepName+\".log\")\n   170→\tdata, err := os.ReadFile(src)\n   171→\tif err != nil {\n   172→\t\treturn\n   173→\t}\n   174→\t_ = os.WriteFile(dst, data, 0644)\n   175→}\n   176→\n   177→type statusReporter struct {\n   178→\twriter    *protocol.StatusWriter\n   179→\tlogStream *logstream.Writer\n   180→}\n   181→\n   182→func (s *statusReporter) OnStepStart(_ *domain.Run, step *domain.Step) {\n   183→\ts.writer.StepStarted(step.Name)\n   184→\ts.logStream.Log(logstream.TypeStatus, \"step_started: \"+step.Name)\n   185→}\n   186→\n   187→func (s *statusReporter) OnStepComplete(_ *domain.Run, step *domain.Step, result string) {\n   188→\ts.writer.StepCompleted(step.Name, result)\n   189→\ts.logStream.Log(logstream.TypeStatus, \"step_completed: \"+step.Name+\" -> \"+result)\n   190→}\n   191→\n   192→func (s *statusReporter) OnRunComplete(_ *domain.Run) {}\n   193→"}]},"parent_tool_use_id":null,"session_id":"a9440e5b-e6f6-4c81-b349-8ecc9e375ee5","uuid":"44836fdd-a67a-46fd-abfa-6b5205f59040","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/agent/runner.go","content":"package agent\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"io\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"strings\"\n\n\t\"github.com/cloche-dev/cloche/internal/adapters/agents/generic\"\n\t\"github.com/cloche-dev/cloche/internal/adapters/agents/prompt\"\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/dsl\"\n\t\"github.com/cloche-dev/cloche/internal/engine\"\n\t\"github.com/cloche-dev/cloche/internal/logstream\"\n\t\"github.com/cloche-dev/cloche/internal/protocol\"\n)\n\ntype RunnerConfig struct {\n\tWorkflowPath string\n\tWorkDir      string\n\tStatusOutput io.Writer\n\tRunID        string\n}\n\ntype Runner struct {\n\tcfg RunnerConfig\n}\n\nfunc NewRunner(cfg RunnerConfig) *Runner {\n\treturn &Runner{\n\t\tcfg: cfg,\n\t}\n}\n\nfunc (r *Runner) Run(ctx context.Context) error {\n\tdata, err := os.ReadFile(r.cfg.WorkflowPath)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"reading workflow file: %w\", err)\n\t}\n\n\twf, err := dsl.Parse(string(data))\n\tif err != nil {\n\t\treturn fmt.Errorf(\"parsing workflow: %w\", err)\n\t}\n\n\tstatusWriter := protocol.NewStatusWriter(r.cfg.StatusOutput)\n\tgenericAdapter := generic.New()\n\tpromptAdapter := prompt.New()\n\tpromptAdapter.RunID = r.cfg.RunID\n\tpromptAdapter.StatusWriter = statusWriter\n\tif cmd, ok := os.LookupEnv(\"CLOCHE_AGENT_COMMAND\"); ok {\n\t\tpromptAdapter.Commands = prompt.ParseCommands(cmd)\n\t}\n\tif cmd := wf.Config[\"container.agent_command\"]; cmd != \"\" {\n\t\tpromptAdapter.Commands = prompt.ParseCommands(cmd)\n\t}\n\tif args := wf.Config[\"container.agent_args\"]; args != \"\" {\n\t\tpromptAdapter.ExplicitArgs = strings.Fields(args)\n\t}\n\n\t// Reset per-run state from any previous run\n\t_ = os.RemoveAll(filepath.Join(r.cfg.WorkDir, \".cloche\", \"attempt_count\"))\n\t_ = os.RemoveAll(filepath.Join(r.cfg.WorkDir, \".cloche\", \"output\"))\n\n\t// Create unified log writer\n\tulog, err := logstream.New(r.cfg.WorkDir)\n\tif err != nil {\n\t\treturn fmt.Errorf(\"creating unified log: %w\", err)\n\t}\n\tdefer ulog.Close()\n\n\texecutor := &stepExecutor{\n\t\tworkDir:   r.cfg.WorkDir,\n\t\tgeneric:   genericAdapter,\n\t\tprompt:    promptAdapter,\n\t\tlogStream: ulog,\n\t}\n\n\teng := engine.New(executor)\n\teng.SetStatusHandler(&statusReporter{writer: statusWriter, logStream: ulog})\n\n\tprotocol.AppendHistoryMarker(r.cfg.WorkDir, \"workflow:start \"+wf.Name)\n\n\trun, runErr := eng.Run(ctx, wf)\n\tif runErr != nil {\n\t\tprotocol.AppendHistoryMarker(r.cfg.WorkDir, \"workflow:end \"+wf.Name+\" result:failed\")\n\t\tulog.Log(logstream.TypeStatus, \"error: \"+runErr.Error())\n\t\tulog.Log(logstream.TypeStatus, \"run_completed: failed\")\n\t\tstatusWriter.Error(\"\", runErr.Error())\n\t\tstatusWriter.RunCompleted(\"failed\")\n\t\treturn runErr\n\t}\n\n\tprotocol.AppendHistoryMarker(r.cfg.WorkDir, \"workflow:end \"+wf.Name+\" result:\"+string(run.State))\n\n\tulog.Log(logstream.TypeStatus, \"run_completed: \"+string(run.State))\n\tstatusWriter.RunCompleted(string(run.State))\n\treturn nil\n}\n\ntype stepExecutor struct {\n\tworkDir   string\n\tgeneric   *generic.Adapter\n\tprompt    *prompt.Adapter\n\tlogStream *logstream.Writer\n}\n\nfunc (e *stepExecutor) Execute(ctx context.Context, step *domain.Step) (string, error) {\n\tswitch step.Type {\n\tcase domain.StepTypeScript:\n\t\tresult, err := e.generic.Execute(ctx, step, e.workDir)\n\t\te.logStepOutput(step.Name, logstream.TypeScript)\n\t\treturn result, err\n\tcase domain.StepTypeAgent:\n\t\tif _, ok := step.Config[\"run\"]; ok {\n\t\t\tresult, err := e.generic.Execute(ctx, step, e.workDir)\n\t\t\te.logStepOutput(step.Name, logstream.TypeScript)\n\t\t\treturn result, err\n\t\t}\n\t\tif _, ok := step.Config[\"prompt\"]; ok {\n\t\t\tadapter := e.promptAdapterForStep(step)\n\t\t\tresult, err := adapter.Execute(ctx, step, e.workDir)\n\t\t\te.copyToLLMLog(step.Name)\n\t\t\te.logStepOutput(step.Name, logstream.TypeLLM)\n\t\t\treturn result, err\n\t\t}\n\t\treturn \"\", fmt.Errorf(\"agent step %q requires either 'run' or 'prompt' config\", step.Name)\n\tdefault:\n\t\treturn \"\", fmt.Errorf(\"unknown step type: %s\", step.Type)\n\t}\n}\n\n// promptAdapterForStep returns a prompt adapter configured for the given step.\n// If the step has agent_command or agent_args overrides, a copy of the base\n// adapter is returned with those overrides applied, avoiding mutation of the\n// shared adapter (which would be a race condition for parallel steps).\nfunc (e *stepExecutor) promptAdapterForStep(step *domain.Step) *prompt.Adapter {\n\tcmd := step.Config[\"agent_command\"]\n\targs := step.Config[\"agent_args\"]\n\tif cmd == \"\" && args == \"\" {\n\t\treturn e.prompt\n\t}\n\t// Create a shallow copy with overrides\n\tcp := *e.prompt\n\tif cmd != \"\" {\n\t\tcp.Commands = prompt.ParseCommands(cmd)\n\t}\n\tif args != \"\" {\n\t\tcp.ExplicitArgs = strings.Fields(args)\n\t}\n\treturn &cp\n}\n\n// logStepOutput reads the per-step log file and writes its contents to the unified log.\nfunc (e *stepExecutor) logStepOutput(stepName string, typ logstream.EntryType) {\n\tpath := filepath.Join(e.workDir, \".cloche\", \"output\", stepName+\".log\")\n\tdata, err := os.ReadFile(path)\n\tif err != nil || len(data) == 0 {\n\t\treturn\n\t}\n\te.logStream.Log(typ, string(data))\n}\n\n// copyToLLMLog copies <step>.log to llm-<step>.log for agent prompt steps.\nfunc (e *stepExecutor) copyToLLMLog(stepName string) {\n\tsrc := filepath.Join(e.workDir, \".cloche\", \"output\", stepName+\".log\")\n\tdst := filepath.Join(e.workDir, \".cloche\", \"output\", \"llm-\"+stepName+\".log\")\n\tdata, err := os.ReadFile(src)\n\tif err != nil {\n\t\treturn\n\t}\n\t_ = os.WriteFile(dst, data, 0644)\n}\n\ntype statusReporter struct {\n\twriter    *protocol.StatusWriter\n\tlogStream *logstream.Writer\n}\n\nfunc (s *statusReporter) OnStepStart(_ *domain.Run, step *domain.Step) {\n\ts.writer.StepStarted(step.Name)\n\ts.logStream.Log(logstream.TypeStatus, \"step_started: \"+step.Name)\n}\n\nfunc (s *statusReporter) OnStepComplete(_ *domain.Run, step *domain.Step, result string) {\n\ts.writer.StepCompleted(step.Name, result)\n\ts.logStream.Log(logstream.TypeStatus, \"step_completed: \"+step.Name+\" -> \"+result)\n}\n\nfunc (s *statusReporter) OnRunComplete(_ *domain.Run) {}\n","numLines":193,"startLine":1,"totalLines":193}}}
