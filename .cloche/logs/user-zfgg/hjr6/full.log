no default arguments (prompt on stdin only).\n var defaultAgentArgs = map[string][]string{\n \t\"claude\": {\"-p\", \"--output-format\", \"stream-json\", \"--verbose\", \"--dangerously-skip-permissions\"},\n+\t\"gemini\": {\"-p\"},\n+\t\"codex\":  {\"-q\", \"--approval-mode\", \"full-auto\"},\n }\n \n type Adapter struct {\n@@ -39,9 +41,9 @@ func (a *Adapter) Name() string {\n \treturn \"prompt\"\n }\n \n-// argsFor returns the arguments for the given command. If ExplicitArgs is set,\n+// ArgsFor returns the arguments for the given command. If ExplicitArgs is set,\n // it is used for all commands. Otherwise, known agents get their default args.\n-func (a *Adapter) argsFor(command string) []string {\n+func (a *Adapter) ArgsFor(command string) []string {\n \tif a.ExplicitArgs != nil {\n \t\treturn a.ExplicitArgs\n \t}\n@@ -90,7 +92,10 @@ func (a *Adapter) Execute(ctx context.Context, step *domain.Step, workDir string\n \tvar lastErr error\n \tran := false\n \n-\tfor _, command := range a.Commands {\n+\tfor i, command := range a.Commands {\n+\t\tif i > 0 && a.StatusWriter != nil {\n+\t\t\ta.StatusWriter.Log(step.Name, fmt.Sprintf(\"[fallback] agent %q failed, trying %q\", a.Commands[i-1], command))\n+\t\t}\n \t\tresult, stdout, fallbackErr := a.tryCommand(ctx, command, fullPrompt, workDir, step.Name)\n \t\tlastResult = result\n \t\tlastStdout = stdout\n@@ -98,6 +103,9 @@ func (a *Adapter) Execute(ctx context.Context, step *domain.Step, workDir string\n \n \t\tif fallbackErr == nil {\n \t\t\t// Definitive result — agent completed (exit 0 or exit non-zero with marker)\n+\t\t\tif i > 0 && a.StatusWriter != nil {\n+\t\t\t\ta.StatusWriter.Log(step.Name, fmt.Sprintf(\"[fallback] agent %q succeeded\", command))\n+\t\t\t}\n \t\t\tbreak\n \t\t}\n \t\tif stdout != nil {\n@@ -139,7 +147,7 @@ func (a *Adapter) Execute(ctx context.Context, step *domain.Step, workDir string\n //   - Command exited 0\n //   - Command exited non-zero but produced a CLOCHE_RESULT marker\n func (a *Adapter) tryCommand(ctx context.Context, command string, prompt string, workDir string, stepName string) (result string, stdout []byte, fallbackErr error) {\n-\targs := a.argsFor(command)\n+\targs := a.ArgsFor(command)\n \tcmd := exec.CommandContext(ctx, command, args...)\n \tcmd.Dir = workDir\n \tcmd.Stdin = strings.NewReader(prompt)\n@@ -233,9 +241,10 @@ func (a *Adapter) classifyResult(command string, stdoutBytes []byte, runErr erro\n \t\treturn \"fail\", stdoutBytes, fmt.Errorf(\"command %q exited with error: %w\", command, runErr)\n \t}\n \n-\t// Command succeeded (exit 0)\n+\t// Command succeeded (exit 0) but produced no output — likely auth/config issue.\n+\t// This is fallback-eligible so the next agent in the chain can be tried.\n \tif len(bytes.TrimSpace(stdoutBytes)) == 0 {\n-\t\treturn \"fail\", stdoutBytes, fmt.Errorf(\"command %q exited 0 but produced no output (auth/config issue?)\", command)\n+\t\treturn \"\", stdoutBytes, fmt.Errorf(\"command %q exited 0 but produced no output (auth/config issue?)\", command)\n \t}\n \tmarkerResult, _, found := protocol.ExtractResult(stdoutBytes)\n \tresult := \"success\"\ndiff --git a/internal/adapters/agents/prompt/prompt_test.go b/internal/adapters/agents/prompt/prompt_test.go\nindex b87316d..f0da705 100644\n--- a/internal/adapters/agents/prompt/prompt_test.go\n+++ b/internal/adapters/agents/prompt/prompt_test.go\n@@ -421,6 +421,60 @@ func TestPromptAdapter_DefaultArgsForClaude(t *testing.T) {\n \tassert.Nil(t, adapter.ExplicitArgs)\n }\n \n+func TestPromptAdapter_DefaultArgsForKnownAgents(t *testing.T) {\n+\tadapter := prompt.New()\n+\n+\t// Claude should have stream-json args\n+\tclaudeArgs := adapter.ArgsFor(\"claude\")\n+\tassert.Contains(t, claudeArgs, \"--output-format\")\n+\n+\t// Gemini and codex should have their own defaults\n+\tgeminiArgs := adapter.ArgsFor(\"gemini\")\n+\tassert.NotNil(t, geminiArgs)\n+\tassert.Contains(t, geminiArgs, \"-p\")\n+\n+\tcodexArgs := adapter.ArgsFor(\"codex\")\n+\tassert.NotNil(t, codexArgs)\n+\tassert.Contains(t, codexArgs, \"-q\")\n+\n+\t// Unknown agent should get no args\n+\tunknownArgs := adapter.ArgsFor(\"some-unknown-agent\")\n+\tassert.Nil(t, unknownArgs)\n+}\n+\n+func TestPromptAdapter_FallbackOnEmptyOutput(t *testing.T) {\n+\tdir := t.TempDir()\n+\n+\t// First command exits 0 but produces no output (auth/config issue)\n+\temptyAgent := filepath.Join(dir, \"empty-agent.sh\")\n+\trequire.NoError(t, os.WriteFile(emptyAgent, []byte(\"#!/bin/sh\\ncat > /dev/null\\n\"), 0755))\n+\n+\t// Second command works fine\n+\tgoodAgent := filepath.Join(dir, \"good-agent.sh\")\n+\trequire.NoError(t, os.WriteFile(goodAgent, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'good output'\\n\"), 0755))\n+\n+\tadapter := &prompt.Adapter{\n+\t\tCommands: []string{emptyAgent, goodAgent},\n+\t}\n+\n+\tstep := &domain.Step{\n+\t\tName:    \"implement\",\n+\t\tType:    domain.StepTypeAgent,\n+\t\tResults: []string{\"success\", \"fail\"},\n+\t\tConfig:  map[string]string{\"prompt\": \"Do something.\"},\n+\t}\n+\n+\tresult, err := adapter.Execute(context.Background(), step, dir)\n+\trequire.NoError(t, err)\n+\tassert.Equal(t, \"success\", result)\n+\n+\t// Verify the good agent's output was captured\n+\toutputPath := filepath.Join(dir, \".cloche\", \"output\", \"implement.log\")\n+\tdata, err := os.ReadFile(outputPath)\n+\trequire.NoError(t, err)\n+\tassert.Contains(t, string(data), \"good output\")\n+}\n+\n func TestParseCommands(t *testing.T) {\n \ttests := []struct {\n \t\tinput    string\ndiff --git a/internal/agent/runner.go b/internal/agent/runner.go\nindex 57ae944..334e989 100644\n--- a/internal/agent/runner.go\n+++ b/internal/agent/runner.go\n@@ -120,13 +120,8 @@ func (e *stepExecutor) Execute(ctx context.Context, step *domain.Step) (string,\n \t\t\treturn result, err\n \t\t}\n \t\tif _, ok := step.Config[\"prompt\"]; ok {\n-\t\t\tif cmd := step.Config[\"agent_command\"]; cmd != \"\" {\n-\t\t\t\te.prompt.Commands = prompt.ParseCommands(cmd)\n-\t\t\t}\n-\t\t\tif args := step.Config[\"agent_args\"]; args != \"\" {\n-\t\t\t\te.prompt.ExplicitArgs = strings.Fields(args)\n-\t\t\t}\n-\t\t\tresult, err := e.prompt.Execute(ctx, step, e.workDir)\n+\t\t\tadapter := e.promptAdapterForStep(step)\n+\t\t\tresult, err := adapter.Execute(ctx, step, e.workDir)\n \t\t\te.copyToLLMLog(step.Name)\n \t\t\te.logStepOutput(step.Name, logstream.TypeLLM)\n \t\t\treturn result, err\n@@ -137,6 +132,27 @@ func (e *stepExecutor) Execute(ctx context.Context, step *domain.Step) (string,\n \t}\n }\n \n+// promptAdapterForStep returns a prompt adapter configured for the given step.\n+// If the step has agent_command or agent_args overrides, a copy of the base\n+// adapter is returned with those overrides applied, avoiding mutation of the\n+// shared adapter (which would be a race condition for parallel steps).\n+func (e *stepExecutor) promptAdapterForStep(step *domain.Step) *prompt.Adapter {\n+\tcmd := step.Config[\"agent_command\"]\n+\targs := step.Config[\"agent_args\"]\n+\tif cmd == \"\" && args == \"\" {\n+\t\treturn e.prompt\n+\t}\n+\t// Create a shallow copy with overrides\n+\tcp := *e.prompt\n+\tif cmd != \"\" {\n+\t\tcp.Commands = prompt.ParseCommands(cmd)\n+\t}\n+\tif args != \"\" {\n+\t\tcp.ExplicitArgs = strings.Fields(args)\n+\t}\n+\treturn &cp\n+}\n+\n // logStepOutput reads the per-step log file and writes its contents to the unified log.\n func (e *stepExecutor) logStepOutput(stepName string, typ logstream.EntryType) {\n \tpath := filepath.Join(e.workDir, \".cloche\", \"output\", stepName+\".log\")\ndiff --git a/internal/agent/runner_test.go b/internal/agent/runner_test.go\nindex c0b92b7..2e11940 100644\n--- a/internal/agent/runner_test.go\n+++ b/internal/agent/runner_test.go\n@@ -310,6 +310,83 @@ func TestRunner_WorkflowLevelFallbackChain(t *testing.T) {\n \tassert.Equal(t, \"succeeded\", last.Result)\n }\n \n+func TestRunner_ParallelStepOverridesSafe(t *testing.T) {\n+\tdir := t.TempDir()\n+\n+\t// Create two mock agent scripts that identify themselves\n+\tagentA := filepath.Join(dir, \"agent-a.sh\")\n+\trequire.NoError(t, os.WriteFile(agentA, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'agent-a ran'\\n\"), 0755))\n+\n+\tagentB := filepath.Join(dir, \"agent-b.sh\")\n+\trequire.NoError(t, os.WriteFile(agentB, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'agent-b ran'\\n\"), 0755))\n+\n+\t// Two parallel prompt steps, each with its own agent_command override\n+\tworkflowContent := `workflow \"parallel-test\" {\n+  step setup {\n+    run = \"echo ready\"\n+    results = [success, fail]\n+  }\n+\n+  step impl_a {\n+    agent_command = \"` + agentA + `\"\n+    prompt = \"Task A.\"\n+    results = [success, fail]\n+  }\n+\n+  step impl_b {\n+    agent_command = \"` + agentB + `\"\n+    prompt = \"Task B.\"\n+    results = [success, fail]\n+  }\n+\n+  setup:success -> impl_a\n+  setup:success -> impl_b\n+  setup:fail -> abort\n+\n+  collect all(impl_a:success, impl_b:success) -> done\n+  impl_a:fail -> abort\n+  impl_b:fail -> abort\n+}`\n+\tworkflowPath := filepath.Join(dir, \"parallel.cloche\")\n+\trequire.NoError(t, os.WriteFile(workflowPath, []byte(workflowContent), 0644))\n+\n+\tvar statusBuf bytes.Buffer\n+\trunner := agent.NewRunner(agent.RunnerConfig{\n+\t\tWorkflowPath: workflowPath,\n+\t\tWorkDir:      dir,\n+\t\tStatusOutput: &statusBuf,\n+\t})\n+\n+\terr := runner.Run(context.Background())\n+\trequire.NoError(t, err)\n+\n+\tmsgs, err := protocol.ParseStatusStream(statusBuf.Bytes())\n+\trequire.NoError(t, err)\n+\n+\t// Both steps should have completed successfully\n+\tcompletedSteps := map[string]bool{}\n+\tfor _, msg := range msgs {\n+\t\tif msg.Type == protocol.MsgStepCompleted {\n+\t\t\tcompletedSteps[msg.StepName] = true\n+\t\t}\n+\t}\n+\tassert.True(t, completedSteps[\"impl_a\"], \"impl_a should have completed\")\n+\tassert.True(t, completedSteps[\"impl_b\"], \"impl_b should have completed\")\n+\n+\tlast := msgs[len(msgs)-1]\n+\tassert.Equal(t, protocol.MsgRunCompleted, last.Type)\n+\tassert.Equal(t, \"succeeded\", last.Result)\n+\n+\t// Verify each agent ran by checking output files\n+\toutputA, err := os.ReadFile(filepath.Join(dir, \".cloche\", \"output\", \"impl_a.log\"))\n+\trequire.NoError(t, err)\n+\tassert.Contains(t, string(outputA), \"agent-a ran\")\n+\n+\toutputB, err := os.ReadFile(filepath.Join(dir, \".cloche\", \"output\", \"impl_b.log\"))\n+\trequire.NoError(t, err)\n+\tassert.Contains(t, string(outputB), \"agent-b ran\")\n+}\n+\n func TestRunner_UnifiedLogScriptSteps(t *testing.T) {\n \tdir := t.TempDir()\n \tworkflowContent := `workflow \"log-test\" {","is_error":false}]},"parent_tool_use_id":null,"session_id":"a9440e5b-e6f6-4c81-b349-8ecc9e375ee5","uuid":"bdc13811-1b6e-4aa2-8b7d-b13abc9bff8c","tool_use_result":{"stdout":"diff --git a/.beads/issues.jsonl b/.beads/issues.jsonl\nindex 7feeecc..248734e 100644\n--- a/.beads/issues.jsonl\n+++ b/.beads/issues.jsonl\n@@ -110,3 +110,10 @@\n {\"id\":\"cloche-y5x\",\"title\":\"Evolution Orchestrator\",\"description\":\"Main pipeline wiring: Collector -\\u003e Classifier -\\u003e Reflector -\\u003e branch routing -\\u003e AuditLogger. See Task 16 in docs/plans/2026-02-24-self-evolution-implementation.md\",\"status\":\"closed\",\"priority\":2,\"issue_type\":\"task\",\"owner\":\"lucas@perfectlunacy.com\",\"estimated_minutes\":25,\"created_at\":\"2026-02-24T10:07:52.930451072-08:00\",\"created_by\":\"lucas\",\"updated_at\":\"2026-02-24T11:03:14.186375127-08:00\",\"closed_at\":\"2026-02-24T11:03:14.186375127-08:00\",\"close_reason\":\"Closed\",\"labels\":[\"evolution\"],\"dependencies\":[{\"issue_id\":\"cloche-y5x\",\"depends_on_id\":\"cloche-oa5\",\"type\":\"blocks\",\"created_at\":\"2026-02-24T10:09:30.023409923-08:00\",\"created_by\":\"lucas\"},{\"issue_id\":\"cloche-y5x\",\"depends_on_id\":\"cloche-cu5\",\"type\":\"blocks\",\"created_at\":\"2026-02-24T10:09:30.057960664-08:00\",\"created_by\":\"lucas\"},{\"issue_id\":\"cloche-y5x\",\"depends_on_id\":\"cloche-jf5\",\"type\":\"blocks\",\"c