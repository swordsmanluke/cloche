, 0644))\n\n\tvar statusBuf bytes.Buffer\n\trunner := agent.NewRunner(agent.RunnerConfig{\n\t\tWorkflowPath: workflowPath,\n\t\tWorkDir:      dir,\n\t\tStatusOutput: &statusBuf,\n\t})\n\n\terr := runner.Run(context.Background())\n\trequire.NoError(t, err)\n\n\tmsgs, err := protocol.ParseStatusStream(statusBuf.Bytes())\n\trequire.NoError(t, err)\n\n\t// Should have: build started, build completed, test started, test completed, run completed\n\tassert.GreaterOrEqual(t, len(msgs), 5)\n\n\tlast := msgs[len(msgs)-1]\n\tassert.Equal(t, protocol.MsgRunCompleted, last.Type)\n\tassert.Equal(t, \"succeeded\", last.Result)\n}\n","structuredPatch":[{"oldStart":310,"oldLines":6,"newStart":310,"newLines":83,"lines":["   assert.Equal(t, \"succeeded\", last.Result)"," }"," ","+func TestRunner_ParallelStepOverridesSafe(t *testing.T) {","+  dir := t.TempDir()","+","+  // Create two mock agent scripts that identify themselves","+  agentA := filepath.Join(dir, \"agent-a.sh\")","+  require.NoError(t, os.WriteFile(agentA, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'agent-a ran'\\n\"), 0755))","+","+  agentB := filepath.Join(dir, \"agent-b.sh\")","+  require.NoError(t, os.WriteFile(agentB, []byte(\"#!/bin/sh\\ncat > /dev/null\\necho 'agent-b ran'\\n\"), 0755))","+","+  // Two parallel prompt steps, each with its own agent_command override","+  workflowContent := `workflow \"parallel-test\" {","+  step setup {","+    run = \"echo ready\"","+    results = [success, fail]","+  }","+","+  step impl_a {","+    agent_command = \"` + agentA + `\"","+    prompt = \"Task A.\"","+    results = [success, fail]","+  }","+","+  step impl_b {","+    agent_command = \"` + agentB + `\"","+    prompt = \"Task B.\"","+    results = [success, fail]","+  }","+","+  setup:success -> impl_a","+  setup:success -> impl_b","+  setup:fail -> abort","+","+  collect all(impl_a:success, impl_b:success) -> done","+  impl_a:fail -> abort","+  impl_b:fail -> abort","+}`","+  workflowPath := filepath.Join(dir, \"parallel.cloche\")","+  require.NoError(t, os.WriteFile(workflowPath, []byte(workflowContent), 0644))","+","+  var statusBuf bytes.Buffer","+  runner := agent.NewRunner(agent.RunnerConfig{","+    WorkflowPath: workflowPath,","+    WorkDir:      dir,","+    StatusOutput: &statusBuf,","+  })","+","+  err := runner.Run(context.Background())","+  require.NoError(t, err)","+","+  msgs, err := protocol.ParseStatusStream(statusBuf.Bytes())","+  require.NoError(t, err)","+","+  // Both steps should have completed successfully","+  completedSteps := map[string]bool{}","+  for _, msg := range msgs {","+    if msg.Type == protocol.MsgStepCompleted {","+      completedSteps[msg.StepName] = true","+    }","+  }","+  assert.True(t, completedSteps[\"impl_a\"], \"impl_a should have completed\")","+  assert.True(t, completedSteps[\"impl_b\"], \"impl_b should have completed\")","+","+  last := msgs[len(msgs)-1]","+  assert.Equal(t, protocol.MsgRunCompleted, last.Type)","+  assert.Equal(t, \"succeeded\", last.Result)","+","+  // Verify each agent ran by checking output files","+  outputA, err := os.ReadFile(filepath.Join(dir, \".cloche\", \"output\", \"impl_a.log\"))","+  require.NoError(t, err)","+  assert.Contains(t, string(outputA), \"agent-a ran\")","+","+  outputB, err := os.ReadFile(filepath.Join(dir, \".cloche\", \"output\", \"impl_b.log\"))","+  require.NoError(t, err)","+  assert.Contains(t, string(outputB), \"agent-b ran\")","+}","+"," func TestRunner_UnifiedLogScriptSteps(t *testing.T) {","   dir := t.TempDir()","   workflowContent := `workflow \"log-test\" {"]}],"userModified":false,"replaceAll":false}}
