[2026-03-07T16:39:30Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01McceFrkjH88FM42eVc85UV","type":"tool_result","content":"     1→package prompt\n     2→\n     3→import (\n     4→\t\"bufio\"\n     5→\t\"bytes\"\n     6→\t\"context\"\n     7→\t\"encoding/json\"\n     8→\t\"fmt\"\n     9→\t\"os\"\n    10→\t\"os/exec\"\n    11→\t\"path/filepath\"\n    12→\t\"strconv\"\n    13→\t\"strings\"\n    14→\n    15→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    16→\t\"github.com/cloche-dev/cloche/internal/protocol\"\n    17→)\n    18→\n    19→// defaultAgentArgs maps known agent commands to their default arguments.\n    20→// Commands not in this map receive no default arguments (prompt on stdin only).\n    21→var defaultAgentArgs = map[string][]string{\n    22→\t\"claude\": {\"-p\", \"--output-format\", \"stream-json\", \"--verbose\", \"--dangerously-skip-permissions\"},\n    23→\t\"gemini\": {\"-p\"},\n    24→\t\"codex\":  {\"-q\", \"--approval-mode\", \"full-auto\"},\n    25→}\n    26→\n    27→type Adapter struct {\n    28→\tCommands     []string // ordered fallback chain of agent commands\n    29→\tExplicitArgs []string // if non-nil, overrides default args for all commands\n    30→\tRunID        string\n    31→\tStatusWriter *protocol.StatusWriter // optional: streams live output lines\n    32→}\n    33→\n    34→func New() *Adapter {\n    35→\treturn &Adapter{\n    36→\t\tCommands: []string{\"claude\"},\n    37→\t}\n    38→}\n    39→\n    40→func (a *Adapter) Name() string {\n    41→\treturn \"prompt\"\n    42→}\n    43→\n    44→// ArgsFor returns the arguments for the given command. If ExplicitArgs is set,\n    45→// it is used for all commands. Otherwise, known agents get their default args.\n    46→func (a *Adapter) ArgsFor(command string) []string {\n    47→\tif a.ExplicitArgs != nil {\n    48→\t\treturn a.ExplicitArgs\n    49→\t}\n    50→\tif args, ok := defaultAgentArgs[command]; ok {\n    51→\t\treturn args\n    52→\t}\n    53→\treturn nil\n    54→}\n    55→\n    56→// ParseCommands splits a comma-separated agent_command string into individual\n    57→// command names, trimming whitespace from each entry.\n    58→func ParseCommands(s string) []string {\n    59→\tparts := strings.Split(s, \",\")\n    60→\tvar cmds []string\n    61→\tfor _, p := range parts {\n    62→\t\tp = strings.TrimSpace(p)\n    63→\t\tif p != \"\" {\n    64→\t\t\tcmds = append(cmds, p)\n    65→\t\t}\n    66→\t}\n    67→\treturn cmds\n    68→}\n    69→\n    70→func (a *Adapter) Execute(ctx context.Context, step *domain.Step, workDir string) (string, error) {\n    71→\t// Check attempt count for retry limiting\n    72→\tif maxStr, ok := step.Config[\"max_attempts\"]; ok {\n    73→\t\tmax, err := strconv.Atoi(maxStr)\n    74→\t\tif err == nil {\n    75→\t\t\tcount := readAttemptCount(workDir, step.Name)\n    76→\t\t\tif count >= max {\n    77→\t\t\t\treturn \"give-up\", nil\n    78→\t\t\t}\n    79→\t\t}\n    80→\t}\n    81→\tincrementAttemptCount(workDir, step.Name)\n    82→\n    83→\t// Build the full prompt\n    84→\tfullPrompt, err := assemblePrompt(step, workDir, a.RunID)\n    85→\tif err != nil {\n    86→\t\treturn \"\", fmt.Errorf(\"assembling prompt: %w\", err)\n    87→\t}\n    88→\n    89→\t// Try each command in the fallback chain\n    90→\tvar lastResult string\n    91→\tvar lastStdout []byte\n    92→\tvar lastErr error\n    93→\tran := false\n    94→\n    95→\tfor i, command := range a.Commands {\n    96→\t\tif i > 0 && a.StatusWriter != nil {\n    97→\t\t\ta.StatusWriter.Log(step.Name, fmt.Sprintf(\"[fallback] agent %q failed, trying %q\", a.Commands[i-1], command))\n    98→\t\t}\n    99→\t\tresult, stdout, fallbackErr := a.tryCommand(ctx, command, fullPrompt, workDir, step.Name)\n   100→\t\tlastResult = result\n   101→\t\tlastStdout = stdout\n   102→\t\tlastErr = fallbackErr\n   103→\n   104→\t\tif fallbackErr == nil {\n   105→\t\t\t// Definitive result — agent completed (exit 0 or exit non-zero with marker)\n   106→\t\t\tif i > 0 && a.StatusWriter != nil {\n   107→\t\t\t\ta.StatusWriter.Log(step.Name, fmt.Sprintf(\"[fallback] agent %q succeeded\", command))\n   108→\t\t\t}\n   109→\t\t\tbreak\n   110→\t\t}\n   111→\t\tif stdout != nil {\n   112→\t\t\tran = true\n   113→\t\t}\n   114→\t\t// Fallback-eligible — try next command\n   115→\t}\n   116→\n   117→\tif lastErr != nil && !ran && lastStdout == nil {\n   118→\t\t// All commands failed to produce any output (e.g., all not found)\n   119→\t\treturn \"\", lastErr\n   120→\t}\n   121→\n   122→\tresult := lastResult\n   123→\tif lastErr != nil {\n   124→\t\t// Last command in chain crashed without a result marker\n   125→\t\tresult = \"fail\"\n   126→\t}\n   127→\n   128→\t// Write output file\n   129→\toutputDir := filepath.Join(workDir, \".cloche\", \"output\")\n   130→\tif mkErr := os.MkdirAll(outputDir, 0755); mkErr == nil {\n   131→\t\t_ = os.WriteFile(filepath.Join(outputDir, step.Name+\".log\"), lastStdout, 0644)\n   132→\t}\n   133→\tprotocol.AppendHistory(workDir, step.Name, result, true, nil)\n   134→\treturn result, nil\n   135→}\n   136→\n   137→// tryCommand executes a single agent command and returns:\n   138→//   - result: the step result name (e.g. \"success\", \"fail\")\n   139→//   - stdout: captured stdout bytes\n   140→//   - fallbackErr: nil if the result is definitive, non-nil if fallback-eligible\n   141→//\n   142→// Fallback-eligible conditions:\n   143→//   - Command not found or failed to start (stdout will be nil)\n   144→//   - Command exited non-zero without a CLOCHE_RESULT marker\n   145→//\n   146→// Definitive (non-fallback) conditions:\n   147→//   - Command exited 0\n   148→//   - Command exited non-zero but produced a CLOCHE_RESULT marker\n   149→func (a *Adapter) tryCommand(ctx context.Context, command string, prompt string, workDir string, stepName string) (result string, stdout []byte, fallbackErr error) {\n   150→\targs := a.ArgsFor(command)\n   151→\tcmd := exec.CommandContext(ctx, command, args...)\n   152→\tcmd.Dir = workDir\n   153→\tcmd.Stdin = strings.NewReader(prompt)\n   154→\n   155→\t// If we have a StatusWriter, stream stdout line-by-line; otherwise buffer.\n   156→\tif a.StatusWriter == nil {\n   157→\t\tvar stdoutBuf, stderrBuf bytes.Buffer\n   158→\t\tcmd.Stdout = &stdoutBuf\n   159→\t\tcmd.Stderr = &stderrBuf\n   160→\n   161→\t\trunErr := cmd.Run()\n   162→\t\tstdoutBytes := stdoutBuf.Bytes()\n   163→\t\treturn a.classifyResult(command, stdoutBytes, runErr)\n   164→\t}\n   165→\n   166→\t// Streaming path: pipe stdout through a scanner so we can emit lines live.\n   167→\tpipe, err := cmd.StdoutPipe()\n   168→\tif err != nil {\n   169→\t\treturn \"\", nil, fmt.Errorf(\"command %q stdout pipe: %w\", command, err)\n   170→\t}\n   171→\tcmd.Stderr = nil // discard stderr\n   172→\n   173→\tif err := cmd.Start(); err != nil {\n   174→\t\treturn \"\", nil, fmt.Errorf(\"command %q failed to start: %w\", command, err)\n   175→\t}\n   176→\n   177→\t// textBuf accumulates extracted text content for result extraction.\n   178→\t// rawBuf accumulates raw stdout for the output log file.\n   179→\tvar textBuf, rawBuf bytes.Buffer\n   180→\t// lineBuf accumulates text deltas into lines for streaming.\n   181→\tvar lineBuf strings.Builder\n   182→\n   183→\tscanner := bufio.NewScanner(pipe)\n   184→\tscanner.Buffer(make([]byte, 0, 256*1024), 1024*1024)\n   185→\tfor scanner.Scan() {\n   186→\t\traw := scanner.Bytes()\n   187→\t\trawBuf.Write(raw)\n   188→\t\trawBuf.WriteByte('\\n')\n   189→\n   190→\t\ttext := extractStreamText(raw)\n   191→\t\tif text == \"\" {\n   192→\t\t\tcontinue\n   193→\t\t}\n   194→\t\ttextBuf.WriteString(text)\n   195→\n   196→\t\t// Stream complete lines to StatusWriter as they form.\n   197→\t\tlineBuf.WriteString(text)\n   198→\t\tfor {\n   199→\t\t\ts := lineBuf.String()\n   200→\t\t\tidx := strings.IndexByte(s, '\\n')\n   201→\t\t\tif idx < 0 {\n   202→\t\t\t\tbreak\n   203→\t\t\t}\n   204→\t\t\ta.StatusWriter.Log(stepName, s[:idx])\n   205→\t\t\tlineBuf.Reset()\n   206→\t\t\tlineBuf.WriteString(s[idx+1:])\n   207→\t\t}\n   208→\t}\n   209→\t// Flush any remaining partial line.\n   210→\tif lineBuf.Len() > 0 {\n   211→\t\ta.StatusWriter.Log(stepName, lineBuf.String())\n   212→\t}\n   213→\tif scanErr := scanner.Err(); scanErr != nil {\n   214→\t\ta.StatusWriter.Log(stepName, fmt.Sprintf(\"[scan error: %v]\", scanErr))\n   215→\t}\n   216→\n   217→\twaitErr := cmd.Wait()\n   218→\t// Prefer extracted text (stream-json) for result classification; fall back\n   219→\t// to raw output for non-JSON commands (scripts, non-claude agents).\n   220→\tclassifyBuf := textBuf.Bytes()\n   221→\tif len(bytes.TrimSpace(classifyBuf)) == 0 {\n   222→\t\tclassifyBuf = rawBuf.Bytes()\n   223→\t}\n   224→\tresult, _, fallbackErr = a.classifyResult(command, classifyBuf, waitErr)\n   225→\treturn result, rawBuf.Bytes(), fallbackErr\n   226→}\n   227→\n   228→// classifyResult interprets the command's exit status and stdout to determine\n   229→// the step result.\n   230→func (a *Adapter) classifyResult(command string, stdoutBytes []byte, runErr error) (string, []byte, error) {\n   231→\tif runErr != nil {\n   232→\t\tif _, ok := runErr.(*exec.ExitError); !ok {\n   233→\t\t\t// Command failed to start (not found, permission denied, etc.)\n   234→\t\t\treturn \"\", nil, fmt.Errorf(\"command %q failed to start: %w\", command, runErr)\n   235→\t\t}\n   236→\t\t// Command ran but exited non-zero\n   237→\t\tmarkerResult, _, found := protocol.ExtractResult(stdoutBytes)\n   238→\t\tif found {\n   239→\t\t\treturn markerResult, stdoutBytes, nil\n   240→\t\t}\n   241→\t\treturn \"fail\", stdoutBytes, fmt.Errorf(\"command %q exited with error: %w\", command, runErr)\n   242→\t}\n   243→\n   244→\t// Command succeeded (exit 0) but produced no output — likely auth/config issue.\n   245→\t// This is fallback-eligible so the next agent in the chain can be tried.\n   246→\tif len(bytes.TrimSpace(stdoutBytes)) == 0 {\n   247→\t\treturn \"\", stdoutBytes, fmt.Errorf(\"command %q exited 0 but produced no output (auth/config issue?)\", command)\n   248→\t}\n   249→\tmarkerResult, _, found := protocol.ExtractResult(stdoutBytes)\n   250→\tresult := \"success\"\n   251→\tif found {\n   252→\t\tresult = markerResult\n   253→\t}\n   254→\treturn result, stdoutBytes, nil\n   255→}\n   256→\n   257→// extractStreamText parses a stream-json line and returns text content.\n   258→// It handles both content_block_delta (text_delta) events for streaming and\n   259→// result events for final output (which contains the CLOCHE_RESULT marker).\n   260→func extractStreamText(line []byte) string {\n   261→\t// Fast path: only parse lines that could contain text we care about.\n   262→\tif bytes.Contains(line, []byte(`\"text_delta\"`)) {\n   263→\t\tvar event struct {\n   264→\t\t\tType  string `json:\"type\"`\n   265→\t\t\tDelta struct {\n   266→\t\t\t\tType string `json:\"type\"`\n   267→\t\t\t\tText string `json:\"text\"`\n   268→\t\t\t} `json:\"delta\"`\n   269→\t\t}\n   270→\t\tif json.Unmarshal(line, &event) == nil &&\n   271→\t\t\tevent.Type == \"content_block_delta\" && event.Delta.Type == \"text_delta\" {\n   272→\t\t\treturn event.Delta.Text\n   273→\t\t}\n   274→\t}\n   275→\n   276→\t// Also extract the final result text (contains CLOCHE_RESULT marker).\n   277→\tif bytes.Contains(line, []byte(`\"result\"`)) && bytes.Contains(line, []byte(`\"subtype\"`)) {\n   278→\t\tvar event struct {\n   279→\t\t\tType   string `json:\"type\"`\n   280→\t\t\tResult string `json:\"result\"`\n   281→\t\t}\n   282→\t\tif json.Unmarshal(line, &event) == nil && event.Type == \"result\" {\n   283→\t\t\treturn event.Result\n   284→\t\t}\n   285→\t}\n   286→\n   287→\treturn \"\"\n   288→}\n   289→\n   290→func assemblePrompt(step *domain.Step, workDir, runID string) (string, error) {\n   291→\tvar parts []string\n   292→\n   293→\t// 1. Read system template from step config\n   294→\tif tmpl, ok := step.Config[\"prompt\"]; ok {\n   295→\t\tcontent, err := resolveContent(tmpl, workDir)\n   296→\t\tif err != nil {\n   297→\t\t\treturn \"\", fmt.Errorf(\"reading prompt template: %w\", err)\n   298→\t\t}\n   299→\t\tparts = append(parts, content)\n   300→\t}\n   301→\n   302→\t// 2. Read user prompt from .cloche/<run-id>/prompt.txt\n   303→\tuserPrompt := readUserPrompt(workDir, runID)\n   304→\tif userPrompt != \"\" {\n   305→\t\tparts = append(parts, \"## User Request\\n\"+userPrompt)\n   306→\t}\n   307→\n   308→\t// 3. Read feedback from .cloche/output/*.log (opt-in via step config)\n   309→\tif step.Config[\"feedback\"] == \"true\" {\n   310→\t\tfeedback := readFeedback(workDir)\n   311→\t\tif feedback != \"\" {\n   312→\t\t\tparts = append(parts, \"## Validation Output\\n\"+feedback)\n   313→\t\t}\n   314→\t}\n   315→\n   316→\t// 4. Result selection instructions\n   317→\tif len(step.Results) > 0 {\n   318→\t\tvar resultLines []string\n   319→\t\tresultLines = append(resultLines, \"## Result Selection\")\n   320→\t\tresultLines = append(resultLines, \"When you are finished, output exactly one of the following on its own line:\")\n   321→\t\tfor _, r := range step.Results {\n   322→\t\t\tresultLines = append(resultLines, protocol.ResultPrefix+r)\n   323→\t\t}\n   324→\t\tparts = append(parts, strings.Join(resultLines, \"\\n\"))\n   325→\t}\n   326→\n   327→\treturn strings.Join(parts, \"\\n\\n\"), nil\n   328→}\n   329→\n   330→// resolveContent handles file(\"path\") syntax or returns the string directly.\n   331→func resolveContent(value string, workDir string) (string, error) {\n   332→\t// Check for file(\"path\") syntax from DSL parser\n   333→\tif strings.HasPrefix(value, `file(\"`) && strings.HasSuffix(value, `\")`) {\n   334→\t\tpath := value[6 : len(value)-2]\n   335→\t\tdata, err := os.ReadFile(filepath.Join(workDir, path))\n   336→\t\tif err != nil {\n   337→\t\t\treturn \"\", fmt.Errorf(\"reading file %q: %w\", path, err)\n   338→\t\t}\n   339→\t\treturn string(data), nil\n   340→\t}\n   341→\treturn value, nil\n   342→}\n   343→\n   344→func readFeedback(workDir string) string {\n   345→\toutputDir := filepath.Join(workDir, \".cloche\", \"output\")\n   346→\tentries, err := os.ReadDir(outputDir)\n   347→\tif err != nil {\n   348→\t\treturn \"\"\n   349→\t}\n   350→\n   351→\tvar parts []string\n   352→\tfor _, entry := range entries {\n   353→\t\tif entry.IsDir() || !strings.HasSuffix(entry.Name(), \".log\") {\n   354→\t\t\tcontinue\n   355→\t\t}\n   356→\t\tdata, err := os.ReadFile(filepath.Join(outputDir, entry.Name()))\n   357→\t\tif err != nil {\n   358→\t\t\tcontinue\n   359→\t\t}\n   360→\t\tcontent := strings.TrimSpace(string(data))\n   361→\t\tif content != \"\" {\n   362→\t\t\tstepName := strings.TrimSuffix(entry.Name(), \".log\")\n   363→\t\t\tparts = append(parts, fmt.Sprintf(\"### %s\\n```\\n%s\\n```\", stepName, content))\n   364→\t\t}\n   365→\t}\n   366→\n   367→\treturn strings.Join(parts, \"\\n\\n\")\n   368→}\n   369→\n   370→func readAttemptCount(workDir, stepName string) int {\n   371→\tpath := filepath.Join(workDir, \".cloche\", \"attempt_count\", stepName)\n   372→\tdata, err := os.ReadFile(path)\n   373→\tif err != nil {\n   374→\t\treturn 0\n   375→\t}\n   376→\tn, _ := strconv.Atoi(strings.TrimSpace(string(data)))\n   377→\treturn n\n   378→}\n   379→\n   380→// readUserPrompt reads the user prompt from .cloche/<run-id>/prompt.txt.\n   381→func readUserPrompt(workDir, runID string) string {\n   382→\tif runID == \"\" {\n   383→\t\treturn \"\"\n   384→\t}\n   385→\tpath := filepath.Join(workDir, \".cloche\", runID, \"prompt.txt\")\n   386→\tif data, err := os.ReadFile(path); err == nil {\n   387→\t\treturn string(data)\n   388→\t}\n   389→\treturn \"\"\n   390→}\n   391→\n   392→func incrementAttemptCount(workDir, stepName string) {\n   393→\tdir := filepath.Join(workDir, \".cloche\", \"attempt_count\")\n   394→\t_ = os.MkdirAll(dir, 0755)\n   395→\tcount := readAttemptCount(workDir, stepName) + 1\n   396→\t_ = os.WriteFile(filepath.Join(dir, stepName), []byte(strconv.Itoa(count)), 0644)\n   397→}\n   398→"}]},"parent_tool_use_id":null,"session_id":"a9440e5b-e6f6-4c81-b349-8ecc9e375ee5","uuid":"598310ab-d340-46c3-b597-294004e06b91","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/agents/prompt/prompt.go","content":"package prompt\n\nimport (\n\t\"bufio\"\n\t\"bytes\"\n\t\"context\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"os\"\n\t\"os/exec\"\n\t\"path/filepath\"\n\t\"strconv\"\n\t\"strings\"\n\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/protocol\"\n)\n\n// defaultAgentArgs maps known agent commands to their default arguments.\n// Commands not in this map receive no default arguments (prompt on stdin only).\nvar defaultAgentArgs = map[string][]string{\n\t\"claude\": {\"-p\", \"--output-format\", \"stream-json\", \"--verbose\", \"--dangerously-skip-permissions\"},\n\t\"gemini\": {\"-p\"},\n\t\"codex\":  {\"-q\", \"--approval-mode\", \"full-auto\"},\n}\n\ntype Adapter struct {\n\tCommands     []string // ordered fallback chain of agent commands\n\tExplicitArgs []string // if non-nil, overrides default args for all commands\n\tRunID        string\n\tStatusWriter *protocol.StatusWriter // optional: streams live output lines\n}\n\nfunc New() *Adapter {\n\treturn &Adapter{\n\t\tCommands: []string{\"claude\"},\n\t}\n}\n\nfunc (a *Adapter) Name() string {\n\treturn \"prompt\"\n}\n\n// ArgsFor returns the arguments for the given command. If ExplicitArgs is set,\n// it is used for all commands. Otherwise, known agents get their default args.\nfunc (a *Adapter) ArgsFor(command string) []string {\n\tif a.ExplicitArgs != nil {\n\t\treturn a.ExplicitArgs\n\t}\n\tif args, ok := defaultAgentArgs[command]; ok {\n\t\treturn args\n\t}\n\treturn nil\n}\n\n// ParseCommands splits a comma-separated agent_command string into individual\n// command names, trimming whitespace from each entry.\nfunc ParseCommands(s string) []string {\n\tparts := strings.Split(s, \",\")\n\tvar cmds []string\n\tfor _, p := range parts {\n\t\tp = strings.TrimSpace(p)\n\t\tif p != \"\" {\n\t\t\tcmds = append(cmds, p)\n\t\t}\n\t}\n\treturn cmds\n}\n\nfunc (a *Adapter) Execute(ctx context.Context, step *domain.Step, workDir string) (string, error) {\n\t// Check attempt count for retry limiting\n\tif maxStr, ok := step.Config[\"max_attempts\"]; ok {\n\t\tmax, err := strconv.Atoi(maxStr)\n\t\tif err == nil {\n\t\t\tcount := readAttemptCount(workDir, step.Name)\n\t\t\tif count >= max {\n\t\t\t\treturn \"give-up\", nil\n\t\t\t}\n\t\t}\n\t}\n\tincrementAttemptCount(workDir, step.Name)\n\n\t// Build the full prompt\n\tfullPrompt, err := assemblePrompt(step, workDir, a.RunID)\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"assembling prompt: %w\", err)\n\t}\n\n\t// Try each command in the fallback chain\n\tvar lastResult string\n\tvar lastStdout []byte\n\tvar lastErr error\n\tran := false\n\n\tfor i, command := range a.Commands {\n\t\tif i > 0 && a.StatusWriter != nil {\n\t\t\ta.StatusWriter.Log(step.Name, fmt.Sprintf(\"[fallback] agent %q failed, trying %q\", a.Commands[i-1], command))\n\t\t}\n\t\tresult, stdout, fallbackErr := a.tryCommand(ctx, command, fullPrompt, workDir, step.Name)\n\t\tlastResult = result\n\t\tlastStdout = stdout\n\t\tlastErr = fallbackErr\n\n\t\tif fallbackErr == nil {\n\t\t\t// Definitive result — agent completed (exit 0 or exit non-zero with marker)\n\t\t\tif i > 0 && a.StatusWriter != nil {\n\t\t\t\ta.StatusWriter.Log(step.Name, fmt.Sprintf(\"[fallback] agent %q succeeded\", command))\n\t\t\t}\n\t\t\tbreak\n\t\t}\n\t\tif stdout != nil {\n\t\t\tran = true\n\t\t}\n\t\t// Fallback-eligible — try next command\n\t}\n\n\tif lastErr != nil && !ran && lastStdout == nil {\n\t\t// All commands failed to produce any output (e.g., all not found)\n\t\treturn \"\", lastErr\n\t}\n\n\tresult := lastResult\n\tif lastErr != nil {\n\t\t// Last command in chain crashed without a result marker\n\t\tresult = \"fail\"\n\t}\n\n\t// Write output file\n\toutputDir := filepath.Join(workDir, \".cloche\", \"output\")\n\tif mkErr := os.MkdirAll(outputDir, 0755); mkErr == nil {\n\t\t_ = os.WriteFile(filepath.Join(outputDir, step.Name+\".log\"), lastStdout, 0644)\n\t}\n\tprotocol.AppendHistory(workDir, step.Name, result, true, nil)\n\treturn result, nil\n}\n\n// tryCommand executes a single agent command and returns:\n//   - result: the step result name (e.g. \"success\", \"fail\")\n//   - stdout: captured stdout bytes\n//   - fallbackErr: nil if the result is definitive, non-nil if fallback-eligible\n//\n// Fallback-eligible conditions:\n//   - Command not found or failed to start (stdout will be nil)\n//   - Command exited non-zero without a CLOCHE_RESULT marker\n//\n// Definitive (non-fallback) conditions:\n//   - Command exited 0\n//   - Command exited non-zero but produced a CLOCHE_RESULT marker\nfunc (a *Adapter) tryCommand(ctx context.Context, command string, prompt string, workDir string, stepName string) (result string, stdout []byte, fallbackErr error) {\n\targs := a.ArgsFor(command)\n\tcmd := exec.CommandContext(ctx, command, args...)\n\tcmd.Dir = workDir\n\tcmd.Stdin = strings.NewReader(prompt)\n\n\t// If we have a StatusWriter, stream stdout line-by-line; otherwise buffer.\n\tif a.StatusWriter == nil {\n\t\tvar stdoutBuf, stderrBuf bytes.Buffer\n\t\tcmd.Stdout = &stdoutBuf\n\t\tcmd.Stderr = &stderrBuf\n\n\t\trunErr := cmd.Run()\n\t\tstdoutBytes := stdoutBuf.Bytes()\n\t\treturn a.classifyResult(command, stdoutBytes, runErr)\n\t}\n\n\t// Streaming path: pipe stdout through a scanner so we can emit lines live.\n\tpipe, err := cmd.StdoutPipe()\n\tif err != nil {\n\t\treturn \"\", nil, fmt.Errorf(\"command %q stdout pipe: %w\", command, err)\n\t}\n\tcmd.Stderr = nil // discard stderr\n\n\tif err := cmd.Start(); err != nil {\n\t\treturn \"\", nil, fmt.Errorf(\"command %q failed to start: %w\", command, err)\n\t}\n\n\t// textBuf accumulates extracted text content for result extraction.\n\t// rawBuf accumulates raw stdout for the output log file.\n\tvar textBuf, rawBuf bytes.Buffer\n\t// lineBuf accumulates text deltas into lines for streaming.\n\tvar lineBuf strings.Builder\n\n\tscanner := bufio.NewScanner(pipe)\n\tscanner.Buffer(make([]byte, 0, 256*1024), 1024*1024)\n\tfor scanner.Scan() {\n\t\traw := scanner.Bytes()\n\t\trawBuf.Write(raw)\n\t\trawBuf.WriteByte('\\n')\n\n\t\ttext := extractStreamText(raw)\n\t\tif text == \"\" {\n\t\t\tcontinue\n\t\t}\n\t\ttextBuf.WriteString(text)\n\n\t\t// Stream complete lines to StatusWriter as they form.\n\t\tlineBuf.WriteString(text)\n\t\tfor {\n\t\t\ts := lineBuf.String()\n\t\t\tidx := strings.IndexByte(s, '\\n')\n\t\t\tif idx < 0 {\n\t\t\t\tbreak\n\t\t\t}\n\t\t\ta.StatusWriter.Log(stepName, s[:idx])\n\t\t\tlineBuf.Reset()\n\t\t\tlineBuf.WriteString(s[idx+1:])\n\t\t}\n\t}\n\t// Flush any remaining partial line.\n\tif lineBuf.Len() > 0 {\n\t\ta.StatusWriter.Log(stepName, lineBuf.String())\n\t}\n\tif scanErr := scanner.Err(); scanErr != nil {\n\t\ta.StatusWriter.Log(stepName, fmt.Sprintf(\"[scan error: %v]\", scanErr))\n\t}\n\n\twaitErr := cmd.Wait()\n\t// Prefer extracted text (stream-json) for result classification; fall back\n\t// to raw output for non-JSON commands (scripts, non-claude agents).\n\tclassifyBuf := textBuf.Bytes()\n\tif len(bytes.TrimSpace(classifyBuf)) == 0 {\n\t\tclassifyBuf = rawBuf.Bytes()\n\t}\n\tresult, _, fallbackErr = a.classifyResult(command, classifyBuf, waitErr)\n\treturn result, rawBuf.Bytes(), fallbackErr\n}\n\n// classifyResult interprets the command's exit status and stdout to determine\n// the step result.\nfunc (a *Adapter) classifyResult(command string, stdoutBytes []byte, runErr error) (string, []byte, error) {\n\tif runErr != nil {\n\t\tif _, ok := runErr.(*exec.ExitError); !ok {\n\t\t\t// Command failed to start (not found, permission denied, etc.)\n\t\t\treturn \"\", nil, fmt.Errorf(\"command %q failed to start: %w\", command, runErr)\n\t\t}\n\t\t// Command ran but exited non-zero\n\t\tmarkerResult, _, found := protocol.ExtractResult(stdoutBytes)\n\t\tif found {\n\t\t\treturn markerResult, stdoutBytes, nil\n\t\t}\n\t\treturn \"fail\", stdoutBytes, fmt.Errorf(\"command %q exited with error: %w\", command, runErr)\n\t}\n\n\t// Command succeeded (exit 0) but produced no output — likely auth/config issue.\n\t// This is fallback-eligible so the next agent in the chain can be tried.\n\tif len(bytes.TrimSpace(stdoutBytes)) == 0 {\n\t\treturn \"\", stdoutBytes, fmt.Errorf(\"command %q exited 0 but produced no output (auth/config issue?)\", command)\n\t}\n\tmarkerResult, _, found := protocol.ExtractResult(stdoutBytes)\n\tresult := \"success\"\n\tif found {\n\t\tresult = markerResult\n\t}\n\treturn result, stdoutBytes, nil\n}\n\n// extractStreamText parses a stream-json line and returns text content.\n// It handles both content_block_delta (text_delta) events for streaming and\n// result events for final output (which contains the CLOCHE_RESULT marker).\nfunc extractStreamText(line []byte) string {\n\t// Fast path: only parse lines that could contain text we care about.\n\tif bytes.Contains(line, []byte(`\"text_delta\"`)) {\n\t\tvar event struct {\n\t\t\tType  string `json:\"type\"`\n\t\t\tDelta struct {\n\t\t\t\tType string `json:\"type\"`\n\t\t\t\tText string `json:\"text\"`\n\t\t\t} `json:\"delta\"`\n\t\t}\n\t\tif json.Unmarshal(line, &event) == nil &&\n\t\t\tevent.Type == \"content_block_delta\" && event.Delta.Type == \"text_delta\" {\n\t\t\treturn event.Delta.Text\n\t\t}\n\t}\n\n\t// Also extract the final result text (contains CLOCHE_RESULT marker).\n\tif bytes.Contains(line, []byte(`\"result\"`)) && bytes.Contains(line, []byte(`\"subtype\"`)) {\n\t\tvar event struct {\n\t\t\tType   string `json:\"type\"`\n\t\t\tResult string `json:\"result\"`\n\t\t}\n\t\tif json.Unmarshal(line, &event) == nil && event.Type == \"result\" {\n\t\t\treturn event.Result\n\t\t}\n\t}\n\n\treturn \"\"\n}\n\nfunc assemblePrompt(step *domain.Step, workDir, runID string) (string, error) {\n\tvar parts []string\n\n\t// 1. Read system template from step config\n\tif tmpl, ok := step.Config[\"prompt\"]; ok {\n\t\tcontent, err := resolveContent(tmpl, workDir)\n\t\tif err != nil {\n\t\t\treturn \"\", fmt.Errorf(\"reading prompt template: %w\", err)\n\t\t}\n\t\tparts = append(parts, content)\n\t}\n\n\t// 2. Read user prompt from .cloche/<run-id>/prompt.txt\n\tuserPrompt := readUserPrompt(workDir, runID)\n\tif userPrompt != \"\" {\n\t\tparts = append(parts, \"## User Request\\n\"+userPrompt)\n\t}\n\n\t// 3. Read feedback from .cloche/output/*.log (opt-in via step config)\n\tif step.Config[\"feedback\"] == \"true\" {\n\t\tfeedback := readFeedback(workDir)\n\t\tif feedback != \"\" {\n\t\t\tparts = append(parts, \"## Validation Output\\n\"+feedback)\n\t\t}\n\t}\n\n\t// 4. Result selection instructions\n\tif len(step.Results) > 0 {\n\t\tvar resultLines []string\n\t\tresultLines = append(resultLines, \"## Result Selection\")\n\t\tresultLines = append(resultLines, \"When you are finished, output exactly one of the following on its own line:\")\n\t\tfor _, r := range step.Results {\n\t\t\tresultLines = append(resultLines, protocol.ResultPrefix+r)\n\t\t}\n\t\tparts = append(parts, strings.Join(resultLines, \"\\n\"))\n\t}\n\n\treturn strings.Join(parts, \"\\n\\n\"), nil\n}\n\n// resolveContent handles file(\"path\") syntax or returns the string directly.\nfunc resolveContent(value string, workDir string) (string, error) {\n\t// Check for file(\"path\") syntax from DSL parser\n\tif strings.HasPrefix(value, `file(\"`) && strings.HasSuffix(value, `\")`) {\n\t\tpath := value[6 : len(value)-2]\n\t\tdata, err := os.ReadFile(filepath.Join(workDir, path))\n\t\tif err != nil {\n\t\t\treturn \"\", fmt.Errorf(\"reading file %q: %w\", path, err)\n\t\t}\n\t\treturn string(data), nil\n\t}\n\treturn value, nil\n}\n\nfunc readFeedback(workDir string) string {\n\toutputDir := filepath.Join(workDir, \".cloche\", \"output\")\n\tentries, err := os.ReadDir(outputDir)\n\tif err != nil {\n\t\treturn \"\"\n\t}\n\n\tvar parts []string\n\tfor _, entry := range entries {\n\t\tif entry.IsDir() || !strings.HasSuffix(entry.Name(), \".log\") {\n\t\t\tcontinue\n\t\t}\n\t\tdata, err := os.ReadFile(filepath.Join(outputDir, entry.Name()))\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tcontent := strings.TrimSpace(string(data))\n\t\tif content != \"\" {\n\t\t\tstepName := strings.TrimSuffix(entry.Name(), \".log\")\n\t\t\tparts = append(parts, fmt.Sprintf(\"### %s\\n```\\n%s\\n```\", stepName, content))\n\t\t}\n\t}\n\n\treturn strings.Join(parts, \"\\n\\n\")\n}\n\nfunc readAttemptCount(workDir, stepName string) int {\n\tpath := filepath.Join(workDir, \".cloche\", \"attempt_count\", stepName)\n\tdata, err := os.ReadFile(path)\n\tif err != nil {\n\t\treturn 0\n\t}\n\tn, _ := strconv.Atoi(strings.TrimSpace(string(data)))\n\treturn n\n}\n\n// readUserPrompt reads the user prompt from .cloche/<run-id>/prompt.txt.\nfunc readUserPrompt(workDir, runID string) string {\n\tif runID == \"\" {\n\t\treturn \"\"\n\t}\n\tpath := filepath.Join(workDir, \".cloche\", runID, \"prompt.txt\")\n\tif data, err := os.ReadFile(path); err == nil {\n\t\treturn string(data)\n\t}\n\treturn \"\"\n}\n\nfunc incrementAttemptCount(workDir, stepName string) {\n\tdir := filepath.Join(workDir, \".cloche\", \"attempt_count\")\n\t_ = os.MkdirAll(dir, 0755)\n\tcount := readAttemptCount(workDir, stepName) + 1\n\t_ = os.WriteFile(filepath.Join(dir, stepName), []byte(strconv.Itoa(count)), 0644)\n}\n","numLines":398,"startLine":1,"totalLines":398}}}
