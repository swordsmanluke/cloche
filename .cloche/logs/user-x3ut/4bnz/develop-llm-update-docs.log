\tlabels := projectLabels(projects)\n\tlabel := labels[dir]\n\trequire.NotEmpty(t, label)\n\n\t// Test: fetch prompt step content (file reference)\n\treq := httptest.NewRequest(\"GET\", \"/api/projects/\"+label+\"/workflows/test/steps/build/content\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tassert.Equal(t, \"Build the project carefully.\", w.Body.String())\n\n\t// Test: fetch run step content (inline command)\n\treq = httptest.NewRequest(\"GET\", \"/api/projects/\"+label+\"/workflows/test/steps/run-tests/content\", nil)\n\tw = httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tassert.Equal(t, \"go test ./...\", w.Body.String())\n\n\t// Test: nonexistent step\n\treq = httptest.NewRequest(\"GET\", \"/api/projects/\"+label+\"/workflows/test/steps/nonexistent/content\", nil)\n\tw = httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusNotFound, w.Code)\n}"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":178,"cache_read_input_tokens":69093,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":178},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"fe399e8d-ac34-4834-9459-9cc0582e00b8","uuid":"7bdf1413-a226-401f-acee-8f4034687128"}
