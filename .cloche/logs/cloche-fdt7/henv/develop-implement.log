{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CBg3x4VPCGYj4jnmCgmemp","type":"tool_result","content":"     1→package host\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"fmt\"\n     6→\t\"log\"\n     7→\t\"os\"\n     8→\t\"path/filepath\"\n     9→\t\"strings\"\n    10→\t\"time\"\n    11→\n    12→\t\"github.com/cloche-dev/cloche/internal/adapters/agents/prompt\"\n    13→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    14→\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    15→\t\"github.com/cloche-dev/cloche/internal/engine\"\n    16→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    17→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    18→)\n    19→\n    20→// Ensure hostStatusHandler implements engine.StatusHandler.\n    21→var _ engine.StatusHandler = (*hostStatusHandler)(nil)\n    22→\n    23→// Runner executes a host workflow by parsing host.cloche and walking the step graph.\n    24→type Runner struct {\n    25→\tDispatcher    RunDispatcher\n    26→\tStore         ports.RunStore\n    27→\tCaptures      ports.CaptureStore       // optional: saves step captures for cloche logs\n    28→\tLogBroadcast  *logstream.Broadcaster   // optional: publishes live log lines\n    29→\tTaskID        string                   // optional task ID assigned by the daemon loop\n    30→\tExtraEnv      []string                 // additional KEY=VALUE env vars passed to all steps\n    31→\tSkipRunRecord bool                     // when true, don't persist a run record to the store\n    32→}\n    33→\n    34→// RunResult contains the outcome of a host workflow execution.\n    35→type RunResult struct {\n    36→\tRunID     string\n    37→\tState     domain.RunState\n    38→\tOutputDir string // path to the step output directory\n    39→}\n    40→\n    41→// Run parses .cloche/host.cloche from projectDir and executes the \"main\" workflow.\n    42→func (r *Runner) Run(ctx context.Context, projectDir string) (*RunResult, error) {\n    43→\treturn r.RunWithID(ctx, projectDir, domain.GenerateRunID(\"main\"))\n    44→}\n    45→\n    46→// RunWithID is like Run but uses the provided run ID instead of generating one.\n    47→func (r *Runner) RunWithID(ctx context.Context, projectDir string, orchRunID string) (*RunResult, error) {\n    48→\treturn r.runNamedWorkflow(ctx, projectDir, \"main\", orchRunID)\n    49→}\n    50→\n    51→// RunNamed parses .cloche/host.cloche from projectDir and executes the workflow\n    52→// with the given name. The host.cloche file may contain multiple workflows (e.g.\n    53→// \"list-tasks\", \"main\", \"finalize\"). Returns an error if the named workflow is\n    54→// not found.\n    55→func (r *Runner) RunNamed(ctx context.Context, projectDir string, workflowName string) (*RunResult, error) {\n    56→\torchRunID := domain.GenerateRunID(workflowName)\n    57→\treturn r.runNamedWorkflow(ctx, projectDir, workflowName, orchRunID)\n    58→}\n    59→\n    60→// runNamedWorkflow is the internal implementation that runs a specific named\n    61→// workflow from host.cloche.\n    62→func (r *Runner) runNamedWorkflow(ctx context.Context, projectDir string, workflowName string, orchRunID string) (*RunResult, error) {\n    63→\thostPath := filepath.Join(projectDir, \".cloche\", \"host.cloche\")\n    64→\tdata, err := os.ReadFile(hostPath)\n    65→\tif err != nil {\n    66→\t\treturn nil, fmt.Errorf(\"reading host.cloche: %w\", err)\n    67→\t}\n    68→\n    69→\tworkflows, err := dsl.ParseAllForHost(string(data))\n    70→\tif err != nil {\n    71→\t\treturn nil, fmt.Errorf(\"parsing host.cloche: %w\", err)\n    72→\t}\n    73→\n    74→\twf, ok := workflows[workflowName]\n    75→\tif !ok {\n    76→\t\treturn nil, fmt.Errorf(\"host.cloche has no workflow %q\", workflowName)\n    77→\t}\n    78→\n    79→\t// Create output directory for step outputs\n    80→\toutputDir := filepath.Join(projectDir, \".cloche\", orchRunID, \"output\")\n    81→\tif err := os.MkdirAll(outputDir, 0755); err != nil {\n    82→\t\treturn nil, fmt.Errorf(\"creating output dir: %w\", err)\n    83→\t}\n    84→\n    85→\tlog.Printf(\"host workflow: starting %q for project %s (run %s)\", wf.Name, projectDir, orchRunID)\n    86→\n    87→\t// Persist the host run in the store so it appears in list/status/logs.\n    88→\t// When SkipRunRecord is set (e.g. for list-tasks polling), skip creating\n    89→\t// the record to avoid cluttering the run history.\n    90→\tif !r.SkipRunRecord {\n    91→\t\thostRun := domain.NewRun(orchRunID, wf.Name)\n    92→\t\thostRun.ProjectDir = projectDir\n    93→\t\thostRun.IsHost = true\n    94→\t\thostRun.TaskID = r.TaskID\n    95→\t\tif err := r.Store.CreateRun(ctx, hostRun); err != nil {\n    96→\t\t\treturn nil, fmt.Errorf(\"creating host run record: %w\", err)\n    97→\t\t}\n    98→\t\thostRun.Start()\n    99→\t\t_ = r.Store.UpdateRun(ctx, hostRun)\n   100→\t}\n   101→\n   102→\texecutor := &Executor{\n   103→\t\tProjectDir: projectDir,\n   104→\t\tMainDir:    MainWorktreeDir(projectDir),\n   105→\t\tDispatcher: r.Dispatcher,\n   106→\t\tStore:      r.Store,\n   107→\t\tOutputDir:  outputDir,\n   108→\t\tWires:      wf.Wiring,\n   109→\t\tHostRunID:  orchRunID,\n   110→\t\tTaskID:     r.TaskID,\n   111→\t\tExtraEnv:   r.ExtraEnv,\n   112→\t}\n   113→\n   114→\t// Configure agent from workflow-level host config\n   115→\tif cmd := wf.Config[\"host.agent_command\"]; cmd != \"\" {\n   116→\t\texecutor.AgentCommands = prompt.ParseCommands(cmd)\n   117→\t}\n   118→\tif args := wf.Config[\"host.agent_args\"]; args != \"\" {\n   119→\t\texecutor.AgentArgs = strings.Fields(args)\n   120→\t}\n   121→\n   122→\teng := engine.New(executor)\n   123→\teng.SetStatusHandler(&hostStatusHandler{\n   124→\t\tprojectDir:   projectDir,\n   125→\t\torchRunID:    orchRunID,\n   126→\t\tstore:        r.Store,\n   127→\t\tcaptures:     r.Captures,\n   128→\t\tlogBroadcast: r.LogBroadcast,\n   129→\t\toutputDir:    outputDir,\n   130→\t})\n   131→\n   132→\trun, runErr := eng.Run(ctx, wf)\n   133→\n   134→\tresult := &RunResult{\n   135→\t\tRunID:     orchRunID,\n   136→\t\tState:     domain.RunStateFailed,\n   137→\t\tOutputDir: outputDir,\n   138→\t}\n   139→\tif run != nil {\n   140→\t\tresult.State = run.State\n   141→\t}\n   142→\n   143→\t// Persist final state.\n   144→\tif !r.SkipRunRecord {\n   145→\t\thostRun, _ := r.Store.GetRun(ctx, orchRunID)\n   146→\t\tif hostRun != nil {\n   147→\t\t\tif runErr != nil {\n   148→\t\t\t\thostRun.Fail(runErr.Error())\n   149→\t\t\t} else {\n   150→\t\t\t\thostRun.Complete(result.State)\n   151→\t\t\t}\n   152→\t\t\thostRun.ActiveSteps = nil\n   153→\t\t\t_ = r.Store.UpdateRun(ctx, hostRun)\n   154→\t\t}\n   155→\t}\n   156→\n   157→\tif runErr != nil {\n   158→\t\tlog.Printf(\"host workflow: %q failed for %s: %v\", wf.Name, projectDir, runErr)\n   159→\t\treturn result, runErr\n   160→\t}\n   161→\n   162→\tlog.Printf(\"host workflow: %q completed for %s with state %s\", wf.Name, projectDir, run.State)\n   163→\treturn result, nil\n   164→}\n   165→\n   166→// RunListTasksWorkflow executes the list-tasks workflow and returns the\n   167→// discovered tasks. No run record is created for list-tasks executions since\n   168→// they are polling operations that would otherwise clutter the run history.\n   169→func RunListTasksWorkflow(ctx context.Context, runner *Runner, projectDir string) ([]Task, *RunResult, error) {\n   170→\trunner.SkipRunRecord = true\n   171→\tresult, err := runner.RunNamed(ctx, projectDir, \"list-tasks\")\n   172→\tif err != nil {\n   173→\t\treturn nil, nil, err\n   174→\t}\n   175→\tif result.State != domain.RunStateSucceeded {\n   176→\t\treturn nil, result, fmt.Errorf(\"list-tasks workflow failed with state %s\", result.State)\n   177→\t}\n   178→\ttasks, err := ReadListTasksOutput(result.OutputDir)\n   179→\tif err != nil {\n   180→\t\treturn nil, result, err\n   181→\t}\n   182→\treturn tasks, result, nil\n   183→}\n   184→\n   185→// hostStatusHandler logs host workflow step events and persists them to the store.\n   186→// It mirrors the container-side status pipeline: saving captures and publishing\n   187→// to the log broadcaster so that cloche logs works identically for host runs.\n   188→type hostStatusHandler struct {\n   189→\tprojectDir   string\n   190→\torchRunID    string\n   191→\tstore        ports.RunStore\n   192→\tcaptures     ports.CaptureStore\n   193→\tlogBroadcast *logstream.Broadcaster\n   194→\toutputDir    string\n   195→}\n   196→\n   197→func (h *hostStatusHandler) OnStepStart(_ *domain.Run, step *domain.Step) {\n   198→\tnow := time.Now()\n   199→\tlog.Printf(\"host workflow [%s]: step %q started\", h.orchRunID, step.Name)\n   200→\tif h.store != nil {\n   201→\t\tif r, err := h.store.GetRun(context.Background(), h.orchRunID); err == nil {\n   202→\t\t\tr.RecordStepStart(step.Name)\n   203→\t\t\t_ = h.store.UpdateRun(context.Background(), r)\n   204→\t\t}\n   205→\t}\n   206→\tif h.captures != nil {\n   207→\t\t_ = h.captures.SaveCapture(context.Background(), h.orchRunID, &domain.StepExecution{\n   208→\t\t\tStepName:  step.Name,\n   209→\t\t\tStartedAt: now,\n   210→\t\t})\n   211→\t}\n   212→\tif h.logBroadcast != nil {\n   213→\t\th.logBroadcast.Publish(h.orchRunID, logstream.LogLine{\n   214→\t\t\tTimestamp: now.Format(time.RFC3339),\n   215→\t\t\tType:      \"status\",\n   216→\t\t\tContent:   \"step_started: \" + step.Name,\n   217→\t\t\tStepName:  step.Name,\n   218→\t\t})\n   219→\t}\n   220→}\n   221→\n   222→func (h *hostStatusHandler) OnStepComplete(_ *domain.Run, step *domain.Step, result string) {\n   223→\tnow := time.Now()\n   224→\tlog.Printf(\"host workflow [%s]: step %q completed with result %q\", h.orchRunID, step.Name, result)\n   225→\tif h.store != nil {\n   226→\t\tif r, err := h.store.GetRun(context.Background(), h.orchRunID); err == nil {\n   227→\t\t\tr.RecordStepComplete(step.Name, result)\n   228→\t\t\t_ = h.store.UpdateRun(context.Background(), r)\n   229→\t\t}\n   230→\t}\n   231→\tif h.captures != nil {\n   232→\t\t_ = h.captures.SaveCapture(context.Background(), h.orchRunID, &domain.StepExecution{\n   233→\t\t\tStepName:    step.Name,\n   234→\t\t\tResult:      result,\n   235→\t\t\tCompletedAt: now,\n   236→\t\t})\n   237→\t}\n   238→\tif h.logBroadcast != nil {\n   239→\t\t// Read step output and publish it before the completion event.\n   240→\t\toutputPath := filepath.Join(h.outputDir, step.Name+\".out\")\n   241→\t\tif data, err := os.ReadFile(outputPath); err == nil && len(data) > 0 {\n   242→\t\t\th.logBroadcast.Publish(h.orchRunID, logstream.LogLine{\n   243→\t\t\t\tTimestamp: now.Format(time.RFC3339),\n   244→\t\t\t\tType:      \"script\",\n   245→\t\t\t\tContent:   string(data),\n   246→\t\t\t\tStepName:  step.Name,\n   247→\t\t\t})\n   248→\t\t}\n   249→\t\th.logBroadcast.Publish(h.orchRunID, logstream.LogLine{\n   250→\t\t\tTimestamp: now.Format(time.RFC3339),\n   251→\t\t\tType:      \"status\",\n   252→\t\t\tContent:   \"step_completed: \" + step.Name + \" -> \" + result,\n   253→\t\t\tStepName:  step.Name,\n   254→\t\t})\n   255→\t}\n   256→}\n   257→\n   258→func (h *hostStatusHandler) OnRunComplete(run *domain.Run) {\n   259→\tlog.Printf(\"host workflow [%s]: run completed with state %s\", h.orchRunID, run.State)\n   260→}\n   261→"}]},"parent_tool_use_id":null,"session_id":"3b83d887-9f3b-4385-8c16-91cb9c40f66f","uuid":"763dc9ac-50ab-4270-b348-be2aaf8bab54","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/host/runner.go","content":"package host\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"log\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/cloche-dev/cloche/internal/adapters/agents/prompt\"\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/dsl\"\n\t\"github.com/cloche-dev/cloche/internal/engine\"\n\t\"github.com/cloche-dev/cloche/internal/logstream\"\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n)\n\n// Ensure hostStatusHandler implements engine.StatusHandler.\nvar _ engine.StatusHandler = (*hostStatusHandler)(nil)\n\n// Runner executes a host workflow by parsing host.cloche and walking the step graph.\ntype Runner struct {\n\tDispatcher    RunDispatcher\n\tStore         ports.RunStore\n\tCaptures      ports.CaptureStore       // optional: saves step captures for cloche logs\n\tLogBroadcast  *logstream.Broadcaster   // optional: publishes live log lines\n\tTaskID        string                   // optional task ID assigned by the daemon loop\n\tExtraEnv      []string                 // additional KEY=VALUE env vars passed to all steps\n\tSkipRunRecord bool                     // when true, don't persist a run record to the store\n}\n\n// RunResult contains the outcome of a host workflow execution.\ntype RunResult struct {\n\tRunID     string\n\tState     domain.RunState\n\tOutputDir string // path to the step output directory\n}\n\n// Run parses .cloche/host.cloche from projectDir and executes the \"main\" workflow.\nfunc (r *Runner) Run(ctx context.Context, projectDir string) (*RunResult, error) {\n\treturn r.RunWithID(ctx, projectDir, domain.GenerateRunID(\"main\"))\n}\n\n// RunWithID is like Run but uses the provided run ID instead of generating one.\nfunc (r *Runner) RunWithID(ctx context.Context, projectDir string, orchRunID string) (*RunResult, error) {\n\treturn r.runNamedWorkflow(ctx, projectDir, \"main\", orchRunID)\n}\n\n// RunNamed parses .cloche/host.cloche from projectDir and executes the workflow\n// with the given name. The host.cloche file may contain multiple workflows (e.g.\n// \"list-tasks\", \"main\", \"finalize\"). Returns an error if the named workflow is\n// not found.\nfunc (r *Runner) RunNamed(ctx context.Context, projectDir string, workflowName string) (*RunResult, error) {\n\torchRunID := domain.GenerateRunID(workflowName)\n\treturn r.runNamedWorkflow(ctx, projectDir, workflowName, orchRunID)\n}\n\n// runNamedWorkflow is the internal implementation that runs a specific named\n// workflow from host.cloche.\nfunc (r *Runner) runNamedWorkflow(ctx context.Context, projectDir string, workflowName string, orchRunID string) (*RunResult, error) {\n\thostPath := filepath.Join(projectDir, \".cloche\", \"host.cloche\")\n\tdata, err := os.ReadFile(hostPath)\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"reading host.cloche: %w\", err)\n\t}\n\n\tworkflows, err := dsl.ParseAllForHost(string(data))\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"parsing host.cloche: %w\", err)\n\t}\n\n\twf, ok := workflows[workflowName]\n\tif !ok {\n\t\treturn nil, fmt.Errorf(\"host.cloche has no workflow %q\", workflowName)\n\t}\n\n\t// Create output directory for step outputs\n\toutputDir := filepath.Join(projectDir, \".cloche\", orchRunID, \"output\")\n\tif err := os.MkdirAll(outputDir, 0755); err != nil {\n\t\treturn nil, fmt.Errorf(\"creating output dir: %w\", err)\n\t}\n\n\tlog.Printf(\"host workflow: starting %q for project %s (run %s)\", wf.Name, projectDir, orchRunID)\n\n\t// Persist the host run in the store so it appears in list/status/logs.\n\t// When SkipRunRecord is set (e.g. for list-tasks polling), skip creating\n\t// the record to avoid cluttering the run history.\n\tif !r.SkipRunRecord {\n\t\thostRun := domain.NewRun(orchRunID, wf.Name)\n\t\thostRun.ProjectDir = projectDir\n\t\thostRun.IsHost = true\n\t\thostRun.TaskID = r.TaskID\n\t\tif err := r.Store.CreateRun(ctx, hostRun); err != nil {\n\t\t\treturn nil, fmt.Errorf(\"creating host run record: %w\", err)\n\t\t}\n\t\thostRun.Start()\n\t\t_ = r.Store.UpdateRun(ctx, hostRun)\n\t}\n\n\texecutor := &Executor{\n\t\tProjectDir: projectDir,\n\t\tMainDir:    MainWorktreeDir(projectDir),\n\t\tDispatcher: r.Dispatcher,\n\t\tStore:      r.Store,\n\t\tOutputDir:  outputDir,\n\t\tWires:      wf.Wiring,\n\t\tHostRunID:  orchRunID,\n\t\tTaskID:     r.TaskID,\n\t\tExtraEnv:   r.ExtraEnv,\n\t}\n\n\t// Configure agent from workflow-level host config\n\tif cmd := wf.Config[\"host.agent_command\"]; cmd != \"\" {\n\t\texecutor.AgentCommands = prompt.ParseCommands(cmd)\n\t}\n\tif args := wf.Config[\"host.agent_args\"]; args != \"\" {\n\t\texecutor.AgentArgs = strings.Fields(args)\n\t}\n\n\teng := engine.New(executor)\n\teng.SetStatusHandler(&hostStatusHandler{\n\t\tprojectDir:   projectDir,\n\t\torchRunID:    orchRunID,\n\t\tstore:        r.Store,\n\t\tcaptures:     r.Captures,\n\t\tlogBroadcast: r.LogBroadcast,\n\t\toutputDir:    outputDir,\n\t})\n\n\trun, runErr := eng.Run(ctx, wf)\n\n\tresult := &RunResult{\n\t\tRunID:     orchRunID,\n\t\tState:     domain.RunStateFailed,\n\t\tOutputDir: outputDir,\n\t}\n\tif run != nil {\n\t\tresult.State = run.State\n\t}\n\n\t// Persist final state.\n\tif !r.SkipRunRecord {\n\t\thostRun, _ := r.Store.GetRun(ctx, orchRunID)\n\t\tif hostRun != nil {\n\t\t\tif runErr != nil {\n\t\t\t\thostRun.Fail(runErr.Error())\n\t\t\t} else {\n\t\t\t\thostRun.Complete(result.State)\n\t\t\t}\n\t\t\thostRun.ActiveSteps = nil\n\t\t\t_ = r.Store.UpdateRun(ctx, hostRun)\n\t\t}\n\t}\n\n\tif runErr != nil {\n\t\tlog.Printf(\"host workflow: %q failed for %s: %v\", wf.Name, projectDir, runErr)\n\t\treturn result, runErr\n\t}\n\n\tlog.Printf(\"host workflow: %q completed for %s with state %s\", wf.Name, projectDir, run.State)\n\treturn result, nil\n}\n\n// RunListTasksWorkflow executes the list-tasks workflow and returns the\n// discovered tasks. No run record is created for list-tasks executions since\n// they are polling operations that would otherwise clutter the run history.\nfunc RunListTasksWorkflow(ctx context.Context, runner *Runner, projectDir string) ([]Task, *RunResult, error) {\n\trunner.SkipRunRecord = true\n\tresult, err := runner.RunNamed(ctx, projectDir, \"list-tasks\")\n\tif err != nil {\n\t\treturn nil, nil, err\n\t}\n\tif result.State != domain.RunStateSucceeded {\n\t\treturn nil, result, fmt.Errorf(\"list-tasks workflow failed with state %s\", result.State)\n\t}\n\ttasks, err := ReadListTasksOutput(result.OutputDir)\n\tif err != nil {\n\t\treturn nil, result, err\n\t}\n\treturn tasks, result, nil\n}\n\n// hostStatusHandler logs host workflow step events and persists them to the store.\n// It mirrors the container-side status pipeline: saving captures and publishing\n// to the log broadcaster so that cloche logs works identically for host runs.\ntype hostStatusHandler struct {\n\tprojectDir   string\n\torchRunID    string\n\tstore        ports.RunStore\n\tcaptures     ports.CaptureStore\n\tlogBroadcast *logstream.Broadcaster\n\toutputDir    string\n}\n\nfunc (h *hostStatusHandler) OnStepStart(_ *domain.Run, step *domain.Step) {\n\tnow := time.Now()\n\tlog.Printf(\"host workflow [%s]: step %q started\", h.orchRunID, step.Name)\n\tif h.store != nil {\n\t\tif r, err := h.store.GetRun(context.Background(), h.orchRunID); err == nil {\n\t\t\tr.RecordStepStart(step.Name)\n\t\t\t_ = h.store.UpdateRun(context.Background(), r)\n\t\t}\n\t}\n\tif h.captures != nil {\n\t\t_ = h.captures.SaveCapture(context.Background(), h.orchRunID, &domain.StepExecution{\n\t\t\tStepName:  step.Name,\n\t\t\tStartedAt: now,\n\t\t})\n\t}\n\tif h.logBroadcast != nil {\n\t\th.logBroadcast.Publish(h.orchRunID, logstream.LogLine{\n\t\t\tTimestamp: now.Format(time.RFC3339),\n\t\t\tType:      \"status\",\n\t\t\tContent:   \"step_started: \" + step.Name,\n\t\t\tStepName:  step.Name,\n\t\t})\n\t}\n}\n\nfunc (h *hostStatusHandler) OnStepComplete(_ *domain.Run, step *domain.Step, result string) {\n\tnow := time.Now()\n\tlog.Printf(\"host workflow [%s]: step %q completed with result %q\", h.orchRunID, step.Name, result)\n\tif h.store != nil {\n\t\tif r, err := h.store.GetRun(context.Background(), h.orchRunID); err == nil {\n\t\t\tr.RecordStepComplete(step.Name, result)\n\t\t\t_ = h.store.UpdateRun(context.Background(), r)\n\t\t}\n\t}\n\tif h.captures != nil {\n\t\t_ = h.captures.SaveCapture(context.Background(), h.orchRunID, &domain.StepExecution{\n\t\t\tStepName:    step.Name,\n\t\t\tResult:      result,\n\t\t\tCompletedAt: now,\n\t\t})\n\t}\n\tif h.logBroadcast != nil {\n\t\t// Read step output and publish it before the completion event.\n\t\toutputPath := filepath.Join(h.outputDir, step.Name+\".out\")\n\t\tif data, err := os.ReadFile(outputPath); err == nil && len(data) > 0 {\n\t\t\th.logBroadcast.Publish(h.orchRunID, logstream.LogLine{\n\t\t\t\tTimestamp: now.Format(time.RFC3339),\n\t\t\t\tType:      \"script\",\n\t\t\t\tContent:   string(data),\n\t\t\t\tStepName:  step.Name,\n\t\t\t})\n\t\t}\n\t\th.logBroadcast.Publish(h.orchRunID, logstream.LogLine{\n\t\t\tTimestamp: now.Format(time.RFC3339),\n\t\t\tType:      \"status\",\n\t\t\tContent:   \"step_completed: \" + step.Name + \" -> \" + result,\n\t\t\tStepName:  step.Name,\n\t\t})\n\t}\n}\n\nfunc (h *hostStatusHandler) OnRunComplete(run *domain.Run) {\n\tlog.Printf(\"host workflow [%s]: run completed with state %s\", h.orchRunID, run.State)\n}\n","numLines":261,"startLine":1,"totalLines":261}}}
