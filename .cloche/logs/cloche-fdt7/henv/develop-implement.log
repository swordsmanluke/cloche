n    53→\twf := &domain.Workflow{\n    54→\t\tName: \"retry\",\n    55→\t\tSteps: map[string]*domain.Step{\n    56→\t\t\t\"code\":  {Name: \"code\", Type: domain.StepTypeAgent, Results: []string{\"success\", \"fail\"}},\n    57→\t\t\t\"check\": {Name: \"check\", Type: domain.StepTypeScript, Results: []string{\"pass\", \"fail\"}},\n    58→\t\t},\n    59→\t\tWiring: []domain.Wire{\n    60→\t\t\t{From: \"code\", Result: \"success\", To: \"check\"},\n    61→\t\t\t{From: \"code\", Result: \"fail\", To: domain.StepAbort},\n    62→\t\t\t{From: \"check\", Result: \"pass\", To: domain.StepDone},\n    63→\t\t\t{From: \"check\", Result: \"fail\", To: \"code\"},\n    64→\t\t},\n    65→\t\tEntryStep: \"code\",\n    66→\t}\n    67→\n    68→\tcallCount := 0\n    69→\tdynamicExec := engine.StepExecutorFunc(func(_ context.Context, step *domain.Step) (string, error) {\n    70→\t\tcallCount++\n    71→\t\tif step.Name == \"check\" && callCount <= 2 {\n    72→\t\t\treturn \"fail\", nil\n    73→\t\t}\n    74→\t\tif step.Name == \"code\" {\n    75→\t\t\treturn \"success\", nil\n    76→\t\t}\n    77→\t\treturn \"pass\", nil\n    78→\t})\n    79→\n    80→\teng := engine.New(dynamicExec)\n    81→\trun, err := eng.Run(context.Background(), wf)\n    82→\trequire.NoError(t, err)\n    83→\tassert.Equal(t, domain.RunStateSucceeded, run.State)\n    84→}\n    85→\n    86→func TestEngine_Abort(t *testing.T) {\n    87→\twf := &domain.Workflow{\n    88→\t\tName: \"abort-test\",\n    89→\t\tSteps: map[string]*domain.Step{\n    90→\t\t\t\"code\": {Name: \"code\", Type: domain.StepTypeAgent, Results: []string{\"success\", \"fail\"}},\n    91→\t\t},\n    92→\t\tWiring: []domain.Wire{\n    93→\t\t\t{From: \"code\", Result: \"success\", To: domain.StepDone},\n    94→\t\t\t{From: \"code\", Result: \"fail\", To: domain.StepAbort},\n    95→\t\t},\n    96→\t\tEntryStep: \"code\",\n    97→\t}\n    98→\n    99→\texec := &fakeExecutor{results: map[string]string{\"code\": \"fail\"}}\n   100→\teng := engine.New(exec)\n   101→\n   102→\trun, err := eng.Run(context.Background(), wf)\n   103→\trequire.NoError(t, err)\n   104→\tassert.Equal(t, domain.RunStateFailed, run.State)\n   105→}\n   106→\n   107→func TestEngine_ContextCancellation(t *testing.T) {\n   108→\twf := &domain.Workflow{\n   109→\t\tName: \"cancel-test\",\n   110→\t\tSteps: map[string]*domain.Step{\n   111→\t\t\t\"slow\": {Name: \"slow\", Type: domain.StepTypeScript, Results: []string{\"done\"}},\n   112→\t\t},\n   113→\t\tWiring: []domain.Wire{\n   114→\t\t\t{From: \"slow\", Result: \"done\", To: domain.StepDone},\n   115→\t\t},\n   116→\t\tEntryStep: \"slow\",\n   117→\t}\n   118→\n   119→\tctx, cancel := context.WithCancel(context.Background())\n   120→\tcancel()\n   121→\n   122→\texec := &fakeExecutor{results: map[string]string{\"slow\": \"done\"}}\n   123→\teng := engine.New(exec)\n   124→\n   125→\trun, err := eng.Run(ctx, wf)\n   126→\trequire.Error(t, err)\n   127→\tassert.Equal(t, domain.RunStateCancelled, run.State)\n   128→}\n   129→\n   130→func TestEngine_Fanout(t *testing.T) {\n   131→\twf := &domain.Workflow{\n   132→\t\tName: \"fanout\",\n   133→\t\tSteps: map[string]*domain.Step{\n   134→\t\t\t\"code\": {Name: \"code\", Type: domain.StepTypeAgent, Results: []string{\"success\"}},\n   135→\t\t\t\"test\": {Name: \"test\", Type: domain.StepTypeScript, Results: []string{\"success\"}},\n   136→\t\t\t\"lint\": {Name: \"lint\", Type: domain.StepTypeScript, Results: []string{\"success\"}},\n   137→\t\t},\n   138→\t\tWiring: []domain.Wire{\n   139→\t\t\t{From: \"code\", Result: \"success\", To: \"test\"},\n   140→\t\t\t{From: \"code\", Result: \"success\", To: \"lint\"},\n   141→\t\t\t{From: \"test\", Result: \"success\", To: domain.StepDone},\n   142→\t\t\t{From: \"lint\", Result: \"success\", To: domain.StepDone},\n   143→\t\t},\n   144→\t\tEntryStep: \"code\",\n   145→\t}\n   146→\n   147→\texec := &fakeExecutor{results: map[string]string{\n   148→\t\t\"code\": \"success\", \"test\": \"success\", \"lint\": \"success\",\n   149→\t}}\n   150→\teng := engine.New(exec)\n   151→\n   152→\trun, err := eng.Run(context.Background(), wf)\n   153→\trequire.NoError(t, err)\n   154→\tassert.Equal(t, domain.RunStateSucceeded, run.State)\n   155→\t// All three steps must have been called\n   156→\texec.mu.Lock()\n   157→\tassert.Contains(t, exec.called, \"code\")\n   158→\tassert.Contains(t, exec.called, \"test\")\n   159→\tassert.Contains(t, exec.called, \"lint\")\n   160→\texec.mu.Unlock()\n   161→}\n   162→\n   163→func TestEngine_CollectAll(t *testing.T) {\n   164→\twf := &domain.Workflow{\n   165→\t\tName: \"collect-all\",\n   166→\t\tSteps: map[string]*domain.Step{\n   167→\t\t\t\"code\":  {Name: \"code\", Type: domain.StepTypeAgent, Results: []string{\"success\"}},\n   168→\t\t\t\"test\":  {Name: \"test\", Type: domain.StepTypeScript, Results: []string{\"success\"}},\n   169→\t\t\t\"lint\":  {Name: \"lint\", Type: domain.StepTypeScript, Results: []string{\"success\"}},\n   170→\t\t\t\"merge\": {Name: \"merge\", Type: domain.StepTypeScript, Results: []string{\"success\"}},\n   171→\t\t},\n   172→\t\tWiring: []domain.Wire{\n   173→\t\t\t{From: \"code\", Result: \"success\", To: \"test\"},\n   174→\t\t\t{From: \"code\", Result: \"success\", To: \"lint\"},\n   175→\t\t\t{From: \"merge\", Result: \"success\", To: domain.StepDone},\n   176→\t\t},\n   177→\t\tCollects: []domain.Collect{\n   178→\t\t\t{\n   179→\t\t\t\tMode: domain.CollectAll,\n   180→\t\t\t\tConditions: []domain.WireCondition{\n   181→\t\t\t\t\t{Step: \"test\", Result: \"success\"},\n   182→\t\t\t\t\t{Step: \"lint\", Result: \"success\"},\n   183→\t\t\t\t},\n   184→\t\t\t\tTo: \"merge\",\n   185→\t\t\t},\n   186→\t\t},\n   187→\t\tEntryStep: \"code\",\n   188→\t}\n   189→\n   190→\texec := &fakeExecutor{results: map[string]string{\n   191→\t\t\"code\": \"success\", \"test\": \"success\", \"lint\": \"success\", \"merge\": \"success\",\n   192→\t}}\n   193→\teng := engine.New(exec)\n   194→\n   195→\trun, err := eng.Run(context.Background(), wf)\n   196→\trequire.NoError(t, err)\n   197→\tassert.Equal(t, domain.RunStateSucceeded, run.State)\n   198→\texec.mu.Lock()\n   199→\tassert.Contains(t, exec.called, \"merge\")\n   200→\texec.mu.Unlock()\n   201→}\n   202→\n   203→func TestEngine_CollectAny(t *testing.T) {\n   204→\twf := &domain.Workflow{\n   205→\t\tName: \"collect-any\",\n   206→\t\tSteps: map[string]*domain.Step{\n   207→\t\t\t\"code\":  {Name: \"code\", Type: domain.StepTypeAgent, Results: []string{\"success\"}},\n   208→\t\t\t\"test\":  {Name: \"test\", Type: domain.StepTypeScript, Results: []string{\"success\"}},\n   209→\t\t\t\"lint\":  {Name: \"lint\", Type: domain.StepTypeScript, Results: []string{\"success\"}},\n   210→\t\t\t\"quick\": {Name: \"quick\", Type: domain.StepTypeScript, Results: []string{\"success\"}},\n   211→\t\t},\n   212→\t\tWiring: []domain.Wire{\n   213→\t\t\t{From: \"code\", Result: \"success\", To: \"test\"},\n   214→\t\t\t{From: \"code\", Result: \"success\", To: \"lint\"},\n   215→\t\t\t{From: \"test\", Result: \"success\", To: domain.StepDone},\n   216→\t\t\t{From: \"lint\", Result: \"success\", To: domain.StepDone},\n   217→\t\t\t{From: \"quick\", Result: \"success\", To: domain.StepDone},\n   218→\t\t},\n   219→\t\tCollects: []domain.Collect{\n   220→\t\t\t{\n   221→\t\t\t\tMode: domain.CollectAny,\n   222→\t\t\t\tConditions: []domain.WireCondition{\n   223→\t\t\t\t\t{Step: \"test\", Result: \"success\"},\n   224→\t\t\t\t\t{Step: \"lint\", Result: \"success\"},\n   225→\t\t\t\t},\n   226→\t\t\t\tTo: \"quick\",\n   227→\t\t\t},\n   228→\t\t},\n   229→\t\tEntryStep: \"code\",\n   230→\t}\n   231→\n   232→\texec := &fakeExecutor{results: map[string]string{\n   233→\t\t\"code\": \"success\", \"test\": \"success\", \"lint\": \"success\", \"quick\": \"success\",\n   234→\t}}\n   235→\teng := engine.New(exec)\n   236→\n   237→\trun, err := eng.Run(context.Background(), wf)\n   238→\trequire.NoError(t, err)\n   239→\tassert.Equal(t, domain.RunStateSucceeded, run.State)\n   240→\texec.mu.Lock()\n   241→\tassert.Contains(t, exec.called, \"quick\")\n   242→\texec.mu.Unlock()\n   243→}\n   244→\n   245→func TestEngine_UndeclaredResultAborts(t *testing.T) {\n   246→\twf := &domain.Workflow{\n   247→\t\tName: \"undeclared\",\n   248→\t\tSteps: map[string]*domain.Step{\n   249→\t\t\t\"code\": {Name: \"code\", Type: domain.StepTypeAgent, Results: []string{\"success\", \"fail\"}},\n   250→\t\t},\n   251→\t\tWiring: []domain.Wire{\n   252→\t\t\t{From: \"code\", Result: \"success\", To: domain.StepDone},\n   253→\t\t\t{From: \"code\", Result: \"fail\", To: domain.StepAbort},\n   254→\t\t},\n   255→\t\tEntryStep: \"code\",\n   256→\t}\n   257→\n   258→\texec := &fakeExecutor{results: map[string]string{\"code\": \"unknown\"}}\n   259→\teng := engine.New(exec)\n   260→\n   261→\trun, err := eng.Run(context.Background(), wf)\n   262→\trequire.Error(t, err)\n   263→\tassert.Equal(t, domain.RunStateFailed, run.State)\n   264→\tassert.Contains(t, err.Error(), \"undeclared\")\n   265→}\n   266→\n   267→// slowExecutor blocks until the context is cancelled, simulating a hanging agent.\n   268→type slowExecutor struct {\n   269→\tmu     sync.Mutex\n   270→\tcalled []string\n   271→}\n   272→\n   273→func (s *slowExecutor) Execute(ctx context.Context, step *domain.Step) (string, error) {\n   274→\ts.mu.Lock()\n   275→\ts.called = append(s.called, step.Name)\n   276→\ts.mu.Unlock()\n   277→\t<-ctx.Done()\n   278→\treturn \"\", fmt.Errorf(\"step %q timed out: %w\", step.Name, ctx.Err())\n   279→}\n   280→\n   281→func TestEngine_StepTimeout(t *testing.T) {\n   282→\twf := &domain.Workflow{\n   283→\t\tName: \"timeout-test\",\n   284→\t\tSteps: map[string]*domain.Step{\n   285→\t\t\t\"hang\": {\n   286→\t\t\t\tName:    \"hang\",\n   287→\t\t\t\tType:    domain.StepTypeAgent,\n   288→\t\t\t\tResults: []string{\"success\", \"fail\"},\n   289→\t\t\t\tConfig:  map[string]string{\"prompt\": \"do stuff\", \"timeout\": \"100ms\"},\n   290→\t\t\t},\n   291→\t\t},\n   292→\t\tWiring: []domain.Wire{\n   293→\t\t\t{From: \"hang\", Result: \"success\", To: domain.StepDone},\n   294→\t\t\t{From: \"hang\", Result: \"fail\", To: domain.StepAbort},\n   295→\t\t},\n   296→\t\tEntryStep: \"hang\",\n   297→\t}\n   298→\n   299→\texec := &slowExecutor{}\n   300→\teng := engine.New(exec)\n   301→\n   302→\tstart := time.Now()\n   303→\trun, err := eng.Run(context.Background(), wf)\n   304→\telapsed := time.Since(start)\n   305→\n   306→\trequire.Error(t, err)\n   307→\tassert.Equal(t, domain.RunStateFailed, run.State)\n   308→\tassert.Contains(t, err.Error(), \"timed out\")\n   309→\tassert.Less(t, elapsed, 5*time.Second, \"timeout should fire quickly, not wait for default 30m\")\n   310→}\n   311→\n   312→func TestEngine_StepTimeoutOverridesDefault(t *testing.T) {\n   313→\twf := &domain.Workflow{\n   314→\t\tName: \"timeout-override\",\n   315→\t\tSteps: map[string]*domain.Step{\n   316→\t\t\t\"hang\": {\n   317→\t\t\t\tName:    \"hang\",\n   318→\t\t\t\tType:    domain.StepTypeAgent,\n   319→\t\t\t\tResults: []string{\"success\", \"fail\"},\n   320→\t\t\t\tConfig:  map[string]string{\"prompt\": \"do stuff\"}, // no per-step timeout\n   321→\t\t\t},\n   322→\t\t},\n   323→\t\tWiring: []domain.Wire{\n   324→\t\t\t{From: \"hang\", Result: \"success\", To: domain.StepDone},\n   325→\t\t\t{From: \"hang\", Result: \"fail\", To: domain.StepAbort},\n   326→\t\t},\n   327→\t\tEntryStep: \"hang\",\n   328→\t}\n   329→\n   330→\texec := &slowExecutor{}\n   331→\teng := engine.New(exec)\n   332→\teng.SetDefaultTimeout(100 * time.Millisecond)\n   333→\n   334→\tstart := time.Now()\n   335→\trun, err := eng.Run(context.Background(), wf)\n   336→\telapsed := time.Since(start)\n   337→\n   338→\trequire.Error(t, err)\n   339→\tassert.Equal(t, domain.RunStateFailed, run.State)\n   340→\tassert.Less(t, elapsed, 5*time.Second, \"default timeout should fire quickly\")\n   341→}\n   342→"}]},"parent_tool_use_id":null,"session_id":"3b83d887-9f3b-4385-8c16-91cb9c40f66f","uuid":"ab76f3cc-c765-4eaf-b39d-f4b610fbd7d5","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/engine/engine_test.go","content":"package engine_test\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"sync\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/engine\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n)\n\ntype fakeExecutor struct {\n\tmu      sync.Mutex\n\tresults map[string]string\n\tcalled  []string\n}\n\nfunc (f *fakeExecutor) Execute(_ context.Context, step *domain.Step) (string, error) {\n\tf.mu.Lock()\n\tdefer f.mu.Unlock()\n\tf.called = append(f.called, step.Name)\n\treturn f.results[step.Name], nil\n}\n\nfunc TestEngine_LinearWorkflow(t *testing.T) {\n\twf := &domain.Workflow{\n\t\tName: \"linear\",\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"build\": {Name: \"build\", Type: domain.StepTypeScript, Results: []string{\"success\"}},\n\t\t\t\"test\":  {Name: \"test\", Type: domain.StepTypeScript, Results: []string{\"pass\"}},\n\t\t},\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"build\", Result: \"success\", To: \"test\"},\n\t\t\t{From: \"test\", Result: \"pass\", To: domain.StepDone},\n\t\t},\n\t\tEntryStep: \"build\",\n\t}\n\n\texec := &fakeExecutor{results: map[string]string{\"build\": \"success\", \"test\": \"pass\"}}\n\teng := engine.New(exec)\n\n\trun, err := eng.Run(context.Background(), wf)\n\trequire.NoError(t, err)\n\tassert.Equal(t, domain.RunStateSucceeded, run.State)\n\tassert.Equal(t, []string{\"build\", \"test\"}, exec.called)\n}\n\nfunc TestEngine_RetryLoop(t *testing.T) {\n\twf := &domain.Workflow{\n\t\tName: \"retry\",\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"code\":  {Name: \"code\", Type: domain.StepTypeAgent, Results: []string{\"success\", \"fail\"}},\n\t\t\t\"check\": {Name: \"check\", Type: domain.StepTypeScript, Results: []string{\"pass\", \"fail\"}},\n\t\t},\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"code\", Result: \"success\", To: \"check\"},\n\t\t\t{From: \"code\", Result: \"fail\", To: domain.StepAbort},\n\t\t\t{From: \"check\", Result: \"pass\", To: domain.StepDone},\n\t\t\t{From: \"check\", Result: \"fail\", To: \"code\"},\n\t\t},\n\t\tEntryStep: \"code\",\n\t}\n\n\tcallCount := 0\n\tdynamicExec := engine.StepExecutorFunc(func(_ context.Context, step *domain.Step) (string, error) {\n\t\tcallCount++\n\t\tif step.Name == \"check\" && callCount <= 2 {\n\t\t\treturn \"fail\", nil\n\t\t}\n\t\tif step.Name == \"code\" {\n\t\t\treturn \"success\", nil\n\t\t}\n\t\treturn \"pass\", nil\n\t})\n\n\teng := engine.New(dynamicExec)\n\trun, err := eng.Run(context.Background(), wf)\n\trequire.NoError(t, err)\n\tassert.Equal(t, domain.RunStateSucceeded, run.State)\n}\n\nfunc TestEngine_Abort(t *testing.T) {\n\twf := &domain.Workflow{\n\t\tName: \"abort-test\",\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"code\": {Name: \"code\", Type: domain.StepTypeAgent, Results: []string{\"success\", \"fail\"}},\n\t\t},\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"code\", Result: \"success\", To: domain.StepDone},\n\t\t\t{From: \"code\", Result: \"fail\", To: domain.StepAbort},\n\t\t},\n\t\tEntryStep: \"code\",\n\t}\n\n\texec := &fakeExecutor{results: map[string]string{\"code\": \"fail\"}}\n\teng := engine.New(exec)\n\n\trun, err := eng.Run(context.Background(), wf)\n\trequire.NoError(t, err)\n\tassert.Equal(t, domain.RunStateFailed, run.State)\n}\n\nfunc TestEngine_ContextCancellation(t *testing.T) {\n\twf := &domain.Workflow{\n\t\tName: \"cancel-test\",\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"slow\": {Name: \"slow\", Type: domain.StepTypeScript, Results: []string{\"done\"}},\n\t\t},\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"slow\", Result: \"done\", To: domain.StepDone},\n\t\t},\n\t\tEntryStep: \"slow\",\n\t}\n\n\tctx, cancel := context.WithCancel(context.Background())\n\tcancel()\n\n\texec := &fakeExecutor{results: map[string]string{\"slow\": \"done\"}}\n\teng := engine.New(exec)\n\n\trun, err := eng.Run(ctx, wf)\n\trequire.Error(t, err)\n\tassert.Equal(t, domain.RunStateCancelled, run.State)\n}\n\nfunc TestEngine_Fanout(t *testing.T) {\n\twf := &domain.Workflow{\n\t\tName: \"fanout\",\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"code\": {Name: \"code\", Type: domain.StepTypeAgent, Results: []string{\"success\"}},\n\t\t\t\"test\": {Name: \"test\", Type: domain.StepTypeScript, Results: []string{\"success\"}},\n\t\t\t\"lint\": {Name: \"lint\", Type: domain.StepTypeScript, Results: []string{\"success\"}},\n\t\t},\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"code\", Result: \"success\", To: \"test\"},\n\t\t\t{From: \"code\", Result: \"success\", To: \"lint\"},\n\t\t\t{From: \"test\", Result: \"success\", To: domain.StepDone},\n\t\t\t{From: \"lint\", Result: \"success\", To: domain.StepDone},\n\t\t},\n\t\tEntryStep: \"code\",\n\t}\n\n\texec := &fakeExecutor{results: map[string]string{\n\t\t\"code\": \"success\", \"test\": \"success\", \"lint\": \"success\",\n\t}}\n\teng := engine.New(exec)\n\n\trun, err := eng.Run(context.Background(), wf)\n\trequire.NoError(t, err)\n\tassert.Equal(t, domain.RunStateSucceeded, run.State)\n\t// All three steps must have been called\n\texec.mu.Lock()\n\tassert.Contains(t, exec.called, \"code\")\n\tassert.Contains(t, exec.called, \"test\")\n\tassert.Contains(t, exec.called, \"lint\")\n\texec.mu.Unlock()\n}\n\nfunc TestEngine_CollectAll(t *testing.T) {\n\twf := &domain.Workflow{\n\t\tName: \"collect-all\",\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"code\":  {Name: \"code\", Type: domain.StepTypeAgent, Results: []string{\"success\"}},\n\t\t\t\"test\":  {Name: \"test\", Type: domain.StepTypeScript, Results: []string{\"success\"}},\n\t\t\t\"lint\":  {Name: \"lint\", Type: domain.StepTypeScript, Results: []string{\"success\"}},\n\t\t\t\"merge\": {Name: \"merge\", Type: domain.StepTypeScript, Results: []string{\"success\"}},\n\t\t},\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"code\", Result: \"success\", To: \"test\"},\n\t\t\t{From: \"code\", Result: \"success\", To: \"lint\"},\n\t\t\t{From: \"merge\", Result: \"success\", To: domain.StepDone},\n\t\t},\n\t\tCollects: []domain.Collect{\n\t\t\t{\n\t\t\t\tMode: domain.CollectAll,\n\t\t\t\tConditions: []domain.WireCondition{\n\t\t\t\t\t{Step: \"test\", Result: \"success\"},\n\t\t\t\t\t{Step: \"lint\", Result: \"success\"},\n\t\t\t\t},\n\t\t\t\tTo: \"merge\",\n\t\t\t},\n\t\t},\n\t\tEntryStep: \"code\",\n\t}\n\n\texec := &fakeExecutor{results: map[string]string{\n\t\t\"code\": \"success\", \"test\": \"success\", \"lint\": \"success\", \"merge\": \"success\",\n\t}}\n\teng := engine.New(exec)\n\n\trun, err := eng.Run(context.Background(), wf)\n\trequire.NoError(t, err)\n\tassert.Equal(t, domain.RunStateSucceeded, run.State)\n\texec.mu.Lock()\n\tassert.Contains(t, exec.called, \"merge\")\n\texec.mu.Unlock()\n}\n\nfunc TestEngine_CollectAny(t *testing.T) {\n\twf := &domain.Workflow{\n\t\tName: \"collect-any\",\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"code\":  {Name: \"code\", Type: domain.StepTypeAgent, Results: []string{\"success\"}},\n\t\t\t\"test\":  {Name: \"test\", Type: domain.StepTypeScript, Results: []string{\"success\"}},\n\t\t\t\"lint\":  {Name: \"lint\", Type: domain.StepTypeScript, Results: []string{\"success\"}},\n\t\t\t\"quick\": {Name: \"quick\", Type: domain.StepTypeScript, Results: []string{\"success\"}},\n\t\t},\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"code\", Result: \"success\", To: \"test\"},\n\t\t\t{From: \"code\", Result: \"success\", To: \"lint\"},\n\t\t\t{From: \"test\", Result: \"success\", To: domain.StepDone},\n\t\t\t{From: \"lint\", Result: \"success\", To: domain.StepDone},\n\t\t\t{From: \"quick\", Result: \"success\", To: domain.StepDone},\n\t\t},\n\t\tCollects: []domain.Collect{\n\t\t\t{\n\t\t\t\tMode: domain.CollectAny,\n\t\t\t\tConditions: []domain.WireCondition{\n\t\t\t\t\t{Step: \"test\", Result: \"success\"},\n\t\t\t\t\t{Step: \"lint\", Result: \"success\"},\n\t\t\t\t},\n\t\t\t\tTo: \"quick\",\n\t\t\t},\n\t\t},\n\t\tEntryStep: \"code\",\n\t}\n\n\texec := &fakeExecutor{results: map[string]string{\n\t\t\"code\": \"success\", \"test\": \"success\", \"lint\": \"success\", \"quick\": \"success\",\n\t}}\n\teng := engine.New(exec)\n\n\trun, err := eng.Run(context.Background(), wf)\n\trequire.NoError(t, err)\n\tassert.Equal(t, domain.RunStateSucceeded, run.State)\n\texec.mu.Lock()\n\tassert.Contains(t, exec.called, \"quick\")\n\texec.mu.Unlock()\n}\n\nfunc TestEngine_UndeclaredResultAborts(t *testing.T) {\n\twf := &domain.Workflow{\n\t\tName: \"undeclared\",\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"code\": {Name: \"code\", Type: domain.StepTypeAgent, Results: []string{\"success\", \"fail\"}},\n\t\t},\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"code\", Result: \"success\", To: domain.StepDone},\n\t\t\t{From: \"code\", Result: \"fail\", To: domain.StepAbort},\n\t\t},\n\t\tEntryStep: \"code\",\n\t}\n\n\texec := &fakeExecutor{results: map[string]string{\"code\": \"unknown\"}}\n\teng := engine.New(exec)\n\n\trun, err := eng.Run(context.Background(), wf)\n\trequire.Error(t, err)\n\tassert.Equal(t, domain.RunStateFailed, run.State)\n\tassert.Contains(t, err.Error(), \"undeclared\")\n}\n\n// slowExecutor blocks until the context is cancelled, simulating a hanging agent.\ntype slowExecutor struct {\n\tmu     sync.Mutex\n\tcalled []string\n}\n\nfunc (s *slowExecutor) Execute(ctx context.Context, step *domain.Step) (string, error) {\n\ts.mu.Lock()\n\ts.called = append(s.called, step.Name)\n\ts.mu.Unlock()\n\t<-ctx.Done()\n\treturn \"\", fmt.Errorf(\"step %q timed out: %w\", step.Name, ctx.Err())\n}\n\nfunc TestEngine_StepTimeout(t *testing.T) {\n\twf := &domain.Workflow{\n\t\tName: \"timeout-test\",\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"hang\": {\n\t\t\t\tName:    \"hang\",\n\t\t\t\tType:    domain.StepTypeAgent,\n\t\t\t\tResults: []string{\"success\", \"fail\"},\n\t\t\t\tConfig:  map[string]string{\"prompt\": \"do stuff\", \"timeout\": \"100ms\"},\n\t\t\t},\n\t\t},\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"hang\", Result: \"success\", To: domain.StepDone},\n\t\t\t{From: \"hang\", Result: \"fail\", To: domain.StepAbort},\n\t\t},\n\t\tEntryStep: \"hang\",\n\t}\n\n\texec := &slowExecutor{}\n\teng := engine.New(exec)\n\n\tstart := time.Now()\n\trun, err := eng.Run(context.Background(), wf)\n\telapsed := time.Since(start)\n\n\trequire.Error(t, err)\n\tassert.Equal(t, domain.RunStateFailed, run.State)\n\tassert.Contains(t, err.Error(), \"timed out\")\n\tassert.Less(t, elapsed, 5*time.Second, \"timeout should fire quickly, not wait for default 30m\")\n}\n\nfunc TestEngine_StepTimeoutOverridesDefault(t *testing.T) {\n\twf := &domain.Workflow{\n\t\tName: \"timeout-override\",\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"hang\": {\n\t\t\t\tName:    \"hang\",\n\t\t\t\tType:    domain.StepTypeAgent,\n\t\t\t\tResults: []string{\"success\", \"fail\"},\n\t\t\t\tConfig:  map[string]string{\"prompt\": \"do stuff\"}, // no per-step timeout\n\t\t\t},\n\t\t},\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"hang\", Result: \"success\", To: domain.StepDone},\n\t\t\t{From: \"hang\", Result: \"fail\", To: domain.StepAbort},\n\t\t},\n\t\tEntryStep: \"hang\",\n\t}\n\n\texec := &slowExecutor{}\n\teng := engine.New(exec)\n\teng.SetDefaultTimeout(100 * time.Millisecond)\n\n\tstart := time.Now()\n\trun, err := eng.Run(context.Background(), wf)\n\telapsed := time.Since(start)\n\n\trequire.Error(t, err)\n\tassert.Equal(t, domain.RunStateFailed, run.State)\n\tassert.Less(t, elapsed, 5*time.Second, \"default timeout should fire quickly\")\n}\n","numLines":342,"startLine":1,"totalLines":342}}}
