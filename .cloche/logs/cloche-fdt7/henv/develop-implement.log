{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01176ALvA76XjnRUCFSGKTBz","type":"tool_result","content":"     1→package sqlite\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"database/sql\"\n     6→\t\"fmt\"\n     7→\t\"time\"\n     8→\n     9→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    10→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    11→\t_ \"modernc.org/sqlite\"\n    12→)\n    13→\n    14→type Store struct {\n    15→\tdb *sql.DB\n    16→}\n    17→\n    18→func NewStore(dsn string) (*Store, error) {\n    19→\tdb, err := sql.Open(\"sqlite\", dsn)\n    20→\tif err != nil {\n    21→\t\treturn nil, fmt.Errorf(\"opening sqlite: %w\", err)\n    22→\t}\n    23→\n    24→\t// Enable WAL mode for concurrent read/write access\n    25→\tdb.Exec(\"PRAGMA journal_mode=WAL\")\n    26→\n    27→\t// Wait up to 5 seconds when the database is locked instead of failing immediately\n    28→\tdb.Exec(\"PRAGMA busy_timeout=5000\")\n    29→\n    30→\t// Serialize all Go-side access through a single connection so SQLite\n    31→\t// never sees concurrent writers (WAL + busy_timeout as defense-in-depth).\n    32→\tdb.SetMaxOpenConns(1)\n    33→\n    34→\tif err := migrate(db); err != nil {\n    35→\t\tdb.Close()\n    36→\t\treturn nil, fmt.Errorf(\"migrating: %w\", err)\n    37→\t}\n    38→\n    39→\treturn &Store{db: db}, nil\n    40→}\n    41→\n    42→func (s *Store) Close() error {\n    43→\treturn s.db.Close()\n    44→}\n    45→\n    46→func migrate(db *sql.DB) error {\n    47→\t_, err := db.Exec(`\n    48→\t\tCREATE TABLE IF NOT EXISTS runs (\n    49→\t\t\tid TEXT PRIMARY KEY,\n    50→\t\t\tworkflow_name TEXT NOT NULL,\n    51→\t\t\tstate TEXT NOT NULL,\n    52→\t\t\tactive_steps TEXT,\n    53→\t\t\tstarted_at TEXT,\n    54→\t\t\tcompleted_at TEXT\n    55→\t\t);\n    56→\t\tCREATE TABLE IF NOT EXISTS step_executions (\n    57→\t\t\tid INTEGER PRIMARY KEY AUTOINCREMENT,\n    58→\t\t\trun_id TEXT NOT NULL,\n    59→\t\t\tstep_name TEXT NOT NULL,\n    60→\t\t\tresult TEXT,\n    61→\t\t\tstarted_at TEXT NOT NULL,\n    62→\t\t\tcompleted_at TEXT,\n    63→\t\t\tlogs TEXT,\n    64→\t\t\tgit_ref TEXT,\n    65→\t\t\tFOREIGN KEY (run_id) REFERENCES runs(id)\n    66→\t\t);\n    67→\t`)\n    68→\tif err != nil {\n    69→\t\treturn err\n    70→\t}\n    71→\n    72→\t// Evolution schema additions (idempotent)\n    73→\talterStmts := []string{\n    74→\t\t`ALTER TABLE runs ADD COLUMN project_dir TEXT NOT NULL DEFAULT ''`,\n    75→\t\t`ALTER TABLE step_executions ADD COLUMN prompt_text TEXT`,\n    76→\t\t`ALTER TABLE step_executions ADD COLUMN agent_output TEXT`,\n    77→\t\t`ALTER TABLE step_executions ADD COLUMN attempt_number INTEGER DEFAULT 0`,\n    78→\t\t`ALTER TABLE runs ADD COLUMN error_message TEXT`,\n    79→\t\t`ALTER TABLE runs ADD COLUMN container_id TEXT`,\n    80→\t\t`ALTER TABLE runs ADD COLUMN base_sha TEXT`,\n    81→\t\t`ALTER TABLE runs ADD COLUMN container_kept INTEGER NOT NULL DEFAULT 0`,\n    82→\t\t`ALTER TABLE runs ADD COLUMN title TEXT NOT NULL DEFAULT ''`,\n    83→\t\t`ALTER TABLE runs ADD COLUMN is_host INTEGER NOT NULL DEFAULT 0`,\n    84→\t\t`ALTER TABLE runs ADD COLUMN parent_run_id TEXT NOT NULL DEFAULT ''`,\n    85→\t\t`ALTER TABLE runs ADD COLUMN task_id TEXT NOT NULL DEFAULT ''`,\n    86→\t}\n    87→\tfor _, stmt := range alterStmts {\n    88→\t\tdb.Exec(stmt) // ignore \"duplicate column\" errors\n    89→\t}\n    90→\n    91→\t_, errLog := db.Exec(`CREATE TABLE IF NOT EXISTS log_files (\n    92→\t\tid INTEGER PRIMARY KEY AUTOINCREMENT,\n    93→\t\trun_id TEXT NOT NULL,\n    94→\t\tstep_name TEXT,\n    95→\t\tfile_type TEXT NOT NULL,\n    96→\t\tfile_path TEXT NOT NULL,\n    97→\t\tfile_size INTEGER,\n    98→\t\tcreated_at TEXT NOT NULL,\n    99→\t\tFOREIGN KEY (run_id) REFERENCES runs(id)\n   100→\t)`)\n   101→\tif errLog != nil {\n   102→\t\treturn errLog\n   103→\t}\n   104→\n   105→\t_, errMQ := db.Exec(`CREATE TABLE IF NOT EXISTS merge_queue (\n   106→\t\trun_id TEXT PRIMARY KEY,\n   107→\t\tbranch TEXT NOT NULL,\n   108→\t\tproject TEXT NOT NULL,\n   109→\t\tstatus TEXT NOT NULL DEFAULT 'pending',\n   110→\t\tenqueued_at TEXT NOT NULL,\n   111→\t\tcompleted_at TEXT\n   112→\t)`)\n   113→\tif errMQ != nil {\n   114→\t\treturn errMQ\n   115→\t}\n   116→\n   117→\t_, err2 := db.Exec(`CREATE TABLE IF NOT EXISTS evolution_log (\n   118→\t\tid TEXT PRIMARY KEY,\n   119→\t\tproject_dir TEXT NOT NULL,\n   120→\t\tworkflow_name TEXT NOT NULL,\n   121→\t\ttrigger_run_id TEXT NOT NULL,\n   122→\t\tcreated_at TEXT NOT NULL,\n   123→\t\tclassification TEXT,\n   124→\t\tchanges_json TEXT NOT NULL,\n   125→\t\tknowledge_delta TEXT\n   126→\t)`)\n   127→\tif err2 != nil {\n   128→\t\treturn err2\n   129→\t}\n   130→\n   131→\treturn nil\n   132→}\n   133→\n   134→func (s *Store) CreateRun(ctx context.Context, run *domain.Run) error {\n   135→\t_, err := s.db.ExecContext(ctx,\n   136→\t\t`INSERT INTO runs (id, workflow_name, state, active_steps, started_at, completed_at, project_dir, error_message, container_id, base_sha, container_kept, title, is_host, parent_run_id, task_id)\n   137→\t\t VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)`,\n   138→\t\trun.ID, run.WorkflowName, string(run.State), run.ActiveStepsString(),\n   139→\t\tformatTime(run.StartedAt), formatTime(run.CompletedAt), run.ProjectDir, truncateErrorMessage(run.ErrorMessage), run.ContainerID, run.BaseSHA, boolToInt(run.ContainerKept), run.Title, boolToInt(run.IsHost), run.ParentRunID, run.TaskID,\n   140→\t)\n   141→\treturn err\n   142→}\n   143→\n   144→// runSelectCols is the standard column list for scanning a Run row.\n   145→const runSelectCols = `id, workflow_name, state, active_steps, started_at, completed_at, project_dir, COALESCE(error_message,''), COALESCE(container_id,''), COALESCE(base_sha,''), COALESCE(container_kept,0), COALESCE(title,''), COALESCE(is_host,0), COALESCE(parent_run_id,''), COALESCE(task_id,'')`\n   146→\n   147→// scanRun scans a single row into a *domain.Run.\n   148→func scanRun(scanner interface{ Scan(...any) error }) (*domain.Run, error) {\n   149→\trun := &domain.Run{}\n   150→\tvar activeSteps, startedAt, completedAt string\n   151→\tvar containerKept, isHost int\n   152→\terr := scanner.Scan(&run.ID, &run.WorkflowName, &run.State, &activeSteps, &startedAt, &completedAt, &run.ProjectDir, &run.ErrorMessage, &run.ContainerID, &run.BaseSHA, &containerKept, &run.Title, &isHost, &run.ParentRunID, &run.TaskID)\n   153→\tif err != nil {\n   154→\t\treturn nil, err\n   155→\t}\n   156→\trun.SetActiveStepsFromString(activeSteps)\n   157→\trun.StartedAt = parseTime(startedAt)\n   158→\trun.CompletedAt = parseTime(completedAt)\n   159→\trun.ContainerKept = containerKept != 0\n   160→\trun.IsHost = isHost != 0\n   161→\treturn run, nil\n   162→}\n   163→\n   164→func (s *Store) GetRun(ctx context.Context, id string) (*domain.Run, error) {\n   165→\trow := s.db.QueryRowContext(ctx,\n   166→\t\t`SELECT `+runSelectCols+` FROM runs WHERE id = ?`, id)\n   167→\n   168→\trun, err := scanRun(row)\n   169→\tif err == sql.ErrNoRows {\n   170→\t\treturn nil, fmt.Errorf(\"run %q not found\", id)\n   171→\t}\n   172→\treturn run, err\n   173→}\n   174→\n   175→func (s *Store) UpdateRun(ctx context.Context, run *domain.Run) error {\n   176→\t_, err := s.db.ExecContext(ctx,\n   177→\t\t`UPDATE runs SET state = ?, active_steps = ?, started_at = ?, completed_at = ?, error_message = ?, container_id = ?, base_sha = ?, container_kept = ?, title = ?, is_host = ?, parent_run_id = ?, task_id = ? WHERE id = ?`,\n   178→\t\tstring(run.State), run.ActiveStepsString(),\n   179→\t\tformatTime(run.StartedAt), formatTime(run.CompletedAt),\n   180→\t\ttruncateErrorMessage(run.ErrorMessage), run.ContainerID, run.BaseSHA, boolToInt(run.ContainerKept), run.Title, boolToInt(run.IsHost), run.ParentRunID, run.TaskID, run.ID,\n   181→\t)\n   182→\treturn err\n   183→}\n   184→\n   185→func (s *Store) DeleteRun(ctx context.Context, id string) error {\n   186→\t_, err := s.db.ExecContext(ctx, `DELETE FROM step_executions WHERE run_id = ?`, id)\n   187→\tif err != nil {\n   188→\t\treturn err\n   189→\t}\n   190→\t_, err = s.db.ExecContext(ctx, `DELETE FROM runs WHERE id = ?`, id)\n   191→\treturn err\n   192→}\n   193→\n   194→func (s *Store) ListRuns(ctx context.Context, since time.Time) ([]*domain.Run, error) {\n   195→\tvar rows *sql.Rows\n   196→\tvar err error\n   197→\tif since.IsZero() {\n   198→\t\trows, err = s.db.QueryContext(ctx,\n   199→\t\t\t`SELECT `+runSelectCols+` FROM runs ORDER BY CASE WHEN state = 'running' THEN 0 ELSE 1 END, started_at DESC`)\n   200→\t} else {\n   201→\t\trows, err = s.db.QueryContext(ctx,\n   202→\t\t\t`SELECT `+runSelectCols+` FROM runs WHERE started_at >= ? ORDER BY CASE WHEN state = 'running' THEN 0 ELSE 1 END, started_at DESC`,\n   203→\t\t\tformatTime(since))\n   204→\t}\n   205→\tif err != nil {\n   206→\t\treturn nil, err\n   207→\t}\n   208→\tdefer rows.Close()\n   209→\treturn scanRuns(rows)\n   210→}\n   211→\n   212→// scanRuns scans all rows into a []*domain.Run slice.\n   213→func scanRuns(rows *sql.Rows) ([]*domain.Run, error) {\n   214→\tvar runs []*domain.Run\n   215→\tfor rows.Next() {\n   216→\t\trun, err := scanRun(rows)\n   217→\t\tif err != nil {\n   218→\t\t\treturn nil, err\n   219→\t\t}\n   220→\t\truns = append(runs, run)\n   221→\t}\n   222→\treturn runs, rows.Err()\n   223→}\n   224→\n   225→func (s *Store) ListRunsByProject(ctx context.Context, projectDir string, since time.Time) ([]*domain.Run, error) {\n   226→\tvar rows *sql.Rows\n   227→\tvar err error\n   228→\tif since.IsZero() {\n   229→\t\trows, err = s.db.QueryContext(ctx,\n   230→\t\t\t`SELECT `+runSelectCols+` FROM runs WHERE project_dir = ? ORDER BY CASE WHEN state = 'running' THEN 0 ELSE 1 END, started_at DESC`,\n   231→\t\t\tprojectDir)\n   232→\t} else {\n   233→\t\trows, err = s.db.QueryContext(ctx,\n   234→\t\t\t`SELECT `+runSelectCols+` FROM runs WHERE project_dir = ? AND started_at >= ? ORDER BY CASE WHEN state = 'running' THEN 0 ELSE 1 END, started_at DESC`,\n   235→\t\t\tprojectDir, formatTime(since))\n   236→\t}\n   237→\tif err != nil {\n   238→\t\treturn nil, err\n   239→\t}\n   240→\tdefer rows.Close()\n   241→\treturn scanRuns(rows)\n   242→}\n   243→\n   244→func (s *Store) ListRunsFiltered(ctx context.Context, filter domain.RunListFilter) ([]*domain.Run, error) {\n   245→\tquery := `SELECT ` + runSelectCols + ` FROM runs WHERE 1=1`\n   246→\tvar args []interface{}\n   247→\n   248→\tif filter.ProjectDir != \"\" {\n   249→\t\tquery += ` AND project_dir = ?`\n   250→\t\targs = append(args, filter.ProjectDir)\n   251→\t}\n   252→\tif filter.State != \"\" {\n   253→\t\tquery += ` AND state = ?`\n   254→\t\targs = append(args, string(filter.State))\n   255→\t}\n   256→\tif filter.TaskID != \"\" {\n   257→\t\tquery += ` AND task_id = ?`\n   258→\t\targs = append(args, filter.TaskID)\n   259→\t}\n   260→\tif !filter.Since.IsZero() {\n   261→\t\tquery += ` AND started_at >= ?`\n   262→\t\targs = append(args, formatTime(filter.Since))\n   263→\t}\n   264→\n   265→\tquery += ` ORDER BY CASE WHEN state = 'running' THEN 0 ELSE 1 END, started_at DESC`\n   266→\n   267→\tif filter.Limit > 0 {\n   268→\t\tquery += fmt.Sprintf(` LIMIT %d`, filter.Limit)\n   269→\t}\n   270→\n   271→\trows, err := s.db.QueryContext(ctx, query, args...)\n   272→\tif err != nil {\n   273→\t\treturn nil, err\n   274→\t}\n   275→\tdefer rows.Close()\n   276→\treturn scanRuns(rows)\n   277→}\n   278→\n   279→func (s *Store) ListProjects(ctx context.Context) ([]string, error) {\n   280→\trows, err := s.db.QueryContext(ctx,\n   281→\t\t`SELECT DISTINCT project_dir FROM runs WHERE project_dir != '' ORDER BY project_dir`)\n   282→\tif err != nil {\n   283→\t\treturn nil, err\n   284→\t}\n   285→\tdefer rows.Close()\n   286→\n   287→\tvar projects []string\n   288→\tfor rows.Next() {\n   289→\t\tvar dir string\n   290→\t\tif err := rows.Scan(&dir); err != nil {\n   291→\t\t\treturn nil, err\n   292→\t\t}\n   293→\t\tprojects = append(projects, dir)\n   294→\t}\n   295→\treturn projects, rows.Err()\n   296→}\n   297→\n   298→func (s *Store) ListChildRuns(ctx context.Context, parentRunID string) ([]*domain.Run, error) {\n   299→\trows, err := s.db.QueryContext(ctx,\n   300→\t\t`SELECT `+runSelectCols+` FROM runs WHERE parent_run_id = ? ORDER BY started_at ASC`,\n   301→\t\tparentRunID)\n   302→\tif err != nil {\n   303→\t\treturn nil, err\n   304→\t}\n   305→\tdefer rows.Close()\n   306→\treturn scanRuns(rows)\n   307→}\n   308→\n   309→func (s *Store) SaveCapture(ctx context.Context, runID string, exec *domain.StepExecution) error {\n   310→\t_, err := s.db.ExecContext(ctx,\n   311→\t\t`INSERT INTO step_executions (run_id, step_name, result, started_at, completed_at, logs, git_ref)\n   312→\t\t VALUES (?, ?, ?, ?, ?, ?, ?)`,\n   313→\t\trunID, exec.StepName, exec.Result,\n   314→\t\tformatTime(exec.StartedAt), formatTime(exec.CompletedAt),\n   315→\t\texec.Logs, exec.GitRef,\n   316→\t)\n   317→\treturn err\n   318→}\n   319→\n   320→func (s *Store) GetCaptures(ctx context.Context, runID string) ([]*domain.StepExecution, error) {\n   321→\trows, err := s.db.QueryContext(ctx,\n   322→\t\t`SELECT step_name, result, started_at, completed_at, COALESCE(logs,''), COALESCE(git_ref,'')\n   323→\t\t FROM step_executions WHERE run_id = ? ORDER BY id`, runID)\n   324→\tif err != nil {\n   325→\t\treturn nil, err\n   326→\t}\n   327→\tdefer rows.Close()\n   328→\n   329→\tvar execs []*domain.StepExecution\n   330→\tfor rows.Next() {\n   331→\t\te := &domain.StepExecution{}\n   332→\t\tvar startedAt, completedAt string\n   333→\t\tif err := rows.Scan(&e.StepName, &e.Result, &startedAt, &completedAt, &e.Logs, &e.GitRef); err != nil {\n   334→\t\t\treturn nil, err\n   335→\t\t}\n   336→\t\te.StartedAt = parseTime(startedAt)\n   337→\t\te.CompletedAt = parseTime(completedAt)\n   338→\t\texecs = append(execs, e)\n   339→\t}\n   340→\treturn execs, rows.Err()\n   341→}\n   342→\n   343→func (s *Store) SaveLogFile(ctx context.Context, entry *ports.LogFileEntry) error {\n   344→\t_, err := s.db.ExecContext(ctx,\n   345→\t\t`INSERT INTO log_files (run_id, step_name, file_type, file_path, file_size, created_at)\n   346→\t\t VALUES (?, ?, ?, ?, ?, ?)`,\n   347→\t\tentry.RunID, entry.StepName, entry.FileType, entry.FilePath, entry.FileSize,\n   348→\t\tformatTime(entry.CreatedAt),\n   349→\t)\n   350→\treturn err\n   351→}\n   352→\n   353→func (s *Store) GetLogFiles(ctx context.Context, runID string) ([]*ports.LogFileEntry, error) {\n   354→\trows, err := s.db.QueryContext(ctx,\n   355→\t\t`SELECT id, run_id, COALESCE(step_name,''), file_type, file_path, COALESCE(file_size,0), created_at\n   356→\t\t FROM log_files WHERE run_id = ? ORDER BY id`, runID)\n   357→\tif err != nil {\n   358→\t\treturn nil, err\n   359→\t}\n   360→\tdefer rows.Close()\n   361→\treturn scanLogFiles(rows)\n   362→}\n   363→\n   364→func (s *Store) GetLogFilesByStep(ctx context.Context, runID, stepName string) ([]*ports.LogFileEntry, error) {\n   365→\trows, err := s.db.QueryContext(ctx,\n   366→\t\t`SELECT id, run_id, COALESCE(step_name,''), file_type, file_path, COALESCE(file_size,0), created_at\n   367→\t\t FROM log_files WHERE run_id = ? AND step_name = ? ORDER BY id`, runID, stepName)\n   368→\tif err != nil {\n   369→\t\treturn nil, err\n   370→\t}\n   371→\tdefer rows.Close()\n   372→\treturn scanLogFiles(rows)\n   373→}\n   374→\n   375→func (s *Store) GetLogFileByType(ctx context.Context, runID, fileType string) ([]*ports.LogFileEntry, error) {\n   376→\trows, err := s.db.QueryContext(ctx,\n   377→\t\t`SELECT id, run_id, COALESCE(step_name,''), file_type, file_path, COALESCE(file_size,0), created_at\n   378→\t\t FROM log_files WHERE run_id = ? AND file_type = ? ORDER BY id`, runID, fileType)\n   379→\tif err != nil {\n   380→\t\treturn nil, err\n   381→\t}\n   382→\tdefer rows.Close()\n   383→\treturn scanLogFiles(rows)\n   384→}\n   385→\n   386→func scanLogFiles(rows *sql.Rows) ([]*ports.LogFileEntry, error) {\n   387→\tvar entries []*ports.LogFileEntry\n   388→\tfor rows.Next() {\n   389→\t\te := &ports.LogFileEntry{}\n   390→\t\tvar createdAt string\n   391→\t\tif err := rows.Scan(&e.ID, &e.RunID, &e.StepName, &e.FileType, &e.FilePath, &e.FileSize, &createdAt); err != nil {\n   392→\t\t\treturn nil, err\n   393→\t\t}\n   394→\t\te.CreatedAt = parseTime(createdAt)\n   395→\t\tentries = append(entries, e)\n   396→\t}\n   397→\treturn entries, rows.Err()\n   398→}\n   399→\n   400→func (s *Store) SaveEvolution(ctx context.Context, entry *ports.EvolutionEntry) error {\n   401→\t_, err := s.db.ExecContext(ctx,\n   402→\t\t`INSERT INTO evolution_log (id, project_dir, workflow_name, trigger_run_id, created_at, classification, changes_json, knowledge_delta)\n   403→\t\t VALUES (?, ?, ?, ?, ?, ?, ?, ?)`,\n   404→\t\tentry.ID, entry.ProjectDir, entry.WorkflowName, entry.TriggerRunID,\n   405→\t\tformatTime(entry.CreatedAt), entry.Classification, entry.ChangesJSON, entry.KnowledgeDelta,\n   406→\t)\n   407→\treturn err\n   408→}\n   409→\n   410→func (s *Store) GetLastEvolution(ctx context.Context, projectDir, workflowName string) (*ports.EvolutionEntry, error) {\n   411→\trow := s.db.QueryRowContext(ctx,\n   412→\t\t`SELECT id, project_dir, workflow_name, trigger_run_id, created_at, COALESCE(classification,''), changes_json, COALESCE(knowledge_delta,'')\n   413→\t\t FROM evolution_log WHERE project_dir = ? AND workflow_name = ? ORDER BY created_at DESC LIMIT 1`,\n   414→\t\tprojectDir, workflowName)\n   415→\n   416→\tentry := &ports.EvolutionEntry{}\n   417→\tvar createdAt string\n   418→\terr := row.Scan(&entry.ID, &entry.ProjectDir, &entry.WorkflowName, &entry.TriggerRunID,\n   419→\t\t&createdAt, &entry.Classification, &entry.ChangesJSON, &entry.KnowledgeDelta)\n   420→\tif err == sql.ErrNoRows {\n   421→\t\treturn nil, nil\n   422→\t}\n   423→\tif err != nil {\n   424→\t\treturn nil, err\n   425→\t}\n   426→\tentry.CreatedAt = parseTime(createdAt)\n   427→\treturn entry, nil\n   428→}\n   429→\n   430→func (s *Store) ListRunsSince(ctx context.Context, projectDir, workflowName, sinceRunID string) ([]*domain.Run, error) {\n   431→\tvar rows *sql.Rows\n   432→\tvar err error\n   433→\n   434→\tif sinceRunID == \"\" {\n   435→\t\trows, err = s.db.QueryContext(ctx,\n   436→\t\t\t`SELECT `+runSelectCols+`\n   437→\t\t\t FROM runs WHERE project_dir = ? AND workflow_name = ? ORDER BY started_at ASC`,\n   438→\t\t\tprojectDir, workflowName)\n   439→\t} else {\n   440→\t\trows, err = s.db.QueryContext(ctx,\n   441→\t\t\t`SELECT `+runSelectCols+`\n   442→\t\t\t FROM runs WHERE project_dir = ? AND workflow_name = ? AND started_at > (SELECT started_at FROM runs WHERE id = ?)\n   443→\t\t\t ORDER BY started_at ASC`,\n   444→\t\t\tprojectDir, workflowName, sinceRunID)\n   445→\t}\n   446→\tif err != nil {\n   447→\t\treturn nil, err\n   448→\t}\n   449→\tdefer rows.Close()\n   450→\treturn scanRuns(rows)\n   451→}\n   452→\n   453→\n   454→func (s *Store) FailStaleRuns(ctx context.Context) (int64, error) {\n   455→\tnow := formatTime(time.Now())\n   456→\tres, err := s.db.ExecContext(ctx,\n   457→\t\t`UPDATE runs SET state = 'failed', completed_at = ?, error_message = 'daemon restarted while run was active'\n   458→\t\t WHERE state IN ('pending', 'running')`,\n   459→\t\tnow,\n   460→\t)\n   461→\tif err != nil {\n   462→\t\treturn 0, err\n   463→\t}\n   464→\treturn res.RowsAffected()\n   465→}\n   466→\n   467→func formatTime(t time.Time) string {\n   468→\tif t.IsZero() {\n   469→\t\treturn \"\"\n   470→\t}\n   471→\treturn t.Format(time.RFC3339Nano)\n   472→}\n   473→\n   474→func parseTime(s string) time.Time {\n   475→\tif s == \"\" {\n   476→\t\treturn time.Time{}\n   477→\t}\n   478→\tt, _ := time.Parse(time.RFC3339Nano, s)\n   479→\treturn t\n   480→}\n   481→\n   482→func boolToInt(b bool) int {\n   483→\tif b {\n   484→\t\treturn 1\n   485→\t}\n   486→\treturn 0\n   487→}\n   488→\n   489→const maxErrorMessageLen = 1000\n   490→\n   491→// truncateErrorMessage caps s to maxErrorMessageLen characters to prevent\n   492→// oversized agent output dumps from bloating the database. Full error\n   493→// details remain available in step logs.\n   494→func truncateErrorMessage(s string) string {\n   495→\tif len(s) <= maxErrorMessageLen {\n   496→\t\treturn s\n   497→\t}\n   498→\treturn s[:maxErrorMessageLen] + \"... (truncated)\"\n   499→}\n   500→"}]},"parent_tool_use_id":"toolu_01Uhw7e7ZkKBT1DJZH7BGWt7","session_id":"3b83d887-9f3b-4385-8c16-91cb9c40f66f","uuid":"be3ce88a-c158-4bc1-abc1-97e2504fa9e6"}
