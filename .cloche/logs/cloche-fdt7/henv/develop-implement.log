{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HvxFToqsxkTmj18SKPuDNQ","type":"tool_result","content":"   425→func (s *ClocheServer) GetStatus(ctx context.Context, req *pb.GetStatusRequest) (*pb.GetStatusResponse, error) {\n   426→\trun, err := s.store.GetRun(ctx, req.RunId)\n   427→\tif err != nil {\n   428→\t\treturn nil, fmt.Errorf(\"getting run: %w\", err)\n   429→\t}\n   430→\n   431→\tresp := &pb.GetStatusResponse{\n   432→\t\tRunId:        run.ID,\n   433→\t\tWorkflowName: run.WorkflowName,\n   434→\t\tState:        string(run.State),\n   435→\t\tCurrentStep:  strings.Join(run.ActiveSteps, \",\"),\n   436→\t\tErrorMessage: run.ErrorMessage,\n   437→\t\tContainerId:  run.ContainerID,\n   438→\t\tTitle:        run.Title,\n   439→\t\tIsHost:       run.IsHost,\n   440→\t}\n   441→\n   442→\t// Check container liveness\n   443→\tif run.ContainerID != \"\" && s.container != nil {\n   444→\t\tif cs, err := s.container.Inspect(ctx, run.ContainerID); err == nil {\n   445→\t\t\tresp.ContainerAlive = cs.Running\n   446→\t\t\tif !cs.Running && !cs.FinishedAt.IsZero() {\n   447→\t\t\t\tresp.ContainerDeadSince = cs.FinishedAt.Format(time.RFC3339Nano)\n   448→\t\t\t}\n   449→\t\t}\n   450→\t}\n   451→\n   452→\t// Load step executions from captures store if available\n   453→\tif s.captures != nil {\n   454→\t\tcaptures, err := s.captures.GetCaptures(ctx, req.RunId)\n   455→\t\tif err == nil {\n   456→\t\t\tfor _, exec := range captures {\n   457→\t\t\t\tresp.StepExecutions = append(resp.StepExecutions, &pb.StepExecutionStatus{\n   458→\t\t\t\t\tStepName:    exec.StepName,\n   459→\t\t\t\t\tResult:      exec.Result,\n   460→\t\t\t\t\tStartedAt:   exec.StartedAt.String(),\n   461→\t\t\t\t\tCompletedAt: exec.CompletedAt.String(),\n   462→\t\t\t\t})\n   463→\t\t\t}\n   464→\t\t}\n   465→\t} else {\n   466→\t\tfor _, exec := range run.StepExecutions {\n   467→\t\t\tresp.StepExecutions = append(resp.StepExecutions, &pb.StepExecutionStatus{\n   468→\t\t\t\tStepName:    exec.StepName,\n   469→\t\t\t\tResult:      exec.Result,\n   470→\t\t\t\tStartedAt:   exec.StartedAt.String(),\n   471→\t\t\t\tCompletedAt: exec.CompletedAt.String(),\n   472→\t\t\t})\n   473→\t\t}\n   474→\t}\n   475→\n   476→\treturn resp, nil\n   477→}\n   478→\n   479→func (s *ClocheServer) StreamLogs(req *pb.StreamLogsRequest, stream rpcgrpc.ServerStreamingServer[pb.LogEntry]) error {\n   480→\tctx := stream.Context()\n   481→\n   482→\t// Check for follow mode via gRPC metadata.\n   483→\tfollow := followFromContext(ctx)\n   484→\n   485→\t// Verify run exists\n   486→\trun, err := s.store.GetRun(ctx, req.RunId)\n   487→\tif err != nil {\n   488→\t\treturn fmt.Errorf(\"run %q not found: %w\", req.RunId, err)\n   489→\t}\n   490→\n   491→\t// If step_name or log_type filter is set, serve content directly from the log index\n   492→\tif req.StepName != \"\" || req.LogType != \"\" {\n   493→\t\treturn s.streamFilteredLogs(ctx, req, run, stream)\n   494→\t}\n   495→\n   496→\tisActive := run.State == domain.RunStateRunning || run.State == domain.RunStatePending\n   497→\n   498→\t// With -f on an active run: send existing logs then tail live output.\n   499→\tif follow && isActive && s.logBroadcast != nil {\n   500→\t\treturn s.streamFollowLogs(req.RunId, run, stream)\n   501→\t}\n   502→\n   503→\t// Without -f on an active run: snapshot existing logs and return.\n   504→\t// (Legacy callers that relied on implicit live streaming should use -f.)\n   505→\t// With -f on a completed run: same as without -f — no new lines will arrive.\n   506→\n   507→\t// Check for full.log first — if it exists, serve it as the unified log\n   508→\tfullLogPath := filepath.Join(run.ProjectDir, \".cloche\", req.RunId, \"output\", \"full.log\")\n   509→\tif data, readErr := os.ReadFile(fullLogPath); readErr == nil && len(data) > 0 {\n   510→\t\tif err := stream.Send(&pb.LogEntry{\n   511→\t\t\tType:    \"full_log\",\n   512→\t\t\tMessage: string(data),\n   513→\t\t}); err != nil {\n   514→\t\t\treturn err\n   515→\t\t}\n   516→\t\tif !isActive {\n   517→\t\t\tif err := stream.Send(&pb.LogEntry{\n   518→\t\t\t\tType:      \"run_completed\",\n   519→\t\t\t\tResult:    string(run.State),\n   520→\t\t\t\tTimestamp: run.CompletedAt.String(),\n   521→\t\t\t\tMessage:   run.ErrorMessage,\n   522→\t\t\t}); err != nil {\n   523→\t\t\t\treturn err\n   524→\t\t\t}"}]},"parent_tool_use_id":"toolu_01Uhw7e7ZkKBT1DJZH7BGWt7","session_id":"3b83d887-9f3b-4385-8c16-91cb9c40f66f","uuid":"01d0d386-7e39-4f67-b97e-8de4fc693b65"}
