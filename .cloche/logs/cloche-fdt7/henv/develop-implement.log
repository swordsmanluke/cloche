/user/project-b\"\n    51→\trequire.NoError(t, store.CreateRun(ctx, runB))\n    52→\n    53→\tsrv := server.NewClocheServer(store, nil)\n    54→\n    55→\t// Filter by project-a: should only return runA\n    56→\tresp, err := srv.ListRuns(ctx, &pb.ListRunsRequest{ProjectDir: \"/home/user/project-a\"})\n    57→\trequire.NoError(t, err)\n    58→\trequire.Len(t, resp.Runs, 1)\n    59→\tassert.Equal(t, \"run-proj-a\", resp.Runs[0].RunId)\n    60→\tassert.Equal(t, \"/home/user/project-a\", resp.Runs[0].ProjectDir)\n    61→\n    62→\t// Filter by project-b: should only return runB\n    63→\tresp, err = srv.ListRuns(ctx, &pb.ListRunsRequest{ProjectDir: \"/home/user/project-b\"})\n    64→\trequire.NoError(t, err)\n    65→\trequire.Len(t, resp.Runs, 1)\n    66→\tassert.Equal(t, \"run-proj-b\", resp.Runs[0].RunId)\n    67→\n    68→\t// No filter (--all): should return both\n    69→\tresp, err = srv.ListRuns(ctx, &pb.ListRunsRequest{All: true})\n    70→\trequire.NoError(t, err)\n    71→\tassert.Len(t, resp.Runs, 2)\n    72→}\n    73→\n    74→func TestServer_ListRuns_FilterByState(t *testing.T) {\n    75→\tstore, err := sqlite.NewStore(\":memory:\")\n    76→\trequire.NoError(t, err)\n    77→\tdefer store.Close()\n    78→\n    79→\tctx := context.Background()\n    80→"}]},"parent_tool_use_id":null,"session_id":"3b83d887-9f3b-4385-8c16-91cb9c40f66f","uuid":"81226465-da3d-4c39-80a7-aaed02e15512","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/grpc/server_test.go","content":"package grpc_test\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"sync/atomic\"\n\t\"testing\"\n\t\"time\"\n\n\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n\tserver \"github.com/cloche-dev/cloche/internal/adapters/grpc\"\n\t\"github.com/cloche-dev/cloche/internal/adapters/local\"\n\t\"github.com/cloche-dev/cloche/internal/adapters/sqlite\"\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/logstream\"\n\t\"github.com/cloche-dev/cloche/internal/protocol\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n\tgrpclib \"google.golang.org/grpc\"\n\t\"google.golang.org/grpc/metadata\"\n)\n\nfunc TestServer_ListRuns_Empty(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tsrv := server.NewClocheServer(store, nil)\n\tresp, err := srv.ListRuns(context.Background(), &pb.ListRunsRequest{All: true})\n\trequire.NoError(t, err)\n\tassert.Empty(t, resp.Runs)\n}\n\nfunc TestServer_ListRuns_FilterByProject(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n\n\t// Create runs for two different projects\n\trunA := domain.NewRun(\"run-proj-a\", \"wf\")\n\trunA.ProjectDir = \"/home/user/project-a\"\n\trequire.NoError(t, store.CreateRun(ctx, runA))\n\n\trunB := domain.NewRun(\"run-proj-b\", \"wf\")\n\trunB.ProjectDir = \"/home/user/project-b\"\n\trequire.NoError(t, store.CreateRun(ctx, runB))\n\n\tsrv := server.NewClocheServer(store, nil)\n\n\t// Filter by project-a: should only return runA\n\tresp, err := srv.ListRuns(ctx, &pb.ListRunsRequest{ProjectDir: \"/home/user/project-a\"})\n\trequire.NoError(t, err)\n\trequire.Len(t, resp.Runs, 1)\n\tassert.Equal(t, \"run-proj-a\", resp.Runs[0].RunId)\n\tassert.Equal(t, \"/home/user/project-a\", resp.Runs[0].ProjectDir)\n\n\t// Filter by project-b: should only return runB\n\tresp, err = srv.ListRuns(ctx, &pb.ListRunsRequest{ProjectDir: \"/home/user/project-b\"})\n\trequire.NoError(t, err)\n\trequire.Len(t, resp.Runs, 1)\n\tassert.Equal(t, \"run-proj-b\", resp.Runs[0].RunId)\n\n\t// No filter (--all): should return both\n\tresp, err = srv.ListRuns(ctx, &pb.ListRunsRequest{All: true})\n\trequire.NoError(t, err)\n\tassert.Len(t, resp.Runs, 2)\n}\n\nfunc TestServer_ListRuns_FilterByState(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tdefer store.Close()\n\n\tctx := context.Background()\n","numLines":80,"startLine":1,"totalLines":1695}}}
{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01TBipYuZAFSGWR7tcEk59d5","type":"message","role":"assistant","content":[{"type":"thinking","thinking":"Now I have a full picture. Let me implement the changes:\n\n### Changes needed:\n\n1. **`internal/agent/runner.go`**: When the engine fails, extract the failed step name from run's step executions and include it in the `MsgError` call.\n\n2. **`internal/adapters/grpc/server.go`**: \n   - Handle `MsgError` messages in `trackRun` to capture error info\n   - When finalizing a failed run, use captured error to call `run.Fail()` instead of `run.Complete(RunStateFailed)`\n\n3. **`internal/host/runner.go`**: Already handles errors via `runErr.Error()`. Could also handle the case where run fails without engine error (abort case) by deriving info from step executions. But let me focus on the main issue first.\n   \nI should also add tests to verify the error handling works correctly across the agent runner, server, and integration layers. Now let me start implementing the changes, beginning with modifying the agent runner to extract the failed step name and include it when reporting errors.\n\nStill writing implementation... Still writing error handling... I'm realizing the error message from the engine already includes the step name, so prepending it again would create redundancy like `step \"develop\" failed: step \"develop\" execution failed: exit code 1`. I need to reconsider how to handle the `MsgError` message without duplicating information. I'll capture the error message from `MsgError` and pass it directly to the server's error handling, since the engine already includes step information in the message itself. For the host runner, the error path is already covered through the existing failure mechanism, but I need to think through what happens in the abort case.\n\nWhen a step returns \"fail\" and triggers an abort, `runErr` is nil, so the host runner just completes with the failed state but no error message attached. The step that caused the failure is recorded in the execution history, but deriving the error from that would be an enhancement beyond what's needed here—the core requirement is just capturing the error message when a step explicitly fails.\n\nActually, rereading the task, it seems like it could cover both error crashes and intentional \"fail\" returns. Let me handle both cases simply: when a step execution errors, the engine should return that error with the step name included, and when a step returns a \"fail\" result that aborts the workflow, I could have the engine construct an error message from that step execution record instead of leaving it nil. Still writing error handling... The step executions already indicate which step failed, but adding an Error field to the status output would show the actual error message without requiring users to check logs separately. For the abort case, I'd display a message like \"step 'code' aborted the workflow\" to make it clear what happened. The engine already returns informative errors, so I mainly need to capture and surface them in the status display.\n\nMy plan is to extract the failed step name from run.StepExecutions in the agent runner and pass it to the status writer, then handle the error message in the server when tracking runs. For the host runner, if the engine returns an error on abort, I can use that directly. But I'm realizing that making the engine return an error for abort cases would change existing behavior—tests currently expect no error in those scenarios.\n\nLooking at this more carefully, abort is really a controlled termination, not an error in the traditional sense. The workflow author intentionally designed it to stop at certain conditions. The task asks for displaying the failed step name and error message, but I need to think about whether abort should actually be treated as an error or handled differently.\n\nFor actual step execution failures, there's a real error message to display. But for abort, no step technically failed—it just returned a result that triggered the abort path. So I should leave the engine behavior as-is and instead focus on making sure container run failures properly capture and propagate their error information through the step execution data.\n\nMy approach: update the agent runner to extract the failed step name from the step executions and include that in the error message, then have the server handle that error message when finalizing the run. I'll also add tests to verify this works for actual step failures.\n\nNow I'm ready to start implementing.","signature":""}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":6415,"cache_read_input_tokens":59595,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":6415},"output_tokens":8,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"3b83d887-9f3b-4385-8c16-91cb9c40f66f","uuid":"ad0d7a1c-65a0-4295-8e3c-f729aa1b9216"}
