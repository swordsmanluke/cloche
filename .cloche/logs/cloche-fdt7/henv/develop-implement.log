{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015cC1Ynzue98JTGx6UrLCTQ","type":"tool_result","content":"     1→package grpc\n     2→\n     3→import (\n     4→\t\"bufio\"\n     5→\t\"context\"\n     6→\t\"encoding/json\"\n     7→\t\"fmt\"\n     8→\t\"log\"\n     9→\t\"os\"\n    10→\t\"os/exec\"\n    11→\t\"path/filepath\"\n    12→\t\"sort\"\n    13→\t\"strings\"\n    14→\t\"sync\"\n    15→\t\"time\"\n    16→\n    17→\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    18→\t\"github.com/cloche-dev/cloche/internal/adapters/docker\"\n    19→\t\"github.com/cloche-dev/cloche/internal/adapters/web\"\n    20→\t\"github.com/cloche-dev/cloche/internal/config\"\n    21→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    22→\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    23→\t\"github.com/cloche-dev/cloche/internal/evolution\"\n    24→\t\"github.com/cloche-dev/cloche/internal/host\"\n    25→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    26→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    27→\t\"github.com/cloche-dev/cloche/internal/protocol\"\n    28→\t\"github.com/cloche-dev/cloche/internal/version\"\n    29→\trpcgrpc \"google.golang.org/grpc\"\n    30→\t\"google.golang.org/grpc/metadata\"\n    31→)\n    32→\n    33→type ClocheServer struct {\n    34→\tpb.UnimplementedClocheServiceServer\n    35→\tstore        ports.RunStore\n    36→\tcaptures     ports.CaptureStore\n    37→\tlogStore     ports.LogStore\n    38→\tcontainer    ports.ContainerRuntime\n    39→\tdefaultImage string\n    40→\tevolution    *evolution.Trigger\n    41→\tlogBroadcast *logstream.Broadcaster\n    42→\tshutdownFn   func()\n    43→\tmu           sync.Mutex\n    44→\trunIDs       map[string]string      // run_id -> container_id\n    45→\tloops        map[string]*host.Loop  // project_dir -> orchestration loop\n    46→}\n    47→\n    48→func NewClocheServer(store ports.RunStore, container ports.ContainerRuntime) *ClocheServer {\n    49→\treturn &ClocheServer{\n    50→\t\tstore:     store,\n    51→\t\tcontainer: container,\n    52→\t\trunIDs:    make(map[string]string),\n    53→\t\tloops:     make(map[string]*host.Loop),\n    54→\t}\n    55→}\n    56→\n    57→func NewClocheServerWithCaptures(store ports.RunStore, captures ports.CaptureStore, container ports.ContainerRuntime, defaultImage string) *ClocheServer {\n    58→\treturn &ClocheServer{\n    59→\t\tstore:        store,\n    60→\t\tcaptures:     captures,\n    61→\t\tcontainer:    container,\n    62→\t\tdefaultImage: defaultImage,\n    63→\t\trunIDs:       make(map[string]string),\n    64→\t\tloops:        make(map[string]*host.Loop),\n    65→\t}\n    66→}\n    67→\n    68→// SetLogStore attaches a log store to the server for indexing extracted log files.\n    69→func (s *ClocheServer) SetLogStore(ls ports.LogStore) {\n    70→\ts.logStore = ls\n    71→}\n    72→\n    73→\n    74→// SetEvolution attaches an evolution trigger to the server.\n    75→func (s *ClocheServer) SetEvolution(trigger *evolution.Trigger) {\n    76→\ts.evolution = trigger\n    77→}\n    78→\n    79→// SetLogBroadcaster attaches a log broadcaster for live-streaming LLM output.\n    80→func (s *ClocheServer) SetLogBroadcaster(b *logstream.Broadcaster) {\n    81→\ts.logBroadcast = b\n    82→}\n    83→\n    84→// SetShutdownFunc sets the callback invoked when the Shutdown RPC is called.\n    85→func (s *ClocheServer) SetShutdownFunc(fn func()) {\n    86→\ts.shutdownFn = fn\n    87→}\n    88→\n    89→func (s *ClocheServer) RunWorkflow(ctx context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error) {\n    90→\tif s.container == nil {\n    91→\t\treturn nil, fmt.Errorf(\"no container runtime configured\")\n    92→\t}\n    93→\n    94→\t// Generate a unique run ID, retrying on collision\n    95→\tvar runID string\n    96→\tfor attempts := 0; attempts < 10; attempts++ {\n    97→\t\trunID = domain.GenerateRunID(req.WorkflowName)\n    98→\t\texisting, err := s.store.GetRun(ctx, runID)\n    99→\t\tif err != nil {\n   100→\t\t\tbreak // ID is free\n   101→\t\t}\n   102→\t\t// Reuse if completed more than 1 hour ago\n   103→\t\tif !existing.CompletedAt.IsZero() && time.Since(existing.CompletedAt) > time.Hour {\n   104→\t\t\t_ = s.store.DeleteRun(ctx, runID)\n   105→\t\t\tbreak\n   106→\t\t}\n   107→\t}\n   108→\n   109→\t// Write prompt to .cloche/<run-id>/prompt.txt (run-specific to avoid conflicts)\n   110→\tif req.Prompt != \"\" {\n   111→\t\tclocheDir := filepath.Join(req.ProjectDir, \".cloche\", runID)\n   112→\t\tif err := os.MkdirAll(clocheDir, 0755); err != nil {\n   113→\t\t\treturn nil, fmt.Errorf(\"creating .cloche dir: %w\", err)\n   114→\t\t}\n   115→\t\tif err := os.WriteFile(filepath.Join(clocheDir, \"prompt.txt\"), []byte(req.Prompt), 0644); err != nil {\n   116→\t\t\treturn nil, fmt.Errorf(\"writing prompt: %w\", err)\n   117→\t\t}\n   118→\t}\n   119→\trun := domain.NewRun(runID, req.WorkflowName)\n   120→\trun.ProjectDir = req.ProjectDir\n   121→\trun.Title = req.Title\n   122→\tif err := s.store.CreateRun(ctx, run); err != nil {\n   123→\t\treturn nil, fmt.Errorf(\"creating run: %w\", err)\n   124→\t}\n   125→\n   126→\t// Resolve image: request-level override, then server default\n   127→\timage := req.Image\n   128→\tif image == \"\" {\n   129→\t\timage = s.defaultImage\n   130→\t}\n   131→\n   132→\t// Launch container start + tracking in background so the RPC returns immediately.\n   133→\t// The run stays in \"pending\" state until the container is up.\n   134→\tgo s.launchAndTrack(runID, image, req.KeepContainer, req)\n   135→\n   136→\treturn &pb.RunWorkflowResponse{RunId: runID}, nil\n   137→}\n   138→\n   139→// launchAndTrack starts the container and then tracks it to completion.\n   140→// It runs in a background goroutine with its own context, independent of the\n   141→// RPC context which may be cancelled after RunWorkflow returns.\n   142→func (s *ClocheServer) launchAndTrack(runID, image string, keepContainer bool, req *pb.RunWorkflowRequest) {\n   143→\tctx := context.Background()\n   144→\n   145→\t// Auto-rebuild image if the project Dockerfile has changed since last build.\n   146→\tif ensurer, ok := s.container.(ports.ImageEnsurer); ok {\n   147→\t\tif err := ensurer.EnsureImage(ctx, req.ProjectDir, image); err != nil {\n   148→\t\t\trun, _ := s.store.GetRun(ctx, runID)\n   149→\t\t\tif run != nil {\n   150→\t\t\t\trun.Fail(fmt.Sprintf(\"failed to ensure image: %v\", err))"}]},"parent_tool_use_id":"toolu_01Uhw7e7ZkKBT1DJZH7BGWt7","session_id":"3b83d887-9f3b-4385-8c16-91cb9c40f66f","uuid":"80f30be9-7616-4450-b90d-637bbd375e90"}
