{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01J5PbpPLs2TezRsgUaE2wR2","type":"tool_result","content":"     1→package main\n     2→\n     3→import (\n     4→\t\"fmt\"\n     5→\t\"os\"\n     6→\t\"path/filepath\"\n     7→\t\"sort\"\n     8→\t\"strings\"\n     9→\n    10→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    11→\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    12→)\n    13→\n    14→func cmdWorkflow(args []string) {\n    15→\tvar projectDir, workflowName string\n    16→\tfor i := 0; i < len(args); i++ {\n    17→\t\tswitch args[i] {\n    18→\t\tcase \"--project\", \"-p\":\n    19→\t\t\tif i+1 < len(args) {\n    20→\t\t\t\ti++\n    21→\t\t\t\tprojectDir = args[i]\n    22→\t\t\t}\n    23→\t\tdefault:\n    24→\t\t\tif !strings.HasPrefix(args[i], \"-\") && workflowName == \"\" {\n    25→\t\t\t\tworkflowName = args[i]\n    26→\t\t\t}\n    27→\t\t}\n    28→\t}\n    29→\n    30→\tif projectDir == \"\" {\n    31→\t\tprojectDir, _ = os.Getwd()\n    32→\t} else {\n    33→\t\tabs, err := filepath.Abs(projectDir)\n    34→\t\tif err == nil {\n    35→\t\t\tprojectDir = abs\n    36→\t\t}\n    37→\t}\n    38→\n    39→\tif workflowName == \"\" {\n    40→\t\tlistWorkflows(projectDir)\n    41→\t} else {\n    42→\t\tshowWorkflow(projectDir, workflowName)\n    43→\t}\n    44→}\n    45→\n    46→type workflowInfo struct {\n    47→\tname     string\n    48→\tlocation domain.WorkflowLocation\n    49→}\n    50→\n    51→func discoverWorkflows(projectDir string) ([]workflowInfo, error) {\n    52→\tclocheDir := filepath.Join(projectDir, \".cloche\")\n    53→\tentries, err := filepath.Glob(filepath.Join(clocheDir, \"*.cloche\"))\n    54→\tif err != nil {\n    55→\t\treturn nil, err\n    56→\t}\n    57→\n    58→\tvar infos []workflowInfo\n    59→\tfor _, path := range entries {\n    60→\t\tbase := filepath.Base(path)\n    61→\t\tdata, err := os.ReadFile(path)\n    62→\t\tif err != nil {\n    63→\t\t\tcontinue\n    64→\t\t}\n    65→\n    66→\t\tif base == \"host.cloche\" {\n    67→\t\t\twfs, err := dsl.ParseAllForHost(string(data))\n    68→\t\t\tif err != nil {\n    69→\t\t\t\tcontinue\n    70→\t\t\t}\n    71→\t\t\tfor name := range wfs {\n    72→\t\t\t\tinfos = append(infos, workflowInfo{name: name, location: domain.LocationHost})\n    73→\t\t\t}\n    74→\t\t} else {\n    75→\t\t\twf, err := dsl.ParseForContainer(string(data))\n    76→\t\t\tif err != nil {\n    77→\t\t\t\tcontinue\n    78→\t\t\t}\n    79→\t\t\tinfos = append(infos, workflowInfo{name: wf.Name, location: domain.LocationContainer})\n    80→\t\t}\n    81→\t}\n    82→\n    83→\treturn infos, nil\n    84→}\n    85→\n    86→func listWorkflows(projectDir string) {\n    87→\tinfos, err := discoverWorkflows(projectDir)\n    88→\tif err != nil {\n    89→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n    90→\t\tos.Exit(1)\n    91→\t}\n    92→\n    93→\tif len(infos) == 0 {\n    94→\t\tfmt.Println(\"No workflows found.\")\n    95→\t\treturn\n    96→\t}\n    97→\n    98→\tvar container, host []string\n    99→\tfor _, info := range infos {\n   100→\t\tswitch info.location {\n   101→\t\tcase domain.LocationContainer:\n   102→\t\t\tcontainer = append(container, info.name)\n   103→\t\tcase domain.LocationHost:\n   104→\t\t\thost = append(host, info.name)\n   105→\t\t}\n   106→\t}\n   107→\n   108→\tsort.Strings(container)\n   109→\tsort.Strings(host)\n   110→\n   111→\tif len(container) > 0 {\n   112→\t\tfmt.Println(\"Container workflows:\")\n   113→\t\tfor _, name := range container {\n   114→\t\t\tfmt.Printf(\"  %s\\n\", name)\n   115→\t\t}\n   116→\t}\n   117→\n   118→\tif len(host) > 0 {\n   119→\t\tif len(container) > 0 {\n   120→\t\t\tfmt.Println()\n   121→\t\t}\n   122→\t\tfmt.Println(\"Host workflows:\")\n   123→\t\tfor _, name := range host {\n   124→\t\t\tfmt.Printf(\"  %s\\n\", name)\n   125→\t\t}\n   126→\t}\n   127→}\n   128→\n   129→func loadWorkflow(projectDir, name string) (*domain.Workflow, error) {\n   130→\tclocheDir := filepath.Join(projectDir, \".cloche\")\n   131→\n   132→\t// Try container workflow first (named file)\n   133→\tcontainerPath := filepath.Join(clocheDir, name+\".cloche\")\n   134→\tif data, err := os.ReadFile(containerPath); err == nil {\n   135→\t\twf, err := dsl.ParseForContainer(string(data))\n   136→\t\tif err != nil {\n   137→\t\t\treturn nil, fmt.Errorf(\"parsing %s.cloche: %w\", name, err)\n   138→\t\t}\n   139→\t\treturn wf, nil\n   140→\t}\n   141→\n   142→\t// Try host workflow\n   143→\thostPath := filepath.Join(clocheDir, \"host.cloche\")\n   144→\tif data, err := os.ReadFile(hostPath); err == nil {\n   145→\t\twfs, err := dsl.ParseAllForHost(string(data))\n   146→\t\tif err != nil {\n   147→\t\t\treturn nil, fmt.Errorf(\"parsing host.cloche: %w\", err)\n   148→\t\t}\n   149→\t\tif wf, ok := wfs[name]; ok {\n   150→\t\t\treturn wf, nil\n   151→\t\t}\n   152→\t}\n   153→\n   154→\treturn nil, fmt.Errorf(\"workflow %q not found\", name)\n   155→}\n   156→\n   157→func showWorkflow(projectDir, name string) {\n   158→\twf, err := loadWorkflow(projectDir, name)\n   159→\tif err != nil {\n   160→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   161→\t\tos.Exit(1)\n   162→\t}\n   163→\tfmt.Print(renderWorkflowGraph(wf, isTTY()))\n   164→}\n   165→\n   166→// ANSI color codes for wire colorization.\n   167→const (\n   168→\tcolorReset   = \"\\033[0m\"\n   169→\tcolorGreen   = \"\\033[32m\"\n   170→\tcolorRed     = \"\\033[31m\"\n   171→\tcolorBlue    = \"\\033[34m\"\n   172→\tcolorYellow  = \"\\033[33m\"\n   173→\tcolorOrange  = \"\\033[38;5;208m\"\n   174→\tcolorMagenta = \"\\033[35m\"\n   175→)\n   176→\n   177→var otherResultColors = []string{colorBlue, colorYellow, colorOrange, colorMagenta}\n   178→\n   179→// buildResultColorMap assigns a color to each unique result name in the workflow.\n   180→// \"success\" is always green, \"fail\"/\"failed\" always red, others cycle through\n   181→// blue, yellow, orange, magenta.\n   182→func buildResultColorMap(w *domain.Workflow, order []string) map[string]string {\n   183→\tcolorMap := map[string]string{\n   184→\t\t\"success\": colorGreen,\n   185→\t\t\"fail\":    colorRed,\n   186→\t\t\"failed\":  colorRed,\n   187→\t}\n   188→\n   189→\totherIdx := 0\n   190→\tfor _, stepName := range order {\n   191→\t\tstep := w.Steps[stepName]\n   192→\t\tfor _, r := range step.Results {\n   193→\t\t\tif _, ok := colorMap[r]; ok {\n   194→\t\t\t\tcontinue\n   195→\t\t\t}\n   196→\t\t\tcolorMap[r] = otherResultColors[otherIdx%len(otherResultColors)]\n   197→\t\t\totherIdx++\n   198→\t\t}\n   199→\t}\n   200→\n   201→\treturn colorMap\n   202→}\n   203→\n   204→func renderWorkflowGraph(w *domain.Workflow, color bool) string {\n   205→\tvar buf strings.Builder\n   206→\n   207→\t// Header\n   208→\tfmt.Fprintf(&buf, \"workflow %q (%s)\\n\\n\", w.Name, w.Location)\n   209→\n   210→\torder := bfsOrder(w)\n   211→\tif len(order) == 0 {\n   212→\t\tbuf.WriteString(\"  (no steps)\\n\")\n   213→\t\treturn buf.String()\n   214→\t}\n   215→\n   216→\tcolorMap := buildResultColorMap(w, order)\n   217→\n   218→\t// Compute max step name length for consistent box widths\n   219→\tnameWidth := 0\n   220→\tfor _, name := range order {\n   221→\t\tif len(name) > nameWidth {\n   222→\t\t\tnameWidth = len(name)\n   223→\t\t}\n   224→\t}\n   225→\t// Minimum width\n   226→\tif nameWidth < 6 {\n   227→\t\tnameWidth = 6\n   228→\t}\n   229→\n   230→\tfor i, stepName := range order {\n   231→\t\tstep := w.Steps[stepName]\n   232→\t\tisEntry := stepName == w.EntryStep\n   233→\n   234→\t\trenderStepBox(&buf, step, isEntry, nameWidth)\n   235→\t\tgroups := groupWiresByDest(w, stepName)\n   236→\t\trenderWireGroups(&buf, groups, colorMap, color)\n   237→\n   238→\t\t// Also render any collect conditions originating from this step\n   239→\t\trenderCollects(&buf, w, stepName, colorMap, color)\n   240→\n   241→\t\tif i < len(order)-1 {\n   242→\t\t\tbuf.WriteString(\"\\n\")\n   243→\t\t}\n   244→\t}\n   245→\n   246→\treturn buf.String()\n   247→}\n   248→\n   249→func renderStepBox(buf *strings.Builder, step *domain.Step, isEntry bool, nameWidth int) {\n   250→\tpadded := fmt.Sprintf(\" %-*s \", nameWidth, step.Name)\n   251→\tborder := strings.Repeat(\"─\", nameWidth+2)\n   252→\n   253→\tsuffix := fmt.Sprintf(\" %s\", step.Type)\n   254→\tif isEntry {\n   255→\t\tsuffix += \"  ◀ entry\"\n   256→\t}\n   257→\n   258→\tfmt.Fprintf(buf, \"  ┌%s┐\\n\", border)\n   259→\tfmt.Fprintf(buf, \"  │%s│%s\\n\", padded, suffix)\n   260→\tfmt.Fprintf(buf, \"  └%s┘\\n\", border)\n   261→}\n   262→\n   263→type wireGroup struct {\n   264→\tresults []string\n   265→\tto      string\n   266→}\n   267→\n   268→// groupWiresByDest groups wires from a step by destination, preserving order.\n   269→// Wires to the same destination are merged into a single group.\n   270→func groupWiresByDest(w *domain.Workflow, stepName string) []wireGroup {\n   271→\tdestMap := make(map[string][]string)\n   272→\tvar destOrder []string\n   273→\n   274→\tfor _, wire := range w.Wiring {\n   275→\t\tif wire.From != stepName {\n   276→\t\t\tcontinue\n   277→\t\t}\n   278→\t\tif _, seen := destMap[wire.To]; !seen {\n   279→\t\t\tdestOrder = append(destOrder, wire.To)\n   280→\t\t}\n   281→\t\tdestMap[wire.To] = append(destMap[wire.To], wire.Result)\n   282→\t}\n   283→\n   284→\tvar groups []wireGroup\n   285→\tfor _, dest := range destOrder {\n   286→\t\tgroups = append(groups, wireGroup{results: destMap[dest], to: dest})\n   287→\t}\n   288→\treturn groups\n   289→}\n   290→\n   291→func renderWireGroups(buf *strings.Builder, groups []wireGroup, colorMap map[string]string, useColor bool) {\n   292→\tfor i, g := range groups {\n   293→\t\tisLast := i == len(groups)-1\n   294→\t\tbranch := \"├\"\n   295→\t\tif isLast {\n   296→\t\t\tbranch = \"└\"\n   297→\t\t}\n   298→\n   299→\t\t// Build colored result list\n   300→\t\tvar resultParts []string\n   301→\t\tfor _, r := range g.results {\n   302→\t\t\tif useColor {\n   303→\t\t\t\tresultParts = append(resultParts, colorMap[r]+r+colorReset)\n   304→\t\t\t} else {\n   305→\t\t\t\tresultParts = append(resultParts, r)\n   306→\t\t\t}\n   307→\t\t}\n   308→\t\tresultStr := strings.Join(resultParts, \", \")\n   309→\n   310→\t\t// Format destination\n   311→\t\tdest := formatDest(g.to, useColor)\n   312→\n   313→\t\tfmt.Fprintf(buf, \"    %s── %s ──▶ %s\\n\", branch, resultStr, dest)\n   314→\t}\n   315→}\n   316→\n   317→func formatDest(to string, useColor bool) string {\n   318→\tswitch to {\n   319→\tcase domain.StepDone:\n   320→\t\tif useColor {\n   321→\t\t\treturn colorGreen + \"DONE\" + colorReset\n   322→\t\t}\n   323→\t\treturn \"DONE\"\n   324→\tcase domain.StepAbort:\n   325→\t\tif useColor {\n   326→\t\t\treturn colorRed + \"ABORT\" + colorReset\n   327→\t\t}\n   328→\t\treturn \"ABORT\"\n   329→\tdefault:\n   330→\t\treturn to\n   331→\t}\n   332→}\n   333→\n   334→// renderCollects renders any collect conditions that reference this step.\n   335→func renderCollects(buf *strings.Builder, w *domain.Workflow, stepName string, colorMap map[string]string, useColor bool) {\n   336→\tfor _, c := range w.Collects {\n   337→\t\t// Check if this step is part of the collect conditions\n   338→\t\tvar parts []string\n   339→\t\tinvolves := false\n   340→\t\tfor _, cond := range c.Conditions {\n   341→\t\t\tlabel := cond.Step + \":\" + cond.Result\n   342→\t\t\tif useColor {\n   343→\t\t\t\tif clr, ok := colorMap[cond.Result]; ok {\n   344→\t\t\t\t\tlabel = cond.Step + \":\" + clr + cond.Result + colorReset\n   345→\t\t\t\t}\n   346→\t\t\t}\n   347→\t\t\tparts = append(parts, label)\n   348→\t\t\tif cond.Step == stepName {\n   349→\t\t\t\tinvolves = true\n   350→\t\t\t}\n   351→\t\t}\n   352→\t\t// Only render the collect on the last condition step to avoid duplication\n   353→\t\tif involves && c.Conditions[len(c.Conditions)-1].Step == stepName {\n   354→\t\t\tdest := formatDest(c.To, useColor)\n   355→\t\t\tfmt.Fprintf(buf, \"    collect %s(%s) ──▶ %s\\n\", c.Mode, strings.Join(parts, \", \"), dest)\n   356→\t\t}\n   357→\t}\n   358→}\n   359→\n   360→// bfsOrder returns steps in BFS order from the entry step.\n   361→// Handles cycles by skipping already-visited nodes.\n   362→func bfsOrder(w *domain.Workflow) []string {\n   363→\tif w.EntryStep == \"\" {\n   364→\t\treturn nil\n   365→\t}\n   366→\n   367→\tvisited := map[string]bool{w.EntryStep: true}\n   368→\tvar order []string\n   369→\tqueue := []string{w.EntryStep}\n   370→\n   371→\tfor len(queue) > 0 {\n   372→\t\tcurrent := queue[0]\n   373→\t\tqueue = queue[1:]\n   374→\t\torder = append(order, current)\n   375→\n   376→\t\t// Collect unique target steps in wire order\n   377→\t\tfor _, wire := range w.Wiring {\n   378→\t\t\tif wire.From != current {\n   379→\t\t\t\tcontinue\n   380→\t\t\t}\n   381→\t\t\tif wire.To == domain.StepDone || wire.To == domain.StepAbort {\n   382→\t\t\t\tcontinue\n   383→\t\t\t}\n   384→\t\t\tif visited[wire.To] {\n   385→\t\t\t\tcontinue\n   386→\t\t\t}\n   387→\t\t\tvisited[wire.To] = true\n   388→\t\t\tqueue = append(queue, wire.To)\n   389→\t\t}\n   390→\t}\n   391→\n   392→\treturn order\n   393→}\n   394→"}]},"parent_tool_use_id":"toolu_01Uhw7e7ZkKBT1DJZH7BGWt7","session_id":"3b83d887-9f3b-4385-8c16-91cb9c40f66f","uuid":"53505181-2d1d-4164-b38d-130da36da38f"}
