{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019kjvzFtiHxEr6UpGm3KJeq","type":"tool_result","content":"   150→\t\t\t\trun.Fail(fmt.Sprintf(\"failed to ensure image: %v\", err))\n   151→\t\t\t\t_ = s.store.UpdateRun(ctx, run)\n   152→\t\t\t}\n   153→\t\t\tlog.Printf(\"run %s: failed to ensure image: %v\", runID, err)\n   154→\t\t\t\treturn\n   155→\t\t}\n   156→\t}\n   157→\n   158→\tbaseSHA := gitHEAD(req.ProjectDir)\n   159→\n   160→\tcontainerID, err := s.container.Start(ctx, ports.ContainerConfig{\n   161→\t\tImage:        image,\n   162→\t\tWorkflowName: req.WorkflowName,\n   163→\t\tProjectDir:   req.ProjectDir,\n   164→\t\tRunID:        runID,\n   165→\t\tNetworkAllow: []string{\"*\"},\n   166→\t})\n   167→\tif err != nil {\n   168→\t\trun, _ := s.store.GetRun(ctx, runID)\n   169→\t\tif run != nil {\n   170→\t\t\trun.Fail(fmt.Sprintf(\"failed to start container: %v\", err))\n   171→\t\t\t_ = s.store.UpdateRun(ctx, run)\n   172→\t\t}\n   173→\t\tlog.Printf(\"run %s: failed to start container: %v\", runID, err)\n   174→\t\treturn\n   175→\t}\n   176→\n   177→\ts.mu.Lock()\n   178→\ts.runIDs[runID] = containerID\n   179→\ts.mu.Unlock()\n   180→\n   181→\trun, _ := s.store.GetRun(ctx, runID)\n   182→\tif run != nil {\n   183→\t\trun.Start()\n   184→\t\trun.ContainerID = containerID\n   185→\t\trun.BaseSHA = baseSHA\n   186→\t\t_ = s.store.UpdateRun(ctx, run)\n   187→\t}\n   188→\n   189→\ts.trackRun(runID, containerID, req.ProjectDir, req.WorkflowName, keepContainer)\n   190→}\n   191→\n   192→func (s *ClocheServer) trackRun(runID, containerID, projectDir, workflowName string, keepContainer bool) {\n   193→\tctx := context.Background()\n   194→\n   195→\t// Attach to agent output\n   196→\treader, err := s.container.AttachOutput(ctx, containerID)\n   197→\tif err != nil {\n   198→\t\tlog.Printf(\"failed to attach to output for run %s: %v\", runID, err)\n   199→\t\t\treturn\n   200→\t}\n   201→\n   202→\t// Parse JSON-lines status messages\n   203→\tvar reportedResult string // captured from MsgRunCompleted, persisted after branch extraction\n   204→\tscanner := bufio.NewScanner(reader)\n   205→\tscanner.Buffer(make([]byte, 0, 256*1024), 1024*1024) // 1MB max to handle large log messages\n   206→\tfor scanner.Scan() {\n   207→\t\tvar msg protocol.StatusMessage\n   208→\t\tif err := json.Unmarshal(scanner.Bytes(), &msg); err != nil {\n   209→\t\t\tcontinue\n   210→\t\t}\n   211→\n   212→\t\t// Fast path: log messages don't need store interaction.\n   213→\t\tif msg.Type == protocol.MsgLog {\n   214→\t\t\tif s.logBroadcast != nil {\n   215→\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n   216→\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n   217→\t\t\t\t\tType:      \"llm\",\n   218→\t\t\t\t\tContent:   msg.Message,\n   219→\t\t\t\t\tStepName:  msg.StepName,\n   220→\t\t\t\t})\n   221→\t\t\t}\n   222→\t\t\tcontinue\n   223→\t\t}\n   224→\n   225→\t\trun, err := s.store.GetRun(ctx, runID)\n   226→\t\tif err != nil {\n   227→\t\t\tcontinue\n   228→\t\t}\n   229→\n   230→\t\tswitch msg.Type {\n   231→\t\tcase protocol.MsgStepStarted:\n   232→\t\t\trun.RecordStepStart(msg.StepName)\n   233→\t\t\tif s.captures != nil {\n   234→\t\t\t\t_ = s.captures.SaveCapture(ctx, runID, &domain.StepExecution{\n   235→\t\t\t\t\tStepName:  msg.StepName,\n   236→\t\t\t\t\tStartedAt: msg.Timestamp,\n   237→\t\t\t\t})\n   238→\t\t\t}\n   239→\t\t\tif s.logBroadcast != nil {\n   240→\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n   241→\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n   242→\t\t\t\t\tType:      \"status\",\n   243→\t\t\t\t\tContent:   \"step_started: \" + msg.StepName,\n   244→\t\t\t\t\tStepName:  msg.StepName,\n   245→\t\t\t\t})\n   246→\t\t\t}\n   247→\t\tcase protocol.MsgStepCompleted:\n   248→\t\t\trun.RecordStepComplete(msg.StepName, msg.Result)\n   249→\t\t\tif s.captures != nil {\n   250→\t\t\t\t_ = s.captures.SaveCapture(ctx, runID, &domain.StepExecution{\n   251→\t\t\t\t\tStepName:    msg.StepName,\n   252→\t\t\t\t\tResult:      msg.Result,\n   253→\t\t\t\t\tCompletedAt: msg.Timestamp,\n   254→\t\t\t\t})\n   255→\t\t\t}\n   256→\t\t\tif s.logBroadcast != nil {\n   257→\t\t\t\ts.logBroadcast.Publish(runID, logstream.LogLine{\n   258→\t\t\t\t\tTimestamp: msg.Timestamp.Format(time.RFC3339),\n   259→\t\t\t\t\tType:      \"status\",\n   260→\t\t\t\t\tContent:   \"step_completed: \" + msg.StepName + \" -> \" + msg.Result,\n   261→\t\t\t\t\tStepName:  msg.StepName,\n   262→\t\t\t\t})\n   263→\t\t\t}\n   264→\t\tcase protocol.MsgRunTitle:\n   265→\t\t\tif run.Title == \"\" {\n   266→\t\t\t\trun.Title = msg.Message\n   267→\t\t\t}\n   268→\t\tcase protocol.MsgRunCompleted:\n   269→\t\t\treportedResult = msg.Result\n   270→\t\t\tcontinue // Don't persist terminal state yet; branch extraction must finish first\n   271→\t\t}\n   272→\n   273→\t\t_ = s.store.UpdateRun(ctx, run)\n   274→\t}\n   275→\treader.Close()\n   276→\n   277→\t// Signal live-stream subscribers that this run is done.\n   278→\tif s.logBroadcast != nil {\n   279→\t\ts.logBroadcast.Finish(runID)\n   280→\t}\n   281→\n   282→\t// Wait for process exit\n   283→\texitCode, err := s.container.Wait(ctx, containerID)\n   284→\tif err != nil {\n   285→\t\tlog.Printf(\"error waiting for run %s: %v\", runID, err)\n   286→\t}\n   287→\n   288→\t// Extract step output files from container before it's removed\n   289→\toutputDst := filepath.Join(projectDir, \".cloche\", runID, \"output\")\n   290→\tif err := os.MkdirAll(outputDst, 0755); err == nil {\n   291→\t\tif cpErr := s.container.CopyFrom(ctx, containerID, \"/workspace/.cloche/output/.\", outputDst); cpErr != nil {\n   292→\t\t\tlog.Printf(\"run %s: failed to extract output: %v\", runID, cpErr)\n   293→\t\t}\n   294→\t}\n   295→\n   296→\t// Capture full container stdout/stderr before the container is removed\n   297→\tif logs, logErr := s.container.Logs(ctx, containerID); logErr == nil && logs != \"\" {\n   298→\t\tcontainerLogPath := filepath.Join(outputDst, \"container.log\")\n   299→\t\tif writeErr := os.WriteFile(containerLogPath, []byte(logs), 0644); writeErr != nil {\n   300→\t\t\tlog.Printf(\"run %s: failed to write container.log: %v\", runID, writeErr)\n   301→\t\t}\n   302→\t}\n   303→\n   304→\t// Index extracted log files in the log store\n   305→\tif s.logStore != nil {\n   306→\t\ts.indexLogFiles(ctx, runID, outputDst)\n   307→\t}\n   308→\n   309→\t// Extract results to git branch BEFORE finalizing state, so that\n   310→\t// WaitRun callers (e.g. host workflow merge step) see branches exist\n   311→\t// before the run is marked complete.\n   312→\tresultLabel := reportedResult\n   313→\tif resultLabel == \"\" {\n   314→\t\tif exitCode == 0 {\n   315→\t\t\tresultLabel = \"succeeded\"\n   316→\t\t} else {\n   317→\t\t\tresultLabel = \"failed\"\n   318→\t\t}\n   319→\t}\n   320→\t{\n   321→\t\textractRun, _ := s.store.GetRun(ctx, runID)\n   322→\t\tif extractRun != nil && extractRun.BaseSHA != \"\" {\n   323→\t\t\tlog.Printf(\"run %s: extracting results to branch cloche/%s (baseSHA=%s)\", runID, runID, extractRun.BaseSHA)\n   324→\t\t\tif err := docker.ExtractResults(ctx, containerID, extractRun.ProjectDir, runID, extractRun.BaseSHA, workflowName, resultLabel); err != nil {\n   325→\t\t\t\tlog.Printf(\"run %s: failed to extract results to branch: %v\", runID, err)\n   326→\t\t\t} else {\n   327→\t\t\t\tlog.Printf(\"run %s: branch cloche/%s created successfully\", runID, runID)\n   328→\t\t\t}\n   329→\t\t} else {\n   330→\t\t\tlog.Printf(\"run %s: skipping branch extraction (baseSHA empty or run not found)\", runID)\n   331→\t\t}\n   332→\t}\n   333→\n   334→\t// Now finalize run state\n   335→\trun, err := s.store.GetRun(ctx, runID)\n   336→\tif err != nil {\n   337→\t\treturn\n   338→\t}\n   339→\tif run.State == domain.RunStateRunning {\n   340→\t\tif reportedResult == \"succeeded\" {\n   341→\t\t\trun.Complete(domain.RunStateSucceeded)\n   342→\t\t} else if reportedResult != \"\" {\n   343→\t\t\trun.Complete(domain.RunStateFailed)\n   344→\t\t} else if exitCode == 0 {\n   345→\t\t\trun.Complete(domain.RunStateSucceeded)\n   346→\t\t} else {\n   347→\t\t\trun.Fail(fmt.Sprintf(\"container exited with code %d\", exitCode))\n   348→\t\t}\n   349→\t\t_ = s.store.UpdateRun(ctx, run)"}]},"parent_tool_use_id":"toolu_01Uhw7e7ZkKBT1DJZH7BGWt7","session_id":"3b83d887-9f3b-4385-8c16-91cb9c40f66f","uuid":"81caeca6-5134-46c2-acd2-ad97b83d5835"}
