tdout\n    92→\tcmd.Stderr = &stderr\n    93→\tif err := cmd.Run(); err != nil {\n    94→\t\treturn \"\", fmt.Errorf(\"inspecting base image %s: %s: %w\", image, strings.TrimSpace(stderr.String()), err)\n    95→\t}\n    96→\tid := strings.TrimSpace(stdout.String())\n    97→\tif id == \"\" {\n    98→\t\treturn \"\", fmt.Errorf(\"empty image ID for %s\", image)\n    99→\t}\n   100→\treturn id, nil\n   101→}\n   102→\n   103→// isBaseImageStale checks whether the base image used to build the project\n   104→// image has changed locally since build time. It compares the stored base\n   105→// image digest label to the current local image ID of the base image.\n   106→// Returns (true, reason) if stale, (false, \"\") if up-to-date or if the\n   107→// check cannot be performed (e.g. base image not available locally).\n   108→func isBaseImageStale(ctx context.Context, image string, dockerfileContent []byte) (bool, string) {\n   109→\tbaseRef := parseBaseImage(dockerfileContent)\n   110→\tif baseRef == \"\" || strings.ToLower(baseRef) == \"scratch\" {\n   111→\t\treturn false, \"\"\n   112→\t}\n   113→\n   114→\tstoredDigest, err := imageLabel(ctx, image, baseImageDigestLabel)\n   115→\tif err != nil {\n   116→\t\t// Label not present (old build) — can't determine staleness.\n   117→\t\treturn false, \"\"\n   118→\t}\n   119→\n   120→\tcurrentID, err := baseImageID(ctx, baseRef)\n   121→\tif err != nil {\n   122→\t\t// Base image not available locally — can't compare.\n   123→\t\treturn false, \"\"\n   124→\t}\n   125→\n   126→\tif currentID != storedDigest {\n   127→\t\treturn true, fmt.Sprintf(\"base %s changed from %s to %s\", baseRef, storedDigest[:12], currentID[:12])\n   128→\t}\n   129→\treturn false, \"\"\n   130→}\n   131→\n   132→// hashBytes returns the hex-encoded SHA-256 digest of data.\n   133→func hashBytes(data []byte) string {\n   134→\th := sha256.Sum256(data)\n   135→\treturn hex.EncodeToString(h[:])\n   136→}\n   137→\n   138→// imageLabel retrieves a label value from a Docker image.\n   139→// Returns an error if the image does not exist or cannot be inspected.\n   140→func imageLabel(ctx context.Context, image, label string) (string, error) {\n   141→\tcmd := exec.CommandContext(ctx, \"docker\", \"inspect\",\n   142→\t\t\"--format\", fmt.Sprintf(\"{{index .Config.Labels %q}}\", label),\n   143→\t\timage)\n   144→\tvar stdout, stderr bytes.Buffer\n   145→\tcmd.Stdout = &stdout\n   146→\tcmd.Stderr = &stderr\n   147→\tif err := cmd.Run(); err != nil {\n   148→\t\treturn \"\", fmt.Errorf(\"inspecting image %s: %s: %w\", image, strings.TrimSpace(stderr.String()), err)\n   149→\t}\n   150→\tval := strings.TrimSpace(stdout.String())\n   151→\tif val == \"\" || val == \"<no value>\" {\n   152→\t\treturn \"\", fmt.Errorf(\"label %s not set on image %s\", label, image)\n   153→\t}\n   154→\treturn val, nil\n   155→}\n   156→\n   157→// buildImage runs docker build for the project, tagging the result with the\n   158→// given image name and embedding the Dockerfile hash and base image digest\n   159→// as labels.\n   160→func buildImage(ctx context.Context, projectDir, dockerfilePath, image, hash string, dockerfileContent []byte) error {\n   161→\tlog.Printf(\"building image %s from %s\", image, dockerfilePath)\n   162→\n   163→\targs := []string{\n   164→\t\t\"build\",\n   165→\t\t\"-t\", image,\n   166→\t\t\"-f\", dockerfilePath,\n   167→\t\t\"--label\", fmt.Sprintf(\"%s=%s\", dockerfileHashLabel, hash),\n   168→\t}\n   169→\n   170→\t// Record the base image digest so we can detect upstream changes later.\n   171→\tif baseRef := parseBaseImage(dockerfileContent); baseRef != \"\" && strings.ToLower(baseRef) != \"scratch\" {\n   172→\t\tif id, err := baseImageID(ctx, baseRef); err == nil {\n   173→\t\t\targs = append(args, \"--label\", fmt.Sprintf(\"%s=%s\", baseImageDigestLabel, id))\n   174→\t\t}\n   175→\t}\n   176→\n   177→\targs = append(args, projectDir)\n   178→\n   179→\tcmd := exec.CommandContext(ctx, \"docker\"