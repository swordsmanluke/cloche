{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CFGFWaj7h1VXi2cTat4daW","type":"tool_result","content":"     1→package web\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"encoding/json\"\n     6→\t\"fmt\"\n     7→\t\"net/http\"\n     8→\t\"net/http/httptest\"\n     9→\t\"strings\"\n    10→\t\"testing\"\n    11→\t\"time\"\n    12→\n    13→\t\"github.com/cloche-dev/cloche/internal/adapters/sqlite\"\n    14→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    15→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    16→\t\"github.com/stretchr/testify/assert\"\n    17→\t\"github.com/stretchr/testify/require\"\n    18→)\n    19→\n    20→// mockContainerManager implements ContainerManager for testing.\n    21→type mockContainerManager struct {\n    22→\tcontainers map[string]bool // containerID -> exists\n    23→\trunning    map[string]bool // containerID -> running\n    24→\tremoved    []string\n    25→}\n    26→\n    27→func newMockContainerManager() *mockContainerManager {\n    28→\treturn &mockContainerManager{\n    29→\t\tcontainers: map[string]bool{},\n    30→\t\trunning:    map[string]bool{},\n    31→\t}\n    32→}\n    33→\n    34→func (m *mockContainerManager) Logs(_ context.Context, containerID string) (string, error) {\n    35→\treturn \"mock logs\", nil\n    36→}\n    37→\n    38→func (m *mockContainerManager) Remove(_ context.Context, containerID string) error {\n    39→\tif !m.containers[containerID] {\n    40→\t\treturn fmt.Errorf(\"container %s not found\", containerID)\n    41→\t}\n    42→\tdelete(m.containers, containerID)\n    43→\tm.removed = append(m.removed, containerID)\n    44→\treturn nil\n    45→}\n    46→\n    47→func (m *mockContainerManager) Inspect(_ context.Context, containerID string) (*ports.ContainerStatus, error) {\n    48→\tif !m.containers[containerID] {\n    49→\t\treturn nil, fmt.Errorf(\"container %s not found\", containerID)\n    50→\t}\n    51→\treturn &ports.ContainerStatus{Running: m.running[containerID], ExitCode: 0}, nil\n    52→}\n    53→\n    54→func setupHandler(t *testing.T) (*Handler, *sqlite.Store) {\n    55→\tt.Helper()\n    56→\tstore, err := sqlite.NewStore(\":memory:\")\n    57→\trequire.NoError(t, err)\n    58→\tt.Cleanup(func() { store.Close() })\n    59→\n    60→\th, err := NewHandler(store, store)\n    61→\trequire.NoError(t, err)\n    62→\treturn h, store\n    63→}\n    64→\n    65→func seedRun(t *testing.T, store *sqlite.Store, id, workflow string, state domain.RunState) {\n    66→\tt.Helper()\n    67→\tseedRunWithProject(t, store, id, workflow, state, \"\")\n    68→}\n    69→\n    70→func seedRunWithProject(t *testing.T, store *sqlite.Store, id, workflow string, state domain.RunState, projectDir string) {\n    71→\tt.Helper()\n    72→\tctx := context.Background()\n    73→\trun := domain.NewRun(id, workflow)\n    74→\trun.ProjectDir = projectDir\n    75→\tif state != domain.RunStatePending {\n    76→\t\trun.Start()\n    77→\t\trun.ContainerID = \"abc123def456789\"\n    78→\t}\n    79→\tif state == domain.RunStateSucceeded || state == domain.RunStateFailed {\n    80→\t\trun.Complete(state)\n    81→\t}\n    82→\tif state == domain.RunStateFailed {\n    83→\t\trun.ErrorMessage = \"something went wrong\"\n    84→\t}\n    85→\trequire.NoError(t, store.CreateRun(ctx, run))\n    86→}\n    87→\n    88→func TestRunsList_WithRuns(t *testing.T) {\n    89→\th, store := setupHandler(t)\n    90→\tseedRun(t, store, \"test-run-1\", \"develop\", domain.RunStateRunning)\n    91→\tseedRun(t, store, \"test-run-2\", \"deploy\", domain.RunStateSucceeded)\n    92→\n    93→\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n    94→\tw := httptest.NewRecorder()\n    95→\th.ServeHTTP(w, req)\n    96→\n    97→\tassert.Equal(t, http.StatusOK, w.Code)\n    98→\tassert.Contains(t, w.Header().Get(\"Content-Type\"), \"text/html\")\n    99→\tbody := w.Body.String()\n   100→\tassert.Contains(t, body, \"test-run-1\")\n   101→\tassert.Contains(t, body, \"test-run-2\")\n   102→\tassert.Contains(t, body, \"badge-running\")\n   103→\tassert.Contains(t, body, \"badge-succeeded\")\n   104→\tassert.Contains(t, body, \"develop\")\n   105→\tassert.Contains(t, body, \"deploy\")\n   106→}\n   107→\n   108→func TestRunsList_Empty(t *testing.T) {\n   109→\th, _ := setupHandler(t)\n   110→\n   111→\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n   112→\tw := httptest.NewRecorder()\n   113→\th.ServeHTTP(w, req)\n   114→\n   115→\tassert.Equal(t, http.StatusOK, w.Code)\n   116→\tassert.Contains(t, w.Body.String(), \"No runs yet.\")\n   117→}\n   118→\n   119→func TestRunDetail_WithCaptures(t *testing.T) {\n   120→\th, store := setupHandler(t)\n   121→\tseedRun(t, store, \"run-detail-1\", \"develop\", domain.RunStateRunning)\n   122→\n   123→\tctx := context.Background()\n   124→\trequire.NoError(t, store.SaveCapture(ctx, \"run-detail-1\", &domain.StepExecution{\n   125→\t\tStepName:    \"implement\",\n   126→\t\tResult:      \"success\",\n   127→\t\tStartedAt:   time.Now().Add(-5 * time.Minute),\n   128→\t\tCompletedAt: time.Now(),\n   129→\t}))\n   130→\n   131→\treq := httptest.NewRequest(\"GET\", \"/runs/run-detail-1\", nil)\n   132→\tw := httptest.NewRecorder()\n   133→\th.ServeHTTP(w, req)\n   134→\n   135→\tassert.Equal(t, http.StatusOK, w.Code)\n   136→\tbody := w.Body.String()\n   137→\tassert.Contains(t, body, \"run-detail-1\")\n   138→\tassert.Contains(t, body, \"implement\")\n   139→}\n   140→\n   141→func TestRunDetail_NotFound(t *testing.T) {\n   142→\th, _ := setupHandler(t)\n   143→\n   144→\treq := httptest.NewRequest(\"GET\", \"/runs/nonexistent\", nil)\n   145→\tw := httptest.NewRecorder()\n   146→\th.ServeHTTP(w, req)\n   147→\n   148→\tassert.Equal(t, http.StatusNotFound, w.Code)\n   149→}\n   150→\n   151→func TestAPIRuns(t *testing.T) {\n   152→\th, store := setupHandler(t)\n   153→\tseedRun(t, store, \"api-run-1\", \"develop\", domain.RunStateRunning)\n   154→\tseedRun(t, store, \"api-run-2\", \"deploy\", domain.RunStateSucceeded)\n   155→\n   156→\treq := httptest.NewRequest(\"GET\", \"/api/runs\", nil)\n   157→\tw := httptest.NewRecorder()\n   158→\th.ServeHTTP(w, req)\n   159→\n   160→\tassert.Equal(t, http.StatusOK, w.Code)\n   161→\tassert.Contains(t, w.Header().Get(\"Content-Type\"), \"application/json\")\n   162→\n   163→\tvar runs []apiRun\n   164→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &runs))\n   165→\tassert.Len(t, runs, 2)\n   166→\n   167→\tids := map[string]bool{}\n   168→\tfor _, r := range runs {\n   169→\t\tids[r.ID] = true\n   170→\t}\n   171→\tassert.True(t, ids[\"api-run-1\"])\n   172→\tassert.True(t, ids[\"api-run-2\"])\n   173→}\n   174→\n   175→func TestAPIRunDetail(t *testing.T) {\n   176→\th, store := setupHandler(t)\n   177→\tseedRun(t, store, \"api-detail-1\", \"develop\", domain.RunStateRunning)\n   178→\n   179→\tctx := context.Background()\n   180→\trequire.NoError(t, store.SaveCapture(ctx, \"api-detail-1\", &domain.StepExecution{\n   181→\t\tStepName:    \"build\",\n   182→\t\tResult:      \"success\",\n   183→\t\tStartedAt:   time.Now().Add(-10 * time.Second),\n   184→\t\tCompletedAt: time.Now(),\n   185→\t}))\n   186→\n   187→\treq := httptest.NewRequest(\"GET\", \"/api/runs/api-detail-1\", nil)\n   188→\tw := httptest.NewRecorder()\n   189→\th.ServeHTTP(w, req)\n   190→\n   191→\tassert.Equal(t, http.StatusOK, w.Code)\n   192→\n   193→\tvar detail apiRunDetail\n   194→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &detail))\n   195→\tassert.Equal(t, \"api-detail-1\", detail.ID)\n   196→\tassert.Equal(t, \"running\", detail.State)\n   197→\tassert.Len(t, detail.Steps, 1)\n   198→\tassert.Equal(t, \"build\", detail.Steps[0].StepName)\n   199→\tassert.NotEmpty(t, detail.Steps[0].Duration)\n   200→}\n   201→\n   202→func TestStaticCSS(t *testing.T) {\n   203→\th, _ := setupHandler(t)\n   204→\n   205→\treq := httptest.NewRequest(\"GET\", \"/static/style.css\", nil)\n   206→\tw := httptest.NewRecorder()\n   207→\th.ServeHTTP(w, req)\n   208→\n   209→\tassert.Equal(t, http.StatusOK, w.Code)\n   210→\tassert.Contains(t, w.Body.String(), \":root\")\n   211→\tassert.Contains(t, w.Body.String(), \"badge-running\")\n   212→}\n   213→\n   214→func TestHelpers(t *testing.T) {\n   215→\tt.Run(\"stateColor\", func(t *testing.T) {\n   216→\t\tassert.Equal(t, \"pending\", stateColor(domain.RunStatePending))\n   217→\t\tassert.Equal(t, \"running\", stateColor(domain.RunStateRunning))\n   218→\t\tassert.Equal(t, \"succeeded\", stateColor(domain.RunStateSucceeded))\n   219→\t\tassert.Equal(t, \"failed\", stateColor(domain.RunStateFailed))\n   220→\t\tassert.Equal(t, \"cancelled\", stateColor(domain.RunStateCancelled))\n   221→\t})\n   222→\n   223→\tt.Run(\"formatTime\", func(t *testing.T) {\n   224→\t\tassert.Equal(t, \"\", formatTime(time.Time{}))\n   225→\t\tts := time.Date(2026, 2, 26, 14, 30, 0, 0, time.UTC)\n   226→\t\tassert.Equal(t, \"2026-02-26 14:30:00\", formatTime(ts))\n   227→\t})\n   228→\n   229→\tt.Run(\"formatDuration\", func(t *testing.T) {\n   230→\t\tnow := time.Now()\n   231→\t\tassert.Equal(t, \"\", formatDuration(time.Time{}, now))\n   232→\t\tassert.Equal(t, \"\", formatDuration(now, time.Time{}))\n   233→\t\tassert.Equal(t, \"500ms\", formatDuration(now, now.Add(500*time.Millisecond)))\n   234→\t\tassert.Equal(t, \"5.0s\", formatDuration(now, now.Add(5*time.Second)))\n   235→\t\tassert.Equal(t, \"2m30s\", formatDuration(now, now.Add(2*time.Minute+30*time.Second)))\n   236→\t})\n   237→\n   238→\tt.Run(\"truncate\", func(t *testing.T) {\n   239→\t\tassert.Equal(t, \"hello\", truncate(\"hello\", 10))\n   240→\t\tassert.Equal(t, \"hel...\", truncate(\"hello world\", 3))\n   241→\t})\n   242→\n   243→\tt.Run(\"shortContainerID\", func(t *testing.T) {\n   244→\t\tassert.Equal(t, \"abc123def456\", shortContainerID(\"abc123def456789abcdef\"))\n   245→\t\tassert.Equal(t, \"short\", shortContainerID(\"short\"))\n   246→\t})\n   247→\n   248→\tt.Run(\"projectLabels\", func(t *testing.T) {\n   249→\t\t// No conflict: show base name only\n   250→\t\tlabels := projectLabels([]string{\"/home/user/alpha\", \"/home/user/beta\"})\n   251→\t\tassert.Equal(t, \"alpha\", labels[\"/home/user/alpha\"])\n   252→\t\tassert.Equal(t, \"beta\", labels[\"/home/user/beta\"])\n   253→\n   254→\t\t// Conflict: two dirs share the same base name\n   255→\t\tlabels = projectLabels([]string{\"/home/foo/bar\", \"/home/baz/bar\"})\n   256→\t\tassert.Equal(t, \"foo/bar\", labels[\"/home/foo/bar\"])\n   257→\t\tassert.Equal(t, \"baz/bar\", labels[\"/home/baz/bar\"])\n   258→\n   259→\t\t// Mixed: some conflict, some don't\n   260→\t\tlabels = projectLabels([]string{\"/a/bar\", \"/b/bar\", \"/c/unique\"})\n   261→\t\tassert.Equal(t, \"a/bar\", labels[\"/a/bar\"])\n   262→\t\tassert.Equal(t, \"b/bar\", labels[\"/b/bar\"])\n   263→\t\tassert.Equal(t, \"unique\", labels[\"/c/unique\"])\n   264→\n   265→\t\t// Empty list\n   266→\t\tlabels = projectLabels(nil)\n   267→\t\tassert.Empty(t, labels)\n   268→\t})\n   269→}\n   270→\n   271→func TestRunsList_ProjectFilter(t *testing.T) {\n   272→\th, store := setupHandler(t)\n   273→\tseedRunWithProject(t, store, \"run-a1\", \"develop\", domain.RunStateRunning, \"/home/user/alpha\")\n   274→\tseedRunWithProject(t, store, \"run-a2\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n   275→\tseedRunWithProject(t, store, \"run-b1\", \"deploy\", domain.RunStateRunning, \"/home/user/beta\")\n   276→\n   277→\t// Without filter: all runs shown\n   278→\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n   279→\tw := httptest.NewRecorder()\n   280→\th.ServeHTTP(w, req)\n   281→\tassert.Equal(t, http.StatusOK, w.Code)\n   282→\tbody := w.Body.String()\n   283→\tassert.Contains(t, body, \"run-a1\")\n   284→\tassert.Contains(t, body, \"run-b1\")\n   285→\n   286→\t// With project filter: only matching runs\n   287→\treq = httptest.NewRequest(\"GET\", \"/runs?project=/home/user/alpha\", nil)\n   288→\tw = httptest.NewRecorder()\n   289→\th.ServeHTTP(w, req)\n   290→\tassert.Equal(t, http.StatusOK, w.Code)\n   291→\tbody = w.Body.String()\n   292→\tassert.Contains(t, body, \"run-a1\")\n   293→\tassert.Contains(t, body, \"run-a2\")\n   294→\tassert.NotContains(t, body, \"run-b1\")\n   295→}\n   296→\n   297→func TestRunsList_ProjectColumn(t *testing.T) {\n   298→\th, store := setupHandler(t)\n   299→\tseedRunWithProject(t, store, \"run-p1\", \"develop\", domain.RunStateRunning, \"/home/user/myproject\")\n   300→\n   301→\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n   302→\tw := httptest.NewRecorder()\n   303→\th.ServeHTTP(w, req)\n   304→\tassert.Equal(t, http.StatusOK, w.Code)\n   305→\tbody := w.Body.String()\n   306→\tassert.Contains(t, body, \"myproject\")\n   307→\tassert.Contains(t, body, \"Project\")\n   308→}\n   309→\n   310→func TestAPIRuns_ProjectFilter(t *testing.T) {\n   311→\th, store := setupHandler(t)\n   312→\tseedRunWithProject(t, store, \"api-a1\", \"develop\", domain.RunStateRunning, \"/home/user/alpha\")\n   313→\tseedRunWithProject(t, store, \"api-b1\", \"deploy\", domain.RunStateRunning, \"/home/user/beta\")\n   314→\n   315→\t// Without filter: all runs\n   316→\treq := httptest.NewRequest(\"GET\", \"/api/runs\", nil)\n   317→\tw := httptest.NewRecorder()\n   318→\th.ServeHTTP(w, req)\n   319→\tassert.Equal(t, http.StatusOK, w.Code)\n   320→\n   321→\tvar allRuns []apiRun\n   322→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &allRuns))\n   323→\tassert.Len(t, allRuns, 2)\n   324→\n   325→\t// With filter: only matching\n   326→\treq = httptest.NewRequest(\"GET\", \"/api/runs?project=/home/user/alpha\", nil)\n   327→\tw = httptest.NewRecorder()\n   328→\th.ServeHTTP(w, req)\n   329→\tassert.Equal(t, http.StatusOK, w.Code)\n   330→\n   331→\tvar filtered []apiRun\n   332→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &filtered))\n   333→\tassert.Len(t, filtered, 1)\n   334→\tassert.Equal(t, \"api-a1\", filtered[0].ID)\n   335→\tassert.Equal(t, \"/home/user/alpha\", filtered[0].ProjectDir)\n   336→\tassert.Equal(t, \"alpha\", filtered[0].ProjectLabel)\n   337→}\n   338→\n   339→func setupHandlerWithContainerManager(t *testing.T) (*Handler, *sqlite.Store, *mockContainerManager) {\n   340→\tt.Helper()\n   341→\tstore, err := sqlite.NewStore(\":memory:\")\n   342→\trequire.NoError(t, err)\n   343→\tt.Cleanup(func() { store.Close() })\n   344→\n   345→\tmgr := newMockContainerManager()\n   346→\th, err := NewHandler(store, store, WithContainerManager(mgr))\n   347→\trequire.NoError(t, err)\n   348→\treturn h, store, mgr\n   349→}\n   350→\n   351→func seedRunWithContainer(t *testing.T, store *sqlite.Store, mgr *mockContainerManager, id, workflow, projectDir, containerID string, kept bool) {\n   352→\tt.Helper()\n   353→\tctx := context.Background()\n   354→\trun := domain.NewRun(id, workflow)\n   355→\trun.ProjectDir = projectDir\n   356→\trun.Start()\n   357→\trun.ContainerID = containerID\n   358→\trun.ContainerKept = kept\n   359→\trun.Complete(domain.RunStateSucceeded)\n   360→\trequire.NoError(t, store.CreateRun(ctx, run))\n   361→\tif kept {\n   362→\t\tmgr.containers[containerID] = true\n   363→\t}\n   364→}\n   365→\n   366→func TestRunDetail_ContainerRunning(t *testing.T) {\n   367→\th, store, mgr := setupHandlerWithContainerManager(t)\n   368→\n   369→\tctx := context.Background()\n   370→\trun := domain.NewRun(\"run-cr\", \"develop\")\n   371→\trun.ProjectDir = \"/proj\"\n   372→\trun.Start()\n   373→\trun.ContainerID = \"cid-running\"\n   374→\trequire.NoError(t, store.CreateRun(ctx, run))\n   375→\tmgr.containers[\"cid-running\"] = true\n   376→\tmgr.running[\"cid-running\"] = true\n   377→\n   378→\treq := httptest.NewRequest(\"GET\", \"/runs/run-cr\", nil)\n   379→\tw := httptest.NewRecorder()\n   380→\th.ServeHTTP(w, req)\n   381→\n   382→\tassert.Equal(t, http.StatusOK, w.Code)\n   383→\tbody := w.Body.String()\n   384→\tassert.Contains(t, body, \"Container running\")\n   385→\tassert.Contains(t, body, `badge-running\">Container running`)\n   386→}\n   387→\n   388→func TestRunDetail_ContainerStopped(t *testing.T) {\n   389→\th, store, mgr := setupHandlerWithContainerManager(t)\n   390→\n   391→\tctx := context.Background()\n   392→\trun := domain.NewRun(\"run-cs\", \"develop\")\n   393→\trun.ProjectDir = \"/proj\"\n   394→\trun.Start()\n   395→\trun.ContainerID = \"cid-stopped\"\n   396→\trun.ContainerKept = false\n   397→\trun.Complete(domain.RunStateSucceeded)\n   398→\trequire.NoError(t, store.CreateRun(ctx, run))\n   399→\tmgr.containers[\"cid-stopped\"] = true // container exists but not running, not kept\n   400→\n   401→\treq := httptest.NewRequest(\"GET\", \"/runs/run-cs\", nil)\n   402→\tw := httptest.NewRecorder()\n   403→\th.ServeHTTP(w, req)\n   404→\n   405→\tassert.Equal(t, http.StatusOK, w.Code)\n   406→\tbody := w.Body.String()\n   407→\tassert.Contains(t, body, \"Container stopped\")\n   408→\tassert.Contains(t, body, `badge-stopped\">Container stopped`)\n   409→}\n   410→\n   411→func TestRunDetail_ContainerAvailable(t *testing.T) {\n   412→\th, store, mgr := setupHandlerWithContainerManager(t)\n   413→\tseedRunWithContainer(t, store, mgr, \"run-c1\", \"develop\", \"/proj\", \"cid-1234567890ab\", true)\n   414→\n   415→\treq := httptest.NewRequest(\"GET\", \"/runs/run-c1\", nil)\n   416→\tw := httptest.NewRecorder()\n   417→\th.ServeHTTP(w, req)\n   418→\n   419→\tassert.Equal(t, http.StatusOK, w.Code)\n   420→\tbody := w.Body.String()\n   421→\tassert.Contains(t, body, \"Container available\")\n   422→\tassert.Contains(t, body, `badge-succeeded\">Container available`)\n   423→\tassert.Contains(t, body, `id=\"delete-container-btn\"`)\n   424→}\n   425→\n   426→func TestRunDetail_ContainerRemoved(t *testing.T) {\n   427→\th, store, _ := setupHandlerWithContainerManager(t)\n   428→\n   429→\tctx := context.Background()\n   430→\trun := domain.NewRun(\"run-c2\", \"develop\")\n   431→\trun.ProjectDir = \"/proj\"\n   432→\trun.Start()\n   433→\trun.ContainerID = \"cid-gone\"\n   434→\trun.ContainerKept = false\n   435→\trun.Complete(domain.RunStateSucceeded)\n   436→\trequire.NoError(t, store.CreateRun(ctx, run))\n   437→\t// container NOT in mock's containers map → Inspect will fail → \"removed\"\n   438→\n   439→\treq := httptest.NewRequest(\"GET\", \"/runs/run-c2\", nil)\n   440→\tw := httptest.NewRecorder()\n   441→\th.ServeHTTP(w, req)\n   442→\n   443→\tassert.Equal(t, http.StatusOK, w.Code)\n   444→\tbody := w.Body.String()\n   445→\tassert.Contains(t, body, \"Container removed\")\n   446→\tassert.Contains(t, body, `badge-pending\">Container removed`)\n   447→}\n   448→\n   449→func TestAPIDeleteContainer_Success(t *testing.T) {\n   450→\th, store, mgr := setupHandlerWithContainerManager(t)\n   451→\tseedRunWithContainer(t, store, mgr, \"run-del1\", \"develop\", \"/proj\", \"cid-to-delete\", true)\n   452→\n   453→\treq := httptest.NewRequest(\"DELETE\", \"/api/runs/run-del1/container\", nil)\n   454→\tw := httptest.NewRecorder()\n   455→\th.ServeHTTP(w, req)\n   456→\n   457→\tassert.Equal(t, http.StatusOK, w.Code)\n   458→\n   459→\tvar resp map[string]string\n   460→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n   461→\tassert.Equal(t, \"ok\", resp[\"status\"])\n   462→\n   463→\t// Verify container was removed\n   464→\tassert.Contains(t, mgr.removed, \"cid-to-delete\")\n   465→\n   466→\t// Verify run was updated\n   467→\trun, err := store.GetRun(context.Background(), \"run-del1\")\n   468→\trequire.NoError(t, err)\n   469→\tassert.False(t, run.ContainerKept)\n   470→}\n   471→\n   472→func TestAPIDeleteContainer_RunNotFound(t *testing.T) {\n   473→\th, _, _ := setupHandlerWithContainerManager(t)\n   474→\n   475→\treq := httptest.NewRequest(\"DELETE\", \"/api/runs/nonexistent/container\", nil)\n   476→\tw := httptest.NewRecorder()\n   477→\th.ServeHTTP(w, req)\n   478→\n   479→\tassert.Equal(t, http.StatusNotFound, w.Code)\n   480→}\n   481→\n   482→func TestAPIDeleteContainer_NoManager(t *testing.T) {\n   483→\th, store := setupHandler(t) // no container manager\n   484→\tseedRun(t, store, \"run-noman\", \"develop\", domain.RunStateSucceeded)\n   485→\n   486→\treq := httptest.NewRequest(\"DELETE\", \"/api/runs/run-noman/container\", nil)\n   487→\tw := httptest.NewRecorder()\n   488→\th.ServeHTTP(w, req)\n   489→\n   490→\tassert.Equal(t, http.StatusBadRequest, w.Code)\n   491→}\n   492→\n   493→func TestAPIRunDetail_ContainerState(t *testing.T) {\n   494→\th, store, mgr := setupHandlerWithContainerManager(t)\n   495→\n   496→\t// Seed a running container\n   497→\tctx := context.Background()\n   498→\trun := domain.NewRun(\"api-cs1\", \"develop\")\n   499→\trun.ProjectDir = \"/proj\"\n   500→\trun.Start()\n   501→\trun.ContainerID = \"cid-api-running\"\n   502→\trequire.NoError(t, store.CreateRun(ctx, run))\n   503→\tmgr.containers[\"cid-api-running\"] = true\n   504→\tmgr.running[\"cid-api-running\"] = true\n   505→\n   506→\treq := httptest.NewRequest(\"GET\", \"/api/runs/api-cs1\", nil)\n   507→\tw := httptest.NewRecorder()\n   508→\th.ServeHTTP(w, req)\n   509→\n   510→\tassert.Equal(t, http.StatusOK, w.Code)\n   511→\n   512→\tvar detail apiRunDetail\n   513→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &detail))\n   514→\tassert.Equal(t, \"running\", detail.ContainerState)\n   515→\n   516→\t// Now stop it\n   517→\tmgr.running[\"cid-api-running\"] = false\n   518→\n   519→\tw = httptest.NewRecorder()\n   520→\th.ServeHTTP(w, httptest.NewRequest(\"GET\", \"/api/runs/api-cs1\", nil))\n   521→\n   522→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &detail))\n   523→\tassert.Equal(t, \"stopped\", detail.ContainerState)\n   524→}\n   525→\n   526→func TestRunsList_ContainerCount(t *testing.T) {\n   527→\th, store, mgr := setupHandlerWithContainerManager(t)\n   528→\tseedRunWithContainer(t, store, mgr, \"run-cc1\", \"develop\", \"/home/user/alpha\", \"cid-1\", true)\n   529→\tseedRunWithContainer(t, store, mgr, \"run-cc2\", \"develop\", \"/home/user/alpha\", \"cid-2\", true)\n   530→\tseedRunWithContainer(t, store, mgr, \"run-cc3\", \"deploy\", \"/home/user/beta\", \"cid-3\", false)\n   531→\n   532→\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n   533→\tw := httptest.NewRecorder()\n   534→\th.ServeHTTP(w, req)\n   535→\n   536→\tassert.Equal(t, http.StatusOK, w.Code)\n   537→\tbody := w.Body.String()\n   538→\t// alpha has 2 retained containers\n   539→\tassert.Contains(t, body, \"2 containers\")\n   540→\t// beta has 0, so no count should appear\n   541→\tassert.NotContains(t, body, \"0 container\")\n   542→}\n   543→\n   544→func TestAPIProjects(t *testing.T) {\n   545→\th, store := setupHandler(t)\n   546→\tseedRunWithProject(t, store, \"p1\", \"develop\", domain.RunStateRunning, \"/home/user/alpha\")\n   547→\tseedRunWithProject(t, store, \"p2\", \"develop\", domain.RunStateRunning, \"/home/user/beta\")\n   548→\tseedRunWithProject(t, store, \"p3\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n   549→\n   550→\treq := httptest.NewRequest(\"GET\", \"/api/projects\", nil)\n   551→\tw := httptest.NewRecorder()\n   552→\th.ServeHTTP(w, req)\n   553→\tassert.Equal(t, http.StatusOK, w.Code)\n   554→\n   555→\ttype apiHealth struct {\n   556→\t\tStatus string `json:\"status\"`\n   557→\t\tPassed int    `json:\"passed\"`\n   558→\t\tFailed int    `json:\"failed\"`\n   559→\t\tTotal  int    `json:\"total\"`\n   560→\t}\n   561→\ttype project struct {\n   562→\t\tDir         string    `json:\"dir\"`\n   563→\t\tLabel       string    `json:\"label\"`\n   564→\t\tHealth      apiHealth `json:\"health\"`\n   565→\t\tActiveCount int       `json:\"active_count\"`\n   566→\t}\n   567→\tvar projects []project\n   568→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &projects))\n   569→\tassert.Len(t, projects, 2)\n   570→\n   571→\tbyDir := map[string]project{}\n   572→\tfor _, p := range projects {\n   573→\t\tbyDir[p.Dir] = p\n   574→\t}\n   575→\tassert.Equal(t, \"alpha\", byDir[\"/home/user/alpha\"].Label)\n   576→\tassert.Equal(t, \"beta\", byDir[\"/home/user/beta\"].Label)\n   577→\t// alpha has 1 running + 1 succeeded = yellow health (mix), 1 active\n   578→\tassert.Equal(t, 1, byDir[\"/home/user/alpha\"].ActiveCount)\n   579→\tassert.NotEmpty(t, byDir[\"/home/user/alpha\"].Health.Status)\n   580→\t// beta has 1 running = blue (all in-progress), 1 active\n   581→\tassert.Equal(t, \"blue\", byDir[\"/home/user/beta\"].Health.Status)\n   582→\tassert.Equal(t, 1, byDir[\"/home/user/beta\"].ActiveCount)\n   583→}\n   584→\n   585→func TestProjectOverview_WithProjects(t *testing.T) {\n   586→\th, store := setupHandler(t)\n   587→\tseedRunWithProject(t, store, \"ov-1\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n   588→\tseedRunWithProject(t, store, \"ov-2\", \"develop\", domain.RunStateFailed, \"/home/user/alpha\")\n   589→\tseedRunWithProject(t, store, \"ov-3\", \"develop\", domain.RunStateRunning, \"/home/user/beta\")\n   590→\n   591→\treq := httptest.NewRequest(\"GET\", \"/\", nil)\n   592→\tw := httptest.NewRecorder()\n   593→\th.ServeHTTP(w, req)\n   594→\n   595→\tassert.Equal(t, http.StatusOK, w.Code)\n   596→\tassert.Contains(t, w.Header().Get(\"Content-Type\"), \"text/html\")\n   597→\tbody := w.Body.String()\n   598→\t// Project cards should be present\n   599→\tassert.Contains(t, body, \"project-card\")\n   600→\tassert.Contains(t, body, \"alpha\")\n   601→\tassert.Contains(t, body, \"beta\")\n   602→\t// Health dots\n   603→\tassert.Contains(t, body, \"health-dot\")\n   604→\t// Run history dots\n   605→\tassert.Contains(t, body, \"run-dot\")\n   606→\t// Quick actions\n   607→\tassert.Contains(t, body, \"View Runs\")\n   608→\tassert.Contains(t, body, \"Trigger Orchestrator\")\n   609→}\n   610→\n   611→func TestProjectOverview_Empty(t *testing.T) {\n   612→\th, _ := setupHandler(t)\n   613→\n   614→\treq := httptest.NewRequest(\"GET\", \"/\", nil)\n   615→\tw := httptest.NewRecorder()\n   616→\th.ServeHTTP(w, req)\n   617→\n   618→\tassert.Equal(t, http.StatusOK, w.Code)\n   619→\tassert.Contains(t, w.Body.String(), \"No projects yet\")\n   620→}\n   621→\n   622→func TestAPITriggerOrchestrator_NoOrchestrator(t *testing.T) {\n   623→\th, store := setupHandler(t)\n   624→\tseedRunWithProject(t, store, \"orch-1\", \"develop\", domain.RunStateSucceeded, \"/home/user/myproject\")\n   625→\n   626→\treq := httptest.NewRequest(\"POST\", \"/api/projects/myproject/trigger\", nil)\n   627→\tw := httptest.NewRecorder()\n   628→\th.ServeHTTP(w, req)\n   629→\n   630→\tassert.Equal(t, http.StatusNotImplemented, w.Code)\n   631→\tassert.Contains(t, w.Header().Get(\"Content-Type\"), \"application/json\")\n   632→\n   633→\tvar result map[string]string\n   634→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &result))\n   635→\tassert.Equal(t, \"orchestrator not configured\", result[\"error\"])\n   636→}\n   637→\n   638→func TestAPITriggerOrchestrator_Success(t *testing.T) {\n   639→\tstore, err := sqlite.NewStore(\":memory:\")\n   640→\trequire.NoError(t, err)\n   641→\tt.Cleanup(func() { store.Close() })\n   642→\n   643→\th, err := NewHandler(store, store, WithOrchestrateFunc(func(ctx context.Context, projectDir string) (int, error) {\n   644→\t\tassert.Equal(t, \"/home/user/myproject\", projectDir)\n   645→\t\treturn 3, nil\n   646→\t}))\n   647→\trequire.NoError(t, err)\n   648→\n   649→\tseedRunWithProject(t, store, \"orch-2\", \"develop\", domain.RunStateSucceeded, \"/home/user/myproject\")\n   650→\n   651→\treq := httptest.NewRequest(\"POST\", \"/api/projects/myproject/trigger\", nil)\n   652→\tw := httptest.NewRecorder()\n   653→\th.ServeHTTP(w, req)\n   654→\n   655→\tassert.Equal(t, http.StatusOK, w.Code)\n   656→\tassert.Contains(t, w.Header().Get(\"Content-Type\"), \"application/json\")\n   657→\n   658→\tvar result map[string]any\n   659→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &result))\n   660→\tassert.Equal(t, \"ok\", result[\"status\"])\n   661→\tassert.Equal(t, \"myproject\", result[\"project\"])\n   662→\tassert.Equal(t, float64(3), result[\"dispatched\"])\n   663→}\n   664→\n   665→func TestAPITriggerOrchestrator_ProjectNotFound(t *testing.T) {\n   666→\tstore, err := sqlite.NewStore(\":memory:\")\n   667→\trequire.NoError(t, err)\n   668→\tt.Cleanup(func() { store.Close() })\n   669→\n   670→\th, err := NewHandler(store, store, WithOrchestrateFunc(func(ctx context.Context, projectDir string) (int, error) {\n   671→\t\treturn 0, nil\n   672→\t}))\n   673→\trequire.NoError(t, err)\n   674→\n   675→\treq := httptest.NewRequest(\"POST\", \"/api/projects/nonexistent/trigger\", nil)\n   676→\tw := httptest.NewRecorder()\n   677→\th.ServeHTTP(w, req)\n   678→\n   679→\tassert.Equal(t, http.StatusNotFound, w.Code)\n   680→\n   681→\tvar result map[string]string\n   682→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &result))\n   683→\tassert.Equal(t, \"project not found\", result[\"error\"])\n   684→}\n   685→\n   686→func TestAPITriggerOrchestrator_Error(t *testing.T) {\n   687→\tstore, err := sqlite.NewStore(\":memory:\")\n   688→\trequire.NoError(t, err)\n   689→\tt.Cleanup(func() { store.Close() })\n   690→\n   691→\th, err := NewHandler(store, store, WithOrchestrateFunc(func(ctx context.Context, projectDir string) (int, error) {\n   692→\t\treturn 0, fmt.Errorf(\"orchestration failed\")\n   693→\t}))\n   694→\trequire.NoError(t, err)\n   695→\n   696→\tseedRunWithProject(t, store, \"orch-3\", \"develop\", domain.RunStateSucceeded, \"/home/user/errproject\")\n   697→\n   698→\treq := httptest.NewRequest(\"POST\", \"/api/projects/errproject/trigger\", nil)\n   699→\tw := httptest.NewRecorder()\n   700→\th.ServeHTTP(w, req)\n   701→\n   702→\tassert.Equal(t, http.StatusInternalServerError, w.Code)\n   703→\n   704→\tvar result map[string]string\n   705→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &result))\n   706→\tassert.Equal(t, \"orchestration failed\", result[\"error\"])\n   707→}\n   708→\n   709→func TestHealthColor(t *testing.T) {\n   710→\tassert.Equal(t, \"green\", healthColor(domain.HealthGreen))\n   711→\tassert.Equal(t, \"yellow\", healthColor(domain.HealthYellow))\n   712→\tassert.Equal(t, \"red\", healthColor(domain.HealthRed))\n   713→\tassert.Equal(t, \"blue\", healthColor(domain.HealthBlue))\n   714→\tassert.Equal(t, \"grey\", healthColor(domain.HealthGrey))\n   715→\tassert.Equal(t, \"grey\", healthColor(\"unknown\"))\n   716→}\n   717→\n   718→func TestAPIProjects_HealthData(t *testing.T) {\n   719→\th, store := setupHandler(t)\n   720→\t// alpha: 3 succeeded, 1 failed → yellow\n   721→\tseedRunWithProject(t, store, \"h1\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n   722→\tseedRunWithProject(t, store, \"h2\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n   723→\tseedRunWithProject(t, store, \"h3\", \"develop\", domain.RunStateFailed, \"/home/user/alpha\")\n   724→\tseedRunWithProject(t, store, \"h4\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n   725→\n   726→\t// beta: all succeeded → green\n   727→\tseedRunWithProject(t, store, \"h5\", \"develop\", domain.RunStateSucceeded, \"/home/user/beta\")\n   728→\tseedRunWithProject(t, store, \"h6\", \"develop\", domain.RunStateSucceeded, \"/home/user/beta\")\n   729→\n   730→\treq := httptest.NewRequest(\"GET\", \"/api/projects\", nil)\n   731→\tw := httptest.NewRecorder()\n   732→\th.ServeHTTP(w, req)\n   733→\tassert.Equal(t, http.StatusOK, w.Code)\n   734→\n   735→\ttype health struct {\n   736→\t\tStatus string `json:\"status\"`\n   737→\t\tPassed int    `json:\"passed\"`\n   738→\t\tFailed int    `json:\"failed\"`\n   739→\t\tTotal  int    `json:\"total\"`\n   740→\t}\n   741→\ttype project struct {\n   742→\t\tDir    string `json:\"dir\"`\n   743→\t\tLabel  string `json:\"label\"`\n   744→\t\tHealth health `json:\"health\"`\n   745→\t}\n   746→\tvar projects []project\n   747→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &projects))\n   748→\tassert.Len(t, projects, 2)\n   749→\n   750→\tbyDir := map[string]project{}\n   751→\tfor _, p := range projects {\n   752→\t\tbyDir[p.Dir] = p\n   753→\t}\n   754→\n   755→\talpha := byDir[\"/home/user/alpha\"]\n   756→\tassert.Equal(t, \"yellow\", alpha.Health.Status)\n   757→\tassert.Equal(t, 3, alpha.Health.Passed)\n   758→\tassert.Equal(t, 1, alpha.Health.Failed)\n   759→\tassert.Equal(t, 4, alpha.Health.Total)\n   760→\n   761→\tbeta := byDir[\"/home/user/beta\"]\n   762→\tassert.Equal(t, \"green\", beta.Health.Status)\n   763→\tassert.Equal(t, 2, beta.Health.Passed)\n   764→\tassert.Equal(t, 0, beta.Health.Failed)\n   765→\tassert.Equal(t, 2, beta.Health.Total)\n   766→}\n   767→\n   768→func TestAPIProjects_HealthNoRuns(t *testing.T) {\n   769→\th, _ := setupHandler(t)\n   770→\n   771→\treq := httptest.NewRequest(\"GET\", \"/api/projects\", nil)\n   772→\tw := httptest.NewRecorder()\n   773→\th.ServeHTTP(w, req)\n   774→\tassert.Equal(t, http.StatusOK, w.Code)\n   775→\n   776→\t// No projects means empty array\n   777→\ttype project struct {\n   778→\t\tDir   string `json:\"dir\"`\n   779→\t\tLabel string `json:\"label\"`\n   780→\t}\n   781→\tvar projects []project\n   782→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &projects))\n   783→\tassert.Empty(t, projects)\n   784→}\n   785→\n   786→// --- Project detail page tests ---\n   787→\n   788→// mockOrchestratorController implements OrchestratorController for testing.\n   789→type mockOrchestratorController struct {\n   790→\tenabled     bool\n   791→\tinFlight    int\n   792→\tconcurrency int\n   793→\tsetEnabled  *bool\n   794→\tsetConcurrency *int\n   795→}\n   796→\n   797→func (m *mockOrchestratorController) Status(dir string) (bool, int, int) {\n   798→\treturn m.enabled, m.inFlight, m.concurrency\n   799→}\n   800→\n   801→func (m *mockOrchestratorController) SetEnabled(dir string, enabled bool) {\n   802→\tm.setEnabled = &enabled\n   803→\tm.enabled = enabled\n   804→}\n   805→\n   806→func (m *mockOrchestratorController) SetConcurrency(dir string, concurrency int) {\n   807→\tm.setConcurrency = &concurrency\n   808→\tm.concurrency = concurrency\n   809→}\n   810→\n   811→func TestProjectDetail_HTML(t *testing.T) {\n   812→\th, store := setupHandler(t)\n   813→\tseedRunWithProject(t, store, \"pd-1\", \"develop\", domain.RunStateSucceeded, \"/home/user/myproject\")\n   814→\tseedRunWithProject(t, store, \"pd-2\", \"develop\", domain.RunStateRunning, \"/home/user/myproject\")\n   815→\n   816→\treq := httptest.NewRequest(\"GET\", \"/projects/myproject\", nil)\n   817→\tw := httptest.NewRecorder()\n   818→\th.ServeHTTP(w, req)\n   819→\n   820→\tassert.Equal(t, http.StatusOK, w.Code)\n   821→\tassert.Contains(t, w.Header().Get(\"Content-Type\"), \"text/html\")\n   822→\tbody := w.Body.String()\n   823→\tassert.Contains(t, body, \"myproject\")\n   824→\tassert.Contains(t, body, \"orchestrator-panel\")\n   825→\tassert.Contains(t, body, \"info-panel\")\n   826→\tassert.Contains(t, body, \"workflow-panel\")\n   827→}\n   828→\n   829→func TestProjectDetail_NotFound(t *testing.T) {\n   830→\th, _ := setupHandler(t)\n   831→\n   832→\treq := httptest.NewRequest(\"GET\", \"/projects/nonexistent\", nil)\n   833→\tw := httptest.NewRecorder()\n   834→\th.ServeHTTP(w, req)\n   835→\n   836→\tassert.Equal(t, http.StatusNotFound, w.Code)\n   837→}\n   838→\n   839→func TestAPIOrchestratorStatus(t *testing.T) {\n   840→\tstore, err := sqlite.NewStore(\":memory:\")\n   841→\trequire.NoError(t, err)\n   842→\tt.Cleanup(func() { store.Close() })\n   843→\n   844→\tmock := &mockOrchestratorController{enabled: true, inFlight: 1, concurrency: 3}\n   845→\th, err := NewHandler(store, store, WithOrchestrator(mock))\n   846→\trequire.NoError(t, err)\n   847→\n   848→\tseedRunWithProject(t, store, \"os-1\", \"develop\", domain.RunStateSucceeded, \"/home/user/myproject\")\n   849→\n   850→\treq := httptest.NewRequest(\"GET\", \"/api/projects/myproject/orchestrator\", nil)\n   851→\tw := httptest.NewRecorder()\n   852→\th.ServeHTTP(w, req)\n   853→\n   854→\tassert.Equal(t, http.StatusOK, w.Code)\n   855→\tvar result map[string]any\n   856→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &result))\n   857→\tassert.Equal(t, true, result[\"enabled\"])\n   858→\tassert.Equal(t, float64(1), result[\"in_flight\"])\n   859→\tassert.Equal(t, float64(3), result[\"concurrency\"])\n   860→}\n   861→\n   862→func TestAPIOrchestratorStatus_NoOrchestrator(t *testing.T) {\n   863→\th, store := setupHandler(t)\n   864→\tseedRunWithProject(t, store, \"os-2\", \"develop\", domain.RunStateSucceeded, \"/home/user/myproject\")\n   865→\n   866→\treq := httptest.NewRequest(\"GET\", \"/api/projects/myproject/orchestrator\", nil)\n   867→\tw := httptest.NewRecorder()\n   868→\th.ServeHTTP(w, req)\n   869→\n   870→\tassert.Equal(t, http.StatusOK, w.Code)\n   871→\tvar result map[string]any\n   872→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &result))\n   873→\tassert.Equal(t, false, result[\"enabled\"])\n   874→}\n   875→\n   876→func TestAPIOrchestratorStartStop(t *testing.T) {\n   877→\tstore, err := sqlite.NewStore(\":memory:\")\n   878→\trequire.NoError(t, err)\n   879→\tt.Cleanup(func() { store.Close() })\n   880→\n   881→\tmock := &mockOrchestratorController{enabled: false, concurrency: 1}\n   882→\th, err := NewHandler(store, store, WithOrchestrator(mock))\n   883→\trequire.NoError(t, err)\n   884→\n   885→\tseedRunWithProject(t, store, \"ss-1\", \"develop\", domain.RunStateSucceeded, \"/home/user/myproject\")\n   886→\n   887→\t// Start\n   888→\treq := httptest.NewRequest(\"POST\", \"/api/projects/myproject/orchestrator/start\", nil)\n   889→\tw := httptest.NewRecorder()\n   890→\th.ServeHTTP(w, req)\n   891→\tassert.Equal(t, http.StatusOK, w.Code)\n   892→\trequire.NotNil(t, mock.setEnabled)\n   893→\tassert.True(t, *mock.setEnabled)\n   894→\n   895→\t// Stop\n   896→\treq = httptest.NewRequest(\"POST\", \"/api/projects/myproject/orchestrator/stop\", nil)\n   897→\tw = httptest.NewRecorder()\n   898→\th.ServeHTTP(w, req)\n   899→\tassert.Equal(t, http.StatusOK, w.Code)\n   900→\tassert.False(t, *mock.setEnabled)\n   901→}\n   902→\n   903→func TestAPIOrchestratorStartStop_NoOrchestrator(t *testing.T) {\n   904→\th, store := setupHandler(t)\n   905→\tseedRunWithProject(t, store, \"ss-2\", \"develop\", domain.RunStateSucceeded, \"/home/user/myproject\")\n   906→\n   907→\treq := httptest.NewRequest(\"POST\", \"/api/projects/myproject/orchestrator/start\", nil)\n   908→\tw := httptest.NewRecorder()\n   909→\th.ServeHTTP(w, req)\n   910→\tassert.Equal(t, http.StatusNotImplemented, w.Code)\n   911→}\n   912→\n   913→func TestAPIOrchestratorConcurrency(t *testing.T) {\n   914→\tstore, err := sqlite.NewStore(\":memory:\")\n   915→\trequire.NoError(t, err)\n   916→\tt.Cleanup(func() { store.Close() })\n   917→\n   918→\tmock := &mockOrchestratorController{enabled: true, concurrency: 1}\n   919→\th, err := NewHandler(store, store, WithOrchestrator(mock))\n   920→\trequire.NoError(t, err)\n   921→\n   922→\tseedRunWithProject(t, store, \"cc-1\", \"develop\", domain.RunStateSucceeded, \"/home/user/myproject\")\n   923→\n   924→\treq := httptest.NewRequest(\"POST\", \"/api/projects/myproject/orchestrator/concurrency\",\n   925→\t\tstrings.NewReader(`{\"concurrency\": 5}`))\n   926→\treq.Header.Set(\"Content-Type\", \"application/json\")\n   927→\tw := httptest.NewRecorder()\n   928→\th.ServeHTTP(w, req)\n   929→\n   930→\tassert.Equal(t, http.StatusOK, w.Code)\n   931→\trequire.NotNil(t, mock.setConcurrency)\n   932→\tassert.Equal(t, 5, *mock.setConcurrency)\n   933→}\n   934→\n   935→func TestAPIOrchestratorConcurrency_Invalid(t *testing.T) {\n   936→\tstore, err := sqlite.NewStore(\":memory:\")\n   937→\trequire.NoError(t, err)\n   938→\tt.Cleanup(func() { store.Close() })\n   939→\n   940→\tmock := &mockOrchestratorController{enabled: true, concurrency: 1}\n   941→\th, err := NewHandler(store, store, WithOrchestrator(mock))\n   942→\trequire.NoError(t, err)\n   943→\n   944→\tseedRunWithProject(t, store, \"cc-2\", \"develop\", domain.RunStateSucceeded, \"/home/user/myproject\")\n   945→\n   946→\treq := httptest.NewRequest(\"POST\", \"/api/projects/myproject/orchestrator/concurrency\",\n   947→\t\tstrings.NewReader(`{\"concurrency\": 0}`))\n   948→\treq.Header.Set(\"Content-Type\", \"application/json\")\n   949→\tw := httptest.NewRecorder()\n   950→\th.ServeHTTP(w, req)\n   951→\n   952→\tassert.Equal(t, http.StatusBadRequest, w.Code)\n   953→}\n   954→\n   955→func TestAPIProjectInfo(t *testing.T) {\n   956→\th, store := setupHandler(t)\n   957→\tseedRunWithProject(t, store, \"pi-1\", \"develop\", domain.RunStateSucceeded, \"/home/user/myproject\")\n   958→\n   959→\treq := httptest.NewRequest(\"GET\", \"/api/projects/myproject/info\", nil)\n   960→\tw := httptest.NewRecorder()\n   961→\th.ServeHTTP(w, req)\n   962→\n   963→\tassert.Equal(t, http.StatusOK, w.Code)\n   964→\tvar result map[string]any\n   965→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &result))\n   966→\t// Project dir won't have .cloche files, so expect empty/zero values\n   967→\tassert.Equal(t, \"\", result[\"docker_image\"])\n   968→\tassert.Equal(t, float64(0), result[\"version\"])\n   969→}\n   970→\n   971→func TestAPIWorkflows_NoWorkflows(t *testing.T) {\n   972→\th, store := setupHandler(t)\n   973→\tseedRunWithProject(t, store, \"wf-1\", \"develop\", domain.RunStateSucceeded, \"/home/user/myproject\")\n   974→\n   975→\treq := httptest.NewRequest(\"GET\", \"/api/projects/myproject/workflows\", nil)\n   976→\tw := httptest.NewRecorder()\n   977→\th.ServeHTTP(w, req)\n   978→\n   979→\tassert.Equal(t, http.StatusOK, w.Code)\n   980→\tvar result []any\n   981→\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &result))\n   982→\tassert.Empty(t, result)\n   983→}\n   984→\n   985→func TestAPIStepContent_WorkflowNotFound(t *testing.T) {\n   986→\th, store := setupHandler(t)\n   987→\tseedRunWithProject(t, store, \"sc-1\", \"develop\", domain.RunStateSucceeded, \"/home/user/myproject\")\n   988→\n   989→\treq := httptest.NewRequest(\"GET\", \"/api/projects/myproject/workflows/develop/steps/implement/content\", nil)\n   990→\tw := httptest.NewRecorder()\n   991→\th.ServeHTTP(w, req)\n   992→\n   993→\tassert.Equal(t, http.StatusNotFound, w.Code)\n   994→}\n   995→\n   996→func TestProjectsPage_HasProjectLinks(t *testing.T) {\n   997→\th, store := setupHandler(t)\n   998→\tseedRunWithProject(t, store, \"pl-1\", \"develop\", domain.RunStateSucceeded, \"/home/user/myproject\")\n   999→\n  1000→\treq := httptest.NewRequest(\"GET\", \"/\", nil)\n  1001→\tw := httptest.NewRecorder()\n  1002→\th.ServeHTTP(w, req)\n  1003→\n  1004→\tassert.Equal(t, http.StatusOK, w.Code)\n  1005→\tbody := w.Body.String()\n  1006→\tassert.Contains(t, body, `href=\"/projects/myproject\"`)\n  1007→}\n  1008→"}]},"parent_tool_use_id":null,"session_id":"3a4260cb-3063-4465-881d-24f718f4c0c9","uuid":"2ee02a1d-eaa5-485e-a4bd-9394132570a4","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/web/handler_test.go","content":"package web\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"net/http\"\n\t\"net/http/httptest\"\n\t\"strings\"\n\t\"testing\"\n\t\"time\"\n\n\t\"github.com/cloche-dev/cloche/internal/adapters/sqlite\"\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n)\n\n// mockContainerManager implements ContainerManager for testing.\ntype mockContainerManager struct {\n\tcontainers map[string]bool // containerID -> exists\n\trunning    map[string]bool // containerID -> running\n\tremoved    []string\n}\n\nfunc newMockContainerManager() *mockContainerManager {\n\treturn &mockContainerManager{\n\t\tcontainers: map[string]bool{},\n\t\trunning:    map[string]bool{},\n\t}\n}\n\nfunc (m *mockContainerManager) Logs(_ context.Context, containerID string) (string, error) {\n\treturn \"mock logs\", nil\n}\n\nfunc (m *mockContainerManager) Remove(_ context.Context, containerID string) error {\n\tif !m.containers[containerID] {\n\t\treturn fmt.Errorf(\"container %s not found\", containerID)\n\t}\n\tdelete(m.containers, containerID)\n\tm.removed = append(m.removed, containerID)\n\treturn nil\n}\n\nfunc (m *mockContainerManager) Inspect(_ context.Context, containerID string) (*ports.ContainerStatus, error) {\n\tif !m.containers[containerID] {\n\t\treturn nil, fmt.Errorf(\"container %s not found\", containerID)\n\t}\n\treturn &ports.ContainerStatus{Running: m.running[containerID], ExitCode: 0}, nil\n}\n\nfunc setupHandler(t *testing.T) (*Handler, *sqlite.Store) {\n\tt.Helper()\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tt.Cleanup(func() { store.Close() })\n\n\th, err := NewHandler(store, store)\n\trequire.NoError(t, err)\n\treturn h, store\n}\n\nfunc seedRun(t *testing.T, store *sqlite.Store, id, workflow string, state domain.RunState) {\n\tt.Helper()\n\tseedRunWithProject(t, store, id, workflow, state, \"\")\n}\n\nfunc seedRunWithProject(t *testing.T, store *sqlite.Store, id, workflow string, state domain.RunState, projectDir string) {\n\tt.Helper()\n\tctx := context.Background()\n\trun := domain.NewRun(id, workflow)\n\trun.ProjectDir = projectDir\n\tif state != domain.RunStatePending {\n\t\trun.Start()\n\t\trun.ContainerID = \"abc123def456789\"\n\t}\n\tif state == domain.RunStateSucceeded || state == domain.RunStateFailed {\n\t\trun.Complete(state)\n\t}\n\tif state == domain.RunStateFailed {\n\t\trun.ErrorMessage = \"something went wrong\"\n\t}\n\trequire.NoError(t, store.CreateRun(ctx, run))\n}\n\nfunc TestRunsList_WithRuns(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRun(t, store, \"test-run-1\", \"develop\", domain.RunStateRunning)\n\tseedRun(t, store, \"test-run-2\", \"deploy\", domain.RunStateSucceeded)\n\n\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tassert.Contains(t, w.Header().Get(\"Content-Type\"), \"text/html\")\n\tbody := w.Body.String()\n\tassert.Contains(t, body, \"test-run-1\")\n\tassert.Contains(t, body, \"test-run-2\")\n\tassert.Contains(t, body, \"badge-running\")\n\tassert.Contains(t, body, \"badge-succeeded\")\n\tassert.Contains(t, body, \"develop\")\n\tassert.Contains(t, body, \"deploy\")\n}\n\nfunc TestRunsList_Empty(t *testing.T) {\n\th, _ := setupHandler(t)\n\n\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tassert.Contains(t, w.Body.String(), \"No runs yet.\")\n}\n\nfunc TestRunDetail_WithCaptures(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRun(t, store, \"run-detail-1\", \"develop\", domain.RunStateRunning)\n\n\tctx := context.Background()\n\trequire.NoError(t, store.SaveCapture(ctx, \"run-detail-1\", &domain.StepExecution{\n\t\tStepName:    \"implement\",\n\t\tResult:      \"success\",\n\t\tStartedAt:   time.Now().Add(-5 * time.Minute),\n\t\tCompletedAt: time.Now(),\n\t}))\n\n\treq := httptest.NewRequest(\"GET\", \"/runs/run-detail-1\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody := w.Body.String()\n\tassert.Contains(t, body, \"run-detail-1\")\n\tassert.Contains(t, body, \"implement\")\n}\n\nfunc TestRunDetail_NotFound(t *testing.T) {\n\th, _ := setupHandler(t)\n\n\treq := httptest.NewRequest(\"GET\", \"/runs/nonexistent\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusNotFound, w.Code)\n}\n\nfunc TestAPIRuns(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRun(t, store, \"api-run-1\", \"develop\", domain.RunStateRunning)\n\tseedRun(t, store, \"api-run-2\", \"deploy\", domain.RunStateSucceeded)\n\n\treq := httptest.NewRequest(\"GET\", \"/api/runs\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tassert.Contains(t, w.Header().Get(\"Content-Type\"), \"application/json\")\n\n\tvar runs []apiRun\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &runs))\n\tassert.Len(t, runs, 2)\n\n\tids := map[string]bool{}\n\tfor _, r := range runs {\n\t\tids[r.ID] = true\n\t}\n\tassert.True(t, ids[\"api-run-1\"])\n\tassert.True(t, ids[\"api-run-2\"])\n}\n\nfunc TestAPIRunDetail(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRun(t, store, \"api-detail-1\", \"develop\", domain.RunStateRunning)\n\n\tctx := context.Background()\n\trequire.NoError(t, store.SaveCapture(ctx, \"api-detail-1\", &domain.StepExecution{\n\t\tStepName:    \"build\",\n\t\tResult:      \"success\",\n\t\tStartedAt:   time.Now().Add(-10 * time.Second),\n\t\tCompletedAt: time.Now(),\n\t}))\n\n\treq := httptest.NewRequest(\"GET\", \"/api/runs/api-detail-1\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\n\tvar detail apiRunDetail\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &detail))\n\tassert.Equal(t, \"api-detail-1\", detail.ID)\n\tassert.Equal(t, \"running\", detail.State)\n\tassert.Len(t, detail.Steps, 1)\n\tassert.Equal(t, \"build\", detail.Steps[0].StepName)\n\tassert.NotEmpty(t, detail.Steps[0].Duration)\n}\n\nfunc TestStaticCSS(t *testing.T) {\n\th, _ := setupHandler(t)\n\n\treq := httptest.NewRequest(\"GET\", \"/static/style.css\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tassert.Contains(t, w.Body.String(), \":root\")\n\tassert.Contains(t, w.Body.String(), \"badge-running\")\n}\n\nfunc TestHelpers(t *testing.T) {\n\tt.Run(\"stateColor\", func(t *testing.T) {\n\t\tassert.Equal(t, \"pending\", stateColor(domain.RunStatePending))\n\t\tassert.Equal(t, \"running\", stateColor(domain.RunStateRunning))\n\t\tassert.Equal(t, \"succeeded\", stateColor(domain.RunStateSucceeded))\n\t\tassert.Equal(t, \"failed\", stateColor(domain.RunStateFailed))\n\t\tassert.Equal(t, \"cancelled\", stateColor(domain.RunStateCancelled))\n\t})\n\n\tt.Run(\"formatTime\", func(t *testing.T) {\n\t\tassert.Equal(t, \"\", formatTime(time.Time{}))\n\t\tts := time.Date(2026, 2, 26, 14, 30, 0, 0, time.UTC)\n\t\tassert.Equal(t, \"2026-02-26 14:30:00\", formatTime(ts))\n\t})\n\n\tt.Run(\"formatDuration\", func(t *testing.T) {\n\t\tnow := time.Now()\n\t\tassert.Equal(t, \"\", formatDuration(time.Time{}, now))\n\t\tassert.Equal(t, \"\", formatDuration(now, time.Time{}))\n\t\tassert.Equal(t, \"500ms\", formatDuration(now, now.Add(500*time.Millisecond)))\n\t\tassert.Equal(t, \"5.0s\", formatDuration(now, now.Add(5*time.Second)))\n\t\tassert.Equal(t, \"2m30s\", formatDuration(now, now.Add(2*time.Minute+30*time.Second)))\n\t})\n\n\tt.Run(\"truncate\", func(t *testing.T) {\n\t\tassert.Equal(t, \"hello\", truncate(\"hello\", 10))\n\t\tassert.Equal(t, \"hel...\", truncate(\"hello world\", 3))\n\t})\n\n\tt.Run(\"shortContainerID\", func(t *testing.T) {\n\t\tassert.Equal(t, \"abc123def456\", shortContainerID(\"abc123def456789abcdef\"))\n\t\tassert.Equal(t, \"short\", shortContainerID(\"short\"))\n\t})\n\n\tt.Run(\"projectLabels\", func(t *testing.T) {\n\t\t// No conflict: show base name only\n\t\tlabels := projectLabels([]string{\"/home/user/alpha\", \"/home/user/beta\"})\n\t\tassert.Equal(t, \"alpha\", labels[\"/home/user/alpha\"])\n\t\tassert.Equal(t, \"beta\", labels[\"/home/user/beta\"])\n\n\t\t// Conflict: two dirs share the same base name\n\t\tlabels = projectLabels([]string{\"/home/foo/bar\", \"/home/baz/bar\"})\n\t\tassert.Equal(t, \"foo/bar\", labels[\"/home/foo/bar\"])\n\t\tassert.Equal(t, \"baz/bar\", labels[\"/home/baz/bar\"])\n\n\t\t// Mixed: some conflict, some don't\n\t\tlabels = projectLabels([]string{\"/a/bar\", \"/b/bar\", \"/c/unique\"})\n\t\tassert.Equal(t, \"a/bar\", labels[\"/a/bar\"])\n\t\tassert.Equal(t, \"b/bar\", labels[\"/b/bar\"])\n\t\tassert.Equal(t, \"unique\", labels[\"/c/unique\"])\n\n\t\t// Empty list\n\t\tlabels = projectLabels(nil)\n\t\tassert.Empty(t, labels)\n\t})\n}\n\nfunc TestRunsList_ProjectFilter(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRunWithProject(t, store, \"run-a1\", \"develop\", domain.RunStateRunning, \"/home/user/alpha\")\n\tseedRunWithProject(t, store, \"run-a2\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n\tseedRunWithProject(t, store, \"run-b1\", \"deploy\", domain.RunStateRunning, \"/home/user/beta\")\n\n\t// Without filter: all runs shown\n\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody := w.Body.String()\n\tassert.Contains(t, body, \"run-a1\")\n\tassert.Contains(t, body, \"run-b1\")\n\n\t// With project filter: only matching runs\n\treq = httptest.NewRequest(\"GET\", \"/runs?project=/home/user/alpha\", nil)\n\tw = httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody = w.Body.String()\n\tassert.Contains(t, body, \"run-a1\")\n\tassert.Contains(t, body, \"run-a2\")\n\tassert.NotContains(t, body, \"run-b1\")\n}\n\nfunc TestRunsList_ProjectColumn(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRunWithProject(t, store, \"run-p1\", \"develop\", domain.RunStateRunning, \"/home/user/myproject\")\n\n\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody := w.Body.String()\n\tassert.Contains(t, body, \"myproject\")\n\tassert.Contains(t, body, \"Project\")\n}\n\nfunc TestAPIRuns_ProjectFilter(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRunWithProject(t, store, \"api-a1\", \"develop\", domain.RunStateRunning, \"/home/user/alpha\")\n\tseedRunWithProject(t, store, \"api-b1\", \"deploy\", domain.RunStateRunning, \"/home/user/beta\")\n\n\t// Without filter: all runs\n\treq := httptest.NewRequest(\"GET\", \"/api/runs\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\tassert.Equal(t, http.StatusOK, w.Code)\n\n\tvar allRuns []apiRun\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &allRuns))\n\tassert.Len(t, allRuns, 2)\n\n\t// With filter: only matching\n\treq = httptest.NewRequest(\"GET\", \"/api/runs?project=/home/user/alpha\", nil)\n\tw = httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\tassert.Equal(t, http.StatusOK, w.Code)\n\n\tvar filtered []apiRun\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &filtered))\n\tassert.Len(t, filtered, 1)\n\tassert.Equal(t, \"api-a1\", filtered[0].ID)\n\tassert.Equal(t, \"/home/user/alpha\", filtered[0].ProjectDir)\n\tassert.Equal(t, \"alpha\", filtered[0].ProjectLabel)\n}\n\nfunc setupHandlerWithContainerManager(t *testing.T) (*Handler, *sqlite.Store, *mockContainerManager) {\n\tt.Helper()\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tt.Cleanup(func() { store.Close() })\n\n\tmgr := newMockContainerManager()\n\th, err := NewHandler(store, store, WithContainerManager(mgr))\n\trequire.NoError(t, err)\n\treturn h, store, mgr\n}\n\nfunc seedRunWithContainer(t *testing.T, store *sqlite.Store, mgr *mockContainerManager, id, workflow, projectDir, containerID string, kept bool) {\n\tt.Helper()\n\tctx := context.Background()\n\trun := domain.NewRun(id, workflow)\n\trun.ProjectDir = projectDir\n\trun.Start()\n\trun.ContainerID = containerID\n\trun.ContainerKept = kept\n\trun.Complete(domain.RunStateSucceeded)\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\tif kept {\n\t\tmgr.containers[containerID] = true\n\t}\n}\n\nfunc TestRunDetail_ContainerRunning(t *testing.T) {\n\th, store, mgr := setupHandlerWithContainerManager(t)\n\n\tctx := context.Background()\n\trun := domain.NewRun(\"run-cr\", \"develop\")\n\trun.ProjectDir = \"/proj\"\n\trun.Start()\n\trun.ContainerID = \"cid-running\"\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\tmgr.containers[\"cid-running\"] = true\n\tmgr.running[\"cid-running\"] = true\n\n\treq := httptest.NewRequest(\"GET\", \"/runs/run-cr\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody := w.Body.String()\n\tassert.Contains(t, body, \"Container running\")\n\tassert.Contains(t, body, `badge-running\">Container running`)\n}\n\nfunc TestRunDetail_ContainerStopped(t *testing.T) {\n\th, store, mgr := setupHandlerWithContainerManager(t)\n\n\tctx := context.Background()\n\trun := domain.NewRun(\"run-cs\", \"develop\")\n\trun.ProjectDir = \"/proj\"\n\trun.Start()\n\trun.ContainerID = \"cid-stopped\"\n\trun.ContainerKept = false\n\trun.Complete(domain.RunStateSucceeded)\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\tmgr.containers[\"cid-stopped\"] = true // container exists but not running, not kept\n\n\treq := httptest.NewRequest(\"GET\", \"/runs/run-cs\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody := w.Body.String()\n\tassert.Contains(t, body, \"Container stopped\")\n\tassert.Contains(t, body, `badge-stopped\">Container stopped`)\n}\n\nfunc TestRunDetail_ContainerAvailable(t *testing.T) {\n\th, store, mgr := setupHandlerWithContainerManager(t)\n\tseedRunWithContainer(t, store, mgr, \"run-c1\", \"develop\", \"/proj\", \"cid-1234567890ab\", true)\n\n\treq := httptest.NewRequest(\"GET\", \"/runs/run-c1\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody := w.Body.String()\n\tassert.Contains(t, body, \"Container available\")\n\tassert.Contains(t, body, `badge-succeeded\">Container available`)\n\tassert.Contains(t, body, `id=\"delete-container-btn\"`)\n}\n\nfunc TestRunDetail_ContainerRemoved(t *testing.T) {\n\th, store, _ := setupHandlerWithContainerManager(t)\n\n\tctx := context.Background()\n\trun := domain.NewRun(\"run-c2\", \"develop\")\n\trun.ProjectDir = \"/proj\"\n\trun.Start()\n\trun.ContainerID = \"cid-gone\"\n\trun.ContainerKept = false\n\trun.Complete(domain.RunStateSucceeded)\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\t// container NOT in mock's containers map → Inspect will fail → \"removed\"\n\n\treq := httptest.NewRequest(\"GET\", \"/runs/run-c2\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody := w.Body.String()\n\tassert.Contains(t, body, \"Container removed\")\n\tassert.Contains(t, body, `badge-pending\">Container removed`)\n}\n\nfunc TestAPIDeleteContainer_Success(t *testing.T) {\n\th, store, mgr := setupHandlerWithContainerManager(t)\n\tseedRunWithContainer(t, store, mgr, \"run-del1\", \"develop\", \"/proj\", \"cid-to-delete\", true)\n\n\treq := httptest.NewRequest(\"DELETE\", \"/api/runs/run-del1/container\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\n\tvar resp map[string]string\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &resp))\n\tassert.Equal(t, \"ok\", resp[\"status\"])\n\n\t// Verify container was removed\n\tassert.Contains(t, mgr.removed, \"cid-to-delete\")\n\n\t// Verify run was updated\n\trun, err := store.GetRun(context.Background(), \"run-del1\")\n\trequire.NoError(t, err)\n\tassert.False(t, run.ContainerKept)\n}\n\nfunc TestAPIDeleteContainer_RunNotFound(t *testing.T) {\n\th, _, _ := setupHandlerWithContainerManager(t)\n\n\treq := httptest.NewRequest(\"DELETE\", \"/api/runs/nonexistent/container\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusNotFound, w.Code)\n}\n\nfunc TestAPIDeleteContainer_NoManager(t *testing.T) {\n\th, store := setupHandler(t) // no container manager\n\tseedRun(t, store, \"run-noman\", \"develop\", domain.RunStateSucceeded)\n\n\treq := httptest.NewRequest(\"DELETE\", \"/api/runs/run-noman/container\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusBadRequest, w.Code)\n}\n\nfunc TestAPIRunDetail_ContainerState(t *testing.T) {\n\th, store, mgr := setupHandlerWithContainerManager(t)\n\n\t// Seed a running container\n\tctx := context.Background()\n\trun := domain.NewRun(\"api-cs1\", \"develop\")\n\trun.ProjectDir = \"/proj\"\n\trun.Start()\n\trun.ContainerID = \"cid-api-running\"\n\trequire.NoError(t, store.CreateRun(ctx, run))\n\tmgr.containers[\"cid-api-running\"] = true\n\tmgr.running[\"cid-api-running\"] = true\n\n\treq := httptest.NewRequest(\"GET\", \"/api/runs/api-cs1\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\n\tvar detail apiRunDetail\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &detail))\n\tassert.Equal(t, \"running\", detail.ContainerState)\n\n\t// Now stop it\n\tmgr.running[\"cid-api-running\"] = false\n\n\tw = httptest.NewRecorder()\n\th.ServeHTTP(w, httptest.NewRequest(\"GET\", \"/api/runs/api-cs1\", nil))\n\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &detail))\n\tassert.Equal(t, \"stopped\", detail.ContainerState)\n}\n\nfunc TestRunsList_ContainerCount(t *testing.T) {\n\th, store, mgr := setupHandlerWithContainerManager(t)\n\tseedRunWithContainer(t, store, mgr, \"run-cc1\", \"develop\", \"/home/user/alpha\", \"cid-1\", true)\n\tseedRunWithContainer(t, store, mgr, \"run-cc2\", \"develop\", \"/home/user/alpha\", \"cid-2\", true)\n\tseedRunWithContainer(t, store, mgr, \"run-cc3\", \"deploy\", \"/home/user/beta\", \"cid-3\", false)\n\n\treq := httptest.NewRequest(\"GET\", \"/runs\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody := w.Body.String()\n\t// alpha has 2 retained containers\n\tassert.Contains(t, body, \"2 containers\")\n\t// beta has 0, so no count should appear\n\tassert.NotContains(t, body, \"0 container\")\n}\n\nfunc TestAPIProjects(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRunWithProject(t, store, \"p1\", \"develop\", domain.RunStateRunning, \"/home/user/alpha\")\n\tseedRunWithProject(t, store, \"p2\", \"develop\", domain.RunStateRunning, \"/home/user/beta\")\n\tseedRunWithProject(t, store, \"p3\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n\n\treq := httptest.NewRequest(\"GET\", \"/api/projects\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\tassert.Equal(t, http.StatusOK, w.Code)\n\n\ttype apiHealth struct {\n\t\tStatus string `json:\"status\"`\n\t\tPassed int    `json:\"passed\"`\n\t\tFailed int    `json:\"failed\"`\n\t\tTotal  int    `json:\"total\"`\n\t}\n\ttype project struct {\n\t\tDir         string    `json:\"dir\"`\n\t\tLabel       string    `json:\"label\"`\n\t\tHealth      apiHealth `json:\"health\"`\n\t\tActiveCount int       `json:\"active_count\"`\n\t}\n\tvar projects []project\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &projects))\n\tassert.Len(t, projects, 2)\n\n\tbyDir := map[string]project{}\n\tfor _, p := range projects {\n\t\tbyDir[p.Dir] = p\n\t}\n\tassert.Equal(t, \"alpha\", byDir[\"/home/user/alpha\"].Label)\n\tassert.Equal(t, \"beta\", byDir[\"/home/user/beta\"].Label)\n\t// alpha has 1 running + 1 succeeded = yellow health (mix), 1 active\n\tassert.Equal(t, 1, byDir[\"/home/user/alpha\"].ActiveCount)\n\tassert.NotEmpty(t, byDir[\"/home/user/alpha\"].Health.Status)\n\t// beta has 1 running = blue (all in-progress), 1 active\n\tassert.Equal(t, \"blue\", byDir[\"/home/user/beta\"].Health.Status)\n\tassert.Equal(t, 1, byDir[\"/home/user/beta\"].ActiveCount)\n}\n\nfunc TestProjectOverview_WithProjects(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRunWithProject(t, store, \"ov-1\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n\tseedRunWithProject(t, store, \"ov-2\", \"develop\", domain.RunStateFailed, \"/home/user/alpha\")\n\tseedRunWithProject(t, store, \"ov-3\", \"develop\", domain.RunStateRunning, \"/home/user/beta\")\n\n\treq := httptest.NewRequest(\"GET\", \"/\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tassert.Contains(t, w.Header().Get(\"Content-Type\"), \"text/html\")\n\tbody := w.Body.String()\n\t// Project cards should be present\n\tassert.Contains(t, body, \"project-card\")\n\tassert.Contains(t, body, \"alpha\")\n\tassert.Contains(t, body, \"beta\")\n\t// Health dots\n\tassert.Contains(t, body, \"health-dot\")\n\t// Run history dots\n\tassert.Contains(t, body, \"run-dot\")\n\t// Quick actions\n\tassert.Contains(t, body, \"View Runs\")\n\tassert.Contains(t, body, \"Trigger Orchestrator\")\n}\n\nfunc TestProjectOverview_Empty(t *testing.T) {\n\th, _ := setupHandler(t)\n\n\treq := httptest.NewRequest(\"GET\", \"/\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tassert.Contains(t, w.Body.String(), \"No projects yet\")\n}\n\nfunc TestAPITriggerOrchestrator_NoOrchestrator(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRunWithProject(t, store, \"orch-1\", \"develop\", domain.RunStateSucceeded, \"/home/user/myproject\")\n\n\treq := httptest.NewRequest(\"POST\", \"/api/projects/myproject/trigger\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusNotImplemented, w.Code)\n\tassert.Contains(t, w.Header().Get(\"Content-Type\"), \"application/json\")\n\n\tvar result map[string]string\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &result))\n\tassert.Equal(t, \"orchestrator not configured\", result[\"error\"])\n}\n\nfunc TestAPITriggerOrchestrator_Success(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tt.Cleanup(func() { store.Close() })\n\n\th, err := NewHandler(store, store, WithOrchestrateFunc(func(ctx context.Context, projectDir string) (int, error) {\n\t\tassert.Equal(t, \"/home/user/myproject\", projectDir)\n\t\treturn 3, nil\n\t}))\n\trequire.NoError(t, err)\n\n\tseedRunWithProject(t, store, \"orch-2\", \"develop\", domain.RunStateSucceeded, \"/home/user/myproject\")\n\n\treq := httptest.NewRequest(\"POST\", \"/api/projects/myproject/trigger\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tassert.Contains(t, w.Header().Get(\"Content-Type\"), \"application/json\")\n\n\tvar result map[string]any\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &result))\n\tassert.Equal(t, \"ok\", result[\"status\"])\n\tassert.Equal(t, \"myproject\", result[\"project\"])\n\tassert.Equal(t, float64(3), result[\"dispatched\"])\n}\n\nfunc TestAPITriggerOrchestrator_ProjectNotFound(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tt.Cleanup(func() { store.Close() })\n\n\th, err := NewHandler(store, store, WithOrchestrateFunc(func(ctx context.Context, projectDir string) (int, error) {\n\t\treturn 0, nil\n\t}))\n\trequire.NoError(t, err)\n\n\treq := httptest.NewRequest(\"POST\", \"/api/projects/nonexistent/trigger\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusNotFound, w.Code)\n\n\tvar result map[string]string\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &result))\n\tassert.Equal(t, \"project not found\", result[\"error\"])\n}\n\nfunc TestAPITriggerOrchestrator_Error(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tt.Cleanup(func() { store.Close() })\n\n\th, err := NewHandler(store, store, WithOrchestrateFunc(func(ctx context.Context, projectDir string) (int, error) {\n\t\treturn 0, fmt.Errorf(\"orchestration failed\")\n\t}))\n\trequire.NoError(t, err)\n\n\tseedRunWithProject(t, store, \"orch-3\", \"develop\", domain.RunStateSucceeded, \"/home/user/errproject\")\n\n\treq := httptest.NewRequest(\"POST\", \"/api/projects/errproject/trigger\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusInternalServerError, w.Code)\n\n\tvar result map[string]string\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &result))\n\tassert.Equal(t, \"orchestration failed\", result[\"error\"])\n}\n\nfunc TestHealthColor(t *testing.T) {\n\tassert.Equal(t, \"green\", healthColor(domain.HealthGreen))\n\tassert.Equal(t, \"yellow\", healthColor(domain.HealthYellow))\n\tassert.Equal(t, \"red\", healthColor(domain.HealthRed))\n\tassert.Equal(t, \"blue\", healthColor(domain.HealthBlue))\n\tassert.Equal(t, \"grey\", healthColor(domain.HealthGrey))\n\tassert.Equal(t, \"grey\", healthColor(\"unknown\"))\n}\n\nfunc TestAPIProjects_HealthData(t *testing.T) {\n\th, store := setupHandler(t)\n\t// alpha: 3 succeeded, 1 failed → yellow\n\tseedRunWithProject(t, store, \"h1\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n\tseedRunWithProject(t, store, \"h2\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n\tseedRunWithProject(t, store, \"h3\", \"develop\", domain.RunStateFailed, \"/home/user/alpha\")\n\tseedRunWithProject(t, store, \"h4\", \"develop\", domain.RunStateSucceeded, \"/home/user/alpha\")\n\n\t// beta: all succeeded → green\n\tseedRunWithProject(t, store, \"h5\", \"develop\", domain.RunStateSucceeded, \"/home/user/beta\")\n\tseedRunWithProject(t, store, \"h6\", \"develop\", domain.RunStateSucceeded, \"/home/user/beta\")\n\n\treq := httptest.NewRequest(\"GET\", \"/api/projects\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\tassert.Equal(t, http.StatusOK, w.Code)\n\n\ttype health struct {\n\t\tStatus string `json:\"status\"`\n\t\tPassed int    `json:\"passed\"`\n\t\tFailed int    `json:\"failed\"`\n\t\tTotal  int    `json:\"total\"`\n\t}\n\ttype project struct {\n\t\tDir    string `json:\"dir\"`\n\t\tLabel  string `json:\"label\"`\n\t\tHealth health `json:\"health\"`\n\t}\n\tvar projects []project\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &projects))\n\tassert.Len(t, projects, 2)\n\n\tbyDir := map[string]project{}\n\tfor _, p := range projects {\n\t\tbyDir[p.Dir] = p\n\t}\n\n\talpha := byDir[\"/home/user/alpha\"]\n\tassert.Equal(t, \"yellow\", alpha.Health.Status)\n\tassert.Equal(t, 3, alpha.Health.Passed)\n\tassert.Equal(t, 1, alpha.Health.Failed)\n\tassert.Equal(t, 4, alpha.Health.Total)\n\n\tbeta := byDir[\"/home/user/beta\"]\n\tassert.Equal(t, \"green\", beta.Health.Status)\n\tassert.Equal(t, 2, beta.Health.Passed)\n\tassert.Equal(t, 0, beta.Health.Failed)\n\tassert.Equal(t, 2, beta.Health.Total)\n}\n\nfunc TestAPIProjects_HealthNoRuns(t *testing.T) {\n\th, _ := setupHandler(t)\n\n\treq := httptest.NewRequest(\"GET\", \"/api/projects\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\tassert.Equal(t, http.StatusOK, w.Code)\n\n\t// No projects means empty array\n\ttype project struct {\n\t\tDir   string `json:\"dir\"`\n\t\tLabel string `json:\"label\"`\n\t}\n\tvar projects []project\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &projects))\n\tassert.Empty(t, projects)\n}\n\n// --- Project detail page tests ---\n\n// mockOrchestratorController implements OrchestratorController for testing.\ntype mockOrchestratorController struct {\n\tenabled     bool\n\tinFlight    int\n\tconcurrency int\n\tsetEnabled  *bool\n\tsetConcurrency *int\n}\n\nfunc (m *mockOrchestratorController) Status(dir string) (bool, int, int) {\n\treturn m.enabled, m.inFlight, m.concurrency\n}\n\nfunc (m *mockOrchestratorController) SetEnabled(dir string, enabled bool) {\n\tm.setEnabled = &enabled\n\tm.enabled = enabled\n}\n\nfunc (m *mockOrchestratorController) SetConcurrency(dir string, concurrency int) {\n\tm.setConcurrency = &concurrency\n\tm.concurrency = concurrency\n}\n\nfunc TestProjectDetail_HTML(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRunWithProject(t, store, \"pd-1\", \"develop\", domain.RunStateSucceeded, \"/home/user/myproject\")\n\tseedRunWithProject(t, store, \"pd-2\", \"develop\", domain.RunStateRunning, \"/home/user/myproject\")\n\n\treq := httptest.NewRequest(\"GET\", \"/projects/myproject\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tassert.Contains(t, w.Header().Get(\"Content-Type\"), \"text/html\")\n\tbody := w.Body.String()\n\tassert.Contains(t, body, \"myproject\")\n\tassert.Contains(t, body, \"orchestrator-panel\")\n\tassert.Contains(t, body, \"info-panel\")\n\tassert.Contains(t, body, \"workflow-panel\")\n}\n\nfunc TestProjectDetail_NotFound(t *testing.T) {\n\th, _ := setupHandler(t)\n\n\treq := httptest.NewRequest(\"GET\", \"/projects/nonexistent\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusNotFound, w.Code)\n}\n\nfunc TestAPIOrchestratorStatus(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tt.Cleanup(func() { store.Close() })\n\n\tmock := &mockOrchestratorController{enabled: true, inFlight: 1, concurrency: 3}\n\th, err := NewHandler(store, store, WithOrchestrator(mock))\n\trequire.NoError(t, err)\n\n\tseedRunWithProject(t, store, \"os-1\", \"develop\", domain.RunStateSucceeded, \"/home/user/myproject\")\n\n\treq := httptest.NewRequest(\"GET\", \"/api/projects/myproject/orchestrator\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tvar result map[string]any\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &result))\n\tassert.Equal(t, true, result[\"enabled\"])\n\tassert.Equal(t, float64(1), result[\"in_flight\"])\n\tassert.Equal(t, float64(3), result[\"concurrency\"])\n}\n\nfunc TestAPIOrchestratorStatus_NoOrchestrator(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRunWithProject(t, store, \"os-2\", \"develop\", domain.RunStateSucceeded, \"/home/user/myproject\")\n\n\treq := httptest.NewRequest(\"GET\", \"/api/projects/myproject/orchestrator\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tvar result map[string]any\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &result))\n\tassert.Equal(t, false, result[\"enabled\"])\n}\n\nfunc TestAPIOrchestratorStartStop(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tt.Cleanup(func() { store.Close() })\n\n\tmock := &mockOrchestratorController{enabled: false, concurrency: 1}\n\th, err := NewHandler(store, store, WithOrchestrator(mock))\n\trequire.NoError(t, err)\n\n\tseedRunWithProject(t, store, \"ss-1\", \"develop\", domain.RunStateSucceeded, \"/home/user/myproject\")\n\n\t// Start\n\treq := httptest.NewRequest(\"POST\", \"/api/projects/myproject/orchestrator/start\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\tassert.Equal(t, http.StatusOK, w.Code)\n\trequire.NotNil(t, mock.setEnabled)\n\tassert.True(t, *mock.setEnabled)\n\n\t// Stop\n\treq = httptest.NewRequest(\"POST\", \"/api/projects/myproject/orchestrator/stop\", nil)\n\tw = httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tassert.False(t, *mock.setEnabled)\n}\n\nfunc TestAPIOrchestratorStartStop_NoOrchestrator(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRunWithProject(t, store, \"ss-2\", \"develop\", domain.RunStateSucceeded, \"/home/user/myproject\")\n\n\treq := httptest.NewRequest(\"POST\", \"/api/projects/myproject/orchestrator/start\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\tassert.Equal(t, http.StatusNotImplemented, w.Code)\n}\n\nfunc TestAPIOrchestratorConcurrency(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tt.Cleanup(func() { store.Close() })\n\n\tmock := &mockOrchestratorController{enabled: true, concurrency: 1}\n\th, err := NewHandler(store, store, WithOrchestrator(mock))\n\trequire.NoError(t, err)\n\n\tseedRunWithProject(t, store, \"cc-1\", \"develop\", domain.RunStateSucceeded, \"/home/user/myproject\")\n\n\treq := httptest.NewRequest(\"POST\", \"/api/projects/myproject/orchestrator/concurrency\",\n\t\tstrings.NewReader(`{\"concurrency\": 5}`))\n\treq.Header.Set(\"Content-Type\", \"application/json\")\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\trequire.NotNil(t, mock.setConcurrency)\n\tassert.Equal(t, 5, *mock.setConcurrency)\n}\n\nfunc TestAPIOrchestratorConcurrency_Invalid(t *testing.T) {\n\tstore, err := sqlite.NewStore(\":memory:\")\n\trequire.NoError(t, err)\n\tt.Cleanup(func() { store.Close() })\n\n\tmock := &mockOrchestratorController{enabled: true, concurrency: 1}\n\th, err := NewHandler(store, store, WithOrchestrator(mock))\n\trequire.NoError(t, err)\n\n\tseedRunWithProject(t, store, \"cc-2\", \"develop\", domain.RunStateSucceeded, \"/home/user/myproject\")\n\n\treq := httptest.NewRequest(\"POST\", \"/api/projects/myproject/orchestrator/concurrency\",\n\t\tstrings.NewReader(`{\"concurrency\": 0}`))\n\treq.Header.Set(\"Content-Type\", \"application/json\")\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusBadRequest, w.Code)\n}\n\nfunc TestAPIProjectInfo(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRunWithProject(t, store, \"pi-1\", \"develop\", domain.RunStateSucceeded, \"/home/user/myproject\")\n\n\treq := httptest.NewRequest(\"GET\", \"/api/projects/myproject/info\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tvar result map[string]any\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &result))\n\t// Project dir won't have .cloche files, so expect empty/zero values\n\tassert.Equal(t, \"\", result[\"docker_image\"])\n\tassert.Equal(t, float64(0), result[\"version\"])\n}\n\nfunc TestAPIWorkflows_NoWorkflows(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRunWithProject(t, store, \"wf-1\", \"develop\", domain.RunStateSucceeded, \"/home/user/myproject\")\n\n\treq := httptest.NewRequest(\"GET\", \"/api/projects/myproject/workflows\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tvar result []any\n\trequire.NoError(t, json.Unmarshal(w.Body.Bytes(), &result))\n\tassert.Empty(t, result)\n}\n\nfunc TestAPIStepContent_WorkflowNotFound(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRunWithProject(t, store, \"sc-1\", \"develop\", domain.RunStateSucceeded, \"/home/user/myproject\")\n\n\treq := httptest.NewRequest(\"GET\", \"/api/projects/myproject/workflows/develop/steps/implement/content\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusNotFound, w.Code)\n}\n\nfunc TestProjectsPage_HasProjectLinks(t *testing.T) {\n\th, store := setupHandler(t)\n\tseedRunWithProject(t, store, \"pl-1\", \"develop\", domain.RunStateSucceeded, \"/home/user/myproject\")\n\n\treq := httptest.NewRequest(\"GET\", \"/\", nil)\n\tw := httptest.NewRecorder()\n\th.ServeHTTP(w, req)\n\n\tassert.Equal(t, http.StatusOK, w.Code)\n\tbody := w.Body.String()\n\tassert.Contains(t, body, `href=\"/projects/myproject\"`)\n}\n","numLines":1008,"startLine":1,"totalLines":1008}}}
