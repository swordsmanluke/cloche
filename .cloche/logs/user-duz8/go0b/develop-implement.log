{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01R29WBao1j3i2bcYEeGmTyj","type":"tool_result","content":"     1→package config\n     2→\n     3→import (\n     4→\t\"os\"\n     5→\t\"path/filepath\"\n     6→\t\"testing\"\n     7→\n     8→\t\"github.com/stretchr/testify/assert\"\n     9→\t\"github.com/stretchr/testify/require\"\n    10→)\n    11→\n    12→func TestLoadEvolutionConfig(t *testing.T) {\n    13→\tdir := t.TempDir()\n    14→\tclocheDir := filepath.Join(dir, \".cloche\")\n    15→\tos.MkdirAll(clocheDir, 0755)\n    16→\n    17→\tos.WriteFile(filepath.Join(clocheDir, \"config.toml\"), []byte(`\n    18→[evolution]\n    19→enabled = true\n    20→debounce_seconds = 45\n    21→min_confidence = \"high\"\n    22→max_prompt_bullets = 30\n    23→`), 0644)\n    24→\n    25→\tcfg, err := Load(dir)\n    26→\trequire.NoError(t, err)\n    27→\tassert.True(t, cfg.Evolution.Enabled)\n    28→\tassert.Equal(t, 45, cfg.Evolution.DebounceSeconds)\n    29→\tassert.Equal(t, \"high\", cfg.Evolution.MinConfidence)\n    30→\tassert.Equal(t, 30, cfg.Evolution.MaxPromptBullets)\n    31→}\n    32→\n    33→func TestLoadEvolutionConfigDefaults(t *testing.T) {\n    34→\tdir := t.TempDir()\n    35→\n    36→\tcfg, err := Load(dir)\n    37→\trequire.NoError(t, err)\n    38→\tassert.True(t, cfg.Evolution.Enabled)\n    39→\tassert.Equal(t, 30, cfg.Evolution.DebounceSeconds)\n    40→\tassert.Equal(t, \"medium\", cfg.Evolution.MinConfidence)\n    41→\tassert.Equal(t, 50, cfg.Evolution.MaxPromptBullets)\n    42→}\n    43→\n    44→func TestLoadDaemonConfig(t *testing.T) {\n    45→\tdir := t.TempDir()\n    46→\tclocheDir := filepath.Join(dir, \".cloche\")\n    47→\tos.MkdirAll(clocheDir, 0755)\n    48→\n    49→\tos.WriteFile(filepath.Join(clocheDir, \"config.toml\"), []byte(`\n    50→[daemon]\n    51→listen = \"localhost:9090\"\n    52→http = \"localhost:8080\"\n    53→image = \"my-agent:v2\"\n    54→db = \"/var/lib/cloche/data.db\"\n    55→runtime = \"local\"\n    56→agent