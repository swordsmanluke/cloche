{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XDYuCvC5hFFVXUJFpcCDuJ","type":"tool_result","content":"     1→package config\n     2→\n     3→import (\n     4→\t\"fmt\"\n     5→\t\"os\"\n     6→\t\"path/filepath\"\n     7→\t\"strconv\"\n     8→\t\"strings\"\n     9→\n    10→\t\"github.com/BurntSushi/toml\"\n    11→)\n    12→\n    13→type DaemonConfig struct {\n    14→\tListen     string `toml:\"listen\"`\n    15→\tHTTP       string `toml:\"http\"`\n    16→\tImage      string `toml:\"image\"`\n    17→\tDB         string `toml:\"db\"`\n    18→\tRuntime    string `toml:\"runtime\"`\n    19→\tAgentPath  string `toml:\"agent_path\"`\n    20→\tLLMCommand string `toml:\"llm_command\"`\n    21→}\n    22→\n    23→type EvolutionConfig struct {\n    24→\tEnabled          bool   `toml:\"enabled\"`\n    25→\tDebounceSeconds  int    `toml:\"debounce_seconds\"`\n    26→\tMinConfidence    string `toml:\"min_confidence\"`\n    27→\tMaxPromptBullets int    `toml:\"max_prompt_bullets\"`\n    28→}\n    29→\n    30→type OrchestrationConfig struct {\n    31→\tEnabled     bool   `toml:\"enabled\"`\n    32→\tTracker     string `toml:\"tracker\"`\n    33→\tConcurrency int    `toml:\"concurrency\"`\n    34→\tWorkflow    string `toml:\"workflow\"`\n    35→}\n    36→\n    37→type Config struct {\n    38→\tDaemon        DaemonConfig        `toml:\"daemon\"`\n    39→\tEvolution     EvolutionConfig     `toml:\"evolution\"`\n    40→\tOrchestration OrchestrationConfig `toml:\"orchestration\"`\n    41→}\n    42→\n    43→func defaults() Config {\n    44→\treturn Config{\n    45→\t\tEvolution: EvolutionConfig{\n    46→\t\t\tEnabled:          true,\n    47→\t\t\tDebounceSeconds:  30,\n    48→\t\t\tMinConfidence:    \"medium\",\n    49→\t\t\tMaxPromptBullets: 50,\n    50→\t\t},\n    51→\t\tOrchestration: OrchestrationConfig{\n    52→\t\t\tTracker:     \"beads\",\n    53→\t\t\tConcurrency: 1,\n    54→\t\t\tWorkflow:     \"develop\",\n    55→\t\t},\n    56→\t}\n    57→}\n    58→\n    59→// Load reads a per-project config from <projectDir>/.cloche/config.toml.\n    60→func Load(projectDir string) (*Config, error) {\n    61→\tcfg := defaults()\n    62→\tpath := filepath.Join(projectDir, \".cloche\", \"config.toml\")\n    63→\n    64→\tdata, err := os.ReadFile(path)\n    65→\tif os.IsNotExist(err) {\n    66→\t\treturn &cfg, nil\n    67→\t}\n    68→\tif err != nil {\n    69→\t\treturn nil, err\n    70→\t}\n    71→\n    72→\tif _, err := toml.Decode(string(data), &cfg); err != nil {\n    73→\t\treturn nil, err\n    74→\t}\n    75→\treturn &cfg, nil\n    76→}\n    77→\n    78→// LoadGlobal reads the global daemon config from ~/.config/cloche/config.\n    79→// Returns defaults if the file does not exist.\n    80→func LoadGlobal() (*Config, error) {\n    81→\tcfg := defaults()\n    82→\n    83→\thome, err := os.UserHomeDir()\n    84→\tif err != nil {\n    85→\t\treturn &cfg, nil\n    86→\t}\n    87→\n    88→\tpath := filepath.Join(home, \".config\", \"cloche\", \"config\")\n    89→\tdata, err := os.ReadFile(path)\n    90→\tif os.IsNotExist(err) {\n    91→\t\treturn &cfg, nil\n    92→\t}\n    93→\tif err != nil {\n    94→\t\treturn nil, err\n    95→\t}\n    96→\n    97→\tif _, err := toml.Decode(string(data), &cfg); err != nil {\n    98→\t\treturn nil, err\n    99→\t}\n   100→\treturn &cfg, nil\n   101→}\n   102→\n   103→// LoadVersion reads the project version from <projectDir>/.cloche/version.\n   104→// Returns 1 if the file does not exist.\n   105→func LoadVersion(projectDir string) (int, error) {\n   106→\tpath := filepath.Join(projectDir, \".cloche\", \"version\")\n   107→\tdata, err := os.ReadFile(path)\n   108→\tif os.IsNotExist(err) {\n   109→\t\treturn 1, nil\n   110→\t}\n   111→\tif err != nil {\n   112→\t\treturn 0, err\n   113→\t}\n   114→\tv, err := strconv.Atoi(strings.TrimSpace(string(data)))\n   115→\tif err != nil {\n   116→\t\treturn 0, fmt.Errorf(\"invalid version file: %w\", err)\n   117→\t}\n   118→\treturn v, nil\n   119→}\n   120→\n   121→// IncrementProjectVersion atomically increments the integer in .cloche/version.\n   122→// If the file does not exist, it writes 2 (treating missing as implicit version 1).\n   123→func IncrementProjectVersion(projectDir string) error {\n   124→\tdir := filepath.Join(projectDir, \".cloche\")\n   125→\tpath := filepath.Join(dir, \"version\")\n   126→\n   127→\tcurrent := 1\n   128→\tif data, err := os.ReadFile(path); err == nil {\n   129→\t\tif v, err := strconv.Atoi(strings.TrimSpace(string(data))); err == nil {\n   130→\t\t\tcurrent = v\n   131→\t\t}\n   132→\t}\n   133→\n   134→\tnext := current + 1\n   135→\ttmp := path + \".tmp\"\n   136→\tif err := os.WriteFile(tmp, []byte(fmt.Sprintf(\"%d\\n\", next)), 0644); err != nil {\n   137→\t\treturn err\n   138→\t}\n   139→\treturn os.Rename(tmp, path)\n   140→}\n   141→\n   142→// LoadGlobalFrom reads the global config from a specific path.\n   143→// Useful for testing.\n   144→func LoadGlobalFrom(path string) (*Config, error) {\n   145→\tcfg := defaults()\n   146→\n   147→\tdata, err := os.ReadFile(path)\n   148→\tif os.IsNotExist(err) {\n   149→\t\treturn &cfg, nil\n   150→\t}\n   151→\tif err != nil {\n   152→\t\treturn nil, err\n   153→\t}\n   154→\n   155→\tif _, err := toml.Decode(string(data), &cfg); err != nil {\n   156→\t\treturn nil, err\n   157→\t}\n   158→\treturn &cfg, nil\n   159→}\n   160→"}]},"parent_tool_use_id":null,"session_id":"9a8be337-ad54-47e6-9bd9-fa6c30e55852","uuid":"336a3ed0-e11f-4a81-ab42-0f96a869e011","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/config/config.go","content":"package config\n\nimport (\n\t\"fmt\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"strconv\"\n\t\"strings\"\n\n\t\"github.com/BurntSushi/toml\"\n)\n\ntype DaemonConfig struct {\n\tListen     string `toml:\"listen\"`\n\tHTTP       string `toml:\"http\"`\n\tImage      string `toml:\"image\"`\n\tDB         string `toml:\"db\"`\n\tRuntime    string `toml:\"runtime\"`\n\tAgentPath  string `toml:\"agent_path\"`\n\tLLMCommand string `toml:\"llm_command\"`\n}\n\ntype EvolutionConfig struct {\n\tEnabled          bool   `toml:\"enabled\"`\n\tDebounceSeconds  int    `toml:\"debounce_seconds\"`\n\tMinConfidence    string `toml:\"min_confidence\"`\n\tMaxPromptBullets int    `toml:\"max_prompt_bullets\"`\n}\n\ntype OrchestrationConfig struct {\n\tEnabled     bool   `toml:\"enabled\"`\n\tTracker     string `toml:\"tracker\"`\n\tConcurrency int    `toml:\"concurrency\"`\n\tWorkflow    string `toml:\"workflow\"`\n}\n\ntype Config struct {\n\tDaemon        DaemonConfig        `toml:\"daemon\"`\n\tEvolution     EvolutionConfig     `toml:\"evolution\"`\n\tOrchestration OrchestrationConfig `toml:\"orchestration\"`\n}\n\nfunc defaults() Config {\n\treturn Config{\n\t\tEvolution: EvolutionConfig{\n\t\t\tEnabled:          true,\n\t\t\tDebounceSeconds:  30,\n\t\t\tMinConfidence:    \"medium\",\n\t\t\tMaxPromptBullets: 50,\n\t\t},\n\t\tOrchestration: OrchestrationConfig{\n\t\t\tTracker:     \"beads\",\n\t\t\tConcurrency: 1,\n\t\t\tWorkflow:     \"develop\",\n\t\t},\n\t}\n}\n\n// Load reads a per-project config from <projectDir>/.cloche/config.toml.\nfunc Load(projectDir string) (*Config, error) {\n\tcfg := defaults()\n\tpath := filepath.Join(projectDir, \".cloche\", \"config.toml\")\n\n\tdata, err := os.ReadFile(path)\n\tif os.IsNotExist(err) {\n\t\treturn &cfg, nil\n\t}\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tif _, err := toml.Decode(string(data), &cfg); err != nil {\n\t\treturn nil, err\n\t}\n\treturn &cfg, nil\n}\n\n// LoadGlobal reads the global daemon config from ~/.config/cloche/config.\n// Returns defaults if the file does not exist.\nfunc LoadGlobal() (*Config, error) {\n\tcfg := defaults()\n\n\thome, err := os.UserHomeDir()\n\tif err != nil {\n\t\treturn &cfg, nil\n\t}\n\n\tpath := filepath.Join(home, \".config\", \"cloche\", \"config\")\n\tdata, err := os.ReadFile(path)\n\tif os.IsNotExist(err) {\n\t\treturn &cfg, nil\n\t}\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tif _, err := toml.Decode(string(data), &cfg); err != nil {\n\t\treturn nil, err\n\t}\n\treturn &cfg, nil\n}\n\n// LoadVersion reads the project version from <projectDir>/.cloche/version.\n// Returns 1 if the file does not exist.\nfunc LoadVersion(projectDir string) (int, error) {\n\tpath := filepath.Join(projectDir, \".cloche\", \"version\")\n\tdata, err := os.ReadFile(path)\n\tif os.IsNotExist(err) {\n\t\treturn 1, nil\n\t}\n\tif err != nil {\n\t\treturn 0, err\n\t}\n\tv, err := strconv.Atoi(strings.TrimSpace(string(data)))\n\tif err != nil {\n\t\treturn 0, fmt.Errorf(\"invalid version file: %w\", err)\n\t}\n\treturn v, nil\n}\n\n// IncrementProjectVersion atomically increments the integer in .cloche/version.\n// If the file does not exist, it writes 2 (treating missing as implicit version 1).\nfunc IncrementProjectVersion(projectDir string) error {\n\tdir := filepath.Join(projectDir, \".cloche\")\n\tpath := filepath.Join(dir, \"version\")\n\n\tcurrent := 1\n\tif data, err := os.ReadFile(path); err == nil {\n\t\tif v, err := strconv.Atoi(strings.TrimSpace(string(data))); err == nil {\n\t\t\tcurrent = v\n\t\t}\n\t}\n\n\tnext := current + 1\n\ttmp := path + \".tmp\"\n\tif err := os.WriteFile(tmp, []byte(fmt.Sprintf(\"%d\\n\", next)), 0644); err != nil {\n\t\treturn err\n\t}\n\treturn os.Rename(tmp, path)\n}\n\n// LoadGlobalFrom reads the global config from a specific path.\n// Useful for testing.\nfunc LoadGlobalFrom(path string) (*Config, error) {\n\tcfg := defaults()\n\n\tdata, err := os.ReadFile(path)\n\tif os.IsNotExist(err) {\n\t\treturn &cfg, nil\n\t}\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tif _, err := toml.Decode(string(data), &cfg); err != nil {\n\t\treturn nil, err\n\t}\n\treturn &cfg, nil\n}\n","numLines":160,"startLine":1,"totalLines":160}}}
