gs []string) {\n   474→\tif len(args) < 1 {\n   475→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche delete <container-or-run-id>\\n\")\n   476→\t\tos.Exit(1)\n   477→\t}\n   478→\n   479→\t_, err := client.DeleteContainer(ctx, &pb.DeleteContainerRequest{Id: args[0]})\n   480→\tif err != nil {\n   481→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   482→\t\tos.Exit(1)\n   483→\t}\n   484→\tfmt.Printf(\"Deleted container: %s\\n\", args[0])\n   485→}\n   486→\n   487→func cmdLoop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   488→\tcwd, _ := os.Getwd()\n   489→\n   490→\t// Check for \"stop\" subcommand\n   491→\tif len(args) > 0 && args[0] == \"stop\" {\n   492→\t\t_, err := client.DisableLoop(ctx, &pb.DisableLoopRequest{ProjectDir: cwd})\n   493→\t\tif err != nil {\n   494→\t\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   495→\t\t\tos.Exit(1)\n   496→\t\t}\n   497→\t\tfmt.Println(\"Orchestration loop stopped.\")\n   498→\t\treturn\n   499→\t}\n   500→\n   501→\t// Check for \"resume\" subcommand\n   502→\tif len(args) > 0 && args[0] == \"resume\" {\n   503→\t\t_, err := client.ResumeLoop(ctx, &pb.ResumeLoopRequest{ProjectDir: cwd})\n   504→\t\tif err != nil {\n   505→\t\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   506→\t\t\tos.Exit(1)\n   507→\t\t}\n   508→\t\tfmt.Println(\"Orchestration loop resumed.\")\n   509→\t\treturn\n   510→\t}\n   511→\n   512→\t// Default: 0 means \"use config value\" (server reads .cloche/config.toml).\n   513→\tvar maxConcurrent int32\n   514→\tfor i := 0; i < len(args); i++ {\n   515→\t\tswitch args[i] {\n   516→\t\tcase \"--max\":\n   517→\t\t\tif i+1 < len(args) {\n   518→\t\t\t\ti++\n   519→\t\t\t\tn, err := fmt.Sscanf(args[i], \"%d\", &maxConcurrent)\n   520→\t\t\t\tif n != 1 || err != nil {\n   521→\t\t\t\t\tfmt.Fprintf(os.Stderr, \"invalid --max value: %s\\n\", args[i])\n   522→\t\t\t\t\tos.Exit(1)\n   523→\t\t\t\t}\n   524→\t\t\t}\n   525→\t\t}\n   526→\t}\n   527→\n   528→\t_, err := client.EnableLoop(ctx, &pb.EnableLoopRequest{\n   529→\t\tProjectDir:    cwd,\n   530→\t\tMaxConcurrent: maxConcurrent,\n   531→\t})\n   532→\tif err != nil {\n   533→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   534→\t\tos.Exit(1)\n   535→\t}\n   536→\tif maxConcurrent > 0 {\n   537→\t\tfmt.Printf(\"Orchestration loop started (max_concurrent=%d).\\n\", maxConcurrent)\n   538→\t} else {\n   539→\t\tfmt.Println(\"Orchestration loop started (using config defaults).\")\n   540→\t}\n   541→}\n   542→\n   543→func cmdTasks(args []string) {\n   544→\t// Determine HTTP address from env\n   545→\thttpAddr := os.Getenv(\"CLOCHE_HTTP\")\n   546→\tif httpAddr == \"\" {\n   547→\t\thttpAddr = \"localhost:8080\"\n   548→\t}\n   549→\thttpAddr = strings.TrimPrefix(httpAddr, \"http://\")\n   550→\n   551→\t// Determine project label from --project flag or current directory\n   552→\tprojectDir := \"\"\n   553→\tfor i := 0; i < len(args); i++ {\n   554→\t\tswitch args[i] {\n   555→\t\tcase \"--project\":\n   556→\t\t\tif i+1 < len(args) {\n   557→\t\t\t\ti++\n   558→\t\t\t\tprojectDir = args[i]\n   559→\t\t\t}\n   560→\t\t}\n   561→\t}\n   562→\n   563→\tif projectDir == \"\" {\n   564→\t\tcwd, _ := os.Getwd()\n   565→\t\tprojectDir = filepath.Base(cwd)\n   566→\t}\n   567→\n   568→\ttasksURL := fmt.Sprintf(\"http://%s/api/projects/%s/tasks\", httpAddr, projectDir)\n   569→\tresp, err := http.Get(tasksURL)\n   570→\tif err != nil {\n   571→\t\tfmt.Fprintf(os.Stderr, \"error connecting to daemon web API: %v\\n\", err)\n   572→\t\tfmt.Fprintf(os.Stderr, \"hint: ensure CLOCHE_HTTP is set and the daemon is running with --http\\n\")\n   573→\t\tos.Exit(1)\n   574→\t}\n   575→\tdefer resp.Body.Close()\n   576→\n   577→\tif resp.StatusCode != 200 {\n   578→\t\tbody, _ := io.ReadAll(resp.Body)\n   579→\t\tfmt.Fprintf(os.Stderr, \"error: HTTP %d: %s\\n\", resp.StatusCode, strings.TrimSpace(string(body)))\n   580→\t\tos.Exit(1)\n   581→\t}\n   582→\n   583→\ttype taskEntry struct {\n   584→\t\tID          string `json:\"id\"`\n   585→\t\tStatus      string `json:\"status\"`\n   586→\t\tTitle       string `json:\"title\"`\n   587→\t\tDescription string `json:\"description\"`\n   588→\t\tAssigned    bool   `json:\"assigned\"`\n   589→\t\tAssignedAt  string `json:\"assigned_at\"`\n   590→\t\tRunID       string `json:\"run_id\"`\n   591→\t}\n   592→\n   593→\tvar tasks []taskEntry\n   594→\tif err := json.NewDecoder(resp.Body).Decode(&tasks); err != nil {\n   595→\t\tfmt.Fprintf(os.Stderr, \"error parsing response: %v\\n\", err)\n   596→\t\tos.Exit(1)\n   597→\t}\n   598→\n   599→\tif len(tasks) == 0 {\n   600→\t\tfmt.Println(\"No tasks found. (Is the orchestration loop running?)\")\n   601→\t\treturn\n   602→\t}\n   603→\n   604→\tfmt.Printf(\"%-20s  %-12s  %-10s  %-30s  %s\\n\", \"ID\", \"STATUS\", \"ASSIGNED\", \"RUN\", \"TITLE\")\n   605→\tfor _, t := range tasks {\n   606→\t\tstatus := t.Status\n   607→\t\tif status == \"\" {\n   608→\t\t\tstatus = \"open\"\n   609→\t\t}\n   610→\t\tassigned := \"-\"\n   611→\t\tif t.Assigned {\n   612→\t\t\tassigned = \"yes\"\n   613→\t\t}\n   614→\t\trunID := \"\"\n   615→\t\tif t.RunID != \"\" {\n   616→\t\t\trunID = t.RunID\n   617→\t\t\tif len(runID) > 30 {\n   618→\t\t\t\trunID = runID[:27] + \"...\"\n   619→\t\t\t}\n   620→\t\t}\n   621→\t\ttitle := t.Title\n   622→\t\tif len(title) > 40 {\n   623→\t\t\ttitle = title[:37] + \"...\"\n   624→\t\t}\n   625→\t\tfmt.Printf(\"%-20s  %-12s  %-10s  %-30s  %s\\n\", t.ID, status, assigned, runID, title)\n   626→\t}\n   627→}\n   628→\n   629→func cmdShutdown(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   630→\tvar force bool\n   631→\tfor _, a := range args {\n   632→\t\tif a == \"-f\" || a == \"--force\" {\n   633→\t\t\tforce = true\n   634→\t\t}\n   635→\t}\n   636→\t_, err := client.Shutdown(ctx, &pb.ShutdownRequest{Force: force})\n   637→\tif err != nil {\n   638→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   639→\t\tos.Exit(1)\n   640→\t}\n   641→\tfmt.Println(\"Daemon shutting down.\")\n   642→}\n   643→\n   644→// resolveRunContext returns the project directory and run ID for context\n   645→// commands. The run ID comes from CLOCHE_RUN_ID and the project directory\n   646→// from CLOCHE_PROJECT_DIR (falling back to cwd).\n   647→func resolveRunContext() (projectDir, runID string, err error) {\n   648→\trunID = os.Getenv(\"CLOCHE_RUN_ID\")\n   649→\tif runID == \"\" {\n   650→\t\treturn \"\", \"\", fmt.Errorf(\"CLOCHE_RUN_ID environment variable is not set\")\n   651→\t}\n   652→\tprojectDir = os.Getenv(\"CLOCHE_PROJECT_DIR\")\n   653→\tif projectDir == \"\" {\n   654→\t\tprojectDir, err = os.Getwd()\n   655→\t\tif err != nil {\n   656→\t\t\treturn \"\", \"\", fmt.Errorf(\"getting working directory: %w\", err)\n   657→\t\t}\n   658→\t}\n   659→\treturn projectDir, runID, nil\n   660→}\n   661→\n   662→func cmdGet(args []string) {\n   663→\tif len(args) < 1 {\n   664→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche get <key>\\n\")\n   665→\t\tos.Exit(1)\n   666→\t}\n   667→\n   668→\tprojectDir, runID, err := resolveRunContext()\n   669→\tif err != nil {\n   670→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   671→\t\tos.Exit(1)\n   672→\t}\n   673→\n   674→\tval, ok, err := runcontext.Get(projectDir, runID, args[0])\n   675→\tif err != nil {\n   676→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   677→\t\tos.Exit(1)\n   678→\t}\n   679→\tif !ok {\n   680→\t\tos.Exit(1)\n   681→\t}\n   682→\tfmt.Println(val)\n   683→}\n   684→\n   685→func cmdSet(args []string) {\n   686→\tif len(args) < 2 {\n   687→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche set <key> <value>\\n\")\n   688→\t\tfmt.Fprintf(os.Stderr, \"       cloche set <key> -     (read value from stdin)\\n\")\n   689→\t\tos.Exit(1)\n   690→\t}\n   691→\n   692→\tprojectDir, runID, err := resolveRunContext()\n   693→\tif err != nil {\n   694→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   695→\t\tos.Exit(1)\n   696→\t}\n   697→\n   698→\tvalue := args[1]\n   699→\tif value == \"-\" {\n   700→\t\tdata, err := io.ReadAll(os.Stdin)\n   701→\t\tif err != nil {\n   702→\t\t\tfmt.Fprintf(os.Stderr, \"error reading stdin: %v\\n\", err)\n   703→\t\t\tos.Exit(1)\n   704→\t\t}\n   705→\t\tvalue = strings.TrimRight(string(data), \"\\n\")\n   706→\t}\n   707→\n   708→\tif err := runcontext.Set(projectDir, runID, args[0], value); err != nil {\n   709→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   710→\t\tos.Exit(1)\n   711→\t}\n   712→}\n   713→\n   714→func cmdVersion() {\n   715→\tcliVersion := version.Version()\n   716→\tfmt.Printf(\"cloche %s\\n\", cliVersion)\n   717→\n   718→\t// Try to get daemon version via gRPC\n   719→\tdaemonVersion := \"<unavailable>\"\n   720→\taddr := os.Getenv(\"CLOCHE_ADDR\")\n   721→\tif addr == \"\" {\n   722→\t\taddr = \"unix:///tmp/cloche.sock\"\n   723→\t}\n   724→\tconn, err := grpc.NewClient(addr, grpc.WithTransportCredentials(insecure.NewCredentials()))\n   725→\tif err == nil {\n   726→\t\tdefer conn.Close()\n   727→\t\tclient := pb.NewClocheServiceClient(conn)\n   728→\t\tctx, cancel := context.WithTimeout(context.Background(), 3*time.Second)\n   729→\t\tdefer cancel()\n   730→\t\tresp, err := client.GetVersion(ctx, &pb.GetVersionRequest{})\n   731→\t\tif err == nil {\n   732→\t\t\tdaemonVersion = resp.Version\n   733→\t\t}\n   734→\t}\n   735→\tfmt.Printf(\"cloched %s\\n\", daemonVersion)\n   736→\n   737→\t// Try to get agent version by running: docker run --rm <image> cloche-agent -v\n   738→\tagentVersion := \"<unavailable>\"\n   739→\timage := os.Getenv(\"CLOCHE_IMAGE\")\n   740→\tif image == \"\" {\n   741→\t\timage = \"cloche-agent:latest\"\n   742→\t}\n   743→\tout, err := exec.CommandContext(\n   744→\t\tcontext.Background(),\n   745→\t\t\"docker\", \"run\", \"--rm\", \"--entrypoint\", \"cloche-agent\", image, \"-v\",\n   746→\t).Output()\n   747→\tif err == nil {\n   748→\t\tagentVersion = strings.TrimSpace(string(out))\n   749→\t\t// Strip \"cloc