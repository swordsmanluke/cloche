→\n   242→\tfmt.Printf(\"Run:       %s\\n\", resp.RunId)\n   243→\tif resp.Title != \"\" {\n   244→\t\tfmt.Printf(\"Title:     %s\\n\", resp.Title)\n   245→\t}\n   246→\tfmt.Printf(\"Workflow:  %s\\n\", resp.WorkflowName)\n   247→\tif resp.IsHost {\n   248→\t\tfmt.Printf(\"Type:      host\\n\")\n   249→\t} else {\n   250→\t\tfmt.Printf(\"Type:      container\\n\")\n   251→\t}\n   252→\tfmt.Printf(\"State:     %s\\n\", resp.State)\n   253→\tif resp.ContainerId != \"\" {\n   254→\t\tcid := resp.ContainerId\n   255→\t\tif len(cid) > 12 {\n   256→\t\t\tcid = cid[:12]\n   257→\t\t}\n   258→\t\tfmt.Printf(\"Container: %s\\n\", cid)\n   259→\t}\n   260→\tif resp.ErrorMessage != \"\" {\n   261→\t\tfmt.Printf(\"Error:     %s\\n\", resp.ErrorMessage)\n   262→\t}\n   263→\tfmt.Printf(\"Active:    %s\\n\", resp.CurrentStep)\n   264→\tfor _, exec := range resp.StepExecutions {\n   265→\t\tfmt.Printf(\"  %s: %s (%s -> %s)\\n\", exec.StepName, exec.Result, exec.StartedAt, exec.CompletedAt)\n   266→\t}\n   267→}\n   268→\n   269→func cmdList(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   270→\tvar all bool\n   271→\tvar projectDir, stateFilter, issueFilter string\n   272→\tvar limit int32\n   273→\n   274→\tfor i := 0; i < len(args); i++ {\n   275→\t\tswitch args[i] {\n   276→\t\tcase \"--all\":\n   277→\t\t\tall = true\n   278→\t\tcase \"--project\", \"-p\":\n   279→\t\t\tif i+1 < len(args) {\n   280→\t\t\t\ti++\n   281→\t\t\t\tprojectDir = args[i]\n   282→\t\t\t}\n   283→\t\tcase \"--state\", \"-s\":\n   284→\t\t\tif i+1 < len(args) {\n   285→\t\t\t\ti++\n   286→\t\t\t\tstateFilter = args[i]\n   287→\t\t\t}\n   288→\t\tcase \"--limit\", \"-n\":\n   289→\t\t\tif i+1 < len(args) {\n   290→\t\t\t\ti++\n   291→\t\t\t\tn, err := strconv.Atoi(args[i])\n   292→\t\t\t\tif err != nil {\n   293→\t\t\t\t\tfmt.Fprintf(os.Stderr, \"error: invalid --limit value: %s\\n\", args[i])\n   294→\t\t\t\t\tos.Exit(1)\n   295→\t\t\t\t}\n   296→\t\t\t\tlimit = int32(n)\n   297→\t\t\t}\n   298→\t\tcase \"--issue\", \"-i\":\n   299→\t\t\tif i+1 < len(args) {\n   300→\t\t\t\ti++\n   301→\t\t\t\tissueFilter = args[i]\n   302→\t\t\t}\n   303→\t\t}\n   304→\t}\n   305→\n   306→\treq := &pb.ListRunsRequest{\n   307→\t\tState:  stateFilter,\n   308→\t\tLimit:  limit,\n   309→\t\tTaskId: issueFilter,\n   310→\t}\n   311→\tif projectDir != \"\" {\n   312→\t\treq.ProjectDir = projectDir\n   313→\t} else if all {\n   314→\t\treq.All = true\n   315→\t} else {\n   316→\t\t// Default: filter to current project\n   317→\t\tcwd, _ := os.Getwd()\n   318→\t\treq.ProjectDir = cwd\n   319→\t}\n   320→\n   321→\tresp, err := client.ListRuns(ctx, req)\n   322→\tif err != nil {\n   323→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   324→\t\tos.Exit(1)\n   325→\t}\n   326→\n   327→\tif len(resp.Runs) == 0 {\n   328→\t\tfmt.Println(\"No runs found.\")\n   329→\t\treturn\n   330→\t}\n   331→\n   332→\tw := tabwriter.NewWriter(os.Stdout, 0, 0, 2, ' ', 0)\n   333→\tfmt.Fprintln(w, \"RUN ID\\tWORKFLOW\\tSTATE\\tTYPE\\tTASK ID\\tTITLE\\tCONTAINER\\tERROR\")\n   334→\tfor _, run := range resp.Runs {\n   335→\t\trunType := \"container\"\n   336→\t\tif run.IsHost {\n   337→\t\t\trunType = \"host\"\n   338→\t\t}\n   339→\t\ttitle := run.Title\n   340→\t\tif len(title) > 40 {\n   341→\t\t\ttitle = title[:37] + \"...\"\n   342→\t\t}\n   343→\t\terrMsg := run.ErrorMessage\n   344→\t\tif len(errMsg) > 60 {\n   345→\t\t\terrMsg = errMsg[:57] + \"...\"\n   346→\t\t}\n   347→\t\tfmt.Fprintf(w, \"%s\\t%s\\t%s\\t%s\\t%s\\t%s\\t%s\\t%s\\n\",\n   348→\t\t\trun.RunId, run.WorkflowName, run.State, runType,\n   349→\t\t\trun.TaskId, title, run.ContainerId, errMsg)\n   350→\t}\n   351→\tw.Flush()\n   352→}\n   353→\n   354→func cmdLogs(client pb.ClocheServiceClient, args []string) {\n   355→\tif len(args) < 1 {\n   356→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche logs <run-id> [-s <name>] [--type <full|script|llm>] [-f] [-l <n>]\\n\")\n   357→\t\tos.Exit(1)\n   358→\t}\n   359→\n   360→\tvar stepFilter, typeFilter string\n   361→\tvar follow bool\n   362→\tvar limit int\n   363→\trunID := args[0]\n   364→\n   365→\tfor i := 1; i < len(args); i++ {\n   366→\t\tswitch args[i] {\n   367→\t\tcase \"--step\", \"-s\":\n   368→\t\t\tif i+1 < len(args) {\n   369→\t\t\t\ti++\n   370→\t\t\t\tstepFilter = args[i]\n   371→\t\t\t}\n   372→\t\tcase \"--type\":\n   373→\t\t\tif i+1 < len(args) {\n   374→\t\t\t\ti++\n   375→\t\t\t\ttypeFilter = args[i]\n   376→\t\t\t}\n   377→\t\tcase \"--follow\", \"-f\":\n   378→\t\t\tfollow = true\n   379→\t\tcase \"--limit\", \"-l\":\n   380→\t\t\tif i+1 < len(args) {\n   381→\t\t\t\ti++\n   382→\t\t\t\tn, err := strconv.Atoi(args[i])\n   383→\t\t\t\tif err != nil || n < 0 {\n   384→\t\t\t\t\tfmt.Fprintf(os.Stderr, \"error: --limit requires a positive integer\\n\")\n   385→\t\t\t\t\tos.Exit(1)\n   386→\t\t\t\t}\n   387→\t\t\t\tlimit = n\n   388→\t\t\t}\n   389→\t\t}\n   390→\t}\n   391→\n   392→\t// Use background context — log output can be large and follow mode blocks.\n   393→\tctx := context.Background()\n   394→\tvar mdPairs []string\n   395→\tif follow {\n   396→\t\tmdPairs = append(mdPairs, \"x-cloche-follow\", \"true\")\n   397→\t}\n   398→\tif limit > 0 {\n   399→\t\tmdPairs = append(mdPairs, \"x-cloche-limit\", strconv.Itoa(limit))\n   400→\t}\n   401→\tif len(mdPairs) > 0 {\n   402→\t\tmd := metadata.Pairs(mdPairs...)\n   403→\t\tctx = metadata.NewOutgoingContext(ctx, md)\n   404→\t}\n   405→\n   406→\tstream, err := client.StreamLogs(ctx, &pb.StreamLogsRequest{\n   407→\t\tRunId:    runID,\n   408→\t\tStepName: stepFilter,\n   409→\t\tLogType:  typeFilter,\n   410→\t})\n   411→\tif err != nil {\n   412→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   413→\t\tos.Exit(1)\n   414→\t}\n   415→\n   416→\tfor {\n   417→\t\tentry, err := stream.Recv()\n   418→\t\tif err != nil {\n   419→\t\t\tif errors.Is(err, io.EOF) {\n   420→\t\t\t\tbreak\n   421→\t\t\t}\n   422→\t\t\tfmt.Fprintf(os.Stderr, \"error reading logs