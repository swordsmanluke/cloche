{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Gw8PidwuiB8T3yxXKiZ7QW","type":"tool_result","content":"     1→package config\n     2→\n     3→import (\n     4→\t\"os\"\n     5→\t\"path/filepath\"\n     6→\n     7→\t\"github.com/BurntSushi/toml\"\n     8→)\n     9→\n    10→type DaemonConfig struct {\n    11→\tListen     string `toml:\"listen\"`\n    12→\tHTTP       string `toml:\"http\"`\n    13→\tImage      string `toml:\"image\"`\n    14→\tDB         string `toml:\"db\"`\n    15→\tRuntime    string `toml:\"runtime\"`\n    16→\tAgentPath  string `toml:\"agent_path\"`\n    17→\tLLMCommand string `toml:\"llm_command\"`\n    18→}\n    19→\n    20→type EvolutionConfig struct {\n    21→\tEnabled          bool   `toml:\"enabled\"`\n    22→\tDebounceSeconds  int    `toml:\"debounce_seconds\"`\n    23→\tMinConfidence    string `toml:\"min_confidence\"`\n    24→\tMaxPromptBullets int    `toml:\"max_prompt_bullets\"`\n    25→}\n    26→\n    27→type OrchestrationConfig struct {\n    28→\tConcurrency      int     `toml:\"concurrency\"`\n    29→\tStaggerSeconds   float64 `toml:\"stagger_seconds\"`\n    30→\tListTasksCommand string  `toml:\"list_tasks_command\"` // shell command to list open tasks (JSON array output)\n    31→\tDedupSeconds     float64 `toml:\"dedup_seconds\"`      // dedup window for task assignment (default: 300)\n    32→\tStopOnError      bool    `toml:\"stop_on_error\"`      // halt orchestration loop on unrecovered error\n    33→}\n    34→\n    35→type Config struct {\n    36→\tActive        bool                `toml:\"active\"`\n    37→\tDaemon        DaemonConfig        `toml:\"daemon\"`\n    38→\tEvolution     EvolutionConfig     `toml:\"evolution\"`\n    39→\tOrchestration OrchestrationConfig `toml:\"orchestration\"`\n    40→}\n    41→\n    42→func defaults() Config {\n    43→\treturn Config{\n    44→\t\tEvolution: EvolutionConfig{\n    45→\t\t\tEnabled:          true,\n    46→\t\t\tDebounceSeconds:  30,\n    47→\t\t\tMinConfidence:    \"medium\",\n    48→\t\t\tMaxPromptBullets: 50,\n    49→\t\t},\n    50→\t\tOrchestration: OrchestrationConfig{\n    51→\t\t\tConcurrency:    1,\n    52→\t\t\tStaggerSeconds: 1.0,\n    53→\t\t},\n    54→\t}\n    55→}\n    56→\n    57→// Load reads a per-project config from <projectDir>/.cloche/config.toml.\n    58→func Load(projectDir string) (*Config, error) {\n    59→\tcfg := defaults()\n    60→\tpath := filepath.Join(projectDir, \".cloche\", \"config.toml\")\n    61→\n    62→\tdata, err := os.ReadFile(path)\n    63→\tif os.IsNotExist(err) {\n    64→\t\treturn &cfg, nil\n    65→\t}\n    66→\tif err != nil {\n    67→\t\treturn nil, err\n    68→\t}\n    69→\n    70→\tif _, err := toml.Decode(string(data), &cfg); err != nil {\n    71→\t\treturn nil, err\n    72→\t}\n    73→\treturn &cfg, nil\n    74→}\n    75→\n    76→// LoadGlobal reads the global daemon config from ~/.config/cloche/config.\n    77→// Returns defaults if the file does not exist.\n    78→func LoadGlobal() (*Config, error) {\n    79→\tcfg := defaults()\n    80→\n    81→\thome, err := os.UserHomeDir()\n    82→\tif err != nil {\n    83→\t\treturn &cfg, nil\n    84→\t}\n    85→\n    86→\tpath := filepath.Join(home, \".config\", \"cloche\", \"config\")\n    87→\tdata, err := os.ReadFile(path)\n    88→\tif os.IsNotExist(err) {\n    89→\t\treturn &cfg, nil\n    90→\t}\n    91→\tif err != nil {\n    92→\t\treturn nil, err\n    93→\t}\n    94→\n    95→\tif _, err := toml.Decode(string(data), &cfg); err != nil {\n    96→\t\treturn nil, err\n    97→\t}\n    98→\treturn &cfg, nil\n    99→}\n   100→\n   101→// LoadGlobalFrom reads the global config from a specific path.\n   102→// Useful for testing.\n   103→func LoadGlobalFrom(path string) (*Config, error) {\n   104→\tcfg := defaults()\n   105→\n   106→\tdata, err := os.ReadFile(path)\n   107→\tif os.IsNotExist(err) {\n   108→\t\treturn &cfg, nil\n   109→\t}\n   110→\tif err != nil {\n   111→\t\treturn nil, err\n   112→\t}\n   113→\n   114→\tif _, err :=