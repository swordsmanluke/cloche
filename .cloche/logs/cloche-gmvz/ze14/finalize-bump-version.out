{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_016LkvQAPGX7ZdPCmXKP842s","type":"message","role":"assistant","content":[{"type":"thinking","thinking":"This change moves the default socket and DB paths from `/tmp/cloche.sock` to `~/.config/cloche/cloche.sock`. It adds new config functions and changes default behavior. This is a user-facing behavior change (default paths changed) and adds new API functions. This is a minor bump since it changes where the daemon listens by default — existing users with no explicit config will connect to a different path. However, it's backward-compatible in the sense that users can still override via env vars.\n\nThis is a minor bump — new feature/behavior change (default socket location moved to user config dir).\n\nCurrent version: 1.6.2 → bump to 1.7.0","signature":""}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":2027,"cache_read_input_tokens":17583,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":2027},"output_tokens":8,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"db057372-e109-4bd2-87ab-04ce2cc69cdd","uuid":"1e97eb78-bc49-47e5-852c-5e4628bfeb87"}
