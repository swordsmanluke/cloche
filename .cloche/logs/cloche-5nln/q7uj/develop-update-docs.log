{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01H1KBVBtY5QLsAmQrFheeo7","type":"tool_result","content":"     1‚Üípackage main\n     2‚Üí\n     3‚Üíimport (\n     4‚Üí\t\"fmt\"\n     5‚Üí\t\"os\"\n     6‚Üí\t\"path/filepath\"\n     7‚Üí\t\"sort\"\n     8‚Üí\t\"strings\"\n     9‚Üí\n    10‚Üí\t\"github.com/cloche-dev/cloche/internal/domain\"\n    11‚Üí\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    12‚Üí)\n    13‚Üí\n    14‚Üífunc cmdWorkflow(args []string) {\n    15‚Üí\tvar projectDir, workflowName string\n    16‚Üí\tfor i := 0; i < len(args); i++ {\n    17‚Üí\t\tswitch args[i] {\n    18‚Üí\t\tcase \"--project\", \"-p\":\n    19‚Üí\t\t\tif i+1 < len(args) {\n    20‚Üí\t\t\t\ti++\n    21‚Üí\t\t\t\tprojectDir = args[i]\n    22‚Üí\t\t\t}\n    23‚Üí\t\tdefault:\n    24‚Üí\t\t\tif !strings.HasPrefix(args[i], \"-\") && workflowName == \"\" {\n    25‚Üí\t\t\t\tworkflowName = args[i]\n    26‚Üí\t\t\t}\n    27‚Üí\t\t}\n    28‚Üí\t}\n    29‚Üí\n    30‚Üí\tif projectDir == \"\" {\n    31‚Üí\t\tprojectDir, _ = os.Getwd()\n    32‚Üí\t} else {\n    33‚Üí\t\tabs, err := filepath.Abs(projectDir)\n    34‚Üí\t\tif err == nil {\n    35‚Üí\t\t\tprojectDir = abs\n    36‚Üí\t\t}\n    37‚Üí\t}\n    38‚Üí\n    39‚Üí\tif workflowName == \"\" {\n    40‚Üí\t\tlistWorkflows(projectDir)\n    41‚Üí\t} else {\n    42‚Üí\t\tshowWorkflow(projectDir, workflowName)\n    43‚Üí\t}\n    44‚Üí}\n    45‚Üí\n    46‚Üítype workflowInfo struct {\n    47‚Üí\tname     string\n    48‚Üí\tlocation domain.WorkflowLocation\n    49‚Üí}\n    50‚Üí\n    51‚Üífunc discoverWorkflows(projectDir string) ([]workflowInfo, error) {\n    52‚Üí\tclocheDir := filepath.Join(projectDir, \".cloche\")\n    53‚Üí\tentries, err := filepath.Glob(filepath.Join(clocheDir, \"*.cloche\"))\n    54‚Üí\tif err != nil {\n    55‚Üí\t\treturn nil, err\n    56‚Üí\t}\n    57‚Üí\n    58‚Üí\tvar infos []workflowInfo\n    59‚Üí\tfor _, path := range entries {\n    60‚Üí\t\tbase := filepath.Base(path)\n    61‚Üí\t\tdata, err := os.ReadFile(path)\n    62‚Üí\t\tif err != nil {\n    63‚Üí\t\t\tcontinue\n    64‚Üí\t\t}\n    65‚Üí\n    66‚Üí\t\tif base == \"host.cloche\" {\n    67‚Üí\t\t\twfs, err := dsl.ParseAllForHost(string(data))\n    68‚Üí\t\t\tif err != nil {\n    69‚Üí\t\t\t\tcontinue\n    70‚Üí\t\t\t}\n    71‚Üí\t\t\tfor name := range wfs {\n    72‚Üí\t\t\t\tinfos = append(infos, workflowInfo{name: name, location: domain.LocationHost})\n    73‚Üí\t\t\t}\n    74‚Üí\t\t} else {\n    75‚Üí\t\t\twf, err := dsl.ParseForContainer(string(data))\n    76‚Üí\t\t\tif err != nil {\n    77‚Üí\t\t\t\tcontinue\n    78‚Üí\t\t\t}\n    79‚Üí\t\t\tinfos = append(infos, workflowInfo{name: wf.Name, location: domain.LocationContainer})\n    80‚Üí\t\t}\n    81‚Üí\t}\n    82‚Üí\n    83‚Üí\treturn infos, nil\n    84‚Üí}\n    85‚Üí\n    86‚Üífunc listWorkflows(projectDir string) {\n    87‚Üí\tinfos, err := discoverWorkflows(projectDir)\n    88‚Üí\tif err != nil {\n    89‚Üí\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n    90‚Üí\t\tos.Exit(1)\n    91‚Üí\t}\n    92‚Üí\n    93‚Üí\tif len(infos) == 0 {\n    94‚Üí\t\tfmt.Println(\"No workflows found.\")\n    95‚Üí\t\treturn\n    96‚Üí\t}\n    97‚Üí\n    98‚Üí\tvar container, host []string\n    99‚Üí\tfor _, info := range infos {\n   100‚Üí\t\tswitch info.location {\n   101‚Üí\t\tcase domain.LocationContainer:\n   102‚Üí\t\t\tcontainer = append(container, info.name)\n   103‚Üí\t\tcase domain.LocationHost:\n   104‚Üí\t\t\thost = append(host, info.name)\n   105‚Üí\t\t}\n   106‚Üí\t}\n   107‚Üí\n   108‚Üí\tsort.Strings(container)\n   109‚Üí\tsort.Strings(host)\n   110‚Üí\n   111‚Üí\tif len(container) > 0 {\n   112‚Üí\t\tfmt.Println(\"Container workflows:\")\n   113‚Üí\t\tfor _, name := range container {\n   114‚Üí\t\t\tfmt.Printf(\"  %s\\n\", name)\n   115‚Üí\t\t}\n   116‚Üí\t}\n   117‚Üí\n   118‚Üí\tif len(host) > 0 {\n   119‚Üí\t\tif len(container) > 0 {\n   120‚Üí\t\t\tfmt.Println()\n   121‚Üí\t\t}\n   122‚Üí\t\tfmt.Println(\"Host workflows:\")\n   123‚Üí\t\tfor _, name := range host {\n   124‚Üí\t\t\tfmt.Printf(\"  %s\\n\", name)\n   125‚Üí\t\t}\n   126‚Üí\t}\n   127‚Üí}\n   128‚Üí\n   129‚Üífunc loadWorkflow(projectDir, name string) (*domain.Workflow, error) {\n   130‚Üí\tclocheDir := filepath.Join(projectDir, \".cloche\")\n   131‚Üí\n   132‚Üí\t// Try container workflow first (named file)\n   133‚Üí\tcontainerPath := filepath.Join(clocheDir, name+\".cloche\")\n   134‚Üí\tif data, err := os.ReadFile(containerPath); err == nil {\n   135‚Üí\t\twf, err := dsl.ParseForContainer(string(data))\n   136‚Üí\t\tif err != nil {\n   137‚Üí\t\t\treturn nil, fmt.Errorf(\"parsing %s.cloche: %w\", name, err)\n   138‚Üí\t\t}\n   139‚Üí\t\treturn wf, nil\n   140‚Üí\t}\n   141‚Üí\n   142‚Üí\t// Try host workflow\n   143‚Üí\thostPath := filepath.Join(clocheDir, \"host.cloche\")\n   144‚Üí\tif data, err := os.ReadFile(hostPath); err == nil {\n   145‚Üí\t\twfs, err := dsl.ParseAllForHost(string(data))\n   146‚Üí\t\tif err != nil {\n   147‚Üí\t\t\treturn nil, fmt.Errorf(\"parsing host.cloche: %w\", err)\n   148‚Üí\t\t}\n   149‚Üí\t\tif wf, ok := wfs[name]; ok {\n   150‚Üí\t\t\treturn wf, nil\n   151‚Üí\t\t}\n   152‚Üí\t}\n   153‚Üí\n   154‚Üí\treturn nil, fmt.Errorf(\"workflow %q not found\", name)\n   155‚Üí}\n   156‚Üí\n   157‚Üífunc showWorkflow(projectDir, name string) {\n   158‚Üí\twf, err := loadWorkflow(projectDir, name)\n   159‚Üí\tif err != nil {\n   160‚Üí\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   161‚Üí\t\tos.Exit(1)\n   162‚Üí\t}\n   163‚Üí\tfmt.Print(renderWorkflowGraph(wf, isTTY()))\n   164‚Üí}\n   165‚Üí\n   166‚Üí// ANSI color codes for wire colorization.\n   167‚Üíconst (\n   168‚Üí\tcolorReset   = \"\\033[0m\"\n   169‚Üí\tcolorGreen   = \"\\033[32m\"\n   170‚Üí\tcolorRed     = \"\\033[31m\"\n   171‚Üí\tcolorBlue    = \"\\033[34m\"\n   172‚Üí\tcolorYellow  = \"\\033[33m\"\n   173‚Üí\tcolorOrange  = \"\\033[38;5;208m\"\n   174‚Üí\tcolorMagenta = \"\\033[35m\"\n   175‚Üí)\n   176‚Üí\n   177‚Üívar otherResultColors = []string{colorBlue, colorYellow, colorOrange, colorMagenta}\n   178‚Üí\n   179‚Üí// buildResultColorMap assigns a color to each unique result name in the workflow.\n   180‚Üí// \"success\" is always green, \"fail\"/\"failed\" always red, others cycle through\n   181‚Üí// blue, yellow, orange, magenta.\n   182‚Üífunc buildResultColorMap(w *domain.Workflow, order []string) map[string]string {\n   183‚Üí\tcolorMap := map[string]string{\n   184‚Üí\t\t\"success\": colorGreen,\n   185‚Üí\t\t\"fail\":    colorRed,\n   186‚Üí\t\t\"failed\":  colorRed,\n   187‚Üí\t}\n   188‚Üí\n   189‚Üí\totherIdx := 0\n   190‚Üí\tfor _, stepName := range order {\n   191‚Üí\t\tstep := w.Steps[stepName]\n   192‚Üí\t\tfor _, r := range step.Results {\n   193‚Üí\t\t\tif _, ok := colorMap[r]; ok {\n   194‚Üí\t\t\t\tcontinue\n   195‚Üí\t\t\t}\n   196‚Üí\t\t\tcolorMap[r] = otherResultColors[otherIdx%len(otherResultColors)]\n   197‚Üí\t\t\totherIdx++\n   198‚Üí\t\t}\n   199‚Üí\t}\n   200‚Üí\n   201‚Üí\treturn colorMap\n   202‚Üí}\n   203‚Üí\n   204‚Üífunc renderWorkflowGraph(w *domain.Workflow, color bool) string {\n   205‚Üí\tvar buf strings.Builder\n   206‚Üí\n   207‚Üí\t// Header\n   208‚Üí\tfmt.Fprintf(&buf, \"workflow %q (%s)\\n\\n\", w.Name, w.Location)\n   209‚Üí\n   210‚Üí\torder := bfsOrder(w)\n   211‚Üí\tif len(order) == 0 {\n   212‚Üí\t\tbuf.WriteString(\"  (no steps)\\n\")\n   213‚Üí\t\treturn buf.String()\n   214‚Üí\t}\n   215‚Üí\n   216‚Üí\tcolorMap := buildResultColorMap(w, order)\n   217‚Üí\n   218‚Üí\t// Compute max step name length for consistent box widths\n   219‚Üí\tnameWidth := 0\n   220‚Üí\tfor _, name := range order {\n   221‚Üí\t\tif len(name) > nameWidth {\n   222‚Üí\t\t\tnameWidth = len(name)\n   223‚Üí\t\t}\n   224‚Üí\t}\n   225‚Üí\t// Minimum width\n   226‚Üí\tif nameWidth < 6 {\n   227‚Üí\t\tnameWidth = 6\n   228‚Üí\t}\n   229‚Üí\n   230‚Üí\tfor i, stepName := range order {\n   231‚Üí\t\tstep := w.Steps[stepName]\n   232‚Üí\t\tisEntry := stepName == w.EntryStep\n   233‚Üí\n   234‚Üí\t\trenderStepBox(&buf, step, isEntry, nameWidth)\n   235‚Üí\t\tgroups := groupWiresByDest(w, stepName)\n   236‚Üí\t\trenderWireGroups(&buf, groups, colorMap, color)\n   237‚Üí\n   238‚Üí\t\t// Also render any collect conditions originating from this step\n   239‚Üí\t\trenderCollects(&buf, w, stepName, colorMap, color)\n   240‚Üí\n   241‚Üí\t\tif i < len(order)-1 {\n   242‚Üí\t\t\tbuf.WriteString(\"\\n\")\n   243‚Üí\t\t}\n   244‚Üí\t}\n   245‚Üí\n   246‚Üí\treturn buf.String()\n   247‚Üí}\n   248‚Üí\n   249‚Üífunc renderStepBox(buf *strings.Builder, step *domain.Step, isEntry bool, nameWidth int) {\n   250‚Üí\tpadded := fmt.Sprintf(\" %-*s \", nameWidth, step.Name)\n   251‚Üí\tborder := strings.Repeat(\"‚îÄ\", nameWidth+2)\n   252‚Üí\n   253‚Üí\tsuffix := fmt.Sprintf(\" %s\", step.Type)\n   254‚Üí\tif isEntry {\n   255‚Üí\t\tsuffix += \"  ‚óÄ entry\"\n   256‚Üí\t}\n   257‚Üí\n   258‚Üí\tfmt.Fprintf(buf, \"  ‚îå%s‚îê\\n\", border)\n   259‚Üí\tfmt.Fprintf(buf, \"  ‚îÇ%s‚îÇ%s\\n\", padded, suffix)\n   260‚Üí\tfmt.Fprintf(buf, \"  ‚îî%s‚îò\\n\", border)\n   261‚Üí}\n   262‚Üí\n   263‚Üítype wireGroup struct {\n   264‚Üí\tresults []string\n   265‚Üí\tto      string\n   266‚Üí}\n   267‚Üí\n   268‚Üí// groupWiresByDest groups wires from a step by destination, preserving order.\n   269‚Üí// Wires to the same destination are merged into a single group.\n   270‚Üífunc groupWiresByDest(w *domain.Workflow, stepName string) []wireGroup {\n   271‚Üí\tdestMap := make(map[string][]string)\n   272‚Üí\tvar destOrder []string\n   273‚Üí\n   274‚Üí\tfor _, wire := range w.Wiring {\n   275‚Üí\t\tif wire.From != stepName {\n   276‚Üí\t\t\tcontinue\n   277‚Üí\t\t}\n   278‚Üí\t\tif _, seen := destMap[wire.To]; !seen {\n   279‚Üí\t\t\tdestOrder = append(destOrder, wire.To)\n   280‚Üí\t\t}\n   281‚Üí\t\tdestMap[wire.To] = append(destMap[wire.To], wire.Result)\n   282‚Üí\t}\n   283‚Üí\n   284‚Üí\tvar groups []wireGroup\n   285‚Üí\tfor _, dest := range destOrder {\n   286‚Üí\t\tgroups = append(groups, wireGroup{results: destMap[dest], to: dest})\n   287‚Üí\t}\n   288‚Üí\treturn groups\n   289‚Üí}\n   290‚Üí\n   291‚Üífunc renderWireGroups(buf *strings.Builder, groups []wireGroup, colorMap map[string]string, useColor bool) {\n   292‚Üí\tfor i, g := range groups {\n   293‚Üí\t\tisLast := i == len(groups)-1\n   294‚Üí\t\tbranch := \"‚îú\"\n   295‚Üí\t\tif isLast {\n   296‚Üí\t\t\tbranch = \"‚îî\"\n   297‚Üí\t\t}\n   298‚Üí\n   299‚Üí\t\t// Build colored result list\n   300‚Üí\t\tvar resultParts []string\n   301‚Üí\t\tfor _, r := range g.results {\n   302‚Üí\t\t\tif useColor {\n   303‚Üí\t\t\t\tresultParts = append(resultParts, colorMap[r]+r+colorReset)\n   304‚Üí\t\t\t} else {\n   305‚Üí\t\t\t\tresultParts = append(resultParts, r)\n   306‚Üí\t\t\t}\n   307‚Üí\t\t}\n   308‚Üí\t\tresultStr := strings.Join(resultParts, \", \")\n   309‚Üí\n   310‚Üí\t\t// Format destination\n   311‚Üí\t\tdest := formatDest(g.to, useColor)\n   312‚Üí\n   313‚Üí\t\tfmt.Fprintf(buf, \"    %s‚îÄ‚îÄ %s ‚îÄ‚îÄ‚ñ∂ %s\\n\", branch, resultStr, dest)\n   314‚Üí\t}\n   315‚Üí}\n   316‚Üí\n   317‚Üífunc formatDest(to string, useColor bool) string {\n   318‚Üí\tswitch to {\n   319‚Üí\tcase domain.StepDone:\n   320‚Üí\t\tif useColor {\n   321‚Üí\t\t\treturn colorGreen + \"DONE\" + colorReset\n   322‚Üí\t\t}\n   323‚Üí\t\treturn \"DONE\"\n   324‚Üí\tcase domain.StepAbort:\n   325‚Üí\t\tif useColor {\n   326‚Üí\t\t\treturn colorRed + \"ABORT\" + colorReset\n   327‚Üí\t\t}\n   328‚Üí\t\treturn \"ABORT\"\n   329‚Üí\tdefault:\n   330‚Üí\t\treturn to\n   331‚Üí\t}\n   332‚Üí}\n   333‚Üí\n   334‚Üí// renderCollects renders any collect conditions that reference this step.\n   335‚Üífunc renderCollects(buf *strings.Builder, w *domain.Workflow, stepName string, colorMap map[string]string, useColor bool) {\n   336‚Üí\tfor _, c := range w.Collects {\n   337‚Üí\t\t// Check if this step is part of the collect conditions\n   338‚Üí\t\tvar parts []string\n   339‚Üí\t\tinvolves := false\n   340‚Üí\t\tfor _, cond := range c.Conditions {\n   341‚Üí\t\t\tlabel := cond.Step + \":\" + cond.Result\n   342‚Üí\t\t\tif useColor {\n   343‚Üí\t\t\t\tif clr, ok := colorMap[cond.Result]; ok {\n   344‚Üí\t\t\t\t\tlabel = cond.Step + \":\" + clr + cond.Result + colorReset\n   345‚Üí\t\t\t\t}\n   346‚Üí\t\t\t}\n   347‚Üí\t\t\tparts = append(parts, label)\n   348‚Üí\t\t\tif cond.Step == stepName {\n   349‚Üí\t\t\t\tinvolves = true\n   350‚Üí\t\t\t}\n   351‚Üí\t\t}\n   352‚Üí\t\t// Only render the collect on the last condition step to avoid duplication\n   353‚Üí\t\tif involves && c.Conditions[len(c.Conditions)-1].Step == stepName {\n   354‚Üí\t\t\tdest := formatDest(c.To, useColor)\n   355‚Üí\t\t\tfmt.Fprintf(buf, \"    collect %s(%s) ‚îÄ‚îÄ‚ñ∂ %s\\n\", c.Mode, strings.Join(parts, \", \"), dest)\n   356‚Üí\t\t}\n   357‚Üí\t}\n   358‚Üí}\n   359‚Üí\n   360‚Üí// bfsOrder returns steps in BFS order from the entry step.\n   361‚Üí// Handles cycles by skipping already-visited nodes.\n   362‚Üífunc bfsOrder(w *domain.Workflow) []string {\n   363‚Üí\tif w.EntryStep == \"\" {\n   364‚Üí\t\treturn nil\n   365‚Üí\t}\n   366‚Üí\n   367‚Üí\tvisited := map[string]bool{w.EntryStep: true}\n   368‚Üí\tvar order []string\n   369‚Üí\tqueue := []string{w.EntryStep}\n   370‚Üí\n   371‚Üí\tfor len(queue) > 0 {\n   372‚Üí\t\tcurrent := queue[0]\n   373‚Üí\t\tqueue = queue[1:]\n   374‚Üí\t\torder = append(order, current)\n   375‚Üí\n   376‚Üí\t\t// Collect unique target steps in wire order\n   377‚Üí\t\tfor _, wire := range w.Wiring {\n   378‚Üí\t\t\tif wire.From != current {\n   379‚Üí\t\t\t\tcontinue\n   380‚Üí\t\t\t}\n   381‚Üí\t\t\tif wire.To == domain.StepDone || wire.To == domain.StepAbort {\n   382‚Üí\t\t\t\tcontinue\n   383‚Üí\t\t\t}\n   384‚Üí\t\t\tif visited[wire.To] {\n   385‚Üí\t\t\t\tcontinue\n   386‚Üí\t\t\t}\n   387‚Üí\t\t\tvisited[wire.To] = true\n   388‚Üí\t\t\tqueue = append(queue, wire.To)\n   389‚Üí\t\t}\n   390‚Üí\t}\n   391‚Üí\n   392‚Üí\treturn order\n   393‚Üí}\n   394‚Üí"}]},"parent_tool_use_id":null,"session_id":"2090add2-0fe6-4270-9f3b-b52deb6bac91","uuid":"bb59043e-9397-4a5e-bc1c-067af49ab556","tool_use_result":{"type":"text","file":{"filePath":"/workspace/cmd/cloche/workflow.go","content":"package main\n\nimport (\n\t\"fmt\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"sort\"\n\t\"strings\"\n\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/dsl\"\n)\n\nfunc cmdWorkflow(args []string) {\n\tvar projectDir, workflowName string\n\tfor i := 0; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--project\", \"-p\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tprojectDir = args[i]\n\t\t\t}\n\t\tdefault:\n\t\t\tif !strings.HasPrefix(args[i], \"-\") && workflowName == \"\" {\n\t\t\t\tworkflowName = args[i]\n\t\t\t}\n\t\t}\n\t}\n\n\tif projectDir == \"\" {\n\t\tprojectDir, _ = os.Getwd()\n\t} else {\n\t\tabs, err := filepath.Abs(projectDir)\n\t\tif err == nil {\n\t\t\tprojectDir = abs\n\t\t}\n\t}\n\n\tif workflowName == \"\" {\n\t\tlistWorkflows(projectDir)\n\t} else {\n\t\tshowWorkflow(projectDir, workflowName)\n\t}\n}\n\ntype workflowInfo struct {\n\tname     string\n\tlocation domain.WorkflowLocation\n}\n\nfunc discoverWorkflows(projectDir string) ([]workflowInfo, error) {\n\tclocheDir := filepath.Join(projectDir, \".cloche\")\n\tentries, err := filepath.Glob(filepath.Join(clocheDir, \"*.cloche\"))\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tvar infos []workflowInfo\n\tfor _, path := range entries {\n\t\tbase := filepath.Base(path)\n\t\tdata, err := os.ReadFile(path)\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\n\t\tif base == \"host.cloche\" {\n\t\t\twfs, err := dsl.ParseAllForHost(string(data))\n\t\t\tif err != nil {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tfor name := range wfs {\n\t\t\t\tinfos = append(infos, workflowInfo{name: name, location: domain.LocationHost})\n\t\t\t}\n\t\t} else {\n\t\t\twf, err := dsl.ParseForContainer(string(data))\n\t\t\tif err != nil {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tinfos = append(infos, workflowInfo{name: wf.Name, location: domain.LocationContainer})\n\t\t}\n\t}\n\n\treturn infos, nil\n}\n\nfunc listWorkflows(projectDir string) {\n\tinfos, err := discoverWorkflows(projectDir)\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tif len(infos) == 0 {\n\t\tfmt.Println(\"No workflows found.\")\n\t\treturn\n\t}\n\n\tvar container, host []string\n\tfor _, info := range infos {\n\t\tswitch info.location {\n\t\tcase domain.LocationContainer:\n\t\t\tcontainer = append(container, info.name)\n\t\tcase domain.LocationHost:\n\t\t\thost = append(host, info.name)\n\t\t}\n\t}\n\n\tsort.Strings(container)\n\tsort.Strings(host)\n\n\tif len(container) > 0 {\n\t\tfmt.Println(\"Container workflows:\")\n\t\tfor _, name := range container {\n\t\t\tfmt.Printf(\"  %s\\n\", name)\n\t\t}\n\t}\n\n\tif len(host) > 0 {\n\t\tif len(container) > 0 {\n\t\t\tfmt.Println()\n\t\t}\n\t\tfmt.Println(\"Host workflows:\")\n\t\tfor _, name := range host {\n\t\t\tfmt.Printf(\"  %s\\n\", name)\n\t\t}\n\t}\n}\n\nfunc loadWorkflow(projectDir, name string) (*domain.Workflow, error) {\n\tclocheDir := filepath.Join(projectDir, \".cloche\")\n\n\t// Try container workflow first (named file)\n\tcontainerPath := filepath.Join(clocheDir, name+\".cloche\")\n\tif data, err := os.ReadFile(containerPath); err == nil {\n\t\twf, err := dsl.ParseForContainer(string(data))\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"parsing %s.cloche: %w\", name, err)\n\t\t}\n\t\treturn wf, nil\n\t}\n\n\t// Try host workflow\n\thostPath := filepath.Join(clocheDir, \"host.cloche\")\n\tif data, err := os.ReadFile(hostPath); err == nil {\n\t\twfs, err := dsl.ParseAllForHost(string(data))\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"parsing host.cloche: %w\", err)\n\t\t}\n\t\tif wf, ok := wfs[name]; ok {\n\t\t\treturn wf, nil\n\t\t}\n\t}\n\n\treturn nil, fmt.Errorf(\"workflow %q not found\", name)\n}\n\nfunc showWorkflow(projectDir, name string) {\n\twf, err := loadWorkflow(projectDir, name)\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Print(renderWorkflowGraph(wf, isTTY()))\n}\n\n// ANSI color codes for wire colorization.\nconst (\n\tcolorReset   = \"\\033[0m\"\n\tcolorGreen   = \"\\033[32m\"\n\tcolorRed     = \"\\033[31m\"\n\tcolorBlue    = \"\\033[34m\"\n\tcolorYellow  = \"\\033[33m\"\n\tcolorOrange  = \"\\033[38;5;208m\"\n\tcolorMagenta = \"\\033[35m\"\n)\n\nvar otherResultColors = []string{colorBlue, colorYellow, colorOrange, colorMagenta}\n\n// buildResultColorMap assigns a color to each unique result name in the workflow.\n// \"success\" is always green, \"fail\"/\"failed\" always red, others cycle through\n// blue, yellow, orange, magenta.\nfunc buildResultColorMap(w *domain.Workflow, order []string) map[string]string {\n\tcolorMap := map[string]string{\n\t\t\"success\": colorGreen,\n\t\t\"fail\":    colorRed,\n\t\t\"failed\":  colorRed,\n\t}\n\n\totherIdx := 0\n\tfor _, stepName := range order {\n\t\tstep := w.Steps[stepName]\n\t\tfor _, r := range step.Results {\n\t\t\tif _, ok := colorMap[r]; ok {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tcolorMap[r] = otherResultColors[otherIdx%len(otherResultColors)]\n\t\t\totherIdx++\n\t\t}\n\t}\n\n\treturn colorMap\n}\n\nfunc renderWorkflowGraph(w *domain.Workflow, color bool) string {\n\tvar buf strings.Builder\n\n\t// Header\n\tfmt.Fprintf(&buf, \"workflow %q (%s)\\n\\n\", w.Name, w.Location)\n\n\torder := bfsOrder(w)\n\tif len(order) == 0 {\n\t\tbuf.WriteString(\"  (no steps)\\n\")\n\t\treturn buf.String()\n\t}\n\n\tcolorMap := buildResultColorMap(w, order)\n\n\t// Compute max step name length for consistent box widths\n\tnameWidth := 0\n\tfor _, name := range order {\n\t\tif len(name) > nameWidth {\n\t\t\tnameWidth = len(name)\n\t\t}\n\t}\n\t// Minimum width\n\tif nameWidth < 6 {\n\t\tnameWidth = 6\n\t}\n\n\tfor i, stepName := range order {\n\t\tstep := w.Steps[stepName]\n\t\tisEntry := stepName == w.EntryStep\n\n\t\trenderStepBox(&buf, step, isEntry, nameWidth)\n\t\tgroups := groupWiresByDest(w, stepName)\n\t\trenderWireGroups(&buf, groups, colorMap, color)\n\n\t\t// Also render any collect conditions originating from this step\n\t\trenderCollects(&buf, w, stepName, colorMap, color)\n\n\t\tif i < len(order)-1 {\n\t\t\tbuf.WriteString(\"\\n\")\n\t\t}\n\t}\n\n\treturn buf.String()\n}\n\nfunc renderStepBox(buf *strings.Builder, step *domain.Step, isEntry bool, nameWidth int) {\n\tpadded := fmt.Sprintf(\" %-*s \", nameWidth, step.Name)\n\tborder := strings.Repeat(\"‚îÄ\", nameWidth+2)\n\n\tsuffix := fmt.Sprintf(\" %s\", step.Type)\n\tif isEntry {\n\t\tsuffix += \"  ‚óÄ entry\"\n\t}\n\n\tfmt.Fprintf(buf, \"  ‚îå%s‚îê\\n\", border)\n\tfmt.Fprintf(buf, \"  ‚îÇ%s‚îÇ%s\\n\", padded, suffix)\n\tfmt.Fprintf(buf, \"  ‚îî%s‚îò\\n\", border)\n}\n\ntype wireGroup struct {\n\tresults []string\n\tto      string\n}\n\n// groupWiresByDest groups wires from a step by destination, preserving order.\n// Wires to the same destination are merged into a single group.\nfunc groupWiresByDest(w *domain.Workflow, stepName string) []wireGroup {\n\tdestMap := make(map[string][]string)\n\tvar destOrder []string\n\n\tfor _, wire := range w.Wiring {\n\t\tif wire.From != stepName {\n\t\t\tcontinue\n\t\t}\n\t\tif _, seen := destMap[wire.To]; !seen {\n\t\t\tdestOrder = append(destOrder, wire.To)\n\t\t}\n\t\tdestMap[wire.To] = append(destMap[wire.To], wire.Result)\n\t}\n\n\tvar groups []wireGroup\n\tfor _, dest := range destOrder {\n\t\tgroups = append(groups, wireGroup{results: destMap[dest], to: dest})\n\t}\n\treturn groups\n}\n\nfunc renderWireGroups(buf *strings.Builder, groups []wireGroup, colorMap map[string]string, useColor bool) {\n\tfor i, g := range groups {\n\t\tisLast := i == len(groups)-1\n\t\tbranch := \"‚îú\"\n\t\tif isLast {\n\t\t\tbranch = \"‚îî\"\n\t\t}\n\n\t\t// Build colored result list\n\t\tvar resultParts []string\n\t\tfor _, r := range g.results {\n\t\t\tif useColor {\n\t\t\t\tresultParts = append(resultParts, colorMap[r]+r+colorReset)\n\t\t\t} else {\n\t\t\t\tresultParts = append(resultParts, r)\n\t\t\t}\n\t\t}\n\t\tresultStr := strings.Join(resultParts, \", \")\n\n\t\t// Format destination\n\t\tdest := formatDest(g.to, useColor)\n\n\t\tfmt.Fprintf(buf, \"    %s‚îÄ‚îÄ %s ‚îÄ‚îÄ‚ñ∂ %s\\n\", branch, resultStr, dest)\n\t}\n}\n\nfunc formatDest(to string, useColor bool) string {\n\tswitch to {\n\tcase domain.StepDone:\n\t\tif useColor {\n\t\t\treturn colorGreen + \"DONE\" + colorReset\n\t\t}\n\t\treturn \"DONE\"\n\tcase domain.StepAbort:\n\t\tif useColor {\n\t\t\treturn colorRed + \"ABORT\" + colorReset\n\t\t}\n\t\treturn \"ABORT\"\n\tdefault:\n\t\treturn to\n\t}\n}\n\n// renderCollects renders any collect conditions that reference this step.\nfunc renderCollects(buf *strings.Builder, w *domain.Workflow, stepName string, colorMap map[string]string, useColor bool) {\n\tfor _, c := range w.Collects {\n\t\t// Check if this step is part of the collect conditions\n\t\tvar parts []string\n\t\tinvolves := false\n\t\tfor _, cond := range c.Conditions {\n\t\t\tlabel := cond.Step + \":\" + cond.Result\n\t\t\tif useColor {\n\t\t\t\tif clr, ok := colorMap[cond.Result]; ok {\n\t\t\t\t\tlabel = cond.Step + \":\" + clr + cond.Result + colorReset\n\t\t\t\t}\n\t\t\t}\n\t\t\tparts = append(parts, label)\n\t\t\tif cond.Step == stepName {\n\t\t\t\tinvolves = true\n\t\t\t}\n\t\t}\n\t\t// Only render the collect on the last condition step to avoid duplication\n\t\tif involves && c.Conditions[len(c.Conditions)-1].Step == stepName {\n\t\t\tdest := formatDest(c.To, useColor)\n\t\t\tfmt.Fprintf(buf, \"    collect %s(%s) ‚îÄ‚îÄ‚ñ∂ %s\\n\", c.Mode, strings.Join(parts, \", \"), dest)\n\t\t}\n\t}\n}\n\n// bfsOrder returns steps in BFS order from the entry step.\n// Handles cycles by skipping already-visited nodes.\nfunc bfsOrder(w *domain.Workflow) []string {\n\tif w.EntryStep == \"\" {\n\t\treturn nil\n\t}\n\n\tvisited := map[string]bool{w.EntryStep: true}\n\tvar order []string\n\tqueue := []string{w.EntryStep}\n\n\tfor len(queue) > 0 {\n\t\tcurrent := queue[0]\n\t\tqueue = queue[1:]\n\t\torder = append(order, current)\n\n\t\t// Collect unique target steps in wire order\n\t\tfor _, wire := range w.Wiring {\n\t\t\tif wire.From != current {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tif wire.To == domain.StepDone || wire.To == domain.StepAbort {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tif visited[wire.To] {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tvisited[wire.To] = true\n\t\t\tqueue = append(queue, wire.To)\n\t\t}\n\t}\n\n\treturn order\n}\n","numLines":394,"startLine":1,"totalLines":394}}}
