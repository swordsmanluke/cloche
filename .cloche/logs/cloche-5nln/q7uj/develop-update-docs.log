{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011GUfT521vjatx5u18DAuAo","type":"tool_result","content":"     1‚Üípackage main\n     2‚Üí\n     3‚Üíimport (\n     4‚Üí\t\"context\"\n     5‚Üí\t\"encoding/json\"\n     6‚Üí\t\"errors\"\n     7‚Üí\t\"fmt\"\n     8‚Üí\t\"io\"\n     9‚Üí\t\"net/http\"\n    10‚Üí\t\"os\"\n    11‚Üí\t\"path/filepath\"\n    12‚Üí\t\"strings\"\n    13‚Üí\t\"time\"\n    14‚Üí\n    15‚Üí\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    16‚Üí\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    17‚Üí\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    18‚Üí\t\"github.com/cloche-dev/cloche/internal/runcontext\"\n    19‚Üí\t\"google.golang.org/grpc\"\n    20‚Üí\t\"google.golang.org/grpc/credentials/insecure\"\n    21‚Üí\t\"google.golang.org/grpc/metadata\"\n    22‚Üí)\n    23‚Üí\n    24‚Üífunc main() {\n    25‚Üí\tif len(os.Args) < 2 {\n    26‚Üí\t\tprintTopLevelHelp()\n    27‚Üí\t\tos.Exit(1)\n    28‚Üí\t}\n    29‚Üí\n    30‚Üí\t// Handle top-level help: \"cloche help\", \"cloche --help\", \"cloche -h\"\n    31‚Üí\tswitch os.Args[1] {\n    32‚Üí\tcase \"help\":\n    33‚Üí\t\tprintHelp(os.Args[2:])\n    34‚Üí\t\treturn\n    35‚Üí\tcase \"--help\", \"-h\":\n    36‚Üí\t\tprintTopLevelHelp()\n    37‚Üí\t\treturn\n    38‚Üí\t}\n    39‚Üí\n    40‚Üí\t// Commands that don't need a daemon connection\n    41‚Üí\tswitch os.Args[1] {\n    42‚Üí\tcase \"init\":\n    43‚Üí\t\tif hasHelpFlag(os.Args[2:]) {\n    44‚Üí\t\t\tprintSubcommandHelp(\"init\")\n    45‚Üí\t\t\treturn\n    46‚Üí\t\t}\n    47‚Üí\t\tcmdInit(os.Args[2:])\n    48‚Üí\t\treturn\n    49‚Üí\tcase \"health\":\n    50‚Üí\t\tif hasHelpFlag(os.Args[2:]) {\n    51‚Üí\t\t\tprintSubcommandHelp(\"health\")\n    52‚Üí\t\t\treturn\n    53‚Üí\t\t}\n    54‚Üí\t\tcmdHealth(os.Args[2:])\n    55‚Üí\t\treturn\n    56‚Üí\tcase \"get\":\n    57‚Üí\t\tif hasHelpFlag(os.Args[2:]) {\n    58‚Üí\t\t\tprintSubcommandHelp(\"get\")\n    59‚Üí\t\t\treturn\n    60‚Üí\t\t}\n    61‚Üí\t\tcmdGet(os.Args[2:])\n    62‚Üí\t\treturn\n    63‚Üí\tcase \"set\":\n    64‚Üí\t\tif hasHelpFlag(os.Args[2:]) {\n    65‚Üí\t\t\tprintSubcommandHelp(\"set\")\n    66‚Üí\t\t\treturn\n    67‚Üí\t\t}\n    68‚Üí\t\tcmdSet(os.Args[2:])\n    69‚Üí\t\treturn\n    70‚Üí\tcase \"tasks\":\n    71‚Üí\t\tif hasHelpFlag(os.Args[2:]) {\n    72‚Üí\t\t\tprintSubcommandHelp(\"tasks\")\n    73‚Üí\t\t\treturn\n    74‚Üí\t\t}\n    75‚Üí\t\tcmdTasks(os.Args[2:])\n    76‚Üí\t\treturn\n    77‚Üí\tcase \"workflow\":\n    78‚Üí\t\tif hasHelpFlag(os.Args[2:]) {\n    79‚Üí\t\t\tprintSubcommandHelp(\"workflow\")\n    80‚Üí\t\t\treturn\n    81‚Üí\t\t}\n    82‚Üí\t\tcmdWorkflow(os.Args[2:])\n    83‚Üí\t\treturn\n    84‚Üí\t}\n    85‚Üí\n    86‚Üí\t// Handle --help for daemon commands before connecting\n    87‚Üí\tdaemonCmds := map[string]bool{\n    88‚Üí\t\t\"run\": true, \"status\": true, \"logs\": true, \"poll\": true,\n    89‚Üí\t\t\"list\": true, \"stop\": true, \"delete\": true, \"loop\": true, \"shutdown\": true,\n    90‚Üí\t}\n    91‚Üí\tif daemonCmds[os.Args[1]] && hasHelpFlag(os.Args[2:]) {\n    92‚Üí\t\tprintSubcommandHelp(os.Args[1])\n    93‚Üí\t\treturn\n    94‚Üí\t}\n    95‚Üí\n    96‚Üí\t// Commands that need a daemon connection\n    97‚Üí\taddr := os.Getenv(\"CLOCHE_ADDR\")\n    98‚Üí\tif addr == \"\" {\n    99‚Üí\t\taddr = \"unix:///tmp/cloche.sock\"\n   100‚Üí\t}\n   101‚Üí\n   102‚Üí\tconn, err := grpc.NewClient(addr, grpc.WithTransportCredentials(insecure.NewCredentials()))\n   103‚Üí\tif err != nil {\n   104‚Üí\t\tfmt.Fprintf(os.Stderr, \"failed to connect: %v\\n\", err)\n   105‚Üí\t\tos.Exit(1)\n   106‚Üí\t}\n   107‚Üí\tdefer conn.Close()\n   108‚Üí\n   109‚Üí\tclient := pb.NewClocheServiceClient(conn)\n   110‚Üí\tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n   111‚Üí\tdefer cancel()\n   112‚Üí\n   113‚Üí\tswitch os.Args[1] {\n   114‚Üí\tcase \"run\":\n   115‚Üí\t\tcmdRun(ctx, client, os.Args[2:])\n   116‚Üí\tcase \"status\":\n   117‚Üí\t\tcmdStatus(ctx, client, os.Args[2:])\n   118‚Üí\tcase \"logs\":\n   119‚Üí\t\tcmdLogs(client, os.Args[2:])\n   120‚Üí\tcase \"poll\":\n   121‚Üí\t\tcmdPoll(client, os.Args[2:])\n   122‚Üí\tcase \"list\":\n   123‚Üí\t\tcmdList(ctx, client, os.Args[2:])\n   124‚Üí\tcase \"stop\":\n   125‚Üí\t\tcmdStop(ctx, client, os.Args[2:])\n   126‚Üí\tcase \"delete\":\n   127‚Üí\t\tcmdDelete(ctx, client, os.Args[2:])\n   128‚Üí\tcase \"loop\":\n   129‚Üí\t\tcmdLoop(ctx, client, os.Args[2:])\n   130‚Üí\tcase \"shutdown\":\n   131‚Üí\t\tcmdShutdown(ctx, client)\n   132‚Üí\tdefault:\n   133‚Üí\t\tfmt.Fprintf(os.Stderr, \"unknown command: %s\\n\\n\", os.Args[1])\n   134‚Üí\t\tprintTopLevelHelp()\n   135‚Üí\t\tos.Exit(1)\n   136‚Üí\t}\n   137‚Üí}\n   138‚Üí\n   139‚Üí\n   140‚Üífunc cmdRun(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   141‚Üí\tvar workflow, prompt, title string\n   142‚Üí\tvar keepContainer bool\n   143‚Üí\n   144‚Üí\tfor i := 0; i < len(args); i++ {\n   145‚Üí\t\tswitch args[i] {\n   146‚Üí\t\tcase \"--workflow\":\n   147‚Üí\t\t\tif i+1 < len(args) {\n   148‚Üí\t\t\t\ti++\n   149‚Üí\t\t\t\tworkflow = args[i]\n   150‚Üí\t\t\t}\n   151‚Üí\t\tcase \"--prompt\", \"-p\":\n   152‚Üí\t\t\tif i+1 < len(args) {\n   153‚Üí\t\t\t\ti++\n   154‚Üí\t\t\t\tprompt = args[i]\n   155‚Üí\t\t\t}\n   156‚Üí\t\tcase \"--title\":\n   157‚Üí\t\t\tif i+1 < len(args) {\n   158‚Üí\t\t\t\ti++\n   159‚Üí\t\t\t\ttitle = args[i]\n   160‚Üí\t\t\t}\n   161‚Üí\t\tcase \"--keep-container\":\n   162‚Üí\t\t\tkeepContainer = true\n   163‚Üí\t\tdefault:\n   164‚Üí\t\t\t// Support bare positional arg as workflow name for backwards compat\n   165‚Üí\t\t\tif workflow == \"\" && !strings.HasPrefix(args[i], \"-\") {\n   166‚Üí\t\t\t\tworkflow = args[i]\n   167‚Üí\t\t\t}\n   168‚Üí\t\t}\n   169‚Üí\t}\n   170‚Üí\n   171‚Üí\tif workflow == \"\" {\n   172‚Üí\t\tfmt.Fprintf(os.Stderr, \"usage: cloche run --workflow <name> [--prompt \\\"...\\\"] [--title \\\"...\\\"]\\n\")\n   173‚Üí\t\tos.Exit(1)\n   174‚Üí\t}\n   175‚Üí\n   176‚Üí\tcwd, _ := os.Getwd()\n   177‚Üí\n   178‚Üí\t// Resolve image from workflow file (soft failure ‚Äî fall back to daemon default)\n   179‚Üí\tvar image string\n   180‚Üí\twfPath := filepath.Join(cwd, \".cloche\", workflow+\".cloche\")\n   181‚Üí\tif data, err := os.ReadFile(wfPath); err == nil {\n   182‚Üí\t\tif wf, err := dsl.ParseForContainer(string(data)); err == nil {\n   183‚Üí\t\t\timage = wf.Config[\"container.image\"]\n   184‚Üí\t\t}\n   185‚Üí\t}\n   186‚Üí\n   187‚Üí\tresp, err := client.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n   188‚Üí\t\tWorkflowName:  workflow,\n   189‚Üí\t\tProjectDir:    cwd,\n   190‚Üí\t\tImage:         image,\n   191‚Üí\t\tPrompt:        prompt,\n   192‚Üí\t\tKeepContainer: keepContainer,\n   193‚Üí\t\tTitle:         title,\n   194‚Üí\t})\n   195‚Üí\tif err != nil {\n   196‚Üí\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   197‚Üí\t\tos.Exit(1)\n   198‚Üí\t}\n   199‚Üí\tfmt.Printf(\"Started run: %s\\n\", resp.RunId)\n   200‚Üí}\n   201‚Üí\n   202‚Üífunc cmdStatus(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   203‚Üí\tif len(args) < 1 {\n   204‚Üí\t\tfmt.Fprintf(os.Stderr, \"usage: cloche status <run-id>\\n\")\n   205‚Üí\t\tos.Exit(1)\n   206‚Üí\t}\n   207‚Üí\n   208‚Üí\tresp, err := client.GetStatus(ctx, &pb.GetStatusRequest{RunId: args[0]})\n   209‚Üí\tif err != nil {\n   210‚Üí\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   211‚Üí\t\tos.Exit(1)\n   212‚Üí\t}\n   213‚Üí\n   214‚Üí\tfmt.Printf(\"Run:       %s\\n\", resp.RunId)\n   215‚Üí\tif resp.Title != \"\" {\n   216‚Üí\t\tfmt.Printf(\"Title:     %s\\n\", resp.Title)\n   217‚Üí\t}\n   218‚Üí\tfmt.Printf(\"Workflow:  %s\\n\", resp.WorkflowName)\n   219‚Üí\tif resp.IsHost {\n   220‚Üí\t\tfmt.Printf(\"Type:      host\\n\")\n   221‚Üí\t} else {\n   222‚Üí\t\tfmt.Printf(\"Type:      container\\n\")\n   223‚Üí\t}\n   224‚Üí\tfmt.Printf(\"State:     %s\\n\", resp.State)\n   225‚Üí\tif resp.ContainerId != \"\" {\n   226‚Üí\t\tcid := resp.ContainerId\n   227‚Üí\t\tif len(cid) > 12 {\n   228‚Üí\t\t\tcid = cid[:12]\n   229‚Üí\t\t}\n   230‚Üí\t\tfmt.Printf(\"Container: %s\\n\", cid)\n   231‚Üí\t}\n   232‚Üí\tif resp.ErrorMessage != \"\" {\n   233‚Üí\t\tfmt.Printf(\"Error:     %s\\n\", resp.ErrorMessage)\n   234‚Üí\t}\n   235‚Üí\tfmt.Printf(\"Active:    %s\\n\", resp.CurrentStep)\n   236‚Üí\tfor _, exec := range resp.StepExecutions {\n   237‚Üí\t\tfmt.Printf(\"  %s: %s (%s -> %s)\\n\", exec.StepName, exec.Result, exec.StartedAt, exec.CompletedAt)\n   238‚Üí\t}\n   239‚Üí}\n   240‚Üí\n   241‚Üífunc cmdList(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   242‚Üí\tvar all bool\n   243‚Üí\tfor _, arg := range args {\n   244‚Üí\t\tif arg == \"--all\" {\n   245‚Üí\t\t\tall = true\n   246‚Üí\t\t}\n   247‚Üí\t}\n   248‚Üí\n   249‚Üí\treq := &pb.ListRunsRequest{}\n   250‚Üí\tif all {\n   251‚Üí\t\t// --all: show all runs across all projects (no time limit)\n   252‚Üí\t\treq.All = true\n   253‚Üí\t} else {\n   254‚Üí\t\t// Default: filter to current project\n   255‚Üí\t\tcwd, _ := os.Getwd()\n   256‚Üí\t\treq.ProjectDir = cwd\n   257‚Üí\t}\n   258‚Üí\n   259‚Üí\tresp, err := client.ListRuns(ctx, req)\n   260‚Üí\tif err != nil {\n   261‚Üí\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   262‚Üí\t\tos.Exit(1)\n   263‚Üí\t}\n   264‚Üí\n   265‚Üí\tif len(resp.Runs) == 0 {\n   266‚Üí\t\tfmt.Println(\"No runs found.\")\n   267‚Üí\t\treturn\n   268‚Üí\t}\n   269‚Üí\n   270‚Üí\tfor _, run := range resp.Runs {\n   271‚Üí\t\trunType := \"container\"\n   272‚Üí\t\tif run.IsHost {\n   273‚Üí\t\t\trunType = \"host\"\n   274‚Üí\t\t}\n   275‚Üí\t\tline := fmt.Sprintf(\"%s  %-20s  %-10s  %-9s\", run.RunId, run.WorkflowName, run.State, runType)\n   276‚Üí\t\tif run.Title != \"\" {\n   277‚Üí\t\t\tt := run.Title\n   278‚Üí\t\t\tif len(t) > 40 {\n   279‚Üí\t\t\t\tt = t[:37] + \"...\"\n   280‚Üí\t\t\t}\n   281‚Üí\t\t\tline += \"  \" + t\n   282‚Üí\t\t}\n   283‚Üí\t\tif run.ContainerId != \"\" {\n   284‚Üí\t\t\tline += \"  \" + run.ContainerId\n   285‚Üí\t\t}\n   286‚Üí\t\tif run.ErrorMessage != \"\" {\n   287‚Üí\t\t\terrMsg := run.ErrorMessage\n   288‚Üí\t\t\tif len(errMsg) > 60 {\n   289‚Üí\t\t\t\terrMsg = errMsg[:57] + \"...\"\n   290‚Üí\t\t\t}\n   291‚Üí\t\t\tline += \"  \" + errMsg\n   292‚Üí\t\t}\n   293‚Üí\t\tfmt.Println(line)\n   294‚Üí\t}\n   295‚Üí}\n   296‚Üí\n   297‚Üífunc cmdLogs(client pb.ClocheServiceClient, args []string) {\n   298‚Üí\tif len(args) < 1 {\n   299‚Üí\t\tfmt.Fprintf(os.Stderr, \"usage: cloche logs <run-id> [--step <name>] [--type <full|script|llm>] [-f]\\n\")\n   300‚Üí\t\tos.Exit(1)\n   301‚Üí\t}\n   302‚Üí\n   303‚Üí\tvar stepFilter, typeFilter string\n   304‚Üí\tvar follow bool\n   305‚Üí\trunID := args[0]\n   306‚Üí\n   307‚Üí\tfor i := 1; i < len(args); i++ {\n   308‚Üí\t\tswitch args[i] {\n   309‚Üí\t\tcase \"--step\":\n   310‚Üí\t\t\tif i+1 < len(args) {\n   311‚Üí\t\t\t\ti++\n   312‚Üí\t\t\t\tstepFilter = args[i]\n   313‚Üí\t\t\t}\n   314‚Üí\t\tcase \"--type\":\n   315‚Üí\t\t\tif i+1 < len(args) {\n   316‚Üí\t\t\t\ti++\n   317‚Üí\t\t\t\ttypeFilter = args[i]\n   318‚Üí\t\t\t}\n   319‚Üí\t\tcase \"--follow\", \"-f\":\n   320‚Üí\t\t\tfollow = true\n   321‚Üí\t\t}\n   322‚Üí\t}\n   323‚Üí\n   324‚Üí\t// Use background context ‚Äî log output can be large and follow mode blocks.\n   325‚Üí\tctx := context.Background()\n   326‚Üí\tif follow {\n   327‚Üí\t\tmd := metadata.Pairs(\"x-cloche-follow\", \"true\")\n   328‚Üí\t\tctx = metadata.NewOutgoingContext(ctx, md)\n   329‚Üí\t}\n   330‚Üí\n   331‚Üí\tstream, err := client.StreamLogs(ctx, &pb.StreamLogsRequest{\n   332‚Üí\t\tRunId:    runID,\n   333‚Üí\t\tStepName: stepFilter,\n   334‚Üí\t\tLogType:  typeFilter,\n   335‚Üí\t})\n   336‚Üí\tif err != nil {\n   337‚Üí\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   338‚Üí\t\tos.Exit(1)\n   339‚Üí\t}\n   340‚Üí\n   341‚Üí\tfor {\n   342‚Üí\t\tentry, err := stream.Recv()\n   343‚Üí\t\tif err != nil {\n   344‚Üí\t\t\tif errors.Is(err, io.EOF) {\n   345‚Üí\t\t\t\tbreak\n   346‚Üí\t\t\t}\n   347‚Üí\t\t\tfmt.Fprintf(os.Stderr, \"error reading logs: %v\\n\", err)\n   348‚Üí\t\t\tos.Exit(1)\n   349‚Üí\t\t}\n   350‚Üí\n   351‚Üí\t\tswitch entry.Type {\n   352‚Üí\t\tcase \"step_started\":\n   353‚Üí\t\t\tfmt.Printf(\"--- %s started ---\\n\", entry.StepName)\n   354‚Üí\t\t\tif entry.Message != \"\" {\n   355‚Üí\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n   356‚Üí\t\t\t}\n   357‚Üí\t\tcase \"step_completed\":\n   358‚Üí\t\t\tfmt.Printf(\"--- %s: %s ---\\n\", entry.StepName, entry.Result)\n   359‚Üí\t\t\tif entry.Message != \"\" {\n   360‚Üí\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n   361‚Üí\t\t\t}\n   362‚Üí\t\tcase \"run_completed\":\n   363‚Üí\t\t\tfmt.Printf(\"\\nRun result: %s\\n\", entry.Result)\n   364‚Üí\t\t\tif entry.Message != \"\" {\n   365‚Üí\t\t\t\tfmt.Printf(\"Error:      %s\\n\", entry.Message)\n   366‚Üí\t\t\t}\n   367‚Üí\t\tcase \"full_log\":\n   368‚Üí\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n   369‚Üí\t\tcase \"log\":\n   370‚Üí\t\t\t// Live-streamed log line from an active run.\n   371‚Üí\t\t\tfmt.Println(entry.Message)\n   372‚Üí\t\tdefault:\n   373‚Üí\t\t\t// Handles filtered log entries like \"script_log\", \"llm_log\", \"step_log\"\n   374‚Üí\t\t\tif entry.StepName != \"\" {\n   375‚Üí\t\t\t\tfmt.Printf(\"--- %s ---\\n\", entry.StepName)\n   376‚Üí\t\t\t}\n   377‚Üí\t\t\tif entry.Message != \"\" {\n   378‚Üí\t\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n   379‚Üí\t\t\t}\n   380‚Üí\t\t}\n   381‚Üí\t}\n   382‚Üí}\n   383‚Üí\n   384‚Üífunc cmdStop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   385‚Üí\tif len(args) < 1 {\n   386‚Üí\t\tfmt.Fprintf(os.Stderr, \"usage: cloche stop <run-id>\\n\")\n   387‚Üí\t\tos.Exit(1)\n   388‚Üí\t}\n   389‚Üí\n   390‚Üí\t_, err := client.StopRun(ctx, &pb.StopRunRequest{RunId: args[0]})\n   391‚Üí\tif err != nil {\n   392‚Üí\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   393‚Üí\t\tos.Exit(1)\n   394‚Üí\t}\n   395‚Üí\tfmt.Printf(\"Stopped run: %s\\n\", args[0])\n   396‚Üí}\n   397‚Üí\n   398‚Üífunc cmdDelete(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   399‚Üí\tif len(args) < 1 {\n   400‚Üí\t\tfmt.Fprintf(os.Stderr, \"usage: cloche delete <container-or-run-id>\\n\")\n   401‚Üí\t\tos.Exit(1)\n   402‚Üí\t}\n   403‚Üí\n   404‚Üí\t_, err := client.DeleteContainer(ctx, &pb.DeleteContainerRequest{Id: args[0]})\n   405‚Üí\tif err != nil {\n   406‚Üí\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   407‚Üí\t\tos.Exit(1)\n   408‚Üí\t}\n   409‚Üí\tfmt.Printf(\"Deleted container: %s\\n\", args[0])\n   410‚Üí}\n   411‚Üí\n   412‚Üífunc cmdLoop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   413‚Üí\tcwd, _ := os.Getwd()\n   414‚Üí\n   415‚Üí\t// Check for \"stop\" subcommand\n   416‚Üí\tif len(args) > 0 && args[0] == \"stop\" {\n   417‚Üí\t\t_, err := client.DisableLoop(ctx, &pb.DisableLoopRequest{ProjectDir: cwd})\n   418‚Üí\t\tif err != nil {\n   419‚Üí\t\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   420‚Üí\t\t\tos.Exit(1)\n   421‚Üí\t\t}\n   422‚Üí\t\tfmt.Println(\"Orchestration loop stopped.\")\n   423‚Üí\t\treturn\n   424‚Üí\t}\n   425‚Üí\n   426‚Üí\t// Default: 0 means \"use config value\" (server reads .cloche/config.toml).\n   427‚Üí\tvar maxConcurrent int32\n   428‚Üí\tfor i := 0; i < len(args); i++ {\n   429‚Üí\t\tswitch args[i] {\n   430‚Üí\t\tcase \"--max\":\n   431‚Üí\t\t\tif i+1 < len(args) {\n   432‚Üí\t\t\t\ti++\n   433‚Üí\t\t\t\tn, err := fmt.Sscanf(args[i], \"%d\", &maxConcurrent)\n   434‚Üí\t\t\t\tif n != 1 || err != nil {\n   435‚Üí\t\t\t\t\tfmt.Fprintf(os.Stderr, \"invalid --max value: %s\\n\", args[i])\n   436‚Üí\t\t\t\t\tos.Exit(1)\n   437‚Üí\t\t\t\t}\n   438‚Üí\t\t\t}\n   439‚Üí\t\t}\n   440‚Üí\t}\n   441‚Üí\n   442‚Üí\t_, err := client.EnableLoop(ctx, &pb.EnableLoopRequest{\n   443‚Üí\t\tProjectDir:    cwd,\n   444‚Üí\t\tMaxConcurrent: maxConcurrent,\n   445‚Üí\t})\n   446‚Üí\tif err != nil {\n   447‚Üí\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   448‚Üí\t\tos.Exit(1)\n   449‚Üí\t}\n   450‚Üí\tif maxConcurrent > 0 {\n   451‚Üí\t\tfmt.Printf(\"Orchestration loop started (max_concurrent=%d).\\n\", maxConcurrent)\n   452‚Üí\t} else {\n   453‚Üí\t\tfmt.Println(\"Orchestration loop started (using config defaults).\")\n   454‚Üí\t}\n   455‚Üí}\n   456‚Üí\n   457‚Üífunc cmdTasks(args []string) {\n   458‚Üí\t// Determine HTTP address from env\n   459‚Üí\thttpAddr := os.Getenv(\"CLOCHE_HTTP\")\n   460‚Üí\tif httpAddr == \"\" {\n   461‚Üí\t\thttpAddr = \"localhost:8080\"\n   462‚Üí\t}\n   463‚Üí\thttpAddr = strings.TrimPrefix(httpAddr, \"http://\")\n   464‚Üí\n   465‚Üí\t// Determine project label from --project flag or current directory\n   466‚Üí\tprojectDir := \"\"\n   467‚Üí\tfor i := 0; i < len(args); i++ {\n   468‚Üí\t\tswitch args[i] {\n   469‚Üí\t\tcase \"--project\":\n   470‚Üí\t\t\tif i+1 < len(args) {\n   471‚Üí\t\t\t\ti++\n   472‚Üí\t\t\t\tprojectDir = args[i]\n   473‚Üí\t\t\t}\n   474‚Üí\t\t}\n   475‚Üí\t}\n   476‚Üí\n   477‚Üí\tif projectDir == \"\" {\n   478‚Üí\t\tcwd, _ := os.Getwd()\n   479‚Üí\t\tprojectDir = filepath.Base(cwd)\n   480‚Üí\t}\n   481‚Üí\n   482‚Üí\ttasksURL := fmt.Sprintf(\"http://%s/api/projects/%s/tasks\", httpAddr, projectDir)\n   483‚Üí\tresp, err := http.Get(tasksURL)\n   484‚Üí\tif err != nil {\n   485‚Üí\t\tfmt.Fprintf(os.Stderr, \"error connecting to daemon web API: %v\\n\", err)\n   486‚Üí\t\tfmt.Fprintf(os.Stderr, \"hint: ensure CLOCHE_HTTP is set and the daemon is running with --http\\n\")\n   487‚Üí\t\tos.Exit(1)\n   488‚Üí\t}\n   489‚Üí\tdefer resp.Body.Close()\n   490‚Üí\n   491‚Üí\tif resp.StatusCode != 200 {\n   492‚Üí\t\tbody, _ := io.ReadAll(resp.Body)\n   493‚Üí\t\tfmt.Fprintf(os.Stderr, \"error: HTTP %d: %s\\n\", resp.StatusCode, strings.TrimSpace(string(body)))\n   494‚Üí\t\tos.Exit(1)\n   495‚Üí\t}\n   496‚Üí\n   497‚Üí\ttype taskEntry struct {\n   498‚Üí\t\tID          string `json:\"id\"`\n   499‚Üí\t\tStatus      string `json:\"status\"`\n   500‚Üí\t\tTitle       string `json:\"title\"`\n   501‚Üí\t\tDescription string `json:\"description\"`\n   502‚Üí\t\tAssigned    bool   `json:\"assigned\"`\n   503‚Üí\t\tAssignedAt  string `json:\"assigned_at\"`\n   504‚Üí\t\tRunID       string `json:\"run_id\"`\n   505‚Üí\t}\n   506‚Üí\n   507‚Üí\tvar tasks []taskEntry\n   508‚Üí\tif err := json.NewDecoder(resp.Body).Decode(&tasks); err != nil {\n   509‚Üí\t\tfmt.Fprintf(os.Stderr, \"error parsing response: %v\\n\", err)\n   510‚Üí\t\tos.Exit(1)\n   511‚Üí\t}\n   512‚Üí\n   513‚Üí\tif len(tasks) == 0 {\n   514‚Üí\t\tfmt.Println(\"No tasks found. (Is the orchestration loop running?)\")\n   515‚Üí\t\treturn\n   516‚Üí\t}\n   517‚Üí\n   518‚Üí\tfmt.Printf(\"%-20s  %-12s  %-10s  %-30s  %s\\n\", \"ID\", \"STATUS\", \"ASSIGNED\", \"RUN\", \"TITLE\")\n   519‚Üí\tfor _, t := range tasks {\n   520‚Üí\t\tstatus := t.Status\n   521‚Üí\t\tif status == \"\" {\n   522‚Üí\t\t\tstatus = \"open\"\n   523‚Üí\t\t}\n   524‚Üí\t\tassigned := \"-\"\n   525‚Üí\t\tif t.Assigned {\n   526‚Üí\t\t\tassigned = \"yes\"\n   527‚Üí\t\t}\n   528‚Üí\t\trunID := \"\"\n   529‚Üí\t\tif t.RunID != \"\" {\n   530‚Üí\t\t\trunID = t.RunID\n   531‚Üí\t\t\tif len(runID) > 30 {\n   532‚Üí\t\t\t\trunID = runID[:27] + \"...\"\n   533‚Üí\t\t\t}\n   534‚Üí\t\t}\n   535‚Üí\t\ttitle := t.Title\n   536‚Üí\t\tif len(title) > 40 {\n   537‚Üí\t\t\ttitle = title[:37] + \"...\"\n   538‚Üí\t\t}\n   539‚Üí\t\tfmt.Printf(\"%-20s  %-12s  %-10s  %-30s  %s\\n\", t.ID, status, assigned, runID, title)\n   540‚Üí\t}\n   541‚Üí}\n   542‚Üí\n   543‚Üífunc cmdShutdown(ctx context.Context, client pb.ClocheServiceClient) {\n   544‚Üí\t_, err := client.Shutdown(ctx, &pb.ShutdownRequest{})\n   545‚Üí\tif err != nil {\n   546‚Üí\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   547‚Üí\t\tos.Exit(1)\n   548‚Üí\t}\n   549‚Üí\tfmt.Println(\"Daemon shutting down.\")\n   550‚Üí}\n   551‚Üí\n   552‚Üí// resolveRunContext returns the project directory and run ID for context\n   553‚Üí// commands. The run ID comes from CLOCHE_RUN_ID and the project directory\n   554‚Üí// from CLOCHE_PROJECT_DIR (falling back to cwd).\n   555‚Üífunc resolveRunContext() (projectDir, runID string, err error) {\n   556‚Üí\trunID = os.Getenv(\"CLOCHE_RUN_ID\")\n   557‚Üí\tif runID == \"\" {\n   558‚Üí\t\treturn \"\", \"\", fmt.Errorf(\"CLOCHE_RUN_ID environment variable is not set\")\n   559‚Üí\t}\n   560‚Üí\tprojectDir = os.Getenv(\"CLOCHE_PROJECT_DIR\")\n   561‚Üí\tif projectDir == \"\" {\n   562‚Üí\t\tprojectDir, err = os.Getwd()\n   563‚Üí\t\tif err != nil {\n   564‚Üí\t\t\treturn \"\", \"\", fmt.Errorf(\"getting working directory: %w\", err)\n   565‚Üí\t\t}\n   566‚Üí\t}\n   567‚Üí\treturn projectDir, runID, nil\n   568‚Üí}\n   569‚Üí\n   570‚Üífunc cmdGet(args []string) {\n   571‚Üí\tif len(args) < 1 {\n   572‚Üí\t\tfmt.Fprintf(os.Stderr, \"usage: cloche get <key>\\n\")\n   573‚Üí\t\tos.Exit(1)\n   574‚Üí\t}\n   575‚Üí\n   576‚Üí\tprojectDir, runID, err := resolveRunContext()\n   577‚Üí\tif err != nil {\n   578‚Üí\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   579‚Üí\t\tos.Exit(1)\n   580‚Üí\t}\n   581‚Üí\n   582‚Üí\tval, ok, err := runcontext.Get(projectDir, runID, args[0])\n   583‚Üí\tif err != nil {\n   584‚Üí\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   585‚Üí\t\tos.Exit(1)\n   586‚Üí\t}\n   587‚Üí\tif !ok {\n   588‚Üí\t\tos.Exit(1)\n   589‚Üí\t}\n   590‚Üí\tfmt.Println(val)\n   591‚Üí}\n   592‚Üí\n   593‚Üífunc cmdSet(args []string) {\n   594‚Üí\tif len(args) < 2 {\n   595‚Üí\t\tfmt.Fprintf(os.Stderr, \"usage: cloche set <key> <value>\\n\")\n   596‚Üí\t\tfmt.Fprintf(os.Stderr, \"       cloche set <key> -     (read value from stdin)\\n\")\n   597‚Üí\t\tos.Exit(1)\n   598‚Üí\t}\n   599‚Üí\n   600‚Üí\tprojectDir, runID, err := resolveRunContext()\n   601‚Üí\tif err != nil {\n   602‚Üí\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   603‚Üí\t\tos.Exit(1)\n   604‚Üí\t}\n   605‚Üí\n   606‚Üí\tvalue := args[1]\n   607‚Üí\tif value == \"-\" {\n   608‚Üí\t\tdata, err := io.ReadAll(os.Stdin)\n   609‚Üí\t\tif err != nil {\n   610‚Üí\t\t\tfmt.Fprintf(os.Stderr, \"error reading stdin: %v\\n\", err)\n   611‚Üí\t\t\tos.Exit(1)\n   612‚Üí\t\t}\n   613‚Üí\t\tvalue = strings.TrimRight(string(data), \"\\n\")\n   614‚Üí\t}\n   615‚Üí\n   616‚Üí\tif err := runcontext.Set(projectDir, runID, args[0], value); err != nil {\n   617‚Üí\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   618‚Üí\t\tos.Exit(1)\n   619‚Üí\t}\n   620‚Üí}\n   621‚Üí"}]},"parent_tool_use_id":null,"session_id":"2090add2-0fe6-4270-9f3b-b52deb6bac91","uuid":"d59dcb5b-25df-4572-b7da-6e845721696b","tool_use_result":{"type":"text","file":{"filePath":"/workspace/cmd/cloche/main.go","content":"package main\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"errors\"\n\t\"fmt\"\n\t\"io\"\n\t\"net/http\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"strings\"\n\t\"time\"\n\n\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n\t\"github.com/cloche-dev/cloche/internal/dsl\"\n\t\"github.com/cloche-dev/cloche/internal/logstream\"\n\t\"github.com/cloche-dev/cloche/internal/runcontext\"\n\t\"google.golang.org/grpc\"\n\t\"google.golang.org/grpc/credentials/insecure\"\n\t\"google.golang.org/grpc/metadata\"\n)\n\nfunc main() {\n\tif len(os.Args) < 2 {\n\t\tprintTopLevelHelp()\n\t\tos.Exit(1)\n\t}\n\n\t// Handle top-level help: \"cloche help\", \"cloche --help\", \"cloche -h\"\n\tswitch os.Args[1] {\n\tcase \"help\":\n\t\tprintHelp(os.Args[2:])\n\t\treturn\n\tcase \"--help\", \"-h\":\n\t\tprintTopLevelHelp()\n\t\treturn\n\t}\n\n\t// Commands that don't need a daemon connection\n\tswitch os.Args[1] {\n\tcase \"init\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"init\")\n\t\t\treturn\n\t\t}\n\t\tcmdInit(os.Args[2:])\n\t\treturn\n\tcase \"health\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"health\")\n\t\t\treturn\n\t\t}\n\t\tcmdHealth(os.Args[2:])\n\t\treturn\n\tcase \"get\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"get\")\n\t\t\treturn\n\t\t}\n\t\tcmdGet(os.Args[2:])\n\t\treturn\n\tcase \"set\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"set\")\n\t\t\treturn\n\t\t}\n\t\tcmdSet(os.Args[2:])\n\t\treturn\n\tcase \"tasks\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"tasks\")\n\t\t\treturn\n\t\t}\n\t\tcmdTasks(os.Args[2:])\n\t\treturn\n\tcase \"workflow\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"workflow\")\n\t\t\treturn\n\t\t}\n\t\tcmdWorkflow(os.Args[2:])\n\t\treturn\n\t}\n\n\t// Handle --help for daemon commands before connecting\n\tdaemonCmds := map[string]bool{\n\t\t\"run\": true, \"status\": true, \"logs\": true, \"poll\": true,\n\t\t\"list\": true, \"stop\": true, \"delete\": true, \"loop\": true, \"shutdown\": true,\n\t}\n\tif daemonCmds[os.Args[1]] && hasHelpFlag(os.Args[2:]) {\n\t\tprintSubcommandHelp(os.Args[1])\n\t\treturn\n\t}\n\n\t// Commands that need a daemon connection\n\taddr := os.Getenv(\"CLOCHE_ADDR\")\n\tif addr == \"\" {\n\t\taddr = \"unix:///tmp/cloche.sock\"\n\t}\n\n\tconn, err := grpc.NewClient(addr, grpc.WithTransportCredentials(insecure.NewCredentials()))\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"failed to connect: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tdefer conn.Close()\n\n\tclient := pb.NewClocheServiceClient(conn)\n\tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n\tdefer cancel()\n\n\tswitch os.Args[1] {\n\tcase \"run\":\n\t\tcmdRun(ctx, client, os.Args[2:])\n\tcase \"status\":\n\t\tcmdStatus(ctx, client, os.Args[2:])\n\tcase \"logs\":\n\t\tcmdLogs(client, os.Args[2:])\n\tcase \"poll\":\n\t\tcmdPoll(client, os.Args[2:])\n\tcase \"list\":\n\t\tcmdList(ctx, client, os.Args[2:])\n\tcase \"stop\":\n\t\tcmdStop(ctx, client, os.Args[2:])\n\tcase \"delete\":\n\t\tcmdDelete(ctx, client, os.Args[2:])\n\tcase \"loop\":\n\t\tcmdLoop(ctx, client, os.Args[2:])\n\tcase \"shutdown\":\n\t\tcmdShutdown(ctx, client)\n\tdefault:\n\t\tfmt.Fprintf(os.Stderr, \"unknown command: %s\\n\\n\", os.Args[1])\n\t\tprintTopLevelHelp()\n\t\tos.Exit(1)\n\t}\n}\n\n\nfunc cmdRun(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tvar workflow, prompt, title string\n\tvar keepContainer bool\n\n\tfor i := 0; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--workflow\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tworkflow = args[i]\n\t\t\t}\n\t\tcase \"--prompt\", \"-p\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tprompt = args[i]\n\t\t\t}\n\t\tcase \"--title\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\ttitle = args[i]\n\t\t\t}\n\t\tcase \"--keep-container\":\n\t\t\tkeepContainer = true\n\t\tdefault:\n\t\t\t// Support bare positional arg as workflow name for backwards compat\n\t\t\tif workflow == \"\" && !strings.HasPrefix(args[i], \"-\") {\n\t\t\t\tworkflow = args[i]\n\t\t\t}\n\t\t}\n\t}\n\n\tif workflow == \"\" {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche run --workflow <name> [--prompt \\\"...\\\"] [--title \\\"...\\\"]\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tcwd, _ := os.Getwd()\n\n\t// Resolve image from workflow file (soft failure ‚Äî fall back to daemon default)\n\tvar image string\n\twfPath := filepath.Join(cwd, \".cloche\", workflow+\".cloche\")\n\tif data, err := os.ReadFile(wfPath); err == nil {\n\t\tif wf, err := dsl.ParseForContainer(string(data)); err == nil {\n\t\t\timage = wf.Config[\"container.image\"]\n\t\t}\n\t}\n\n\tresp, err := client.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n\t\tWorkflowName:  workflow,\n\t\tProjectDir:    cwd,\n\t\tImage:         image,\n\t\tPrompt:        prompt,\n\t\tKeepContainer: keepContainer,\n\t\tTitle:         title,\n\t})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Printf(\"Started run: %s\\n\", resp.RunId)\n}\n\nfunc cmdStatus(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche status <run-id>\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tresp, err := client.GetStatus(ctx, &pb.GetStatusRequest{RunId: args[0]})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tfmt.Printf(\"Run:       %s\\n\", resp.RunId)\n\tif resp.Title != \"\" {\n\t\tfmt.Printf(\"Title:     %s\\n\", resp.Title)\n\t}\n\tfmt.Printf(\"Workflow:  %s\\n\", resp.WorkflowName)\n\tif resp.IsHost {\n\t\tfmt.Printf(\"Type:      host\\n\")\n\t} else {\n\t\tfmt.Printf(\"Type:      container\\n\")\n\t}\n\tfmt.Printf(\"State:     %s\\n\", resp.State)\n\tif resp.ContainerId != \"\" {\n\t\tcid := resp.ContainerId\n\t\tif len(cid) > 12 {\n\t\t\tcid = cid[:12]\n\t\t}\n\t\tfmt.Printf(\"Container: %s\\n\", cid)\n\t}\n\tif resp.ErrorMessage != \"\" {\n\t\tfmt.Printf(\"Error:     %s\\n\", resp.ErrorMessage)\n\t}\n\tfmt.Printf(\"Active:    %s\\n\", resp.CurrentStep)\n\tfor _, exec := range resp.StepExecutions {\n\t\tfmt.Printf(\"  %s: %s (%s -> %s)\\n\", exec.StepName, exec.Result, exec.StartedAt, exec.CompletedAt)\n\t}\n}\n\nfunc cmdList(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tvar all bool\n\tfor _, arg := range args {\n\t\tif arg == \"--all\" {\n\t\t\tall = true\n\t\t}\n\t}\n\n\treq := &pb.ListRunsRequest{}\n\tif all {\n\t\t// --all: show all runs across all projects (no time limit)\n\t\treq.All = true\n\t} else {\n\t\t// Default: filter to current project\n\t\tcwd, _ := os.Getwd()\n\t\treq.ProjectDir = cwd\n\t}\n\n\tresp, err := client.ListRuns(ctx, req)\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tif len(resp.Runs) == 0 {\n\t\tfmt.Println(\"No runs found.\")\n\t\treturn\n\t}\n\n\tfor _, run := range resp.Runs {\n\t\trunType := \"container\"\n\t\tif run.IsHost {\n\t\t\trunType = \"host\"\n\t\t}\n\t\tline := fmt.Sprintf(\"%s  %-20s  %-10s  %-9s\", run.RunId, run.WorkflowName, run.State, runType)\n\t\tif run.Title != \"\" {\n\t\t\tt := run.Title\n\t\t\tif len(t) > 40 {\n\t\t\t\tt = t[:37] + \"...\"\n\t\t\t}\n\t\t\tline += \"  \" + t\n\t\t}\n\t\tif run.ContainerId != \"\" {\n\t\t\tline += \"  \" + run.ContainerId\n\t\t}\n\t\tif run.ErrorMessage != \"\" {\n\t\t\terrMsg := run.ErrorMessage\n\t\t\tif len(errMsg) > 60 {\n\t\t\t\terrMsg = errMsg[:57] + \"...\"\n\t\t\t}\n\t\t\tline += \"  \" + errMsg\n\t\t}\n\t\tfmt.Println(line)\n\t}\n}\n\nfunc cmdLogs(client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche logs <run-id> [--step <name>] [--type <full|script|llm>] [-f]\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tvar stepFilter, typeFilter string\n\tvar follow bool\n\trunID := args[0]\n\n\tfor i := 1; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--step\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tstepFilter = args[i]\n\t\t\t}\n\t\tcase \"--type\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\ttypeFilter = args[i]\n\t\t\t}\n\t\tcase \"--follow\", \"-f\":\n\t\t\tfollow = true\n\t\t}\n\t}\n\n\t// Use background context ‚Äî log output can be large and follow mode blocks.\n\tctx := context.Background()\n\tif follow {\n\t\tmd := metadata.Pairs(\"x-cloche-follow\", \"true\")\n\t\tctx = metadata.NewOutgoingContext(ctx, md)\n\t}\n\n\tstream, err := client.StreamLogs(ctx, &pb.StreamLogsRequest{\n\t\tRunId:    runID,\n\t\tStepName: stepFilter,\n\t\tLogType:  typeFilter,\n\t})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tfor {\n\t\tentry, err := stream.Recv()\n\t\tif err != nil {\n\t\t\tif errors.Is(err, io.EOF) {\n\t\t\t\tbreak\n\t\t\t}\n\t\t\tfmt.Fprintf(os.Stderr, \"error reading logs: %v\\n\", err)\n\t\t\tos.Exit(1)\n\t\t}\n\n\t\tswitch entry.Type {\n\t\tcase \"step_started\":\n\t\t\tfmt.Printf(\"--- %s started ---\\n\", entry.StepName)\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n\t\t\t}\n\t\tcase \"step_completed\":\n\t\t\tfmt.Printf(\"--- %s: %s ---\\n\", entry.StepName, entry.Result)\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n\t\t\t}\n\t\tcase \"run_completed\":\n\t\t\tfmt.Printf(\"\\nRun result: %s\\n\", entry.Result)\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Printf(\"Error:      %s\\n\", entry.Message)\n\t\t\t}\n\t\tcase \"full_log\":\n\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n\t\tcase \"log\":\n\t\t\t// Live-streamed log line from an active run.\n\t\t\tfmt.Println(entry.Message)\n\t\tdefault:\n\t\t\t// Handles filtered log entries like \"script_log\", \"llm_log\", \"step_log\"\n\t\t\tif entry.StepName != \"\" {\n\t\t\t\tfmt.Printf(\"--- %s ---\\n\", entry.StepName)\n\t\t\t}\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n\t\t\t}\n\t\t}\n\t}\n}\n\nfunc cmdStop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche stop <run-id>\\n\")\n\t\tos.Exit(1)\n\t}\n\n\t_, err := client.StopRun(ctx, &pb.StopRunRequest{RunId: args[0]})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Printf(\"Stopped run: %s\\n\", args[0])\n}\n\nfunc cmdDelete(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche delete <container-or-run-id>\\n\")\n\t\tos.Exit(1)\n\t}\n\n\t_, err := client.DeleteContainer(ctx, &pb.DeleteContainerRequest{Id: args[0]})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Printf(\"Deleted container: %s\\n\", args[0])\n}\n\nfunc cmdLoop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tcwd, _ := os.Getwd()\n\n\t// Check for \"stop\" subcommand\n\tif len(args) > 0 && args[0] == \"stop\" {\n\t\t_, err := client.DisableLoop(ctx, &pb.DisableLoopRequest{ProjectDir: cwd})\n\t\tif err != nil {\n\t\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\t\tos.Exit(1)\n\t\t}\n\t\tfmt.Println(\"Orchestration loop stopped.\")\n\t\treturn\n\t}\n\n\t// Default: 0 means \"use config value\" (server reads .cloche/config.toml).\n\tvar maxConcurrent int32\n\tfor i := 0; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--max\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tn, err := fmt.Sscanf(args[i], \"%d\", &maxConcurrent)\n\t\t\t\tif n != 1 || err != nil {\n\t\t\t\t\tfmt.Fprintf(os.Stderr, \"invalid --max value: %s\\n\", args[i])\n\t\t\t\t\tos.Exit(1)\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\t_, err := client.EnableLoop(ctx, &pb.EnableLoopRequest{\n\t\tProjectDir:    cwd,\n\t\tMaxConcurrent: maxConcurrent,\n\t})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tif maxConcurrent > 0 {\n\t\tfmt.Printf(\"Orchestration loop started (max_concurrent=%d).\\n\", maxConcurrent)\n\t} else {\n\t\tfmt.Println(\"Orchestration loop started (using config defaults).\")\n\t}\n}\n\nfunc cmdTasks(args []string) {\n\t// Determine HTTP address from env\n\thttpAddr := os.Getenv(\"CLOCHE_HTTP\")\n\tif httpAddr == \"\" {\n\t\thttpAddr = \"localhost:8080\"\n\t}\n\thttpAddr = strings.TrimPrefix(httpAddr, \"http://\")\n\n\t// Determine project label from --project flag or current directory\n\tprojectDir := \"\"\n\tfor i := 0; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--project\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tprojectDir = args[i]\n\t\t\t}\n\t\t}\n\t}\n\n\tif projectDir == \"\" {\n\t\tcwd, _ := os.Getwd()\n\t\tprojectDir = filepath.Base(cwd)\n\t}\n\n\ttasksURL := fmt.Sprintf(\"http://%s/api/projects/%s/tasks\", httpAddr, projectDir)\n\tresp, err := http.Get(tasksURL)\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error connecting to daemon web API: %v\\n\", err)\n\t\tfmt.Fprintf(os.Stderr, \"hint: ensure CLOCHE_HTTP is set and the daemon is running with --http\\n\")\n\t\tos.Exit(1)\n\t}\n\tdefer resp.Body.Close()\n\n\tif resp.StatusCode != 200 {\n\t\tbody, _ := io.ReadAll(resp.Body)\n\t\tfmt.Fprintf(os.Stderr, \"error: HTTP %d: %s\\n\", resp.StatusCode, strings.TrimSpace(string(body)))\n\t\tos.Exit(1)\n\t}\n\n\ttype taskEntry struct {\n\t\tID          string `json:\"id\"`\n\t\tStatus      string `json:\"status\"`\n\t\tTitle       string `json:\"title\"`\n\t\tDescription string `json:\"description\"`\n\t\tAssigned    bool   `json:\"assigned\"`\n\t\tAssignedAt  string `json:\"assigned_at\"`\n\t\tRunID       string `json:\"run_id\"`\n\t}\n\n\tvar tasks []taskEntry\n\tif err := json.NewDecoder(resp.Body).Decode(&tasks); err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error parsing response: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tif len(tasks) == 0 {\n\t\tfmt.Println(\"No tasks found. (Is the orchestration loop running?)\")\n\t\treturn\n\t}\n\n\tfmt.Printf(\"%-20s  %-12s  %-10s  %-30s  %s\\n\", \"ID\", \"STATUS\", \"ASSIGNED\", \"RUN\", \"TITLE\")\n\tfor _, t := range tasks {\n\t\tstatus := t.Status\n\t\tif status == \"\" {\n\t\t\tstatus = \"open\"\n\t\t}\n\t\tassigned := \"-\"\n\t\tif t.Assigned {\n\t\t\tassigned = \"yes\"\n\t\t}\n\t\trunID := \"\"\n\t\tif t.RunID != \"\" {\n\t\t\trunID = t.RunID\n\t\t\tif len(runID) > 30 {\n\t\t\t\trunID = runID[:27] + \"...\"\n\t\t\t}\n\t\t}\n\t\ttitle := t.Title\n\t\tif len(title) > 40 {\n\t\t\ttitle = title[:37] + \"...\"\n\t\t}\n\t\tfmt.Printf(\"%-20s  %-12s  %-10s  %-30s  %s\\n\", t.ID, status, assigned, runID, title)\n\t}\n}\n\nfunc cmdShutdown(ctx context.Context, client pb.ClocheServiceClient) {\n\t_, err := client.Shutdown(ctx, &pb.ShutdownRequest{})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Println(\"Daemon shutting down.\")\n}\n\n// resolveRunContext returns the project directory and run ID for context\n// commands. The run ID comes from CLOCHE_RUN_ID and the project directory\n// from CLOCHE_PROJECT_DIR (falling back to cwd).\nfunc resolveRunContext() (projectDir, runID string, err error) {\n\trunID = os.Getenv(\"CLOCHE_RUN_ID\")\n\tif runID == \"\" {\n\t\treturn \"\", \"\", fmt.Errorf(\"CLOCHE_RUN_ID environment variable is not set\")\n\t}\n\tprojectDir = os.Getenv(\"CLOCHE_PROJECT_DIR\")\n\tif projectDir == \"\" {\n\t\tprojectDir, err = os.Getwd()\n\t\tif err != nil {\n\t\t\treturn \"\", \"\", fmt.Errorf(\"getting working directory: %w\", err)\n\t\t}\n\t}\n\treturn projectDir, runID, nil\n}\n\nfunc cmdGet(args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche get <key>\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tprojectDir, runID, err := resolveRunContext()\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tval, ok, err := runcontext.Get(projectDir, runID, args[0])\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tif !ok {\n\t\tos.Exit(1)\n\t}\n\tfmt.Println(val)\n}\n\nfunc cmdSet(args []string) {\n\tif len(args) < 2 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche set <key> <value>\\n\")\n\t\tfmt.Fprintf(os.Stderr, \"       cloche set <key> -     (read value from stdin)\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tprojectDir, runID, err := resolveRunContext()\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tvalue := args[1]\n\tif value == \"-\" {\n\t\tdata, err := io.ReadAll(os.Stdin)\n\t\tif err != nil {\n\t\t\tfmt.Fprintf(os.Stderr, \"error reading stdin: %v\\n\", err)\n\t\t\tos.Exit(1)\n\t\t}\n\t\tvalue = strings.TrimRight(string(data), \"\\n\")\n\t}\n\n\tif err := runcontext.Set(projectDir, runID, args[0], value); err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n}\n","numLines":621,"startLine":1,"totalLines":621}}}
