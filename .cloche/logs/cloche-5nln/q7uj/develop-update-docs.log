{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015cdFQ2yrxqo4C7dkP5Tj1X","type":"tool_result","content":"     1‚Üípackage main\n     2‚Üí\n     3‚Üíimport (\n     4‚Üí\t\"os\"\n     5‚Üí\t\"path/filepath\"\n     6‚Üí\t\"strings\"\n     7‚Üí\t\"testing\"\n     8‚Üí\n     9‚Üí\t\"github.com/cloche-dev/cloche/internal/domain\"\n    10‚Üí)\n    11‚Üí\n    12‚Üífunc TestBfsOrder_LinearWorkflow(t *testing.T) {\n    13‚Üí\twf := &domain.Workflow{\n    14‚Üí\t\tEntryStep: \"a\",\n    15‚Üí\t\tSteps: map[string]*domain.Step{\n    16‚Üí\t\t\t\"a\": {Name: \"a\", Results: []string{\"ok\"}},\n    17‚Üí\t\t\t\"b\": {Name: \"b\", Results: []string{\"ok\"}},\n    18‚Üí\t\t\t\"c\": {Name: \"c\", Results: []string{\"ok\"}},\n    19‚Üí\t\t},\n    20‚Üí\t\tWiring: []domain.Wire{\n    21‚Üí\t\t\t{From: \"a\", Result: \"ok\", To: \"b\"},\n    22‚Üí\t\t\t{From: \"b\", Result: \"ok\", To: \"c\"},\n    23‚Üí\t\t\t{From: \"c\", Result: \"ok\", To: \"done\"},\n    24‚Üí\t\t},\n    25‚Üí\t}\n    26‚Üí\n    27‚Üí\torder := bfsOrder(wf)\n    28‚Üí\tif len(order) != 3 {\n    29‚Üí\t\tt.Fatalf(\"expected 3 steps, got %d: %v\", len(order), order)\n    30‚Üí\t}\n    31‚Üí\tif order[0] != \"a\" || order[1] != \"b\" || order[2] != \"c\" {\n    32‚Üí\t\tt.Errorf(\"expected [a b c], got %v\", order)\n    33‚Üí\t}\n    34‚Üí}\n    35‚Üí\n    36‚Üífunc TestBfsOrder_WithCycle(t *testing.T) {\n    37‚Üí\twf := &domain.Workflow{\n    38‚Üí\t\tEntryStep: \"a\",\n    39‚Üí\t\tSteps: map[string]*domain.Step{\n    40‚Üí\t\t\t\"a\": {Name: \"a\", Results: []string{\"ok\", \"fail\"}},\n    41‚Üí\t\t\t\"b\": {Name: \"b\", Results: []string{\"ok\", \"retry\"}},\n    42‚Üí\t\t},\n    43‚Üí\t\tWiring: []domain.Wire{\n    44‚Üí\t\t\t{From: \"a\", Result: \"ok\", To: \"b\"},\n    45‚Üí\t\t\t{From: \"a\", Result: \"fail\", To: \"abort\"},\n    46‚Üí\t\t\t{From: \"b\", Result: \"ok\", To: \"done\"},\n    47‚Üí\t\t\t{From: \"b\", Result: \"retry\", To: \"a\"}, // cycle\n    48‚Üí\t\t},\n    49‚Üí\t}\n    50‚Üí\n    51‚Üí\torder := bfsOrder(wf)\n    52‚Üí\tif len(order) != 2 {\n    53‚Üí\t\tt.Fatalf(\"expected 2 steps (cycle skipped), got %d: %v\", len(order), order)\n    54‚Üí\t}\n    55‚Üí\tif order[0] != \"a\" || order[1] != \"b\" {\n    56‚Üí\t\tt.Errorf(\"expected [a b], got %v\", order)\n    57‚Üí\t}\n    58‚Üí}\n    59‚Üí\n    60‚Üífunc TestBfsOrder_EmptyWorkflow(t *testing.T) {\n    61‚Üí\twf := &domain.Workflow{Steps: map[string]*domain.Step{}}\n    62‚Üí\torder := bfsOrder(wf)\n    63‚Üí\tif len(order) != 0 {\n    64‚Üí\t\tt.Errorf(\"expected empty order, got %v\", order)\n    65‚Üí\t}\n    66‚Üí}\n    67‚Üí\n    68‚Üífunc TestGroupWiresByDest_Merging(t *testing.T) {\n    69‚Üí\twf := &domain.Workflow{\n    70‚Üí\t\tWiring: []domain.Wire{\n    71‚Üí\t\t\t{From: \"fix\", Result: \"success\", To: \"test\"},\n    72‚Üí\t\t\t{From: \"fix\", Result: \"fail\", To: \"abort\"},\n    73‚Üí\t\t\t{From: \"fix\", Result: \"give-up\", To: \"abort\"},\n    74‚Üí\t\t},\n    75‚Üí\t}\n    76‚Üí\n    77‚Üí\tgroups := groupWiresByDest(wf, \"fix\")\n    78‚Üí\tif len(groups) != 2 {\n    79‚Üí\t\tt.Fatalf(\"expected 2 groups (test + abort merged), got %d\", len(groups))\n    80‚Üí\t}\n    81‚Üí\n    82‚Üí\t// First group: success -> test\n    83‚Üí\tif groups[0].to != \"test\" || len(groups[0].results) != 1 || groups[0].results[0] != \"success\" {\n    84‚Üí\t\tt.Errorf(\"expected first group to be success->test, got %+v\", groups[0])\n    85‚Üí\t}\n    86‚Üí\n    87‚Üí\t// Second group: fail,give-up -> abort (merged)\n    88‚Üí\tif groups[1].to != \"abort\" || len(groups[1].results) != 2 {\n    89‚Üí\t\tt.Errorf(\"expected second group to be fail,give-up->abort, got %+v\", groups[1])\n    90‚Üí\t}\n    91‚Üí\tif groups[1].results[0] != \"fail\" || groups[1].results[1] != \"give-up\" {\n    92‚Üí\t\tt.Errorf(\"expected results [fail give-up], got %v\", groups[1].results)\n    93‚Üí\t}\n    94‚Üí}\n    95‚Üí\n    96‚Üífunc TestGroupWiresByDest_NoWires(t *testing.T) {\n    97‚Üí\twf := &domain.Workflow{\n    98‚Üí\t\tWiring: []domain.Wire{\n    99‚Üí\t\t\t{From: \"other\", Result: \"ok\", To: \"done\"},\n   100‚Üí\t\t},\n   101‚Üí\t}\n   102‚Üí\n   103‚Üí\tgroups := groupWiresByDest(wf, \"step\")\n   104‚Üí\tif len(groups) != 0 {\n   105‚Üí\t\tt.Errorf(\"expected no groups, got %d\", len(groups))\n   106‚Üí\t}\n   107‚Üí}\n   108‚Üí\n   109‚Üífunc TestBuildResultColorMap(t *testing.T) {\n   110‚Üí\twf := &domain.Workflow{\n   111‚Üí\t\tSteps: map[string]*domain.Step{\n   112‚Üí\t\t\t\"a\": {Name: \"a\", Results: []string{\"success\", \"fail\", \"retry\", \"skip\"}},\n   113‚Üí\t\t},\n   114‚Üí\t}\n   115‚Üí\n   116‚Üí\tcolorMap := buildResultColorMap(wf, []string{\"a\"})\n   117‚Üí\n   118‚Üí\tif colorMap[\"success\"] != colorGreen {\n   119‚Üí\t\tt.Error(\"success should be green\")\n   120‚Üí\t}\n   121‚Üí\tif colorMap[\"fail\"] != colorRed {\n   122‚Üí\t\tt.Error(\"fail should be red\")\n   123‚Üí\t}\n   124‚Üí\tif colorMap[\"retry\"] == \"\" {\n   125‚Üí\t\tt.Error(\"retry should have an assigned color\")\n   126‚Üí\t}\n   127‚Üí\tif colorMap[\"skip\"] == \"\" {\n   128‚Üí\t\tt.Error(\"skip should have an assigned color\")\n   129‚Üí\t}\n   130‚Üí\tif colorMap[\"retry\"] == colorMap[\"skip\"] {\n   131‚Üí\t\tt.Error(\"retry and skip should get different colors\")\n   132‚Üí\t}\n   133‚Üí}\n   134‚Üí\n   135‚Üífunc TestRenderWorkflowGraph_NoColor(t *testing.T) {\n   136‚Üí\twf := &domain.Workflow{\n   137‚Üí\t\tName:      \"test-wf\",\n   138‚Üí\t\tLocation:  domain.LocationContainer,\n   139‚Üí\t\tEntryStep: \"build\",\n   140‚Üí\t\tSteps: map[string]*domain.Step{\n   141‚Üí\t\t\t\"build\": {Name: \"build\", Type: domain.StepTypeScript, Results: []string{\"success\", \"fail\"}},\n   142‚Üí\t\t\t\"deploy\": {Name: \"deploy\", Type: domain.StepTypeAgent, Results: []string{\"success\"}},\n   143‚Üí\t\t},\n   144‚Üí\t\tWiring: []domain.Wire{\n   145‚Üí\t\t\t{From: \"build\", Result: \"success\", To: \"deploy\"},\n   146‚Üí\t\t\t{From: \"build\", Result: \"fail\", To: \"abort\"},\n   147‚Üí\t\t\t{From: \"deploy\", Result: \"success\", To: \"done\"},\n   148‚Üí\t\t},\n   149‚Üí\t}\n   150‚Üí\n   151‚Üí\toutput := renderWorkflowGraph(wf, false)\n   152‚Üí\n   153‚Üí\t// Check header\n   154‚Üí\tif !strings.Contains(output, `workflow \"test-wf\" (container)`) {\n   155‚Üí\t\tt.Error(\"missing workflow header\")\n   156‚Üí\t}\n   157‚Üí\n   158‚Üí\t// Check step boxes\n   159‚Üí\tif !strings.Contains(output, \"build\") {\n   160‚Üí\t\tt.Error(\"missing build step\")\n   161‚Üí\t}\n   162‚Üí\tif !strings.Contains(output, \"deploy\") {\n   163‚Üí\t\tt.Error(\"missing deploy step\")\n   164‚Üí\t}\n   165‚Üí\n   166‚Üí\t// Check box drawing characters\n   167‚Üí\tif !strings.Contains(output, \"‚îå\") || !strings.Contains(output, \"‚îò\") {\n   168‚Üí\t\tt.Error(\"missing box drawing characters\")\n   169‚Üí\t}\n   170‚Üí\n   171‚Üí\t// Check entry marker\n   172‚Üí\tif !strings.Contains(output, \"‚óÄ entry\") {\n   173‚Üí\t\tt.Error(\"missing entry marker\")\n   174‚Üí\t}\n   175‚Üí\n   176‚Üí\t// Check step types\n   177‚Üí\tif !strings.Contains(output, \"script\") {\n   178‚Üí\t\tt.Error(\"missing step type 'script'\")\n   179‚Üí\t}\n   180‚Üí\tif !strings.Contains(output, \"agent\") {\n   181‚Üí\t\tt.Error(\"missing step type 'agent'\")\n   182‚Üí\t}\n   183‚Üí\n   184‚Üí\t// Check wires\n   185‚Üí\tif !strings.Contains(output, \"success ‚îÄ‚îÄ‚ñ∂ deploy\") {\n   186‚Üí\t\tt.Error(\"missing success wire to deploy\")\n   187‚Üí\t}\n   188‚Üí\tif !strings.Contains(output, \"fail ‚îÄ‚îÄ‚ñ∂ ABORT\") {\n   189‚Üí\t\tt.Error(\"missing fail wire to ABORT\")\n   190‚Üí\t}\n   191‚Üí\tif !strings.Contains(output, \"success ‚îÄ‚îÄ‚ñ∂ DONE\") {\n   192‚Üí\t\tt.Error(\"missing success wire to DONE\")\n   193‚Üí\t}\n   194‚Üí\n   195‚Üí\t// Check tree branch characters\n   196‚Üí\tif !strings.Contains(output, \"‚îú‚îÄ‚îÄ\") {\n   197‚Üí\t\tt.Error(\"missing non-last branch character\")\n   198‚Üí\t}\n   199‚Üí\tif !strings.Contains(output, \"‚îî‚îÄ‚îÄ\") {\n   200‚Üí\t\tt.Error(\"missing last branch character\")\n   201‚Üí\t}\n   202‚Üí}\n   203‚Üí\n   204‚Üífunc TestRenderWorkflowGraph_WireMerging(t *testing.T) {\n   205‚Üí\twf := &domain.Workflow{\n   206‚Üí\t\tName:      \"merge-test\",\n   207‚Üí\t\tLocation:  domain.LocationContainer,\n   208‚Üí\t\tEntryStep: \"step1\",\n   209‚Üí\t\tSteps: map[string]*domain.Step{\n   210‚Üí\t\t\t\"step1\": {Name: \"step1\", Type: domain.StepTypeScript, Results: []string{\"success\", \"fail\", \"error\"}},\n   211‚Üí\t\t},\n   212‚Üí\t\tWiring: []domain.Wire{\n   213‚Üí\t\t\t{From: \"step1\", Result: \"success\", To: \"done\"},\n   214‚Üí\t\t\t{From: \"step1\", Result: \"fail\", To: \"abort\"},\n   215‚Üí\t\t\t{From: \"step1\", Result: \"error\", To: \"abort\"},\n   216‚Üí\t\t},\n   217‚Üí\t}\n   218‚Üí\n   219‚Üí\toutput := renderWorkflowGraph(wf, false)\n   220‚Üí\n   221‚Üí\t// fail and error should be merged into one wire to ABORT\n   222‚Üí\tif !strings.Contains(output, \"fail, error ‚îÄ‚îÄ‚ñ∂ ABORT\") {\n   223‚Üí\t\tt.Errorf(\"expected merged wire 'fail, error ‚îÄ‚îÄ‚ñ∂ ABORT', got:\\n%s\", output)\n   224‚Üí\t}\n   225‚Üí\n   226‚Üí\t// Should have exactly 2 wire lines (done + merged abort)\n   227‚Üí\tlines := strings.Split(output, \"\\n\")\n   228‚Üí\twireLines := 0\n   229‚Üí\tfor _, line := range lines {\n   230‚Üí\t\tif strings.Contains(line, \"‚îÄ‚îÄ‚ñ∂\") {\n   231‚Üí\t\t\twireLines++\n   232‚Üí\t\t}\n   233‚Üí\t}\n   234‚Üí\tif wireLines != 2 {\n   235‚Üí\t\tt.Errorf(\"expected 2 wire lines (1 done + 1 merged abort), got %d\", wireLines)\n   236‚Üí\t}\n   237‚Üí}\n   238‚Üí\n   239‚Üífunc TestRenderWorkflowGraph_WithColor(t *testing.T) {\n   240‚Üí\twf := &domain.Workflow{\n   241‚Üí\t\tName:      \"color-test\",\n   242‚Üí\t\tLocation:  domain.LocationHost,\n   243‚Üí\t\tEntryStep: \"step1\",\n   244‚Üí\t\tSteps: map[string]*domain.Step{\n   245‚Üí\t\t\t\"step1\": {Name: \"step1\", Type: domain.StepTypeScript, Results: []string{\"success\", \"fail\"}},\n   246‚Üí\t\t},\n   247‚Üí\t\tWiring: []domain.Wire{\n   248‚Üí\t\t\t{From: \"step1\", Result: \"success\", To: \"done\"},\n   249‚Üí\t\t\t{From: \"step1\", Result: \"fail\", To: \"abort\"},\n   250‚Üí\t\t},\n   251‚Üí\t}\n   252‚Üí\n   253‚Üí\toutput := renderWorkflowGraph(wf, true)\n   254‚Üí\n   255‚Üí\t// Check ANSI color codes are present\n   256‚Üí\tif !strings.Contains(output, colorGreen) {\n   257‚Üí\t\tt.Error(\"expected green color code for success\")\n   258‚Üí\t}\n   259‚Üí\tif !strings.Contains(output, colorRed) {\n   260‚Üí\t\tt.Error(\"expected red color code for fail\")\n   261‚Üí\t}\n   262‚Üí\tif !strings.Contains(output, colorReset) {\n   263‚Üí\t\tt.Error(\"expected color reset code\")\n   264‚Üí\t}\n   265‚Üí}\n   266‚Üí\n   267‚Üífunc TestRenderWorkflowGraph_HostLocation(t *testing.T) {\n   268‚Üí\twf := &domain.Workflow{\n   269‚Üí\t\tName:      \"host-wf\",\n   270‚Üí\t\tLocation:  domain.LocationHost,\n   271‚Üí\t\tEntryStep: \"run\",\n   272‚Üí\t\tSteps: map[string]*domain.Step{\n   273‚Üí\t\t\t\"run\": {Name: \"run\", Type: domain.StepTypeWorkflow, Results: []string{\"success\"}},\n   274‚Üí\t\t},\n   275‚Üí\t\tWiring: []domain.Wire{\n   276‚Üí\t\t\t{From: \"run\", Result: \"success\", To: \"done\"},\n   277‚Üí\t\t},\n   278‚Üí\t}\n   279‚Üí\n   280‚Üí\toutput := renderWorkflowGraph(wf, false)\n   281‚Üí\tif !strings.Contains(output, \"(host)\") {\n   282‚Üí\t\tt.Error(\"expected host location in header\")\n   283‚Üí\t}\n   284‚Üí\tif !strings.Contains(output, \"workflow\") {\n   285‚Üí\t\tt.Error(\"expected workflow step type\")\n   286‚Üí\t}\n   287‚Üí}\n   288‚Üí\n   289‚Üífunc TestRenderWorkflowGraph_OtherResultColors(t *testing.T) {\n   290‚Üí\twf := &domain.Workflow{\n   291‚Üí\t\tName:      \"multi-color\",\n   292‚Üí\t\tLocation:  domain.LocationContainer,\n   293‚Üí\t\tEntryStep: \"step1\",\n   294‚Üí\t\tSteps: map[string]*domain.Step{\n   295‚Üí\t\t\t\"step1\": {Name: \"step1\", Type: domain.StepTypeAgent, Results: []string{\"retry\", \"skip\", \"timeout\", \"partial\"}},\n   296‚Üí\t\t},\n   297‚Üí\t\tWiring: []domain.Wire{\n   298‚Üí\t\t\t{From: \"step1\", Result: \"retry\", To: \"done\"},\n   299‚Üí\t\t\t{From: \"step1\", Result: \"skip\", To: \"done\"},\n   300‚Üí\t\t\t{From: \"step1\", Result: \"timeout\", To: \"abort\"},\n   301‚Üí\t\t\t{From: \"step1\", Result: \"partial\", To: \"abort\"},\n   302‚Üí\t\t},\n   303‚Üí\t}\n   304‚Üí\n   305‚Üí\toutput := renderWorkflowGraph(wf, true)\n   306‚Üí\n   307‚Üí\t// Each \"other\" result should get a distinct color from the palette\n   308‚Üí\tif !strings.Contains(output, colorBlue) {\n   309‚Üí\t\tt.Error(\"expected blue color for first other result\")\n   310‚Üí\t}\n   311‚Üí\tif !strings.Contains(output, colorYellow) {\n   312‚Üí\t\tt.Error(\"expected yellow color for second other result\")\n   313‚Üí\t}\n   314‚Üí\tif !strings.Contains(output, colorOrange) {\n   315‚Üí\t\tt.Error(\"expected orange color for third other result\")\n   316‚Üí\t}\n   317‚Üí\tif !strings.Contains(output, colorMagenta) {\n   318‚Üí\t\tt.Error(\"expected magenta color for fourth other result\")\n   319‚Üí\t}\n   320‚Üí}\n   321‚Üí\n   322‚Üífunc TestRenderWorkflowGraph_ConsistentBoxWidth(t *testing.T) {\n   323‚Üí\twf := &domain.Workflow{\n   324‚Üí\t\tName:      \"width-test\",\n   325‚Üí\t\tLocation:  domain.LocationContainer,\n   326‚Üí\t\tEntryStep: \"a\",\n   327‚Üí\t\tSteps: map[string]*domain.Step{\n   328‚Üí\t\t\t\"a\":             {Name: \"a\", Type: domain.StepTypeScript, Results: []string{\"ok\"}},\n   329‚Üí\t\t\t\"long-step-name\": {Name: \"long-step-name\", Type: domain.StepTypeAgent, Results: []string{\"ok\"}},\n   330‚Üí\t\t},\n   331‚Üí\t\tWiring: []domain.Wire{\n   332‚Üí\t\t\t{From: \"a\", Result: \"ok\", To: \"long-step-name\"},\n   333‚Üí\t\t\t{From: \"long-step-name\", Result: \"ok\", To: \"done\"},\n   334‚Üí\t\t},\n   335‚Üí\t}\n   336‚Üí\n   337‚Üí\toutput := renderWorkflowGraph(wf, false)\n   338‚Üí\tlines := strings.Split(output, \"\\n\")\n   339‚Üí\n   340‚Üí\t// Find border lines (those with ‚îå or ‚îî)\n   341‚Üí\tvar borderLengths []int\n   342‚Üí\tfor _, line := range lines {\n   343‚Üí\t\tif strings.Contains(line, \"‚îå\") && strings.Contains(line, \"‚îê\") {\n   344‚Üí\t\t\tborderLengths = append(borderLengths, len(line))\n   345‚Üí\t\t}\n   346‚Üí\t}\n   347‚Üí\n   348‚Üí\tif len(borderLengths) < 2 {\n   349‚Üí\t\tt.Fatal(\"expected at least 2 border lines\")\n   350‚Üí\t}\n   351‚Üí\n   352‚Üí\t// All borders should have the same length\n   353‚Üí\tfor i := 1; i < len(borderLengths); i++ {\n   354‚Üí\t\tif borderLengths[i] != borderLengths[0] {\n   355‚Üí\t\t\tt.Errorf(\"inconsistent box widths: %d vs %d\", borderLengths[0], borderLengths[i])\n   356‚Üí\t\t}\n   357‚Üí\t}\n   358‚Üí}\n   359‚Üí\n   360‚Üífunc TestDiscoverWorkflows(t *testing.T) {\n   361‚Üí\tdir := t.TempDir()\n   362‚Üí\tclocheDir := filepath.Join(dir, \".cloche\")\n   363‚Üí\tos.MkdirAll(clocheDir, 0755)\n   364‚Üí\n   365‚Üí\t// Write a container workflow\n   366‚Üí\tos.WriteFile(filepath.Join(clocheDir, \"build.cloche\"), []byte(`workflow \"build\" {\n   367‚Üí  step compile {\n   368‚Üí    run = \"make\"\n   369‚Üí    results = [success, fail]\n   370‚Üí  }\n   371‚Üí  compile:success -> done\n   372‚Üí  compile:fail -> abort\n   373‚Üí}`), 0644)\n   374‚Üí\n   375‚Üí\t// Write a host workflow with two workflows\n   376‚Üí\tos.WriteFile(filepath.Join(clocheDir, \"host.cloche\"), []byte(`workflow \"plan\" {\n   377‚Üí  step pick {\n   378‚Üí    run = \"echo pick\"\n   379‚Üí    results = [success]\n   380‚Üí  }\n   381‚Üí  pick:success -> done\n   382‚Üí}\n   383‚Üí\n   384‚Üíworkflow \"run\" {\n   385‚Üí  step exec {\n   386‚Üí    run = \"echo run\"\n   387‚Üí    results = [success]\n   388‚Üí  }\n   389‚Üí  exec:success -> done\n   390‚Üí}`), 0644)\n   391‚Üí\n   392‚Üí\tinfos, err := discoverWorkflows(dir)\n   393‚Üí\tif err != nil {\n   394‚Üí\t\tt.Fatal(err)\n   395‚Üí\t}\n   396‚Üí\n   397‚Üí\t// Should find 3 workflows: 1 container + 2 host\n   398‚Üí\tif len(infos) != 3 {\n   399‚Üí\t\tt.Fatalf(\"expected 3 workflows, got %d\", len(infos))\n   400‚Üí\t}\n   401‚Üí\n   402‚Üí\tvar containerCount, hostCount int\n   403‚Üí\tnames := map[string]bool{}\n   404‚Üí\tfor _, info := range infos {\n   405‚Üí\t\tnames[info.name] = true\n   406‚Üí\t\tswitch info.location {\n   407‚Üí\t\tcase domain.LocationContainer:\n   408‚Üí\t\t\tcontainerCount++\n   409‚Üí\t\tcase domain.LocationHost:\n   410‚Üí\t\t\thostCount++\n   411‚Üí\t\t}\n   412‚Üí\t}\n   413‚Üí\n   414‚Üí\tif containerCount != 1 {\n   415‚Üí\t\tt.Errorf(\"expected 1 container workflow, got %d\", containerCount)\n   416‚Üí\t}\n   417‚Üí\tif hostCount != 2 {\n   418‚Üí\t\tt.Errorf(\"expected 2 host workflows, got %d\", hostCount)\n   419‚Üí\t}\n   420‚Üí\tfor _, name := range []string{\"build\", \"plan\", \"run\"} {\n   421‚Üí\t\tif !names[name] {\n   422‚Üí\t\t\tt.Errorf(\"missing workflow %q\", name)\n   423‚Üí\t\t}\n   424‚Üí\t}\n   425‚Üí}\n   426‚Üí\n   427‚Üífunc TestDiscoverWorkflows_NoClocheDir(t *testing.T) {\n   428‚Üí\tdir := t.TempDir()\n   429‚Üí\n   430‚Üí\tinfos, err := discoverWorkflows(dir)\n   431‚Üí\tif err != nil {\n   432‚Üí\t\tt.Fatal(err)\n   433‚Üí\t}\n   434‚Üí\tif len(infos) != 0 {\n   435‚Üí\t\tt.Errorf(\"expected 0 workflows, got %d\", len(infos))\n   436‚Üí\t}\n   437‚Üí}\n   438‚Üí\n   439‚Üífunc TestLoadWorkflow_Container(t *testing.T) {\n   440‚Üí\tdir := t.TempDir()\n   441‚Üí\tclocheDir := filepath.Join(dir, \".cloche\")\n   442‚Üí\tos.MkdirAll(clocheDir, 0755)\n   443‚Üí\n   444‚Üí\tos.WriteFile(filepath.Join(clocheDir, \"deploy.cloche\"), []byte(`workflow \"deploy\" {\n   445‚Üí  step ship {\n   446‚Üí    run = \"echo ship\"\n   447‚Üí    results = [success, fail]\n   448‚Üí  }\n   449‚Üí  ship:success -> done\n   450‚Üí  ship:fail -> abort\n   451‚Üí}`), 0644)\n   452‚Üí\n   453‚Üí\twf, err := loadWorkflow(dir, \"deploy\")\n   454‚Üí\tif err != nil {\n   455‚Üí\t\tt.Fatal(err)\n   456‚Üí\t}\n   457‚Üí\tif wf.Name != \"deploy\" {\n   458‚Üí\t\tt.Errorf(\"expected name 'deploy', got %q\", wf.Name)\n   459‚Üí\t}\n   460‚Üí\tif wf.Location != domain.LocationContainer {\n   461‚Üí\t\tt.Errorf(\"expected container location, got %q\", wf.Location)\n   462‚Üí\t}\n   463‚Üí}\n   464‚Üí\n   465‚Üífunc TestLoadWorkflow_Host(t *testing.T) {\n   466‚Üí\tdir := t.TempDir()\n   467‚Üí\tclocheDir := filepath.Join(dir, \".cloche\")\n   468‚Üí\tos.MkdirAll(clocheDir, 0755)\n   469‚Üí\n   470‚Üí\tos.WriteFile(filepath.Join(clocheDir, \"host.cloche\"), []byte(`workflow \"orchestrate\" {\n   471‚Üí  step dispatch {\n   472‚Üí    run = \"echo go\"\n   473‚Üí    results = [success]\n   474‚Üí  }\n   475‚Üí  dispatch:success -> done\n   476‚Üí}`), 0644)\n   477‚Üí\n   478‚Üí\twf, err := loadWorkflow(dir, \"orchestrate\")\n   479‚Üí\tif err != nil {\n   480‚Üí\t\tt.Fatal(err)\n   481‚Üí\t}\n   482‚Üí\tif wf.Name != \"orchestrate\" {\n   483‚Üí\t\tt.Errorf(\"expected name 'orchestrate', got %q\", wf.Name)\n   484‚Üí\t}\n   485‚Üí\tif wf.Location != domain.LocationHost {\n   486‚Üí\t\tt.Errorf(\"expected host location, got %q\", wf.Location)\n   487‚Üí\t}\n   488‚Üí}\n   489‚Üí\n   490‚Üífunc TestLoadWorkflow_NotFound(t *testing.T) {\n   491‚Üí\tdir := t.TempDir()\n   492‚Üí\tos.MkdirAll(filepath.Join(dir, \".cloche\"), 0755)\n   493‚Üí\n   494‚Üí\t_, err := loadWorkflow(dir, \"nonexistent\")\n   495‚Üí\tif err == nil {\n   496‚Üí\t\tt.Error(\"expected error for nonexistent workflow\")\n   497‚Üí\t}\n   498‚Üí\tif !strings.Contains(err.Error(), \"not found\") {\n   499‚Üí\t\tt.Errorf(\"expected 'not found' error, got: %v\", err)\n   500‚Üí\t}\n   501‚Üí}\n   502‚Üí\n   503‚Üífunc TestRenderWorkflowGraph_DevelopWorkflow(t *testing.T) {\n   504‚Üí\t// Simulate the develop workflow from the project\n   505‚Üí\twf := &domain.Workflow{\n   506‚Üí\t\tName:      \"develop\",\n   507‚Üí\t\tLocation:  domain.LocationContainer,\n   508‚Üí\t\tEntryStep: \"implement\",\n   509‚Üí\t\tSteps: map[string]*domain.Step{\n   510‚Üí\t\t\t\"implement\":   {Name: \"implement\", Type: domain.StepTypeAgent, Results: []string{\"success\", \"fail\"}},\n   511‚Üí\t\t\t\"test\":        {Name: \"test\", Type: domain.StepTypeScript, Results: []string{\"success\", \"fail\"}},\n   512‚Üí\t\t\t\"fix\":         {Name: \"fix\", Type: domain.StepTypeAgent, Results: []string{\"success\", \"fail\", \"give-up\"}},\n   513‚Üí\t\t\t\"update-docs\": {Name: \"update-docs\", Type: domain.StepTypeAgent, Results: []string{\"success\", \"fail\"}},\n   514‚Üí\t\t},\n   515‚Üí\t\tWiring: []domain.Wire{\n   516‚Üí\t\t\t{From: \"implement\", Result: \"success\", To: \"test\"},\n   517‚Üí\t\t\t{From: \"implement\", Result: \"fail\", To: \"abort\"},\n   518‚Üí\t\t\t{From: \"test\", Result: \"success\", To: \"update-docs\"},\n   519‚Üí\t\t\t{From: \"test\", Result: \"fail\", To: \"fix\"},\n   520‚Üí\t\t\t{From: \"fix\", Result: \"success\", To: \"test\"},\n   521‚Üí\t\t\t{From: \"fix\", Result: \"fail\", To: \"abort\"},\n   522‚Üí\t\t\t{From: \"fix\", Result: \"give-up\", To: \"abort\"},\n   523‚Üí\t\t\t{From: \"update-docs\", Result: \"success\", To: \"done\"},\n   524‚Üí\t\t\t{From: \"update-docs\", Result: \"fail\", To: \"done\"},\n   525‚Üí\t\t},\n   526‚Üí\t}\n   527‚Üí\n   528‚Üí\toutput := renderWorkflowGraph(wf, false)\n   529‚Üí\n   530‚Üí\t// Check BFS order: implement -> test -> update-docs -> fix\n   531‚Üí\t// (update-docs before fix because test:success wire comes before test:fail wire)\n   532‚Üí\tlines := strings.Split(output, \"\\n\")\n   533‚Üí\tstepBoxOrder := []string{}\n   534‚Üí\tfor _, line := range lines {\n   535‚Üí\t\tif strings.Contains(line, \"‚îÇ\") && strings.Contains(line, \"‚óÄ entry\") {\n   536‚Üí\t\t\tstepBoxOrder = append(stepBoxOrder, \"implement\")\n   537‚Üí\t\t} else if strings.Contains(line, \"‚îÇ\") && strings.Contains(line, \"script\") && strings.Contains(line, \"test\") {\n   538‚Üí\t\t\tstepBoxOrder = append(stepBoxOrder, \"test\")\n   539‚Üí\t\t} else if strings.Contains(line, \"‚îÇ\") && strings.Contains(line, \"update-docs\") {\n   540‚Üí\t\t\tstepBoxOrder = append(stepBoxOrder, \"update-docs\")\n   541‚Üí\t\t} else if strings.Contains(line, \"‚îÇ\") && strings.Contains(line, \"fix\") && strings.Contains(line, \"agent\") && !strings.Contains(line, \"update\") && !strings.Contains(line, \"implement\") {\n   542‚Üí\t\t\tstepBoxOrder = append(stepBoxOrder, \"fix\")\n   543‚Üí\t\t}\n   544‚Üí\t}\n   545‚Üí\n   546‚Üí\texpected := []string{\"implement\", \"test\", \"update-docs\", \"fix\"}\n   547‚Üí\tif len(stepBoxOrder) != len(expected) {\n   548‚Üí\t\tt.Fatalf(\"expected %d step boxes, got %d: %v\", len(expected), len(stepBoxOrder), stepBoxOrder)\n   549‚Üí\t}\n   550‚Üí\tfor i, name := range expected {\n   551‚Üí\t\tif stepBoxOrder[i] != name {\n   552‚Üí\t\t\tt.Errorf(\"step %d: expected %q, got %q (order: %v)\", i, name, stepBoxOrder[i], stepBoxOrder)\n   553‚Üí\t\t}\n   554‚Üí\t}\n   555‚Üí\n   556‚Üí\t// Check wire merging: fix's fail and give-up should merge to ABORT\n   557‚Üí\tif !strings.Contains(output, \"fail, give-up ‚îÄ‚îÄ‚ñ∂ ABORT\") {\n   558‚Üí\t\tt.Errorf(\"expected merged wire 'fail, give-up ‚îÄ‚îÄ‚ñ∂ ABORT' in output:\\n%s\", output)\n   559‚Üí\t}\n   560‚Üí\n   561‚Üí\t// Check wire merging: update-docs success and fail should merge to DONE\n   562‚Üí\tif !strings.Contains(output, \"success, fail ‚îÄ‚îÄ‚ñ∂ DONE\") {\n   563‚Üí\t\tt.Errorf(\"expected merged wire 'success, fail ‚îÄ‚îÄ‚ñ∂ DONE' in output:\\n%s\", output)\n   564‚Üí\t}\n   565‚Üí\n   566‚Üí\t// Check cycle reference: fix:success -> test (back reference)\n   567‚Üí\tif !strings.Contains(output, \"success ‚îÄ‚îÄ‚ñ∂ test\") {\n   568‚Üí\t\tt.Error(\"expected fix:success wire to test\")\n   569‚Üí\t}\n   570‚Üí}\n   571‚Üí\n   572‚Üífunc TestFormatDest(t *testing.T) {\n   573‚Üí\ttests := []struct {\n   574‚Üí\t\tto       string\n   575‚Üí\t\tcolor    bool\n   576‚Üí\t\texpected string\n   577‚Üí\t}{\n   578‚Üí\t\t{\"done\", false, \"DONE\"},\n   579‚Üí\t\t{\"abort\", false, \"ABORT\"},\n   580‚Üí\t\t{\"step_a\", false, \"step_a\"},\n   581‚Üí\t\t{\"done\", true, colorGreen + \"DONE\" + colorReset},\n   582‚Üí\t\t{\"abort\", true, colorRed + \"ABORT\" + colorReset},\n   583‚Üí\t\t{\"step_a\", true, \"step_a\"},\n   584‚Üí\t}\n   585‚Üí\n   586‚Üí\tfor _, tt := range tests {\n   587‚Üí\t\tgot := formatDest(tt.to, tt.color)\n   588‚Üí\t\tif got != tt.expected {\n   589‚Üí\t\t\tt.Errorf(\"formatDest(%q, %v) = %q, want %q\", tt.to, tt.color, got, tt.expected)\n   590‚Üí\t\t}\n   591‚Üí\t}\n   592‚Üí}\n   593‚Üí\n   594‚Üífunc TestRenderWorkflowGraph_CollectBlock(t *testing.T) {\n   595‚Üí\twf := &domain.Workflow{\n   596‚Üí\t\tName:      \"collect-test\",\n   597‚Üí\t\tLocation:  domain.LocationContainer,\n   598‚Üí\t\tEntryStep: \"step1\",\n   599‚Üí\t\tSteps: map[string]*domain.Step{\n   600‚Üí\t\t\t\"step1\": {Name: \"step1\", Type: domain.StepTypeScript, Results: []string{\"success\"}},\n   601‚Üí\t\t\t\"step2\": {Name: \"step2\", Type: domain.StepTypeScript, Results: []string{\"success\"}},\n   602‚Üí\t\t\t\"step3\": {Name: \"step3\", Type: domain.StepTypeScript, Results: []string{\"success\"}},\n   603‚Üí\t\t},\n   604‚Üí\t\tWiring: []domain.Wire{\n   605‚Üí\t\t\t{From: \"step1\", Result: \"success\", To: \"step2\"},\n   606‚Üí\t\t\t{From: \"step1\", Result: \"success\", To: \"step3\"},\n   607‚Üí\t\t\t{From: \"step3\", Result: \"success\", To: \"done\"},\n   608‚Üí\t\t},\n   609‚Üí\t\tCollects: []domain.Collect{\n   610‚Üí\t\t\t{\n   611‚Üí\t\t\t\tMode: domain.CollectAll,\n   612‚Üí\t\t\t\tConditions: []domain.WireCondition{\n   613‚Üí\t\t\t\t\t{Step: \"step2\", Result: \"success\"},\n   614‚Üí\t\t\t\t\t{Step: \"step3\", Result: \"success\"},\n   615‚Üí\t\t\t\t},\n   616‚Üí\t\t\t\tTo: \"done\",\n   617‚Üí\t\t\t},\n   618‚Üí\t\t},\n   619‚Üí\t}\n   620‚Üí\n   621‚Üí\toutput := renderWorkflowGraph(wf, false)\n   622‚Üí\tif !strings.Contains(output, \"collect all\") {\n   623‚Üí\t\tt.Errorf(\"expected collect block in output:\\n%s\", output)\n   624‚Üí\t}\n   625‚Üí}\n   626‚Üí"}]},"parent_tool_use_id":null,"session_id":"2090add2-0fe6-4270-9f3b-b52deb6bac91","uuid":"af464c44-c8fb-47ed-9d36-2551b16fd4d1","tool_use_result":{"type":"text","file":{"filePath":"/workspace/cmd/cloche/workflow_test.go","content":"package main\n\nimport (\n\t\"os\"\n\t\"path/filepath\"\n\t\"strings\"\n\t\"testing\"\n\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n)\n\nfunc TestBfsOrder_LinearWorkflow(t *testing.T) {\n\twf := &domain.Workflow{\n\t\tEntryStep: \"a\",\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"a\": {Name: \"a\", Results: []string{\"ok\"}},\n\t\t\t\"b\": {Name: \"b\", Results: []string{\"ok\"}},\n\t\t\t\"c\": {Name: \"c\", Results: []string{\"ok\"}},\n\t\t},\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"a\", Result: \"ok\", To: \"b\"},\n\t\t\t{From: \"b\", Result: \"ok\", To: \"c\"},\n\t\t\t{From: \"c\", Result: \"ok\", To: \"done\"},\n\t\t},\n\t}\n\n\torder := bfsOrder(wf)\n\tif len(order) != 3 {\n\t\tt.Fatalf(\"expected 3 steps, got %d: %v\", len(order), order)\n\t}\n\tif order[0] != \"a\" || order[1] != \"b\" || order[2] != \"c\" {\n\t\tt.Errorf(\"expected [a b c], got %v\", order)\n\t}\n}\n\nfunc TestBfsOrder_WithCycle(t *testing.T) {\n\twf := &domain.Workflow{\n\t\tEntryStep: \"a\",\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"a\": {Name: \"a\", Results: []string{\"ok\", \"fail\"}},\n\t\t\t\"b\": {Name: \"b\", Results: []string{\"ok\", \"retry\"}},\n\t\t},\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"a\", Result: \"ok\", To: \"b\"},\n\t\t\t{From: \"a\", Result: \"fail\", To: \"abort\"},\n\t\t\t{From: \"b\", Result: \"ok\", To: \"done\"},\n\t\t\t{From: \"b\", Result: \"retry\", To: \"a\"}, // cycle\n\t\t},\n\t}\n\n\torder := bfsOrder(wf)\n\tif len(order) != 2 {\n\t\tt.Fatalf(\"expected 2 steps (cycle skipped), got %d: %v\", len(order), order)\n\t}\n\tif order[0] != \"a\" || order[1] != \"b\" {\n\t\tt.Errorf(\"expected [a b], got %v\", order)\n\t}\n}\n\nfunc TestBfsOrder_EmptyWorkflow(t *testing.T) {\n\twf := &domain.Workflow{Steps: map[string]*domain.Step{}}\n\torder := bfsOrder(wf)\n\tif len(order) != 0 {\n\t\tt.Errorf(\"expected empty order, got %v\", order)\n\t}\n}\n\nfunc TestGroupWiresByDest_Merging(t *testing.T) {\n\twf := &domain.Workflow{\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"fix\", Result: \"success\", To: \"test\"},\n\t\t\t{From: \"fix\", Result: \"fail\", To: \"abort\"},\n\t\t\t{From: \"fix\", Result: \"give-up\", To: \"abort\"},\n\t\t},\n\t}\n\n\tgroups := groupWiresByDest(wf, \"fix\")\n\tif len(groups) != 2 {\n\t\tt.Fatalf(\"expected 2 groups (test + abort merged), got %d\", len(groups))\n\t}\n\n\t// First group: success -> test\n\tif groups[0].to != \"test\" || len(groups[0].results) != 1 || groups[0].results[0] != \"success\" {\n\t\tt.Errorf(\"expected first group to be success->test, got %+v\", groups[0])\n\t}\n\n\t// Second group: fail,give-up -> abort (merged)\n\tif groups[1].to != \"abort\" || len(groups[1].results) != 2 {\n\t\tt.Errorf(\"expected second group to be fail,give-up->abort, got %+v\", groups[1])\n\t}\n\tif groups[1].results[0] != \"fail\" || groups[1].results[1] != \"give-up\" {\n\t\tt.Errorf(\"expected results [fail give-up], got %v\", groups[1].results)\n\t}\n}\n\nfunc TestGroupWiresByDest_NoWires(t *testing.T) {\n\twf := &domain.Workflow{\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"other\", Result: \"ok\", To: \"done\"},\n\t\t},\n\t}\n\n\tgroups := groupWiresByDest(wf, \"step\")\n\tif len(groups) != 0 {\n\t\tt.Errorf(\"expected no groups, got %d\", len(groups))\n\t}\n}\n\nfunc TestBuildResultColorMap(t *testing.T) {\n\twf := &domain.Workflow{\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"a\": {Name: \"a\", Results: []string{\"success\", \"fail\", \"retry\", \"skip\"}},\n\t\t},\n\t}\n\n\tcolorMap := buildResultColorMap(wf, []string{\"a\"})\n\n\tif colorMap[\"success\"] != colorGreen {\n\t\tt.Error(\"success should be green\")\n\t}\n\tif colorMap[\"fail\"] != colorRed {\n\t\tt.Error(\"fail should be red\")\n\t}\n\tif colorMap[\"retry\"] == \"\" {\n\t\tt.Error(\"retry should have an assigned color\")\n\t}\n\tif colorMap[\"skip\"] == \"\" {\n\t\tt.Error(\"skip should have an assigned color\")\n\t}\n\tif colorMap[\"retry\"] == colorMap[\"skip\"] {\n\t\tt.Error(\"retry and skip should get different colors\")\n\t}\n}\n\nfunc TestRenderWorkflowGraph_NoColor(t *testing.T) {\n\twf := &domain.Workflow{\n\t\tName:      \"test-wf\",\n\t\tLocation:  domain.LocationContainer,\n\t\tEntryStep: \"build\",\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"build\": {Name: \"build\", Type: domain.StepTypeScript, Results: []string{\"success\", \"fail\"}},\n\t\t\t\"deploy\": {Name: \"deploy\", Type: domain.StepTypeAgent, Results: []string{\"success\"}},\n\t\t},\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"build\", Result: \"success\", To: \"deploy\"},\n\t\t\t{From: \"build\", Result: \"fail\", To: \"abort\"},\n\t\t\t{From: \"deploy\", Result: \"success\", To: \"done\"},\n\t\t},\n\t}\n\n\toutput := renderWorkflowGraph(wf, false)\n\n\t// Check header\n\tif !strings.Contains(output, `workflow \"test-wf\" (container)`) {\n\t\tt.Error(\"missing workflow header\")\n\t}\n\n\t// Check step boxes\n\tif !strings.Contains(output, \"build\") {\n\t\tt.Error(\"missing build step\")\n\t}\n\tif !strings.Contains(output, \"deploy\") {\n\t\tt.Error(\"missing deploy step\")\n\t}\n\n\t// Check box drawing characters\n\tif !strings.Contains(output, \"‚îå\") || !strings.Contains(output, \"‚îò\") {\n\t\tt.Error(\"missing box drawing characters\")\n\t}\n\n\t// Check entry marker\n\tif !strings.Contains(output, \"‚óÄ entry\") {\n\t\tt.Error(\"missing entry marker\")\n\t}\n\n\t// Check step types\n\tif !strings.Contains(output, \"script\") {\n\t\tt.Error(\"missing step type 'script'\")\n\t}\n\tif !strings.Contains(output, \"agent\") {\n\t\tt.Error(\"missing step type 'agent'\")\n\t}\n\n\t// Check wires\n\tif !strings.Contains(output, \"success ‚îÄ‚îÄ‚ñ∂ deploy\") {\n\t\tt.Error(\"missing success wire to deploy\")\n\t}\n\tif !strings.Contains(output, \"fail ‚îÄ‚îÄ‚ñ∂ ABORT\") {\n\t\tt.Error(\"missing fail wire to ABORT\")\n\t}\n\tif !strings.Contains(output, \"success ‚îÄ‚îÄ‚ñ∂ DONE\") {\n\t\tt.Error(\"missing success wire to DONE\")\n\t}\n\n\t// Check tree branch characters\n\tif !strings.Contains(output, \"‚îú‚îÄ‚îÄ\") {\n\t\tt.Error(\"missing non-last branch character\")\n\t}\n\tif !strings.Contains(output, \"‚îî‚îÄ‚îÄ\") {\n\t\tt.Error(\"missing last branch character\")\n\t}\n}\n\nfunc TestRenderWorkflowGraph_WireMerging(t *testing.T) {\n\twf := &domain.Workflow{\n\t\tName:      \"merge-test\",\n\t\tLocation:  domain.LocationContainer,\n\t\tEntryStep: \"step1\",\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"step1\": {Name: \"step1\", Type: domain.StepTypeScript, Results: []string{\"success\", \"fail\", \"error\"}},\n\t\t},\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"step1\", Result: \"success\", To: \"done\"},\n\t\t\t{From: \"step1\", Result: \"fail\", To: \"abort\"},\n\t\t\t{From: \"step1\", Result: \"error\", To: \"abort\"},\n\t\t},\n\t}\n\n\toutput := renderWorkflowGraph(wf, false)\n\n\t// fail and error should be merged into one wire to ABORT\n\tif !strings.Contains(output, \"fail, error ‚îÄ‚îÄ‚ñ∂ ABORT\") {\n\t\tt.Errorf(\"expected merged wire 'fail, error ‚îÄ‚îÄ‚ñ∂ ABORT', got:\\n%s\", output)\n\t}\n\n\t// Should have exactly 2 wire lines (done + merged abort)\n\tlines := strings.Split(output, \"\\n\")\n\twireLines := 0\n\tfor _, line := range lines {\n\t\tif strings.Contains(line, \"‚îÄ‚îÄ‚ñ∂\") {\n\t\t\twireLines++\n\t\t}\n\t}\n\tif wireLines != 2 {\n\t\tt.Errorf(\"expected 2 wire lines (1 done + 1 merged abort), got %d\", wireLines)\n\t}\n}\n\nfunc TestRenderWorkflowGraph_WithColor(t *testing.T) {\n\twf := &domain.Workflow{\n\t\tName:      \"color-test\",\n\t\tLocation:  domain.LocationHost,\n\t\tEntryStep: \"step1\",\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"step1\": {Name: \"step1\", Type: domain.StepTypeScript, Results: []string{\"success\", \"fail\"}},\n\t\t},\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"step1\", Result: \"success\", To: \"done\"},\n\t\t\t{From: \"step1\", Result: \"fail\", To: \"abort\"},\n\t\t},\n\t}\n\n\toutput := renderWorkflowGraph(wf, true)\n\n\t// Check ANSI color codes are present\n\tif !strings.Contains(output, colorGreen) {\n\t\tt.Error(\"expected green color code for success\")\n\t}\n\tif !strings.Contains(output, colorRed) {\n\t\tt.Error(\"expected red color code for fail\")\n\t}\n\tif !strings.Contains(output, colorReset) {\n\t\tt.Error(\"expected color reset code\")\n\t}\n}\n\nfunc TestRenderWorkflowGraph_HostLocation(t *testing.T) {\n\twf := &domain.Workflow{\n\t\tName:      \"host-wf\",\n\t\tLocation:  domain.LocationHost,\n\t\tEntryStep: \"run\",\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"run\": {Name: \"run\", Type: domain.StepTypeWorkflow, Results: []string{\"success\"}},\n\t\t},\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"run\", Result: \"success\", To: \"done\"},\n\t\t},\n\t}\n\n\toutput := renderWorkflowGraph(wf, false)\n\tif !strings.Contains(output, \"(host)\") {\n\t\tt.Error(\"expected host location in header\")\n\t}\n\tif !strings.Contains(output, \"workflow\") {\n\t\tt.Error(\"expected workflow step type\")\n\t}\n}\n\nfunc TestRenderWorkflowGraph_OtherResultColors(t *testing.T) {\n\twf := &domain.Workflow{\n\t\tName:      \"multi-color\",\n\t\tLocation:  domain.LocationContainer,\n\t\tEntryStep: \"step1\",\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"step1\": {Name: \"step1\", Type: domain.StepTypeAgent, Results: []string{\"retry\", \"skip\", \"timeout\", \"partial\"}},\n\t\t},\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"step1\", Result: \"retry\", To: \"done\"},\n\t\t\t{From: \"step1\", Result: \"skip\", To: \"done\"},\n\t\t\t{From: \"step1\", Result: \"timeout\", To: \"abort\"},\n\t\t\t{From: \"step1\", Result: \"partial\", To: \"abort\"},\n\t\t},\n\t}\n\n\toutput := renderWorkflowGraph(wf, true)\n\n\t// Each \"other\" result should get a distinct color from the palette\n\tif !strings.Contains(output, colorBlue) {\n\t\tt.Error(\"expected blue color for first other result\")\n\t}\n\tif !strings.Contains(output, colorYellow) {\n\t\tt.Error(\"expected yellow color for second other result\")\n\t}\n\tif !strings.Contains(output, colorOrange) {\n\t\tt.Error(\"expected orange color for third other result\")\n\t}\n\tif !strings.Contains(output, colorMagenta) {\n\t\tt.Error(\"expected magenta color for fourth other result\")\n\t}\n}\n\nfunc TestRenderWorkflowGraph_ConsistentBoxWidth(t *testing.T) {\n\twf := &domain.Workflow{\n\t\tName:      \"width-test\",\n\t\tLocation:  domain.LocationContainer,\n\t\tEntryStep: \"a\",\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"a\":             {Name: \"a\", Type: domain.StepTypeScript, Results: []string{\"ok\"}},\n\t\t\t\"long-step-name\": {Name: \"long-step-name\", Type: domain.StepTypeAgent, Results: []string{\"ok\"}},\n\t\t},\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"a\", Result: \"ok\", To: \"long-step-name\"},\n\t\t\t{From: \"long-step-name\", Result: \"ok\", To: \"done\"},\n\t\t},\n\t}\n\n\toutput := renderWorkflowGraph(wf, false)\n\tlines := strings.Split(output, \"\\n\")\n\n\t// Find border lines (those with ‚îå or ‚îî)\n\tvar borderLengths []int\n\tfor _, line := range lines {\n\t\tif strings.Contains(line, \"‚îå\") && strings.Contains(line, \"‚îê\") {\n\t\t\tborderLengths = append(borderLengths, len(line))\n\t\t}\n\t}\n\n\tif len(borderLengths) < 2 {\n\t\tt.Fatal(\"expected at least 2 border lines\")\n\t}\n\n\t// All borders should have the same length\n\tfor i := 1; i < len(borderLengths); i++ {\n\t\tif borderLengths[i] != borderLengths[0] {\n\t\t\tt.Errorf(\"inconsistent box widths: %d vs %d\", borderLengths[0], borderLengths[i])\n\t\t}\n\t}\n}\n\nfunc TestDiscoverWorkflows(t *testing.T) {\n\tdir := t.TempDir()\n\tclocheDir := filepath.Join(dir, \".cloche\")\n\tos.MkdirAll(clocheDir, 0755)\n\n\t// Write a container workflow\n\tos.WriteFile(filepath.Join(clocheDir, \"build.cloche\"), []byte(`workflow \"build\" {\n  step compile {\n    run = \"make\"\n    results = [success, fail]\n  }\n  compile:success -> done\n  compile:fail -> abort\n}`), 0644)\n\n\t// Write a host workflow with two workflows\n\tos.WriteFile(filepath.Join(clocheDir, \"host.cloche\"), []byte(`workflow \"plan\" {\n  step pick {\n    run = \"echo pick\"\n    results = [success]\n  }\n  pick:success -> done\n}\n\nworkflow \"run\" {\n  step exec {\n    run = \"echo run\"\n    results = [success]\n  }\n  exec:success -> done\n}`), 0644)\n\n\tinfos, err := discoverWorkflows(dir)\n\tif err != nil {\n\t\tt.Fatal(err)\n\t}\n\n\t// Should find 3 workflows: 1 container + 2 host\n\tif len(infos) != 3 {\n\t\tt.Fatalf(\"expected 3 workflows, got %d\", len(infos))\n\t}\n\n\tvar containerCount, hostCount int\n\tnames := map[string]bool{}\n\tfor _, info := range infos {\n\t\tnames[info.name] = true\n\t\tswitch info.location {\n\t\tcase domain.LocationContainer:\n\t\t\tcontainerCount++\n\t\tcase domain.LocationHost:\n\t\t\thostCount++\n\t\t}\n\t}\n\n\tif containerCount != 1 {\n\t\tt.Errorf(\"expected 1 container workflow, got %d\", containerCount)\n\t}\n\tif hostCount != 2 {\n\t\tt.Errorf(\"expected 2 host workflows, got %d\", hostCount)\n\t}\n\tfor _, name := range []string{\"build\", \"plan\", \"run\"} {\n\t\tif !names[name] {\n\t\t\tt.Errorf(\"missing workflow %q\", name)\n\t\t}\n\t}\n}\n\nfunc TestDiscoverWorkflows_NoClocheDir(t *testing.T) {\n\tdir := t.TempDir()\n\n\tinfos, err := discoverWorkflows(dir)\n\tif err != nil {\n\t\tt.Fatal(err)\n\t}\n\tif len(infos) != 0 {\n\t\tt.Errorf(\"expected 0 workflows, got %d\", len(infos))\n\t}\n}\n\nfunc TestLoadWorkflow_Container(t *testing.T) {\n\tdir := t.TempDir()\n\tclocheDir := filepath.Join(dir, \".cloche\")\n\tos.MkdirAll(clocheDir, 0755)\n\n\tos.WriteFile(filepath.Join(clocheDir, \"deploy.cloche\"), []byte(`workflow \"deploy\" {\n  step ship {\n    run = \"echo ship\"\n    results = [success, fail]\n  }\n  ship:success -> done\n  ship:fail -> abort\n}`), 0644)\n\n\twf, err := loadWorkflow(dir, \"deploy\")\n\tif err != nil {\n\t\tt.Fatal(err)\n\t}\n\tif wf.Name != \"deploy\" {\n\t\tt.Errorf(\"expected name 'deploy', got %q\", wf.Name)\n\t}\n\tif wf.Location != domain.LocationContainer {\n\t\tt.Errorf(\"expected container location, got %q\", wf.Location)\n\t}\n}\n\nfunc TestLoadWorkflow_Host(t *testing.T) {\n\tdir := t.TempDir()\n\tclocheDir := filepath.Join(dir, \".cloche\")\n\tos.MkdirAll(clocheDir, 0755)\n\n\tos.WriteFile(filepath.Join(clocheDir, \"host.cloche\"), []byte(`workflow \"orchestrate\" {\n  step dispatch {\n    run = \"echo go\"\n    results = [success]\n  }\n  dispatch:success -> done\n}`), 0644)\n\n\twf, err := loadWorkflow(dir, \"orchestrate\")\n\tif err != nil {\n\t\tt.Fatal(err)\n\t}\n\tif wf.Name != \"orchestrate\" {\n\t\tt.Errorf(\"expected name 'orchestrate', got %q\", wf.Name)\n\t}\n\tif wf.Location != domain.LocationHost {\n\t\tt.Errorf(\"expected host location, got %q\", wf.Location)\n\t}\n}\n\nfunc TestLoadWorkflow_NotFound(t *testing.T) {\n\tdir := t.TempDir()\n\tos.MkdirAll(filepath.Join(dir, \".cloche\"), 0755)\n\n\t_, err := loadWorkflow(dir, \"nonexistent\")\n\tif err == nil {\n\t\tt.Error(\"expected error for nonexistent workflow\")\n\t}\n\tif !strings.Contains(err.Error(), \"not found\") {\n\t\tt.Errorf(\"expected 'not found' error, got: %v\", err)\n\t}\n}\n\nfunc TestRenderWorkflowGraph_DevelopWorkflow(t *testing.T) {\n\t// Simulate the develop workflow from the project\n\twf := &domain.Workflow{\n\t\tName:      \"develop\",\n\t\tLocation:  domain.LocationContainer,\n\t\tEntryStep: \"implement\",\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"implement\":   {Name: \"implement\", Type: domain.StepTypeAgent, Results: []string{\"success\", \"fail\"}},\n\t\t\t\"test\":        {Name: \"test\", Type: domain.StepTypeScript, Results: []string{\"success\", \"fail\"}},\n\t\t\t\"fix\":         {Name: \"fix\", Type: domain.StepTypeAgent, Results: []string{\"success\", \"fail\", \"give-up\"}},\n\t\t\t\"update-docs\": {Name: \"update-docs\", Type: domain.StepTypeAgent, Results: []string{\"success\", \"fail\"}},\n\t\t},\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"implement\", Result: \"success\", To: \"test\"},\n\t\t\t{From: \"implement\", Result: \"fail\", To: \"abort\"},\n\t\t\t{From: \"test\", Result: \"success\", To: \"update-docs\"},\n\t\t\t{From: \"test\", Result: \"fail\", To: \"fix\"},\n\t\t\t{From: \"fix\", Result: \"success\", To: \"test\"},\n\t\t\t{From: \"fix\", Result: \"fail\", To: \"abort\"},\n\t\t\t{From: \"fix\", Result: \"give-up\", To: \"abort\"},\n\t\t\t{From: \"update-docs\", Result: \"success\", To: \"done\"},\n\t\t\t{From: \"update-docs\", Result: \"fail\", To: \"done\"},\n\t\t},\n\t}\n\n\toutput := renderWorkflowGraph(wf, false)\n\n\t// Check BFS order: implement -> test -> update-docs -> fix\n\t// (update-docs before fix because test:success wire comes before test:fail wire)\n\tlines := strings.Split(output, \"\\n\")\n\tstepBoxOrder := []string{}\n\tfor _, line := range lines {\n\t\tif strings.Contains(line, \"‚îÇ\") && strings.Contains(line, \"‚óÄ entry\") {\n\t\t\tstepBoxOrder = append(stepBoxOrder, \"implement\")\n\t\t} else if strings.Contains(line, \"‚îÇ\") && strings.Contains(line, \"script\") && strings.Contains(line, \"test\") {\n\t\t\tstepBoxOrder = append(stepBoxOrder, \"test\")\n\t\t} else if strings.Contains(line, \"‚îÇ\") && strings.Contains(line, \"update-docs\") {\n\t\t\tstepBoxOrder = append(stepBoxOrder, \"update-docs\")\n\t\t} else if strings.Contains(line, \"‚îÇ\") && strings.Contains(line, \"fix\") && strings.Contains(line, \"agent\") && !strings.Contains(line, \"update\") && !strings.Contains(line, \"implement\") {\n\t\t\tstepBoxOrder = append(stepBoxOrder, \"fix\")\n\t\t}\n\t}\n\n\texpected := []string{\"implement\", \"test\", \"update-docs\", \"fix\"}\n\tif len(stepBoxOrder) != len(expected) {\n\t\tt.Fatalf(\"expected %d step boxes, got %d: %v\", len(expected), len(stepBoxOrder), stepBoxOrder)\n\t}\n\tfor i, name := range expected {\n\t\tif stepBoxOrder[i] != name {\n\t\t\tt.Errorf(\"step %d: expected %q, got %q (order: %v)\", i, name, stepBoxOrder[i], stepBoxOrder)\n\t\t}\n\t}\n\n\t// Check wire merging: fix's fail and give-up should merge to ABORT\n\tif !strings.Contains(output, \"fail, give-up ‚îÄ‚îÄ‚ñ∂ ABORT\") {\n\t\tt.Errorf(\"expected merged wire 'fail, give-up ‚îÄ‚îÄ‚ñ∂ ABORT' in output:\\n%s\", output)\n\t}\n\n\t// Check wire merging: update-docs success and fail should merge to DONE\n\tif !strings.Contains(output, \"success, fail ‚îÄ‚îÄ‚ñ∂ DONE\") {\n\t\tt.Errorf(\"expected merged wire 'success, fail ‚îÄ‚îÄ‚ñ∂ DONE' in output:\\n%s\", output)\n\t}\n\n\t// Check cycle reference: fix:success -> test (back reference)\n\tif !strings.Contains(output, \"success ‚îÄ‚îÄ‚ñ∂ test\") {\n\t\tt.Error(\"expected fix:success wire to test\")\n\t}\n}\n\nfunc TestFormatDest(t *testing.T) {\n\ttests := []struct {\n\t\tto       string\n\t\tcolor    bool\n\t\texpected string\n\t}{\n\t\t{\"done\", false, \"DONE\"},\n\t\t{\"abort\", false, \"ABORT\"},\n\t\t{\"step_a\", false, \"step_a\"},\n\t\t{\"done\", true, colorGreen + \"DONE\" + colorReset},\n\t\t{\"abort\", true, colorRed + \"ABORT\" + colorReset},\n\t\t{\"step_a\", true, \"step_a\"},\n\t}\n\n\tfor _, tt := range tests {\n\t\tgot := formatDest(tt.to, tt.color)\n\t\tif got != tt.expected {\n\t\t\tt.Errorf(\"formatDest(%q, %v) = %q, want %q\", tt.to, tt.color, got, tt.expected)\n\t\t}\n\t}\n}\n\nfunc TestRenderWorkflowGraph_CollectBlock(t *testing.T) {\n\twf := &domain.Workflow{\n\t\tName:      \"collect-test\",\n\t\tLocation:  domain.LocationContainer,\n\t\tEntryStep: \"step1\",\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"step1\": {Name: \"step1\", Type: domain.StepTypeScript, Results: []string{\"success\"}},\n\t\t\t\"step2\": {Name: \"step2\", Type: domain.StepTypeScript, Results: []string{\"success\"}},\n\t\t\t\"step3\": {Name: \"step3\", Type: domain.StepTypeScript, Results: []string{\"success\"}},\n\t\t},\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"step1\", Result: \"success\", To: \"step2\"},\n\t\t\t{From: \"step1\", Result: \"success\", To: \"step3\"},\n\t\t\t{From: \"step3\", Result: \"success\", To: \"done\"},\n\t\t},\n\t\tCollects: []domain.Collect{\n\t\t\t{\n\t\t\t\tMode: domain.CollectAll,\n\t\t\t\tConditions: []domain.WireCondition{\n\t\t\t\t\t{Step: \"step2\", Result: \"success\"},\n\t\t\t\t\t{Step: \"step3\", Result: \"success\"},\n\t\t\t\t},\n\t\t\t\tTo: \"done\",\n\t\t\t},\n\t\t},\n\t}\n\n\toutput := renderWorkflowGraph(wf, false)\n\tif !strings.Contains(output, \"collect all\") {\n\t\tt.Errorf(\"expected collect block in output:\\n%s\", output)\n\t}\n}\n","numLines":626,"startLine":1,"totalLines":626}}}
