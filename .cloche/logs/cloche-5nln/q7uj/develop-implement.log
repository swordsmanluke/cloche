{"type":"assistant","message":{"model":"claude-haiku-4-5-20251001","id":"msg_01MCepNfEo95LX6VfPBxp3p1","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_018za24sRhxFqJnv8GFvPJFZ","name":"Read","input":{"file_path":"/workspace/internal/dsl/parser.go"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":5,"cache_creation_input_tokens":17500,"cache_read_input_tokens":15797,"cache_creation":{"ephemeral_5m_input_tokens":17500,"ephemeral_1h_input_tokens":0},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_01R9B5ZLwaA81q4buXwXBtpB","session_id":"824f09ed-450b-4e33-88c5-1585f66e5eba","uuid":"618cb101-0584-4af5-993b-d066d392fb11"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018za24sRhxFqJnv8GFvPJFZ","type":"tool_result","content":"     1→package dsl\n     2→\n     3→import (\n     4→\t\"fmt\"\n     5→\t\"strconv\"\n     6→\t\"strings\"\n     7→\n     8→\t\"github.com/cloche-dev/cloche/internal/domain\"\n     9→)\n    10→\n    11→type Parser struct {\n    12→\tlexer    *Lexer\n    13→\tcurrent  Token\n    14→\tpeek     Token\n    15→\tlocation domain.WorkflowLocation\n    16→}\n    17→\n    18→// ParseOption configures the parser.\n    19→type ParseOption func(*Parser)\n    20→\n    21→// WithLocation sets the workflow location, enabling location-based validation.\n    22→func WithLocation(loc domain.WorkflowLocation) ParseOption {\n    23→\treturn func(p *Parser) {\n    24→\t\tp.location = loc\n    25→\t}\n    26→}\n    27→\n    28→func Parse(input string, opts ...ParseOption) (*domain.Workflow, error) {\n    29→\tp := &Parser{lexer: NewLexer(input)}\n    30→\tfor _, opt := range opts {\n    31→\t\topt(p)\n    32→\t}\n    33→\tp.advance() // load current\n    34→\tp.advance() // load peek\n    35→\treturn p.parseWorkflow()\n    36→}\n    37→\n    38→// ParseForHost parses a host.cloche file containing a single workflow.\n    39→func ParseForHost(input string) (*domain.Workflow, error) {\n    40→\treturn Parse(input, WithLocation(domain.LocationHost))\n    41→}\n    42→\n    43→// ParseAllForHost parses a host.cloche file that may contain multiple workflows.\n    44→// Returns a map of workflow name to workflow definition.\n    45→func ParseAllForHost(input string) (map[string]*domain.Workflow, error) {\n    46→\tp := &Parser{lexer: NewLexer(input), location: domain.LocationHost}\n    47→\tp.advance() // load current\n    48→\tp.advance() // load peek\n    49→\n    50→\tworkflows := make(map[string]*domain.Workflow)\n    51→\tfor p.current.Type != TokenEOF {\n    52→\t\twf, err := p.parseWorkflow()\n    53→\t\tif err != nil {\n    54→\t\t\treturn nil, err\n    55→\t\t}\n    56→\t\tif _, exists := workflows[wf.Name]; exists {\n    57→\t\t\treturn nil, fmt.Errorf(\"duplicate workflow name %q\", wf.Name)\n    58→\t\t}\n    59→\t\tworkflows[wf.Name] = wf\n    60→\t}\n    61→\n    62→\tif len(workflows) == 0 {\n    63→\t\treturn nil, fmt.Errorf(\"no workflows found in host.cloche\")\n    64→\t}\n    65→\n    66→\treturn workflows, nil\n    67→}\n    68→\n    69→// ParseForContainer parses a container workflow file.\n    70→func ParseForContainer(input string) (*domain.Workflow, error) {\n    71→\treturn Parse(input, WithLocation(domain.LocationContainer))\n    72→}\n    73→\n    74→func (p *Parser) advance() {\n    75→\tp.current = p.peek\n    76→\tp.peek = p.lexer.NextToken()\n    77→}\n    78→\n    79→func (p *Parser) expect(typ TokenType) (Token, error) {\n    80→\tif p.current.Type != typ {\n    81→\t\treturn p.current, fmt.Errorf(\"line %d col %d: expected %v, got %v (%q)\",\n    82→\t\t\tp.current.Line, p.current.Col, typ, p.current.Type, p.current.Literal)\n    83→\t}\n    84→\ttok := p.current\n    85→\tp.advance()\n    86→\treturn tok, nil\n    87→}\n    88→\n    89→func (p *Parser) expectIdent(value string) (Token, error) {\n    90→\tif p.current.Type != TokenIdent || p.current.Literal != value {\n    91→\t\treturn p.current, fmt.Errorf(\"line %d col %d: expected %q, got %q\",\n    92→\t\t\tp.current.Line, p.current.Col, value, p.current.Literal)\n    93→\t}\n    94→\ttok := p.current\n    95→\tp.advance()\n    96→\treturn tok, nil\n    97→}\n    98→\n    99→func (p *Parser) parseWorkflow() (*domain.Workflow, error) {\n   100→\tif _, err := p.expectIdent(\"workflow\"); err != nil {\n   101→\t\treturn nil, err\n   102→\t}\n   103→\n   104→\tnameTok, err := p.expect(TokenString)\n   105→\tif err != nil {\n   106→\t\treturn nil, fmt.Errorf(\"expected workflow name string: %w\", err)\n   107→\t}\n   108→\n   109→\tif _, err := p.expect(TokenLBrace); err != nil {\n   110→\t\treturn nil, err\n   111→\t}\n   112→\n   113→\twf := &domain.Workflow{\n   114→\t\tName:     nameTok.Literal,\n   115→\t\tLocation: p.location,\n   116→\t\tSteps:    make(map[string]*domain.Step),\n   117→\t\tConfig:   make(map[string]string),\n   118→\t}\n   119→\n   120→\tfor p.current.Type != TokenRBrace && p.current.Type != TokenEOF {\n   121→\t\tif p.current.Type == TokenIdent && p.current.Literal == \"step\" {\n   122→\t\t\tstep, err := p.parseStep()\n   123→\t\t\tif err != nil {\n   124→\t\t\t\treturn nil, err\n   125→\t\t\t}\n   126→\t\t\twf.Steps[step.Name] = step\n   127→\t\t\tif wf.EntryStep == \"\" {\n   128→\t\t\t\twf.EntryStep = step.Name\n   129→\t\t\t}\n   130→\t\t} else if p.current.Type == TokenIdent && p.current.Literal == \"collect\" {\n   131→\t\t\tcollect, err := p.parseCollect()\n   132→\t\t\tif err != nil {\n   133→\t\t\t\treturn nil, err\n   134→\t\t\t}\n   135→\t\t\twf.Collects = append(wf.Collects, collect)\n   136→\t\t} else if p.current.Type == TokenIdent && p.peek.Type == TokenLBrace {\n   137→\t\t\tif err := p.parseWorkflowConfig(wf); err != nil {\n   138→\t\t\t\treturn nil, err\n   139→\t\t\t}\n   140→\t\t} else if p.current.Type == TokenIdent && p.peek.Type == TokenColon {\n   141→\t\t\twire, err := p.parseWire()\n   142→\t\t\tif err != nil {\n   143→\t\t\t\treturn nil, err\n   144→\t\t\t}\n   145→\t\t\twf.Wiring = append(wf.Wiring, wire)\n   146→\t\t} else {\n   147→\t\t\treturn nil, fmt.Errorf(\"line %d col %d: unexpected token %q\", p.current.Line, p.current.Col, p.current.Literal)\n   148→\t\t}\n   149→\t}\n   150→\n   151→\tif _, err := p.expect(TokenRBrace); err != nil {\n   152→\t\treturn nil, err\n   153→\t}\n   154→\n   155→\tif wf.Location != \"\" {\n   156→\t\tif err := wf.ValidateLocation(); err != nil {\n   157→\t\t\treturn nil, err\n   158→\t\t}\n   159→\t}\n   160→\n   161→\treturn wf, nil\n   162→}\n   163→\n   164→func (p *Parser) parseWorkflowConfig(wf *domain.Workflow) error {\n   165→\tprefix := p.current.Literal // e.g. \"container\"\n   166→\tp.advance()                 // consume prefix ident\n   167→\n   168→\tif _, err := p.expect(TokenLBrace); err != nil {\n   169→\t\treturn err\n   170→\t}\n   171→\n   172→\tfor p.current.Type != TokenRBrace && p.current.Type != TokenEOF {\n   173→\t\tkeyTok, err := p.expect(TokenIdent)\n   174→\t\tif err != nil {\n   175→\t\t\treturn fmt.Errorf(\"expected field name: %w\", err)\n   176→\t\t}\n   177→\n   178→\t\tif _, err := p.expect(TokenEquals); err != nil {\n   179→\t\t\treturn err\n   180→\t\t}\n   181→\n   182→\t\tval, err := p.parseValue()\n   183→\t\tif err != nil {\n   184→\t\t\treturn err\n   185→\t\t}\n   186→\n   187→\t\twf.Config[prefix+\".\"+keyTok.Literal] = val\n   188→\t}\n   189→\n   190→\tif _, err := p.expect(TokenRBrace); err != nil {\n   191→\t\treturn err\n   192→\t}\n   193→\n   194→\treturn nil\n   195→}\n   196→\n   197→func (p *Parser) parseStep() (*domain.Step, error) {\n   198→\tp.advance() // consume \"step\"\n   199→\n   200→\tnameTok, err := p.expect(TokenIdent)\n   201→\tif err != nil {\n   202→\t\treturn nil, fmt.Errorf(\"expected step name: %w\", err)\n   203→\t}\n   204→\n   205→\tif _, err := p.expect(TokenLBrace); err != nil {\n   206→\t\treturn nil, err\n   207→\t}\n   208→\n   209→\tstep := &domain.Step{\n   210→\t\tName:   nameTok.Literal,\n   211→\t\tConfig: make(map[string]string),\n   212→\t}\n   213→\n   214→\tfor p.current.Type != TokenRBrace && p.current.Type != TokenEOF {\n   215→\t\tif err := p.parseStepField(step, \"\"); err != nil {\n   216→\t\t\treturn nil, err\n   217→\t\t}\n   218→\t}\n   219→\n   220→\tif _, err := p.expect(TokenRBrace); err != nil {\n   221→\t\treturn nil, err\n   222→\t}\n   223→\n   224→\t// Infer step type from content\n   225→\t_, hasPrompt := step.Config[\"prompt\"]\n   226→\t_, hasRun := step.Config[\"run\"]\n   227→\t_, hasWorkflowName := step.Config[\"workflow_name\"]\n   228→\n   229→\tcount := 0\n   230→\tif hasPrompt {\n   231→\t\tcount++\n   232→\t}\n   233→\tif hasRun {\n   234→\t\tcount++\n   235→\t}\n   236→\tif hasWorkflowName {\n   237→\t\tcount++\n   238→\t}\n   239→\n   240→\tif count > 1 {\n   241→\t\treturn nil, fmt.Errorf(\"step %q has multiple of 'prompt', 'run', 'workflow_name'; must have exactly one\", step.Name)\n   242→\t}\n   243→\n   244→\tswitch {\n   245→\tcase hasPrompt:\n   246→\t\tstep.Type = domain.StepTypeAgent\n   247→\tcase hasRun:\n   248→\t\tstep.Type = domain.StepTypeScript\n   249→\tcase hasWorkflowName:\n   250→\t\tstep.Type = domain.StepTypeWorkflow\n   251→\tdefault:\n   252→\t\treturn nil, fmt.Errorf(\"step %q has none of 'prompt', 'run', or 'workflow_name'; must have exactly one\", step.Name)\n   253→\t}\n   254→\n   255→\treturn step, nil\n   256→}\n   257→\n   258→func (p *Parser) parseStepField(step *domain.Step, prefix string) error {\n   259→\tkeyTok, err := p.expect(TokenIdent)\n   260→\tif err != nil {\n   261→\t\treturn fmt.Errorf(\"expected field name: %w\", err)\n   262→\t}\n   263→\n   264→\tkey := keyTok.Literal\n   265→\tif prefix != \"\" {\n   266→\t\tkey = prefix + \".\" + key\n   267→\t}\n   268→\n   269→\t// Sub-block (e.g., container { ... })\n   270→\tif p.current.Type == TokenLBrace {\n   271→\t\tp.advance() // consume {\n   272→\t\tfor p.current.Type != TokenRBrace && p.current.Type != TokenEOF {\n   273→\t\t\tif err := p.parseStepField(step, key); err != nil {\n   274→\t\t\t\treturn err\n   275→\t\t\t}\n   276→\t\t}\n   277→\t\tp.advance() // consume }\n   278→\t\treturn nil\n   279→\t}\n   280→\n   281→\tif _, err := p.expect(TokenEquals); err != nil {\n   282→\t\treturn err\n   283→\t}\n   284→\n   285→\tif key == \"results\" {\n   286→\t\tresults, err := p.parseIdentList()\n   287→\t\tif err != nil {\n   288→\t\t\treturn err\n   289→\t\t}\n   290→\t\tstep.Results = results\n   291→\t} else if p.current.Type == TokenLBracket {\n   292→\t\tvalues, err := p.parseStringList()\n   293→\t\tif err != nil {\n   294→\t\t\treturn err\n   295→\t\t}\n   296→\t\tstep.Config[key] = strings.Join(values, \",\")\n   297→\t} else {\n   298→\t\tval, err := p.parseValue()\n   299→\t\tif err != nil {\n   300→\t\t\treturn err\n   301→\t\t}\n   302→\t\tstep.Config[key] = val\n   303→\t}\n   304→\n   305→\treturn nil\n   306→}\n   307→\n   308→func (p *Parser) parseIdentList() ([]string, error) {\n   309→\tif _, err := p.expect(TokenLBracket); err != nil {\n   310→\t\treturn nil, err\n   311→\t}\n   312→\n   313→\tvar items []string\n   314→\tfor p.current.Type != TokenRBracket && p.current.Type != TokenEOF {\n   315→\t\ttok, err := p.expect(TokenIdent)\n   316→\t\tif err != nil {\n   317→\t\t\treturn nil, err\n   318→\t\t}\n   319→\t\titems = append(items, tok.Literal)\n   320→\t\tif p.current.Type == TokenComma {\n   321→\t\t\tp.advance()\n   322→\t\t}\n   323→\t}\n   324→\n   325→\tif _, err := p.expect(TokenRBracket); err != nil {\n   326→\t\treturn nil, err\n   327→\t}\n   328→\n   329→\treturn items, nil\n   330→}\n   331→\n   332→func (p *Parser) parseStringList() ([]string, error) {\n   333→\tif _, err := p.expect(TokenLBracket); err != nil {\n   334→\t\treturn nil, err\n   335→\t}\n   336→\n   337→\tvar items []string\n   338→\tfor p.current.Type != TokenRBracket && p.current.Type != TokenEOF {\n   339→\t\ttok, err := p.expect(TokenString)\n   340→\t\tif err != nil {\n   341→\t\t\treturn nil, err\n   342→\t\t}\n   343→\t\titems = append(items, tok.Literal)\n   344→\t\tif p.current.Type == TokenComma {\n   345→\t\t\tp.advance()\n   346→\t\t}\n   347→\t}\n   348→\n   349→\tif _, err := p.expect(TokenRBracket); err != nil {\n   350→\t\treturn nil, err\n   351→\t}\n   352→\n   353→\treturn items, nil\n   354→}\n   355→\n   356→func (p *Parser) parseValue() (string, error) {\n   357→\tif p.current.Type == TokenString {\n   358→\t\ttok := p.current\n   359→\t\tp.advance()\n   360→\t\treturn tok.Literal, nil\n   361→\t}\n   362→\n   363→\tif p.current.Type == TokenIdent {\n   364→\t\tvar buf strings.Builder\n   365→\t\tbuf.WriteString(p.current.Literal)\n   366→\t\tp.advance()\n   367→\n   368→\t\t// Function call: file(\"...\")\n   369→\t\tif p.current.Type == TokenLParen {\n   370→\t\t\tbuf.WriteRune('(')\n   371→\t\t\tp.advance()\n   372→\t\t\tfor p.current.Type != TokenRParen && p.current.Type != TokenEOF {\n   373→\t\t\t\tif p.current.Type == TokenString {\n   374→\t\t\t\t\tbuf.WriteRune('\"')\n   375→\t\t\t\t\tbuf.WriteString(p.current.Literal)\n   376→\t\t\t\t\tbuf.WriteRune('\"')\n   377→\t\t\t\t} else {\n   378→\t\t\t\t\tbuf.WriteString(p.current.Literal)\n   379→\t\t\t\t}\n   380→\t\t\t\tp.advance()\n   381→\t\t\t}\n   382→\t\t\tbuf.WriteRune(')')\n   383→\t\t\tp.advance() // consume )\n   384→\t\t}\n   385→\n   386→\t\t// Dotted path: step.code.output\n   387→\t\tfor p.current.Type == TokenDot {\n   388→\t\t\tbuf.WriteRune('.')\n   389→\t\t\tp.advance()\n   390→\t\t\tif p.current.Type == TokenIdent {\n   391→\t\t\t\tbuf.WriteString(p.current.Literal)\n   392→\t\t\t\tp.advance()\n   393→\t\t\t}\n   394→\t\t}\n   395→\n   396→\t\treturn buf.String(), nil\n   397→\t}\n   398→\n   399→\treturn \"\", fmt.Errorf(\"line %d col %d: expected value, got %q\", p.current.Line, p.current.Col, p.current.Literal)\n   400→}\n   401→\n   402→func (p *Parser) parseWire() (domain.Wire, error) {\n   403→\tfromTok := p.current\n   404→\tp.advance()\n   405→\n   406→\tif _, err := p.expect(TokenColon); err != nil {\n   407→\t\treturn domain.Wire{}, err\n   408→\t}\n   409→\n   410→\tresultTok, err := p.expect(TokenIdent)\n   411→\tif err != nil {\n   412→\t\treturn domain.Wire{}, err\n   413→\t}\n   414→\n   415→\tif _, err := p.expect(TokenArrow); err != nil {\n   416→\t\treturn domain.Wire{}, err\n   417→\t}\n   418→\n   419→\ttoTok, err := p.expect(TokenIdent)\n   420→\tif err != nil {\n   421→\t\treturn domain.Wire{}, err\n   422→\t}\n   423→\n   424→\tvar mappings []domain.OutputMapping\n   425→\tif p.current.Type == TokenLBracket {\n   426→\t\tmappings, err = p.parseOutputMappings()\n   427→\t\tif err != nil {\n   428→\t\t\treturn domain.Wire{}, err\n   429→\t\t}\n   430→\t}\n   431→\n   432→\treturn domain.Wire{\n   433→\t\tFrom:      fromTok.Literal,\n   434→\t\tResult:    resultTok.Literal,\n   435→\t\tTo:        toTok.Literal,\n   436→\t\tOutputMap: mappings,\n   437→\t}, nil\n   438→}\n   439→\n   440→func (p *Parser) parseOutputMappings() ([]domain.OutputMapping, error) {\n   441→\tif _, err := p.expect(TokenLBracket); err != nil {\n   442→\t\treturn nil, err\n   443→\t}\n   444→\n   445→\tvar mappings []domain.OutputMapping\n   446→\tfor p.current.Type != TokenRBracket && p.current.Type != TokenEOF {\n   447→\t\tkeyTok, err := p.expect(TokenIdent)\n   448→\t\tif err != nil {\n   449→\t\t\treturn nil, fmt.Errorf(\"expected mapping key: %w\", err)\n   450→\t\t}\n   451→\n   452→\t\tif _, err := p.expect(TokenEquals); err != nil {\n   453→\t\t\treturn nil, err\n   454→\t\t}\n   455→\n   456→\t\tpath, err := p.parseOutputPath()\n   457→\t\tif err != nil {\n   458→\t\t\treturn nil, err\n   459→\t\t}\n   460→\n   461→\t\tmappings = append(mappings, domain.OutputMapping{\n   462→\t\t\tEnvVar: keyTok.Literal,\n   463→\t\t\tPath:   path,\n   464→\t\t})\n   465→\n   466→\t\tif p.current.Type == TokenComma {\n   467→\t\t\tp.advance()\n   468→\t\t}\n   469→\t}\n   470→\n   471→\tif _, err := p.expect(TokenRBracket); err != nil {\n   472→\t\treturn nil, err\n   473→\t}\n   474→\n   475→\treturn mappings, nil\n   476→}\n   477→\n   478→func (p *Parser) parseOutputPath() (domain.OutputPath, error) {\n   479→\tif p.current.Type != TokenIdent || p.current.Literal != \"output\" {\n   480→\t\treturn domain.OutputPath{}, fmt.Errorf(\"line %d col %d: expected \\\"output\\\", got %q\",\n   481→\t\t\tp.current.Line, p.current.Col, p.current.Literal)\n   482→\t}\n   483→\tp.advance() // consume \"output\"\n   484→\n   485→\tvar segments []domain.PathSegment\n   486→\tfor {\n   487→\t\tif p.current.Type == TokenDot {\n   488→\t\t\tp.advance() // consume \".\"\n   489→\t\t\tfieldTok, err := p.expect(TokenIdent)\n   490→\t\t\tif err != nil {\n   491→\t\t\t\treturn domain.OutputPath{}, fmt.Errorf(\"expected field name after '.': %w\", err)\n   492→\t\t\t}\n   493→\t\t\tsegments = append(segments, domain.PathSegment{Kind: domain.SegmentField, Field: fieldTok.Literal})\n   494→\t\t} else if p.current.Type == TokenLBracket {\n   495→\t\t\tp.advance() // consume \"[\"\n   496→\t\t\tidxTok, err := p.expect(TokenInt)\n   497→\t\t\tif err != nil {\n   498→\t\t\t\treturn domain.OutputPath{}, fmt.Errorf(\"expected integer index: %w\", err)\n   499→\t\t\t}\n   500→\t\t\tidx, _ := strconv.Atoi(idxTok.Literal)\n   501→\t\t\tif _, err := p.expect(TokenRBracket); err != nil {\n   502→\t\t\t\treturn domain.OutputPath{}, err\n   503→\t\t\t}\n   504→\t\t\tsegments = append(segments, domain.PathSegment{Kind: domain.SegmentIndex, Index: idx})\n   505→\t\t} else {\n   506→\t\t\tbreak\n   507→\t\t}\n   508→\t}\n   509→\n   510→\treturn domain.OutputPath{Segments: segments}, nil\n   511→}\n   512→\n   513→func (p *Parser) parseCollect() (domain.Collect, error) {\n   514→\tp.advance() // consume \"collect\"\n   515→\n   516→\tmodeTok, err := p.expect(TokenIdent)\n   517→\tif err != nil {\n   518→\t\treturn domain.Collect{}, fmt.Errorf(\"expected 'all' or 'any': %w\", err)\n   519→\t}\n   520→\n   521→\tvar mode domain.CollectMode\n   522→\tswitch modeTok.Literal {\n   523→\tcase \"all\":\n   524→\t\tmode = domain.CollectAll\n   525→\tcase \"any\":\n   526→\t\tmode = domain.CollectAny\n   527→\tdefault:\n   528→\t\treturn domain.Collect{}, fmt.Errorf(\"line %d col %d: expected 'all' or 'any', got %q\",\n   529→\t\t\tmodeTok.Line, modeTok.Col, modeTok.Literal)\n   530→\t}\n   531→\n   532→\tif _, err := p.expect(TokenLParen); err != nil {\n   533→\t\treturn domain.Collect{}, err\n   534→\t}\n   535→\n   536→\tvar conditions []domain.WireCondition\n   537→\tfor p.current.Type != TokenRParen && p.current.Type != TokenEOF {\n   538→\t\tstepTok, err := p.expect(TokenIdent)\n   539→\t\tif err != nil {\n   540→\t\t\treturn domain.Collect{}, fmt.Errorf(\"expected step name in collect: %w\", err)\n   541→\t\t}\n   542→\t\tif _, err := p.expect(TokenColon); err != nil {\n   543→\t\t\treturn domain.Collect{}, err\n   544→\t\t}\n   545→\t\tresultTok, err := p.expect(TokenIdent)\n   546→\t\tif err != nil {\n   547→\t\t\treturn domain.Collect{}, fmt.Errorf(\"expected result name in collect: %w\", err)\n   548→\t\t}\n   549→\t\tconditions = append(conditions, domain.WireCondition{Step: stepTok.Literal, Result: resultTok.Literal})\n   550→\t\tif p.current.Type == TokenComma {\n   551→\t\t\tp.advance()\n   552→\t\t}\n   553→\t}\n   554→\n   555→\tif _, err := p.expect(TokenRParen); err != nil {\n   556→\t\treturn domain.Collect{}, err\n   557→\t}\n   558→\tif _, err := p.expect(TokenArrow); err != nil {\n   559→\t\treturn domain.Collect{}, err\n   560→\t}\n   561→\n   562→\ttoTok, err := p.expect(TokenIdent)\n   563→\tif err != nil {\n   564→\t\treturn domain.Collect{}, fmt.Errorf(\"expected target step: %w\", err)\n   565→\t}\n   566→\n   567→\treturn domain.Collect{\n   568→\t\tMode:       mode,\n   569→\t\tConditions: conditions,\n   570→\t\tTo:         toTok.Literal,\n   571→\t}, nil\n   572→}\n   573→"}]},"parent_tool_use_id":"toolu_01R9B5ZLwaA81q4buXwXBtpB","session_id":"824f09ed-450b-4e33-88c5-1585f66e5eba","uuid":"74e8ca31-76dc-4eaf-aa75-2689cb554eed"}
