{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Fm6uxTemD36oiusSfGAMU1","type":"tool_result","content":"     1→package main\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"encoding/json\"\n     6→\t\"errors\"\n     7→\t\"fmt\"\n     8→\t\"io\"\n     9→\t\"net/http\"\n    10→\t\"os\"\n    11→\t\"path/filepath\"\n    12→\t\"strings\"\n    13→\t\"time\"\n    14→\n    15→\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    16→\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    17→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    18→\t\"github.com/cloche-dev/cloche/internal/runcontext\"\n    19→\t\"google.golang.org/grpc\"\n    20→\t\"google.golang.org/grpc/credentials/insecure\"\n    21→\t\"google.golang.org/grpc/metadata\"\n    22→)\n    23→\n    24→func main() {\n    25→\tif len(os.Args) < 2 {\n    26→\t\tprintTopLevelHelp()\n    27→\t\tos.Exit(1)\n    28→\t}\n    29→\n    30→\t// Handle top-level help: \"cloche help\", \"cloche --help\", \"cloche -h\"\n    31→\tswitch os.Args[1] {\n    32→\tcase \"help\":\n    33→\t\tprintHelp(os.Args[2:])\n    34→\t\treturn\n    35→\tcase \"--help\", \"-h\":\n    36→\t\tprintTopLevelHelp()\n    37→\t\treturn\n    38→\t}\n    39→\n    40→\t// Commands that don't need a daemon connection\n    41→\tswitch os.Args[1] {\n    42→\tcase \"init\":\n    43→\t\tif hasHelpFlag(os.Args[2:]) {\n    44→\t\t\tprintSubcommandHelp(\"init\")\n    45→\t\t\treturn\n    46→\t\t}\n    47→\t\tcmdInit(os.Args[2:])\n    48→\t\treturn\n    49→\tcase \"health\":\n    50→\t\tif hasHelpFlag(os.Args[2:]) {\n    51→\t\t\tprintSubcommandHelp(\"health\")\n    52→\t\t\treturn\n    53→\t\t}\n    54→\t\tcmdHealth(os.Args[2:])\n    55→\t\treturn\n    56→\tcase \"get\":\n    57→\t\tif hasHelpFlag(os.Args[2:]) {\n    58→\t\t\tprintSubcommandHelp(\"get\")\n    59→\t\t\treturn\n    60→\t\t}\n    61→\t\tcmdGet(os.Args[2:])\n    62→\t\treturn\n    63→\tcase \"set\":\n    64→\t\tif hasHelpFlag(os.Args[2:]) {\n    65→\t\t\tprintSubcommandHelp(\"set\")\n    66→\t\t\treturn\n    67→\t\t}\n    68→\t\tcmdSet(os.Args[2:])\n    69→\t\treturn\n    70→\tcase \"tasks\":\n    71→\t\tif hasHelpFlag(os.Args[2:]) {\n    72→\t\t\tprintSubcommandHelp(\"tasks\")\n    73→\t\t\treturn\n    74→\t\t}\n    75→\t\tcmdTasks(os.Args[2:])\n    76→\t\treturn\n    77→\t}\n    78→\n    79→\t// Handle --help for daemon commands before connecting\n    80→\tdaemonCmds := map[string]bool{\n    81→\t\t\"run\": true, \"status\": true, \"logs\": true, \"poll\": true,\n    82→\t\t\"list\": true, \"stop\": true, \"delete\": true, \"loop\": true, \"shutdown\": true,\n    83→\t}\n    84→\tif daemonCmds[os.Args[1]] && hasHelpFlag(os.Args[2:]) {\n    85→\t\tprintSubcommandHelp(os.Args[1])\n    86→\t\treturn\n    87→\t}\n    88→\n    89→\t// Commands that need a daemon connection\n    90→\taddr := os.Getenv(\"CLOCHE_ADDR\")\n    91→\tif addr == \"\" {\n    92→\t\taddr = \"unix:///tmp/cloche.sock\"\n    93→\t}\n    94→\n    95→\tconn, err := grpc.NewClient(addr, grpc.WithTransportCredentials(insecure.NewCredentials()))\n    96→\tif err != nil {\n    97→\t\tfmt.Fprintf(os.Stderr, \"failed to connect: %v\\n\", err)\n    98→\t\tos.Exit(1)\n    99→\t}\n   100→\tdefer conn.Close()\n   101→\n   102→\tclient := pb.NewClocheServiceClient(conn)\n   103→\tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n   104→\tdefer cancel()\n   105→\n   106→\tswitch os.Args[1] {\n   107→\tcase \"run\":\n   108→\t\tcmdRun(ctx, client, os.Args[2:])\n   109→\tcase \"status\":\n   110→\t\tcmdStatus(ctx, client, os.Args[2:])\n   111→\tcase \"logs\":\n   112→\t\tcmdLogs(client, os.Args[2:])\n   113→\tcase \"poll\":\n   114→\t\tcmdPoll(client, os.Args[2:])\n   115→\tcase \"list\":\n   116→\t\tcmdList(ctx, client, os.Args[2:])\n   117→\tcase \"stop\":\n   118→\t\tcmdStop(ctx, client, os.Args[2:])\n   119→\tcase \"delete\":\n   120→\t\tcmdDelete(ctx, client, os.Args[2:])\n   121→\tcase \"loop\":\n   122→\t\tcmdLoop(ctx, client, os.Args[2:])\n   123→\tcase \"shutdown\":\n   124→\t\tcmdShutdown(ctx, client)\n   125→\tdefault:\n   126→\t\tfmt.Fprintf(os.Stderr, \"unknown command: %s\\n\\n\", os.Args[1])\n   127→\t\tprintTopLevelHelp()\n   128→\t\tos.Exit(1)\n   129→\t}\n   130→}\n   131→\n   132→\n   133→func cmdRun(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   134→\tvar workflow, prompt, title string\n   135→\tvar keepContainer bool\n   136→\n   137→\tfor i := 0; i < len(args); i++ {\n   138→\t\tswitch args[i] {\n   139→\t\tcase \"--workflow\":\n   140→\t\t\tif i+1 < len(args) {\n   141→\t\t\t\ti++\n   142→\t\t\t\tworkflow = args[i]\n   143→\t\t\t}\n   144→\t\tcase \"--prompt\", \"-p\":\n   145→\t\t\tif i+1 < len(args) {\n   146→\t\t\t\ti++\n   147→\t\t\t\tprompt = args[i]\n   148→\t\t\t}\n   149→\t\tcase \"--title\":\n   150→\t\t\tif i+1 < len(args) {\n   151→\t\t\t\ti++\n   152→\t\t\t\ttitle = args[i]\n   153→\t\t\t}\n   154→\t\tcase \"--keep-container\":\n   155→\t\t\tkeepContainer = true\n   156→\t\tdefault:\n   157→\t\t\t// Support bare positional arg as workflow name for backwards compat\n   158→\t\t\tif workflow == \"\" && !strings.HasPrefix(args[i], \"-\") {\n   159→\t\t\t\tworkflow = args[i]\n   160→\t\t\t}\n   161→\t\t}\n   162→\t}\n   163→\n   164→\tif workflow == \"\" {\n   165→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche run --workflow <name> [--prompt \\\"...\\\"] [--title \\\"...\\\"]\\n\")\n   166→\t\tos.Exit(1)\n   167→\t}\n   168→\n   169→\tcwd, _ := os.Getwd()\n   170→\n   171→\t// Resolve image from workflow file (soft failure — fall back to daemon default)\n   172→\tvar image string\n   173→\twfPath := filepath.Join(cwd, \".cloche\", workflow+\".cloche\")\n   174→\tif data, err := os.ReadFile(wfPath); err == nil {\n   175→\t\tif wf, err := dsl.ParseForContainer(string(data)); err == nil {\n   176→\t\t\timage = wf.Config[\"container.image\"]\n   177→\t\t}\n   178→\t}\n   179→\n   180→\tresp, err := client.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n   181→\t\tWorkflowName:  workflow,\n   182→\t\tProjectDir:    cwd,\n   183→\t\tImage:         image,\n   184→\t\tPrompt:        prompt,\n   185→\t\tKeepContainer: keepContainer,\n   186→\t\tTitle:         title,\n   187→\t})\n   188→\tif err != nil {\n   189→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   190→\t\tos.Exit(1)\n   191→\t}\n   192→\tfmt.Printf(\"Started run: %s\\n\", resp.RunId)\n   193→}\n   194→\n   195→func cmdStatus(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   196→\tif len(args) < 1 {\n   197→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche status <run-id>\\n\")\n   198→\t\tos.Exit(1)\n   199→\t}\n   200→\n   201→\tresp, err := client.GetStatus(ctx, &pb.GetStatusRequest{RunId: args[0]})\n   202→\tif err != nil {\n   203→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   204→\t\tos.Exit(1)\n   205→\t}\n   206→\n   207→\tfmt.Printf(\"Run:       %s\\n\", resp.RunId)\n   208→\tif resp.Title != \"\" {\n   209→\t\tfmt.Printf(\"Title:     %s\\n\", resp.Title)\n   210→\t}\n   211→\tfmt.Printf(\"Workflow:  %s\\n\", resp.WorkflowName)\n   212→\tif resp.IsHost {\n   213→\t\tfmt.Printf(\"Type:      host\\n\")\n   214→\t} else {\n   215→\t\tfmt.Printf(\"Type:      container\\n\")\n   216→\t}\n   217→\tfmt.Printf(\"State:     %s\\n\", resp.State)\n   218→\tif resp.ContainerId != \"\" {\n   219→\t\tcid := resp.ContainerId\n   220→\t\tif len(cid) > 12 {\n   221→\t\t\tcid = cid[:12]\n   222→\t\t}\n   223→\t\tfmt.Printf(\"Container: %s\\n\", cid)\n   224→\t}\n   225→\tif resp.ErrorMessage != \"\" {\n   226→\t\tfmt.Printf(\"Error:     %s\\n\", resp.ErrorMessage)\n   227→\t}\n   228→\tfmt.Printf(\"Active:    %s\\n\", resp.CurrentStep)\n   229→\tfor _, exec := range resp.StepExecutions {\n   230→\t\tfmt.Printf(\"  %s: %s (%s -> %s)\\n\", exec.StepName, exec.Result, exec.StartedAt, exec.CompletedAt)\n   231→\t}\n   232→}\n   233→\n   234→func cmdList(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   235→\tvar all bool\n   236→\tfor _, arg := range args {\n   237→\t\tif arg == \"--all\" {\n   238→\t\t\tall = true\n   239→\t\t}\n   240→\t}\n   241→\n   242→\treq := &pb.ListRunsRequest{}\n   243→\tif all {\n   244→\t\t// --all: show all runs across all projects (no time limit)\n   245→\t\treq.All = true\n   246→\t} else {\n   247→\t\t// Default: filter to current project\n   248→\t\tcwd, _ := os.Getwd()\n   249→\t\treq.ProjectDir = cwd\n   250→\t}\n   251→\n   252→\tresp, err := client.ListRuns(ctx, req)\n   253→\tif err != nil {\n   254→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   255→\t\tos.Exit(1)\n   256→\t}\n   257→\n   258→\tif len(resp.Runs) == 0 {\n   259→\t\tfmt.Println(\"No runs found.\")\n   260→\t\treturn\n   261→\t}\n   262→\n   263→\tfor _, run := range resp.Runs {\n   264→\t\trunType := \"container\"\n   265→\t\tif run.IsHost {\n   266→\t\t\trunType = \"host\"\n   267→\t\t}\n   268→\t\tline := fmt.Sprintf(\"%s  %-20s  %-10s  %-9s\", run.RunId, run.WorkflowName, run.State, runType)\n   269→\t\tif run.Title != \"\" {\n   270→\t\t\tt := run.Title\n   271→\t\t\tif len(t) > 40 {\n   272→\t\t\t\tt = t[:37] + \"...\"\n   273→\t\t\t}\n   274→\t\t\tline += \"  \" + t\n   275→\t\t}\n   276→\t\tif run.ContainerId != \"\" {\n   277→\t\t\tline += \"  \" + run.ContainerId\n   278→\t\t}\n   279→\t\tif run.ErrorMessage != \"\" {\n   280→\t\t\terrMsg := run.ErrorMessage\n   281→\t\t\tif len(errMsg) > 60 {\n   282→\t\t\t\terrMsg = errMsg[:57] + \"...\"\n   283→\t\t\t}\n   284→\t\t\tline += \"  \" + errMsg\n   285→\t\t}\n   286→\t\tfmt.Println(line)\n   287→\t}\n   288→}\n   289→\n   290→func cmdLogs(client pb.ClocheServiceClient, args []string) {\n   291→\tif len(args) < 1 {\n   292→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche logs <run-id> [--step <name>] [--type <full|script|llm>] [-f]\\n\")\n   293→\t\tos.Exit(1)\n   294→\t}\n   295→\n   296→\tvar stepFilter, typeFilter string\n   297→\tvar follow bool\n   298→\trunID := args[0]\n   299→\n   300→\tfor i := 1; i < len(args); i++ {\n   301→\t\tswitch args[i] {\n   302→\t\tcase \"--step\":\n   303→\t\t\tif i+1 < len(args) {\n   304→\t\t\t\ti++\n   305→\t\t\t\tstepFilter = args[i]\n   306→\t\t\t}\n   307→\t\tcase \"--type\":\n   308→\t\t\tif i+1 < len(args) {\n   309→\t\t\t\ti++\n   310→\t\t\t\ttypeFilter = args[i]\n   311→\t\t\t}\n   312→\t\tcase \"--follow\", \"-f\":\n   313→\t\t\tfollow = true\n   314→\t\t}\n   315→\t}\n   316→\n   317→\t// Use background context — log output can be large and follow mode blocks.\n   318→\tctx := context.Background()\n   319→\tif follow {\n   320→\t\tmd := metadata.Pairs(\"x-cloche-follow\", \"true\")\n   321→\t\tctx = metadata.NewOutgoingContext(ctx, md)\n   322→\t}\n   323→\n   324→\tstream, err := client.StreamLogs(ctx, &pb.StreamLogsRequest{\n   325→\t\tRunId:    runID,\n   326→\t\tStepName: stepFilter,\n   327→\t\tLogType:  typeFilter,\n   328→\t})\n   329→\tif err != nil {\n   330→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   331→\t\tos.Exit(1)\n   332→\t}\n   333→\n   334→\tfor {\n   335→\t\tentry, err := stream.Recv()\n   336→\t\tif err != nil {\n   337→\t\t\tif errors.Is(err, io.EOF) {\n   338→\t\t\t\tbreak\n   339→\t\t\t}\n   340→\t\t\tfmt.Fprintf(os.Stderr, \"error reading logs: %v\\n\", err)\n   341→\t\t\tos.Exit(1)\n   342→\t\t}\n   343→\n   344→\t\tswitch entry.Type {\n   345→\t\tcase \"step_started\":\n   346→\t\t\tfmt.Printf(\"--- %s started ---\\n\", entry.StepName)\n   347→\t\t\tif entry.Message != \"\" {\n   348→\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n   349→\t\t\t}\n   350→\t\tcase \"step_completed\":\n   351→\t\t\tfmt.Printf(\"--- %s: %s ---\\n\", entry.StepName, entry.Result)\n   352→\t\t\tif entry.Message != \"\" {\n   353→\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n   354→\t\t\t}\n   355→\t\tcase \"run_completed\":\n   356→\t\t\tfmt.Printf(\"\\nRun result: %s\\n\", entry.Result)\n   357→\t\t\tif entry.Message != \"\" {\n   358→\t\t\t\tfmt.Printf(\"Error:      %s\\n\", entry.Message)\n   359→\t\t\t}\n   360→\t\tcase \"full_log\":\n   361→\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n   362→\t\tcase \"log\":\n   363→\t\t\t// Live-streamed log line from an active run.\n   364→\t\t\tfmt.Println(entry.Message)\n   365→\t\tdefault:\n   366→\t\t\t// Handles filtered log entries like \"script_log\", \"llm_log\", \"step_log\"\n   367→\t\t\tif entry.StepName != \"\" {\n   368→\t\t\t\tfmt.Printf(\"--- %s ---\\n\", entry.StepName)\n   369→\t\t\t}\n   370→\t\t\tif entry.Message != \"\" {\n   371→\t\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n   372→\t\t\t}\n   373→\t\t}\n   374→\t}\n   375→}\n   376→\n   377→func cmdStop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   378→\tif len(args) < 1 {\n   379→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche stop <run-id>\\n\")\n   380→\t\tos.Exit(1)\n   381→\t}\n   382→\n   383→\t_, err := client.StopRun(ctx, &pb.StopRunRequest{RunId: args[0]})\n   384→\tif err != nil {\n   385→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   386→\t\tos.Exit(1)\n   387→\t}\n   388→\tfmt.Printf(\"Stopped run: %s\\n\", args[0])\n   389→}\n   390→\n   391→func cmdDelete(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   392→\tif len(args) < 1 {\n   393→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche delete <container-or-run-id>\\n\")\n   394→\t\tos.Exit(1)\n   395→\t}\n   396→\n   397→\t_, err := client.DeleteContainer(ctx, &pb.DeleteContainerRequest{Id: args[0]})\n   398→\tif err != nil {\n   399→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   400→\t\tos.Exit(1)\n   401→\t}\n   402→\tfmt.Printf(\"Deleted container: %s\\n\", args[0])\n   403→}\n   404→\n   405→func cmdLoop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   406→\tcwd, _ := os.Getwd()\n   407→\n   408→\t// Check for \"stop\" subcommand\n   409→\tif len(args) > 0 && args[0] == \"stop\" {\n   410→\t\t_, err := client.DisableLoop(ctx, &pb.DisableLoopRequest{ProjectDir: cwd})\n   411→\t\tif err != nil {\n   412→\t\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   413→\t\t\tos.Exit(1)\n   414→\t\t}\n   415→\t\tfmt.Println(\"Orchestration loop stopped.\")\n   416→\t\treturn\n   417→\t}\n   418→\n   419→\t// Default: 0 means \"use config value\" (server reads .cloche/config.toml).\n   420→\tvar maxConcurrent int32\n   421→\tfor i := 0; i < len(args); i++ {\n   422→\t\tswitch args[i] {\n   423→\t\tcase \"--max\":\n   424→\t\t\tif i+1 < len(args) {\n   425→\t\t\t\ti++\n   426→\t\t\t\tn, err := fmt.Sscanf(args[i], \"%d\", &maxConcurrent)\n   427→\t\t\t\tif n != 1 || err != nil {\n   428→\t\t\t\t\tfmt.Fprintf(os.Stderr, \"invalid --max value: %s\\n\", args[i])\n   429→\t\t\t\t\tos.Exit(1)\n   430→\t\t\t\t}\n   431→\t\t\t}\n   432→\t\t}\n   433→\t}\n   434→\n   435→\t_, err := client.EnableLoop(ctx, &pb.EnableLoopRequest{\n   436→\t\tProjectDir:    cwd,\n   437→\t\tMaxConcurrent: maxConcurrent,\n   438→\t})\n   439→\tif err != nil {\n   440→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   441→\t\tos.Exit(1)\n   442→\t}\n   443→\tif maxConcurrent > 0 {\n   444→\t\tfmt.Printf(\"Orchestration loop started (max_concurrent=%d).\\n\", maxConcurrent)\n   445→\t} else {\n   446→\t\tfmt.Println(\"Orchestration loop started (using config defaults).\")\n   447→\t}\n   448→}\n   449→\n   450→func cmdTasks(args []string) {\n   451→\t// Determine HTTP address from env\n   452→\thttpAddr := os.Getenv(\"CLOCHE_HTTP\")\n   453→\tif httpAddr == \"\" {\n   454→\t\thttpAddr = \"localhost:8080\"\n   455→\t}\n   456→\thttpAddr = strings.TrimPrefix(httpAddr, \"http://\")\n   457→\n   458→\t// Determine project label from --project flag or current directory\n   459→\tprojectDir := \"\"\n   460→\tfor i := 0; i < len(args); i++ {\n   461→\t\tswitch args[i] {\n   462→\t\tcase \"--project\":\n   463→\t\t\tif i+1 < len(args) {\n   464→\t\t\t\ti++\n   465→\t\t\t\tprojectDir = args[i]\n   466→\t\t\t}\n   467→\t\t}\n   468→\t}\n   469→\n   470→\tif projectDir == \"\" {\n   471→\t\tcwd, _ := os.Getwd()\n   472→\t\tprojectDir = filepath.Base(cwd)\n   473→\t}\n   474→\n   475→\ttasksURL := fmt.Sprintf(\"http://%s/api/projects/%s/tasks\", httpAddr, projectDir)\n   476→\tresp, err := http.Get(tasksURL)\n   477→\tif err != nil {\n   478→\t\tfmt.Fprintf(os.Stderr, \"error connecting to daemon web API: %v\\n\", err)\n   479→\t\tfmt.Fprintf(os.Stderr, \"hint: ensure CLOCHE_HTTP is set and the daemon is running with --http\\n\")\n   480→\t\tos.Exit(1)\n   481→\t}\n   482→\tdefer resp.Body.Close()\n   483→\n   484→\tif resp.StatusCode != 200 {\n   485→\t\tbody, _ := io.ReadAll(resp.Body)\n   486→\t\tfmt.Fprintf(os.Stderr, \"error: HTTP %d: %s\\n\", resp.StatusCode, strings.TrimSpace(string(body)))\n   487→\t\tos.Exit(1)\n   488→\t}\n   489→\n   490→\ttype taskEntry struct {\n   491→\t\tID          string `json:\"id\"`\n   492→\t\tStatus      string `json:\"status\"`\n   493→\t\tTitle       string `json:\"title\"`\n   494→\t\tDescription string `json:\"description\"`\n   495→\t\tAssigned    bool   `json:\"assigned\"`\n   496→\t\tAssignedAt  string `json:\"assigned_at\"`\n   497→\t\tRunID       string `json:\"run_id\"`\n   498→\t}\n   499→\n   500→\tvar tasks []taskEntry\n   501→\tif err := json.NewDecoder(resp.Body).Decode(&tasks); err != nil {\n   502→\t\tfmt.Fprintf(os.Stderr, \"error parsing response: %v\\n\", err)\n   503→\t\tos.Exit(1)\n   504→\t}\n   505→\n   506→\tif len(tasks) == 0 {\n   507→\t\tfmt.Println(\"No tasks found. (Is the orchestration loop running?)\")\n   508→\t\treturn\n   509→\t}\n   510→\n   511→\tfmt.Printf(\"%-20s  %-12s  %-10s  %-30s  %s\\n\", \"ID\", \"STATUS\", \"ASSIGNED\", \"RUN\", \"TITLE\")\n   512→\tfor _, t := range tasks {\n   513→\t\tstatus := t.Status\n   514→\t\tif status == \"\" {\n   515→\t\t\tstatus = \"open\"\n   516→\t\t}\n   517→\t\tassigned := \"-\"\n   518→\t\tif t.Assigned {\n   519→\t\t\tassigned = \"yes\"\n   520→\t\t}\n   521→\t\trunID := \"\"\n   522→\t\tif t.RunID != \"\" {\n   523→\t\t\trunID = t.RunID\n   524→\t\t\tif len(runID) > 30 {\n   525→\t\t\t\trunID = runID[:27] + \"...\"\n   526→\t\t\t}\n   527→\t\t}\n   528→\t\ttitle := t.Title\n   529→\t\tif len(title) > 40 {\n   530→\t\t\ttitle = title[:37] + \"...\"\n   531→\t\t}\n   532→\t\tfmt.Printf(\"%-20s  %-12s  %-10s  %-30s  %s\\n\", t.ID, status, assigned, runID, title)\n   533→\t}\n   534→}\n   535→\n   536→func cmdShutdown(ctx context.Context, client pb.ClocheServiceClient) {\n   537→\t_, err := client.Shutdown(ctx, &pb.ShutdownRequest{})\n   538→\tif err != nil {\n   539→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   540→\t\tos.Exit(1)\n   541→\t}\n   542→\tfmt.Println(\"Daemon shutting down.\")\n   543→}\n   544→\n   545→// resolveRunContext returns the project directory and run ID for context\n   546→// commands. The run ID comes from CLOCHE_RUN_ID and the project directory\n   547→// from CLOCHE_PROJECT_DIR (falling back to cwd).\n   548→func resolveRunContext() (projectDir, runID string, err error) {\n   549→\trunID = os.Getenv(\"CLOCHE_RUN_ID\")\n   550→\tif runID == \"\" {\n   551→\t\treturn \"\", \"\", fmt.Errorf(\"CLOCHE_RUN_ID environment variable is not set\")\n   552→\t}\n   553→\tprojectDir = os.Getenv(\"CLOCHE_PROJECT_DIR\")\n   554→\tif projectDir == \"\" {\n   555→\t\tprojectDir, err = os.Getwd()\n   556→\t\tif err != nil {\n   557→\t\t\treturn \"\", \"\", fmt.Errorf(\"getting working directory: %w\", err)\n   558→\t\t}\n   559→\t}\n   560→\treturn projectDir, runID, nil\n   561→}\n   562→\n   563→func cmdGet(args []string) {\n   564→\tif len(args) < 1 {\n   565→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche get <key>\\n\")\n   566→\t\tos.Exit(1)\n   567→\t}\n   568→\n   569→\tprojectDir, runID, err := resolveRunContext()\n   570→\tif err != nil {\n   571→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   572→\t\tos.Exit(1)\n   573→\t}\n   574→\n   575→\tval, ok, err := runcontext.Get(projectDir, runID, args[0])\n   576→\tif err != nil {\n   577→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   578→\t\tos.Exit(1)\n   579→\t}\n   580→\tif !ok {\n   581→\t\tos.Exit(1)\n   582→\t}\n   583→\tfmt.Println(val)\n   584→}\n   585→\n   586→func cmdSet(args []string) {\n   587→\tif len(args) < 2 {\n   588→\t\tfmt.Fprintf(os.Stderr, \"usage: cloche set <key> <value>\\n\")\n   589→\t\tfmt.Fprintf(os.Stderr, \"       cloche set <key> -     (read value from stdin)\\n\")\n   590→\t\tos.Exit(1)\n   591→\t}\n   592→\n   593→\tprojectDir, runID, err := resolveRunContext()\n   594→\tif err != nil {\n   595→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   596→\t\tos.Exit(1)\n   597→\t}\n   598→\n   599→\tvalue := args[1]\n   600→\tif value == \"-\" {\n   601→\t\tdata, err := io.ReadAll(os.Stdin)\n   602→\t\tif err != nil {\n   603→\t\t\tfmt.Fprintf(os.Stderr, \"error reading stdin: %v\\n\", err)\n   604→\t\t\tos.Exit(1)\n   605→\t\t}\n   606→\t\tvalue = strings.TrimRight(string(data), \"\\n\")\n   607→\t}\n   608→\n   609→\tif err := runcontext.Set(projectDir, runID, args[0], value); err != nil {\n   610→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   611→\t\tos.Exit(1)\n   612→\t}\n   613→}\n   614→"}]},"parent_tool_use_id":null,"session_id":"824f09ed-450b-4e33-88c5-1585f66e5eba","uuid":"f2076103-a59d-4d28-8898-e1098095ded8","tool_use_result":{"type":"text","file":{"filePath":"/workspace/cmd/cloche/main.go","content":"package main\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"errors\"\n\t\"fmt\"\n\t\"io\"\n\t\"net/http\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"strings\"\n\t\"time\"\n\n\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n\t\"github.com/cloche-dev/cloche/internal/dsl\"\n\t\"github.com/cloche-dev/cloche/internal/logstream\"\n\t\"github.com/cloche-dev/cloche/internal/runcontext\"\n\t\"google.golang.org/grpc\"\n\t\"google.golang.org/grpc/credentials/insecure\"\n\t\"google.golang.org/grpc/metadata\"\n)\n\nfunc main() {\n\tif len(os.Args) < 2 {\n\t\tprintTopLevelHelp()\n\t\tos.Exit(1)\n\t}\n\n\t// Handle top-level help: \"cloche help\", \"cloche --help\", \"cloche -h\"\n\tswitch os.Args[1] {\n\tcase \"help\":\n\t\tprintHelp(os.Args[2:])\n\t\treturn\n\tcase \"--help\", \"-h\":\n\t\tprintTopLevelHelp()\n\t\treturn\n\t}\n\n\t// Commands that don't need a daemon connection\n\tswitch os.Args[1] {\n\tcase \"init\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"init\")\n\t\t\treturn\n\t\t}\n\t\tcmdInit(os.Args[2:])\n\t\treturn\n\tcase \"health\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"health\")\n\t\t\treturn\n\t\t}\n\t\tcmdHealth(os.Args[2:])\n\t\treturn\n\tcase \"get\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"get\")\n\t\t\treturn\n\t\t}\n\t\tcmdGet(os.Args[2:])\n\t\treturn\n\tcase \"set\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"set\")\n\t\t\treturn\n\t\t}\n\t\tcmdSet(os.Args[2:])\n\t\treturn\n\tcase \"tasks\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"tasks\")\n\t\t\treturn\n\t\t}\n\t\tcmdTasks(os.Args[2:])\n\t\treturn\n\t}\n\n\t// Handle --help for daemon commands before connecting\n\tdaemonCmds := map[string]bool{\n\t\t\"run\": true, \"status\": true, \"logs\": true, \"poll\": true,\n\t\t\"list\": true, \"stop\": true, \"delete\": true, \"loop\": true, \"shutdown\": true,\n\t}\n\tif daemonCmds[os.Args[1]] && hasHelpFlag(os.Args[2:]) {\n\t\tprintSubcommandHelp(os.Args[1])\n\t\treturn\n\t}\n\n\t// Commands that need a daemon connection\n\taddr := os.Getenv(\"CLOCHE_ADDR\")\n\tif addr == \"\" {\n\t\taddr = \"unix:///tmp/cloche.sock\"\n\t}\n\n\tconn, err := grpc.NewClient(addr, grpc.WithTransportCredentials(insecure.NewCredentials()))\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"failed to connect: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tdefer conn.Close()\n\n\tclient := pb.NewClocheServiceClient(conn)\n\tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n\tdefer cancel()\n\n\tswitch os.Args[1] {\n\tcase \"run\":\n\t\tcmdRun(ctx, client, os.Args[2:])\n\tcase \"status\":\n\t\tcmdStatus(ctx, client, os.Args[2:])\n\tcase \"logs\":\n\t\tcmdLogs(client, os.Args[2:])\n\tcase \"poll\":\n\t\tcmdPoll(client, os.Args[2:])\n\tcase \"list\":\n\t\tcmdList(ctx, client, os.Args[2:])\n\tcase \"stop\":\n\t\tcmdStop(ctx, client, os.Args[2:])\n\tcase \"delete\":\n\t\tcmdDelete(ctx, client, os.Args[2:])\n\tcase \"loop\":\n\t\tcmdLoop(ctx, client, os.Args[2:])\n\tcase \"shutdown\":\n\t\tcmdShutdown(ctx, client)\n\tdefault:\n\t\tfmt.Fprintf(os.Stderr, \"unknown command: %s\\n\\n\", os.Args[1])\n\t\tprintTopLevelHelp()\n\t\tos.Exit(1)\n\t}\n}\n\n\nfunc cmdRun(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tvar workflow, prompt, title string\n\tvar keepContainer bool\n\n\tfor i := 0; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--workflow\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tworkflow = args[i]\n\t\t\t}\n\t\tcase \"--prompt\", \"-p\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tprompt = args[i]\n\t\t\t}\n\t\tcase \"--title\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\ttitle = args[i]\n\t\t\t}\n\t\tcase \"--keep-container\":\n\t\t\tkeepContainer = true\n\t\tdefault:\n\t\t\t// Support bare positional arg as workflow name for backwards compat\n\t\t\tif workflow == \"\" && !strings.HasPrefix(args[i], \"-\") {\n\t\t\t\tworkflow = args[i]\n\t\t\t}\n\t\t}\n\t}\n\n\tif workflow == \"\" {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche run --workflow <name> [--prompt \\\"...\\\"] [--title \\\"...\\\"]\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tcwd, _ := os.Getwd()\n\n\t// Resolve image from workflow file (soft failure — fall back to daemon default)\n\tvar image string\n\twfPath := filepath.Join(cwd, \".cloche\", workflow+\".cloche\")\n\tif data, err := os.ReadFile(wfPath); err == nil {\n\t\tif wf, err := dsl.ParseForContainer(string(data)); err == nil {\n\t\t\timage = wf.Config[\"container.image\"]\n\t\t}\n\t}\n\n\tresp, err := client.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n\t\tWorkflowName:  workflow,\n\t\tProjectDir:    cwd,\n\t\tImage:         image,\n\t\tPrompt:        prompt,\n\t\tKeepContainer: keepContainer,\n\t\tTitle:         title,\n\t})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Printf(\"Started run: %s\\n\", resp.RunId)\n}\n\nfunc cmdStatus(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche status <run-id>\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tresp, err := client.GetStatus(ctx, &pb.GetStatusRequest{RunId: args[0]})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tfmt.Printf(\"Run:       %s\\n\", resp.RunId)\n\tif resp.Title != \"\" {\n\t\tfmt.Printf(\"Title:     %s\\n\", resp.Title)\n\t}\n\tfmt.Printf(\"Workflow:  %s\\n\", resp.WorkflowName)\n\tif resp.IsHost {\n\t\tfmt.Printf(\"Type:      host\\n\")\n\t} else {\n\t\tfmt.Printf(\"Type:      container\\n\")\n\t}\n\tfmt.Printf(\"State:     %s\\n\", resp.State)\n\tif resp.ContainerId != \"\" {\n\t\tcid := resp.ContainerId\n\t\tif len(cid) > 12 {\n\t\t\tcid = cid[:12]\n\t\t}\n\t\tfmt.Printf(\"Container: %s\\n\", cid)\n\t}\n\tif resp.ErrorMessage != \"\" {\n\t\tfmt.Printf(\"Error:     %s\\n\", resp.ErrorMessage)\n\t}\n\tfmt.Printf(\"Active:    %s\\n\", resp.CurrentStep)\n\tfor _, exec := range resp.StepExecutions {\n\t\tfmt.Printf(\"  %s: %s (%s -> %s)\\n\", exec.StepName, exec.Result, exec.StartedAt, exec.CompletedAt)\n\t}\n}\n\nfunc cmdList(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tvar all bool\n\tfor _, arg := range args {\n\t\tif arg == \"--all\" {\n\t\t\tall = true\n\t\t}\n\t}\n\n\treq := &pb.ListRunsRequest{}\n\tif all {\n\t\t// --all: show all runs across all projects (no time limit)\n\t\treq.All = true\n\t} else {\n\t\t// Default: filter to current project\n\t\tcwd, _ := os.Getwd()\n\t\treq.ProjectDir = cwd\n\t}\n\n\tresp, err := client.ListRuns(ctx, req)\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tif len(resp.Runs) == 0 {\n\t\tfmt.Println(\"No runs found.\")\n\t\treturn\n\t}\n\n\tfor _, run := range resp.Runs {\n\t\trunType := \"container\"\n\t\tif run.IsHost {\n\t\t\trunType = \"host\"\n\t\t}\n\t\tline := fmt.Sprintf(\"%s  %-20s  %-10s  %-9s\", run.RunId, run.WorkflowName, run.State, runType)\n\t\tif run.Title != \"\" {\n\t\t\tt := run.Title\n\t\t\tif len(t) > 40 {\n\t\t\t\tt = t[:37] + \"...\"\n\t\t\t}\n\t\t\tline += \"  \" + t\n\t\t}\n\t\tif run.ContainerId != \"\" {\n\t\t\tline += \"  \" + run.ContainerId\n\t\t}\n\t\tif run.ErrorMessage != \"\" {\n\t\t\terrMsg := run.ErrorMessage\n\t\t\tif len(errMsg) > 60 {\n\t\t\t\terrMsg = errMsg[:57] + \"...\"\n\t\t\t}\n\t\t\tline += \"  \" + errMsg\n\t\t}\n\t\tfmt.Println(line)\n\t}\n}\n\nfunc cmdLogs(client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche logs <run-id> [--step <name>] [--type <full|script|llm>] [-f]\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tvar stepFilter, typeFilter string\n\tvar follow bool\n\trunID := args[0]\n\n\tfor i := 1; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--step\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tstepFilter = args[i]\n\t\t\t}\n\t\tcase \"--type\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\ttypeFilter = args[i]\n\t\t\t}\n\t\tcase \"--follow\", \"-f\":\n\t\t\tfollow = true\n\t\t}\n\t}\n\n\t// Use background context — log output can be large and follow mode blocks.\n\tctx := context.Background()\n\tif follow {\n\t\tmd := metadata.Pairs(\"x-cloche-follow\", \"true\")\n\t\tctx = metadata.NewOutgoingContext(ctx, md)\n\t}\n\n\tstream, err := client.StreamLogs(ctx, &pb.StreamLogsRequest{\n\t\tRunId:    runID,\n\t\tStepName: stepFilter,\n\t\tLogType:  typeFilter,\n\t})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tfor {\n\t\tentry, err := stream.Recv()\n\t\tif err != nil {\n\t\t\tif errors.Is(err, io.EOF) {\n\t\t\t\tbreak\n\t\t\t}\n\t\t\tfmt.Fprintf(os.Stderr, \"error reading logs: %v\\n\", err)\n\t\t\tos.Exit(1)\n\t\t}\n\n\t\tswitch entry.Type {\n\t\tcase \"step_started\":\n\t\t\tfmt.Printf(\"--- %s started ---\\n\", entry.StepName)\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n\t\t\t}\n\t\tcase \"step_completed\":\n\t\t\tfmt.Printf(\"--- %s: %s ---\\n\", entry.StepName, entry.Result)\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n\t\t\t}\n\t\tcase \"run_completed\":\n\t\t\tfmt.Printf(\"\\nRun result: %s\\n\", entry.Result)\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Printf(\"Error:      %s\\n\", entry.Message)\n\t\t\t}\n\t\tcase \"full_log\":\n\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n\t\tcase \"log\":\n\t\t\t// Live-streamed log line from an active run.\n\t\t\tfmt.Println(entry.Message)\n\t\tdefault:\n\t\t\t// Handles filtered log entries like \"script_log\", \"llm_log\", \"step_log\"\n\t\t\tif entry.StepName != \"\" {\n\t\t\t\tfmt.Printf(\"--- %s ---\\n\", entry.StepName)\n\t\t\t}\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n\t\t\t}\n\t\t}\n\t}\n}\n\nfunc cmdStop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche stop <run-id>\\n\")\n\t\tos.Exit(1)\n\t}\n\n\t_, err := client.StopRun(ctx, &pb.StopRunRequest{RunId: args[0]})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Printf(\"Stopped run: %s\\n\", args[0])\n}\n\nfunc cmdDelete(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche delete <container-or-run-id>\\n\")\n\t\tos.Exit(1)\n\t}\n\n\t_, err := client.DeleteContainer(ctx, &pb.DeleteContainerRequest{Id: args[0]})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Printf(\"Deleted container: %s\\n\", args[0])\n}\n\nfunc cmdLoop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tcwd, _ := os.Getwd()\n\n\t// Check for \"stop\" subcommand\n\tif len(args) > 0 && args[0] == \"stop\" {\n\t\t_, err := client.DisableLoop(ctx, &pb.DisableLoopRequest{ProjectDir: cwd})\n\t\tif err != nil {\n\t\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\t\tos.Exit(1)\n\t\t}\n\t\tfmt.Println(\"Orchestration loop stopped.\")\n\t\treturn\n\t}\n\n\t// Default: 0 means \"use config value\" (server reads .cloche/config.toml).\n\tvar maxConcurrent int32\n\tfor i := 0; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--max\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tn, err := fmt.Sscanf(args[i], \"%d\", &maxConcurrent)\n\t\t\t\tif n != 1 || err != nil {\n\t\t\t\t\tfmt.Fprintf(os.Stderr, \"invalid --max value: %s\\n\", args[i])\n\t\t\t\t\tos.Exit(1)\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\t_, err := client.EnableLoop(ctx, &pb.EnableLoopRequest{\n\t\tProjectDir:    cwd,\n\t\tMaxConcurrent: maxConcurrent,\n\t})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tif maxConcurrent > 0 {\n\t\tfmt.Printf(\"Orchestration loop started (max_concurrent=%d).\\n\", maxConcurrent)\n\t} else {\n\t\tfmt.Println(\"Orchestration loop started (using config defaults).\")\n\t}\n}\n\nfunc cmdTasks(args []string) {\n\t// Determine HTTP address from env\n\thttpAddr := os.Getenv(\"CLOCHE_HTTP\")\n\tif httpAddr == \"\" {\n\t\thttpAddr = \"localhost:8080\"\n\t}\n\thttpAddr = strings.TrimPrefix(httpAddr, \"http://\")\n\n\t// Determine project label from --project flag or current directory\n\tprojectDir := \"\"\n\tfor i := 0; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--project\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tprojectDir = args[i]\n\t\t\t}\n\t\t}\n\t}\n\n\tif projectDir == \"\" {\n\t\tcwd, _ := os.Getwd()\n\t\tprojectDir = filepath.Base(cwd)\n\t}\n\n\ttasksURL := fmt.Sprintf(\"http://%s/api/projects/%s/tasks\", httpAddr, projectDir)\n\tresp, err := http.Get(tasksURL)\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error connecting to daemon web API: %v\\n\", err)\n\t\tfmt.Fprintf(os.Stderr, \"hint: ensure CLOCHE_HTTP is set and the daemon is running with --http\\n\")\n\t\tos.Exit(1)\n\t}\n\tdefer resp.Body.Close()\n\n\tif resp.StatusCode != 200 {\n\t\tbody, _ := io.ReadAll(resp.Body)\n\t\tfmt.Fprintf(os.Stderr, \"error: HTTP %d: %s\\n\", resp.StatusCode, strings.TrimSpace(string(body)))\n\t\tos.Exit(1)\n\t}\n\n\ttype taskEntry struct {\n\t\tID          string `json:\"id\"`\n\t\tStatus      string `json:\"status\"`\n\t\tTitle       string `json:\"title\"`\n\t\tDescription string `json:\"description\"`\n\t\tAssigned    bool   `json:\"assigned\"`\n\t\tAssignedAt  string `json:\"assigned_at\"`\n\t\tRunID       string `json:\"run_id\"`\n\t}\n\n\tvar tasks []taskEntry\n\tif err := json.NewDecoder(resp.Body).Decode(&tasks); err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error parsing response: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tif len(tasks) == 0 {\n\t\tfmt.Println(\"No tasks found. (Is the orchestration loop running?)\")\n\t\treturn\n\t}\n\n\tfmt.Printf(\"%-20s  %-12s  %-10s  %-30s  %s\\n\", \"ID\", \"STATUS\", \"ASSIGNED\", \"RUN\", \"TITLE\")\n\tfor _, t := range tasks {\n\t\tstatus := t.Status\n\t\tif status == \"\" {\n\t\t\tstatus = \"open\"\n\t\t}\n\t\tassigned := \"-\"\n\t\tif t.Assigned {\n\t\t\tassigned = \"yes\"\n\t\t}\n\t\trunID := \"\"\n\t\tif t.RunID != \"\" {\n\t\t\trunID = t.RunID\n\t\t\tif len(runID) > 30 {\n\t\t\t\trunID = runID[:27] + \"...\"\n\t\t\t}\n\t\t}\n\t\ttitle := t.Title\n\t\tif len(title) > 40 {\n\t\t\ttitle = title[:37] + \"...\"\n\t\t}\n\t\tfmt.Printf(\"%-20s  %-12s  %-10s  %-30s  %s\\n\", t.ID, status, assigned, runID, title)\n\t}\n}\n\nfunc cmdShutdown(ctx context.Context, client pb.ClocheServiceClient) {\n\t_, err := client.Shutdown(ctx, &pb.ShutdownRequest{})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Println(\"Daemon shutting down.\")\n}\n\n// resolveRunContext returns the project directory and run ID for context\n// commands. The run ID comes from CLOCHE_RUN_ID and the project directory\n// from CLOCHE_PROJECT_DIR (falling back to cwd).\nfunc resolveRunContext() (projectDir, runID string, err error) {\n\trunID = os.Getenv(\"CLOCHE_RUN_ID\")\n\tif runID == \"\" {\n\t\treturn \"\", \"\", fmt.Errorf(\"CLOCHE_RUN_ID environment variable is not set\")\n\t}\n\tprojectDir = os.Getenv(\"CLOCHE_PROJECT_DIR\")\n\tif projectDir == \"\" {\n\t\tprojectDir, err = os.Getwd()\n\t\tif err != nil {\n\t\t\treturn \"\", \"\", fmt.Errorf(\"getting working directory: %w\", err)\n\t\t}\n\t}\n\treturn projectDir, runID, nil\n}\n\nfunc cmdGet(args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche get <key>\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tprojectDir, runID, err := resolveRunContext()\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tval, ok, err := runcontext.Get(projectDir, runID, args[0])\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tif !ok {\n\t\tos.Exit(1)\n\t}\n\tfmt.Println(val)\n}\n\nfunc cmdSet(args []string) {\n\tif len(args) < 2 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche set <key> <value>\\n\")\n\t\tfmt.Fprintf(os.Stderr, \"       cloche set <key> -     (read value from stdin)\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tprojectDir, runID, err := resolveRunContext()\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tvalue := args[1]\n\tif value == \"-\" {\n\t\tdata, err := io.ReadAll(os.Stdin)\n\t\tif err != nil {\n\t\t\tfmt.Fprintf(os.Stderr, \"error reading stdin: %v\\n\", err)\n\t\t\tos.Exit(1)\n\t\t}\n\t\tvalue = strings.TrimRight(string(data), \"\\n\")\n\t}\n\n\tif err := runcontext.Set(projectDir, runID, args[0], value); err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n}\n","numLines":614,"startLine":1,"totalLines":614}}}
{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01SaSX52i1QcaNfCPhNL71bB","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01F9mk5X1sKY6gnA6NYSCcWk","name":"Read","input":{"file_path":"/workspace/cmd/cloche/help.go"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":5741,"cache_read_input_tokens":16288,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":5741},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"824f09ed-450b-4e33-88c5-1585f66e5eba","uuid":"e01f93fe-3be4-4970-a7b3-74db8902febd"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01F9mk5X1sKY6gnA6NYSCcWk","type":"tool_result","content":"     1→package main\n     2→\n     3→import (\n     4→\t\"fmt\"\n     5→\t\"os\"\n     6→)\n     7→\n     8→// subcommandHelp maps each subcommand to its detailed help text.\n     9→// Help text is formatted for LLM consumption: structured, explicit, with examples.\n    10→var subcommandHelp = map[string]string{\n    11→\t\"init\": `cloche init — Initialize a Cloche project\n    12→\n    13→Creates the .cloche/ directory with a workflow definition, Dockerfile,\n    14→prompt templates, and configuration files.\n    15→\n    16→Usage:\n    17→  cloche init [--workflow <name>] [--base-image <image>]\n    18→\n    19→Flags:\n    20→  --workflow <name>       Name for the workflow file (default: \"develop\")\n    21→  --base-image <image>    Base Docker image for the Dockerfile (default: \"cloche-base:latest\")\n    22→\n    23→What it creates:\n    24→  .cloche/<name>.cloche           Workflow definition\n    25→  .cloche/host.cloche             Host orchestration workflow\n    26→  .cloche/Dockerfile              Container image definition\n    27→  .cloche/config.toml             Project configuration\n    28→  .cloche/prompts/implement.md    Prompt for the implement step\n    29→  .cloche/prompts/fix.md          Prompt for the fix step\n    30→  .cloche/prompts/update-docs.md  Prompt for the update-docs step\n    31→  .cloche/scripts/prepare-prompt.sh  Prompt generation script\n    32→  .cloche/version                 Schema version marker\n    33→\n    34→Existing files are never overwritten. Run this command again safely to add\n    35→missing files without losing customizations.\n    36→\n    37→Examples:\n    38→  cloche init\n    39→  cloche init --workflow build --base-image python:3.12\n    40→`,\n    41→\n    42→\t\"health\": `cloche health — Show project health summary\n    43→\n    44→Queries the daemon's HTTP API for a summary of all registered projects\n    45→and their pass/fail test counts.\n    46→\n    47→Usage:\n    48→  cloche health\n    49→\n    50→Environment:\n    51→  CLOCHE_HTTP    Daemon HTTP address (e.g. \"localhost:8080\"). Required.\n    52→\n    53→Examples:\n    54→  export CLOCHE_HTTP=localhost:8080\n    55→  cloche health\n    56→`,\n    57→\n    58→\t\"run\": `cloche run — Launch a workflow run\n    59→\n    60→Starts a new container workflow run. The daemon builds/pulls the container\n    61→image, copies the project into it, and executes the workflow steps.\n    62→\n    63→Usage:\n    64→  cloche run --workflow <name> [--prompt \"...\"] [--title \"...\"] [--keep-container]\n    65→  cloche run <name>              (shorthand: bare positional workflow name)\n    66→\n    67→Flags:\n    68→  --workflow <name>    Name of the workflow to run (required). Must match a\n    69→                       .cloche/<name>.cloche file in the project.\n    70→  --prompt \"...\"       Prompt text passed to agent steps. Also available as\n    71→  -p \"...\"             the short form.\n    72→  --title \"...\"        Human-readable title for the run (shown in status/list).\n    73→  --keep-container     Do not remove the container after the run completes.\n    74→                       Useful for debugging.\n    75→\n    76→The command prints the run ID on success. Use that ID with status, logs,\n    77→poll, and stop.\n    78→\n    79→Examples:\n    80→  cloche run --workflow develop --prompt \"Add a /health endpoint\"\n    81→  cloche run develop -p \"Fix the broken CSV parser\" --title \"CSV fix\"\n    82→  cloche run --workflow build --keep-container\n    83→`,\n    84→\n    85→\t\"status\": `cloche status — Check run status\n    86→\n    87→Shows the current state of a workflow run including its type, active step,\n    88→and the result of each completed step.\n    89→\n    90→Usage:\n    91→  cloche status <run-id>\n    92→\n    93→Arguments:\n    94→  <run-id>    The run identifier returned by \"cloche run\".\n    95→\n    96→Output fields:\n    97→  Run         Run identifier\n    98→  Title       Human-readable title (if set)\n    99→  Workflow    Workflow name\n   100→  Type        \"host\" or \"container\"\n   101→  State       Current state (e.g. running, succeeded, failed, cancelled)\n   102→  Container   Truncated container ID (container runs only)\n   103→  Error       Error message (if failed)\n   104→  Active      Name of the currently executing step\n   105→  Steps       List of completed steps with results and timestamps\n   106→\n   107→Examples:\n   108→  cloche status abc123\n   109→`,\n   110→\n   111→\t\"logs\": `cloche logs — Show logs for a run\n   112→\n   113→Streams or displays log output for a workflow run. Supports filtering by\n   114→step name and log type, and can follow live output.\n   115→\n   116→Usage:\n   117→  cloche logs <run-id> [--step <name>] [--type <full|script|llm>] [--follow]\n   118→\n   119→Arguments:\n   120→  <run-id>    The run identifier.\n   121→\n   122→Flags:\n   123→  --step <name>                  Show logs only for the named step.\n   124→  --type <full|script|llm>       Filter by log type:\n   125→                                   full    — complete unfiltered output\n   126→                                   script  — script/command output only\n   127→                                   llm     — LLM interaction logs only\n   128→  --follow, -f                   Stream logs in real time (blocks until the\n   129→                                 run completes or is stopped).\n   130→\n   131→Examples:\n   132→  cloche logs abc123\n   133→  cloche logs abc123 --step implement --type llm\n   134→  cloche logs abc123 -f\n   135→  cloche logs abc123 --step test --type script\n   136→`,\n   137→\n   138→\t\"poll\": `cloche poll — Wait for a run to finish\n   139→\n   140→Polls the daemon every 2 seconds and prints step-level progress until the\n   141→run reaches a terminal state (succeeded, failed, or cancelled).\n   142→\n   143→Usage:\n   144→  cloche poll <run-id>\n   145→\n   146→Arguments:\n   147→  <run-id>    The run identifier.\n   148→\n   149→Exit codes:\n   150→  0    Run succeeded.\n   151→  1    Run failed, was cancelled, or the container died.\n   152→\n   153→Examples:\n   154→  cloche poll abc123\n   155→  cloche run develop -p \"Fix bug\" && cloche poll \"$(cloche run develop -p 'Fix bug')\"\n   156→`,\n   157→\n   158→\t\"list\": `cloche list — List workflow runs\n   159→\n   160→Shows all runs for the current project, or all runs across all projects\n   161→with --all.\n   162→\n   163→Usage:\n   164→  cloche list [--all]\n   165→\n   166→Flags:\n   167→  --all    Show runs from all projects (default: current project only).\n   168→\n   169→Output columns: run ID, workflow name, state, type (host/container),\n   170→title, container ID, and error message (if any).\n   171→\n   172→Examples:\n   173→  cloche list\n   174→  cloche list --all\n   175→`,\n   176→\n   177→\t\"stop\": `cloche stop — Stop a running workflow\n   178→\n   179→Sends a stop signal to a running workflow. The container is terminated\n   180→and the run state transitions to \"cancelled\".\n   181→\n   182→Usage:\n   183→  cloche stop <run-id>\n   184→\n   185→Arguments:\n   186→  <run-id>    The run identifier.\n   187→\n   188→Examples:\n   189→  cloche stop abc123\n   190→`,\n   191→\n   192→\t\"delete\": `cloche delete — Delete a retained container\n   193→\n   194→Removes a container that was kept after a run (via --keep-container).\n   195→Accepts either a container ID or a run ID.\n   196→\n   197→Usage:\n   198→  cloche delete <container-or-run-id>\n   199→\n   200→Arguments:\n   201→  <container-or-run-id>    Container ID or run ID to delete.\n   202→\n   203→Examples:\n   204→  cloche delete abc123\n   205→`,\n   206→\n   207→\t\"tasks\": `cloche tasks — Show task pipeline and assignment state\n   208→\n   209→Queries the daemon's HTTP API for the current task list, showing which\n   210→tasks are open, assigned, or completed.\n   211→\n   212→Usage:\n   213→  cloche tasks [--project <dir>]\n   214→\n   215→Flags:\n   216→  --project <dir>    Project directory name to query (default: current\n   217→                     directory basename).\n   218→\n   219→Environment:\n   220→  CLOCHE_HTTP    Daemon HTTP address (default: \"localhost:8080\").\n   221→\n   222→Output columns: ID, STATUS, ASSIGNED, RUN, TITLE\n   223→\n   224→Examples:\n   225→  cloche tasks\n   226→  cloche tasks --project my-app\n   227→`,\n   228→\n   229→\t\"loop\": `cloche loop — Manage the orchestration loop\n   230→\n   231→Starts or stops the daemon's orchestration loop, which automatically\n   232→picks up and runs tasks from the task pipeline.\n   233→\n   234→Usage:\n   235→  cloche loop [--max <n>]     Start the orchestration loop\n   236→  cloche loop stop            Stop the orchestration loop\n   237→\n   238→Flags:\n   239→  --max <n>    Maximum number of concurrent runs (default: value from\n   240→               .cloche/config.toml).\n   241→\n   242→Examples:\n   243→  cloche loop\n   244→  cloche loop --max 3\n   245→  cloche loop stop\n   246→`,\n   247→\n   248→\t\"get\": `cloche get — Get a value from the run context store\n   249→\n   250→Reads a key from the run's context.json file. Intended for use inside\n   251→workflow scripts and steps.\n   252→\n   253→Usage:\n   254→  cloche get <key>\n   255→\n   256→Arguments:\n   257→  <key>    The context key to read.\n   258→\n   259→Environment:\n   260→  CLOCHE_RUN_ID        Run identifier (required).\n   261→  CLOCHE_PROJECT_DIR   Project directory (default: current directory).\n   262→\n   263→Exit codes:\n   264→  0    Key exists; value printed to stdout.\n   265→  1    Key not found or error.\n   266→\n   267→Examples:\n   268→  cloche get branch\n   269→  cloche get task_id\n   270→`,\n   271→\n   272→\t\"set\": `cloche set — Set a value in the run context store\n   273→\n   274→Writes a key-value pair to the run's context.json file. Use \"-\" as the\n   275→value to read from stdin (useful for multi-line content).\n   276→\n   277→Usage:\n   278→  cloche set <key> <value>\n   279→  cloche set <key> -          (read value from stdin)\n   280→\n   281→Arguments:\n   282→  <key>      The context key to write.\n   283→  <value>    The value to store, or \"-\" to read from stdin.\n   284→\n   285→Environment:\n   286→  CLOCHE_RUN_ID        Run identifier (required).\n   287→  CLOCHE_PROJECT_DIR   Project directory (default: current directory).\n   288→\n   289→Examples:\n   290→  cloche set branch feature-auth\n   291→  echo \"multi-line content\" | cloche set notes -\n   292→`,\n   293→\n   294→\t\"shutdown\": `cloche shutdown — Shut down the daemon\n   295→\n   296→Sends a shutdown signal to the Cloche daemon. All running workflows are\n   297→stopped and the daemon process exits.\n   298→\n   299→Usage:\n   300→  cloche shutdown\n   301→\n   302→Examples:\n   303→  cloche shutdown\n   304→`,\n   305→}\n   306→\n   307→// printHelp prints the top-level help or subcommand-specific help.\n   308→// Returns true if help was printed (caller should exit).\n   309→func printHelp(args []string) bool {\n   310→\tif len(args) == 0 {\n   311→\t\tprintTopLevelHelp()\n   312→\t\treturn true\n   313→\t}\n   314→\n   315→\t// \"cloche help <subcommand>\"\n   316→\tcmd := args[0]\n   317→\tif text, ok := subcommandHelp[cmd]; ok {\n   318→\t\tfmt.Fprint(os.Stderr, text)\n   319→\t\treturn true\n   320→\t}\n   321→\n   322→\tfmt.Fprintf(os.Stderr, \"unknown command: %s\\n\\n\", cmd)\n   323→\tprintTopLevelHelp()\n   324→\treturn true\n   325→}\n   326→\n   327→// hasHelpFlag returns true if the args contain --help or -h.\n   328→func hasHelpFlag(args []string) bool {\n   329→\tfor _, arg := range args {\n   330→\t\tif arg == \"--help\" || arg == \"-h\" {\n   331→\t\t\treturn true\n   332→\t\t}\n   333→\t}\n   334→\treturn false\n   335→}\n   336→\n   337→// printSubcommandHelp prints help for a subcommand and exits.\n   338→func printSubcommandHelp(cmd string) {\n   339→\tif text, ok := subcommandHelp[cmd]; ok {\n   340→\t\tfmt.Fprint(os.Stderr, text)\n   341→\t} else {\n   342→\t\tfmt.Fprintf(os.Stderr, \"no help available for %q\\n\", cmd)\n   343→\t}\n   344→}\n   345→\n   346→func printTopLevelHelp() {\n   347→\tfmt.Fprint(os.Stderr, `cloche — Grow-code high quality applications\n   348→\n   349→Cloche provides containerized environments for coding agents, a workflow DSL\n   350→for linking agentic and script-driven tasks, and validated code pipelines.\n   351→\n   352→Usage:\n   353→  cloche <command> [args]\n   354→  cloche help <command>       Show detailed help for a command\n   355→  cloche <command> --help     Same as above\n   356→\n   357→Project Setup:\n   358→  init       Initialize a Cloche project (.cloche/ directory and templates)\n   359→  health     Show project health summary (pass/fail counts)\n   360→\n   361→Workflow Runs:\n   362→  run        Launch a workflow run in a container\n   363→  status     Check run status (state, steps, errors)\n   364→  logs       Show or stream logs for a run\n   365→  poll       Wait for a run to finish (blocks until terminal state)\n   366→  list       List runs for current project (or all projects)\n   367→  stop       Stop a running workflow\n   368→  delete     Delete a retained container\n   369→\n   370→Orchestration:\n   371→  tasks      Show task pipeline and assignment state\n   372→  loop       Start or stop the orchestration loop\n   373→\n   374→Context Store (for use inside workflow steps):\n   375→  get        Get a value from the run context store\n   376→  set        Set a value in the run context store\n   377→\n   378→Daemon:\n   379→  shutdown   Shut down the Cloche daemon\n   380→\n   381→Environment Variables:\n   382→  CLOCHE_ADDR          Daemon gRPC address (default: unix:///tmp/cloche.sock)\n   383→  CLOCHE_HTTP          Daemon HTTP address (for health/tasks commands)\n   384→  CLOCHE_RUN_ID        Run ID for get/set commands (set automatically in steps)\n   385→  CLOCHE_PROJECT_DIR   Project directory override for get/set commands\n   386→\n   387→Examples:\n   388→  cloche init\n   389→  cloche run --workflow develop --prompt \"Add user authentication\"\n   390→  cloche status abc123\n   391→  cloche logs abc123 --follow\n   392→  cloche list\n   393→  cloche loop --max 2\n   394→`)\n   395→}\n   396→"}]},"parent_tool_use_id":null,"session_id":"824f09ed-450b-4e33-88c5-1585f66e5eba","uuid":"40982313-8331-4416-bff3-e064e46c5662","tool_use_result":{"type":"text","file":{"filePath":"/workspace/cmd/cloche/help.go","content":"package main\n\nimport (\n\t\"fmt\"\n\t\"os\"\n)\n\n// subcommandHelp maps each subcommand to its detailed help text.\n// Help text is formatted for LLM consumption: structured, explicit, with examples.\nvar subcommandHelp = map[string]string{\n\t\"init\": `cloche init — Initialize a Cloche project\n\nCreates the .cloche/ directory with a workflow definition, Dockerfile,\nprompt templates, and configuration files.\n\nUsage:\n  cloche init [--workflow <name>] [--base-image <image>]\n\nFlags:\n  --workflow <name>       Name for the workflow file (default: \"develop\")\n  --base-image <image>    Base Docker image for the Dockerfile (default: \"cloche-base:latest\")\n\nWhat it creates:\n  .cloche/<name>.cloche           Workflow definition\n  .cloche/host.cloche             Host orchestration workflow\n  .cloche/Dockerfile              Container image definition\n  .cloche/config.toml             Project configuration\n  .cloche/prompts/implement.md    Prompt for the implement step\n  .cloche/prompts/fix.md          Prompt for the fix step\n  .cloche/prompts/update-docs.md  Prompt for the update-docs step\n  .cloche/scripts/prepare-prompt.sh  Prompt generation script\n  .cloche/version                 Schema version marker\n\nExisting files are never overwritten. Run this command again safely to add\nmissing files without losing customizations.\n\nExamples:\n  cloche init\n  cloche init --workflow build --base-image python:3.12\n`,\n\n\t\"health\": `cloche health — Show project health summary\n\nQueries the daemon's HTTP API for a summary of all registered projects\nand their pass/fail test counts.\n\nUsage:\n  cloche health\n\nEnvironment:\n  CLOCHE_HTTP    Daemon HTTP address (e.g. \"localhost:8080\"). Required.\n\nExamples:\n  export CLOCHE_HTTP=localhost:8080\n  cloche health\n`,\n\n\t\"run\": `cloche run — Launch a workflow run\n\nStarts a new container workflow run. The daemon builds/pulls the container\nimage, copies the project into it, and executes the workflow steps.\n\nUsage:\n  cloche run --workflow <name> [--prompt \"...\"] [--title \"...\"] [--keep-container]\n  cloche run <name>              (shorthand: bare positional workflow name)\n\nFlags:\n  --workflow <name>    Name of the workflow to run (required). Must match a\n                       .cloche/<name>.cloche file in the project.\n  --prompt \"...\"       Prompt text passed to agent steps. Also available as\n  -p \"...\"             the short form.\n  --title \"...\"        Human-readable title for the run (shown in status/list).\n  --keep-container     Do not remove the container after the run completes.\n                       Useful for debugging.\n\nThe command prints the run ID on success. Use that ID with status, logs,\npoll, and stop.\n\nExamples:\n  cloche run --workflow develop --prompt \"Add a /health endpoint\"\n  cloche run develop -p \"Fix the broken CSV parser\" --title \"CSV fix\"\n  cloche run --workflow build --keep-container\n`,\n\n\t\"status\": `cloche status — Check run status\n\nShows the current state of a workflow run including its type, active step,\nand the result of each completed step.\n\nUsage:\n  cloche status <run-id>\n\nArguments:\n  <run-id>    The run identifier returned by \"cloche run\".\n\nOutput fields:\n  Run         Run identifier\n  Title       Human-readable title (if set)\n  Workflow    Workflow name\n  Type        \"host\" or \"container\"\n  State       Current state (e.g. running, succeeded, failed, cancelled)\n  Container   Truncated container ID (container runs only)\n  Error       Error message (if failed)\n  Active      Name of the currently executing step\n  Steps       List of completed steps with results and timestamps\n\nExamples:\n  cloche status abc123\n`,\n\n\t\"logs\": `cloche logs — Show logs for a run\n\nStreams or displays log output for a workflow run. Supports filtering by\nstep name and log type, and can follow live output.\n\nUsage:\n  cloche logs <run-id> [--step <name>] [--type <full|script|llm>] [--follow]\n\nArguments:\n  <run-id>    The run identifier.\n\nFlags:\n  --step <name>                  Show logs only for the named step.\n  --type <full|script|llm>       Filter by log type:\n                                   full    — complete unfiltered output\n                                   script  — script/command output only\n                                   llm     — LLM interaction logs only\n  --follow, -f                   Stream logs in real time (blocks until the\n                                 run completes or is stopped).\n\nExamples:\n  cloche logs abc123\n  cloche logs abc123 --step implement --type llm\n  cloche logs abc123 -f\n  cloche logs abc123 --step test --type script\n`,\n\n\t\"poll\": `cloche poll — Wait for a run to finish\n\nPolls the daemon every 2 seconds and prints step-level progress until the\nrun reaches a terminal state (succeeded, failed, or cancelled).\n\nUsage:\n  cloche poll <run-id>\n\nArguments:\n  <run-id>    The run identifier.\n\nExit codes:\n  0    Run succeeded.\n  1    Run failed, was cancelled, or the container died.\n\nExamples:\n  cloche poll abc123\n  cloche run develop -p \"Fix bug\" && cloche poll \"$(cloche run develop -p 'Fix bug')\"\n`,\n\n\t\"list\": `cloche list — List workflow runs\n\nShows all runs for the current project, or all runs across all projects\nwith --all.\n\nUsage:\n  cloche list [--all]\n\nFlags:\n  --all    Show runs from all projects (default: current project only).\n\nOutput columns: run ID, workflow name, state, type (host/container),\ntitle, container ID, and error message (if any).\n\nExamples:\n  cloche list\n  cloche list --all\n`,\n\n\t\"stop\": `cloche stop — Stop a running workflow\n\nSends a stop signal to a running workflow. The container is terminated\nand the run state transitions to \"cancelled\".\n\nUsage:\n  cloche stop <run-id>\n\nArguments:\n  <run-id>    The run identifier.\n\nExamples:\n  cloche stop abc123\n`,\n\n\t\"delete\": `cloche delete — Delete a retained container\n\nRemoves a container that was kept after a run (via --keep-container).\nAccepts either a container ID or a run ID.\n\nUsage:\n  cloche delete <container-or-run-id>\n\nArguments:\n  <container-or-run-id>    Container ID or run ID to delete.\n\nExamples:\n  cloche delete abc123\n`,\n\n\t\"tasks\": `cloche tasks — Show task pipeline and assignment state\n\nQueries the daemon's HTTP API for the current task list, showing which\ntasks are open, assigned, or completed.\n\nUsage:\n  cloche tasks [--project <dir>]\n\nFlags:\n  --project <dir>    Project directory name to query (default: current\n                     directory basename).\n\nEnvironment:\n  CLOCHE_HTTP    Daemon HTTP address (default: \"localhost:8080\").\n\nOutput columns: ID, STATUS, ASSIGNED, RUN, TITLE\n\nExamples:\n  cloche tasks\n  cloche tasks --project my-app\n`,\n\n\t\"loop\": `cloche loop — Manage the orchestration loop\n\nStarts or stops the daemon's orchestration loop, which automatically\npicks up and runs tasks from the task pipeline.\n\nUsage:\n  cloche loop [--max <n>]     Start the orchestration loop\n  cloche loop stop            Stop the orchestration loop\n\nFlags:\n  --max <n>    Maximum number of concurrent runs (default: value from\n               .cloche/config.toml).\n\nExamples:\n  cloche loop\n  cloche loop --max 3\n  cloche loop stop\n`,\n\n\t\"get\": `cloche get — Get a value from the run context store\n\nReads a key from the run's context.json file. Intended for use inside\nworkflow scripts and steps.\n\nUsage:\n  cloche get <key>\n\nArguments:\n  <key>    The context key to read.\n\nEnvironment:\n  CLOCHE_RUN_ID        Run identifier (required).\n  CLOCHE_PROJECT_DIR   Project directory (default: current directory).\n\nExit codes:\n  0    Key exists; value printed to stdout.\n  1    Key not found or error.\n\nExamples:\n  cloche get branch\n  cloche get task_id\n`,\n\n\t\"set\": `cloche set — Set a value in the run context store\n\nWrites a key-value pair to the run's context.json file. Use \"-\" as the\nvalue to read from stdin (useful for multi-line content).\n\nUsage:\n  cloche set <key> <value>\n  cloche set <key> -          (read value from stdin)\n\nArguments:\n  <key>      The context key to write.\n  <value>    The value to store, or \"-\" to read from stdin.\n\nEnvironment:\n  CLOCHE_RUN_ID        Run identifier (required).\n  CLOCHE_PROJECT_DIR   Project directory (default: current directory).\n\nExamples:\n  cloche set branch feature-auth\n  echo \"multi-line content\" | cloche set notes -\n`,\n\n\t\"shutdown\": `cloche shutdown — Shut down the daemon\n\nSends a shutdown signal to the Cloche daemon. All running workflows are\nstopped and the daemon process exits.\n\nUsage:\n  cloche shutdown\n\nExamples:\n  cloche shutdown\n`,\n}\n\n// printHelp prints the top-level help or subcommand-specific help.\n// Returns true if help was printed (caller should exit).\nfunc printHelp(args []string) bool {\n\tif len(args) == 0 {\n\t\tprintTopLevelHelp()\n\t\treturn true\n\t}\n\n\t// \"cloche help <subcommand>\"\n\tcmd := args[0]\n\tif text, ok := subcommandHelp[cmd]; ok {\n\t\tfmt.Fprint(os.Stderr, text)\n\t\treturn true\n\t}\n\n\tfmt.Fprintf(os.Stderr, \"unknown command: %s\\n\\n\", cmd)\n\tprintTopLevelHelp()\n\treturn true\n}\n\n// hasHelpFlag returns true if the args contain --help or -h.\nfunc hasHelpFlag(args []string) bool {\n\tfor _, arg := range args {\n\t\tif arg == \"--help\" || arg == \"-h\" {\n\t\t\treturn true\n\t\t}\n\t}\n\treturn false\n}\n\n// printSubcommandHelp prints help for a subcommand and exits.\nfunc printSubcommandHelp(cmd string) {\n\tif text, ok := subcommandHelp[cmd]; ok {\n\t\tfmt.Fprint(os.Stderr, text)\n\t} else {\n\t\tfmt.Fprintf(os.Stderr, \"no help available for %q\\n\", cmd)\n\t}\n}\n\nfunc printTopLevelHelp() {\n\tfmt.Fprint(os.Stderr, `cloche — Grow-code high quality applications\n\nCloche provides containerized environments for coding agents, a workflow DSL\nfor linking agentic and script-driven tasks, and validated code pipelines.\n\nUsage:\n  cloche <command> [args]\n  cloche help <command>       Show detailed help for a command\n  cloche <command> --help     Same as above\n\nProject Setup:\n  init       Initialize a Cloche project (.cloche/ directory and templates)\n  health     Show project health summary (pass/fail counts)\n\nWorkflow Runs:\n  run        Launch a workflow run in a container\n  status     Check run status (state, steps, errors)\n  logs       Show or stream logs for a run\n  poll       Wait for a run to finish (blocks until terminal state)\n  list       List runs for current project (or all projects)\n  stop       Stop a running workflow\n  delete     Delete a retained container\n\nOrchestration:\n  tasks      Show task pipeline and assignment state\n  loop       Start or stop the orchestration loop\n\nContext Store (for use inside workflow steps):\n  get        Get a value from the run context store\n  set        Set a value in the run context store\n\nDaemon:\n  shutdown   Shut down the Cloche daemon\n\nEnvironment Variables:\n  CLOCHE_ADDR          Daemon gRPC address (default: unix:///tmp/cloche.sock)\n  CLOCHE_HTTP          Daemon HTTP address (for health/tasks commands)\n  CLOCHE_RUN_ID        Run ID for get/set commands (set automatically in steps)\n  CLOCHE_PROJECT_DIR   Project directory override for get/set commands\n\nExamples:\n  cloche init\n  cloche run --workflow develop --prompt \"Add user authentication\"\n  cloche status abc123\n  cloche logs abc123 --follow\n  cloche list\n  cloche loop --max 2\n`)\n}\n","numLines":396,"startLine":1,"totalLines":396}}}
