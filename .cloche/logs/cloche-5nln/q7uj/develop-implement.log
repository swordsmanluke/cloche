{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XciyZaYDUoobgApegdAmxK","type":"tool_result","content":"     1→package main\n     2→\n     3→import (\n     4→\t\"encoding/json\"\n     5→\t\"fmt\"\n     6→\t\"net/http\"\n     7→\t\"os\"\n     8→\t\"text/tabwriter\"\n     9→)\n    10→\n    11→type healthData struct {\n    12→\tStatus string `json:\"status\"`\n    13→\tPassed int    `json:\"passed\"`\n    14→\tFailed int    `json:\"failed\"`\n    15→\tTotal  int    `json:\"total\"`\n    16→}\n    17→\n    18→type projectHealth struct {\n    19→\tDir    string     `json:\"dir\"`\n    20→\tLabel  string     `json:\"label\"`\n    21→\tHealth healthData `json:\"health\"`\n    22→}\n    23→\n    24→func cmdHealth(args []string) {\n    25→\thttpAddr := os.Getenv(\"CLOCHE_HTTP\")\n    26→\tif httpAddr == \"\" {\n    27→\t\tfmt.Fprintf(os.Stderr, \"error: CLOCHE_HTTP not set (e.g. export CLOCHE_HTTP=localhost:8080)\\n\")\n    28→\t\tos.Exit(1)\n    29→\t}\n    30→\n    31→\turl := \"http://\" + httpAddr + \"/api/projects\"\n    32→\tresp, err := http.Get(url)\n    33→\tif err != nil {\n    34→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n    35→\t\tos.Exit(1)\n    36→\t}\n    37→\tdefer resp.Body.Close()\n    38→\n    39→\tif resp.StatusCode != http.StatusOK {\n    40→\t\tfmt.Fprintf(os.Stderr, \"error: server returned %s\\n\", resp.Status)\n    41→\t\tos.Exit(1)\n    42→\t}\n    43→\n    44→\tvar projects []projectHealth\n    45→\tif err := json.NewDecoder(resp.Body).Decode(&projects); err != nil {\n    46→\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n    47→\t\tos.Exit(1)\n    48→\t}\n    49→\n    50→\tif len(projects) == 0 {\n    51→\t\tfmt.Println(\"No projects found.\")\n    52→\t\treturn\n    53→\t}\n    54→\n    55→\tw := tabwriter.NewWriter(os.Stdout, 0, 0, 2, ' ', 0)\n    56→\tfmt.Fprintln(w, \"PROJECT\\tSTATUS\\tPASSED\\tFAILED\\tTOTAL\")\n    57→\tfor _, p := range projects {\n    58→\t\tname := p.Label\n    59→\t\tif name == \"\" {\n    60→\t\t\tname = p.Dir\n    61→\t\t}\n    62→\t\tstatus := colorStatus(p.Health.Status)\n    63→\t\tfmt.Fprintf(w, \"%s\\t%s\\t%d\\t%d\\t%d\\n\",\n    64→\t\t\tname, status, p.Health.Passed, p.Health.Failed, p.Health.Total)\n    65→\t}\n    66→\tw.Flush()\n    67→}\n    68→\n    69→func colorStatus(status string) string {\n    70→\tif !isTTY() {\n    71→\t\treturn status\n    72→\t}\n    73→\tswitch status {\n    74→\tcase \"green\":\n    75→\t\treturn \"\\033[32m\" + status + \"\\033[0m\"\n    76→\tcase \"yellow\":\n    77→\t\treturn \"\\033[33m\" + status + \"\\033[0m\"\n    78→\tcase \"red\":\n    79→\t\treturn \"\\033[31m\" + status + \"\\033[0m\"\n    80→\tdefault:\n    81→\t\treturn status\n    82→\t}\n    83→}\n    84→\n    85→func isTTY() bool {\n    86→\tfi, err := os.Stdout.Stat()\n    87→\tif err != nil {\n    88→\t\treturn false\n    89→\t}\n    90→\treturn fi.Mode()&os.ModeCharDevice != 0\n    91→}\n    92→"}]},"parent_tool_use_id":null,"session_id":"824f09ed-450b-4e33-88c5-1585f66e5eba","uuid":"342394bb-d754-4320-9f4d-455444276618","tool_use_result":{"type":"text","file":{"filePath":"/workspace/cmd/cloche/health.go","content":"package main\n\nimport (\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"net/http\"\n\t\"os\"\n\t\"text/tabwriter\"\n)\n\ntype healthData struct {\n\tStatus string `json:\"status\"`\n\tPassed int    `json:\"passed\"`\n\tFailed int    `json:\"failed\"`\n\tTotal  int    `json:\"total\"`\n}\n\ntype projectHealth struct {\n\tDir    string     `json:\"dir\"`\n\tLabel  string     `json:\"label\"`\n\tHealth healthData `json:\"health\"`\n}\n\nfunc cmdHealth(args []string) {\n\thttpAddr := os.Getenv(\"CLOCHE_HTTP\")\n\tif httpAddr == \"\" {\n\t\tfmt.Fprintf(os.Stderr, \"error: CLOCHE_HTTP not set (e.g. export CLOCHE_HTTP=localhost:8080)\\n\")\n\t\tos.Exit(1)\n\t}\n\n\turl := \"http://\" + httpAddr + \"/api/projects\"\n\tresp, err := http.Get(url)\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tdefer resp.Body.Close()\n\n\tif resp.StatusCode != http.StatusOK {\n\t\tfmt.Fprintf(os.Stderr, \"error: server returned %s\\n\", resp.Status)\n\t\tos.Exit(1)\n\t}\n\n\tvar projects []projectHealth\n\tif err := json.NewDecoder(resp.Body).Decode(&projects); err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tif len(projects) == 0 {\n\t\tfmt.Println(\"No projects found.\")\n\t\treturn\n\t}\n\n\tw := tabwriter.NewWriter(os.Stdout, 0, 0, 2, ' ', 0)\n\tfmt.Fprintln(w, \"PROJECT\\tSTATUS\\tPASSED\\tFAILED\\tTOTAL\")\n\tfor _, p := range projects {\n\t\tname := p.Label\n\t\tif name == \"\" {\n\t\t\tname = p.Dir\n\t\t}\n\t\tstatus := colorStatus(p.Health.Status)\n\t\tfmt.Fprintf(w, \"%s\\t%s\\t%d\\t%d\\t%d\\n\",\n\t\t\tname, status, p.Health.Passed, p.Health.Failed, p.Health.Total)\n\t}\n\tw.Flush()\n}\n\nfunc colorStatus(status string) string {\n\tif !isTTY() {\n\t\treturn status\n\t}\n\tswitch status {\n\tcase \"green\":\n\t\treturn \"\\033[32m\" + status + \"\\033[0m\"\n\tcase \"yellow\":\n\t\treturn \"\\033[33m\" + status + \"\\033[0m\"\n\tcase \"red\":\n\t\treturn \"\\033[31m\" + status + \"\\033[0m\"\n\tdefault:\n\t\treturn status\n\t}\n}\n\nfunc isTTY() bool {\n\tfi, err := os.Stdout.Stat()\n\tif err != nil {\n\t\treturn false\n\t}\n\treturn fi.Mode()&os.ModeCharDevice != 0\n}\n","numLines":92,"startLine":1,"totalLines":92}}}
