Рєњ}\n   512Рєњ\n   513Рєњfunc (p *Parser) parseCollect() (domain.Collect, error) {\n   514Рєњ\tp.advance() // consume \"collect\"\n   515Рєњ\n   516Рєњ\tmodeTok, err := p.expect(TokenIdent)\n   517Рєњ\tif err != nil {\n   518Рєњ\t\treturn domain.Collect{}, fmt.Errorf(\"expected 'all' or 'any': %w\", err)\n   519Рєњ\t}\n   520Рєњ\n   521Рєњ\tvar mode domain.CollectMode\n   522Рєњ\tswitch modeTok.Literal {\n   523Рєњ\tcase \"all\":\n   524Рєњ\t\tmode = domain.CollectAll\n   525Рєњ\tcase \"any\":\n   526Рєњ\t\tmode = domain.CollectAny\n   527Рєњ\tdefault:\n   528Рєњ\t\treturn domain.Collect{}, fmt.Errorf(\"line %d col %d: expected 'all' or 'any', got %q\",\n   529Рєњ\t\t\tmodeTok.Line, modeTok.Col, modeTok.Literal)\n   530Рєњ\t}\n   531Рєњ\n   532Рєњ\tif _, err := p.expect(TokenLParen); err != nil {\n   533Рєњ\t\treturn domain.Collect{}, err\n   534Рєњ\t}\n   535Рєњ\n   536Рєњ\tvar conditions []domain.WireCondition\n   537Рєњ\tfor p.current.Type != TokenRParen && p.current.Type != TokenEOF {\n   538Рєњ\t\tstepTok, err := p.expect(TokenIdent)\n   539Рєњ\t\tif err != nil {\n   540Рєњ\t\t\treturn domain.Collect{}, fmt.Errorf(\"expected step name in collect: %w\", err)\n   541Рєњ\t\t}\n   542Рєњ\t\tif _, err := p.expect(TokenColon); err != nil {\n   543Рєњ\t\t\treturn domain.Collect{}, err\n   544Рєњ\t\t}\n   545Рєњ\t\tresultTok, err := p.expect(TokenIdent)\n   546Рєњ\t\tif err != nil {\n   547Рєњ\t\t\treturn domain.Collect{}, fmt.Errorf(\"expected result name in collect: %w\", err)\n   548Рєњ\t\t}\n   549Рєњ\t\tconditions = append(conditions, domain.WireCondition{Step: stepTok.Literal, Result: resultTok.Literal})\n   550Рєњ\t\tif p.current.Type == TokenComma {\n   551Рєњ\t\t\tp.advance()\n   552Рєњ\t\t}\n   553Рєњ\t}\n   554Рєњ\n   555Рєњ\tif _, err := p.expect(TokenRParen); err != nil {\n   556Рєњ\t\treturn domain.Collect{}, err\n   557Рєњ\t}\n   558Рєњ\tif _, err := p.expect(TokenArrow); err != nil {\n   559Рєњ\t\treturn domain.Collect{}, err\n   560Рєњ\t}\n   561Рєњ\n   562Рєњ\ttoTok, err := p.expect(TokenIdent)\n   563Рєњ\tif err != nil {\n   564Рєњ\t\treturn domain.Collect{}, fmt.Errorf(\"expected target step: %w\", err)\n   565Рєњ\t}\n   566Рєњ\n   567Рєњ\treturn domain.Collect{\n   568Рєњ\t\tMode:       mode,\n   569Рєњ\t\tConditions: conditions,\n   570Рєњ\t\tTo:         toTok.Literal,\n   571Рєњ\t}, nil\n   572Рєњ}\n   573Рєњ"}]},"parent_tool_use_id":"toolu_01R9B5ZLwaA81q4buXwXBtpB","session_id":"824f09ed-450b-4e33-88c5-1585f66e5eba","uuid":"74e8ca31-76dc-4eaf-aa75-2689cb554eed"}
