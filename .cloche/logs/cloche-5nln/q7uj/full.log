[2026-03-13T17:47:31Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011GUfT521vjatx5u18DAuAo","type":"tool_result","content":"     1Рєњpackage main\n     2Рєњ\n     3Рєњimport (\n     4Рєњ\t\"context\"\n     5Рєњ\t\"encoding/json\"\n     6Рєњ\t\"errors\"\n     7Рєњ\t\"fmt\"\n     8Рєњ\t\"io\"\n     9Рєњ\t\"net/http\"\n    10Рєњ\t\"os\"\n    11Рєњ\t\"path/filepath\"\n    12Рєњ\t\"strings\"\n    13Рєњ\t\"time\"\n    14Рєњ\n    15Рєњ\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    16Рєњ\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    17Рєњ\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    18Рєњ\t\"github.com/cloche-dev/cloche/internal/runcontext\"\n    19Рєњ\t\"google.golang.org/grpc\"\n    20Рєњ\t\"google.golang.org/grpc/credentials/insecure\"\n    21Рєњ\t\"google.golang.org/grpc/metadata\"\n    22Рєњ)\n    23Рєњ\n    24Рєњfunc main() {\n    25Рєњ\tif len(os.Args) < 2 {\n    26Рєњ\t\tprintTopLevelHelp()\n    27Рєњ\t\tos.Exit(1)\n    28Рєњ\t}\n    29Рєњ\n    30Рєњ\t// Handle top-level help: \"cloche help\", \"cloche --help\", \"cloche -h\"\n    31Рєњ\tswitch os.Args[1] {\n    32Рєњ\tcase \"help\":\n    33Рєњ\t\tprintHelp(os.Args[2:])\n    34Рєњ\t\treturn\n    35Рєњ\tcase \"--help\", \"-h\":\n    36Рєњ\t\tprintTopLevelHelp()\n    37Рєњ\t\treturn\n    38Рєњ\t}\n    39Рєњ\n    40Рєњ\t// Commands that don't need a daemon connection\n    41Рєњ\tswitch os.Args[1] {\n    42Рєњ\tcase \"init\":\n    43Рєњ\t\tif hasHelpFlag(os.Args[2:]) {\n    44Рєњ\t\t\tprintSubcommandHelp(\"init\")\n    45Рєњ\t\t\treturn\n    46Рєњ\t\t}\n    47Рєњ\t\tcmdInit(os.Args[2:])\n    48Рєњ\t\treturn\n    49Рєњ\tcase \"health\":\n    50Рєњ\t\tif hasHelpFlag(os.Args[2:]) {\n    51Рєњ\t\t\tprintSubcommandHelp(\"health\")\n    52Рєњ\t\t\treturn\n    53Рєњ\t\t}\n    54Рєњ\t\tcmdHealth(os.Args[2:])\n    55Рєњ\t\treturn\n    56Рєњ\tcase \"get\":\n    57Рєњ\t\tif hasHelpFlag(os.Args[2:]) {\n    58Рєњ\t\t\tprintSubcommandHelp(\"get\")\n    59Рєњ\t\t\treturn\n    60Рєњ\t\t}\n    61Рєњ\t\tcmdGet(os.Args[2:])\n    62Рєњ\t\treturn\n    63Рєњ\tcase \"set\":\n    64Рєњ\t\tif hasHelpFlag(os.Args[2:]) {\n    65Рєњ\t\t\tprintSubcommandHelp(\"set\")\n    66Рєњ\t\t\treturn\n    67Рєњ\t\t}\n    68Рєњ\t\tcmdSet(os.Args[2:])\n    69Рєњ\t\treturn\n    70Рєњ\tcase \"tasks\":\n    71Рєњ\t\tif hasHelpFlag(os.Args[2:]) {\n    72Рєњ\t\t\tprintSubcommandHelp(\"tasks\")\n    73Рєњ\t\t\treturn\n    74Рєњ\t\t}\n    75Рєњ\t\tcmdTasks(os.Args[2:])\n    76Рєњ\t\treturn\n    77Рєњ\tcase \"workflow\":\n    78Рєњ\t\tif hasHelpFlag(os.Args[2:]) {\n    79Рєњ\t\t\tprintSubcommandHelp(\"workflow\")\n    80Рєњ\t\t\treturn\n    81Рєњ\t\t}\n    82Рєњ\t\tcmdWorkflow(os.Args[2:])\n    83Рєњ\t\treturn\n    84Рєњ\t}\n    85Рєњ\n    86Рєњ\t// Handle --help for daemon commands before connecting\n    87Рєњ\tdaemonCmds := map[string]bool{\n    88Рєњ\t\t\"run\": true, \"status\": true, \"logs\": true, \"poll\": true,\n    89Рєњ\t\t\"list\": true, \"stop\": true, \"delete\": true, \"loop\": true, \"shutdown\": true,\n    90Рєњ\t}\n    91Рєњ\tif daemonCmds[os.Args[1]] && hasHelpFlag(os.Args[2:]) {\n    92Рєњ\t\tprintSubcommandHelp(os.Args[1])\n    93Рєњ\t\treturn\n    94Рєњ\t}\n    95Рєњ\n    96Рєњ\t// Commands that need a daemon connection\n    97Рєњ\taddr := os.Getenv(\"CLOCHE_ADDR\")\n    98Рєњ\tif addr == \"\" {\n    99Рєњ\t\taddr = \"unix:///tmp/cloche.sock\"\n   100Рєњ\t}\n   101Рєњ\n   102Рєњ\tconn, err := grpc.NewClient(addr, grpc.WithTransportCredentials(insecure.NewCredentials()))\n   103Рєњ\tif err != nil {\n   104Рєњ\t\tfmt.Fprintf(os.Stderr, \"failed to connect: %v\\n\", err)\n   105Рєњ\t\tos.Exit(1)\n   106Рєњ\t}\n   107Рєњ\tdefer conn.Close()\n   108Рєњ\n   109Рєњ\tclient := pb.NewClocheServiceClient(conn)\n   110Рєњ\tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n   111Рєњ\tdefer cancel()\n   112Рєњ\n   113Рєњ\tswitch os.Args[1] {\n   114Рєњ\tcase \"run\":\n   115Рєњ\t\tcmdRun(ctx, client, os.Args[2:])\n   116Рєњ\tcase \"status\":\n   117Рєњ\t\tcmdStatus(ctx, client, os.Args[2:])\n   118Рєњ\tcase \"logs\":\n   119Рєњ\t\tcmdLogs(client, os.Args[2:])\n   120Рєњ\tcase \"poll\":\n   121Рєњ\t\tcmdPoll(client, os.Args[2:])\n   122Рєњ\tcase \"list\":\n   123Рєњ\t\tcmdList(ctx, client, os.Args[2:])\n   124Рєњ\tcase \"stop\":\n   125Рєњ\t\tcmdStop(ctx, client, os.Args[2:])\n   126Рєњ\tcase \"delete\":\n   127Рєњ\t\tcmdDelete(ctx, client, os.Args[2:])\n   128Рєњ\tcase \"loop\":\n   129Рєњ\t\tcmdLoop(ctx, client, os.Args[2:])\n   130Рєњ\tcase \"shutdown\":\n   131Рєњ\t\tcmdShutdown(ctx, client)\n   132Рєњ\tdefault:\n   133Рєњ\t\tfmt.Fprintf(os.Stderr, \"unknown command: %s\\n\\n\", os.Args[1])\n   134Рєњ\t\tprintTopLevelHelp()\n   135Рєњ\t\tos.Exit(1)\n   136Рєњ\t}\n   137Рєњ}\n   138Рєњ\n   139Рєњ\n   140Рєњfunc cmdRun(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   141Рєњ\tvar workflow, prompt, title string\n   142Рєњ\tvar keepContainer bool\n   143Рєњ\n   144Рєњ\tfor i := 0; i < len(args); i++ {\n   145Рєњ\t\tswitch args[i] {\n   146Рєњ\t\tcase \"--workflow\":\n   147Рєњ\t\t\tif i+1 < len(args) {\n   148Рєњ\t\t\t\ti++\n   149Рєњ\t\t\t\tworkflow = args[i]\n   150Рєњ\t\t\t}\n   151Рєњ\t\tcase \"--prompt\", \"-p\":\n   152Рєњ\t\t\tif i+1 < len(args) {\n   153Рєњ\t\t\t\ti++\n   154Рєњ\t\t\t\tprompt = args[i]\n   155Рєњ\t\t\t}\n   156Рєњ\t\tcase \"--title\":\n   157Рєњ\t\t\tif i+1 < len(args) {\n   158Рєњ\t\t\t\ti++\n   159Рєњ\t\t\t\ttitle = args[i]\n   160Рєњ\t\t\t}\n   161Рєњ\t\tcase \"--keep-container\":\n   162Рєњ\t\t\tkeepContainer = true\n   163Рєњ\t\tdefault:\n   164Рєњ\t\t\t// Support bare positional arg as workflow name for backwards compat\n   165Рєњ\t\t\tif workflow == \"\" && !strings.HasPrefix(args[i], \"-\") {\n   166Рєњ\t\t\t\tworkflow = args[i]\n   167Рєњ\t\t\t}\n   168Рєњ\t\t}\n   169Рєњ\t}\n   170Рєњ\n   171Рєњ\tif workflow == \"\" {\n   172Рєњ\t\tfmt.Fprintf(os.Stderr, \"usage: cloche run --workflow <name> [--prompt \\\"...\\\"] [--title \\\"...\\\"]\\n\")\n   173Рєњ\t\tos.Exit(1)\n   174Рєњ\t}\n   175Рєњ\n   176Рєњ\tcwd, _ := os.Getwd()\n   177Рєњ\n   178Рєњ\t// Resolve image from workflow file (soft failure Рђћ fall back to daemon default)\n   179Рєњ\tvar image string\n   180Рєњ\twfPath := filepath.Join(cwd, \".cloche\", workflow+\".cloche\")\n   181Рєњ\tif data, err := os.ReadFile(wfPath); err == nil {\n   182Рєњ\t\tif wf, err := dsl.ParseForContainer(string(data)); err == nil {\n   183Рєњ\t\t\timage = wf.Config[\"container.image\"]\n   184Рєњ\t\t}\n   185Рєњ\t}\n   186Рєњ\n   187Рєњ\tresp, err := client.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n   188Рєњ\t\tWorkflowName:  workflow,\n   189Рєњ\t\tProjectDir:    cwd,\n   190Рєњ\t\tImage:         image,\n   191Рєњ\t\tPrompt:        prompt,\n   192Рєњ\t\tKeepContainer: keepContainer,\n   193Рєњ\t\tTitle:         title,\n   194Рєњ\t})\n   195Рєњ\tif err != nil {\n   196Рєњ\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   197Рєњ\t\tos.Exit(1)\n   198Рєњ\t}\n   199Рєњ\tfmt.Printf(\"Started run: %s\\n\", resp.RunId)\n   200Рєњ}\n   201Рєњ\n   202Рєњfunc cmdStatus(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   203Рєњ\tif len(args) < 1 {\n   204Рєњ\t\tfmt.Fprintf(os.Stderr, \"usage: cloche status <run-id>\\n\")\n   205Рєњ\t\tos.Exit(1)\n   206Рєњ\t}\n   207Рєњ\n   208Рєњ\tresp, err := client.GetStatus(ctx, &pb.GetStatusRequest{RunId: args[0]})\n   209Рєњ\tif err != nil {\n   210Рєњ\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   211Рєњ\t\tos.Exit(1)\n   212Рєњ\t}\n   213Рєњ\n   214Рєњ\tfmt.Printf(\"Run:       %s\\n\", resp.RunId)\n   215Рєњ\tif resp.Title != \"\" {\n   216Рєњ\t\tfmt.Printf(\"Title:     %s\\n\", resp.Title)\n   217Рєњ\t}\n   218Рєњ\tfmt.Printf(\"Workflow:  %s\\n\", resp.WorkflowName)\n   219Рєњ\tif resp.IsHost {\n   220Рєњ\t\tfmt.Printf(\"Type:      host\\n\")\n   221Рєњ\t} else {\n   222Рєњ\t\tfmt.Printf(\"Type:      container\\n\")\n   223Рєњ\t}\n   224Рєњ\tfmt.Printf(\"State:     %s\\n\", resp.State)\n   225Рєњ\tif resp.ContainerId != \"\" {\n   226Рєњ\t\tcid := resp.ContainerId\n   227Рєњ\t\tif len(cid) > 12 {\n   228Рєњ\t\t\tcid = cid[:12]\n   229Рєњ\t\t}\n   230Рєњ\t\tfmt.Printf(\"Container: %s\\n\", cid)\n   231Рєњ\t}\n   232Рєњ\tif resp.ErrorMessage != \"\" {\n   233Рєњ\t\tfmt.Printf(\"Error:     %s\\n\", resp.ErrorMessage)\n   234Рєњ\t}\n   235Рєњ\tfmt.Printf(\"Active:    %s\\n\", resp.CurrentStep)\n   236Рєњ\tfor _, exec := range resp.StepExecutions {\n   237Рєњ\t\tfmt.Printf(\"  %s: %s (%s -> %s)\\n\", exec.StepName, exec.Result, exec.StartedAt, exec.CompletedAt)\n   238Рєњ\t}\n   239Рєњ}\n   240Рєњ\n   241Рєњfunc cmdList(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   242Рєњ\tvar all bool\n   243Рєњ\tfor _, arg := range args {\n   244Рєњ\t\tif arg == \"--all\" {\n   245Рєњ\t\t\tall = true\n   246Рєњ\t\t}\n   247Рєњ\t}\n   248Рєњ\n   249Рєњ\treq := &pb.ListRunsRequest{}\n   250Рєњ\tif all {\n   251Рєњ\t\t// --all: show all runs across all projects (no time limit)\n   252Рєњ\t\treq.All = true\n   253Рєњ\t} else {\n   254Рєњ\t\t// Default: filter to current project\n   255Рєњ\t\tcwd, _ := os.Getwd()\n   256Рєњ\t\treq.ProjectDir = cwd\n   257Рєњ\t}\n   258Рєњ\n   259Рєњ\tresp, err := client.ListRuns(ctx, req)\n   260Рєњ\tif err != nil {\n   261Рєњ\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   262Рєњ\t\tos.Exit(1)\n   263Рєњ\t}\n   264Рєњ\n   265Рєњ\tif len(resp.Runs) == 0 {\n   266Рєњ\t\tfmt.Println(\"No runs found.\")\n   267Рєњ\t\treturn\n   268Рєњ\t}\n   269Рєњ\n   270Рєњ\tfor _, run := range resp.Runs {\n   271Рєњ\t\trunType := \"container\"\n   272Рєњ\t\tif run.IsHost {\n   273Рєњ\t\t\trunType = \"host\"\n   274Рєњ\t\t}\n   275Рєњ\t\tline := fmt.Sprintf(\"%s  %-20s  %-10s  %-9s\", run.RunId, run.WorkflowName, run.State, runType)\n   276Рєњ\t\tif run.Title != \"\" {\n   277Рєњ\t\t\tt := run.Title\n   278Рєњ\t\t\tif len(t) > 40 {\n   279Рєњ\t\t\t\tt = t[:37] + \"...\"\n   280Рєњ\t\t\t}\n   281Рєњ\t\t\tline += \"  \" + t\n   282Рєњ\t\t}\n   283Рєњ\t\tif run.ContainerId != \"\" {\n   284Рєњ\t\t\tline += \"  \" + run.ContainerId\n   285Рєњ\t\t}\n   286Рєњ\t\tif run.ErrorMessage != \"\" {\n   287Рєњ\t\t\terrMsg := run.ErrorMessage\n   288Рєњ\t\t\tif len(errMsg) > 60 {\n   289Рєњ\t\t\t\terrMsg = errMsg[:57] + \"...\"\n   290Рєњ\t\t\t}\n   291Рєњ\t\t\tline += \"  \" + errMsg\n   292Рєњ\t\t}\n   293Рєњ\t\tfmt.Println(line)\n   294Рєњ\t}\n   295Рєњ}\n   296Рєњ\n   297Рєњfunc cmdLogs(client pb.ClocheServiceClient, args []string) {\n   298Рєњ\tif len(args) < 1 {\n   299Рєњ\t\tfmt.Fprintf(os.Stderr, \"usage: cloche logs <run-id> [--step <name>] [--type <full|script|llm>] [-f]\\n\")\n   300Рєњ\t\tos.Exit(1)\n   301Рєњ\t}\n   302Рєњ\n   303Рєњ\tvar stepFilter, typeFilter string\n   304Рєњ\tvar follow bool\n   305Рєњ\trunID := args[0]\n   306Рєњ\n   307Рєњ\tfor i := 1; i < len(args); i++ {\n   308Рєњ\t\tswitch args[i] {\n   309Рєњ\t\tcase \"--step\":\n   310Рєњ\t\t\tif i+1 < len(args) {\n   311Рєњ\t\t\t\ti++\n   312Рєњ\t\t\t\tstepFilter = args[i]\n   313Рєњ\t\t\t}\n   314Рєњ\t\tcase \"--type\":\n   315Рєњ\t\t\tif i+1 < len(args) {\n   316Рєњ\t\t\t\ti++\n   317Рєњ\t\t\t\ttypeFilter = args[i]\n   318Рєњ\t\t\t}\n   319Рєњ\t\tcase \"--follow\", \"-f\":\n   320Рєњ\t\t\tfollow = true\n   321Рєњ\t\t}\n   322Рєњ\t}\n   323Рєњ\n   324Рєњ\t// Use background context Рђћ log output can be large and follow mode blocks.\n   325Рєњ\tctx := context.Background()\n   326Рєњ\tif follow {\n   327Рєњ\t\tmd := metadata.Pairs(\"x-cloche-follow\", \"true\")\n   328Рєњ\t\tctx = metadata.NewOutgoingContext(ctx, md)\n   329Рєњ\t}\n   330Рєњ\n   331Рєњ\tstream, err := client.StreamLogs(ctx, &pb.StreamLogsRequest{\n   332Рєњ\t\tRunId:    runID,\n   333Рєњ\t\tStepName: stepFilter,\n   334Рєњ\t\tLogType:  typeFilter,\n   335Рєњ\t})\n   336Рєњ\tif err != nil {\n   337Рєњ\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   338Рєњ\t\tos.Exit(1)\n   339Рєњ\t}\n   340Рєњ\n   341Рєњ\tfor {\n   342Рєњ\t\tentry, err := stream.Recv()\n   343Рєњ\t\tif err != nil {\n   344Рєњ\t\t\tif errors.Is(err, io.EOF) {\n   345Рєњ\t\t\t\tbreak\n   346Рєњ\t\t\t}\n   347Рєњ\t\t\tfmt.Fprintf(os.Stderr, \"error reading logs: %v\\n\", err)\n   348Рєњ\t\t\tos.Exit(1)\n   349Рєњ\t\t}\n   350Рєњ\n   351Рєњ\t\tswitch entry.Type {\n   352Рєњ\t\tcase \"step_started\":\n   353Рєњ\t\t\tfmt.Printf(\"--- %s started ---\\n\", entry.StepName)\n   354Рєњ\t\t\tif entry.Message != \"\" {\n   355Рєњ\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n   356Рєњ\t\t\t}\n   357Рєњ\t\tcase \"step_completed\":\n   358Рєњ\t\t\tfmt.Printf(\"--- %s: %s ---\\n\", entry.StepName, entry.Result)\n   359Рєњ\t\t\tif entry.Message != \"\" {\n   360Рєњ\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n   361Рєњ\t\t\t}\n   362Рєњ\t\tcase \"run_completed\":\n   363Рєњ\t\t\tfmt.Printf(\"\\nRun result: %s\\n\", entry.Result)\n   364Рєњ\t\t\tif entry.Message != \"\" {\n   365Рєњ\t\t\t\tfmt.Printf(\"Error:      %s\\n\", entry.Message)\n   366Рєњ\t\t\t}\n   367Рєњ\t\tcase \"full_log\":\n   368Рєњ\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n   369Рєњ\t\tcase \"log\":\n   370Рєњ\t\t\t// Live-streamed log line from an active run.\n   371Рєњ\t\t\tfmt.Println(entry.Message)\n   372Рєњ\t\tdefault:\n   373Рєњ\t\t\t// Handles filtered log entries like \"script_log\", \"llm_log\", \"step_log\"\n   374Рєњ\t\t\tif entry.StepName != \"\" {\n   375Рєњ\t\t\t\tfmt.Printf(\"--- %s ---\\n\", entry.StepName)\n   376Рєњ\t\t\t}\n   377Рєњ\t\t\tif entry.Message != \"\" {\n   378Рєњ\t\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n   379Рєњ\t\t\t}\n   380Рєњ\t\t}\n   381Рєњ\t}\n   382Рєњ}\n   383Рєњ\n   384Рєњfunc cmdStop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   385Рєњ\tif len(args) < 1 {\n   386Рєњ\t\tfmt.Fprintf(os.Stderr, \"usage: cloche stop <run-id>\\n\")\n   387Рєњ\t\tos.Exit(1)\n   388Рєњ\t}\n   389Рєњ\n   390Рєњ\t_, err := client.StopRun(ctx, &pb.StopRunRequest{RunId: args[0]})\n   391Рєњ\tif err != nil {\n   392Рєњ\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   393Рєњ\t\tos.Exit(1)\n   394Рєњ\t}\n   395Рєњ\tfmt.Printf(\"Stopped run: %s\\n\", args[0])\n   396Рєњ}\n   397Рєњ\n   398Рєњfunc cmdDelete(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   399Рєњ\tif len(args) < 1 {\n   400Рєњ\t\tfmt.Fprintf(os.Stderr, \"usage: cloche delete <container-or-run-id>\\n\")\n   401Рєњ\t\tos.Exit(1)\n   402Рєњ\t}\n   403Рєњ\n   404Рєњ\t_, err := client.DeleteContainer(ctx, &pb.DeleteContainerRequest{Id: args[0]})\n   405Рєњ\tif err != nil {\n   406Рєњ\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   407Рєњ\t\tos.Exit(1)\n   408Рєњ\t}\n   409Рєњ\tfmt.Printf(\"Deleted container: %s\\n\", args[0])\n   410Рєњ}\n   411Рєњ\n   412Рєњfunc cmdLoop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   413Рєњ\tcwd, _ := os.Getwd()\n   414Рєњ\n   415Рєњ\t// Check for \"stop\" subcommand\n   416Рєњ\tif len(args) > 0 && args[0] == \"stop\" {\n   417Рєњ\t\t_, err := client.DisableLoop(ctx, &pb.DisableLoopRequest{ProjectDir: cwd})\n   418Рєњ\t\tif err != nil {\n   419Рєњ\t\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   420Рєњ\t\t\tos.Exit(1)\n   421Рєњ\t\t}\n   422Рєњ\t\tfmt.Println(\"Orchestration loop stopped.\")\n   423Рєњ\t\treturn\n   424Рєњ\t}\n   425Рєњ\n   426Рєњ\t// Default: 0 means \"use config value\" (server reads .cloche/config.toml).\n   427Рєњ\tvar maxConcurrent int32\n   428Рєњ\tfor i := 0; i < len(args); i++ {\n   429Рєњ\t\tswitch args[i] {\n   430Рєњ\t\tcase \"--max\":\n   431Рєњ\t\t\tif i+1 < len(args) {\n   432Рєњ\t\t\t\ti++\n   433Рєњ\t\t\t\tn, err := fmt.Sscanf(args[i], \"%d\", &maxConcurrent)\n   434Рєњ\t\t\t\tif n != 1 || err != nil {\n   435Рєњ\t\t\t\t\tfmt.Fprintf(os.Stderr, \"invalid --max value: %s\\n\", args[i])\n   436Рєњ\t\t\t\t\tos.Exit(1)\n   437Рєњ\t\t\t\t}\n   438Рєњ\t\t\t}\n   439Рєњ\t\t}\n   440Рєњ\t}\n   441Рєњ\n   442Рєњ\t_, err := client.EnableLoop(ctx, &pb.EnableLoopRequest{\n   443Рєњ\t\tProjectDir:    cwd,\n   444Рєњ\t\tMaxConcurrent: maxConcurrent,\n   445Рєњ\t})\n   446Рєњ\tif err != nil {\n   447Рєњ\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   448Рєњ\t\tos.Exit(1)\n   449Рєњ\t}\n   450Рєњ\tif maxConcurrent > 0 {\n   451Рєњ\t\tfmt.Printf(\"Orchestration loop started (max_concurrent=%d).\\n\", maxConcurrent)\n   452Рєњ\t} else {\n   453Рєњ\t\tfmt.Println(\"Orchestration loop started (using config defaults).\")\n   454Рєњ\t}\n   455Рєњ}\n   456Рєњ\n   457Рєњfunc cmdTasks(args []string) {\n   458Рєњ\t// Determine HTTP address from env\n   459Рєњ\thttpAddr := os.Getenv(\"CLOCHE_HTTP\")\n   460Рєњ\tif httpAddr == \"\" {\n   461Рєњ\t\thttpAddr = \"localhost:8080\"\n   462Рєњ\t}\n   463Рєњ\thttpAddr = strings.TrimPrefix(httpAddr, \"http://\")\n   464Рєњ\n   465Рєњ\t// Determine project label from --project flag or current directory\n   466Рєњ\tprojectDir := \"\"\n   467Рєњ\tfor i := 0; i < len(args); i++ {\n   468Рєњ\t\tswitch args[i] {\n   469Рєњ\t\tcase \"--project\":\n   470Рєњ\t\t\tif i+1 < len(args) {\n   471Рєњ\t\t\t\ti++\n   472Рєњ\t\t\t\tprojectDir = args[i]\n   473Рєњ\t\t\t}\n   474Рєњ\t\t}\n   475Рєњ\t}\n   476Рєњ\n   477Рєњ\tif projectDir == \"\" {\n   478Рєњ\t\tcwd, _ := os.Getwd()\n   479Рєњ\t\tprojectDir = filepath.Base(cwd)\n   480Рєњ\t}\n   481Рєњ\n   482Рєњ\ttasksURL := fmt.Sprintf(\"http://%s/api/projects/%s/tasks\", httpAddr, projectDir)\n   483Рєњ\tresp, err := http.Get(tasksURL)\n   484Рєњ\tif err != nil {\n   485Рєњ\t\tfmt.Fprintf(os.Stderr, \"error connecting to daemon web API: %v\\n\", err)\n   486Рєњ\t\tfmt.Fprintf(os.Stderr, \"hint: ensure CLOCHE_HTTP is set and the daemon is running with --http\\n\")\n   487Рєњ\t\tos.Exit(1)\n   488Рєњ\t}\n   489Рєњ\tdefer resp.Body.Close()\n   490Рєњ\n   491Рєњ\tif resp.StatusCode != 200 {\n   492Рєњ\t\tbody, _ := io.ReadAll(resp.Body)\n   493Рєњ\t\tfmt.Fprintf(os.Stderr, \"error: HTTP %d: %s\\n\", resp.StatusCode, strings.TrimSpace(string(body)))\n   494Рєњ\t\tos.Exit(1)\n   495Рєњ\t}\n   496Рєњ\n   497Рєњ\ttype taskEntry struct {\n   498Рєњ\t\tID          string `json:\"id\"`\n   499Рєњ\t\tStatus      string `json:\"status\"`\n   500Рєњ\t\tTitle       string `json:\"title\"`\n   501Рєњ\t\tDescription string `json:\"description\"`\n   502Рєњ\t\tAssigned    bool   `json:\"assigned\"`\n   503Рєњ\t\tAssignedAt  string `json:\"assigned_at\"`\n   504Рєњ\t\tRunID       string `json:\"run_id\"`\n   505Рєњ\t}\n   506Рєњ\n   507Рєњ\tvar tasks []taskEntry\n   508Рєњ\tif err := json.NewDecoder(resp.Body).Decode(&tasks); err != nil {\n   509Рєњ\t\tfmt.Fprintf(os.Stderr, \"error parsing response: %v\\n\", err)\n   510Рєњ\t\tos.Exit(1)\n   511Рєњ\t}\n   512Рєњ\n   513Рєњ\tif len(tasks) == 0 {\n   514Рєњ\t\tfmt.Println(\"No tasks found. (Is the orchestration loop running?)\")\n   515Рєњ\t\treturn\n   516Рєњ\t}\n   517Рєњ\n   518Рєњ\tfmt.Printf(\"%-20s  %-12s  %-10s  %-30s  %s\\n\", \"ID\", \"STATUS\", \"ASSIGNED\", \"RUN\", \"TITLE\")\n   519Рєњ\tfor _, t := range tasks {\n   520Рєњ\t\tstatus := t.Status\n   521Рєњ\t\tif status == \"\" {\n   522Рєњ\t\t\tstatus = \"open\"\n   523Рєњ\t\t}\n   524Рєњ\t\tassigned := \"-\"\n   525Рєњ\t\tif t.Assigned {\n   526Рєњ\t\t\tassigned = \"yes\"\n   527Рєњ\t\t}\n   528Рєњ\t\trunID := \"\"\n   529Рєњ\t\tif t.RunID != \"\" {\n   530Рєњ\t\t\trunID = t.RunID\n   531Рєњ\t\t\tif len(runID) > 30 {\n   532Рєњ\t\t\t\trunID = runID[:27] + \"...\"\n   533Рєњ\t\t\t}\n   534Рєњ\t\t}\n   535Рєњ\t\ttitle := t.Title\n   536Рєњ\t\tif len(title) > 40 {\n   537Рєњ\t\t\ttitle = title[:37] + \"...\"\n   538Рєњ\t\t}\n   539Рєњ\t\tfmt.Printf(\"%-20s  %-12s  %-10s  %-30s  %s\\n\", t.ID, status, assigned, runID, title)\n   540Рєњ\t}\n   541Рєњ}\n   542Рєњ\n   543Рєњfunc cmdShutdown(ctx context.Context, client pb.ClocheServiceClient) {\n   544Рєњ\t_, err := client.Shutdown(ctx, &pb.ShutdownRequest{})\n   545Рєњ\tif err != nil {\n   546Рєњ\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   547Рєњ\t\tos.Exit(1)\n   548Рєњ\t}\n   549Рєњ\tfmt.Println(\"Daemon shutting down.\")\n   550Рєњ}\n   551Рєњ\n   552Рєњ// resolveRunContext returns the project directory and run ID for context\n   553Рєњ// commands. The run ID comes from CLOCHE_RUN_ID and the project directory\n   554Рєњ// from CLOCHE_PROJECT_DIR (falling back to cwd).\n   555Рєњfunc resolveRunContext() (projectDir, runID string, err error) {\n   556Рєњ\trunID = os.Getenv(\"CLOCHE_RUN_ID\")\n   557Рєњ\tif runID == \"\" {\n   558Рєњ\t\treturn \"\", \"\", fmt.Errorf(\"CLOCHE_RUN_ID environment variable is not set\")\n   559Рєњ\t}\n   560Рєњ\tprojectDir = os.Getenv(\"CLOCHE_PROJECT_DIR\")\n   561Рєњ\tif projectDir == \"\" {\n   562Рєњ\t\tprojectDir, err = os.Getwd()\n   563Рєњ\t\tif err != nil {\n   564Рєњ\t\t\treturn \"\", \"\", fmt.Errorf(\"getting working directory: %w\", err)\n   565Рєњ\t\t}\n   566Рєњ\t}\n   567Рєњ\treturn projectDir, runID, nil\n   568Рєњ}\n   569Рєњ\n   570Рєњfunc cmdGet(args []string) {\n   571Рєњ\tif len(args) < 1 {\n   572Рєњ\t\tfmt.Fprintf(os.Stderr, \"usage: cloche get <key>\\n\")\n   573Рєњ\t\tos.Exit(1)\n   574Рєњ\t}\n   575Рєњ\n   576Рєњ\tprojectDir, runID, err := resolveRunContext()\n   577Рєњ\tif err != nil {\n   578Рєњ\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   579Рєњ\t\tos.Exit(1)\n   580Рєњ\t}\n   581Рєњ\n   582Рєњ\tval, ok, err := runcontext.Get(projectDir, runID, args[0])\n   583Рєњ\tif err != nil {\n   584Рєњ\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   585Рєњ\t\tos.Exit(1)\n   586Рєњ\t}\n   587Рєњ\tif !ok {\n   588Рєњ\t\tos.Exit(1)\n   589Рєњ\t}\n   590Рєњ\tfmt.Println(val)\n   591Рєњ}\n   592Рєњ\n   593Рєњfunc cmdSet(args []string) {\n   594Рєњ\tif len(args) < 2 {\n   595Рєњ\t\tfmt.Fprintf(os.Stderr, \"usage: cloche set <key> <value>\\n\")\n   596Рєњ\t\tfmt.Fprintf(os.Stderr, \"       cloche set <key> -     (read value from stdin)\\n\")\n   597Рєњ\t\tos.Exit(1)\n   598Рєњ\t}\n   599Рєњ\n   600Рєњ\tprojectDir, runID, err := resolveRunContext()\n   601Рєњ\tif err != nil {\n   602Рєњ\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   603Рєњ\t\tos.Exit(1)\n   604Рєњ\t}\n   605Рєњ\n   606Рєњ\tvalue := args[1]\n   607Рєњ\tif value == \"-\" {\n   608Рєњ\t\tdata, err := io.ReadAll(os.Stdin)\n   609Рєњ\t\tif err != nil {\n   610Рєњ\t\t\tfmt.Fprintf(os.Stderr, \"error reading stdin: %v\\n\", err)\n   611Рєњ\t\t\tos.Exit(1)\n   612Рєњ\t\t}\n   613Рєњ\t\tvalue = strings.TrimRight(string(data), \"\\n\")\n   614Рєњ\t}\n   615Рєњ\n   616Рєњ\tif err := runcontext.Set(projectDir, runID, args[0], value); err != nil {\n   617Рєњ\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   618Рєњ\t\tos.Exit(1)\n   619Рєњ\t}\n   620Рєњ}\n   621Рєњ"}]},"parent_tool_use_id":null,"session_id":"2090add2-0fe6-4270-9f3b-b52deb6bac91","uuid":"d59dcb5b-25df-4572-b7da-6e845721696b","tool_use_result":{"type":"text","file":{"filePath":"/workspace/cmd/cloche/main.go","content":"package main\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"errors\"\n\t\"fmt\"\n\t\"io\"\n\t\"net/http\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"strings\"\n\t\"time\"\n\n\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n\t\"github.com/cloche-dev/cloche/internal/dsl\"\n\t\"github.com/cloche-dev/cloche/internal/logstream\"\n\t\"github.com/cloche-dev/cloche/internal/runcontext\"\n\t\"google.golang.org/grpc\"\n\t\"google.golang.org/grpc/credentials/insecure\"\n\t\"google.golang.org/grpc/metadata\"\n)\n\nfunc main() {\n\tif len(os.Args) < 2 {\n\t\tprintTopLevelHelp()\n\t\tos.Exit(1)\n\t}\n\n\t// Handle top-level help: \"cloche help\", \"cloche --help\", \"cloche -h\"\n\tswitch os.Args[1] {\n\tcase \"help\":\n\t\tprintHelp(os.Args[2:])\n\t\treturn\n\tcase \"--help\", \"-h\":\n\t\tprintTopLevelHelp()\n\t\treturn\n\t}\n\n\t// Commands that don't need a daemon connection\n\tswitch os.Args[1] {\n\tcase \"init\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"init\")\n\t\t\treturn\n\t\t}\n\t\tcmdInit(os.Args[2:])\n\t\treturn\n\tcase \"health\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"health\")\n\t\t\treturn\n\t\t}\n\t\tcmdHealth(os.Args[2:])\n\t\treturn\n\tcase \"get\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"get\")\n\t\t\treturn\n\t\t}\n\t\tcmdGet(os.Args[2:])\n\t\treturn\n\tcase \"set\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"set\")\n\t\t\treturn\n\t\t}\n\t\tcmdSet(os.Args[2:])\n\t\treturn\n\tcase \"tasks\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"tasks\")\n\t\t\treturn\n\t\t}\n\t\tcmdTasks(os.Args[2:])\n\t\treturn\n\tcase \"workflow\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"workflow\")\n\t\t\treturn\n\t\t}\n\t\tcmdWorkflow(os.Args[2:])\n\t\treturn\n\t}\n\n\t// Handle --help for daemon commands before connecting\n\tdaemonCmds := map[string]bool{\n\t\t\"run\": true, \"status\": true, \"logs\": true, \"poll\": true,\n\t\t\"list\": true, \"stop\": true, \"delete\": true, \"loop\": true, \"shutdown\": true,\n\t}\n\tif daemonCmds[os.Args[1]] && hasHelpFlag(os.Args[2:]) {\n\t\tprintSubcommandHelp(os.Args[1])\n\t\treturn\n\t}\n\n\t// Commands that need a daemon connection\n\taddr := os.Getenv(\"CLOCHE_ADDR\")\n\tif addr == \"\" {\n\t\taddr = \"unix:///tmp/cloche.sock\"\n\t}\n\n\tconn, err := grpc.NewClient(addr, grpc.WithTransportCredentials(insecure.NewCredentials()))\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"failed to connect: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tdefer conn.Close()\n\n\tclient := pb.NewClocheServiceClient(conn)\n\tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n\tdefer cancel()\n\n\tswitch os.Args[1] {\n\tcase \"run\":\n\t\tcmdRun(ctx, client, os.Args[2:])\n\tcase \"status\":\n\t\tcmdStatus(ctx, client, os.Args[2:])\n\tcase \"logs\":\n\t\tcmdLogs(client, os.Args[2:])\n\tcase \"poll\":\n\t\tcmdPoll(client, os.Args[2:])\n\tcase \"list\":\n\t\tcmdList(ctx, client, os.Args[2:])\n\tcase \"stop\":\n\t\tcmdStop(ctx, client, os.Args[2:])\n\tcase \"delete\":\n\t\tcmdDelete(ctx, client, os.Args[2:])\n\tcase \"loop\":\n\t\tcmdLoop(ctx, client, os.Args[2:])\n\tcase \"shutdown\":\n\t\tcmdShutdown(ctx, client)\n\tdefault:\n\t\tfmt.Fprintf(os.Stderr, \"unknown command: %s\\n\\n\", os.Args[1])\n\t\tprintTopLevelHelp()\n\t\tos.Exit(1)\n\t}\n}\n\n\nfunc cmdRun(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tvar workflow, prompt, title string\n\tvar keepContainer bool\n\n\tfor i := 0; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--workflow\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tworkflow = args[i]\n\t\t\t}\n\t\tcase \"--prompt\", \"-p\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tprompt = args[i]\n\t\t\t}\n\t\tcase \"--title\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\ttitle = args[i]\n\t\t\t}\n\t\tcase \"--keep-container\":\n\t\t\tkeepContainer = true\n\t\tdefault:\n\t\t\t// Support bare positional arg as workflow name for backwards compat\n\t\t\tif workflow == \"\" && !strings.HasPrefix(args[i], \"-\") {\n\t\t\t\tworkflow = args[i]\n\t\t\t}\n\t\t}\n\t}\n\n\tif workflow == \"\" {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche run --workflow <name> [--prompt \\\"...\\\"] [--title \\\"...\\\"]\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tcwd, _ := os.Getwd()\n\n\t// Resolve image from workflow file (soft failure Рђћ fall back to daemon default)\n\tvar image string\n\twfPath := filepath.Join(cwd, \".cloche\", workflow+\".cloche\")\n\tif data, err := os.ReadFile(wfPath); err == nil {\n\t\tif wf, err := dsl.ParseForContainer(string(data)); err == nil {\n\t\t\timage = wf.Config[\"container.image\"]\n\t\t}\n\t}\n\n\tresp, err := client.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n\t\tWorkflowName:  workflow,\n\t\tProjectDir:    cwd,\n\t\tImage:         image,\n\t\tPrompt:        prompt,\n\t\tKeepContainer: keepContainer,\n\t\tTitle:         title,\n\t})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Printf(\"Started run: %s\\n\", resp.RunId)\n}\n\nfunc cmdStatus(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche status <run-id>\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tresp, err := client.GetStatus(ctx, &pb.GetStatusRequest{RunId: args[0]})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tfmt.Printf(\"Run:       %s\\n\", resp.RunId)\n\tif resp.Title != \"\" {\n\t\tfmt.Printf(\"Title:     %s\\n\", resp.Title)\n\t}\n\tfmt.Printf(\"Workflow:  %s\\n\", resp.WorkflowName)\n\tif resp.IsHost {\n\t\tfmt.Printf(\"Type:      host\\n\")\n\t} else {\n\t\tfmt.Printf(\"Type:      container\\n\")\n\t}\n\tfmt.Printf(\"State:     %s\\n\", resp.State)\n\tif resp.ContainerId != \"\" {\n\t\tcid := resp.ContainerId\n\t\tif len(cid) > 12 {\n\t\t\tcid = cid[:12]\n\t\t}\n\t\tfmt.Printf(\"Container: %s\\n\", cid)\n\t}\n\tif resp.ErrorMessage != \"\" {\n\t\tfmt.Printf(\"Error:     %s\\n\", resp.ErrorMessage)\n\t}\n\tfmt.Printf(\"Active:    %s\\n\", resp.CurrentStep)\n\tfor _, exec := range resp.StepExecutions {\n\t\tfmt.Printf(\"  %s: %s (%s -> %s)\\n\", exec.StepName, exec.Result, exec.StartedAt, exec.CompletedAt)\n\t}\n}\n\nfunc cmdList(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tvar all bool\n\tfor _, arg := range args {\n\t\tif arg == \"--all\" {\n\t\t\tall = true\n\t\t}\n\t}\n\n\treq := &pb.ListRunsRequest{}\n\tif all {\n\t\t// --all: show all runs across all projects (no time limit)\n\t\treq.All = true\n\t} else {\n\t\t// Default: filter to current project\n\t\tcwd, _ := os.Getwd()\n\t\treq.ProjectDir = cwd\n\t}\n\n\tresp, err := client.ListRuns(ctx, req)\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tif len(resp.Runs) == 0 {\n\t\tfmt.Println(\"No runs found.\")\n\t\treturn\n\t}\n\n\tfor _, run := range resp.Runs {\n\t\trunType := \"container\"\n\t\tif run.IsHost {\n\t\t\trunType = \"host\"\n\t\t}\n\t\tline := fmt.Sprintf(\"%s  %-20s  %-10s  %-9s\", run.RunId, run.WorkflowName, run.State, runType)\n\t\tif run.Title != \"\" {\n\t\t\tt := run.Title\n\t\t\tif len(t) > 40 {\n\t\t\t\tt = t[:37] + \"...\"\n\t\t\t}\n\t\t\tline += \"  \" + t\n\t\t}\n\t\tif run.ContainerId != \"\" {\n\t\t\tline += \"  \" + run.ContainerId\n\t\t}\n\t\tif run.ErrorMessage != \"\" {\n\t\t\terrMsg := run.ErrorMessage\n\t\t\tif len(errMsg) > 60 {\n\t\t\t\terrMsg = errMsg[:57] + \"...\"\n\t\t\t}\n\t\t\tline += \"  \" + errMsg\n\t\t}\n\t\tfmt.Println(line)\n\t}\n}\n\nfunc cmdLogs(client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche logs <run-id> [--step <name>] [--type <full|script|llm>] [-f]\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tvar stepFilter, typeFilter string\n\tvar follow bool\n\trunID := args[0]\n\n\tfor i := 1; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--step\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tstepFilter = args[i]\n\t\t\t}\n\t\tcase \"--type\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\ttypeFilter = args[i]\n\t\t\t}\n\t\tcase \"--follow\", \"-f\":\n\t\t\tfollow = true\n\t\t}\n\t}\n\n\t// Use background context Рђћ log output can be large and follow mode blocks.\n\tctx := context.Background()\n\tif follow {\n\t\tmd := metadata.Pairs(\"x-cloche-follow\", \"true\")\n\t\tctx = metadata.NewOutgoingContext(ctx, md)\n\t}\n\n\tstream, err := client.StreamLogs(ctx, &pb.StreamLogsRequest{\n\t\tRunId:    runID,\n\t\tStepName: stepFilter,\n\t\tLogType:  typeFilter,\n\t})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tfor {\n\t\tentry, err := stream.Recv()\n\t\tif err != nil {\n\t\t\tif errors.Is(err, io.EOF) {\n\t\t\t\tbreak\n\t\t\t}\n\t\t\tfmt.Fprintf(os.Stderr, \"error reading logs: %v\\n\", err)\n\t\t\tos.Exit(1)\n\t\t}\n\n\t\tswitch entry.Type {\n\t\tcase \"step_started\":\n\t\t\tfmt.Printf(\"--- %s started ---\\n\", entry.StepName)\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n\t\t\t}\n\t\tcase \"step_completed\":\n\t\t\tfmt.Printf(\"--- %s: %s ---\\n\", entry.StepName, entry.Result)\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n\t\t\t}\n\t\tcase \"run_completed\":\n\t\t\tfmt.Printf(\"\\nRun result: %s\\n\", entry.Result)\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Printf(\"Error:      %s\\n\", entry.Message)\n\t\t\t}\n\t\tcase \"full_log\":\n\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n\t\tcase \"log\":\n\t\t\t// Live-streamed log line from an active run.\n\t\t\tfmt.Println(entry.Message)\n\t\tdefault:\n\t\t\t// Handles filtered log entries like \"script_log\", \"llm_log\", \"step_log\"\n\t\t\tif entry.StepName != \"\" {\n\t\t\t\tfmt.Printf(\"--- %s ---\\n\", entry.StepName)\n\t\t\t}\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n\t\t\t}\n\t\t}\n\t}\n}\n\nfunc cmdStop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche stop <run-id>\\n\")\n\t\tos.Exit(1)\n\t}\n\n\t_, err := client.StopRun(ctx, &pb.StopRunRequest{RunId: args[0]})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Printf(\"Stopped run: %s\\n\", args[0])\n}\n\nfunc cmdDelete(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche delete <container-or-run-id>\\n\")\n\t\tos.Exit(1)\n\t}\n\n\t_, err := client.DeleteContainer(ctx, &pb.DeleteContainerRequest{Id: args[0]})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Printf(\"Deleted container: %s\\n\", args[0])\n}\n\nfunc cmdLoop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tcwd, _ := os.Getwd()\n\n\t// Check for \"stop\" subcommand\n\tif len(args) > 0 && args[0] == \"stop\" {\n\t\t_, err := client.DisableLoop(ctx, &pb.DisableLoopRequest{ProjectDir: cwd})\n\t\tif err != nil {\n\t\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\t\tos.Exit(1)\n\t\t}\n\t\tfmt.Println(\"Orchestration loop stopped.\")\n\t\treturn\n\t}\n\n\t// Default: 0 means \"use config value\" (server reads .cloche/config.toml).\n\tvar maxConcurrent int32\n\tfor i := 0; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--max\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tn, err := fmt.Sscanf(args[i], \"%d\", &maxConcurrent)\n\t\t\t\tif n != 1 || err != nil {\n\t\t\t\t\tfmt.Fprintf(os.Stderr, \"invalid --max value: %s\\n\", args[i])\n\t\t\t\t\tos.Exit(1)\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\t_, err := client.EnableLoop(ctx, &pb.EnableLoopRequest{\n\t\tProjectDir:    cwd,\n\t\tMaxConcurrent: maxConcurrent,\n\t})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tif maxConcurrent > 0 {\n\t\tfmt.Printf(\"Orchestration loop started (max_concurrent=%d).\\n\", maxConcurrent)\n\t} else {\n\t\tfmt.Println(\"Orchestration loop started (using config defaults).\")\n\t}\n}\n\nfunc cmdTasks(args []string) {\n\t// Determine HTTP address from env\n\thttpAddr := os.Getenv(\"CLOCHE_HTTP\")\n\tif httpAddr == \"\" {\n\t\thttpAddr = \"localhost:8080\"\n\t}\n\thttpAddr = strings.TrimPrefix(httpAddr, \"http://\")\n\n\t// Determine project label from --project flag or current directory\n\tprojectDir := \"\"\n\tfor i := 0; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--project\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tprojectDir = args[i]\n\t\t\t}\n\t\t}\n\t}\n\n\tif projectDir == \"\" {\n\t\tcwd, _ := os.Getwd()\n\t\tprojectDir = filepath.Base(cwd)\n\t}\n\n\ttasksURL := fmt.Sprintf(\"http://%s/api/projects/%s/tasks\", httpAddr, projectDir)\n\tresp, err := http.Get(tasksURL)\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error connecting to daemon web API: %v\\n\", err)\n\t\tfmt.Fprintf(os.Stderr, \"hint: ensure CLOCHE_HTTP is set and the daemon is running with --http\\n\")\n\t\tos.Exit(1)\n\t}\n\tdefer resp.Body.Close()\n\n\tif resp.StatusCode != 200 {\n\t\tbody, _ := io.ReadAll(resp.Body)\n\t\tfmt.Fprintf(os.Stderr, \"error: HTTP %d: %s\\n\", resp.StatusCode, strings.TrimSpace(string(body)))\n\t\tos.Exit(1)\n\t}\n\n\ttype taskEntry struct {\n\t\tID          string `json:\"id\"`\n\t\tStatus      string `json:\"status\"`\n\t\tTitle       string `json:\"title\"`\n\t\tDescription string `json:\"description\"`\n\t\tAssigned    bool   `json:\"assigned\"`\n\t\tAssignedAt  string `json:\"assigned_at\"`\n\t\tRunID       string `json:\"run_id\"`\n\t}\n\n\tvar tasks []taskEntry\n\tif err := json.NewDecoder(resp.Body).Decode(&tasks); err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error parsing response: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tif len(tasks) == 0 {\n\t\tfmt.Println(\"No tasks found. (Is the orchestration loop running?)\")\n\t\treturn\n\t}\n\n\tfmt.Printf(\"%-20s  %-12s  %-10s  %-30s  %s\\n\", \"ID\", \"STATUS\", \"ASSIGNED\", \"RUN\", \"TITLE\")\n\tfor _, t := range tasks {\n\t\tstatus := t.Status\n\t\tif status == \"\" {\n\t\t\tstatus = \"open\"\n\t\t}\n\t\tassigned := \"-\"\n\t\tif t.Assigned {\n\t\t\tassigned = \"yes\"\n\t\t}\n\t\trunID := \"\"\n\t\tif t.RunID != \"\" {\n\t\t\trunID = t.RunID\n\t\t\tif len(runID) > 30 {\n\t\t\t\trunID = runID[:27] + \"...\"\n\t\t\t}\n\t\t}\n\t\ttitle := t.Title\n\t\tif len(title) > 40 {\n\t\t\ttitle = title[:37] + \"...\"\n\t\t}\n\t\tfmt.Printf(\"%-20s  %-12s  %-10s  %-30s  %s\\n\", t.ID, status, assigned, runID, title)\n\t}\n}\n\nfunc cmdShutdown(ctx context.Context, client pb.ClocheServiceClient) {\n\t_, err := client.Shutdown(ctx, &pb.ShutdownRequest{})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Println(\"Daemon shutting down.\")\n}\n\n// resolveRunContext returns the project directory and run ID for context\n// commands. The run ID comes from CLOCHE_RUN_ID and the project directory\n// from CLOCHE_PROJECT_DIR (falling back to cwd).\nfunc resolveRunContext() (projectDir, runID string, err error) {\n\trunID = os.Getenv(\"CLOCHE_RUN_ID\")\n\tif runID == \"\" {\n\t\treturn \"\", \"\", fmt.Errorf(\"CLOCHE_RUN_ID environment variable is not set\")\n\t}\n\tprojectDir = os.Getenv(\"CLOCHE_PROJECT_DIR\")\n\tif projectDir == \"\" {\n\t\tprojectDir, err = os.Getwd()\n\t\tif err != nil {\n\t\t\treturn \"\", \"\", fmt.Errorf(\"getting working directory: %w\", err)\n\t\t}\n\t}\n\treturn projectDir, runID, nil\n}\n\nfunc cmdGet(args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche get <key>\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tprojectDir, runID, err := resolveRunContext()\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tval, ok, err := runcontext.Get(projectDir, runID, args[0])\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tif !ok {\n\t\tos.Exit(1)\n\t}\n\tfmt.Println(val)\n}\n\nfunc cmdSet(args []string) {\n\tif len(args) < 2 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche set <key> <value>\\n\")\n\t\tfmt.Fprintf(os.Stderr, \"       cloche set <key> -     (read value from stdin)\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tprojectDir, runID, err := resolveRunContext()\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tvalue := args[1]\n\tif value == \"-\" {\n\t\tdata, err := io.ReadAll(os.Stdin)\n\t\tif err != nil {\n\t\t\tfmt.Fprintf(os.Stderr, \"error reading stdin: %v\\n\", err)\n\t\t\tos.Exit(1)\n\t\t}\n\t\tvalue = strings.TrimRight(string(data), \"\\n\")\n\t}\n\n\tif err := runcontext.Set(projectDir, runID, args[0], value); err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n}\n","numLines":621,"startLine":1,"totalLines":621}}}
