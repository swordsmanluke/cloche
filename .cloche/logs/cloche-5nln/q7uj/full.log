[2026-03-13T17:47:31Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01H1KBVBtY5QLsAmQrFheeo7","type":"tool_result","content":"     1Рєњpackage main\n     2Рєњ\n     3Рєњimport (\n     4Рєњ\t\"fmt\"\n     5Рєњ\t\"os\"\n     6Рєњ\t\"path/filepath\"\n     7Рєњ\t\"sort\"\n     8Рєњ\t\"strings\"\n     9Рєњ\n    10Рєњ\t\"github.com/cloche-dev/cloche/internal/domain\"\n    11Рєњ\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    12Рєњ)\n    13Рєњ\n    14Рєњfunc cmdWorkflow(args []string) {\n    15Рєњ\tvar projectDir, workflowName string\n    16Рєњ\tfor i := 0; i < len(args); i++ {\n    17Рєњ\t\tswitch args[i] {\n    18Рєњ\t\tcase \"--project\", \"-p\":\n    19Рєњ\t\t\tif i+1 < len(args) {\n    20Рєњ\t\t\t\ti++\n    21Рєњ\t\t\t\tprojectDir = args[i]\n    22Рєњ\t\t\t}\n    23Рєњ\t\tdefault:\n    24Рєњ\t\t\tif !strings.HasPrefix(args[i], \"-\") && workflowName == \"\" {\n    25Рєњ\t\t\t\tworkflowName = args[i]\n    26Рєњ\t\t\t}\n    27Рєњ\t\t}\n    28Рєњ\t}\n    29Рєњ\n    30Рєњ\tif projectDir == \"\" {\n    31Рєњ\t\tprojectDir, _ = os.Getwd()\n    32Рєњ\t} else {\n    33Рєњ\t\tabs, err := filepath.Abs(projectDir)\n    34Рєњ\t\tif err == nil {\n    35Рєњ\t\t\tprojectDir = abs\n    36Рєњ\t\t}\n    37Рєњ\t}\n    38Рєњ\n    39Рєњ\tif workflowName == \"\" {\n    40Рєњ\t\tlistWorkflows(projectDir)\n    41Рєњ\t} else {\n    42Рєњ\t\tshowWorkflow(projectDir, workflowName)\n    43Рєњ\t}\n    44Рєњ}\n    45Рєњ\n    46Рєњtype workflowInfo struct {\n    47Рєњ\tname     string\n    48Рєњ\tlocation domain.WorkflowLocation\n    49Рєњ}\n    50Рєњ\n    51Рєњfunc discoverWorkflows(projectDir string) ([]workflowInfo, error) {\n    52Рєњ\tclocheDir := filepath.Join(projectDir, \".cloche\")\n    53Рєњ\tentries, err := filepath.Glob(filepath.Join(clocheDir, \"*.cloche\"))\n    54Рєњ\tif err != nil {\n    55Рєњ\t\treturn nil, err\n    56Рєњ\t}\n    57Рєњ\n    58Рєњ\tvar infos []workflowInfo\n    59Рєњ\tfor _, path := range entries {\n    60Рєњ\t\tbase := filepath.Base(path)\n    61Рєњ\t\tdata, err := os.ReadFile(path)\n    62Рєњ\t\tif err != nil {\n    63Рєњ\t\t\tcontinue\n    64Рєњ\t\t}\n    65Рєњ\n    66Рєњ\t\tif base == \"host.cloche\" {\n    67Рєњ\t\t\twfs, err := dsl.ParseAllForHost(string(data))\n    68Рєњ\t\t\tif err != nil {\n    69Рєњ\t\t\t\tcontinue\n    70Рєњ\t\t\t}\n    71Рєњ\t\t\tfor name := range wfs {\n    72Рєњ\t\t\t\tinfos = append(infos, workflowInfo{name: name, location: domain.LocationHost})\n    73Рєњ\t\t\t}\n    74Рєњ\t\t} else {\n    75Рєњ\t\t\twf, err := dsl.ParseForContainer(string(data))\n    76Рєњ\t\t\tif err != nil {\n    77Рєњ\t\t\t\tcontinue\n    78Рєњ\t\t\t}\n    79Рєњ\t\t\tinfos = append(infos, workflowInfo{name: wf.Name, location: domain.LocationContainer})\n    80Рєњ\t\t}\n    81Рєњ\t}\n    82Рєњ\n    83Рєњ\treturn infos, nil\n    84Рєњ}\n    85Рєњ\n    86Рєњfunc listWorkflows(projectDir string) {\n    87Рєњ\tinfos, err := discoverWorkflows(projectDir)\n    88Рєњ\tif err != nil {\n    89Рєњ\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n    90Рєњ\t\tos.Exit(1)\n    91Рєњ\t}\n    92Рєњ\n    93Рєњ\tif len(infos) == 0 {\n    94Рєњ\t\tfmt.Println(\"No workflows found.\")\n    95Рєњ\t\treturn\n    96Рєњ\t}\n    97Рєњ\n    98Рєњ\tvar container, host []string\n    99Рєњ\tfor _, info := range infos {\n   100Рєњ\t\tswitch info.location {\n   101Рєњ\t\tcase domain.LocationContainer:\n   102Рєњ\t\t\tcontainer = append(container, info.name)\n   103Рєњ\t\tcase domain.LocationHost:\n   104Рєњ\t\t\thost = append(host, info.name)\n   105Рєњ\t\t}\n   106Рєњ\t}\n   107Рєњ\n   108Рєњ\tsort.Strings(container)\n   109Рєњ\tsort.Strings(host)\n   110Рєњ\n   111Рєњ\tif len(container) > 0 {\n   112Рєњ\t\tfmt.Println(\"Container workflows:\")\n   113Рєњ\t\tfor _, name := range container {\n   114Рєњ\t\t\tfmt.Printf(\"  %s\\n\", name)\n   115Рєњ\t\t}\n   116Рєњ\t}\n   117Рєњ\n   118Рєњ\tif len(host) > 0 {\n   119Рєњ\t\tif len(container) > 0 {\n   120Рєњ\t\t\tfmt.Println()\n   121Рєњ\t\t}\n   122Рєњ\t\tfmt.Println(\"Host workflows:\")\n   123Рєњ\t\tfor _, name := range host {\n   124Рєњ\t\t\tfmt.Printf(\"  %s\\n\", name)\n   125Рєњ\t\t}\n   126Рєњ\t}\n   127Рєњ}\n   128Рєњ\n   129Рєњfunc loadWorkflow(projectDir, name string) (*domain.Workflow, error) {\n   130Рєњ\tclocheDir := filepath.Join(projectDir, \".cloche\")\n   131Рєњ\n   132Рєњ\t// Try container workflow first (named file)\n   133Рєњ\tcontainerPath := filepath.Join(clocheDir, name+\".cloche\")\n   134Рєњ\tif data, err := os.ReadFile(containerPath); err == nil {\n   135Рєњ\t\twf, err := dsl.ParseForContainer(string(data))\n   136Рєњ\t\tif err != nil {\n   137Рєњ\t\t\treturn nil, fmt.Errorf(\"parsing %s.cloche: %w\", name, err)\n   138Рєњ\t\t}\n   139Рєњ\t\treturn wf, nil\n   140Рєњ\t}\n   141Рєњ\n   142Рєњ\t// Try host workflow\n   143Рєњ\thostPath := filepath.Join(clocheDir, \"host.cloche\")\n   144Рєњ\tif data, err := os.ReadFile(hostPath); err == nil {\n   145Рєњ\t\twfs, err := dsl.ParseAllForHost(string(data))\n   146Рєњ\t\tif err != nil {\n   147Рєњ\t\t\treturn nil, fmt.Errorf(\"parsing host.cloche: %w\", err)\n   148Рєњ\t\t}\n   149Рєњ\t\tif wf, ok := wfs[name]; ok {\n   150Рєњ\t\t\treturn wf, nil\n   151Рєњ\t\t}\n   152Рєњ\t}\n   153Рєњ\n   154Рєњ\treturn nil, fmt.Errorf(\"workflow %q not found\", name)\n   155Рєњ}\n   156Рєњ\n   157Рєњfunc showWorkflow(projectDir, name string) {\n   158Рєњ\twf, err := loadWorkflow(projectDir, name)\n   159Рєњ\tif err != nil {\n   160Рєњ\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   161Рєњ\t\tos.Exit(1)\n   162Рєњ\t}\n   163Рєњ\tfmt.Print(renderWorkflowGraph(wf, isTTY()))\n   164Рєњ}\n   165Рєњ\n   166Рєњ// ANSI color codes for wire colorization.\n   167Рєњconst (\n   168Рєњ\tcolorReset   = \"\\033[0m\"\n   169Рєњ\tcolorGreen   = \"\\033[32m\"\n   170Рєњ\tcolorRed     = \"\\033[31m\"\n   171Рєњ\tcolorBlue    = \"\\033[34m\"\n   172Рєњ\tcolorYellow  = \"\\033[33m\"\n   173Рєњ\tcolorOrange  = \"\\033[38;5;208m\"\n   174Рєњ\tcolorMagenta = \"\\033[35m\"\n   175Рєњ)\n   176Рєњ\n   177Рєњvar otherResultColors = []string{colorBlue, colorYellow, colorOrange, colorMagenta}\n   178Рєњ\n   179Рєњ// buildResultColorMap assigns a color to each unique result name in the workflow.\n   180Рєњ// \"success\" is always green, \"fail\"/\"failed\" always red, others cycle through\n   181Рєњ// blue, yellow, orange, magenta.\n   182Рєњfunc buildResultColorMap(w *domain.Workflow, order []string) map[string]string {\n   183Рєњ\tcolorMap := map[string]string{\n   184Рєњ\t\t\"success\": colorGreen,\n   185Рєњ\t\t\"fail\":    colorRed,\n   186Рєњ\t\t\"failed\":  colorRed,\n   187Рєњ\t}\n   188Рєњ\n   189Рєњ\totherIdx := 0\n   190Рєњ\tfor _, stepName := range order {\n   191Рєњ\t\tstep := w.Steps[stepName]\n   192Рєњ\t\tfor _, r := range step.Results {\n   193Рєњ\t\t\tif _, ok := colorMap[r]; ok {\n   194Рєњ\t\t\t\tcontinue\n   195Рєњ\t\t\t}\n   196Рєњ\t\t\tcolorMap[r] = otherResultColors[otherIdx%len(otherResultColors)]\n   197Рєњ\t\t\totherIdx++\n   198Рєњ\t\t}\n   199Рєњ\t}\n   200Рєњ\n   201Рєњ\treturn colorMap\n   202Рєњ}\n   203Рєњ\n   204Рєњfunc renderWorkflowGraph(w *domain.Workflow, color bool) string {\n   205Рєњ\tvar buf strings.Builder\n   206Рєњ\n   207Рєњ\t// Header\n   208Рєњ\tfmt.Fprintf(&buf, \"workflow %q (%s)\\n\\n\", w.Name, w.Location)\n   209Рєњ\n   210Рєњ\torder := bfsOrder(w)\n   211Рєњ\tif len(order) == 0 {\n   212Рєњ\t\tbuf.WriteString(\"  (no steps)\\n\")\n   213Рєњ\t\treturn buf.String()\n   214Рєњ\t}\n   215Рєњ\n   216Рєњ\tcolorMap := buildResultColorMap(w, order)\n   217Рєњ\n   218Рєњ\t// Compute max step name length for consistent box widths\n   219Рєњ\tnameWidth := 0\n   220Рєњ\tfor _, name := range order {\n   221Рєњ\t\tif len(name) > nameWidth {\n   222Рєњ\t\t\tnameWidth = len(name)\n   223Рєњ\t\t}\n   224Рєњ\t}\n   225Рєњ\t// Minimum width\n   226Рєњ\tif nameWidth < 6 {\n   227Рєњ\t\tnameWidth = 6\n   228Рєњ\t}\n   229Рєњ\n   230Рєњ\tfor i, stepName := range order {\n   231Рєњ\t\tstep := w.Steps[stepName]\n   232Рєњ\t\tisEntry := stepName == w.EntryStep\n   233Рєњ\n   234Рєњ\t\trenderStepBox(&buf, step, isEntry, nameWidth)\n   235Рєњ\t\tgroups := groupWiresByDest(w, stepName)\n   236Рєњ\t\trenderWireGroups(&buf, groups, colorMap, color)\n   237Рєњ\n   238Рєњ\t\t// Also render any collect conditions originating from this step\n   239Рєњ\t\trenderCollects(&buf, w, stepName, colorMap, color)\n   240Рєњ\n   241Рєњ\t\tif i < len(order)-1 {\n   242Рєњ\t\t\tbuf.WriteString(\"\\n\")\n   243Рєњ\t\t}\n   244Рєњ\t}\n   245Рєњ\n   246Рєњ\treturn buf.String()\n   247Рєњ}\n   248Рєњ\n   249Рєњfunc renderStepBox(buf *strings.Builder, step *domain.Step, isEntry bool, nameWidth int) {\n   250Рєњ\tpadded := fmt.Sprintf(\" %-*s \", nameWidth, step.Name)\n   251Рєњ\tborder := strings.Repeat(\"Рћђ\", nameWidth+2)\n   252Рєњ\n   253Рєњ\tsuffix := fmt.Sprintf(\" %s\", step.Type)\n   254Рєњ\tif isEntry {\n   255Рєњ\t\tsuffix += \"  РЌђ entry\"\n   256Рєњ\t}\n   257Рєњ\n   258Рєњ\tfmt.Fprintf(buf, \"  Рћї%sРћљ\\n\", border)\n   259Рєњ\tfmt.Fprintf(buf, \"  Рћѓ%sРћѓ%s\\n\", padded, suffix)\n   260Рєњ\tfmt.Fprintf(buf, \"  Рћћ%sРћў\\n\", border)\n   261Рєњ}\n   262Рєњ\n   263Рєњtype wireGroup struct {\n   264Рєњ\tresults []string\n   265Рєњ\tto      string\n   266Рєњ}\n   267Рєњ\n   268Рєњ// groupWiresByDest groups wires from a step by destination, preserving order.\n   269Рєњ// Wires to the same destination are merged into a single group.\n   270Рєњfunc groupWiresByDest(w *domain.Workflow, stepName string) []wireGroup {\n   271Рєњ\tdestMap := make(map[string][]string)\n   272Рєњ\tvar destOrder []string\n   273Рєњ\n   274Рєњ\tfor _, wire := range w.Wiring {\n   275Рєњ\t\tif wire.From != stepName {\n   276Рєњ\t\t\tcontinue\n   277Рєњ\t\t}\n   278Рєњ\t\tif _, seen := destMap[wire.To]; !seen {\n   279Рєњ\t\t\tdestOrder = append(destOrder, wire.To)\n   280Рєњ\t\t}\n   281Рєњ\t\tdestMap[wire.To] = append(destMap[wire.To], wire.Result)\n   282Рєњ\t}\n   283Рєњ\n   284Рєњ\tvar groups []wireGroup\n   285Рєњ\tfor _, dest := range destOrder {\n   286Рєњ\t\tgroups = append(groups, wireGroup{results: destMap[dest], to: dest})\n   287Рєњ\t}\n   288Рєњ\treturn groups\n   289Рєњ}\n   290Рєњ\n   291Рєњfunc renderWireGroups(buf *strings.Builder, groups []wireGroup, colorMap map[string]string, useColor bool) {\n   292Рєњ\tfor i, g := range groups {\n   293Рєњ\t\tisLast := i == len(groups)-1\n   294Рєњ\t\tbranch := \"Рћю\"\n   295Рєњ\t\tif isLast {\n   296Рєњ\t\t\tbranch = \"Рћћ\"\n   297Рєњ\t\t}\n   298Рєњ\n   299Рєњ\t\t// Build colored result list\n   300Рєњ\t\tvar resultParts []string\n   301Рєњ\t\tfor _, r := range g.results {\n   302Рєњ\t\t\tif useColor {\n   303Рєњ\t\t\t\tresultParts = append(resultParts, colorMap[r]+r+colorReset)\n   304Рєњ\t\t\t} else {\n   305Рєњ\t\t\t\tresultParts = append(resultParts, r)\n   306Рєњ\t\t\t}\n   307Рєњ\t\t}\n   308Рєњ\t\tresultStr := strings.Join(resultParts, \", \")\n   309Рєњ\n   310Рєњ\t\t// Format destination\n   311Рєњ\t\tdest := formatDest(g.to, useColor)\n   312Рєњ\n   313Рєњ\t\tfmt.Fprintf(buf, \"    %sРћђРћђ %s РћђРћђРќХ %s\\n\", branch, resultStr, dest)\n   314Рєњ\t}\n   315Рєњ}\n   316Рєњ\n   317Рєњfunc formatDest(to string, useColor bool) string {\n   318Рєњ\tswitch to {\n   319Рєњ\tcase domain.StepDone:\n   320Рєњ\t\tif useColor {\n   321Рєњ\t\t\treturn colorGreen + \"DONE\" + colorReset\n   322Рєњ\t\t}\n   323Рєњ\t\treturn \"DONE\"\n   324Рєњ\tcase domain.StepAbort:\n   325Рєњ\t\tif useColor {\n   326Рєњ\t\t\treturn colorRed + \"ABORT\" + colorReset\n   327Рєњ\t\t}\n   328Рєњ\t\treturn \"ABORT\"\n   329Рєњ\tdefault:\n   330Рєњ\t\treturn to\n   331Рєњ\t}\n   332Рєњ}\n   333Рєњ\n   334Рєњ// renderCollects renders any collect conditions that reference this step.\n   335Рєњfunc renderCollects(buf *strings.Builder, w *domain.Workflow, stepName string, colorMap map[string]string, useColor bool) {\n   336Рєњ\tfor _, c := range w.Collects {\n   337Рєњ\t\t// Check if this step is part of the collect conditions\n   338Рєњ\t\tvar parts []string\n   339Рєњ\t\tinvolves := false\n   340Рєњ\t\tfor _, cond := range c.Conditions {\n   341Рєњ\t\t\tlabel := cond.Step + \":\" + cond.Result\n   342Рєњ\t\t\tif useColor {\n   343Рєњ\t\t\t\tif clr, ok := colorMap[cond.Result]; ok {\n   344Рєњ\t\t\t\t\tlabel = cond.Step + \":\" + clr + cond.Result + colorReset\n   345Рєњ\t\t\t\t}\n   346Рєњ\t\t\t}\n   347Рєњ\t\t\tparts = append(parts, label)\n   348Рєњ\t\t\tif cond.Step == stepName {\n   349Рєњ\t\t\t\tinvolves = true\n   350Рєњ\t\t\t}\n   351Рєњ\t\t}\n   352Рєњ\t\t// Only render the collect on the last condition step to avoid duplication\n   353Рєњ\t\tif involves && c.Conditions[len(c.Conditions)-1].Step == stepName {\n   354Рєњ\t\t\tdest := formatDest(c.To, useColor)\n   355Рєњ\t\t\tfmt.Fprintf(buf, \"    collect %s(%s) РћђРћђРќХ %s\\n\", c.Mode, strings.Join(parts, \", \"), dest)\n   356Рєњ\t\t}\n   357Рєњ\t}\n   358Рєњ}\n   359Рєњ\n   360Рєњ// bfsOrder returns steps in BFS order from the entry step.\n   361Рєњ// Handles cycles by skipping already-visited nodes.\n   362Рєњfunc bfsOrder(w *domain.Workflow) []string {\n   363Рєњ\tif w.EntryStep == \"\" {\n   364Рєњ\t\treturn nil\n   365Рєњ\t}\n   366Рєњ\n   367Рєњ\tvisited := map[string]bool{w.EntryStep: true}\n   368Рєњ\tvar order []string\n   369Рєњ\tqueue := []string{w.EntryStep}\n   370Рєњ\n   371Рєњ\tfor len(queue) > 0 {\n   372Рєњ\t\tcurrent := queue[0]\n   373Рєњ\t\tqueue = queue[1:]\n   374Рєњ\t\torder = append(order, current)\n   375Рєњ\n   376Рєњ\t\t// Collect unique target steps in wire order\n   377Рєњ\t\tfor _, wire := range w.Wiring {\n   378Рєњ\t\t\tif wire.From != current {\n   379Рєњ\t\t\t\tcontinue\n   380Рєњ\t\t\t}\n   381Рєњ\t\t\tif wire.To == domain.StepDone || wire.To == domain.StepAbort {\n   382Рєњ\t\t\t\tcontinue\n   383Рєњ\t\t\t}\n   384Рєњ\t\t\tif visited[wire.To] {\n   385Рєњ\t\t\t\tcontinue\n   386Рєњ\t\t\t}\n   387Рєњ\t\t\tvisited[wire.To] = true\n   388Рєњ\t\t\tqueue = append(queue, wire.To)\n   389Рєњ\t\t}\n   390Рєњ\t}\n   391Рєњ\n   392Рєњ\treturn order\n   393Рєњ}\n   394Рєњ"}]},"parent_tool_use_id":null,"session_id":"2090add2-0fe6-4270-9f3b-b52deb6bac91","uuid":"bb59043e-9397-4a5e-bc1c-067af49ab556","tool_use_result":{"type":"text","file":{"filePath":"/workspace/cmd/cloche/workflow.go","content":"package main\n\nimport (\n\t\"fmt\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"sort\"\n\t\"strings\"\n\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/dsl\"\n)\n\nfunc cmdWorkflow(args []string) {\n\tvar projectDir, workflowName string\n\tfor i := 0; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--project\", \"-p\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tprojectDir = args[i]\n\t\t\t}\n\t\tdefault:\n\t\t\tif !strings.HasPrefix(args[i], \"-\") && workflowName == \"\" {\n\t\t\t\tworkflowName = args[i]\n\t\t\t}\n\t\t}\n\t}\n\n\tif projectDir == \"\" {\n\t\tprojectDir, _ = os.Getwd()\n\t} else {\n\t\tabs, err := filepath.Abs(projectDir)\n\t\tif err == nil {\n\t\t\tprojectDir = abs\n\t\t}\n\t}\n\n\tif workflowName == \"\" {\n\t\tlistWorkflows(projectDir)\n\t} else {\n\t\tshowWorkflow(projectDir, workflowName)\n\t}\n}\n\ntype workflowInfo struct {\n\tname     string\n\tlocation domain.WorkflowLocation\n}\n\nfunc discoverWorkflows(projectDir string) ([]workflowInfo, error) {\n\tclocheDir := filepath.Join(projectDir, \".cloche\")\n\tentries, err := filepath.Glob(filepath.Join(clocheDir, \"*.cloche\"))\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tvar infos []workflowInfo\n\tfor _, path := range entries {\n\t\tbase := filepath.Base(path)\n\t\tdata, err := os.ReadFile(path)\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\n\t\tif base == \"host.cloche\" {\n\t\t\twfs, err := dsl.ParseAllForHost(string(data))\n\t\t\tif err != nil {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tfor name := range wfs {\n\t\t\t\tinfos = append(infos, workflowInfo{name: name, location: domain.LocationHost})\n\t\t\t}\n\t\t} else {\n\t\t\twf, err := dsl.ParseForContainer(string(data))\n\t\t\tif err != nil {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tinfos = append(infos, workflowInfo{name: wf.Name, location: domain.LocationContainer})\n\t\t}\n\t}\n\n\treturn infos, nil\n}\n\nfunc listWorkflows(projectDir string) {\n\tinfos, err := discoverWorkflows(projectDir)\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tif len(infos) == 0 {\n\t\tfmt.Println(\"No workflows found.\")\n\t\treturn\n\t}\n\n\tvar container, host []string\n\tfor _, info := range infos {\n\t\tswitch info.location {\n\t\tcase domain.LocationContainer:\n\t\t\tcontainer = append(container, info.name)\n\t\tcase domain.LocationHost:\n\t\t\thost = append(host, info.name)\n\t\t}\n\t}\n\n\tsort.Strings(container)\n\tsort.Strings(host)\n\n\tif len(container) > 0 {\n\t\tfmt.Println(\"Container workflows:\")\n\t\tfor _, name := range container {\n\t\t\tfmt.Printf(\"  %s\\n\", name)\n\t\t}\n\t}\n\n\tif len(host) > 0 {\n\t\tif len(container) > 0 {\n\t\t\tfmt.Println()\n\t\t}\n\t\tfmt.Println(\"Host workflows:\")\n\t\tfor _, name := range host {\n\t\t\tfmt.Printf(\"  %s\\n\", name)\n\t\t}\n\t}\n}\n\nfunc loadWorkflow(projectDir, name string) (*domain.Workflow, error) {\n\tclocheDir := filepath.Join(projectDir, \".cloche\")\n\n\t// Try container workflow first (named file)\n\tcontainerPath := filepath.Join(clocheDir, name+\".cloche\")\n\tif data, err := os.ReadFile(containerPath); err == nil {\n\t\twf, err := dsl.ParseForContainer(string(data))\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"parsing %s.cloche: %w\", name, err)\n\t\t}\n\t\treturn wf, nil\n\t}\n\n\t// Try host workflow\n\thostPath := filepath.Join(clocheDir, \"host.cloche\")\n\tif data, err := os.ReadFile(hostPath); err == nil {\n\t\twfs, err := dsl.ParseAllForHost(string(data))\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"parsing host.cloche: %w\", err)\n\t\t}\n\t\tif wf, ok := wfs[name]; ok {\n\t\t\treturn wf, nil\n\t\t}\n\t}\n\n\treturn nil, fmt.Errorf(\"workflow %q not found\", name)\n}\n\nfunc showWorkflow(projectDir, name string) {\n\twf, err := loadWorkflow(projectDir, name)\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Print(renderWorkflowGraph(wf, isTTY()))\n}\n\n// ANSI color codes for wire colorization.\nconst (\n\tcolorReset   = \"\\033[0m\"\n\tcolorGreen   = \"\\033[32m\"\n\tcolorRed     = \"\\033[31m\"\n\tcolorBlue    = \"\\033[34m\"\n\tcolorYellow  = \"\\033[33m\"\n\tcolorOrange  = \"\\033[38;5;208m\"\n\tcolorMagenta = \"\\033[35m\"\n)\n\nvar otherResultColors = []string{colorBlue, colorYellow, colorOrange, colorMagenta}\n\n// buildResultColorMap assigns a color to each unique result name in the workflow.\n// \"success\" is always green, \"fail\"/\"failed\" always red, others cycle through\n// blue, yellow, orange, magenta.\nfunc buildResultColorMap(w *domain.Workflow, order []string) map[string]string {\n\tcolorMap := map[string]string{\n\t\t\"success\": colorGreen,\n\t\t\"fail\":    colorRed,\n\t\t\"failed\":  colorRed,\n\t}\n\n\totherIdx := 0\n\tfor _, stepName := range order {\n\t\tstep := w.Steps[stepName]\n\t\tfor _, r := range step.Results {\n\t\t\tif _, ok := colorMap[r]; ok {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tcolorMap[r] = otherResultColors[otherIdx%len(otherResultColors)]\n\t\t\totherIdx++\n\t\t}\n\t}\n\n\treturn colorMap\n}\n\nfunc renderWorkflowGraph(w *domain.Workflow, color bool) string {\n\tvar buf strings.Builder\n\n\t// Header\n\tfmt.Fprintf(&buf, \"workflow %q (%s)\\n\\n\", w.Name, w.Location)\n\n\torder := bfsOrder(w)\n\tif len(order) == 0 {\n\t\tbuf.WriteString(\"  (no steps)\\n\")\n\t\treturn buf.String()\n\t}\n\n\tcolorMap := buildResultColorMap(w, order)\n\n\t// Compute max step name length for consistent box widths\n\tnameWidth := 0\n\tfor _, name := range order {\n\t\tif len(name) > nameWidth {\n\t\t\tnameWidth = len(name)\n\t\t}\n\t}\n\t// Minimum width\n\tif nameWidth < 6 {\n\t\tnameWidth = 6\n\t}\n\n\tfor i, stepName := range order {\n\t\tstep := w.Steps[stepName]\n\t\tisEntry := stepName == w.EntryStep\n\n\t\trenderStepBox(&buf, step, isEntry, nameWidth)\n\t\tgroups := groupWiresByDest(w, stepName)\n\t\trenderWireGroups(&buf, groups, colorMap, color)\n\n\t\t// Also render any collect conditions originating from this step\n\t\trenderCollects(&buf, w, stepName, colorMap, color)\n\n\t\tif i < len(order)-1 {\n\t\t\tbuf.WriteString(\"\\n\")\n\t\t}\n\t}\n\n\treturn buf.String()\n}\n\nfunc renderStepBox(buf *strings.Builder, step *domain.Step, isEntry bool, nameWidth int) {\n\tpadded := fmt.Sprintf(\" %-*s \", nameWidth, step.Name)\n\tborder := strings.Repeat(\"Рћђ\", nameWidth+2)\n\n\tsuffix := fmt.Sprintf(\" %s\", step.Type)\n\tif isEntry {\n\t\tsuffix += \"  РЌђ entry\"\n\t}\n\n\tfmt.Fprintf(buf, \"  Рћї%sРћљ\\n\", border)\n\tfmt.Fprintf(buf, \"  Рћѓ%sРћѓ%s\\n\", padded, suffix)\n\tfmt.Fprintf(buf, \"  Рћћ%sРћў\\n\", border)\n}\n\ntype wireGroup struct {\n\tresults []string\n\tto      string\n}\n\n// groupWiresByDest groups wires from a step by destination, preserving order.\n// Wires to the same destination are merged into a single group.\nfunc groupWiresByDest(w *domain.Workflow, stepName string) []wireGroup {\n\tdestMap := make(map[string][]string)\n\tvar destOrder []string\n\n\tfor _, wire := range w.Wiring {\n\t\tif wire.From != stepName {\n\t\t\tcontinue\n\t\t}\n\t\tif _, seen := destMap[wire.To]; !seen {\n\t\t\tdestOrder = append(destOrder, wire.To)\n\t\t}\n\t\tdestMap[wire.To] = append(destMap[wire.To], wire.Result)\n\t}\n\n\tvar groups []wireGroup\n\tfor _, dest := range destOrder {\n\t\tgroups = append(groups, wireGroup{results: destMap[dest], to: dest})\n\t}\n\treturn groups\n}\n\nfunc renderWireGroups(buf *strings.Builder, groups []wireGroup, colorMap map[string]string, useColor bool) {\n\tfor i, g := range groups {\n\t\tisLast := i == len(groups)-1\n\t\tbranch := \"Рћю\"\n\t\tif isLast {\n\t\t\tbranch = \"Рћћ\"\n\t\t}\n\n\t\t// Build colored result list\n\t\tvar resultParts []string\n\t\tfor _, r := range g.results {\n\t\t\tif useColor {\n\t\t\t\tresultParts = append(resultParts, colorMap[r]+r+colorReset)\n\t\t\t} else {\n\t\t\t\tresultParts = append(resultParts, r)\n\t\t\t}\n\t\t}\n\t\tresultStr := strings.Join(resultParts, \", \")\n\n\t\t// Format destination\n\t\tdest := formatDest(g.to, useColor)\n\n\t\tfmt.Fprintf(buf, \"    %sРћђРћђ %s РћђРћђРќХ %s\\n\", branch, resultStr, dest)\n\t}\n}\n\nfunc formatDest(to string, useColor bool) string {\n\tswitch to {\n\tcase domain.StepDone:\n\t\tif useColor {\n\t\t\treturn colorGreen + \"DONE\" + colorReset\n\t\t}\n\t\treturn \"DONE\"\n\tcase domain.StepAbort:\n\t\tif useColor {\n\t\t\treturn colorRed + \"ABORT\" + colorReset\n\t\t}\n\t\treturn \"ABORT\"\n\tdefault:\n\t\treturn to\n\t}\n}\n\n// renderCollects renders any collect conditions that reference this step.\nfunc renderCollects(buf *strings.Builder, w *domain.Workflow, stepName string, colorMap map[string]string, useColor bool) {\n\tfor _, c := range w.Collects {\n\t\t// Check if this step is part of the collect conditions\n\t\tvar parts []string\n\t\tinvolves := false\n\t\tfor _, cond := range c.Conditions {\n\t\t\tlabel := cond.Step + \":\" + cond.Result\n\t\t\tif useColor {\n\t\t\t\tif clr, ok := colorMap[cond.Result]; ok {\n\t\t\t\t\tlabel = cond.Step + \":\" + clr + cond.Result + colorReset\n\t\t\t\t}\n\t\t\t}\n\t\t\tparts = append(parts, label)\n\t\t\tif cond.Step == stepName {\n\t\t\t\tinvolves = true\n\t\t\t}\n\t\t}\n\t\t// Only render the collect on the last condition step to avoid duplication\n\t\tif involves && c.Conditions[len(c.Conditions)-1].Step == stepName {\n\t\t\tdest := formatDest(c.To, useColor)\n\t\t\tfmt.Fprintf(buf, \"    collect %s(%s) РћђРћђРќХ %s\\n\", c.Mode, strings.Join(parts, \", \"), dest)\n\t\t}\n\t}\n}\n\n// bfsOrder returns steps in BFS order from the entry step.\n// Handles cycles by skipping already-visited nodes.\nfunc bfsOrder(w *domain.Workflow) []string {\n\tif w.EntryStep == \"\" {\n\t\treturn nil\n\t}\n\n\tvisited := map[string]bool{w.EntryStep: true}\n\tvar order []string\n\tqueue := []string{w.EntryStep}\n\n\tfor len(queue) > 0 {\n\t\tcurrent := queue[0]\n\t\tqueue = queue[1:]\n\t\torder = append(order, current)\n\n\t\t// Collect unique target steps in wire order\n\t\tfor _, wire := range w.Wiring {\n\t\t\tif wire.From != current {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tif wire.To == domain.StepDone || wire.To == domain.StepAbort {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tif visited[wire.To] {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tvisited[wire.To] = true\n\t\t\tqueue = append(queue, wire.To)\n\t\t}\n\t}\n\n\treturn order\n}\n","numLines":394,"startLine":1,"totalLines":394}}}
[2026-03-13T17:47:31Z] [llm] {"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01VMJCnavRn93ubErejasrAJ","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_015cdFQ2yrxqo4C7dkP5Tj1X","name":"Read","input":{"file_path":"/workspace/cmd/cloche/workflow_test.go"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":3,"cache_creation_input_tokens":7853,"cache_read_input_tokens":8619,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":7853},"output_tokens":2,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"2090add2-0fe6-4270-9f3b-b52deb6bac91","uuid":"b03872b3-41db-4be0-a67d-80a636aa4ad3"}
[2026-03-13T17:47:31Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015cdFQ2yrxqo4C7dkP5Tj1X","type":"tool_result","content":"     1Рєњpackage main\n     2Рєњ\n     3Рєњimport (\n     4Рєњ\t\"os\"\n     5Рєњ\t\"path/filepath\"\n     6Рєњ\t\"strings\"\n     7Рєњ\t\"testing\"\n     8Рєњ\n     9Рєњ\t\"github.com/cloche-dev/cloche/internal/domain\"\n    10Рєњ)\n    11Рєњ\n    12Рєњfunc TestBfsOrder_LinearWorkflow(t *testing.T) {\n    13Рєњ\twf := &domain.Workflow{\n    14Рєњ\t\tEntryStep: \"a\",\n    15Рєњ\t\tSteps: map[string]*domain.Step{\n    16Рєњ\t\t\t\"a\": {Name: \"a\", Results: []string{\"ok\"}},\n    17Рєњ\t\t\t\"b\": {Name: \"b\", Results: []string{\"ok\"}},\n    18Рєњ\t\t\t\"c\": {Name: \"c\", Results: []string{\"ok\"}},\n    19Рєњ\t\t},\n    20Рєњ\t\tWiring: []domain.Wire{\n    21Рєњ\t\t\t{From: \"a\", Result: \"ok\", To: \"b\"},\n    22Рєњ\t\t\t{From: \"b\", Result: \"ok\", To: \"c\"},\n    23Рєњ\t\t\t{From: \"c\", Result: \"ok\", To: \"done\"},\n    24Рєњ\t\t},\n    25Рєњ\t}\n    26Рєњ\n    27Рєњ\torder := bfsOrder(wf)\n    28Рєњ\tif len(order) != 3 {\n    29Рєњ\t\tt.Fatalf(\"expected 3 steps, got %d: %v\", len(order), order)\n    30Рєњ\t}\n    31Рєњ\tif order[0] != \"a\" || order[1] != \"b\" || order[2] != \"c\" {\n    32Рєњ\t\tt.Errorf(\"expected [a b c], got %v\", order)\n    33Рєњ\t}\n    34Рєњ}\n    35Рєњ\n    36Рєњfunc TestBfsOrder_WithCycle(t *testing.T) {\n    37Рєњ\twf := &domain.Workflow{\n    38Рєњ\t\tEntryStep: \"a\",\n    39Рєњ\t\tSteps: map[string]*domain.Step{\n    40Рєњ\t\t\t\"a\": {Name: \"a\", Results: []string{\"ok\", \"fail\"}},\n    41Рєњ\t\t\t\"b\": {Name: \"b\", Results: []string{\"ok\", \"retry\"}},\n    42Рєњ\t\t},\n    43Рєњ\t\tWiring: []domain.Wire{\n    44Рєњ\t\t\t{From: \"a\", Result: \"ok\", To: \"b\"},\n    45Рєњ\t\t\t{From: \"a\", Result: \"fail\", To: \"abort\"},\n    46Рєњ\t\t\t{From: \"b\", Result: \"ok\", To: \"done\"},\n    47Рєњ\t\t\t{From: \"b\", Result: \"retry\", To: \"a\"}, // cycle\n    48Рєњ\t\t},\n    49Рєњ\t}\n    50Рєњ\n    51Рєњ\torder := bfsOrder(wf)\n    52Рєњ\tif len(order) != 2 {\n    53Рєњ\t\tt.Fatalf(\"expected 2 steps (cycle skipped), got %d: %v\", len(order), order)\n    54Рєњ\t}\n    55Рєњ\tif order[0] != \"a\" || order[1] != \"b\" {\n    56Рєњ\t\tt.Errorf(\"expected [a b], got %v\", order)\n    57Рєњ\t}\n    58Рєњ}\n    59Рєњ\n    60Рєњfunc TestBfsOrder_EmptyWorkflow(t *testing.T) {\n    61Рєњ\twf := &domain.Workflow{Steps: map[string]*domain.Step{}}\n    62Рєњ\torder := bfsOrder(wf)\n    63Рєњ\tif len(order) != 0 {\n    64Рєњ\t\tt.Errorf(\"expected empty order, got %v\", order)\n    65Рєњ\t}\n    66Рєњ}\n    67Рєњ\n    68Рєњfunc TestGroupWiresByDest_Merging(t *testing.T) {\n    69Рєњ\twf := &domain.Workflow{\n    70Рєњ\t\tWiring: []domain.Wire{\n    71Рєњ\t\t\t{From: \"fix\", Result: \"success\", To: \"test\"},\n    72Рєњ\t\t\t{From: \"fix\", Result: \"fail\", To: \"abort\"},\n    73Рєњ\t\t\t{From: \"fix\", Result: \"give-up\", To: \"abort\"},\n    74Рєњ\t\t},\n    75Рєњ\t}\n    76Рєњ\n    77Рєњ\tgroups := groupWiresByDest(wf, \"fix\")\n    78Рєњ\tif len(groups) != 2 {\n    79Рєњ\t\tt.Fatalf(\"expected 2 groups (test + abort merged), got %d\", len(groups))\n    80Рєњ\t}\n    81Рєњ\n    82Рєњ\t// First group: success -> test\n    83Рєњ\tif groups[0].to != \"test\" || len(groups[0].results) != 1 || groups[0].results[0] != \"success\" {\n    84Рєњ\t\tt.Errorf(\"expected first group to be success->test, got %+v\", groups[0])\n    85Рєњ\t}\n    86Рєњ\n    87Рєњ\t// Second group: fail,give-up -> abort (merged)\n    88Рєњ\tif groups[1].to != \"abort\" || len(groups[1].results) != 2 {\n    89Рєњ\t\tt.Errorf(\"expected second group to be fail,give-up->abort, got %+v\", groups[1])\n    90Рєњ\t}\n    91Рєњ\tif groups[1].results[0] != \"fail\" || groups[1].results[1] != \"give-up\" {\n    92Рєњ\t\tt.Errorf(\"expected results [fail give-up], got %v\", groups[1].results)\n    93Рєњ\t}\n    94Рєњ}\n    95Рєњ\n    96Рєњfunc TestGroupWiresByDest_NoWires(t *testing.T) {\n    97Рєњ\twf := &domain.Workflow{\n    98Рєњ\t\tWiring: []domain.Wire{\n    99Рєњ\t\t\t{From: \"other\", Result: \"ok\", To: \"done\"},\n   100Рєњ\t\t},\n   101Рєњ\t}\n   102Рєњ\n   103Рєњ\tgroups := groupWiresByDest(wf, \"step\")\n   104Рєњ\tif len(groups) != 0 {\n   105Рєњ\t\tt.Errorf(\"expected no groups, got %d\", len(groups))\n   106Рєњ\t}\n   107Рєњ}\n   108Рєњ\n   109Рєњfunc TestBuildResultColorMap(t *testing.T) {\n   110Рєњ\twf := &domain.Workflow{\n   111Рєњ\t\tSteps: map[string]*domain.Step{\n   112Рєњ\t\t\t\"a\": {Name: \"a\", Results: []string{\"success\", \"fail\", \"retry\", \"skip\"}},\n   113Рєњ\t\t},\n   114Рєњ\t}\n   115Рєњ\n   116Рєњ\tcolorMap := buildResultColorMap(wf, []string{\"a\"})\n   117Рєњ\n   118Рєњ\tif colorMap[\"success\"] != colorGreen {\n   119Рєњ\t\tt.Error(\"success should be green\")\n   120Рєњ\t}\n   121Рєњ\tif colorMap[\"fail\"] != colorRed {\n   122Рєњ\t\tt.Error(\"fail should be red\")\n   123Рєњ\t}\n   124Рєњ\tif colorMap[\"retry\"] == \"\" {\n   125Рєњ\t\tt.Error(\"retry should have an assigned color\")\n   126Рєњ\t}\n   127Рєњ\tif colorMap[\"skip\"] == \"\" {\n   128Рєњ\t\tt.Error(\"skip should have an assigned color\")\n   129Рєњ\t}\n   130Рєњ\tif colorMap[\"retry\"] == colorMap[\"skip\"] {\n   131Рєњ\t\tt.Error(\"retry and skip should get different colors\")\n   132Рєњ\t}\n   133Рєњ}\n   134Рєњ\n   135Рєњfunc TestRenderWorkflowGraph_NoColor(t *testing.T) {\n   136Рєњ\twf := &domain.Workflow{\n   137Рєњ\t\tName:      \"test-wf\",\n   138Рєњ\t\tLocation:  domain.LocationContainer,\n   139Рєњ\t\tEntryStep: \"build\",\n   140Рєњ\t\tSteps: map[string]*domain.Step{\n   141Рєњ\t\t\t\"build\": {Name: \"build\", Type: domain.StepTypeScript, Results: []string{\"success\", \"fail\"}},\n   142Рєњ\t\t\t\"deploy\": {Name: \"deploy\", Type: domain.StepTypeAgent, Results: []string{\"success\"}},\n   143Рєњ\t\t},\n   144Рєњ\t\tWiring: []domain.Wire{\n   145Рєњ\t\t\t{From: \"build\", Result: \"success\", To: \"deploy\"},\n   146Рєњ\t\t\t{From: \"build\", Result: \"fail\", To: \"abort\"},\n   147Рєњ\t\t\t{From: \"deploy\", Result: \"success\", To: \"done\"},\n   148Рєњ\t\t},\n   149Рєњ\t}\n   150Рєњ\n   151Рєњ\toutput := renderWorkflowGraph(wf, false)\n   152Рєњ\n   153Рєњ\t// Check header\n   154Рєњ\tif !strings.Contains(output, `workflow \"test-wf\" (container)`) {\n   155Рєњ\t\tt.Error(\"missing workflow header\")\n   156Рєњ\t}\n   157Рєњ\n   158Рєњ\t// Check step boxes\n   159Рєњ\tif !strings.Contains(output, \"build\") {\n   160Рєњ\t\tt.Error(\"missing build step\")\n   161Рєњ\t}\n   162Рєњ\tif !strings.Contains(output, \"deploy\") {\n   163Рєњ\t\tt.Error(\"missing deploy step\")\n   164Рєњ\t}\n   165Рєњ\n   166Рєњ\t// Check box drawing characters\n   167Рєњ\tif !strings.Contains(output, \"Рћї\") || !strings.Contains(output, \"Рћў\") {\n   168Рєњ\t\tt.Error(\"missing box drawing characters\")\n   169Рєњ\t}\n   170Рєњ\n   171Рєњ\t// Check entry marker\n   172Рєњ\tif !strings.Contains(output, \"РЌђ entry\") {\n   173Рєњ\t\tt.Error(\"missing entry marker\")\n   174Рєњ\t}\n   175Рєњ\n   176Рєњ\t// Check step types\n   177Рєњ\tif !strings.Contains(output, \"script\") {\n   178Рєњ\t\tt.Error(\"missing step type 'script'\")\n   179Рєњ\t}\n   180Рєњ\tif !strings.Contains(output, \"agent\") {\n   181Рєњ\t\tt.Error(\"missing step type 'agent'\")\n   182Рєњ\t}\n   183Рєњ\n   184Рєњ\t// Check wires\n   185Рєњ\tif !strings.Contains(output, \"success РћђРћђРќХ deploy\") {\n   186Рєњ\t\tt.Error(\"missing success wire to deploy\")\n   187Рєњ\t}\n   188Рєњ\tif !strings.Contains(output, \"fail РћђРћђРќХ ABORT\") {\n   189Рєњ\t\tt.Error(\"missing fail wire to ABORT\")\n   190Рєњ\t}\n   191Рєњ\tif !strings.Contains(output, \"success РћђРћђРќХ DONE\") {\n   192Рєњ\t\tt.Error(\"missing success wire to DONE\")\n   193Рєњ\t}\n   194Рєњ\n   195Рєњ\t// Check tree branch characters\n   196Рєњ\tif !strings.Contains(output, \"РћюРћђРћђ\") {\n   197Рєњ\t\tt.Error(\"missing non-last branch character\")\n   198Рєњ\t}\n   199Рєњ\tif !strings.Contains(output, \"РћћРћђРћђ\") {\n   200Рєњ\t\tt.Error(\"missing last branch character\")\n   201Рєњ\t}\n   202Рєњ}\n   203Рєњ\n   204Рєњfunc TestRenderWorkflowGraph_WireMerging(t *testing.T) {\n   205Рєњ\twf := &domain.Workflow{\n   206Рєњ\t\tName:      \"merge-test\",\n   207Рєњ\t\tLocation:  domain.LocationContainer,\n   208Рєњ\t\tEntryStep: \"step1\",\n   209Рєњ\t\tSteps: map[string]*domain.Step{\n   210Рєњ\t\t\t\"step1\": {Name: \"step1\", Type: domain.StepTypeScript, Results: []string{\"success\", \"fail\", \"error\"}},\n   211Рєњ\t\t},\n   212Рєњ\t\tWiring: []domain.Wire{\n   213Рєњ\t\t\t{From: \"step1\", Result: \"success\", To: \"done\"},\n   214Рєњ\t\t\t{From: \"step1\", Result: \"fail\", To: \"abort\"},\n   215Рєњ\t\t\t{From: \"step1\", Result: \"error\", To: \"abort\"},\n   216Рєњ\t\t},\n   217Рєњ\t}\n   218Рєњ\n   219Рєњ\toutput := renderWorkflowGraph(wf, false)\n   220Рєњ\n   221Рєњ\t// fail and error should be merged into one wire to ABORT\n   222Рєњ\tif !strings.Contains(output, \"fail, error РћђРћђРќХ ABORT\") {\n   223Рєњ\t\tt.Errorf(\"expected merged wire 'fail, error РћђРћђРќХ ABORT', got:\\n%s\", output)\n   224Рєњ\t}\n   225Рєњ\n   226Рєњ\t// Should have exactly 2 wire lines (done + merged abort)\n   227Рєњ\tlines := strings.Split(output, \"\\n\")\n   228Рєњ\twireLines := 0\n   229Рєњ\tfor _, line := range lines {\n   230Рєњ\t\tif strings.Contains(line, \"РћђРћђРќХ\") {\n   231Рєњ\t\t\twireLines++\n   232Рєњ\t\t}\n   233Рєњ\t}\n   234Рєњ\tif wireLines != 2 {\n   235Рєњ\t\tt.Errorf(\"expected 2 wire lines (1 done + 1 merged abort), got %d\", wireLines)\n   236Рєњ\t}\n   237Рєњ}\n   238Рєњ\n   239Рєњfunc TestRenderWorkflowGraph_WithColor(t *testing.T) {\n   240Рєњ\twf := &domain.Workflow{\n   241Рєњ\t\tName:      \"color-test\",\n   242Рєњ\t\tLocation:  domain.LocationHost,\n   243Рєњ\t\tEntryStep: \"step1\",\n   244Рєњ\t\tSteps: map[string]*domain.Step{\n   245Рєњ\t\t\t\"step1\": {Name: \"step1\", Type: domain.StepTypeScript, Results: []string{\"success\", \"fail\"}},\n   246Рєњ\t\t},\n   247Рєњ\t\tWiring: []domain.Wire{\n   248Рєњ\t\t\t{From: \"step1\", Result: \"success\", To: \"done\"},\n   249Рєњ\t\t\t{From: \"step1\", Result: \"fail\", To: \"abort\"},\n   250Рєњ\t\t},\n   251Рєњ\t}\n   252Рєњ\n   253Рєњ\toutput := renderWorkflowGraph(wf, true)\n   254Рєњ\n   255Рєњ\t// Check ANSI color codes are present\n   256Рєњ\tif !strings.Contains(output, colorGreen) {\n   257Рєњ\t\tt.Error(\"expected green color code for success\")\n   258Рєњ\t}\n   259Рєњ\tif !strings.Contains(output, colorRed) {\n   260Рєњ\t\tt.Error(\"expected red color code for fail\")\n   261Рєњ\t}\n   262Рєњ\tif !strings.Contains(output, colorReset) {\n   263Рєњ\t\tt.Error(\"expected color reset code\")\n   264Рєњ\t}\n   265Рєњ}\n   266Рєњ\n   267Рєњfunc TestRenderWorkflowGraph_HostLocation(t *testing.T) {\n   268Рєњ\twf := &domain.Workflow{\n   269Рєњ\t\tName:      \"host-wf\",\n   270Рєњ\t\tLocation:  domain.LocationHost,\n   271Рєњ\t\tEntryStep: \"run\",\n   272Рєњ\t\tSteps: map[string]*domain.Step{\n   273Рєњ\t\t\t\"run\": {Name: \"run\", Type: domain.StepTypeWorkflow, Results: []string{\"success\"}},\n   274Рєњ\t\t},\n   275Рєњ\t\tWiring: []domain.Wire{\n   276Рєњ\t\t\t{From: \"run\", Result: \"success\", To: \"done\"},\n   277Рєњ\t\t},\n   278Рєњ\t}\n   279Рєњ\n   280Рєњ\toutput := renderWorkflowGraph(wf, false)\n   281Рєњ\tif !strings.Contains(output, \"(host)\") {\n   282Рєњ\t\tt.Error(\"expected host location in header\")\n   283Рєњ\t}\n   284Рєњ\tif !strings.Contains(output, \"workflow\") {\n   285Рєњ\t\tt.Error(\"expected workflow step type\")\n   286Рєњ\t}\n   287Рєњ}\n   288Рєњ\n   289Рєњfunc TestRenderWorkflowGraph_OtherResultColors(t *testing.T) {\n   290Рєњ\twf := &domain.Workflow{\n   291Рєњ\t\tName:      \"multi-color\",\n   292Рєњ\t\tLocation:  domain.LocationContainer,\n   293Рєњ\t\tEntryStep: \"step1\",\n   294Рєњ\t\tSteps: map[string]*domain.Step{\n   295Рєњ\t\t\t\"step1\": {Name: \"step1\", Type: domain.StepTypeAgent, Results: []string{\"retry\", \"skip\", \"timeout\", \"partial\"}},\n   296Рєњ\t\t},\n   297Рєњ\t\tWiring: []domain.Wire{\n   298Рєњ\t\t\t{From: \"step1\", Result: \"retry\", To: \"done\"},\n   299Рєњ\t\t\t{From: \"step1\", Result: \"skip\", To: \"done\"},\n   300Рєњ\t\t\t{From: \"step1\", Result: \"timeout\", To: \"abort\"},\n   301Рєњ\t\t\t{From: \"step1\", Result: \"partial\", To: \"abort\"},\n   302Рєњ\t\t},\n   303Рєњ\t}\n   304Рєњ\n   305Рєњ\toutput := renderWorkflowGraph(wf, true)\n   306Рєњ\n   307Рєњ\t// Each \"other\" result should get a distinct color from the palette\n   308Рєњ\tif !strings.Contains(output, colorBlue) {\n   309Рєњ\t\tt.Error(\"expected blue color for first other result\")\n   310Рєњ\t}\n   311Рєњ\tif !strings.Contains(output, colorYellow) {\n   312Рєњ\t\tt.Error(\"expected yellow color for second other result\")\n   313Рєњ\t}\n   314Рєњ\tif !strings.Contains(output, colorOrange) {\n   315Рєњ\t\tt.Error(\"expected orange color for third other result\")\n   316Рєњ\t}\n   317Рєњ\tif !strings.Contains(output, colorMagenta) {\n   318Рєњ\t\tt.Error(\"expected magenta color for fourth other result\")\n   319Рєњ\t}\n   320Рєњ}\n   321Рєњ\n   322Рєњfunc TestRenderWorkflowGraph_ConsistentBoxWidth(t *testing.T) {\n   323Рєњ\twf := &domain.Workflow{\n   324Рєњ\t\tName:      \"width-test\",\n   325Рєњ\t\tLocation:  domain.LocationContainer,\n   326Рєњ\t\tEntryStep: \"a\",\n   327Рєњ\t\tSteps: map[string]*domain.Step{\n   328Рєњ\t\t\t\"a\":             {Name: \"a\", Type: domain.StepTypeScript, Results: []string{\"ok\"}},\n   329Рєњ\t\t\t\"long-step-name\": {Name: \"long-step-name\", Type: domain.StepTypeAgent, Results: []string{\"ok\"}},\n   330Рєњ\t\t},\n   331Рєњ\t\tWiring: []domain.Wire{\n   332Рєњ\t\t\t{From: \"a\", Result: \"ok\", To: \"long-step-name\"},\n   333Рєњ\t\t\t{From: \"long-step-name\", Result: \"ok\", To: \"done\"},\n   334Рєњ\t\t},\n   335Рєњ\t}\n   336Рєњ\n   337Рєњ\toutput := renderWorkflowGraph(wf, false)\n   338Рєњ\tlines := strings.Split(output, \"\\n\")\n   339Рєњ\n   340Рєњ\t// Find border lines (those with Рћї or Рћћ)\n   341Рєњ\tvar borderLengths []int\n   342Рєњ\tfor _, line := range lines {\n   343Рєњ\t\tif strings.Contains(line, \"Рћї\") && strings.Contains(line, \"Рћљ\") {\n   344Рєњ\t\t\tborderLengths = append(borderLengths, len(line))\n   345Рєњ\t\t}\n   346Рєњ\t}\n   347Рєњ\n   348Рєњ\tif len(borderLengths) < 2 {\n   349Рєњ\t\tt.Fatal(\"expected at least 2 border lines\")\n   350Рєњ\t}\n   351Рєњ\n   352Рєњ\t// All borders should have the same length\n   353Рєњ\tfor i := 1; i < len(borderLengths); i++ {\n   354Рєњ\t\tif borderLengths[i] != borderLengths[0] {\n   355Рєњ\t\t\tt.Errorf(\"inconsistent box widths: %d vs %d\", borderLengths[0], borderLengths[i])\n   356Рєњ\t\t}\n   357Рєњ\t}\n   358Рєњ}\n   359Рєњ\n   360Рєњfunc TestDiscoverWorkflows(t *testing.T) {\n   361Рєњ\tdir := t.TempDir()\n   362Рєњ\tclocheDir := filepath.Join(dir, \".cloche\")\n   363Рєњ\tos.MkdirAll(clocheDir, 0755)\n   364Рєњ\n   365Рєњ\t// Write a container workflow\n   366Рєњ\tos.WriteFile(filepath.Join(clocheDir, \"build.cloche\"), []byte(`workflow \"build\" {\n   367Рєњ  step compile {\n   368Рєњ    run = \"make\"\n   369Рєњ    results = [success, fail]\n   370Рєњ  }\n   371Рєњ  compile:success -> done\n   372Рєњ  compile:fail -> abort\n   373Рєњ}`), 0644)\n   374Рєњ\n   375Рєњ\t// Write a host workflow with two workflows\n   376Рєњ\tos.WriteFile(filepath.Join(clocheDir, \"host.cloche\"), []byte(`workflow \"plan\" {\n   377Рєњ  step pick {\n   378Рєњ    run = \"echo pick\"\n   379Рєњ    results = [success]\n   380Рєњ  }\n   381Рєњ  pick:success -> done\n   382Рєњ}\n   383Рєњ\n   384Рєњworkflow \"run\" {\n   385Рєњ  step exec {\n   386Рєњ    run = \"echo run\"\n   387Рєњ    results = [success]\n   388Рєњ  }\n   389Рєњ  exec:success -> done\n   390Рєњ}`), 0644)\n   391Рєњ\n   392Рєњ\tinfos, err := discoverWorkflows(dir)\n   393Рєњ\tif err != nil {\n   394Рєњ\t\tt.Fatal(err)\n   395Рєњ\t}\n   396Рєњ\n   397Рєњ\t// Should find 3 workflows: 1 container + 2 host\n   398Рєњ\tif len(infos) != 3 {\n   399Рєњ\t\tt.Fatalf(\"expected 3 workflows, got %d\", len(infos))\n   400Рєњ\t}\n   401Рєњ\n   402Рєњ\tvar containerCount, hostCount int\n   403Рєњ\tnames := map[string]bool{}\n   404Рєњ\tfor _, info := range infos {\n   405Рєњ\t\tnames[info.name] = true\n   406Рєњ\t\tswitch info.location {\n   407Рєњ\t\tcase domain.LocationContainer:\n   408Рєњ\t\t\tcontainerCount++\n   409Рєњ\t\tcase domain.LocationHost:\n   410Рєњ\t\t\thostCount++\n   411Рєњ\t\t}\n   412Рєњ\t}\n   413Рєњ\n   414Рєњ\tif containerCount != 1 {\n   415Рєњ\t\tt.Errorf(\"expected 1 container workflow, got %d\", containerCount)\n   416Рєњ\t}\n   417Рєњ\tif hostCount != 2 {\n   418Рєњ\t\tt.Errorf(\"expected 2 host workflows, got %d\", hostCount)\n   419Рєњ\t}\n   420Рєњ\tfor _, name := range []string{\"build\", \"plan\", \"run\"} {\n   421Рєњ\t\tif !names[name] {\n   422Рєњ\t\t\tt.Errorf(\"missing workflow %q\", name)\n   423Рєњ\t\t}\n   424Рєњ\t}\n   425Рєњ}\n   426Рєњ\n   427Рєњfunc TestDiscoverWorkflows_NoClocheDir(t *testing.T) {\n   428Рєњ\tdir := t.TempDir()\n   429Рєњ\n   430Рєњ\tinfos, err := discoverWorkflows(dir)\n   431Рєњ\tif err != nil {\n   432Рєњ\t\tt.Fatal(err)\n   433Рєњ\t}\n   434Рєњ\tif len(infos) != 0 {\n   435Рєњ\t\tt.Errorf(\"expected 0 workflows, got %d\", len(infos))\n   436Рєњ\t}\n   437Рєњ}\n   438Рєњ\n   439Рєњfunc TestLoadWorkflow_Container(t *testing.T) {\n   440Рєњ\tdir := t.TempDir()\n   441Рєњ\tclocheDir := filepath.Join(dir, \".cloche\")\n   442Рєњ\tos.MkdirAll(clocheDir, 0755)\n   443Рєњ\n   444Рєњ\tos.WriteFile(filepath.Join(clocheDir, \"deploy.cloche\"), []byte(`workflow \"deploy\" {\n   445Рєњ  step ship {\n   446Рєњ    run = \"echo ship\"\n   447Рєњ    results = [success, fail]\n   448Рєњ  }\n   449Рєњ  ship:success -> done\n   450Рєњ  ship:fail -> abort\n   451Рєњ}`), 0644)\n   452Рєњ\n   453Рєњ\twf, err := loadWorkflow(dir, \"deploy\")\n   454Рєњ\tif err != nil {\n   455Рєњ\t\tt.Fatal(err)\n   456Рєњ\t}\n   457Рєњ\tif wf.Name != \"deploy\" {\n   458Рєњ\t\tt.Errorf(\"expected name 'deploy', got %q\", wf.Name)\n   459Рєњ\t}\n   460Рєњ\tif wf.Location != domain.LocationContainer {\n   461Рєњ\t\tt.Errorf(\"expected container location, got %q\", wf.Location)\n   462Рєњ\t}\n   463Рєњ}\n   464Рєњ\n   465Рєњfunc TestLoadWorkflow_Host(t *testing.T) {\n   466Рєњ\tdir := t.TempDir()\n   467Рєњ\tclocheDir := filepath.Join(dir, \".cloche\")\n   468Рєњ\tos.MkdirAll(clocheDir, 0755)\n   469Рєњ\n   470Рєњ\tos.WriteFile(filepath.Join(clocheDir, \"host.cloche\"), []byte(`workflow \"orchestrate\" {\n   471Рєњ  step dispatch {\n   472Рєњ    run = \"echo go\"\n   473Рєњ    results = [success]\n   474Рєњ  }\n   475Рєњ  dispatch:success -> done\n   476Рєњ}`), 0644)\n   477Рєњ\n   478Рєњ\twf, err := loadWorkflow(dir, \"orchestrate\")\n   479Рєњ\tif err != nil {\n   480Рєњ\t\tt.Fatal(err)\n   481Рєњ\t}\n   482Рєњ\tif wf.Name != \"orchestrate\" {\n   483Рєњ\t\tt.Errorf(\"expected name 'orchestrate', got %q\", wf.Name)\n   484Рєњ\t}\n   485Рєњ\tif wf.Location != domain.LocationHost {\n   486Рєњ\t\tt.Errorf(\"expected host location, got %q\", wf.Location)\n   487Рєњ\t}\n   488Рєњ}\n   489Рєњ\n   490Рєњfunc TestLoadWorkflow_NotFound(t *testing.T) {\n   491Рєњ\tdir := t.TempDir()\n   492Рєњ\tos.MkdirAll(filepath.Join(dir, \".cloche\"), 0755)\n   493Рєњ\n   494Рєњ\t_, err := loadWorkflow(dir, \"nonexistent\")\n   495Рєњ\tif err == nil {\n   496Рєњ\t\tt.Error(\"expected error for nonexistent workflow\")\n   497Рєњ\t}\n   498Рєњ\tif !strings.Contains(err.Error(), \"not found\") {\n   499Рєњ\t\tt.Errorf(\"expected 'not found' error, got: %v\", err)\n   500Рєњ\t}\n   501Рєњ}\n   502Рєњ\n   503Рєњfunc TestRenderWorkflowGraph_DevelopWorkflow(t *testing.T) {\n   504Рєњ\t// Simulate the develop workflow from the project\n   505Рєњ\twf := &domain.Workflow{\n   506Рєњ\t\tName:      \"develop\",\n   507Рєњ\t\tLocation:  domain.LocationContainer,\n   508Рєњ\t\tEntryStep: \"implement\",\n   509Рєњ\t\tSteps: map[string]*domain.Step{\n   510Рєњ\t\t\t\"implement\":   {Name: \"implement\", Type: domain.StepTypeAgent, Results: []string{\"success\", \"fail\"}},\n   511Рєњ\t\t\t\"test\":        {Name: \"test\", Type: domain.StepTypeScript, Results: []string{\"success\", \"fail\"}},\n   512Рєњ\t\t\t\"fix\":         {Name: \"fix\", Type: domain.StepTypeAgent, Results: []string{\"success\", \"fail\", \"give-up\"}},\n   513Рєњ\t\t\t\"update-docs\": {Name: \"update-docs\", Type: domain.StepTypeAgent, Results: []string{\"success\", \"fail\"}},\n   514Рєњ\t\t},\n   515Рєњ\t\tWiring: []domain.Wire{\n   516Рєњ\t\t\t{From: \"implement\", Result: \"success\", To: \"test\"},\n   517Рєњ\t\t\t{From: \"implement\", Result: \"fail\", To: \"abort\"},\n   518Рєњ\t\t\t{From: \"test\", Result: \"success\", To: \"update-docs\"},\n   519Рєњ\t\t\t{From: \"test\", Result: \"fail\", To: \"fix\"},\n   520Рєњ\t\t\t{From: \"fix\", Result: \"success\", To: \"test\"},\n   521Рєњ\t\t\t{From: \"fix\", Result: \"fail\", To: \"abort\"},\n   522Рєњ\t\t\t{From: \"fix\", Result: \"give-up\", To: \"abort\"},\n   523Рєњ\t\t\t{From: \"update-docs\", Result: \"success\", To: \"done\"},\n   524Рєњ\t\t\t{From: \"update-docs\", Result: \"fail\", To: \"done\"},\n   525Рєњ\t\t},\n   526Рєњ\t}\n   527Рєњ\n   528Рєњ\toutput := renderWorkflowGraph(wf, false)\n   529Рєњ\n   530Рєњ\t// Check BFS order: implement -> test -> update-docs -> fix\n   531Рєњ\t// (update-docs before fix because test:success wire comes before test:fail wire)\n   532Рєњ\tlines := strings.Split(output, \"\\n\")\n   533Рєњ\tstepBoxOrder := []string{}\n   534Рєњ\tfor _, line := range lines {\n   535Рєњ\t\tif strings.Contains(line, \"Рћѓ\") && strings.Contains(line, \"РЌђ entry\") {\n   536Рєњ\t\t\tstepBoxOrder = append(stepBoxOrder, \"implement\")\n   537Рєњ\t\t} else if strings.Contains(line, \"Рћѓ\") && strings.Contains(line, \"script\") && strings.Contains(line, \"test\") {\n   538Рєњ\t\t\tstepBoxOrder = append(stepBoxOrder, \"test\")\n   539Рєњ\t\t} else if strings.Contains(line, \"Рћѓ\") && strings.Contains(line, \"update-docs\") {\n   540Рєњ\t\t\tstepBoxOrder = append(stepBoxOrder, \"update-docs\")\n   541Рєњ\t\t} else if strings.Contains(line, \"Рћѓ\") && strings.Contains(line, \"fix\") && strings.Contains(line, \"agent\") && !strings.Contains(line, \"update\") && !strings.Contains(line, \"implement\") {\n   542Рєњ\t\t\tstepBoxOrder = append(stepBoxOrder, \"fix\")\n   543Рєњ\t\t}\n   544Рєњ\t}\n   545Рєњ\n   546Рєњ\texpected := []string{\"implement\", \"test\", \"update-docs\", \"fix\"}\n   547Рєњ\tif len(stepBoxOrder) != len(expected) {\n   548Рєњ\t\tt.Fatalf(\"expected %d step boxes, got %d: %v\", len(expected), len(stepBoxOrder), stepBoxOrder)\n   549Рєњ\t}\n   550Рєњ\tfor i, name := range expected {\n   551Рєњ\t\tif stepBoxOrder[i] != name {\n   552Рєњ\t\t\tt.Errorf(\"step %d: expected %q, got %q (order: %v)\", i, name, stepBoxOrder[i], stepBoxOrder)\n   553Рєњ\t\t}\n   554Рєњ\t}\n   555Рєњ\n   556Рєњ\t// Check wire merging: fix's fail and give-up should merge to ABORT\n   557Рєњ\tif !strings.Contains(output, \"fail, give-up РћђРћђРќХ ABORT\") {\n   558Рєњ\t\tt.Errorf(\"expected merged wire 'fail, give-up РћђРћђРќХ ABORT' in output:\\n%s\", output)\n   559Рєњ\t}\n   560Рєњ\n   561Рєњ\t// Check wire merging: update-docs success and fail should merge to DONE\n   562Рєњ\tif !strings.Contains(output, \"success, fail РћђРћђРќХ DONE\") {\n   563Рєњ\t\tt.Errorf(\"expected merged wire 'success, fail РћђРћђРќХ DONE' in output:\\n%s\", output)\n   564Рєњ\t}\n   565Рєњ\n   566Рєњ\t// Check cycle reference: fix:success -> test (back reference)\n   567Рєњ\tif !strings.Contains(output, \"success РћђРћђРќХ test\") {\n   568Рєњ\t\tt.Error(\"expected fix:success wire to test\")\n   569Рєњ\t}\n   570Рєњ}\n   571Рєњ\n   572Рєњfunc TestFormatDest(t *testing.T) {\n   573Рєњ\ttests := []struct {\n   574Рєњ\t\tto       string\n   575Рєњ\t\tcolor    bool\n   576Рєњ\t\texpected string\n   577Рєњ\t}{\n   578Рєњ\t\t{\"done\", false, \"DONE\"},\n   579Рєњ\t\t{\"abort\", false, \"ABORT\"},\n   580Рєњ\t\t{\"step_a\", false, \"step_a\"},\n   581Рєњ\t\t{\"done\", true, colorGreen + \"DONE\" + colorReset},\n   582Рєњ\t\t{\"abort\", true, colorRed + \"ABORT\" + colorReset},\n   583Рєњ\t\t{\"step_a\", true, \"step_a\"},\n   584Рєњ\t}\n   585Рєњ\n   586Рєњ\tfor _, tt := range tests {\n   587Рєњ\t\tgot := formatDest(tt.to, tt.color)\n   588Рєњ\t\tif got != tt.expected {\n   589Рєњ\t\t\tt.Errorf(\"formatDest(%q, %v) = %q, want %q\", tt.to, tt.color, got, tt.expected)\n   590Рєњ\t\t}\n   591Рєњ\t}\n   592Рєњ}\n   593Рєњ\n   594Рєњfunc TestRenderWorkflowGraph_CollectBlock(t *testing.T) {\n   595Рєњ\twf := &domain.Workflow{\n   596Рєњ\t\tName:      \"collect-test\",\n   597Рєњ\t\tLocation:  domain.LocationContainer,\n   598Рєњ\t\tEntryStep: \"step1\",\n   599Рєњ\t\tSteps: map[string]*domain.Step{\n   600Рєњ\t\t\t\"step1\": {Name: \"step1\", Type: domain.StepTypeScript, Results: []string{\"success\"}},\n   601Рєњ\t\t\t\"step2\": {Name: \"step2\", Type: domain.StepTypeScript, Results: []string{\"success\"}},\n   602Рєњ\t\t\t\"step3\": {Name: \"step3\", Type: domain.StepTypeScript, Results: []string{\"success\"}},\n   603Рєњ\t\t},\n   604Рєњ\t\tWiring: []domain.Wire{\n   605Рєњ\t\t\t{From: \"step1\", Result: \"success\", To: \"step2\"},\n   606Рєњ\t\t\t{From: \"step1\", Result: \"success\", To: \"step3\"},\n   607Рєњ\t\t\t{From: \"step3\", Result: \"success\", To: \"done\"},\n   608Рєњ\t\t},\n   609Рєњ\t\tCollects: []domain.Collect{\n   610Рєњ\t\t\t{\n   611Рєњ\t\t\t\tMode: domain.CollectAll,\n   612Рєњ\t\t\t\tConditions: []domain.WireCondition{\n   613Рєњ\t\t\t\t\t{Step: \"step2\", Result: \"success\"},\n   614Рєњ\t\t\t\t\t{Step: \"step3\", Result: \"success\"},\n   615Рєњ\t\t\t\t},\n   616Рєњ\t\t\t\tTo: \"done\",\n   617Рєњ\t\t\t},\n   618Рєњ\t\t},\n   619Рєњ\t}\n   620Рєњ\n   621Рєњ\toutput := renderWorkflowGraph(wf, false)\n   622Рєњ\tif !strings.Contains(output, \"collect all\") {\n   623Рєњ\t\tt.Errorf(\"expected collect block in output:\\n%s\", output)\n   624Рєњ\t}\n   625Рєњ}\n   626Рєњ"}]},"parent_tool_use_id":null,"session_id":"2090add2-0fe6-4270-9f3b-b52deb6bac91","uuid":"af464c44-c8fb-47ed-9d36-2551b16fd4d1","tool_use_result":{"type":"text","file":{"filePath":"/workspace/cmd/cloche/workflow_test.go","content":"package main\n\nimport (\n\t\"os\"\n\t\"path/filepath\"\n\t\"strings\"\n\t\"testing\"\n\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n)\n\nfunc TestBfsOrder_LinearWorkflow(t *testing.T) {\n\twf := &domain.Workflow{\n\t\tEntryStep: \"a\",\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"a\": {Name: \"a\", Results: []string{\"ok\"}},\n\t\t\t\"b\": {Name: \"b\", Results: []string{\"ok\"}},\n\t\t\t\"c\": {Name: \"c\", Results: []string{\"ok\"}},\n\t\t},\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"a\", Result: \"ok\", To: \"b\"},\n\t\t\t{From: \"b\", Result: \"ok\", To: \"c\"},\n\t\t\t{From: \"c\", Result: \"ok\", To: \"done\"},\n\t\t},\n\t}\n\n\torder := bfsOrder(wf)\n\tif len(order) != 3 {\n\t\tt.Fatalf(\"expected 3 steps, got %d: %v\", len(order), order)\n\t}\n\tif order[0] != \"a\" || order[1] != \"b\" || order[2] != \"c\" {\n\t\tt.Errorf(\"expected [a b c], got %v\", order)\n\t}\n}\n\nfunc TestBfsOrder_WithCycle(t *testing.T) {\n\twf := &domain.Workflow{\n\t\tEntryStep: \"a\",\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"a\": {Name: \"a\", Results: []string{\"ok\", \"fail\"}},\n\t\t\t\"b\": {Name: \"b\", Results: []string{\"ok\", \"retry\"}},\n\t\t},\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"a\", Result: \"ok\", To: \"b\"},\n\t\t\t{From: \"a\", Result: \"fail\", To: \"abort\"},\n\t\t\t{From: \"b\", Result: \"ok\", To: \"done\"},\n\t\t\t{From: \"b\", Result: \"retry\", To: \"a\"}, // cycle\n\t\t},\n\t}\n\n\torder := bfsOrder(wf)\n\tif len(order) != 2 {\n\t\tt.Fatalf(\"expected 2 steps (cycle skipped), got %d: %v\", len(order), order)\n\t}\n\tif order[0] != \"a\" || order[1] != \"b\" {\n\t\tt.Errorf(\"expected [a b], got %v\", order)\n\t}\n}\n\nfunc TestBfsOrder_EmptyWorkflow(t *testing.T) {\n\twf := &domain.Workflow{Steps: map[string]*domain.Step{}}\n\torder := bfsOrder(wf)\n\tif len(order) != 0 {\n\t\tt.Errorf(\"expected empty order, got %v\", order)\n\t}\n}\n\nfunc TestGroupWiresByDest_Merging(t *testing.T) {\n\twf := &domain.Workflow{\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"fix\", Result: \"success\", To: \"test\"},\n\t\t\t{From: \"fix\", Result: \"fail\", To: \"abort\"},\n\t\t\t{From: \"fix\", Result: \"give-up\", To: \"abort\"},\n\t\t},\n\t}\n\n\tgroups := groupWiresByDest(wf, \"fix\")\n\tif len(groups) != 2 {\n\t\tt.Fatalf(\"expected 2 groups (test + abort merged), got %d\", len(groups))\n\t}\n\n\t// First group: success -> test\n\tif groups[0].to != \"test\" || len(groups[0].results) != 1 || groups[0].results[0] != \"success\" {\n\t\tt.Errorf(\"expected first group to be success->test, got %+v\", groups[0])\n\t}\n\n\t// Second group: fail,give-up -> abort (merged)\n\tif groups[1].to != \"abort\" || len(groups[1].results) != 2 {\n\t\tt.Errorf(\"expected second group to be fail,give-up->abort, got %+v\", groups[1])\n\t}\n\tif groups[1].results[0] != \"fail\" || groups[1].results[1] != \"give-up\" {\n\t\tt.Errorf(\"expected results [fail give-up], got %v\", groups[1].results)\n\t}\n}\n\nfunc TestGroupWiresByDest_NoWires(t *testing.T) {\n\twf := &domain.Workflow{\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"other\", Result: \"ok\", To: \"done\"},\n\t\t},\n\t}\n\n\tgroups := groupWiresByDest(wf, \"step\")\n\tif len(groups) != 0 {\n\t\tt.Errorf(\"expected no groups, got %d\", len(groups))\n\t}\n}\n\nfunc TestBuildResultColorMap(t *testing.T) {\n\twf := &domain.Workflow{\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"a\": {Name: \"a\", Results: []string{\"success\", \"fail\", \"retry\", \"skip\"}},\n\t\t},\n\t}\n\n\tcolorMap := buildResultColorMap(wf, []string{\"a\"})\n\n\tif colorMap[\"success\"] != colorGreen {\n\t\tt.Error(\"success should be green\")\n\t}\n\tif colorMap[\"fail\"] != colorRed {\n\t\tt.Error(\"fail should be red\")\n\t}\n\tif colorMap[\"retry\"] == \"\" {\n\t\tt.Error(\"retry should have an assigned color\")\n\t}\n\tif colorMap[\"skip\"] == \"\" {\n\t\tt.Error(\"skip should have an assigned color\")\n\t}\n\tif colorMap[\"retry\"] == colorMap[\"skip\"] {\n\t\tt.Error(\"retry and skip should get different colors\")\n\t}\n}\n\nfunc TestRenderWorkflowGraph_NoColor(t *testing.T) {\n\twf := &domain.Workflow{\n\t\tName:      \"test-wf\",\n\t\tLocation:  domain.LocationContainer,\n\t\tEntryStep: \"build\",\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"build\": {Name: \"build\", Type: domain.StepTypeScript, Results: []string{\"success\", \"fail\"}},\n\t\t\t\"deploy\": {Name: \"deploy\", Type: domain.StepTypeAgent, Results: []string{\"success\"}},\n\t\t},\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"build\", Result: \"success\", To: \"deploy\"},\n\t\t\t{From: \"build\", Result: \"fail\", To: \"abort\"},\n\t\t\t{From: \"deploy\", Result: \"success\", To: \"done\"},\n\t\t},\n\t}\n\n\toutput := renderWorkflowGraph(wf, false)\n\n\t// Check header\n\tif !strings.Contains(output, `workflow \"test-wf\" (container)`) {\n\t\tt.Error(\"missing workflow header\")\n\t}\n\n\t// Check step boxes\n\tif !strings.Contains(output, \"build\") {\n\t\tt.Error(\"missing build step\")\n\t}\n\tif !strings.Contains(output, \"deploy\") {\n\t\tt.Error(\"missing deploy step\")\n\t}\n\n\t// Check box drawing characters\n\tif !strings.Contains(output, \"Рћї\") || !strings.Contains(output, \"Рћў\") {\n\t\tt.Error(\"missing box drawing characters\")\n\t}\n\n\t// Check entry marker\n\tif !strings.Contains(output, \"РЌђ entry\") {\n\t\tt.Error(\"missing entry marker\")\n\t}\n\n\t// Check step types\n\tif !strings.Contains(output, \"script\") {\n\t\tt.Error(\"missing step type 'script'\")\n\t}\n\tif !strings.Contains(output, \"agent\") {\n\t\tt.Error(\"missing step type 'agent'\")\n\t}\n\n\t// Check wires\n\tif !strings.Contains(output, \"success РћђРћђРќХ deploy\") {\n\t\tt.Error(\"missing success wire to deploy\")\n\t}\n\tif !strings.Contains(output, \"fail РћђРћђРќХ ABORT\") {\n\t\tt.Error(\"missing fail wire to ABORT\")\n\t}\n\tif !strings.Contains(output, \"success РћђРћђРќХ DONE\") {\n\t\tt.Error(\"missing success wire to DONE\")\n\t}\n\n\t// Check tree branch characters\n\tif !strings.Contains(output, \"РћюРћђРћђ\") {\n\t\tt.Error(\"missing non-last branch character\")\n\t}\n\tif !strings.Contains(output, \"РћћРћђРћђ\") {\n\t\tt.Error(\"missing last branch character\")\n\t}\n}\n\nfunc TestRenderWorkflowGraph_WireMerging(t *testing.T) {\n\twf := &domain.Workflow{\n\t\tName:      \"merge-test\",\n\t\tLocation:  domain.LocationContainer,\n\t\tEntryStep: \"step1\",\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"step1\": {Name: \"step1\", Type: domain.StepTypeScript, Results: []string{\"success\", \"fail\", \"error\"}},\n\t\t},\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"step1\", Result: \"success\", To: \"done\"},\n\t\t\t{From: \"step1\", Result: \"fail\", To: \"abort\"},\n\t\t\t{From: \"step1\", Result: \"error\", To: \"abort\"},\n\t\t},\n\t}\n\n\toutput := renderWorkflowGraph(wf, false)\n\n\t// fail and error should be merged into one wire to ABORT\n\tif !strings.Contains(output, \"fail, error РћђРћђРќХ ABORT\") {\n\t\tt.Errorf(\"expected merged wire 'fail, error РћђРћђРќХ ABORT', got:\\n%s\", output)\n\t}\n\n\t// Should have exactly 2 wire lines (done + merged abort)\n\tlines := strings.Split(output, \"\\n\")\n\twireLines := 0\n\tfor _, line := range lines {\n\t\tif strings.Contains(line, \"РћђРћђРќХ\") {\n\t\t\twireLines++\n\t\t}\n\t}\n\tif wireLines != 2 {\n\t\tt.Errorf(\"expected 2 wire lines (1 done + 1 merged abort), got %d\", wireLines)\n\t}\n}\n\nfunc TestRenderWorkflowGraph_WithColor(t *testing.T) {\n\twf := &domain.Workflow{\n\t\tName:      \"color-test\",\n\t\tLocation:  domain.LocationHost,\n\t\tEntryStep: \"step1\",\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"step1\": {Name: \"step1\", Type: domain.StepTypeScript, Results: []string{\"success\", \"fail\"}},\n\t\t},\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"step1\", Result: \"success\", To: \"done\"},\n\t\t\t{From: \"step1\", Result: \"fail\", To: \"abort\"},\n\t\t},\n\t}\n\n\toutput := renderWorkflowGraph(wf, true)\n\n\t// Check ANSI color codes are present\n\tif !strings.Contains(output, colorGreen) {\n\t\tt.Error(\"expected green color code for success\")\n\t}\n\tif !strings.Contains(output, colorRed) {\n\t\tt.Error(\"expected red color code for fail\")\n\t}\n\tif !strings.Contains(output, colorReset) {\n\t\tt.Error(\"expected color reset code\")\n\t}\n}\n\nfunc TestRenderWorkflowGraph_HostLocation(t *testing.T) {\n\twf := &domain.Workflow{\n\t\tName:      \"host-wf\",\n\t\tLocation:  domain.LocationHost,\n\t\tEntryStep: \"run\",\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"run\": {Name: \"run\", Type: domain.StepTypeWorkflow, Results: []string{\"success\"}},\n\t\t},\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"run\", Result: \"success\", To: \"done\"},\n\t\t},\n\t}\n\n\toutput := renderWorkflowGraph(wf, false)\n\tif !strings.Contains(output, \"(host)\") {\n\t\tt.Error(\"expected host location in header\")\n\t}\n\tif !strings.Contains(output, \"workflow\") {\n\t\tt.Error(\"expected workflow step type\")\n\t}\n}\n\nfunc TestRenderWorkflowGraph_OtherResultColors(t *testing.T) {\n\twf := &domain.Workflow{\n\t\tName:      \"multi-color\",\n\t\tLocation:  domain.LocationContainer,\n\t\tEntryStep: \"step1\",\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"step1\": {Name: \"step1\", Type: domain.StepTypeAgent, Results: []string{\"retry\", \"skip\", \"timeout\", \"partial\"}},\n\t\t},\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"step1\", Result: \"retry\", To: \"done\"},\n\t\t\t{From: \"step1\", Result: \"skip\", To: \"done\"},\n\t\t\t{From: \"step1\", Result: \"timeout\", To: \"abort\"},\n\t\t\t{From: \"step1\", Result: \"partial\", To: \"abort\"},\n\t\t},\n\t}\n\n\toutput := renderWorkflowGraph(wf, true)\n\n\t// Each \"other\" result should get a distinct color from the palette\n\tif !strings.Contains(output, colorBlue) {\n\t\tt.Error(\"expected blue color for first other result\")\n\t}\n\tif !strings.Contains(output, colorYellow) {\n\t\tt.Error(\"expected yellow color for second other result\")\n\t}\n\tif !strings.Contains(output, colorOrange) {\n\t\tt.Error(\"expected orange color for third other result\")\n\t}\n\tif !strings.Contains(output, colorMagenta) {\n\t\tt.Error(\"expected magenta color for fourth other result\")\n\t}\n}\n\nfunc TestRenderWorkflowGraph_ConsistentBoxWidth(t *testing.T) {\n\twf := &domain.Workflow{\n\t\tName:      \"width-test\",\n\t\tLocation:  domain.LocationContainer,\n\t\tEntryStep: \"a\",\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"a\":             {Name: \"a\", Type: domain.StepTypeScript, Results: []string{\"ok\"}},\n\t\t\t\"long-step-name\": {Name: \"long-step-name\", Type: domain.StepTypeAgent, Results: []string{\"ok\"}},\n\t\t},\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"a\", Result: \"ok\", To: \"long-step-name\"},\n\t\t\t{From: \"long-step-name\", Result: \"ok\", To: \"done\"},\n\t\t},\n\t}\n\n\toutput := renderWorkflowGraph(wf, false)\n\tlines := strings.Split(output, \"\\n\")\n\n\t// Find border lines (those with Рћї or Рћћ)\n\tvar borderLengths []int\n\tfor _, line := range lines {\n\t\tif strings.Contains(line, \"Рћї\") && strings.Contains(line, \"Рћљ\") {\n\t\t\tborderLengths = append(borderLengths, len(line))\n\t\t}\n\t}\n\n\tif len(borderLengths) < 2 {\n\t\tt.Fatal(\"expected at least 2 border lines\")\n\t}\n\n\t// All borders should have the same length\n\tfor i := 1; i < len(borderLengths); i++ {\n\t\tif borderLengths[i] != borderLengths[0] {\n\t\t\tt.Errorf(\"inconsistent box widths: %d vs %d\", borderLengths[0], borderLengths[i])\n\t\t}\n\t}\n}\n\nfunc TestDiscoverWorkflows(t *testing.T) {\n\tdir := t.TempDir()\n\tclocheDir := filepath.Join(dir, \".cloche\")\n\tos.MkdirAll(clocheDir, 0755)\n\n\t// Write a container workflow\n\tos.WriteFile(filepath.Join(clocheDir, \"build.cloche\"), []byte(`workflow \"build\" {\n  step compile {\n    run = \"make\"\n    results = [success, fail]\n  }\n  compile:success -> done\n  compile:fail -> abort\n}`), 0644)\n\n\t// Write a host workflow with two workflows\n\tos.WriteFile(filepath.Join(clocheDir, \"host.cloche\"), []byte(`workflow \"plan\" {\n  step pick {\n    run = \"echo pick\"\n    results = [success]\n  }\n  pick:success -> done\n}\n\nworkflow \"run\" {\n  step exec {\n    run = \"echo run\"\n    results = [success]\n  }\n  exec:success -> done\n}`), 0644)\n\n\tinfos, err := discoverWorkflows(dir)\n\tif err != nil {\n\t\tt.Fatal(err)\n\t}\n\n\t// Should find 3 workflows: 1 container + 2 host\n\tif len(infos) != 3 {\n\t\tt.Fatalf(\"expected 3 workflows, got %d\", len(infos))\n\t}\n\n\tvar containerCount, hostCount int\n\tnames := map[string]bool{}\n\tfor _, info := range infos {\n\t\tnames[info.name] = true\n\t\tswitch info.location {\n\t\tcase domain.LocationContainer:\n\t\t\tcontainerCount++\n\t\tcase domain.LocationHost:\n\t\t\thostCount++\n\t\t}\n\t}\n\n\tif containerCount != 1 {\n\t\tt.Errorf(\"expected 1 container workflow, got %d\", containerCount)\n\t}\n\tif hostCount != 2 {\n\t\tt.Errorf(\"expected 2 host workflows, got %d\", hostCount)\n\t}\n\tfor _, name := range []string{\"build\", \"plan\", \"run\"} {\n\t\tif !names[name] {\n\t\t\tt.Errorf(\"missing workflow %q\", name)\n\t\t}\n\t}\n}\n\nfunc TestDiscoverWorkflows_NoClocheDir(t *testing.T) {\n\tdir := t.TempDir()\n\n\tinfos, err := discoverWorkflows(dir)\n\tif err != nil {\n\t\tt.Fatal(err)\n\t}\n\tif len(infos) != 0 {\n\t\tt.Errorf(\"expected 0 workflows, got %d\", len(infos))\n\t}\n}\n\nfunc TestLoadWorkflow_Container(t *testing.T) {\n\tdir := t.TempDir()\n\tclocheDir := filepath.Join(dir, \".cloche\")\n\tos.MkdirAll(clocheDir, 0755)\n\n\tos.WriteFile(filepath.Join(clocheDir, \"deploy.cloche\"), []byte(`workflow \"deploy\" {\n  step ship {\n    run = \"echo ship\"\n    results = [success, fail]\n  }\n  ship:success -> done\n  ship:fail -> abort\n}`), 0644)\n\n\twf, err := loadWorkflow(dir, \"deploy\")\n\tif err != nil {\n\t\tt.Fatal(err)\n\t}\n\tif wf.Name != \"deploy\" {\n\t\tt.Errorf(\"expected name 'deploy', got %q\", wf.Name)\n\t}\n\tif wf.Location != domain.LocationContainer {\n\t\tt.Errorf(\"expected container location, got %q\", wf.Location)\n\t}\n}\n\nfunc TestLoadWorkflow_Host(t *testing.T) {\n\tdir := t.TempDir()\n\tclocheDir := filepath.Join(dir, \".cloche\")\n\tos.MkdirAll(clocheDir, 0755)\n\n\tos.WriteFile(filepath.Join(clocheDir, \"host.cloche\"), []byte(`workflow \"orchestrate\" {\n  step dispatch {\n    run = \"echo go\"\n    results = [success]\n  }\n  dispatch:success -> done\n}`), 0644)\n\n\twf, err := loadWorkflow(dir, \"orchestrate\")\n\tif err != nil {\n\t\tt.Fatal(err)\n\t}\n\tif wf.Name != \"orchestrate\" {\n\t\tt.Errorf(\"expected name 'orchestrate', got %q\", wf.Name)\n\t}\n\tif wf.Location != domain.LocationHost {\n\t\tt.Errorf(\"expected host location, got %q\", wf.Location)\n\t}\n}\n\nfunc TestLoadWorkflow_NotFound(t *testing.T) {\n\tdir := t.TempDir()\n\tos.MkdirAll(filepath.Join(dir, \".cloche\"), 0755)\n\n\t_, err := loadWorkflow(dir, \"nonexistent\")\n\tif err == nil {\n\t\tt.Error(\"expected error for nonexistent workflow\")\n\t}\n\tif !strings.Contains(err.Error(), \"not found\") {\n\t\tt.Errorf(\"expected 'not found' error, got: %v\", err)\n\t}\n}\n\nfunc TestRenderWorkflowGraph_DevelopWorkflow(t *testing.T) {\n\t// Simulate the develop workflow from the project\n\twf := &domain.Workflow{\n\t\tName:      \"develop\",\n\t\tLocation:  domain.LocationContainer,\n\t\tEntryStep: \"implement\",\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"implement\":   {Name: \"implement\", Type: domain.StepTypeAgent, Results: []string{\"success\", \"fail\"}},\n\t\t\t\"test\":        {Name: \"test\", Type: domain.StepTypeScript, Results: []string{\"success\", \"fail\"}},\n\t\t\t\"fix\":         {Name: \"fix\", Type: domain.StepTypeAgent, Results: []string{\"success\", \"fail\", \"give-up\"}},\n\t\t\t\"update-docs\": {Name: \"update-docs\", Type: domain.StepTypeAgent, Results: []string{\"success\", \"fail\"}},\n\t\t},\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"implement\", Result: \"success\", To: \"test\"},\n\t\t\t{From: \"implement\", Result: \"fail\", To: \"abort\"},\n\t\t\t{From: \"test\", Result: \"success\", To: \"update-docs\"},\n\t\t\t{From: \"test\", Result: \"fail\", To: \"fix\"},\n\t\t\t{From: \"fix\", Result: \"success\", To: \"test\"},\n\t\t\t{From: \"fix\", Result: \"fail\", To: \"abort\"},\n\t\t\t{From: \"fix\", Result: \"give-up\", To: \"abort\"},\n\t\t\t{From: \"update-docs\", Result: \"success\", To: \"done\"},\n\t\t\t{From: \"update-docs\", Result: \"fail\", To: \"done\"},\n\t\t},\n\t}\n\n\toutput := renderWorkflowGraph(wf, false)\n\n\t// Check BFS order: implement -> test -> update-docs -> fix\n\t// (update-docs before fix because test:success wire comes before test:fail wire)\n\tlines := strings.Split(output, \"\\n\")\n\tstepBoxOrder := []string{}\n\tfor _, line := range lines {\n\t\tif strings.Contains(line, \"Рћѓ\") && strings.Contains(line, \"РЌђ entry\") {\n\t\t\tstepBoxOrder = append(stepBoxOrder, \"implement\")\n\t\t} else if strings.Contains(line, \"Рћѓ\") && strings.Contains(line, \"script\") && strings.Contains(line, \"test\") {\n\t\t\tstepBoxOrder = append(stepBoxOrder, \"test\")\n\t\t} else if strings.Contains(line, \"Рћѓ\") && strings.Contains(line, \"update-docs\") {\n\t\t\tstepBoxOrder = append(stepBoxOrder, \"update-docs\")\n\t\t} else if strings.Contains(line, \"Рћѓ\") && strings.Contains(line, \"fix\") && strings.Contains(line, \"agent\") && !strings.Contains(line, \"update\") && !strings.Contains(line, \"implement\") {\n\t\t\tstepBoxOrder = append(stepBoxOrder, \"fix\")\n\t\t}\n\t}\n\n\texpected := []string{\"implement\", \"test\", \"update-docs\", \"fix\"}\n\tif len(stepBoxOrder) != len(expected) {\n\t\tt.Fatalf(\"expected %d step boxes, got %d: %v\", len(expected), len(stepBoxOrder), stepBoxOrder)\n\t}\n\tfor i, name := range expected {\n\t\tif stepBoxOrder[i] != name {\n\t\t\tt.Errorf(\"step %d: expected %q, got %q (order: %v)\", i, name, stepBoxOrder[i], stepBoxOrder)\n\t\t}\n\t}\n\n\t// Check wire merging: fix's fail and give-up should merge to ABORT\n\tif !strings.Contains(output, \"fail, give-up РћђРћђРќХ ABORT\") {\n\t\tt.Errorf(\"expected merged wire 'fail, give-up РћђРћђРќХ ABORT' in output:\\n%s\", output)\n\t}\n\n\t// Check wire merging: update-docs success and fail should merge to DONE\n\tif !strings.Contains(output, \"success, fail РћђРћђРќХ DONE\") {\n\t\tt.Errorf(\"expected merged wire 'success, fail РћђРћђРќХ DONE' in output:\\n%s\", output)\n\t}\n\n\t// Check cycle reference: fix:success -> test (back reference)\n\tif !strings.Contains(output, \"success РћђРћђРќХ test\") {\n\t\tt.Error(\"expected fix:success wire to test\")\n\t}\n}\n\nfunc TestFormatDest(t *testing.T) {\n\ttests := []struct {\n\t\tto       string\n\t\tcolor    bool\n\t\texpected string\n\t}{\n\t\t{\"done\", false, \"DONE\"},\n\t\t{\"abort\", false, \"ABORT\"},\n\t\t{\"step_a\", false, \"step_a\"},\n\t\t{\"done\", true, colorGreen + \"DONE\" + colorReset},\n\t\t{\"abort\", true, colorRed + \"ABORT\" + colorReset},\n\t\t{\"step_a\", true, \"step_a\"},\n\t}\n\n\tfor _, tt := range tests {\n\t\tgot := formatDest(tt.to, tt.color)\n\t\tif got != tt.expected {\n\t\t\tt.Errorf(\"formatDest(%q, %v) = %q, want %q\", tt.to, tt.color, got, tt.expected)\n\t\t}\n\t}\n}\n\nfunc TestRenderWorkflowGraph_CollectBlock(t *testing.T) {\n\twf := &domain.Workflow{\n\t\tName:      \"collect-test\",\n\t\tLocation:  domain.LocationContainer,\n\t\tEntryStep: \"step1\",\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"step1\": {Name: \"step1\", Type: domain.StepTypeScript, Results: []string{\"success\"}},\n\t\t\t\"step2\": {Name: \"step2\", Type: domain.StepTypeScript, Results: []string{\"success\"}},\n\t\t\t\"step3\": {Name: \"step3\", Type: domain.StepTypeScript, Results: []string{\"success\"}},\n\t\t},\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"step1\", Result: \"success\", To: \"step2\"},\n\t\t\t{From: \"step1\", Result: \"success\", To: \"step3\"},\n\t\t\t{From: \"step3\", Result: \"success\", To: \"done\"},\n\t\t},\n\t\tCollects: []domain.Collect{\n\t\t\t{\n\t\t\t\tMode: domain.CollectAll,\n\t\t\t\tConditions: []domain.WireCondition{\n\t\t\t\t\t{Step: \"step2\", Result: \"success\"},\n\t\t\t\t\t{Step: \"step3\", Result: \"success\"},\n\t\t\t\t},\n\t\t\t\tTo: \"done\",\n\t\t\t},\n\t\t},\n\t}\n\n\toutput := renderWorkflowGraph(wf, false)\n\tif !strings.Contains(output, \"collect all\") {\n\t\tt.Errorf(\"expected collect block in output:\\n%s\", output)\n\t}\n}\n","numLines":626,"startLine":1,"totalLines":626}}}
