nd-poll-impl.md","docs/plans/2026-03-01-subdirectory-layout-and-poll-design.md","docs/plans/2026-02-24-self-evolution-implementation.md","docs/plans/2026-02-23-cloche-init.md","docs/plans/2026-02-23-cloche-init-design.md","docs/plans/2026-02-20-edge-selection-implementation.md","docs/plans/2026-02-20-edge-selection-design.md","docs/plans/2026-02-20-cloche-implementation.md","docs/plans/2026-02-20-cloche-system-design.md"],"numFiles":24}}
