\"PROJECT\\tSTATUS\\tPASSED\\tFAILED\\tTOTAL\")\n    57Рєњ\tfor _, p := range projects {\n    58Рєњ\t\tname := p.Label\n    59Рєњ\t\tif name == \"\" {\n    60Рєњ\t\t\tname = p.Dir\n    61Рєњ\t\t}\n    62Рєњ\t\tstatus := colorStatus(p.Health.Status)\n    63Рєњ\t\tfmt.Fprintf(w, \"%s\\t%s\\t%d\\t%d\\t%d\\n\",\n    64Рєњ\t\t\tname, status, p.Health.Passed, p.Health.Failed, p.Health.Total)\n    65Рєњ\t}\n    66Рєњ\tw.Flush()\n    67Рєњ}\n    68Рєњ\n    69Рєњfunc colorStatus(status string) string {\n    70Рєњ\tif !isTTY() {\n    71Рєњ\t\treturn status\n    72Рєњ\t}\n    73Рєњ\tswitch status {\n    74Рєњ\tcase \"green\":\n    75Рєњ\t\treturn \"\\033[32m\" + status + \"\\033[0m\"\n    76Рєњ\tcase \"yellow\":\n    77Рєњ\t\treturn \"\\033[33m\" + status + \"\\033[0m\"\n    78Рєњ\tcase \"red\":\n    79Рєњ\t\treturn \"\\033[31m\" + status + \"\\033[0m\"\n    80Рєњ\tdefault:\n    81Рєњ\t\treturn status\n    82Рєњ\t}\n    83Рєњ}\n    84Рєњ\n    85Рєњfunc isTTY() bool {\n    86Рєњ\tfi, err := os.Stdout.Stat()\n    87Рєњ\tif err != nil {\n    88Рєњ\t\treturn false\n    89Рєњ\t}\n    90Рєњ\treturn fi.Mode()&os.ModeCharDevice != 0\n    91Рєњ}\n    92Рєњ"}]},"parent_tool_use_id":null,"session_id":"824f09ed-450b-4e33-88c5-1585f66e5eba","uuid":"342394bb-d754-4320-9f4d-455444276618","tool_use_result":{"type":"text","file":{"filePath":"/workspace/cmd/cloche/health.go","content":"package main\n\nimport (\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"net/http\"\n\t\"os\"\n\t\"text/tabwriter\"\n)\n\ntype healthData struct {\n\tStatus string `json:\"status\"`\n\tPassed int    `json:\"passed\"`\n\tFailed int    `json:\"failed\"`\n\tTotal  int    `json:\"total\"`\n}\n\ntype projectHealth struct {\n\tDir    string     `json:\"dir\"`\n\tLabel  string     `json:\"label\"`\n\tHealth healthData `json:\"health\"`\n}\n\nfunc cmdHealth(args []string) {\n\thttpAddr := os.Getenv(\"CLOCHE_HTTP\")\n\tif httpAddr == \"\" {\n\t\tfmt.Fprintf(os.Stderr, \"error: CLOCHE_HTTP not set (e.g. export CLOCHE_HTTP=localhost:8080)\\n\")\n\t\tos.Exit(1)\n\t}\n\n\turl := \"http://\" + httpAddr + \"/api/projects\"\n\tresp, err := http.Get(url)\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tdefer resp.Body.Close()\n\n\tif resp.StatusCode != http.StatusOK {\n\t\tfmt.Fprintf(os.Stderr, \"error: server returned %s\\n\", resp.Status)\n\t\tos.Exit(1)\n\t}\n\n\tvar projects []projectHealth\n\tif err := json.NewDecoder(resp.Body).Decode(&projects); err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tif len(projects) == 0 {\n\t\tfmt.Println(\"No projects found.\")\n\t\treturn\n\t}\n\n\tw := tabwriter.NewWriter(os.Stdout, 0, 0, 2, ' ', 0)\n\tfmt.Fprintln(w, \"PROJECT\\tSTATUS\\tPASSED\\tFAILED\\tTOTAL\")\n\tfor _, p := range projects {\n\t\tname := p.Label\n\t\tif name == \"\" {\n\t\t\tname = p.Dir\n\t\t}\n\t\tstatus := colorStatus(p.Health.Status)\n\t\tfmt.Fprintf(w, \"%s\\t%s\\t%d\\t%d\\t%d\\n\",\n\t\t\tname, status, p.Health.Passed, p.Health.Failed, p.Health.Total)\n\t}\n\tw.Flush()\n}\n\nfunc colorStatus(status string) string {\n\tif !isTTY() {\n\t\treturn status\n\t}\n\tswitch status {\n\tcase \"green\":\n\t\treturn \"\\033[32m\" + status + \"\\033[0m\"\n\tcase \"yellow\":\n\t\treturn \"\\033[33m\" + status + \"\\033[0m\"\n\tcase \"red\":\n\t\treturn \"\\033[31m\" + status + \"\\033[0m\"\n\tdefault:\n\t\treturn status\n\t}\n}\n\nfunc isTTY() bool {\n\tfi, err := os.Stdout.Stat()\n\tif err != nil {\n\t\treturn false\n\t}\n\treturn fi.Mode()&os.ModeCharDevice != 0\n}\n","numLines":92,"startLine":1,"totalLines":92}}}
