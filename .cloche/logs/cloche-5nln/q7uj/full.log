[2026-03-13T17:46:46Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018za24sRhxFqJnv8GFvPJFZ","type":"tool_result","content":"     1Рєњpackage dsl\n     2Рєњ\n     3Рєњimport (\n     4Рєњ\t\"fmt\"\n     5Рєњ\t\"strconv\"\n     6Рєњ\t\"strings\"\n     7Рєњ\n     8Рєњ\t\"github.com/cloche-dev/cloche/internal/domain\"\n     9Рєњ)\n    10Рєњ\n    11Рєњtype Parser struct {\n    12Рєњ\tlexer    *Lexer\n    13Рєњ\tcurrent  Token\n    14Рєњ\tpeek     Token\n    15Рєњ\tlocation domain.WorkflowLocation\n    16Рєњ}\n    17Рєњ\n    18Рєњ// ParseOption configures the parser.\n    19Рєњtype ParseOption func(*Parser)\n    20Рєњ\n    21Рєњ// WithLocation sets the workflow location, enabling location-based validation.\n    22Рєњfunc WithLocation(loc domain.WorkflowLocation) ParseOption {\n    23Рєњ\treturn func(p *Parser) {\n    24Рєњ\t\tp.location = loc\n    25Рєњ\t}\n    26Рєњ}\n    27Рєњ\n    28Рєњfunc Parse(input string, opts ...ParseOption) (*domain.Workflow, error) {\n    29Рєњ\tp := &Parser{lexer: NewLexer(input)}\n    30Рєњ\tfor _, opt := range opts {\n    31Рєњ\t\topt(p)\n    32Рєњ\t}\n    33Рєњ\tp.advance() // load current\n    34Рєњ\tp.advance() // load peek\n    35Рєњ\treturn p.parseWorkflow()\n    36Рєњ}\n    37Рєњ\n    38Рєњ// ParseForHost parses a host.cloche file containing a single workflow.\n    39Рєњfunc ParseForHost(input string) (*domain.Workflow, error) {\n    40Рєњ\treturn Parse(input, WithLocation(domain.LocationHost))\n    41Рєњ}\n    42Рєњ\n    43Рєњ// ParseAllForHost parses a host.cloche file that may contain multiple workflows.\n    44Рєњ// Returns a map of workflow name to workflow definition.\n    45Рєњfunc ParseAllForHost(input string) (map[string]*domain.Workflow, error) {\n    46Рєњ\tp := &Parser{lexer: NewLexer(input), location: domain.LocationHost}\n    47Рєњ\tp.advance() // load current\n    48Рєњ\tp.advance() // load peek\n    49Рєњ\n    50Рєњ\tworkflows := make(map[string]*domain.Workflow)\n    51Рєњ\tfor p.current.Type != TokenEOF {\n    52Рєњ\t\twf, err := p.parseWorkflow()\n    53Рєњ\t\tif err != nil {\n    54Рєњ\t\t\treturn nil, err\n    55Рєњ\t\t}\n    56Рєњ\t\tif _, exists := workflows[wf.Name]; exists {\n    57Рєњ\t\t\treturn nil, fmt.Errorf(\"duplicate workflow name %q\", wf.Name)\n    58Рєњ\t\t}\n    59Рєњ\t\tworkflows[wf.Name] = wf\n    60Рєњ\t}\n    61Рєњ\n    62Рєњ\tif len(workflows) == 0 {\n    63Рєњ\t\treturn nil, fmt.Errorf(\"no workflows found in host.cloche\")\n    64Рєњ\t}\n    65Рєњ\n    66Рєњ\treturn workflows, nil\n    67Рєњ}\n    68Рєњ\n    69Рєњ// ParseForContainer parses a container workflow file.\n    70Рєњfunc ParseForContainer(input string) (*domain.Workflow, error) {\n    71Рєњ\treturn Parse(input, WithLocation(domain.LocationContainer))\n    72Рєњ}\n    73Рєњ\n    74Рєњfunc (p *Parser) advance() {\n    75Рєњ\tp.current = p.peek\n    76Рєњ\tp.peek = p.lexer.NextToken()\n    77Рєњ}\n    78Рєњ\n    79Рєњfunc (p *Parser) expect(typ TokenType) (Token, error) {\n    80Рєњ\tif p.current.Type != typ {\n    81Рєњ\t\treturn p.current, fmt.Errorf(\"line %d col %d: expected %v, got %v (%q)\",\n    82Рєњ\t\t\tp.current.Line, p.current.Col, typ, p.current.Type, p.current.Literal)\n    83Рєњ\t}\n    84Рєњ\ttok := p.current\n    85Рєњ\tp.advance()\n    86Рєњ\treturn tok, nil\n    87Рєњ}\n    88Рєњ\n    89Рєњfunc (p *Parser) expectIdent(value string) (Token, error) {\n    90Рєњ\tif p.current.Type != TokenIdent || p.current.Literal != value {\n    91Рєњ\t\treturn p.current, fmt.Errorf(\"line %d col %d: expected %q, got %q\",\n    92Рєњ\t\t\tp.current.Line, p.current.Col, value, p.current.Literal)\n    93Рєњ\t}\n    94Рєњ\ttok := p.current\n    95Рєњ\tp.advance()\n    96Рєњ\treturn tok, nil\n    97Рєњ}\n    98Рєњ\n    99Рєњfunc (p *Parser) parseWorkflow() (*domain.Workflow, error) {\n   100Рєњ\tif _, err := p.expectIdent(\"workflow\"); err != nil {\n   101Рєњ\t\treturn nil, err\n   102Рєњ\t}\n   103Рєњ\n   104Рєњ\tnameTok, err := p.expect(TokenString)\n   105Рєњ\tif err != nil {\n   106Рєњ\t\treturn nil, fmt.Errorf(\"expected workflow name string: %w\", err)\n   107Рєњ\t}\n   108Рєњ\n   109Рєњ\tif _, err := p.expect(TokenLBrace); err != nil {\n   110Рєњ\t\treturn nil, err\n   111Рєњ\t}\n   112Рєњ\n   113Рєњ\twf := &domain.Workflow{\n   114Рєњ\t\tName:     nameTok.Literal,\n   115Рєњ\t\tLocation: p.location,\n   116Рєњ\t\tSteps:    make(map[string]*domain.Step),\n   117Рєњ\t\tConfig:   make(map[string]string),\n   118Рєњ\t}\n   119Рєњ\n   120Рєњ\tfor p.current.Type != TokenRBrace && p.current.Type != TokenEOF {\n   121Рєњ\t\tif p.current.Type == TokenIdent && p.current.Literal == \"step\" {\n   122Рєњ\t\t\tstep, err := p.parseStep()\n   123Рєњ\t\t\tif err != nil {\n   124Рєњ\t\t\t\treturn nil, err\n   125Рєњ\t\t\t}\n   126Рєњ\t\t\twf.Steps[step.Name] = step\n   127Рєњ\t\t\tif wf.EntryStep == \"\" {\n   128Рєњ\t\t\t\twf.EntryStep = step.Name\n   129Рєњ\t\t\t}\n   130Рєњ\t\t} else if p.current.Type == TokenIdent && p.current.Literal == \"collect\" {\n   131Рєњ\t\t\tcollect, err := p.parseCollect()\n   132Рєњ\t\t\tif err != nil {\n   133Рєњ\t\t\t\treturn nil, err\n   134Рєњ\t\t\t}\n   135Рєњ\t\t\twf.Collects = append(wf.Collects, collect)\n   136Рєњ\t\t} else if p.current.Type == TokenIdent && p.peek.Type == TokenLBrace {\n   137Рєњ\t\t\tif err := p.parseWorkflowConfig(wf); err != nil {\n   138Рєњ\t\t\t\treturn nil, err\n   139Рєњ\t\t\t}\n   140Рєњ\t\t} else if p.current.Type == TokenIdent && p.peek.Type == TokenColon {\n   141Рєњ\t\t\twire, err := p.parseWire()\n   142Рєњ\t\t\tif err != nil {\n   143Рєњ\t\t\t\treturn nil, err\n   144Рєњ\t\t\t}\n   145Рєњ\t\t\twf.Wiring = append(wf.Wiring, wire)\n   146Рєњ\t\t} else {\n   147Рєњ\t\t\treturn nil, fmt.Errorf(\"line %d col %d: unexpected token %q\", p.current.Line, p.current.Col, p.current.Literal)\n   148Рєњ\t\t}\n   149Рєњ\t}\n   150Рєњ\n   151Рєњ\tif _, err := p.expect(TokenRBrace); err != nil {\n   152Рєњ\t\treturn nil, err\n   153Рєњ\t}\n   154Рєњ\n   155Рєњ\tif wf.Location != \"\" {\n   156Рєњ\t\tif err := wf.ValidateLocation(); err != nil {\n   157Рєњ\t\t\treturn nil, err\n   158Рєњ\t\t}\n   159Рєњ\t}\n   160Рєњ\n   161Рєњ\treturn wf, nil\n   162Рєњ}\n   163Рєњ\n   164Рєњfunc (p *Parser) parseWorkflowConfig(wf *domain.Workflow) error {\n   165Рєњ\tprefix := p.current.Literal // e.g. \"container\"\n   166Рєњ\tp.advance()                 // consume prefix ident\n   167Рєњ\n   168Рєњ\tif _, err := p.expect(TokenLBrace); err != nil {\n   169Рєњ\t\treturn err\n   170Рєњ\t}\n   171Рєњ\n   172Рєњ\tfor p.current.Type != TokenRBrace && p.current.Type != TokenEOF {\n   173Рєњ\t\tkeyTok, err := p.expect(TokenIdent)\n   174Рєњ\t\tif err != nil {\n   175Рєњ\t\t\treturn fmt.Errorf(\"expected field name: %w\", err)\n   176Рєњ\t\t}\n   177Рєњ\n   178Рєњ\t\tif _, err := p.expect(TokenEquals); err != nil {\n   179Рєњ\t\t\treturn err\n   180Рєњ\t\t}\n   181Рєњ\n   182Рєњ\t\tval, err := p.parseValue()\n   183Рєњ\t\tif err != nil {\n   184Рєњ\t\t\treturn err\n   185Рєњ\t\t}\n   186Рєњ\n   187Рєњ\t\twf.Config[prefix+\".\"+keyTok.Literal] = val\n   188Рєњ\t}\n   189Рєњ\n   190Рєњ\tif _, err := p.expect(TokenRBrace); err != nil {\n   191Рєњ\t\treturn err\n   192Рєњ\t}\n   193Рєњ\n   194Рєњ\treturn nil\n   195Рєњ}\n   196Рєњ\n   197Рєњfunc (p *Parser) parseStep() (*domain.Step, error) {\n   198Рєњ\tp.advance() // consume \"step\"\n   199Рєњ\n   200Рєњ\tnameTok, err := p.expect(TokenIdent)\n   201Рєњ\tif err != nil {\n   202Рєњ\t\treturn nil, fmt.Errorf(\"expected step name: %w\", err)\n   203Рєњ\t}\n   204Рєњ\n   205Рєњ\tif _, err := p.expect(TokenLBrace); err != nil {\n   206Рєњ\t\treturn nil, err\n   207Рєњ\t}\n   208Рєњ\n   209Рєњ\tstep := &domain.Step{\n   210Рєњ\t\tName:   nameTok.Literal,\n   211Рєњ\t\tConfig: make(map[string]string),\n   212Рєњ\t}\n   213Рєњ\n   214Рєњ\tfor p.current.Type != TokenRBrace && p.current.Type != TokenEOF {\n   215Рєњ\t\tif err := p.parseStepField(step, \"\"); err != nil {\n   216Рєњ\t\t\treturn nil, err\n   217Рєњ\t\t}\n   218Рєњ\t}\n   219Рєњ\n   220Рєњ\tif _, err := p.expect(TokenRBrace); err != nil {\n   221Рєњ\t\treturn nil, err\n   222Рєњ\t}\n   223Рєњ\n   224Рєњ\t// Infer step type from content\n   225Рєњ\t_, hasPrompt := step.Config[\"prompt\"]\n   226Рєњ\t_, hasRun := step.Config[\"run\"]\n   227Рєњ\t_, hasWorkflowName := step.Config[\"workflow_name\"]\n   228Рєњ\n   229Рєњ\tcount := 0\n   230Рєњ\tif hasPrompt {\n   231Рєњ\t\tcount++\n   232Рєњ\t}\n   233Рєњ\tif hasRun {\n   234Рєњ\t\tcount++\n   235Рєњ\t}\n   236Рєњ\tif hasWorkflowName {\n   237Рєњ\t\tcount++\n   238Рєњ\t}\n   239Рєњ\n   240Рєњ\tif count > 1 {\n   241Рєњ\t\treturn nil, fmt.Errorf(\"step %q has multiple of 'prompt', 'run', 'workflow_name'; must have exactly one\", step.Name)\n   242Рєњ\t}\n   243Рєњ\n   244Рєњ\tswitch {\n   245Рєњ\tcase hasPrompt:\n   246Рєњ\t\tstep.Type = domain.StepTypeAgent\n   247Рєњ\tcase hasRun:\n   248Рєњ\t\tstep.Type = domain.StepTypeScript\n   249Рєњ\tcase hasWorkflowName:\n   250Рєњ\t\tstep.Type = domain.StepTypeWorkflow\n   251Рєњ\tdefault:\n   252Рєњ\t\treturn nil, fmt.Errorf(\"step %q has none of 'prompt', 'run', or 'workflow_name'; must have exactly one\", step.Name)\n   253Рєњ\t}\n   254Рєњ\n   255Рєњ\treturn step, nil\n   256Рєњ}\n   257Рєњ\n   258Рєњfunc (p *Parser) parseStepField(step *domain.Step, prefix string) error {\n   259Рєњ\tkeyTok, err := p.expect(TokenIdent)\n   260Рєњ\tif err != nil {\n   261Рєњ\t\treturn fmt.Errorf(\"expected field name: %w\", err)\n   262Рєњ\t}\n   263Рєњ\n   264Рєњ\tkey := keyTok.Literal\n   265Рєњ\tif prefix != \"\" {\n   266Рєњ\t\tkey = prefix + \".\" + key\n   267Рєњ\t}\n   268Рєњ\n   269Рєњ\t// Sub-block (e.g., container { ... })\n   270Рєњ\tif p.current.Type == TokenLBrace {\n   271Рєњ\t\tp.advance() // consume {\n   272Рєњ\t\tfor p.current.Type != TokenRBrace && p.current.Type != TokenEOF {\n   273Рєњ\t\t\tif err := p.parseStepField(step, key); err != nil {\n   274Рєњ\t\t\t\treturn err\n   275Рєњ\t\t\t}\n   276Рєњ\t\t}\n   277Рєњ\t\tp.advance() // consume }\n   278Рєњ\t\treturn nil\n   279Рєњ\t}\n   280Рєњ\n   281Рєњ\tif _, err := p.expect(TokenEquals); err != nil {\n   282Рєњ\t\treturn err\n   283Рєњ\t}\n   284Рєњ\n   285Рєњ\tif key == \"results\" {\n   286Рєњ\t\tresults, err := p.parseIdentList()\n   287Рєњ\t\tif err != nil {\n   288Рєњ\t\t\treturn err\n   289Рєњ\t\t}\n   290Рєњ\t\tstep.Results = results\n   291Рєњ\t} else if p.current.Type == TokenLBracket {\n   292Рєњ\t\tvalues, err := p.parseStringList()\n   293Рєњ\t\tif err != nil {\n   294Рєњ\t\t\treturn err\n   295Рєњ\t\t}\n   296Рєњ\t\tstep.Config[key] = strings.Join(values, \",\")\n   297Рєњ\t} else {\n   298Рєњ\t\tval, err := p.parseValue()\n   299Рєњ\t\tif err != nil {\n   300Рєњ\t\t\treturn err\n   301Рєњ\t\t}\n   302Рєњ\t\tstep.Config[key] = val\n   303Рєњ\t}\n   304Рєњ\n   305Рєњ\treturn nil\n   306Рєњ}\n   307Рєњ\n   308Рєњfunc (p *Parser) parseIdentList() ([]string, error) {\n   309Рєњ\tif _, err := p.expect(TokenLBracket); err != nil {\n   310Рєњ\t\treturn nil, err\n   311Рєњ\t}\n   312Рєњ\n   313Рєњ\tvar items []string\n   314Рєњ\tfor p.current.Type != TokenRBracket && p.current.Type != TokenEOF {\n   315Рєњ\t\ttok, err := p.expect(TokenIdent)\n   316Рєњ\t\tif err != nil {\n   317Рєњ\t\t\treturn nil, err\n   318Рєњ\t\t}\n   319Рєњ\t\titems = append(items, tok.Literal)\n   320Рєњ\t\tif p.current.Type == TokenComma {\n   321Рєњ\t\t\tp.advance()\n   322Рєњ\t\t}\n   323Рєњ\t}\n   324Рєњ\n   325Рєњ\tif _, err := p.expect(TokenRBracket); err != nil {\n   326Рєњ\t\treturn nil, err\n   327Рєњ\t}\n   328Рєњ\n   329Рєњ\treturn items, nil\n   330Рєњ}\n   331Рєњ\n   332Рєњfunc (p *Parser) parseStringList() ([]string, error) {\n   333Рєњ\tif _, err := p.expect(TokenLBracket); err != nil {\n   334Рєњ\t\treturn nil, err\n   335Рєњ\t}\n   336Рєњ\n   337Рєњ\tvar items []string\n   338Рєњ\tfor p.current.Type != TokenRBracket && p.current.Type != TokenEOF {\n   339Рєњ\t\ttok, err := p.expect(TokenString)\n   340Рєњ\t\tif err != nil {\n   341Рєњ\t\t\treturn nil, err\n   342Рєњ\t\t}\n   343Рєњ\t\titems = append(items, tok.Literal)\n   344Рєњ\t\tif p.current.Type == TokenComma {\n   345Рєњ\t\t\tp.advance()\n   346Рєњ\t\t}\n   347Рєњ\t}\n   348Рєњ\n   349Рєњ\tif _, err := p.expect(TokenRBracket); err != nil {\n   350Рєњ\t\treturn nil, err\n   351Рєњ\t}\n   352Рєњ\n   353Рєњ\treturn items, nil\n   354Рєњ}\n   355Рєњ\n   356Рєњfunc (p *Parser) parseValue() (string, error) {\n   357Рєњ\tif p.current.Type == TokenString {\n   358Рєњ\t\ttok := p.current\n   359Рєњ\t\tp.advance()\n   360Рєњ\t\treturn tok.Literal, nil\n   361Рєњ\t}\n   362Рєњ\n   363Рєњ\tif p.current.Type == TokenIdent {\n   364Рєњ\t\tvar buf strings.Builder\n   365Рєњ\t\tbuf.WriteString(p.current.Literal)\n   366Рєњ\t\tp.advance()\n   367Рєњ\n   368Рєњ\t\t// Function call: file(\"...\")\n   369Рєњ\t\tif p.current.Type == TokenLParen {\n   370Рєњ\t\t\tbuf.WriteRune('(')\n   371Рєњ\t\t\tp.advance()\n   372Рєњ\t\t\tfor p.current.Type != TokenRParen && p.current.Type != TokenEOF {\n   373Рєњ\t\t\t\tif p.current.Type == TokenString {\n   374Рєњ\t\t\t\t\tbuf.WriteRune('\"')\n   375Рєњ\t\t\t\t\tbuf.WriteString(p.current.Literal)\n   376Рєњ\t\t\t\t\tbuf.WriteRune('\"')\n   377Рєњ\t\t\t\t} else {\n   378Рєњ\t\t\t\t\tbuf.WriteString(p.current.Literal)\n   379Рєњ\t\t\t\t}\n   380Рєњ\t\t\t\tp.advance()\n   381Рєњ\t\t\t}\n   382Рєњ\t\t\tbuf.WriteRune(')')\n   383Рєњ\t\t\tp.advance() // consume )\n   384Рєњ\t\t}\n   385Рєњ\n   386Рєњ\t\t// Dotted path: step.code.output\n   387Рєњ\t\tfor p.current.Type == TokenDot {\n   388Рєњ\t\t\tbuf.WriteRune('.')\n   389Рєњ\t\t\tp.advance()\n   390Рєњ\t\t\tif p.current.Type == TokenIdent {\n   391Рєњ\t\t\t\tbuf.WriteString(p.current.Literal)\n   392Рєњ\t\t\t\tp.advance()\n   393Рєњ\t\t\t}\n   394Рєњ\t\t}\n   395Рєњ\n   396Рєњ\t\treturn buf.String(), nil\n   397Рєњ\t}\n   398Рєњ\n   399Рєњ\treturn \"\", fmt.Errorf(\"line %d col %d: expected value, got %q\", p.current.Line, p.current.Col, p.current.Literal)\n   400Рєњ}\n   401Рєњ\n   402Рєњfunc (p *Parser) parseWire() (domain.Wire, error) {\n   403Рєњ\tfromTok := p.current\n   404Рєњ\tp.advance()\n   405Рєњ\n   406Рєњ\tif _, err := p.expect(TokenColon); err != nil {\n   407Рєњ\t\treturn domain.Wire{}, err\n   408Рєњ\t}\n   409Рєњ\n   410Рєњ\tresultTok, err := p.expect(TokenIdent)\n   411Рєњ\tif err != nil {\n   412Рєњ\t\treturn domain.Wire{}, err\n   413Рєњ\t}\n   414Рєњ\n   415Рєњ\tif _, err := p.expect(TokenArrow); err != nil {\n   416Рєњ\t\treturn domain.Wire{}, err\n   417Рєњ\t}\n   418Рєњ\n   419Рєњ\ttoTok, err := p.expect(TokenIdent)\n   420Рєњ\tif err != nil {\n   421Рєњ\t\treturn domain.Wire{}, err\n   422Рєњ\t}\n   423Рєњ\n   424Рєњ\tvar mappings []domain.OutputMapping\n   425Рєњ\tif p.current.Type == TokenLBracket {\n   426Рєњ\t\tmappings, err = p.parseOutputMappings()\n   427Рєњ\t\tif err != nil {\n   428Рєњ\t\t\treturn domain.Wire{}, err\n   429Рєњ\t\t}\n   430Рєњ\t}\n   431Рєњ\n   432Рєњ\treturn domain.Wire{\n   433Рєњ\t\tFrom:      fromTok.Literal,\n   434Рєњ\t\tResult:    resultTok.Literal,\n   435Рєњ\t\tTo:        toTok.Literal,\n   436Рєњ\t\tOutputMap: mappings,\n   437Рєњ\t}, nil\n   438Рєњ}\n   439Рєњ\n   440Рєњfunc (p *Parser) parseOutputMappings() ([]domain.OutputMapping, error) {\n   441Рєњ\tif _, err := p.expect(TokenLBracket); err != nil {\n   442Рєњ\t\treturn nil, err\n   443Рєњ\t}\n   444Рєњ\n   445Рєњ\tvar mappings []domain.OutputMapping\n   446Рєњ\tfor p.current.Type != TokenRBracket && p.current.Type != TokenEOF {\n   447Рєњ\t\tkeyTok, err := p.expect(TokenIdent)\n   448Рєњ\t\tif err != nil {\n   449Рєњ\t\t\treturn nil, fmt.Errorf(\"expected mapping key: %w\", err)\n   450Рєњ\t\t}\n   451Рєњ\n   452Рєњ\t\tif _, err := p.expect(TokenEquals); err != nil {\n   453Рєњ\t\t\treturn nil, err\n   454Рєњ\t\t}\n   455Рєњ\n   456Рєњ\t\tpath, err := p.parseOutputPath()\n   457Рєњ\t\tif err != nil {\n   458Рєњ\t\t\treturn nil, err\n   459Рєњ\t\t}\n   460Рєњ\n   461Рєњ\t\tmappings = append(mappings, domain.OutputMapping{\n   462Р