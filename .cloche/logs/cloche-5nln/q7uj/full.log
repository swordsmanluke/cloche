[2026-03-13T17:46:46Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Fm6uxTemD36oiusSfGAMU1","type":"tool_result","content":"     1Рєњpackage main\n     2Рєњ\n     3Рєњimport (\n     4Рєњ\t\"context\"\n     5Рєњ\t\"encoding/json\"\n     6Рєњ\t\"errors\"\n     7Рєњ\t\"fmt\"\n     8Рєњ\t\"io\"\n     9Рєњ\t\"net/http\"\n    10Рєњ\t\"os\"\n    11Рєњ\t\"path/filepath\"\n    12Рєњ\t\"strings\"\n    13Рєњ\t\"time\"\n    14Рєњ\n    15Рєњ\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    16Рєњ\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    17Рєњ\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    18Рєњ\t\"github.com/cloche-dev/cloche/internal/runcontext\"\n    19Рєњ\t\"google.golang.org/grpc\"\n    20Рєњ\t\"google.golang.org/grpc/credentials/insecure\"\n    21Рєњ\t\"google.golang.org/grpc/metadata\"\n    22Рєњ)\n    23Рєњ\n    24Рєњfunc main() {\n    25Рєњ\tif len(os.Args) < 2 {\n    26Рєњ\t\tprintTopLevelHelp()\n    27Рєњ\t\tos.Exit(1)\n    28Рєњ\t}\n    29Рєњ\n    30Рєњ\t// Handle top-level help: \"cloche help\", \"cloche --help\", \"cloche -h\"\n    31Рєњ\tswitch os.Args[1] {\n    32Рєњ\tcase \"help\":\n    33Рєњ\t\tprintHelp(os.Args[2:])\n    34Рєњ\t\treturn\n    35Рєњ\tcase \"--help\", \"-h\":\n    36Рєњ\t\tprintTopLevelHelp()\n    37Рєњ\t\treturn\n    38Рєњ\t}\n    39Рєњ\n    40Рєњ\t// Commands that don't need a daemon connection\n    41Рєњ\tswitch os.Args[1] {\n    42Рєњ\tcase \"init\":\n    43Рєњ\t\tif hasHelpFlag(os.Args[2:]) {\n    44Рєњ\t\t\tprintSubcommandHelp(\"init\")\n    45Рєњ\t\t\treturn\n    46Рєњ\t\t}\n    47Рєњ\t\tcmdInit(os.Args[2:])\n    48Рєњ\t\treturn\n    49Рєњ\tcase \"health\":\n    50Рєњ\t\tif hasHelpFlag(os.Args[2:]) {\n    51Рєњ\t\t\tprintSubcommandHelp(\"health\")\n    52Рєњ\t\t\treturn\n    53Рєњ\t\t}\n    54Рєњ\t\tcmdHealth(os.Args[2:])\n    55Рєњ\t\treturn\n    56Рєњ\tcase \"get\":\n    57Рєњ\t\tif hasHelpFlag(os.Args[2:]) {\n    58Рєњ\t\t\tprintSubcommandHelp(\"get\")\n    59Рєњ\t\t\treturn\n    60Рєњ\t\t}\n    61Рєњ\t\tcmdGet(os.Args[2:])\n    62Рєњ\t\treturn\n    63Рєњ\tcase \"set\":\n    64Рєњ\t\tif hasHelpFlag(os.Args[2:]) {\n    65Рєњ\t\t\tprintSubcommandHelp(\"set\")\n    66Рєњ\t\t\treturn\n    67Рєњ\t\t}\n    68Рєњ\t\tcmdSet(os.Args[2:])\n    69Рєњ\t\treturn\n    70Рєњ\tcase \"tasks\":\n    71Рєњ\t\tif hasHelpFlag(os.Args[2:]) {\n    72Рєњ\t\t\tprintSubcommandHelp(\"tasks\")\n    73Рєњ\t\t\treturn\n    74Рєњ\t\t}\n    75Рєњ\t\tcmdTasks(os.Args[2:])\n    76Рєњ\t\treturn\n    77Рєњ\t}\n    78Рєњ\n    79Рєњ\t// Handle --help for daemon commands before connecting\n    80Рєњ\tdaemonCmds := map[string]bool{\n    81Рєњ\t\t\"run\": true, \"status\": true, \"logs\": true, \"poll\": true,\n    82Рєњ\t\t\"list\": true, \"stop\": true, \"delete\": true, \"loop\": true, \"shutdown\": true,\n    83Рєњ\t}\n    84Рєњ\tif daemonCmds[os.Args[1]] && hasHelpFlag(os.Args[2:]) {\n    85Рєњ\t\tprintSubcommandHelp(os.Args[1])\n    86Рєњ\t\treturn\n    87Рєњ\t}\n    88Рєњ\n    89Рєњ\t// Commands that need a daemon connection\n    90Рєњ\taddr := os.Getenv(\"CLOCHE_ADDR\")\n    91Рєњ\tif addr == \"\" {\n    92Рєњ\t\taddr = \"unix:///tmp/cloche.sock\"\n    93Рєњ\t}\n    94Рєњ\n    95Рєњ\tconn, err := grpc.NewClient(addr, grpc.WithTransportCredentials(insecure.NewCredentials()))\n    96Рєњ\tif err != nil {\n    97Рєњ\t\tfmt.Fprintf(os.Stderr, \"failed to connect: %v\\n\", err)\n    98Рєњ\t\tos.Exit(1)\n    99Рєњ\t}\n   100Рєњ\tdefer conn.Close()\n   101Рєњ\n   102Рєњ\tclient := pb.NewClocheServiceClient(conn)\n   103Рєњ\tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n   104Рєњ\tdefer cancel()\n   105Рєњ\n   106Рєњ\tswitch os.Args[1] {\n   107Рєњ\tcase \"run\":\n   108Рєњ\t\tcmdRun(ctx, client, os.Args[2:])\n   109Рєњ\tcase \"status\":\n   110Рєњ\t\tcmdStatus(ctx, client, os.Args[2:])\n   111Рєњ\tcase \"logs\":\n   112Рєњ\t\tcmdLogs(client, os.Args[2:])\n   113Рєњ\tcase \"poll\":\n   114Рєњ\t\tcmdPoll(client, os.Args[2:])\n   115Рєњ\tcase \"list\":\n   116Рєњ\t\tcmdList(ctx, client, os.Args[2:])\n   117Рєњ\tcase \"stop\":\n   118Рєњ\t\tcmdStop(ctx, client, os.Args[2:])\n   119Рєњ\tcase \"delete\":\n   120Рєњ\t\tcmdDelete(ctx, client, os.Args[2:])\n   121Рєњ\tcase \"loop\":\n   122Рєњ\t\tcmdLoop(ctx, client, os.Args[2:])\n   123Рєњ\tcase \"shutdown\":\n   124Рєњ\t\tcmdShutdown(ctx, client)\n   125Рєњ\tdefault:\n   126Рєњ\t\tfmt.Fprintf(os.Stderr, \"unknown command: %s\\n\\n\", os.Args[1])\n   127Рєњ\t\tprintTopLevelHelp()\n   128Рєњ\t\tos.Exit(1)\n   129Рєњ\t}\n   130Рєњ}\n   131Рєњ\n   132Рєњ\n   133Рєњfunc cmdRun(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   134Рєњ\tvar workflow, prompt, title string\n   135Рєњ\tvar keepContainer bool\n   136Рєњ\n   137Рєњ\tfor i := 0; i < len(args); i++ {\n   138Рєњ\t\tswitch args[i] {\n   139Рєњ\t\tcase \"--workflow\":\n   140Рєњ\t\t\tif i+1 < len(args) {\n   141Рєњ\t\t\t\ti++\n   142Рєњ\t\t\t\tworkflow = args[i]\n   143Рєњ\t\t\t}\n   144Рєњ\t\tcase \"--prompt\", \"-p\":\n   145Рєњ\t\t\tif i+1 < len(args) {\n   146Рєњ\t\t\t\ti++\n   147Рєњ\t\t\t\tprompt = args[i]\n   148Рєњ\t\t\t}\n   149Рєњ\t\tcase \"--title\":\n   150Рєњ\t\t\tif i+1 < len(args) {\n   151Рєњ\t\t\t\ti++\n   152Рєњ\t\t\t\ttitle = args[i]\n   153Рєњ\t\t\t}\n   154Рєњ\t\tcase \"--keep-container\":\n   155Рєњ\t\t\tkeepContainer = true\n   156Рєњ\t\tdefault:\n   157Рєњ\t\t\t// Support bare positional arg as workflow name for backwards compat\n   158Рєњ\t\t\tif workflow == \"\" && !strings.HasPrefix(args[i], \"-\") {\n   159Рєњ\t\t\t\tworkflow = args[i]\n   160Рєњ\t\t\t}\n   161Рєњ\t\t}\n   162Рєњ\t}\n   163Рєњ\n   164Рєњ\tif workflow == \"\" {\n   165Рєњ\t\tfmt.Fprintf(os.Stderr, \"usage: cloche run --workflow <name> [--prompt \\\"...\\\"] [--title \\\"...\\\"]\\n\")\n   166Рєњ\t\tos.Exit(1)\n   167Рєњ\t}\n   168Рєњ\n   169Рєњ\tcwd, _ := os.Getwd()\n   170Рєњ\n   171Рєњ\t// Resolve image from workflow file (soft failure Рђћ fall back to daemon default)\n   172Рєњ\tvar image string\n   173Рєњ\twfPath := filepath.Join(cwd, \".cloche\", workflow+\".cloche\")\n   174Рєњ\tif data, err := os.ReadFile(wfPath); err == nil {\n   175Рєњ\t\tif wf, err := dsl.ParseForContainer(string(data)); err == nil {\n   176Рєњ\t\t\timage = wf.Config[\"container.image\"]\n   177Рєњ\t\t}\n   178Рєњ\t}\n   179Рєњ\n   180Рєњ\tresp, err := client.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n   181Рєњ\t\tWorkflowName:  workflow,\n   182Рєњ\t\tProjectDir:    cwd,\n   183Рєњ\t\tImage:         image,\n   184Рєњ\t\tPrompt:        prompt,\n   185Рєњ\t\tKeepContainer: keepContainer,\n   186Рєњ\t\tTitle:         title,\n   187Рєњ\t})\n   188Рєњ\tif err != nil {\n   189Рєњ\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   190Рєњ\t\tos.Exit(1)\n   191Рєњ\t}\n   192Рєњ\tfmt.Printf(\"Started run: %s\\n\", resp.RunId)\n   193Рєњ}\n   194Рєњ\n   195Рєњfunc cmdStatus(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   196Рєњ\tif len(args) < 1 {\n   197Рєњ\t\tfmt.Fprintf(os.Stderr, \"usage: cloche status <run-id>\\n\")\n   198Рєњ\t\tos.Exit(1)\n   199Рєњ\t}\n   200Рєњ\n   201Рєњ\tresp, err := client.GetStatus(ctx, &pb.GetStatusRequest{RunId: args[0]})\n   202Рєњ\tif err != nil {\n   203Рєњ\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   204Рєњ\t\tos.Exit(1)\n   205Рєњ\t}\n   206Рєњ\n   207Рєњ\tfmt.Printf(\"Run:       %s\\n\", resp.RunId)\n   208Рєњ\tif resp.Title != \"\" {\n   209Рєњ\t\tfmt.Printf(\"Title:     %s\\n\", resp.Title)\n   210Рєњ\t}\n   211Рєњ\tfmt.Printf(\"Workflow:  %s\\n\", resp.WorkflowName)\n   212Рєњ\tif resp.IsHost {\n   213Рєњ\t\tfmt.Printf(\"Type:      host\\n\")\n   214Рєњ\t} else {\n   215Рєњ\t\tfmt.Printf(\"Type:      container\\n\")\n   216Рєњ\t}\n   217Рєњ\tfmt.Printf(\"State:     %s\\n\", resp.State)\n   218Рєњ\tif resp.ContainerId != \"\" {\n   219Рєњ\t\tcid := resp.ContainerId\n   220Рєњ\t\tif len(cid) > 12 {\n   221Рєњ\t\t\tcid = cid[:12]\n   222Рєњ\t\t}\n   223Рєњ\t\tfmt.Printf(\"Container: %s\\n\", cid)\n   224Рєњ\t}\n   225Рєњ\tif resp.ErrorMessage != \"\" {\n   226Рєњ\t\tfmt.Printf(\"Error:     %s\\n\", resp.ErrorMessage)\n   227Рєњ\t}\n   228Рєњ\tfmt.Printf(\"Active:    %s\\n\", resp.CurrentStep)\n   229Рєњ\tfor _, exec := range resp.StepExecutions {\n   230Рєњ\t\tfmt.Printf(\"  %s: %s (%s -> %s)\\n\", exec.StepName, exec.Result, exec.StartedAt, exec.CompletedAt)\n   231Рєњ\t}\n   232Рєњ}\n   233Рєњ\n   234Рєњfunc cmdList(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   235Рєњ\tvar all bool\n   236Рєњ\tfor _, arg := range args {\n   237Рєњ\t\tif arg == \"--all\" {\n   238Рєњ\t\t\tall = true\n   239Рєњ\t\t}\n   240Рєњ\t}\n   241Рєњ\n   242Рєњ\treq := &pb.ListRunsRequest{}\n   243Рєњ\tif all {\n   244Рєњ\t\t// --all: show all runs across all projects (no time limit)\n   245Рєњ\t\treq.All = true\n   246Рєњ\t} else {\n   247Рєњ\t\t// Default: filter to current project\n   248Рєњ\t\tcwd, _ := os.Getwd()\n   249Рєњ\t\treq.ProjectDir = cwd\n   250Рєњ\t}\n   251Рєњ\n   252Рєњ\tresp, err := client.ListRuns(ctx, req)\n   253Рєњ\tif err != nil {\n   254Рєњ\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   255Рєњ\t\tos.Exit(1)\n   256Рєњ\t}\n   257Рєњ\n   258Рєњ\tif len(resp.Runs) == 0 {\n   259Рєњ\t\tfmt.Println(\"No runs found.\")\n   260Рєњ\t\treturn\n   261Рєњ\t}\n   262Рєњ\n   263Рєњ\tfor _, run := range resp.Runs {\n   264Рєњ\t\trunType := \"container\"\n   265Рєњ\t\tif run.IsHost {\n   266Рєњ\t\t\trunType = \"host\"\n   267Рєњ\t\t}\n   268Рєњ\t\tline := fmt.Sprintf(\"%s  %-20s  %-10s  %-9s\", run.RunId, run.WorkflowName, run.State, runType)\n   269Рєњ\t\tif run.Title != \"\" {\n   270Рєњ\t\t\tt := run.Title\n   271Рєњ\t\t\tif len(t) > 40 {\n   272Рєњ\t\t\t\tt = t[:37] + \"...\"\n   273Рєњ\t\t\t}\n   274Рєњ\t\t\tline += \"  \" + t\n   275Рєњ\t\t}\n   276Рєњ\t\tif run.ContainerId != \"\" {\n   277Рєњ\t\t\tline += \"  \" + run.ContainerId\n   278Рєњ\t\t}\n   279Рєњ\t\tif run.ErrorMessage != \"\" {\n   280Рєњ\t\t\terrMsg := run.ErrorMessage\n   281Рєњ\t\t\tif len(errMsg) > 60 {\n   282Рєњ\t\t\t\terrMsg = errMsg[:57] + \"...\"\n   283Рєњ\t\t\t}\n   284Рєњ\t\t\tline += \"  \" + errMsg\n   285Рєњ\t\t}\n   286Рєњ\t\tfmt.Println(line)\n   287Рєњ\t}\n   288Рєњ}\n   289Рєњ\n   290Рєњfunc cmdLogs(client pb.ClocheServiceClient, args []string) {\n   291Рєњ\tif len(args) < 1 {\n   292Рєњ\t\tfmt.Fprintf(os.Stderr, \"usage: cloche logs <run-id> [--step <name>] [--type <full|script|llm>] [-f]\\n\")\n   293Рєњ\t\tos.Exit(1)\n   294Рєњ\t}\n   295Рєњ\n   296Рєњ\tvar stepFilter, typeFilter string\n   297Рєњ\tvar follow bool\n   298Рєњ\trunID := args[0]\n   299Рєњ\n   300Рєњ\tfor i := 1; i < len(args); i++ {\n   301Рєњ\t\tswitch args[i] {\n   302Рєњ\t\tcase \"--step\":\n   303Рєњ\t\t\tif i+1 < len(args) {\n   304Рєњ\t\t\t\ti++\n   305Рєњ\t\t\t\tstepFilter = args[i]\n   306Рєњ\t\t\t}\n   307Рєњ\t\tcase \"--type\":\n   308Рєњ\t\t\tif i+1 < len(args) {\n   309Рєњ\t\t\t\ti++\n   310Рєњ\t\t\t\ttypeFilter = args[i]\n   311Рєњ\t\t\t}\n   312Рєњ\t\tcase \"--follow\", \"-f\":\n   313Рєњ\t\t\tfollow = true\n   314Рєњ\t\t}\n   315Рєњ\t}\n   316Рєњ\n   317Рєњ\t// Use background context Рђћ log output can be large and follow mode blocks.\n   318Рєњ\tctx := context.Background()\n   319Рєњ\tif follow {\n   320Рєњ\t\tmd := metadata.Pairs(\"x-cloche-follow\", \"true\")\n   321Рєњ\t\tctx = metadata.NewOutgoingContext(ctx, md)\n   322Рєњ\t}\n   323Рєњ\n   324Рєњ\tstream, err := client.StreamLogs(ctx, &pb.StreamLogsRequest{\n   325Рєњ\t\tRunId:    runID,\n   326Рєњ\t\tStepName: stepFilter,\n   327Рєњ\t\tLogType:  typeFilter,\n   328Рєњ\t})\n   329Рєњ\tif err != nil {\n   330Рєњ\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   331Рєњ\t\tos.Exit(1)\n   332Рєњ\t}\n   333Рєњ\n   334Рєњ\tfor {\n   335Рєњ\t\tentry, err := stream.Recv()\n   336Рєњ\t\tif err != nil {\n   337Рєњ\t\t\tif errors.Is(err, io.EOF) {\n   338Рєњ\t\t\t\tbreak\n   339Рєњ\t\t\t}\n   340Рєњ\t\t\tfmt.Fprintf(os.Stderr, \"error reading logs: %v\\n\", err)\n   341Рєњ\t\t\tos.Exit(1)\n   342Рєњ\t\t}\n   343Рєњ\n   344Рєњ\t\tswitch entry.Type {\n   345Рєњ\t\tcase \"step_started\":\n   346Рєњ\t\t\tfmt.Printf(\"--- %s started ---\\n\", entry.StepName)\n   347Рєњ\t\t\tif entry.Message != \"\" {\n   348Рєњ\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n   349Рєњ\t\t\t}\n   350Рєњ\t\tcase \"step_completed\":\n   351Рєњ\t\t\tfmt.Printf(\"--- %s: %s ---\\n\", entry.StepName, entry.Result)\n   352Рєњ\t\t\tif entry.Message != \"\" {\n   353Рєњ\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n   354Рєњ\t\t\t}\n   355Рєњ\t\tcase \"run_completed\":\n   356Рєњ\t\t\tfmt.Printf(\"\\nRun result: %s\\n\", entry.Result)\n   357Рєњ\t\t\tif entry.Message != \"\" {\n   358Рєњ\t\t\t\tfmt.Printf(\"Error:      %s\\n\", entry.Message)\n   359Рєњ\t\t\t}\n   360Рєњ\t\tcase \"full_log\":\n   361Рєњ\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n   362Рєњ\t\tcase \"log\":\n   363Рєњ\t\t\t// Live-streamed log line from an active run.\n   364Рєњ\t\t\tfmt.Println(entry.Message)\n   365Рєњ\t\tdefault:\n   366Рєњ\t\t\t// Handles filtered log entries like \"script_log\", \"llm_log\", \"step_log\"\n   367Рєњ\t\t\tif entry.StepName != \"\" {\n   368Рєњ\t\t\t\tfmt.Printf(\"--- %s ---\\n\", entry.StepName)\n   369Рєњ\t\t\t}\n   370Рєњ\t\t\tif entry.Message != \"\" {\n   371Рєњ\t\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n   372Рєњ\t\t\t}\n   373Рєњ\t\t}\n   374Рєњ\t}\n   375Рєњ}\n   376Рєњ\n   377Рєњfunc cmdStop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   378Рєњ\tif len(args) < 1 {\n   379Рєњ\t\tfmt.Fprintf(os.Stderr, \"usage: cloche stop <run-id>\\n\")\n   380Рєњ\t\tos.Exit(1)\n   381Рєњ\t}\n   382Рєњ\n   383Рєњ\t_, err := client.StopRun(ctx, &pb.StopRunRequest{RunId: args[0]})\n   384Рєњ\tif err != nil {\n   385Рєњ\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   386Рєњ\t\tos.Exit(1)\n   387Рєњ\t}\n   388Рєњ\tfmt.Printf(\"Stopped run: %s\\n\", args[0])\n   389Рєњ}\n   390Рєњ\n   391Рєњfunc cmdDelete(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   392Рєњ\tif len(args) < 1 {\n   393Рєњ\t\tfmt.Fprintf(os.Stderr, \"usage: cloche delete <container-or-run-id>\\n\")\n   394Рєњ\t\tos.Exit(1)\n   395Рєњ\t}\n   396Рєњ\n   397Рєњ\t_, err := client.DeleteContainer(ctx, &pb.DeleteContainerRequest{Id: args[0]})\n   398Рєњ\tif err != nil {\n   399Рєњ\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   400Рєњ\t\tos.Exit(1)\n   401Рєњ\t}\n   402Рєњ\tfmt.Printf(\"Deleted container: %s\\n\", args[0])\n   403Рєњ}\n   404Рєњ\n   405Рєњfunc cmdLoop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   406Рєњ\tcwd, _ := os.Getwd()\n   407Рєњ\n   408Рєњ\t// Check for \"stop\" subcommand\n   409Рєњ\tif len(args) > 0 && args[0] == \"stop\" {\n   410Рєњ\t\t_, err := client.DisableLoop(ctx, &pb.DisableLoopRequest{ProjectDir: cwd})\n   411Рєњ\t\tif err != nil {\n   412Рєњ\t\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   413Рєњ\t\t\tos.Exit(1)\n   414Рєњ\t\t}\n   415Рєњ\t\tfmt.Println(\"Orchestration loop stopped.\")\n   416Рєњ\t\treturn\n   417Рєњ\t}\n   418Рєњ\n   419Рєњ\t// Default: 0 means \"use config value\" (server reads .cloche/config.toml).\n   420Рєњ\tvar maxConcurrent int32\n   421Рєњ\tfor i := 0; i < len(args); i++ {\n   422Рєњ\t\tswitch args[i] {\n   423Рєњ\t\tcase \"--max\":\n   424Рєњ\t\t\tif i+1 < len(args) {\n   425Рєњ\t\t\t\ti++\n   426Рєњ\t\t\t\tn, err := fmt.Sscanf(args[i], \"%d\", &maxConcurrent)\n   427Рєњ\t\t\t\tif n != 1 || err != nil {\n   428Рєњ\t\t\t\t\tfmt.Fprintf(os.Stderr, \"invalid --max value: %s\\n\", args[i])\n   429Рєњ\t\t\t\t\tos.Exit(1)\n   430Рєњ\t\t\t\t}\n   431Рєњ\t\t\t}\n   432Рєњ\t\t}\n   433Рєњ\t}\n   434Рєњ\n   435Рєњ\t_, err := client.EnableLoop(ctx, &pb.EnableLoopRequest{\n   436Рєњ\t\tProjectDir:    cwd,\n   437Рєњ\t\tMaxConcurrent: maxConcurrent,\n   438Рєњ\t})\n   439Рєњ\tif err != nil {\n   440Рєњ\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   441Рєњ\t\tos.Exit(1)\n   442Рєњ\t}\n   443Рєњ\tif maxConcurrent > 0 {\n   444Рєњ\t\tfmt.Printf(\"Orchestration loop started (max_concurrent=%d).\\n\", maxConcurrent)\n   445Рєњ\t} else {\n   446Рєњ\t\tfmt.Println(\"Orchestration loop started (using config defaults).\")\n   447Рєњ\t}\n   448Рєњ}\n   449Рєњ\n   450Рєњfunc cmdTasks(args []string) {\n   451Рєњ\t// Determine HTTP address from env\n   452Рєњ\thttpAddr := os.Getenv(\"CLOCHE_HTTP\")\n   453Рєњ\tif httpAddr == \"\" {\n   454Рєњ\t\thttpAddr = \"localhost:8080\"\n   455Рєњ\t}\n   456Рєњ\thttpAddr = strings.TrimPrefix(httpAddr, \"http://\")\n   457Рєњ\n   458Рєњ\t// Determine project label from --project flag or current directory\n   459Рєњ\tprojectDir := \"\"\n   460Рєњ\tfor i := 0; i < len(args); i++ {\n   461Рєњ\t\tswitch args[i] {\n   462Рєњ\t\tcase \"--project\":\n   463Рєњ\t\t\tif i+1 < len(args) {\n   464Рєњ\t\t\t\ti++\n   465Рєњ\t\t\t\tprojectDir = args[i]\n   466Рєњ\t\t\t}\n   467Рєњ\t\t}\n   468Рєњ\t}\n   469Рєњ\n   470Рєњ\tif projectDir == \"\" {\n   471Рєњ\t\tcwd, _ := os.Getwd()\n   472Рєњ\t\tprojectDir = filepath.Base(cwd)\n   473Рєњ\t}\n   474Рєњ\n   475Рєњ\ttasksURL := fmt.Sprintf(\"http://%s/api/projects/%s/tasks\", httpAddr, projectDir)\n   476Рєњ\tresp, err := http.Get(tasksURL)\n   477Рєњ\tif err != nil {\n   478Рєњ\t\tfmt.Fprintf(os.Stderr, \"error connecting to daemon web API: %v\\n\", err)\n   479Рєњ\t\tfmt.Fprintf(os.Stderr, \"hint: ensure CLOCHE_HTTP is set and the daemon is running with --http\\n\")\n   480Рєњ\t\tos.Exit(1)\n   481Рєњ\t}\n   482Рєњ\tdefer resp.Body.Close()\n   483Рєњ\n   484Рєњ\tif resp.StatusCode != 200 {\n   485Рєњ\t\tbody, _ := io.ReadAll(resp.Body)\n   486Рєњ\t\tfmt.Fprintf(os.Stderr, \"error: HTTP %d: %s\\n\", resp.StatusCode, strings.TrimSpace(string(body)))\n   487Рєњ\t\tos.Exit(1)\n   488Рєњ\t}\n   489Рєњ\n   490Рєњ\ttype taskEntry struct {\n   491Рєњ\t\tID          string `json:\"id\"`\n   492Рєњ\t\tStatus      string `json:\"status\"`\n   493Рєњ\t\tTitle       string `json:\"title\"`\n   494Рєњ\t\tDescription string `json:\"description\"`\n   495Рєњ\t\tAssigned    bool   `json:\"assigned\"`\n   496Рєњ\t\tAssignedAt  string `json:\"assigned_at\"`\n   497Рєњ\t\tRunID       string `json:\"run_id\"`\n   498Рєњ\t}\n   499Рєњ\n   500Рєњ\tvar tasks []taskEntry\n   501Рєњ\tif err := json.NewDecoder(resp.Body).Decode(&tasks); err != nil {\n   502Рєњ\t\tfmt.Fprintf(os.Stderr, \"error parsing response: %v\\n\", err)\n   503Рєњ\t\tos.Exit(1)\n   504Рєњ\t}\n   505Рєњ\n   506Рєњ\tif len(tasks) == 0 {\n   507Рєњ\t\tfmt.Println(\"No tasks found. (Is the orchestration loop running?)\")\n   508Рєњ\t\treturn\n   509Рєњ\t}\n   510Рєњ\n   511Рєњ\tfmt.Printf(\"%-20s  %-12s  %-10s  %-30s  %s\\n\", \"ID\", \"STATUS\", \"ASSIGNED\", \"RUN\", \"TITLE\")\n   512Рєњ\tfor _, t := range tasks {\n   513Рєњ\t\tstatus := t.Status\n   514Рєњ\t\tif status == \"\" {\n   515Рєњ\t\t\tstatus = \"open\"\n   516Рєњ\t\t}\n   517Рєњ\t\tassigned := \"-\"\n   518Рєњ\t\tif t.Assigned {\n   519Рєњ\t\t\tassigned = \"yes\"\n   520Рєњ\t\t}\n   521Рєњ\t\trunID := \"\"\n   522Рєњ\t\tif t.RunID != \"\" {\n   523Рєњ\t\t\trunID = t.RunID\n   524Рєњ\t\t\tif len(runID) > 30 {\n   525Рєњ\t\t\t\trunID = runID[:27] + \"...\"\n   526Рєњ\t\t\t}\n   527Рєњ\t\t}\n   528Рєњ\t\ttitle := t.Title\n   529Рєњ\t\tif len(title) > 40 {\n   530Рєњ\t\t\ttitle = title[:37] + \"...\"\n   531Рєњ\t\t}\n   532Рєњ\t\tfmt.Printf(\"%-20s  %-12s  %-10s  %-30s  %s\\n\", t.ID, status, assigned, runID, title)\n   533Рєњ\t}\n   534Рєњ}\n   535Рєњ\n   536Рєњfunc cmdShutdown(ctx context.Context, client pb.ClocheServiceClient) {\n   537Рєњ\t_, err := client.Shutdown(ctx, &pb.ShutdownRequest{})\n   538Рєњ\tif err != nil {\n   539Рєњ\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   540Рєњ\t\tos.Exit(1)\n   541Рєњ\t}\n   542Рєњ\tfmt.Println(\"Daemon shutting down.\")\n   543Рєњ}\n   544Рєњ\n   545Рєњ// resolveRunContext returns the project directory and run ID for context\n   546Рєњ// commands. The run ID comes from CLOCHE_RUN_ID and the project directory\n   547Рєњ// from CLOCHE_PROJECT_DIR (falling back to cwd).\n   548Рєњfunc resolveRunContext() (projectDir, runID string, err error) {\n   549Рєњ\trunID = os.Getenv(\"CLOCHE_RUN_ID\")\n   550Рєњ\tif runID == \"\" {\n   551Рєњ\t\treturn \"\", \"\", fmt.Errorf(\"CLOCHE_RUN_ID environment variable is not set\")\n   552Рєњ\t}\n   553Рєњ\tprojectDir = os.Getenv(\"CLOCHE_PROJECT_DIR\")\n   554Рєњ\tif projectDir == \"\" {\n   555Рєњ\t\tprojectDir, err = os.Getwd()\n   556Рєњ\t\tif err != nil {\n   557Рєњ\t\t\treturn \"\", \"\", fmt.Errorf(\"getting working directory: %w\", err)\n   558Рєњ\t\t}\n   559Рєњ\t}\n   560Рєњ\treturn projectDir, runID, nil\n   561Рєњ}\n   562Рєњ\n   563Рєњfunc cmdGet(args []string) {\n   564Рєњ\tif len(args) < 1 {\n   565Рєњ\t\tfmt.Fprintf(os.Stderr, \"usage: cloche get <key>\\n\")\n   566Рєњ\t\tos.Exit(1)\n   567Рєњ\t}\n   568Рєњ\n   569Рєњ\tprojectDir, runID, err := resolveRunContext()\n   570Рєњ\tif err != nil {\n   571Рєњ\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   572Рєњ\t\tos.Exit(1)\n   573Рєњ\t}\n   574Рєњ\n   575Рєњ\tval, ok, err := runcontext.Get(projectDir, runID, args[0])\n   576Рєњ\tif err != nil {\n   577Рєњ\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   578Рєњ\t\tos.Exit(1)\n   579Рєњ\t}\n   580Рєњ\tif !ok {\n   581Рєњ\t\tos.Exit(1)\n   582Рєњ\t}\n   583Рєњ\tfmt.Println(val)\n   584Рєњ}\n   585Рєњ\n   586Рєњfunc cmdSet(args []string) {\n   587Рєњ\tif len(args) < 2 {\n   588Рєњ\t\tfmt.Fprintf(os.Stderr, \"usage: cloche set <key> <value>\\n\")\n   589Рєњ\t\tfmt.Fprintf(os.Stderr, \"       cloche set <key> -     (read value from stdin)\\n\")\n   590Рєњ\t\tos.Exit(1)\n   591Рєњ\t}\n   592Рєњ\n   593Рєњ\tprojectDir, runID, err := resolveRunContext()\n   594Рєњ\tif err != nil {\n   595Рєњ\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   596Рєњ\t\tos.Exit(1)\n   597Рєњ\t}\n   598Рєњ\n   599Рєњ\tvalue := args[1]\n   600Рєњ\tif value == \"-\" {\n   601Рєњ\t\tdata, err := io.ReadAll(os.Stdin)\n   602Рєњ\t\tif err != nil {\n   603Рєњ\t\t\tfmt.Fprintf(os.Stderr, \"error reading stdin: %v\\n\", err)\n   604Рєњ\t\t\tos.Exit(1)\n   605Рєњ\t\t}\n   606Рєњ\t\tvalue = strings.TrimRight(string(data), \"\\n\")\n   607Рєњ\t}\n   608Рєњ\n   609Рєњ\tif err := runcontext.Set(projectDir, runID, args[0], value); err != nil {\n   610Рєњ\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   611Рєњ\t\tos.Exit(1)\n   612Рєњ\t}\n   613Рєњ}\n   614Рєњ"}]},"parent_tool_use_id":null,"session_id":"824f09ed-450b-4e33-88c5-1585f66e5eba","uuid":"f2076103-a59d-4d28-8898-e1098095ded8","tool_use_result":{"type":"text","file":{"filePath":"/workspace/cmd/cloche/main.go","content":"package main\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"errors\"\n\t\"fmt\"\n\t\"io\"\n\t\"net/http\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"strings\"\n\t\"time\"\n\n\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n\t\"github.com/cloche-dev/cloche/internal/dsl\"\n\t\"github.com/cloche-dev/cloche/internal/logstream\"\n\t\"github.com/cloche-dev/cloche/internal/runcontext\"\n\t\"google.golang.org/grpc\"\n\t\"google.golang.org/grpc/credentials/insecure\"\n\t\"google.golang.org/grpc/metadata\"\n)\n\nfunc main() {\n\tif len(os.Args) < 2 {\n\t\tprintTopLevelHelp()\n\t\tos.Exit(1)\n\t}\n\n\t// Handle top-level help: \"cloche help\", \"cloche --help\", \"cloche -h\"\n\tswitch os.Args[1] {\n\tcase \"help\":\n\t\tprintHelp(os.Args[2:])\n\t\treturn\n\tcase \"--help\", \"-h\":\n\t\tprintTopLevelHelp()\n\t\treturn\n\t}\n\n\t// Commands that don't need a daemon connection\n\tswitch os.Args[1] {\n\tcase \"init\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"init\")\n\t\t\treturn\n\t\t}\n\t\tcmdInit(os.Args[2:])\n\t\treturn\n\tcase \"health\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"health\")\n\t\t\treturn\n\t\t}\n\t\tcmdHealth(os.Args[2:])\n\t\treturn\n\tcase \"get\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"get\")\n\t\t\treturn\n\t\t}\n\t\tcmdGet(os.Args[2:])\n\t\treturn\n\tcase \"set\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"set\")\n\t\t\treturn\n\t\t}\n\t\tcmdSet(os.Args[2:])\n\t\treturn\n\tcase \"tasks\":\n\t\tif hasHelpFlag(os.Args[2:]) {\n\t\t\tprintSubcommandHelp(\"tasks\")\n\t\t\treturn\n\t\t}\n\t\tcmdTasks(os.Args[2:])\n\t\treturn\n\t}\n\n\t// Handle --help for daemon commands before connecting\n\tdaemonCmds := map[string]bool{\n\t\t\"run\": true, \"status\": true, \"logs\": true, \"poll\": true,\n\t\t\"list\": true, \"stop\": true, \"delete\": true, \"loop\": true, \"shutdown\": true,\n\t}\n\tif daemonCmds[os.Args[1]] && hasHelpFlag(os.Args[2:]) {\n\t\tprintSubcommandHelp(os.Args[1])\n\t\treturn\n\t}\n\n\t// Commands that need a daemon connection\n\taddr := os.Getenv(\"CLOCHE_ADDR\")\n\tif addr == \"\" {\n\t\taddr = \"unix:///tmp/cloche.sock\"\n\t}\n\n\tconn, err := grpc.NewClient(addr, grpc.WithTransportCredentials(insecure.NewCredentials()))\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"failed to connect: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tdefer conn.Close()\n\n\tclient := pb.NewClocheServiceClient(conn)\n\tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n\tdefer cancel()\n\n\tswitch os.Args[1] {\n\tcase \"run\":\n\t\tcmdRun(ctx, client, os.Args[2:])\n\tcase \"status\":\n\t\tcmdStatus(ctx, client, os.Args[2:])\n\tcase \"logs\":\n\t\tcmdLogs(client, os.Args[2:])\n\tcase \"poll\":\n\t\tcmdPoll(client, os.Args[2:])\n\tcase \"list\":\n\t\tcmdList(ctx, client, os.Args[2:])\n\tcase \"stop\":\n\t\tcmdStop(ctx, client, os.Args[2:])\n\tcase \"delete\":\n\t\tcmdDelete(ctx, client, os.Args[2:])\n\tcase \"loop\":\n\t\tcmdLoop(ctx, client, os.Args[2:])\n\tcase \"shutdown\":\n\t\tcmdShutdown(ctx, client)\n\tdefault:\n\t\tfmt.Fprintf(os.Stderr, \"unknown command: %s\\n\\n\", os.Args[1])\n\t\tprintTopLevelHelp()\n\t\tos.Exit(1)\n\t}\n}\n\n\nfunc cmdRun(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tvar workflow, prompt, title string\n\tvar keepContainer bool\n\n\tfor i := 0; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--workflow\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tworkflow = args[i]\n\t\t\t}\n\t\tcase \"--prompt\", \"-p\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tprompt = args[i]\n\t\t\t}\n\t\tcase \"--title\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\ttitle = args[i]\n\t\t\t}\n\t\tcase \"--keep-container\":\n\t\t\tkeepContainer = true\n\t\tdefault:\n\t\t\t// Support bare positional arg as workflow name for backwards compat\n\t\t\tif workflow == \"\" && !strings.HasPrefix(args[i], \"-\") {\n\t\t\t\tworkflow = args[i]\n\t\t\t}\n\t\t}\n\t}\n\n\tif workflow == \"\" {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche run --workflow <name> [--prompt \\\"...\\\"] [--title \\\"...\\\"]\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tcwd, _ := os.Getwd()\n\n\t// Resolve image from workflow file (soft failure Рђћ fall back to daemon default)\n\tvar image string\n\twfPath := filepath.Join(cwd, \".cloche\", workflow+\".cloche\")\n\tif data, err := os.ReadFile(wfPath); err == nil {\n\t\tif wf, err := dsl.ParseForContainer(string(data)); err == nil {\n\t\t\timage = wf.Config[\"container.image\"]\n\t\t}\n\t}\n\n\tresp, err := client.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n\t\tWorkflowName:  workflow,\n\t\tProjectDir:    cwd,\n\t\tImage:         image,\n\t\tPrompt:        prompt,\n\t\tKeepContainer: keepContainer,\n\t\tTitle:         title,\n\t})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Printf(\"Started run: %s\\n\", resp.RunId)\n}\n\nfunc cmdStatus(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche status <run-id>\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tresp, err := client.GetStatus(ctx, &pb.GetStatusRequest{RunId: args[0]})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tfmt.Printf(\"Run:       %s\\n\", resp.RunId)\n\tif resp.Title != \"\" {\n\t\tfmt.Printf(\"Title:     %s\\n\", resp.Title)\n\t}\n\tfmt.Printf(\"Workflow:  %s\\n\", resp.WorkflowName)\n\tif resp.IsHost {\n\t\tfmt.Printf(\"Type:      host\\n\")\n\t} else {\n\t\tfmt.Printf(\"Type:      container\\n\")\n\t}\n\tfmt.Printf(\"State:     %s\\n\", resp.State)\n\tif resp.ContainerId != \"\" {\n\t\tcid := resp.ContainerId\n\t\tif len(cid) > 12 {\n\t\t\tcid = cid[:12]\n\t\t}\n\t\tfmt.Printf(\"Container: %s\\n\", cid)\n\t}\n\tif resp.ErrorMessage != \"\" {\n\t\tfmt.Printf(\"Error:     %s\\n\", resp.ErrorMessage)\n\t}\n\tfmt.Printf(\"Active:    %s\\n\", resp.CurrentStep)\n\tfor _, exec := range resp.StepExecutions {\n\t\tfmt.Printf(\"  %s: %s (%s -> %s)\\n\", exec.StepName, exec.Result, exec.StartedAt, exec.CompletedAt)\n\t}\n}\n\nfunc cmdList(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tvar all bool\n\tfor _, arg := range args {\n\t\tif arg == \"--all\" {\n\t\t\tall = true\n\t\t}\n\t}\n\n\treq := &pb.ListRunsRequest{}\n\tif all {\n\t\t// --all: show all runs across all projects (no time limit)\n\t\treq.All = true\n\t} else {\n\t\t// Default: filter to current project\n\t\tcwd, _ := os.Getwd()\n\t\treq.ProjectDir = cwd\n\t}\n\n\tresp, err := client.ListRuns(ctx, req)\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tif len(resp.Runs) == 0 {\n\t\tfmt.Println(\"No runs found.\")\n\t\treturn\n\t}\n\n\tfor _, run := range resp.Runs {\n\t\trunType := \"container\"\n\t\tif run.IsHost {\n\t\t\trunType = \"host\"\n\t\t}\n\t\tline := fmt.Sprintf(\"%s  %-20s  %-10s  %-9s\", run.RunId, run.WorkflowName, run.State, runType)\n\t\tif run.Title != \"\" {\n\t\t\tt := run.Title\n\t\t\tif len(t) > 40 {\n\t\t\t\tt = t[:37] + \"...\"\n\t\t\t}\n\t\t\tline += \"  \" + t\n\t\t}\n\t\tif run.ContainerId != \"\" {\n\t\t\tline += \"  \" + run.ContainerId\n\t\t}\n\t\tif run.ErrorMessage != \"\" {\n\t\t\terrMsg := run.ErrorMessage\n\t\t\tif len(errMsg) > 60 {\n\t\t\t\terrMsg = errMsg[:57] + \"...\"\n\t\t\t}\n\t\t\tline += \"  \" + errMsg\n\t\t}\n\t\tfmt.Println(line)\n\t}\n}\n\nfunc cmdLogs(client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche logs <run-id> [--step <name>] [--type <full|script|llm>] [-f]\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tvar stepFilter, typeFilter string\n\tvar follow bool\n\trunID := args[0]\n\n\tfor i := 1; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--step\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tstepFilter = args[i]\n\t\t\t}\n\t\tcase \"--type\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\ttypeFilter = args[i]\n\t\t\t}\n\t\tcase \"--follow\", \"-f\":\n\t\t\tfollow = true\n\t\t}\n\t}\n\n\t// Use background context Рђћ log output can be large and follow mode blocks.\n\tctx := context.Background()\n\tif follow {\n\t\tmd := metadata.Pairs(\"x-cloche-follow\", \"true\")\n\t\tctx = metadata.NewOutgoingContext(ctx, md)\n\t}\n\n\tstream, err := client.StreamLogs(ctx, &pb.StreamLogsRequest{\n\t\tRunId:    runID,\n\t\tStepName: stepFilter,\n\t\tLogType:  typeFilter,\n\t})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tfor {\n\t\tentry, err := stream.Recv()\n\t\tif err != nil {\n\t\t\tif errors.Is(err, io.EOF) {\n\t\t\t\tbreak\n\t\t\t}\n\t\t\tfmt.Fprintf(os.Stderr, \"error reading logs: %v\\n\", err)\n\t\t\tos.Exit(1)\n\t\t}\n\n\t\tswitch entry.Type {\n\t\tcase \"step_started\":\n\t\t\tfmt.Printf(\"--- %s started ---\\n\", entry.StepName)\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n\t\t\t}\n\t\tcase \"step_completed\":\n\t\t\tfmt.Printf(\"--- %s: %s ---\\n\", entry.StepName, entry.Result)\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n\t\t\t}\n\t\tcase \"run_completed\":\n\t\t\tfmt.Printf(\"\\nRun result: %s\\n\", entry.Result)\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Printf(\"Error:      %s\\n\", entry.Message)\n\t\t\t}\n\t\tcase \"full_log\":\n\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n\t\tcase \"log\":\n\t\t\t// Live-streamed log line from an active run.\n\t\t\tfmt.Println(entry.Message)\n\t\tdefault:\n\t\t\t// Handles filtered log entries like \"script_log\", \"llm_log\", \"step_log\"\n\t\t\tif entry.StepName != \"\" {\n\t\t\t\tfmt.Printf(\"--- %s ---\\n\", entry.StepName)\n\t\t\t}\n\t\t\tif entry.Message != \"\" {\n\t\t\t\tfmt.Print(string(logstream.ParseClaudeStream([]byte(entry.Message))))\n\t\t\t}\n\t\t}\n\t}\n}\n\nfunc cmdStop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche stop <run-id>\\n\")\n\t\tos.Exit(1)\n\t}\n\n\t_, err := client.StopRun(ctx, &pb.StopRunRequest{RunId: args[0]})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Printf(\"Stopped run: %s\\n\", args[0])\n}\n\nfunc cmdDelete(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche delete <container-or-run-id>\\n\")\n\t\tos.Exit(1)\n\t}\n\n\t_, err := client.DeleteContainer(ctx, &pb.DeleteContainerRequest{Id: args[0]})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Printf(\"Deleted container: %s\\n\", args[0])\n}\n\nfunc cmdLoop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n\tcwd, _ := os.Getwd()\n\n\t// Check for \"stop\" subcommand\n\tif len(args) > 0 && args[0] == \"stop\" {\n\t\t_, err := client.DisableLoop(ctx, &pb.DisableLoopRequest{ProjectDir: cwd})\n\t\tif err != nil {\n\t\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\t\tos.Exit(1)\n\t\t}\n\t\tfmt.Println(\"Orchestration loop stopped.\")\n\t\treturn\n\t}\n\n\t// Default: 0 means \"use config value\" (server reads .cloche/config.toml).\n\tvar maxConcurrent int32\n\tfor i := 0; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--max\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tn, err := fmt.Sscanf(args[i], \"%d\", &maxConcurrent)\n\t\t\t\tif n != 1 || err != nil {\n\t\t\t\t\tfmt.Fprintf(os.Stderr, \"invalid --max value: %s\\n\", args[i])\n\t\t\t\t\tos.Exit(1)\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\t_, err := client.EnableLoop(ctx, &pb.EnableLoopRequest{\n\t\tProjectDir:    cwd,\n\t\tMaxConcurrent: maxConcurrent,\n\t})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tif maxConcurrent > 0 {\n\t\tfmt.Printf(\"Orchestration loop started (max_concurrent=%d).\\n\", maxConcurrent)\n\t} else {\n\t\tfmt.Println(\"Orchestration loop started (using config defaults).\")\n\t}\n}\n\nfunc cmdTasks(args []string) {\n\t// Determine HTTP address from env\n\thttpAddr := os.Getenv(\"CLOCHE_HTTP\")\n\tif httpAddr == \"\" {\n\t\thttpAddr = \"localhost:8080\"\n\t}\n\thttpAddr = strings.TrimPrefix(httpAddr, \"http://\")\n\n\t// Determine project label from --project flag or current directory\n\tprojectDir := \"\"\n\tfor i := 0; i < len(args); i++ {\n\t\tswitch args[i] {\n\t\tcase \"--project\":\n\t\t\tif i+1 < len(args) {\n\t\t\t\ti++\n\t\t\t\tprojectDir = args[i]\n\t\t\t}\n\t\t}\n\t}\n\n\tif projectDir == \"\" {\n\t\tcwd, _ := os.Getwd()\n\t\tprojectDir = filepath.Base(cwd)\n\t}\n\n\ttasksURL := fmt.Sprintf(\"http://%s/api/projects/%s/tasks\", httpAddr, projectDir)\n\tresp, err := http.Get(tasksURL)\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error connecting to daemon web API: %v\\n\", err)\n\t\tfmt.Fprintf(os.Stderr, \"hint: ensure CLOCHE_HTTP is set and the daemon is running with --http\\n\")\n\t\tos.Exit(1)\n\t}\n\tdefer resp.Body.Close()\n\n\tif resp.StatusCode != 200 {\n\t\tbody, _ := io.ReadAll(resp.Body)\n\t\tfmt.Fprintf(os.Stderr, \"error: HTTP %d: %s\\n\", resp.StatusCode, strings.TrimSpace(string(body)))\n\t\tos.Exit(1)\n\t}\n\n\ttype taskEntry struct {\n\t\tID          string `json:\"id\"`\n\t\tStatus      string `json:\"status\"`\n\t\tTitle       string `json:\"title\"`\n\t\tDescription string `json:\"description\"`\n\t\tAssigned    bool   `json:\"assigned\"`\n\t\tAssignedAt  string `json:\"assigned_at\"`\n\t\tRunID       string `json:\"run_id\"`\n\t}\n\n\tvar tasks []taskEntry\n\tif err := json.NewDecoder(resp.Body).Decode(&tasks); err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error parsing response: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tif len(tasks) == 0 {\n\t\tfmt.Println(\"No tasks found. (Is the orchestration loop running?)\")\n\t\treturn\n\t}\n\n\tfmt.Printf(\"%-20s  %-12s  %-10s  %-30s  %s\\n\", \"ID\", \"STATUS\", \"ASSIGNED\", \"RUN\", \"TITLE\")\n\tfor _, t := range tasks {\n\t\tstatus := t.Status\n\t\tif status == \"\" {\n\t\t\tstatus = \"open\"\n\t\t}\n\t\tassigned := \"-\"\n\t\tif t.Assigned {\n\t\t\tassigned = \"yes\"\n\t\t}\n\t\trunID := \"\"\n\t\tif t.RunID != \"\" {\n\t\t\trunID = t.RunID\n\t\t\tif len(runID) > 30 {\n\t\t\t\trunID = runID[:27] + \"...\"\n\t\t\t}\n\t\t}\n\t\ttitle := t.Title\n\t\tif len(title) > 40 {\n\t\t\ttitle = title[:37] + \"...\"\n\t\t}\n\t\tfmt.Printf(\"%-20s  %-12s  %-10s  %-30s  %s\\n\", t.ID, status, assigned, runID, title)\n\t}\n}\n\nfunc cmdShutdown(ctx context.Context, client pb.ClocheServiceClient) {\n\t_, err := client.Shutdown(ctx, &pb.ShutdownRequest{})\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tfmt.Println(\"Daemon shutting down.\")\n}\n\n// resolveRunContext returns the project directory and run ID for context\n// commands. The run ID comes from CLOCHE_RUN_ID and the project directory\n// from CLOCHE_PROJECT_DIR (falling back to cwd).\nfunc resolveRunContext() (projectDir, runID string, err error) {\n\trunID = os.Getenv(\"CLOCHE_RUN_ID\")\n\tif runID == \"\" {\n\t\treturn \"\", \"\", fmt.Errorf(\"CLOCHE_RUN_ID environment variable is not set\")\n\t}\n\tprojectDir = os.Getenv(\"CLOCHE_PROJECT_DIR\")\n\tif projectDir == \"\" {\n\t\tprojectDir, err = os.Getwd()\n\t\tif err != nil {\n\t\t\treturn \"\", \"\", fmt.Errorf(\"getting working directory: %w\", err)\n\t\t}\n\t}\n\treturn projectDir, runID, nil\n}\n\nfunc cmdGet(args []string) {\n\tif len(args) < 1 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche get <key>\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tprojectDir, runID, err := resolveRunContext()\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tval, ok, err := runcontext.Get(projectDir, runID, args[0])\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\tif !ok {\n\t\tos.Exit(1)\n\t}\n\tfmt.Println(val)\n}\n\nfunc cmdSet(args []string) {\n\tif len(args) < 2 {\n\t\tfmt.Fprintf(os.Stderr, \"usage: cloche set <key> <value>\\n\")\n\t\tfmt.Fprintf(os.Stderr, \"       cloche set <key> -     (read value from stdin)\\n\")\n\t\tos.Exit(1)\n\t}\n\n\tprojectDir, runID, err := resolveRunContext()\n\tif err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n\n\tvalue := args[1]\n\tif value == \"-\" {\n\t\tdata, err := io.ReadAll(os.Stdin)\n\t\tif err != nil {\n\t\t\tfmt.Fprintf(os.Stderr, \"error reading stdin: %v\\n\", err)\n\t\t\tos.Exit(1)\n\t\t}\n\t\tvalue = strings.TrimRight(string(data), \"\\n\")\n\t}\n\n\tif err := runcontext.Set(projectDir, runID, args[0], value); err != nil {\n\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n\t\tos.Exit(1)\n\t}\n}\n","numLines":614,"startLine":1,"totalLines":614}}}
