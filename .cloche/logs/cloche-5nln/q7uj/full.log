utionEntry struct {\n    44Рєњ\tID             string\n    45Рєњ\tProjectDir     string\n    46Рєњ\tWorkflowName   string\n    47Рєњ\tTriggerRunID   string\n    48Рєњ\tCreatedAt      time.Time\n    49Рєњ\tClassification string\n    50Рєњ\tChangesJSON    string\n    51Рєњ\tKnowledgeDelta string\n    52Рєњ}\n    53Рєњ\n    54Рєњtype EvolutionStore interface {\n    55Рєњ\tSaveEvolution(ctx context.Context, entry *EvolutionEntry) error\n    56Рєњ\tGetLastEvolution(ctx context.Context, projectDir, workflowName string) (*EvolutionEntry, error)\n    57Рєњ\tListRunsSince(ctx context.Context, projectDir, workflowName, sinceRunID string) ([]*domain.Run, error)\n    58Рєњ}\n    59Рєњ"}]},"parent_tool_use_id":"toolu_01R9B5ZLwaA81q4buXwXBtpB","session_id":"824f09ed-450b-4e33-88c5-1585f66e5eba","uuid":"704439ea-1b84-4b24-92e2-cbd1c0b0d37b"}
