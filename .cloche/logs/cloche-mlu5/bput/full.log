[2026-03-15T16:10:08Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WFx9iKXvZP5GYBKujKU4QQ","type":"tool_result","content":"     1→package main\n     2→\n     3→import (\n     4→\t\"fmt\"\n     5→\t\"os\"\n     6→\t\"path/filepath\"\n     7→\t\"sort\"\n     8→\t\"strings\"\n     9→\n    10→\t\"github.com/cloche-dev/cloche/internal/config\"\n    11→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    12→\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    13→)\n    14→\n    15→func cmdValidate(args []string) {\n    16→\tvar projectDir, workflowFilter string\n    17→\tfor i := 0; i < len(args); i++ {\n    18→\t\tswitch args[i] {\n    19→\t\tcase \"--project\":\n    20→\t\t\tif i+1 < len(args) {\n    21→\t\t\t\ti++\n    22→\t\t\t\tprojectDir = args[i]\n    23→\t\t\t}\n    24→\t\tcase \"--workflow\":\n    25→\t\t\tif i+1 < len(args) {\n    26→\t\t\t\ti++\n    27→\t\t\t\tworkflowFilter = args[i]\n    28→\t\t\t}\n    29→\t\t}\n    30→\t}\n    31→\n    32→\tif projectDir == \"\" {\n    33→\t\tprojectDir, _ = os.Getwd()\n    34→\t} else {\n    35→\t\tabs, err := filepath.Abs(projectDir)\n    36→\t\tif err == nil {\n    37→\t\t\tprojectDir = abs\n    38→\t\t}\n    39→\t}\n    40→\n    41→\terrs := validateProject(projectDir, workflowFilter)\n    42→\tif len(errs) > 0 {\n    43→\t\tfor _, e := range errs {\n    44→\t\t\tfmt.Fprintln(os.Stderr, e)\n    45→\t\t}\n    46→\t\tos.Exit(1)\n    47→\t}\n    48→\n    49→\tfmt.Println(\"All configuration valid.\")\n    50→}\n    51→\n    52→// validateProject performs all validation checks and returns a list of errors.\n    53→func validateProject(projectDir, workflowFilter string) []string {\n    54→\tclocheDir := filepath.Join(projectDir, \".cloche\")\n    55→\n    56→\tinfo, err := os.Stat(clocheDir)\n    57→\tif err != nil || !info.IsDir() {\n    58→\t\treturn []string{fmt.Sprintf(\"%s: .cloche directory not found\", projectDir)}\n    59→\t}\n    60→\n    61→\tvar errs []string\n    62→\n    63→\t// 1. Validate config.toml\n    64→\tconfigErrs := validateConfig(projectDir)\n    65→\terrs = append(errs, configErrs...)\n    66→\n    67→\t// 2. Parse and validate workflow files\n    68→\tworkflows, parseErrs := parseAllWorkflowFiles(clocheDir)\n    69→\terrs = append(errs, parseErrs...)\n    70→\n    71→\t// Filter to specific workflow if requested\n    72→\tif workflowFilter != \"\" {\n    73→\t\tfiltered := make(map[string]*workflowFileInfo)\n    74→\t\tfor key, wfi := range workflows {\n    75→\t\t\tif wfi.workflow.Name == workflowFilter {\n    76→\t\t\t\tfiltered[key] = wfi\n    77→\t\t\t}\n    78→\t\t}\n    79→\t\tif len(filtered) == 0 {\n    80→\t\t\terrs = append(errs, fmt.Sprintf(\"workflow %q not found\", workflowFilter))\n    81→\t\t\treturn errs\n    82→\t\t}\n    83→\t\tworkflows = filtered\n    84→\t}\n    85→\n    86→\t// Validate each workflow\n    87→\tfor _, wfi := range workflows {\n    88→\t\twfErrs := validateWorkflow(wfi, clocheDir)\n    89→\t\terrs = append(errs, wfErrs...)\n    90→\t}\n    91→\n    92→\t// 3. Cross-file consistency (only when not filtering)\n    93→\tif workflowFilter == \"\" {\n    94→\t\tcrossErrs := validateCrossFile(projectDir, workflows)\n    95→\t\terrs = append(errs, crossErrs...)\n    96→\t}\n    97→\n    98→\treturn errs\n    99→}\n   100→\n   101→type workflowFileInfo struct {\n   102→\tworkflow *domain.Workflow\n   103→\tfile     string // filename relative to .cloche/\n   104→}\n   105→\n   106→// parseAllWorkflowFiles parses all .cloche files and returns workflows keyed by name.\n   107→func parseAllWorkflowFiles(clocheDir string) (map[string]*workflowFileInfo, []string) {\n   108→\tentries, err := filepath.Glob(filepath.Join(clocheDir, \"*.cloche\"))\n   109→\tif err != nil {\n   110→\t\treturn nil, []string{fmt.Sprintf(\"%s: %v\", clocheDir, err)}\n   111→\t}\n   112→\n   113→\tworkflows := make(map[string]*workflowFileInfo)\n   114→\tvar errs []string\n   115→\n   116→\tfor _, path := range entries {\n   117→\t\tdata, err := os.ReadFile(path)\n   118→\t\tif err != nil {\n   119→\t\t\terrs = append(errs, fmt.Sprintf(\"%s: %v\", filepath.Base(path), err))\n   120→\t\t\tcontinue\n   121→\t\t}\n   122→\n   123→\t\twfs, err := dsl.ParseAll(string(data))\n   124→\t\tif err != nil {\n   125→\t\t\terrs = append(errs, fmt.Sprintf(\"%s: %v\", filepath.Base(path), err))\n   126→\t\t\tcontinue\n   127→\t\t}\n   128→\n   129→\t\tfilename := filepath.Base(path)\n   130→\t\tfor name, wf := range wfs {\n   131→\t\t\tif existing, ok := workflows[name]; ok {\n   132→\t\t\t\terrs = append(errs, fmt.Sprintf(\n   133→\t\t\t\t\t\"%s: workflow %q already defined in %s\",\n   134→\t\t\t\t\tfilename, name, existing.file))\n   135→\t\t\t\tcontinue\n   136→\t\t\t}\n   137→\t\t\tworkflows[name] = &workflowFileInfo{workflow: wf, file: filename}\n   138→\t\t}\n   139→\t}\n   140→\n   141→\treturn workflows, errs\n   142→}\n   143→\n   144→// validateConfig checks that config.toml parses and is valid.\n   145→func validateConfig(projectDir string) []string {\n   146→\tconfigPath := filepath.Join(projectDir, \".cloche\", \"config.toml\")\n   147→\tif _, err := os.Stat(configPath); os.IsNotExist(err) {\n   148→\t\t// config.toml is optional — defaults are used\n   149→\t\treturn nil\n   150→\t}\n   151→\n   152→\t_, err := config.Load(projectDir)\n   153→\tif err != nil {\n   154→\t\treturn []string{fmt.Sprintf(\"config.toml: %v\", err)}\n   155→\t}\n   156→\n   157→\treturn nil\n   158→}\n   159→\n   160→// validateWorkflow validates a single workflow's structure.\n   161→func validateWorkflow(wfi *workflowFileInfo, clocheDir string) []string {\n   162→\twf := wfi.workflow\n   163→\tvar errs []string\n   164→\n   165→\t// Run domain validation (entry step, wiring, orphans, output mappings)\n   166→\tif err := wf.Validate(); err != nil {\n   167→\t\terrs = append(errs, fmt.Sprintf(\"%s: %v\", wfi.file, err))\n   168→\t}\n   169→\n   170→\t// Location validation\n   171→\tif err := wf.ValidateLocation(); err != nil {\n   172→\t\terrs = append(errs, fmt.Sprintf(\"%s: %v\", wfi.file, err))\n   173→\t}\n   174→\n   175→\t// Config key warnings (treat as errors for validate command)\n   176→\tfor _, w := range wf.ValidateConfig() {\n   177→\t\terrs = append(errs, fmt.Sprintf(\"%s: %v\", wfi.file, w))\n   178→\t}\n   179→\n   180→\t// Terminal coverage: every path must eventually reach done or abort\n   181→\ttermErrs := validateTerminalCoverage(wf, wfi.file)\n   182→\terrs = append(errs, termErrs...)\n   183→\n   184→\t// Prompt and script file references\n   185→\trefErrs := validateFileReferences(wf, wfi.file, clocheDir)\n   186→\terrs = append(errs, refErrs...)\n   187→\n   188→\treturn errs\n   189→}\n   190→\n   191→// validateTerminalCoverage checks that every path through the workflow reaches done or abort.\n   192→func validateTerminalCoverage(wf *domain.Workflow, filename string) []string {\n   193→\tif wf.EntryStep == \"\" {\n   194→\t\treturn nil // already reported by Validate()\n   195→\t}\n   196→\n   197→\t// Build adjacency: step+result -> list of target steps\n   198→\ttype stepResult struct{ step, result string }\n   199→\tadj := make(map[stepResult][]string)\n   200→\tfor _, wire := range wf.Wiring {\n   201→\t\tsr := stepResult{wire.From, wire.Result}\n   202→\t\tadj[sr] = append(adj[sr], wire.To)\n   203→\t}\n   204→\tfor _, c := range wf.Collects {\n   205→\t\tfor _, cond := range c.Conditions {\n   206→\t\t\tsr := stepResult{cond.Step, cond.Result}\n   207→\t\t\tadj[sr] = append(adj[sr], c.To)\n   208→\t\t}\n   209→\t}\n   210→\n   211→\t// DFS from entry step. A step is \"terminal-safe\" if all its results lead\n   212→\t// (directly or transitively) to done/abort. Track visited to handle cycles.\n   213→\tvar errs []string\n   214→\t// Use memoization: true = reaches terminal, false = doesn't\n   215→\tmemo := make(map[string]*bool)\n   216→\n   217→\tvar reaches func(stepName string, visiting map[string]bool) bool\n   218→\treaches = func(stepName string, visiting map[string]bool) bool {\n   219→\t\tif stepName == domain.StepDone || stepName == domain.StepAbort {\n   220→\t\t\treturn true\n   221→\t\t}\n   222→\t\tif _, ok := wf.Steps[stepName]; !ok {\n   223→\t\t\treturn false\n   224→\t\t}\n   225→\t\tif visiting[stepName] {\n   226→\t\t\t// Cycle — optimistically assume the cycle will exit via\n   227→\t\t\t// another branch. The caller checks all results, so if\n   228→\t\t\t// every branch is a dead-end it will still be caught.\n   229→\t\t\treturn true\n   230→\t\t}\n   231→\t\tif v, ok := memo[stepName]; ok {\n   232→\t\t\treturn *v\n   233→\t\t}\n   234→\n   235→\t\tvisiting[stepName] = true\n   236→\t\tstep := wf.Steps[stepName]\n   237→\t\tallReach := true\n   238→\t\tfor _, result := range step.Results {\n   239→\t\t\tsr := stepResult{stepName, result}\n   240→\t\t\ttargets := adj[sr]\n   241→\t\t\tif len(targets) == 0 {\n   242→\t\t\t\tallReach = false\n   243→\t\t\t\tcontinue\n   244→\t\t\t}\n   245→\t\t\t// At least one target must reach terminal\n   246→\t\t\tanyReach := false\n   247→\t\t\tfor _, t := range targets {\n   248→\t\t\t\tif reaches(t, visiting) {\n   249→\t\t\t\t\tanyReach = true\n   250→\t\t\t\t\tbreak\n   251→\t\t\t\t}\n   252→\t\t\t}\n   253→\t\t\tif !anyReach {\n   254→\t\t\t\tallReach = false\n   255→\t\t\t}\n   256→\t\t}\n   257→\t\tdelete(visiting, stepName)\n   258→\n   259→\t\tmemo[stepName] = &allReach\n   260→\t\treturn allReach\n   261→\t}\n   262→\n   263→\t// Check each step\n   264→\tfor name, step := range wf.Steps {\n   265→\t\tfor _, result := range step.Results {\n   266→\t\t\tsr := stepResult{name, result}\n   267→\t\t\ttargets := adj[sr]\n   268→\t\t\tif len(targets) == 0 {\n   269→\t\t\t\tcontinue // unwired results are caught by Validate()\n   270→\t\t\t}\n   271→\t\t\tanyTerminal := false\n   272→\t\t\tfor _, t := range targets {\n   273→\t\t\t\tif reaches(t, make(map[string]bool)) {\n   274→\t\t\t\t\tanyTerminal = true\n   275→\t\t\t\t\tbreak\n   276→\t\t\t\t}\n   277→\t\t\t}\n   278→\t\t\tif !anyTerminal {\n   279→\t\t\t\terrs = append(errs, fmt.Sprintf(\n   280→\t\t\t\t\t\"%s: workflow %q: step %q result %q does not reach a terminal (done/abort)\",\n   281→\t\t\t\t\tfilename, wf.Name, name, result))\n   282→\t\t\t}\n   283→\t\t}\n   284→\t}\n   285→\n   286→\treturn errs\n   287→}\n   288→\n   289→// validateFileReferences checks that prompt file() and script run references exist.\n   290→func validateFileReferences(wf *domain.Workflow, filename, clocheDir string) []string {\n   291→\tvar errs []string\n   292→\n   293→\tfor _, step := range wf.Steps {\n   294→\t\t// Check prompt file references: file(\"prompts/foo.md\")\n   295→\t\tif promptVal, ok := step.Config[\"prompt\"]; ok {\n   296→\t\t\tif ref := extractFileRef(promptVal); ref != \"\" {\n   297→\t\t\t\tpath := filepath.Join(filepath.Dir(clocheDir), ref)\n   298→\t\t\t\tif _, err := os.Stat(path); os.IsNotExist(err) {\n   299→\t\t\t\t\terrs = append(errs, fmt.Sprintf(\n   300→\t\t\t\t\t\t\"%s: workflow %q: step %q references missing file %q\",\n   301→\t\t\t\t\t\tfilename, wf.Name, step.Name, ref))\n   302→\t\t\t\t}\n   303→\t\t\t}\n   304→\t\t}\n   305→\n   306→\t\t// Check script run references that point to .cloche/scripts/\n   307→\t\tif runVal, ok := step.Config[\"run\"]; ok {\n   308→\t\t\tscriptRef := extractScriptRef(runVal)\n   309→\t\t\tif scriptRef != \"\" {\n   310→\t\t\t\tpath := filepath.Join(filepath.Dir(clocheDir), scriptRef)\n   311→\t\t\t\tif _, err := os.Stat(path); os.IsNotExist(err) {\n   312→\t\t\t\t\terrs = append(errs, fmt.Sprintf(\n   313→\t\t\t\t\t\t\"%s: workflow %q: step %q references missing script %q\",\n   314→\t\t\t\t\t\tfilename, wf.Name, step.Name, scriptRef))\n   315→\t\t\t\t}\n   316→\t\t\t}\n   317→\t\t}\n   318→\t}\n   319→\n   320→\treturn errs\n   321→}\n   322→\n   323→// extractFileRef extracts the path from file(\"path\") syntax.\n   324→func extractFileRef(val string) string {\n   325→\tif !strings.HasPrefix(val, `file(\"`) || !strings.HasSuffix(val, `\")`) {\n   326→\t\treturn \"\"\n   327→\t}\n   328→\treturn val[6 : len(val)-2]\n   329→}\n   330→\n   331→// extractScriptRef extracts .cloche/scripts/ references from run commands.\n   332→// Returns the relative path if the run value references a .cloche/scripts/ file.\n   333→func extractScriptRef(val string) string {\n   334→\t// Look for .cloche/scripts/ references in the run command\n   335→\t// Common patterns: \"bash .cloche/scripts/foo.sh\" or \".cloche/scripts/foo.sh\"\n   336→\tparts := strings.Fields(val)\n   337→\tfor _, part := range parts {\n   338→\t\tif strings.HasPrefix(part, \".cloche/scripts/\") {\n   339→\t\t\treturn part\n   340→\t\t}\n   341→\t}\n   342→\treturn \"\"\n   343→}\n   344→\n   345→// validateCrossFile checks that workflows referenced in config exist as files and vice versa.\n   346→func validateCrossFile(projectDir string, workflows map[string]*workflowFileInfo) []string {\n   347→\tconfigPath := filepath.Join(projectDir, \".cloche\", \"config.toml\")\n   348→\tif _, err := os.Stat(configPath); os.IsNotExist(err) {\n   349→\t\treturn nil\n   350→\t}\n   351→\n   352→\t// Check that workflow steps (workflow_name references) point to existing workflows\n   353→\tvar errs []string\n   354→\tworkflowNames := make(map[string]bool)\n   355→\tfor name := range workflows {\n   356→\t\tworkflowNames[name] = true\n   357→\t}\n   358→\n   359→\tfor _, wfi := range workflows {\n   360→\t\tfor _, step := range wfi.workflow.Steps {\n   361→\t\t\tif step.Type == domain.StepTypeWorkflow {\n   362→\t\t\t\trefName := step.Config[\"workflow_name\"]\n   363→\t\t\t\tif refName != \"\" && !workflowNames[refName] {\n   364→\t\t\t\t\terrs = append(errs, fmt.Sprintf(\n   365→\t\t\t\t\t\t\"%s: workflow %q: step %q references undefined workflow %q\",\n   366→\t\t\t\t\t\twfi.file, wfi.workflow.Name, step.Name, refName))\n   367→\t\t\t\t}\n   368→\t\t\t}\n   369→\t\t}\n   370→\t}\n   371→\n   372→\t// Sort errors for deterministic output\n   373→\tsort.Strings(errs)\n   374→\n   375→\treturn errs\n   376→}\n   377→"}]},"parent_tool_use_id":"toolu_01RaQEpV8ZTHF3ytoF87jLqo","session_id":"3f893b55-0a2f-43ca-bb1e-728ad031de5b","uuid":"6653f2cf-fd2a-4726-b2ca-41eb39fb4588"}
