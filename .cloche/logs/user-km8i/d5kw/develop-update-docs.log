{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Ns92Tnt6fXJtE7hbboZKNd","type":"tool_result","content":"     1→{{define \"content\"}}\n     2→<h1>\n     3→    <a href=\"/runs\">Runs</a> /\n     4→    {{if .ParentRun}}<a href=\"/runs/{{.ParentRun.ID}}\" class=\"parent-run-link\">{{.ParentRun.ID}}</a> / {{end}}\n     5→    {{.Run.ID}}\n     6→    <span class=\"badge badge-{{stateColor .Run.State}}\">{{.Run.State}}</span>\n     7→    {{if or (eq .Run.State \"pending\") (eq .Run.State \"running\")}}\n     8→    <button class=\"btn btn-danger btn-sm\" id=\"cancel-run-btn\" onclick=\"cancelRun('{{.Run.ID}}')\" style=\"margin-left:0.5rem;\">Cancel</button>\n     9→    {{end}}\n    10→</h1>\n    11→\n    12→<div class=\"run-meta\">\n    13→    <dl>\n    14→        {{if .Run.Title}}<dt>Title</dt><dd>{{.Run.Title}}</dd>{{end}}\n    15→        {{if .ParentRun}}<dt>Parent Run</dt><dd><a href=\"/runs/{{.ParentRun.ID}}\">{{.ParentRun.ID}}</a> <span class=\"badge badge-{{stateColor .ParentRun.State}}\">{{.ParentRun.State}}</span></dd>{{end}}\n    16→        <dt>Workflow</dt><dd>{{.Run.WorkflowName}}</dd>\n    17→        <dt>Type</dt><dd>{{if .Run.IsHost}}host{{else}}container{{end}}</dd>\n    18→        <dt>Started</dt><dd>{{formatTime .Run.StartedAt}}</dd>\n    19→        <dt>Completed</dt><dd>{{formatTime .Run.CompletedAt}}</dd>\n    20→        <dt>Container</dt><dd class=\"mono\">{{.Run.ContainerID}}</dd>\n    21→        <dt>Container Status</dt>\n    22→        <dd id=\"container-status\">\n    23→            {{if eq .ContainerState \"running\"}}\n    24→                <span class=\"badge badge-running\">Container running</span>\n    25→            {{else if eq .ContainerState \"stopped\"}}\n    26→                <span class=\"badge badge-stopped\">Container stopped</span>\n    27→                {{if or (eq .Run.State \"succeeded\") (eq .Run.State \"failed\") (eq .Run.State \"cancelled\")}}\n    28→                <button class=\"btn btn-danger btn-sm\" id=\"delete-container-btn\" onclick=\"deleteContainer('{{.Run.ID}}')\">Delete Container</button>\n    29→                {{end}}\n    30→            {{else if eq .ContainerState \"available\"}}\n    31→                <span class=\"badge badge-succeeded\">Container available</span>\n    32→                <button class=\"btn btn-danger btn-sm\" id=\"delete-container-btn\" onclick=\"deleteContainer('{{.Run.ID}}')\">Delete Container</button>\n    33→            {{else}}\n    34→                <span class=\"badge badge-pending\">Container removed</span>\n    35→            {{end}}\n    36→        </dd>\n    37→    </dl>\n    38→</div>\n    39→\n    40→{{if .Run.ErrorMessage}}\n    41→<div class=\"error-box\">{{.Run.ErrorMessage}}</div>\n    42→{{end}}\n    43→\n    44→{{if .ChildRuns}}\n    45→<h2>Child Runs</h2>\n    46→<table class=\"runs-table\">\n    47→    <thead>\n    48→        <tr>\n    49→            <th>Run ID</th>\n    50→            <th>Title</th>\n    51→            <th>Workflow</th>\n    52→            <th>State</th>\n    53→            <th>Started</th>\n    54→            <th>Completed</th>\n    55→        </tr>\n    56→    </thead>\n    57→    <tbody>\n    58→        {{range .ChildRuns}}\n    59→        <tr>\n    60→            <td><a href=\"/runs/{{.ID}}\">{{.ID}}</a></td>\n    61→            <td>{{truncate .Title 50}}</td>\n    62→            <td>{{.WorkflowName}}</td>\n    63→            <td><span class=\"badge badge-{{stateColor .State}}\">{{.State}}</span></td>\n    64→            <td>{{formatTime .StartedAt}}</td>\n    65→            <td>{{formatTime .CompletedAt}}</td>\n    66→        </tr>\n    67→        {{end}}\n    68→    </tbody>\n    69→</table>\n    70→{{end}}\n    71→\n    72→<h2>Steps</h2>\n    73→<table class=\"runs-table\">\n    74→    <thead>\n    75→        <tr>\n    76→            <th>Step</th>\n    77→            <th>Result</th>\n    78→            <th>Started</th>\n    79→            <th>Duration</th>\n    80→        </tr>\n    81→    </thead>\n    82→    <tbody id=\"steps-body\">\n    83→    {{if .Steps}}\n    84→        {{range .Steps}}\n    85→        <tr class=\"step-row\" data-run-id=\"{{$.Run.ID}}\" data-step=\"{{.StepName}}\" data-index=\"{{.Index}}\">\n    86→            <td>{{.StepName}}</td>\n    87→            <td>{{if .Result}}<span class=\"badge badge-{{if eq .Result \"success\"}}succeeded{{else if eq .Result \"fail\"}}failed{{else}}pending{{end}}\">{{.Result}}</span>{{else}}<span class=\"badge badge-running\">running</span>{{end}}</td>\n    88→            <td>{{formatTime .StartedAt}}</td>\n    89→            <td>{{.Duration}}</td>\n    90→        </tr>\n    91→        <tr class=\"output-row\" id=\"output-{{.Index}}\" style=\"display:none\">\n    92→            <td colspan=\"4\"><pre class=\"step-output\">Loading...</pre></td>\n    93→        </tr>\n    94→        {{end}}\n    95→    {{else}}\n    96→        <tr><td colspan=\"4\" class=\"empty\">No step executions recorded.</td></tr>\n    97→    {{end}}\n    98→    </tbody>\n    99→</table>\n   100→\n   101→<h2>\n   102→    Log\n   103→    <span id=\"log-status\" class=\"badge badge-running\" style=\"font-size:0.7rem; margin-left:0.5rem;\">Live</span>\n   104→</h2>\n   105→<div id=\"log-viewer\" class=\"log-viewer\"><pre id=\"log-content\"></pre></div>\n   106→{{end}}\n   107→\n   108→{{define \"scripts\"}}\n   109→<script>\n   110→(function() {\n   111→    var runState = '{{.Run.State}}';\n   112→    var runID = '{{.Run.ID}}';\n   113→\n   114→    // --- Log Viewer ---\n   115→    var logContent = document.getElementById('log-content');\n   116→    var logViewer = document.getElementById('log-viewer');\n   117→    var logStatus = document.getElementById('log-status');\n   118→    function appendLogLine(line) {\n   119→        var span = document.createElement('span');\n   120→        span.className = 'log-line log-type-' + (line.type || 'script');\n   121→        span.textContent = '[' + line.timestamp + '] [' + line.type + '] ' + line.content + '\\n';\n   122→\n   123→        // Check scroll position BEFORE appending to avoid race conditions\n   124→        // with the scroll event listener approach.\n   125→        var savedScrollTop = logViewer.scrollTop;\n   126→        var atBottom = logViewer.scrollHeight - savedScrollTop - logViewer.clientHeight < 40;\n   127→\n   128→        logContent.appendChild(span);\n   129→\n   130→        if (atBottom) {\n   131→            logViewer.scrollTop = logViewer.scrollHeight;\n   132→        } else {\n   133→            // Restore scroll position in case the DOM mutation shifted it\n   134→            logViewer.scrollTop = savedScrollTop;\n   135→        }\n   136→    }\n   137→\n   138→    function markComplete() {\n   139→        logStatus.textContent = 'Complete';\n   140→        logStatus.className = 'badge badge-succeeded';\n   141→    }\n   142→\n   143→    // Connect to SSE stream\n   144→    var source = new EventSource('/api/runs/' + runID + '/stream');\n   145→    source.onmessage = function(e) {\n   146→        try {\n   147→            var line = JSON.parse(e.data);\n   148→            appendLogLine(line);\n   149→        } catch(err) {}\n   150→    };\n   151→    source.addEventListener('done', function(e) {\n   152→        markComplete();\n   153→        source.close();\n   154→    });\n   155→    source.onerror = function() {\n   156→        markComplete();\n   157→        source.close();\n   158→    };\n   159→\n   160→    // If already complete, mark the badge immediately\n   161→    if (runState === 'succeeded' || runState === 'failed' || runState === 'cancelled') {\n   162→        logStatus.textContent = 'Complete';\n   163→        logStatus.className = 'badge badge-succeeded';\n   164→    }\n   165→\n   166→    // --- Steps Polling (for active runs) ---\n   167→    if (runState !== 'succeeded' && runState !== 'failed' && runState !== 'cancelled') {\n   168→        function poll() {\n   169→            fetch('/api/runs/' + runID)\n   170→                .then(function(r) { return r.json(); })\n   171→                .then(function(data) {\n   172→                    if (data.state !== runState) {\n   173→                        location.reload();\n   174→                        return;\n   175→                    }\n   176→                    // Update container status\n   177→                    var statusEl = document.getElementById('container-status');\n   178→                    if (statusEl && data.container_state) {\n   179→                        var cs = data.container_state;\n   180→                        if (cs === 'running') {\n   181→                            statusEl.innerHTML = '<span class=\"badge badge-running\">Container running</span>';\n   182→                        } else if (cs === 'stopped') {\n   183→                            var stoppedHtml = '<span class=\"badge badge-stopped\">Container stopped</span>';\n   184→                            if (data.state === 'succeeded' || data.state === 'failed' || data.state === 'cancelled') {\n   185→                                stoppedHtml += ' <button class=\"btn btn-danger btn-sm\" id=\"delete-container-btn\" onclick=\"deleteContainer(\\'' + escapeHtml(runID) + '\\')\">Delete Container</button>';\n   186→                            }\n   187→                            statusEl.innerHTML = stoppedHtml;\n   188→                        } else if (cs === 'available') {\n   189→                            statusEl.innerHTML = '<span class=\"badge badge-succeeded\">Container available</span>' +\n   190→                                ' <button class=\"btn btn-danger btn-sm\" id=\"delete-container-btn\" onclick=\"deleteContainer(\\'' + escapeHtml(runID) + '\\')\">Delete Container</button>';\n   191→                        } else {\n   192→                            statusEl.innerHTML = '<span class=\"badge badge-pending\">Container removed</span>';\n   193→                        }\n   194→                    }\n   195→                    var tbody = document.getElementById('steps-body');\n   196→                    if (!data.steps || data.steps.length === 0) {\n   197→                        tbody.innerHTML = '<tr><td colspan=\"4\" class=\"empty\">No step executions recorded.</td></tr>';\n   198→                        return;\n   199→                    }\n   200→\n   201→                    // Capture current accordion state before updating\n   202→                    var openAccordions = {};\n   203→                    var loadedOutputs = {};\n   204→                    var outputRows = tbody.querySelectorAll('.output-row');\n   205→                    for (var j = 0; j < outputRows.length; j++) {\n   206→                        var id = outputRows[j].id;\n   207→                        if (outputRows[j].style.display !== 'none') {\n   208→                            openAccordions[id] = true;\n   209→                        }\n   210→                        var pre = outputRows[j].querySelector('.step-output');\n   211→                        if (pre && pre.textContent !== 'Loading...') {\n   212→                            loadedOutputs[id] = pre.textContent;\n   213→                        }\n   214→                    }\n   215→\n   216→                    // Build updated step rows, preserving accordion state\n   217→                    var html = '';\n   218→                    for (var i = 0; i < data.steps.length; i++) {\n   219→                        var s = data.steps[i];\n   220→                        var badge = '';\n   221→                        if (s.result) {\n   222→                            var cls = s.result === 'success' ? 'succeeded' : s.result === 'fail' ? 'failed' : 'pending';\n   223→                            badge = '<span class=\"badge badge-' + cls + '\">' + escapeHtml(s.result) + '</span>';\n   224→                        } else {\n   225→                            badge = '<span class=\"badge badge-running\">running</span>';\n   226→                        }\n   227→                        var outputId = 'output-' + i;\n   228→                        var isOpen = openAccordions[outputId];\n   229→                        html += '<tr class=\"step-row\" data-run-id=\"' + escapeHtml(runID) + '\" data-step=\"' + escapeHtml(s.step_name) + '\" data-index=\"' + i + '\">' +\n   230→                            '<td>' + escapeHtml(s.step_name) + '</td>' +\n   231→                            '<td>' + badge + '</td>' +\n   232→                            '<td>' + s.started_at + '</td>' +\n   233→                            '<td>' + s.duration + '</td>' +\n   234→                            '</tr>' +\n   235→                            '<tr class=\"output-row\" id=\"' + outputId + '\"' + (isOpen ? '' : ' style=\"display:none\"') + '>' +\n   236→                            '<td colspan=\"4\"><pre class=\"step-output\">Loading...</pre></td>' +\n   237→                            '</tr>';\n   238→                    }\n   239→                    tbody.innerHTML = html;\n   240→\n   241→                    // Restore loaded output content for open accordions\n   242→                    for (var key in loadedOutputs) {\n   243→                        var row = document.getElementById(key);\n   244→                        if (row) {\n   245→                            var pre = row.querySelector('.step-output');\n   246→                            if (pre) {\n   247→                                pre.textContent = loadedOutputs[key];\n   248→                            }\n   249→                        }\n   250→                    }\n   251→\n   252→                    // Re-fetch output for accordions that were open but had no cached content\n   253→                    for (var key in openAccordions) {\n   254→                        if (!loadedOutputs[key]) {\n   255→                            var row = document.getElementById(key);\n   256→                            if (row) {\n   257→                                var stepRow = row.previousElementSibling;\n   258→                                if (stepRow && stepRow.dataset.runId && stepRow.dataset.step) {\n   259→                                    (function(r, rid, sname) {\n   260→                                        var pre = r.querySelector('.step-output');\n   261→                                        fetch('/api/runs/' + rid + '/steps/' + sname + '/output')\n   262→                                            .then(function(resp) {\n   263→                                                if (!resp.ok) return 'No output available.';\n   264→                                                return resp.text();\n   265→                                            })\n   266→                                            .then(function(text) { pre.textContent = text; })\n   267→                                            .catch(function() { pre.textContent = 'Failed to load output.'; });\n   268→                                    })(row, stepRow.dataset.runId, stepRow.dataset.step);\n   269→                                }\n   270→                            }\n   271→                        }\n   272→                    }\n   273→                })\n   274→                .catch(function() {});\n   275→        }\n   276→        setInterval(poll, 2000);\n   277→    }\n   278→\n   279→    function escapeHtml(s) {\n   280→        if (!s) return '';\n   281→        var d = document.createElement('div');\n   282→        d.appendChild(document.createTextNode(s));\n   283→        return d.innerHTML;\n   284→    }\n   285→})();\n   286→\n   287→// Cancel run\n   288→    window.cancelRun = function(runID) {\n   289→        var btn = document.getElementById('cancel-run-btn');\n   290→        if (btn) btn.disabled = true;\n   291→        fetch('/api/runs/' + runID + '/stop', { method: 'POST' })\n   292→            .then(function(r) { return r.json().then(function(d) { return {ok: r.ok, data: d}; }); })\n   293→            .then(function(res) {\n   294→                if (res.ok) {\n   295→                    location.reload();\n   296→                } else {\n   297→                    if (btn) btn.disabled = false;\n   298→                    alert('Failed to cancel run: ' + (res.data.error || 'unknown error'));\n   299→                }\n   300→            })\n   301→            .catch(function() {\n   302→                if (btn) btn.disabled = false;\n   303→                alert('Failed to cancel run');\n   304→            });\n   305→    };\n   306→\n   307→// Delete container\n   308→    window.deleteContainer = function(runID) {\n   309→        var btn = document.getElementById('delete-container-btn');\n   310→        if (btn) btn.disabled = true;\n   311→        fetch('/api/runs/' + runID + '/container', { method: 'DELETE' })\n   312→            .then(function(r) { return r.json().then(function(d) { return {ok: r.ok, data: d}; }); })\n   313→            .then(function(res) {\n   314→                var statusEl = document.getElementById('container-status');\n   315→                if (res.ok) {\n   316→                    statusEl.innerHTML = '<span class=\"badge badge-pending\">Container removed</span>';\n   317→                } else {\n   318→                    if (btn) btn.disabled = false;\n   319→                    alert('Failed to delete container: ' + (res.data.error || 'unknown error'));\n   320→                }\n   321→            })\n   322→            .catch(function() {\n   323→                if (btn) btn.disabled = false;\n   324→                alert('Failed to delete container');\n   325→            });\n   326→    };\n   327→\n   328→    // Toggle step output rows\n   329→document.addEventListener('click', function(e) {\n   330→    var row = e.target.closest('.step-row');\n   331→    if (!row) return;\n   332→    var idx = row.dataset.index;\n   333→    var outputRow = document.getElementById('output-' + idx);\n   334→    if (!outputRow) return;\n   335→\n   336→    if (outputRow.style.display === 'none') {\n   337→        outputRow.style.display = '';\n   338→        var pre = outputRow.querySelector('.step-output');\n   339→        if (pre.textContent === 'Loading...') {\n   340→            var runId = row.dataset.runId;\n   341→            var step = row.dataset.step;\n   342→            fetch('/api/runs/' + runId + '/steps/' + step + '/output')\n   343→                .then(function(r) {\n   344→                    if (!r.ok) return 'No output available.';\n   345→                    return r.text();\n   346→                })\n   347→                .then(function(text) { pre.textContent = text; })\n   348→                .catch(function() { pre.textContent = 'Failed to load output.'; });\n   349→        }\n   350→    } else {\n   351→        outputRow.style.display = 'none';\n   352→    }\n   353→});\n   354→</script>\n   355→{{end}}\n   356→"}]},"parent_tool_use_id":null,"session_id":"4342ccdd-9137-491c-9e5c-6183f7ddbbdd","uuid":"3ac89692-f419-4e51-9a6b-f34c2b6f0bc3","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/web/templates/run_detail.html","content":"{{define \"content\"}}\n<h1>\n    <a href=\"/runs\">Runs</a> /\n    {{if .ParentRun}}<a href=\"/runs/{{.ParentRun.ID}}\" class=\"parent-run-link\">{{.ParentRun.ID}}</a> / {{end}}\n    {{.Run.ID}}\n    <span class=\"badge badge-{{stateColor .Run.State}}\">{{.Run.State}}</span>\n    {{if or (eq .Run.State \"pending\") (eq .Run.State \"running\")}}\n    <button class=\"btn btn-danger btn-sm\" id=\"cancel-run-btn\" onclick=\"cancelRun('{{.Run.ID}}')\" style=\"margin-left:0.5rem;\">Cancel</button>\n    {{end}}\n</h1>\n\n<div class=\"run-meta\">\n    <dl>\n        {{if .Run.Title}}<dt>Title</dt><dd>{{.Run.Title}}</dd>{{end}}\n        {{if .ParentRun}}<dt>Parent Run</dt><dd><a href=\"/runs/{{.ParentRun.ID}}\">{{.ParentRun.ID}}</a> <span class=\"badge badge-{{stateColor .ParentRun.State}}\">{{.ParentRun.State}}</span></dd>{{end}}\n        <dt>Workflow</dt><dd>{{.Run.WorkflowName}}</dd>\n        <dt>Type</dt><dd>{{if .Run.IsHost}}host{{else}}container{{end}}</dd>\n        <dt>Started</dt><dd>{{formatTime .Run.StartedAt}}</dd>\n        <dt>Completed</dt><dd>{{formatTime .Run.CompletedAt}}</dd>\n        <dt>Container</dt><dd class=\"mono\">{{.Run.ContainerID}}</dd>\n        <dt>Container Status</dt>\n        <dd id=\"container-status\">\n            {{if eq .ContainerState \"running\"}}\n                <span class=\"badge badge-running\">Container running</span>\n            {{else if eq .ContainerState \"stopped\"}}\n                <span class=\"badge badge-stopped\">Container stopped</span>\n                {{if or (eq .Run.State \"succeeded\") (eq .Run.State \"failed\") (eq .Run.State \"cancelled\")}}\n                <button class=\"btn btn-danger btn-sm\" id=\"delete-container-btn\" onclick=\"deleteContainer('{{.Run.ID}}')\">Delete Container</button>\n                {{end}}\n            {{else if eq .ContainerState \"available\"}}\n                <span class=\"badge badge-succeeded\">Container available</span>\n                <button class=\"btn btn-danger btn-sm\" id=\"delete-container-btn\" onclick=\"deleteContainer('{{.Run.ID}}')\">Delete Container</button>\n            {{else}}\n                <span class=\"badge badge-pending\">Container removed</span>\n            {{end}}\n        </dd>\n    </dl>\n</div>\n\n{{if .Run.ErrorMessage}}\n<div class=\"error-box\">{{.Run.ErrorMessage}}</div>\n{{end}}\n\n{{if .ChildRuns}}\n<h2>Child Runs</h2>\n<table class=\"runs-table\">\n    <thead>\n        <tr>\n            <th>Run ID</th>\n            <th>Title</th>\n            <th>Workflow</th>\n            <th>State</th>\n            <th>Started</th>\n            <th>Completed</th>\n        </tr>\n    </thead>\n    <tbody>\n        {{range .ChildRuns}}\n        <tr>\n            <td><a href=\"/runs/{{.ID}}\">{{.ID}}</a></td>\n            <td>{{truncate .Title 50}}</td>\n            <td>{{.WorkflowName}}</td>\n            <td><span class=\"badge badge-{{stateColor .State}}\">{{.State}}</span></td>\n            <td>{{formatTime .StartedAt}}</td>\n            <td>{{formatTime .CompletedAt}}</td>\n        </tr>\n        {{end}}\n    </tbody>\n</table>\n{{end}}\n\n<h2>Steps</h2>\n<table class=\"runs-table\">\n    <thead>\n        <tr>\n            <th>Step</th>\n            <th>Result</th>\n            <th>Started</th>\n            <th>Duration</th>\n        </tr>\n    </thead>\n    <tbody id=\"steps-body\">\n    {{if .Steps}}\n        {{range .Steps}}\n        <tr class=\"step-row\" data-run-id=\"{{$.Run.ID}}\" data-step=\"{{.StepName}}\" data-index=\"{{.Index}}\">\n            <td>{{.StepName}}</td>\n            <td>{{if .Result}}<span class=\"badge badge-{{if eq .Result \"success\"}}succeeded{{else if eq .Result \"fail\"}}failed{{else}}pending{{end}}\">{{.Result}}</span>{{else}}<span class=\"badge badge-running\">running</span>{{end}}</td>\n            <td>{{formatTime .StartedAt}}</td>\n            <td>{{.Duration}}</td>\n        </tr>\n        <tr class=\"output-row\" id=\"output-{{.Index}}\" style=\"display:none\">\n            <td colspan=\"4\"><pre class=\"step-output\">Loading...</pre></td>\n        </tr>\n        {{end}}\n    {{else}}\n        <tr><td colspan=\"4\" class=\"empty\">No step executions recorded.</td></tr>\n    {{end}}\n    </tbody>\n</table>\n\n<h2>\n    Log\n    <span id=\"log-status\" class=\"badge badge-running\" style=\"font-size:0.7rem; margin-left:0.5rem;\">Live</span>\n</h2>\n<div id=\"log-viewer\" class=\"log-viewer\"><pre id=\"log-content\"></pre></div>\n{{end}}\n\n{{define \"scripts\"}}\n<script>\n(function() {\n    var runState = '{{.Run.State}}';\n    var runID = '{{.Run.ID}}';\n\n    // --- Log Viewer ---\n    var logContent = document.getElementById('log-content');\n    var logViewer = document.getElementById('log-viewer');\n    var logStatus = document.getElementById('log-status');\n    function appendLogLine(line) {\n        var span = document.createElement('span');\n        span.className = 'log-line log-type-' + (line.type || 'script');\n        span.textContent = '[' + line.timestamp + '] [' + line.type + '] ' + line.content + '\\n';\n\n        // Check scroll position BEFORE appending to avoid race conditions\n        // with the scroll event listener approach.\n        var savedScrollTop = logViewer.scrollTop;\n        var atBottom = logViewer.scrollHeight - savedScrollTop - logViewer.clientHeight < 40;\n\n        logContent.appendChild(span);\n\n        if (atBottom) {\n            logViewer.scrollTop = logViewer.scrollHeight;\n        } else {\n            // Restore scroll position in case the DOM mutation shifted it\n            logViewer.scrollTop = savedScrollTop;\n        }\n    }\n\n    function markComplete() {\n        logStatus.textContent = 'Complete';\n        logStatus.className = 'badge badge-succeeded';\n    }\n\n    // Connect to SSE stream\n    var source = new EventSource('/api/runs/' + runID + '/stream');\n    source.onmessage = function(e) {\n        try {\n            var line = JSON.parse(e.data);\n            appendLogLine(line);\n        } catch(err) {}\n    };\n    source.addEventListener('done', function(e) {\n        markComplete();\n        source.close();\n    });\n    source.onerror = function() {\n        markComplete();\n        source.close();\n    };\n\n    // If already complete, mark the badge immediately\n    if (runState === 'succeeded' || runState === 'failed' || runState === 'cancelled') {\n        logStatus.textContent = 'Complete';\n        logStatus.className = 'badge badge-succeeded';\n    }\n\n    // --- Steps Polling (for active runs) ---\n    if (runState !== 'succeeded' && runState !== 'failed' && runState !== 'cancelled') {\n        function poll() {\n            fetch('/api/runs/' + runID)\n                .then(function(r) { return r.json(); })\n                .then(function(data) {\n                    if (data.state !== runState) {\n                        location.reload();\n                        return;\n                    }\n                    // Update container status\n                    var statusEl = document.getElementById('container-status');\n                    if (statusEl && data.container_state) {\n                        var cs = data.container_state;\n                        if (cs === 'running') {\n                            statusEl.innerHTML = '<span class=\"badge badge-running\">Container running</span>';\n                        } else if (cs === 'stopped') {\n                            var stoppedHtml = '<span class=\"badge badge-stopped\">Container stopped</span>';\n                            if (data.state === 'succeeded' || data.state === 'failed' || data.state === 'cancelled') {\n                                stoppedHtml += ' <button class=\"btn btn-danger btn-sm\" id=\"delete-container-btn\" onclick=\"deleteContainer(\\'' + escapeHtml(runID) + '\\')\">Delete Container</button>';\n                            }\n                            statusEl.innerHTML = stoppedHtml;\n                        } else if (cs === 'available') {\n                            statusEl.innerHTML = '<span class=\"badge badge-succeeded\">Container available</span>' +\n                                ' <button class=\"btn btn-danger btn-sm\" id=\"delete-container-btn\" onclick=\"deleteContainer(\\'' + escapeHtml(runID) + '\\')\">Delete Container</button>';\n                        } else {\n                            statusEl.innerHTML = '<span class=\"badge badge-pending\">Container removed</span>';\n                        }\n                    }\n                    var tbody = document.getElementById('steps-body');\n                    if (!data.steps || data.steps.length === 0) {\n                        tbody.innerHTML = '<tr><td colspan=\"4\" class=\"empty\">No step executions recorded.</td></tr>';\n                        return;\n                    }\n\n                    // Capture current accordion state before updating\n                    var openAccordions = {};\n                    var loadedOutputs = {};\n                    var outputRows = tbody.querySelectorAll('.output-row');\n                    for (var j = 0; j < outputRows.length; j++) {\n                        var id = outputRows[j].id;\n                        if (outputRows[j].style.display !== 'none') {\n                            openAccordions[id] = true;\n                        }\n                        var pre = outputRows[j].querySelector('.step-output');\n                        if (pre && pre.textContent !== 'Loading...') {\n                            loadedOutputs[id] = pre.textContent;\n                        }\n                    }\n\n                    // Build updated step rows, preserving accordion state\n                    var html = '';\n                    for (var i = 0; i < data.steps.length; i++) {\n                        var s = data.steps[i];\n                        var badge = '';\n                        if (s.result) {\n                            var cls = s.result === 'success' ? 'succeeded' : s.result === 'fail' ? 'failed' : 'pending';\n                            badge = '<span class=\"badge badge-' + cls + '\">' + escapeHtml(s.result) + '</span>';\n                        } else {\n                            badge = '<span class=\"badge badge-running\">running</span>';\n                        }\n                        var outputId = 'output-' + i;\n                        var isOpen = openAccordions[outputId];\n                        html += '<tr class=\"step-row\" data-run-id=\"' + escapeHtml(runID) + '\" data-step=\"' + escapeHtml(s.step_name) + '\" data-index=\"' + i + '\">' +\n                            '<td>' + escapeHtml(s.step_name) + '</td>' +\n                            '<td>' + badge + '</td>' +\n                            '<td>' + s.started_at + '</td>' +\n                            '<td>' + s.duration + '</td>' +\n                            '</tr>' +\n                            '<tr class=\"output-row\" id=\"' + outputId + '\"' + (isOpen ? '' : ' style=\"display:none\"') + '>' +\n                            '<td colspan=\"4\"><pre class=\"step-output\">Loading...</pre></td>' +\n                            '</tr>';\n                    }\n                    tbody.innerHTML = html;\n\n                    // Restore loaded output content for open accordions\n                    for (var key in loadedOutputs) {\n                        var row = document.getElementById(key);\n                        if (row) {\n                            var pre = row.querySelector('.step-output');\n                            if (pre) {\n                                pre.textContent = loadedOutputs[key];\n                            }\n                        }\n                    }\n\n                    // Re-fetch output for accordions that were open but had no cached content\n                    for (var key in openAccordions) {\n                        if (!loadedOutputs[key]) {\n                            var row = document.getElementById(key);\n                            if (row) {\n                                var stepRow = row.previousElementSibling;\n                                if (stepRow && stepRow.dataset.runId && stepRow.dataset.step) {\n                                    (function(r, rid, sname) {\n                                        var pre = r.querySelector('.step-output');\n                                        fetch('/api/runs/' + rid + '/steps/' + sname + '/output')\n                                            .then(function(resp) {\n                                                if (!resp.ok) return 'No output available.';\n                                                return resp.text();\n                                            })\n                                            .then(function(text) { pre.textContent = text; })\n                                            .catch(function() { pre.textContent = 'Failed to load output.'; });\n                                    })(row, stepRow.dataset.runId, stepRow.dataset.step);\n                                }\n                            }\n                        }\n                    }\n                })\n                .catch(function() {});\n        }\n        setInterval(poll, 2000);\n    }\n\n    function escapeHtml(s) {\n        if (!s) return '';\n        var d = document.createElement('div');\n        d.appendChild(document.createTextNode(s));\n        return d.innerHTML;\n    }\n})();\n\n// Cancel run\n    window.cancelRun = function(runID) {\n        var btn = document.getElementById('cancel-run-btn');\n        if (btn) btn.disabled = true;\n        fetch('/api/runs/' + runID + '/stop', { method: 'POST' })\n            .then(function(r) { return r.json().then(function(d) { return {ok: r.ok, data: d}; }); })\n            .then(function(res) {\n                if (res.ok) {\n                    location.reload();\n                } else {\n                    if (btn) btn.disabled = false;\n                    alert('Failed to cancel run: ' + (res.data.error || 'unknown error'));\n                }\n            })\n            .catch(function() {\n                if (btn) btn.disabled = false;\n                alert('Failed to cancel run');\n            });\n    };\n\n// Delete container\n    window.deleteContainer = function(runID) {\n        var btn = document.getElementById('delete-container-btn');\n        if (btn) btn.disabled = true;\n        fetch('/api/runs/' + runID + '/container', { method: 'DELETE' })\n            .then(function(r) { return r.json().then(function(d) { return {ok: r.ok, data: d}; }); })\n            .then(function(res) {\n                var statusEl = document.getElementById('container-status');\n                if (res.ok) {\n                    statusEl.innerHTML = '<span class=\"badge badge-pending\">Container removed</span>';\n                } else {\n                    if (btn) btn.disabled = false;\n                    alert('Failed to delete container: ' + (res.data.error || 'unknown error'));\n                }\n            })\n            .catch(function() {\n                if (btn) btn.disabled = false;\n                alert('Failed to delete container');\n            });\n    };\n\n    // Toggle step output rows\ndocument.addEventListener('click', function(e) {\n    var row = e.target.closest('.step-row');\n    if (!row) return;\n    var idx = row.dataset.index;\n    var outputRow = document.getElementById('output-' + idx);\n    if (!outputRow) return;\n\n    if (outputRow.style.display === 'none') {\n        outputRow.style.display = '';\n        var pre = outputRow.querySelector('.step-output');\n        if (pre.textContent === 'Loading...') {\n            var runId = row.dataset.runId;\n            var step = row.dataset.step;\n            fetch('/api/runs/' + runId + '/steps/' + step + '/output')\n                .then(function(r) {\n                    if (!r.ok) return 'No output available.';\n                    return r.text();\n                })\n                .then(function(text) { pre.textContent = text; })\n                .catch(function() { pre.textContent = 'Failed to load output.'; });\n        }\n    } else {\n        outputRow.style.display = 'none';\n    }\n});\n</script>\n{{end}}\n","numLines":356,"startLine":1,"totalLines":356}}}
