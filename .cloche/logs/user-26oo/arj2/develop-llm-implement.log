{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01An4Fua6fLmYfkDhzcyV77n","type":"tool_result","content":"     1→package host\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"log\"\n     6→\t\"sync\"\n     7→\t\"time\"\n     8→\n     9→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    10→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    11→)\n    12→\n    13→const (\n    14→\tdefaultMaxConcurrent = 1\n    15→\tidlePollInterval     = 30 * time.Second\n    16→\tcapacityPollInterval = 5 * time.Second\n    17→)\n    18→\n    19→// LoopConfig holds configuration for an orchestration loop.\n    20→type LoopConfig struct {\n    21→\tProjectDir    string\n    22→\tMaxConcurrent int\n    23→\tStaggerDelay  time.Duration // delay between launching consecutive runs\n    24→}\n    25→\n    26→// Loop manages a continuous orchestration loop for a project, keeping up to\n    27→// MaxConcurrent host workflow runs active at all times when work is available.\n    28→type Loop struct {\n    29→\tconfig     LoopConfig\n    30→\trunner     func(ctx context.Context, projectDir string) (*RunResult, error)\n    31→\tstore      ports.RunStore\n    32→\tstopCh     chan struct{}\n    33→\tmu         sync.Mutex\n    34→\trunning    bool\n    35→}\n    36→\n    37→// NewLoop creates an orchestration loop. The runFn is called to start each\n    38→// orchestration run and should block until the run completes.\n    39→func NewLoop(cfg LoopConfig, store ports.RunStore, runFn func(ctx context.Context, projectDir string) (*RunResult, error)) *Loop {\n    40→\tif cfg.MaxConcurrent <= 0 {\n    41→\t\tcfg.MaxConcurrent = defaultMaxConcurrent\n    42→\t}\n    43→\treturn &Loop{\n    44→\t\tconfig: cfg,\n    45→\t\trunner: runFn,\n    46→\t\tstore:  store,\n    47→\t}\n    48→}\n    49→\n    50→// Start begins the orchestration loop. No-op if already running.\n    51→func (l *Loop) Start() {\n    52→\tl.mu.Lock()\n    53→\tdefer l.mu.Unlock()\n    54→\tif l.running {\n    55→\t\treturn\n    56→\t}\n    57→\tl.running = true\n    58→\tl.stopCh = make(chan struct{})\n    59→\tgo l.run()\n    60→\tlog.Printf(\"orchestration loop: started for %s (max_concurrent=%d, stagger=%s)\", l.config.ProjectDir, l.config.MaxConcurrent, l.config.StaggerDelay)\n    61→}\n    62→\n    63→// Stop signals the loop to stop. Active runs continue to completion.\n    64→func (l *Loop) Stop() {\n    65→\tl.mu.Lock()\n    66→\tdefer l.mu.Unlock()\n    67→\tif !l.running {\n    68→\t\treturn\n    69→\t}\n    70→\tl.running = false\n    71→\tclose(l.stopCh)\n    72→\tlog.Printf(\"orchestration loop: stopped for %s\", l.config.ProjectDir)\n    73→}\n    74→\n    75→// Running returns whether the loop is currently active.\n    76→func (l *Loop) Running() bool {\n    77→\tl.mu.Lock()\n    78→\tdefer l.mu.Unlock()\n    79→\treturn l.running\n    80→}\n    81→\n    82→func (l *Loop) run() {\n    83→\ttype result struct {\n    84→\t\tstate domain.RunState\n    85→\t}\n    86→\n    87→\tcompletions := make(chan result, l.config.MaxConcurrent)\n    88→\tinFlight := 0\n    89→\n    90→\tfor {\n    91→\t\t// Fill up to max concurrent slots.\n    92→\t\tlaunched := 0\n    93→\t\tfor inFlight < l.config.MaxConcurrent {\n    94→\t\t\tselect {\n    95→\t\t\tcase <-l.stopCh:\n    96→\t\t\t\treturn\n    97→\t\t\tdefault:\n    98→\t\t\t}\n    99→\n   100→\t\t\t// Check how many host runs are active for this project (in case of\n   101→\t\t\t// leftover runs from previous loops).\n   102→\t\t\tactive := l.countActiveHostRuns()\n   103→\t\t\tif active >= l.config.MaxConcurrent {\n   104→\t\t\t\tbreak\n   105→\t\t\t}\n   106→\n   107→\t\t\t// Stagger consecutive launches to avoid race conditions on task claiming.\n   108→\t\t\tif launched > 0 && l.config.StaggerDelay > 0 {\n   109→\t\t\t\tif !l.sleep(l.config.StaggerDelay) {\n   110→\t\t\t\t\treturn\n   111→\t\t\t\t}\n   112→\t\t\t}\n   113→\n   114→\t\t\t// Launch a new orchestration run in a goroutine.\n   115→\t\t\tinFlight++\n   116→\t\t\tlaunched++\n   117→\t\t\tgo func() {\n   118→\t\t\t\tres, err := l.runner(context.Background(), l.config.ProjectDir)\n   119→\t\t\t\tif err != nil {\n   120→\t\t\t\t\tlog.Printf(\"orchestration loop: run failed for %s: %v\", l.config.ProjectDir, err)\n   121→\t\t\t\t\tcompletions <- result{state: domain.RunStateFailed}\n   122→\t\t\t\t\treturn\n   123→\t\t\t\t}\n   124→\t\t\t\tcompletions <- result{state: res.State}\n   125→\t\t\t}()\n   126→\t\t}\n   127→\n   128→\t\tif inFlight == 0 {\n   129→\t\t\t// Nothing in flight and at capacity — wait before checking again.\n   130→\t\t\tif !l.sleep(capacityPollInterval) {\n   131→\t\t\t\treturn\n   132→\t\t\t}\n   133→\t\t\tcontinue\n   134→\t\t}\n   135→\n   136→\t\t// Wait for any run to complete.\n   137→\t\tselect {\n   138→\t\tcase r := <-completions:\n   139→\t\t\tinFlight--\n   140→\t\t\tif r.state == domain.RunStateSucceeded {\n   141→\t\t\t\t// Work was done — try to fill slots immediately.\n   142→\t\t\t\tcontinue\n   143→\t\t\t}\n   144→\t\t\t// Run failed or aborted (no tasks available). Back off.\n   145→\t\t\tif !l.sleep(idlePollInterval) {\n   146→\t\t\t\treturn\n   147→\t\t\t}\n   148→\t\tcase <-l.stopCh:\n   149→\t\t\treturn\n   150→\t\t}\n   151→\t}\n   152→}\n   153→\n   154→// countActiveHostRuns counts running or pending host runs for the project.\n   155→func (l *Loop) countActiveHostRuns() int {\n   156→\tctx := context.Background()\n   157→\truns, err := l.store.ListRunsByProject(ctx, l.config.ProjectDir, time.Time{})\n   158→\tif err != nil {\n   159→\t\treturn 0\n   160→\t}\n   161→\tcount := 0\n   162→\tfor _, r := range runs {\n   163→\t\tif r.IsHost && (r.State == domain.RunStatePending || r.State == domain.RunStateRunning) {\n   164→\t\t\tcount++\n   165→\t\t}\n   166→\t}\n   167→\treturn count\n   168→}\n   169→\n   170→// sleep waits for the given duration or until the loop is stopped.\n   171→// Returns false if the loop was stopped.\n   172→func (l *Loop) sleep