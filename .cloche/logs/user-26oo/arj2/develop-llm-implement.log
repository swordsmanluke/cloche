ep's output\n   223→\t_ = os.WriteFile(filepath.Join(outputDir, \"prepare-prompt.out\"), []byte(\"the task prompt\"), 0644)\n   224→\n   225→\tstore := &fakeStore{runs: map[string]*domain.Run{\n   226→\t\t\"develop-test-run\": {\n   227→\t\t\tID:    \"develop-test-run\",\n   228→\t\t\tState: domain.RunStateSucceeded,\n   229→\t\t},\n   230→\t}}\n   231→\n   232→\tdispatcher := &fakeDispatcher{runID: \"develop-test-run\"}\n   233→\n   234→\texecutor := &Executor{\n   235→\t\tProjectDir: tmpDir,\n   236→\t\tDispatcher: dispatcher,\n   237→\t\tStore:      store,\n   238→\t\tOutputDir:  outputDir,\n   239→\t}\n   240→\n   241→\tstep := &domain.Step{\n   242→\t\tName:    \"develop\",\n   243→\t\tType:    domain.StepTypeWorkflow,\n   244→\t\tResults: []string{\"success\", \"fail\"},\n   245→\t\tConfig: map[string]string{\n   246→\t\t\t\"workflow_name\": \"develop\",\n   247→\t\t\t\"prompt_step\":   \"prepare-prompt\",\n   248→\t\t},\n   249→\t}\n   250→\n   251→\tresult, err := executor.Execute(context.Background(), step)\n   252→\trequire.NoError(t, err)\n   253→\tassert.Equal(t, \"success\", result)\n   254→\tassert.Equal(t, \"the task prompt\", dispatcher.calls[0].Prompt)\n   255→}\n   256→\n   257→func TestEngine_HostWorkflow_Linear(t *testing.T) {\n   258→\ttmpDir := t.TempDir()\n   259→\toutputDir := filepath.Join(tmpDir, \"output\")\n   260→\n   261→\tstore := &fakeStore{runs: map[string]*domain.Run{\n   262→\t\t\"develop-test-run\": {\n   263→\t\t\tID:    \"develop-test-run\",\n   264→\t\t\tState: domain.RunStateSucceeded,\n   265→\t\t},\n   266→\t}}\n   267→\n   268→\tdispatcher := &fakeDispatcher{runID: \"develop-test-run\"}\n   269→\n   270→\texecutor := &Executor{\n   271→\t\tProjectDir: tmpDir,\n   272→\t\tDispatcher: dispatcher,\n   273→\t\tStore:      store,\n   274→\t\tOutputDir:  outputDir,\n   275→\t}\n   276→\n   277→\twf := &domain.Workflow{\n   278→\t\tName: \"main\",\n   279→\t\tSteps: map[string]*domain.Step{\n   280→\t\t\t\"prepare\": {\n   281→\t\t\t\tName:    \"prepare\",\n   282→\t\t\t\tType:    domain.StepTypeScript,\n   283→\t\t\t\tResults: []string{\"success\", \"fail\"},\n   284→\t\t\t\tConfig:  map[string]string{\"run\": \"echo 'prepared'\"},\n   285→\t\t\t},\n   286→\t\t\t\"develop\": {\n   287→\t\t\t\tName:    \"develop\",\n   288→\t\t\t\tType:    domain.StepTypeWorkflow,\n   289→\t\t\t\tResults: []string{\"success\", \"fail\"},\n   290→\t\t\t\tConfig:  map[string]string{\"workflow_name\": \"develop\"},\n   291→\t\t\t},\n   292→\t\t\t\"merge\": {\n   293→\t\t\t\tName:    \"merge\",\n   294→\t\t\t\tType:    domain.StepTypeScript,\n   295→\t\t\t\tResults: []string{\"success\", \"fail\"},\n   296→\t\t\t\tConfig:  map[string]string{\"run\": \"echo 'merged'\"},\n   297→\t\t\t},\n   298→\t\t},\n   299→\t\tWiring: []domain.Wire{\n   300→\t\t\t{From: \"prepare\", Result: \"success\", To: \"develop\"},\n   301→\t\t\t{From: \"prepare\", Result: \"fail\", To: domain.StepAbort},\n   302→\t\t\t{From: \"develop\", Result: \"success\", To: \"merge\"},\n   303→\t\t\t{From: \"develop\", Result: \"fail\", To: domain.StepAbort},\n   304→\t\t\t{From: \"merge\", Result: \"success\", To: domain.StepDone},\n   305→\t\t\t{From: \"merge\", Result: \"fail\", To: domain.StepAbort},\n   306→\t\t},\n   307→\t\tEntryStep: \"prepare\",\n   308→\t}\n   309→\n   310→\teng := engine.New(executor)\n   311→\trun, err := eng.Run(context.Background(), wf)\n   312→\trequire.NoError(t, err)\n   313→\tassert.Equal(t, domain.RunStateSucceeded, run.State)\n   314→\tassert.Len(t, dispatcher.calls, 1)\n   315→}\n   316→\n   317→func TestEngine_HostWorkflow_AbortOnScriptFail(t *testing.T) {\n   318→\ttmpDir := t.TempDir()\n   319→\toutputDir := filepath.Join(tmpDir, \"output\")\n   320→\n   321→\texecutor := &Executor{\n   322→\t\tProjectDir: tmpDir,\n   323→\t\tOutputDir:  outputDir,\n   324→\t}\n   325→\n   326→\twf := &domain.Workflow{\n   327→\t\tName: \"main\",\n   328→\t\tSteps: map[string]*domain.Step{\n   329→\t\t\t\"prepare\": {\n   330→\t\t\t\tName:    \"prepare\",\n   331→\t\t\t\tType:    domain.StepTypeScript,\n   332→\t\t\t\tResults: []string{\"success\", \"fail\"},\n   333→\t\t\t\tConfig:  map[string]string{\"run\": \"exit 1\"},\n   334→\t\t\t},\n   335→\t\t\t\"develop\": {\n   336→\t\t\t\tName:    \"develop\",\n   337→\t\t\t\tType:    domain.StepTypeWorkflow,\n   338→\t\t\t\tResults: []string{\"success\", \"fail\"},\n   339→\t\t\t\tConfig:  map[string]string{\"workflow_name\": \"develop\"},\n   340→\t\t\t},\n   341→\t\t},\n   342→\t\tWiring: []domain.Wire{\n   343→\t\t\t{From: \"prepare\", Result: \"success\", To: \"develop\"},\n   344→\t\t\t{From: \"prepare\", Result: \"fail\", To: domain.StepAbort},\n   345→\t\t\t{From: \"develop\", Result: \"success\", To: domain.StepDone},\n   346→\t\t\t{From: \"develop\", Result: \"fail\", To: domain.StepAbort},\n   347→\t\t},\n   348→\t\tEntryStep: \"prepare\",\n   349→\t}\n   350→\n   351→\teng := engine.New(executor)\n   352→\trun, err := eng.Run(context.Background(), wf)\n   353→\trequire.NoError(t, err)\n   354→\tassert.Equal(t, domain.RunStateFailed, run.State)\n   355→}\n   356→\n   357→func TestExecutor_ScriptStep_EnvironmentVars(t *testing.T) {\n   358→\ttmpDir := t.TempDir()\n   359→\toutputDir := filepath.Join(tmpDir, \"output\")\n   360→\n   361→\texecutor := &Executor{\n   362→\t\tProjectDir: tmpDir,\n   363→\t\tOutputDir:  outputDir,\n   364→\t}\n   365→\n   366→\tstep := &domain.Step{\n   367→\t\tName:    \"env-check\",\n   368→\t\tType:    domain.StepTypeScript,\n   369→\t\tResults: []string{\"success\", \"fail\"},\n   370→\t\tConfig:  map[string]string{\"run\": \"echo $CLOCHE_PROJECT_DIR\"},\n   371→\t}\n   372→\n   373→\tresult, err := executor.Execute(context.Background(), step)\n   374→\trequire.NoError(t, err)\n   375→\tassert.Equal(t, \"success\", result)\n   376→\n   377→\tdata, err := os.ReadFile(filepath.Join(outputDir, \"env-check.out\"))\n   378→\trequire.NoError(t, err)\n   379→\tassert.Contains(t, string(data), tmpDir)\n   380→}\n   381→\n   382→func TestExecutor_ScriptStep_NoOutputMappings(t *testing.T) {\n   383→\ttmpDir := t.TempDir()\n   384→\toutputDir := filepath.Join(tmpDir, \"output\")\n   385→\n   386→\texecutor := &Executor{\n   387→\t\tProjectDir: tmpDir,\n   388→\t\tOutputDir:  outputDir,\n   389→\t\tWires: []domain.Wire{\n   390→\t\t\t{From: \"step-a\", Result: \"success\", To: \"step-b\"},\n   391→\t\t},\n   392→\t}\n   393→\n   394→\tstep := &domain.Step{\n   395→\t\tName:    \"step-b\",\n   396→\t\tType:    domain.StepTypeScript,\n   397→\t\tResults: []string{\"success\", \"fail\"},\n   398→\t\tConfig:  map[string]string{\"run\": \"echo hello\"},\n   399→\t}\n   400→\n   401→\tresult, err := executor.Execute(context.Background(), step)\n   402→\trequire.NoError(t, err)\n   403→\tassert.Equal(t, \"success\", result)\n   404→}\n   405→\n   406→func TestExecutor_ScriptStep_OutputMappings_JSONFields(t *testing.T) {\n   407→\ttmpDir := t.TempDir()\n   408→\toutputDir := filepath.Join(tmpDir, \"output\")\n   409→\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n   410→\n   411→\t// Write source step output as JSON\n   412→\tsourceJSON := `{\"title\": \"Fix bug\", \"priority\": \"high\"}`\n   413→\trequire.NoError(t, os.WriteFile(filepath.Join(outputDir, \"get-tasks.out\"), []byte(sourceJSON), 0644))\n   414→\n   415→\texecutor := &Executor{\n   416→\t\tProjectDir: tmpDir,\n   417→\t\tOutputDir:  outputDir,\n   418→\t\tWires: []domain.Wire{\n   419→\t\t\t{\n   420→\t\t\t\tFrom:   \"get-tasks\",\n   421→\t\t\t\tResult: \"success\",\n   422→\t\t\t\tTo:     \"use-tasks\",\n   423→\t\t\t\tOutputMap: []domain.OutputMapping{\n   424→\t\t\t\t\t{\n   425→\t\t\t\t\t\tEnvVar: \"TASK_TITLE\",\n   426→\t\t\t\t\t\tPath:   domain.OutputPath{Segments: []domain.PathSegment{{Kind: domain.SegmentField, Field: \"title\"}}},\n   427→\t\t\t\t\t},\n   428→\t\t\t\t\t{\n   429→\t\t\t\t\t\tEnvVar: \"TASK_PRIORITY\",\n   430→\t\t\t\t\t\tPath:   domain.OutputPath{Segments: []domain.PathSegment{{Kind: domain.SegmentField, Field: \"priority\"}}},\n   431→\t\t\t\t\t},\n   432→\t\t\t\t},\n   433→\t\t\t},\n   434→\t\t},\n   435→\t}\n   436→\n   437→\tstep := &domain.Step{\n   438→\t\tName:    \"use-tasks\",\n   439→\t\tType:    domain.StepTypeScript,\n   440→\t\tResults: []string{\"success\", \"fail\"},\n   441→\t\tConfig:  map[string]string{\"run\": \"echo $TASK_TITLE $TASK_PRIORITY\"},\n   442→\t}\n   443→\n   444→\tresult, err := executor.Execute(context.Background(), step)\n   445→\trequire.NoError(t, err)\n   446→\tassert.Equal(t, \"success\", result)\n   447→\n   448→\tdata, err := os.ReadFile(filepath.Join(outputDir, \"use-tasks.out\"))\n   449→\trequire.NoError(t, err)\n   450→\tassert.Contains(t, string(data), \"Fix bug\")\n   451→\tassert.Contains(t, string(data), \"high\")\n   452→}\n   453→\n   454→func TestExecutor_ScriptStep_OutputMappings_ArrayIndex(t *testing.T) {\n   455→\ttmpDir := t.TempDir()\n   456→\toutputDir := filepath.Join(tmpDir, \"output\")\n   457→\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n   458→\n   459→\t// Write source step output as JSON array\n   460→\tsourceJSON := `[{\"id\": \"task-1\", \"title\": \"First\"}, {\"id\": \"task-2\", \"title\": \"Second\"}]`\n   461→\trequire.NoError(t, os.WriteFile(filepath.Join(outputDir, \"list-tasks.out\"), []byte(sourceJSON), 0644))\n   462→\n   463→\texecutor := &Executor{\n   464→\t\tProjectDir: tmpDir,\n   465→\t\tOutputDir:  outputDir,\n   466→\t\tWires: []domain.Wire{\n   467→\t\t\t{\n   468→\t\t\t\tFrom:   \"list-tasks\",\n   469→\t\t\t\tResult: \"success\",\n   470→\t\t\t\tTo:     \"process\",\n   471→\t\t\t\tOutputMap: []domain.OutputMapping{\n   472→\t\t\t\t\t{\n   473→\t\t\t\t\t\tEnvVar: \"FIRST_ID\",\n   474→\t\t\t\t\t\tPath: domain.OutputPath{Segments: []domain.PathSegment{\n   475→\t\t\t\t\t\t\t{Kind: domain.SegmentIndex, Index: 0},\n   476→\t\t\t\t\t\t\t{Kind: domain.SegmentField, Field: \"id\"},\n   477→\t\t\t\t\t\t}},\n   478→\t\t\t\t\t},\n   479→\t\t\t\t\t{\n   480→\t\t\t\t\t\tEnvVar: \"SECOND_TITLE\",\n   481→\t\t\t\t\t\tPath: domain.OutputPath{Segments: []domain.PathSegment{\n   482→\t\t\t\t\t\t\t{Kind: domain.SegmentIndex, Index: 1},\n   483→\t\t\t\t\t\t\t{Kind: domain.SegmentField, Field: \"title\"},\n   484→\t\t\t\t\t\t}},\n   485→\t\t\t\t\t},\n   486→\t\t\t\t},\n   487→\t\t\t},\n   488→\t\t},\n   489→\t}\n   490→\n   491→\tstep := &domain.Step{\n   492→\t\tName:    \"process\",\n   493→\t\tType:    domain.StepTypeScript,\n   494→\t\tResults: []string{\"success\", \"fail\"},\n   495→\t\tConfig:  map[string]string{\"run\": \"echo $FIRST_ID $SECOND_TITLE\"},\n   496→\t}\n   497→\n   498→\tresult, err := executor.Execute(context.Background(), step)\n   499→\trequire.NoError(t, err)\n   500→\tassert.Equal(t, \"success\", result)\n   501→\n   502→\tdata, err := os.ReadFile(filepath.Join(outputDir, \"process.out\"))\n   503→\trequire.NoError(t, err)\n   504→\tassert.Contains(t, string(data), \"task-1\")\n   505→\tassert.Contains(t, string(data), \"Second\")\n   506→}\n   507→\n   508→func TestExecutor_ScriptStep_OutputMappings_MissingSourceOutput(t *testing.T) {\n   509→\ttmpDir := t.TempDir()\n   510→\toutputDir := filepath.Join(tmpDir, \"output\")\n   511→\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n   512→\n   513→\t// No source output file written\n   514→\n   515→\texecutor := &Executor{\n   516→\t\tProjectDir: tmpDir,\n   517→\t\tOutputDir:  outputDir,\n   518→\t\tWires: []domain.Wire{\n   519→\t\t\t{\n   520→\t\t\t\tFrom:   \"missing-step\",\n   521→\t\t\t\tResult: \"success\",\n   522→\t\t\t\tTo:     \"consumer\",\n   523→\t\t\t\tOutputMap: []domain.OutputMapping{\n   524→\t\t\t\t\t{\n   525→\t\t\t\t\t\tEnvVar: \"VAL\",\n   526→\t\t\t\t\t\tPath:   domain.OutputPath{Segments: []domain.PathSegment{{Kind: domain.SegmentField, Field: \"key\"}}},\n   527→\t\t\t\t\t},\n   528→\t\t\t\t},\n   529→\t\t\t},\n   530→\t\t},\n   531→\t}\n   532→\n   533→\tstep := &domain.Step{\n   534→\t\tName:    \"consumer\",\n   535→\t\tType:    domain.StepTypeScript,\n   536→\t\tResults: []string{\"success\", \"fail\"},\n   537→\t\tConfig:  map[string]string{\"run\": \"echo hello\"},\n   538→\t}\n   539→\n   540→\t_, err := executor.Execute(context.Background(), step)\n   541→\trequire.Error(t, err)\n   542→\tassert.Contains(t, err.Error(), \"reading output of missing-step\")\n   543→}\n   544→\n   545→func TestExecutor_ScriptStep_OutputMappings_NotJSON(t *testing.T) {\n   546→\ttmpDir := t.TempDir()\n   547→\toutputDir := filepath.Join(tmpDir, \"output\")\n   548→\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n   549→\n   550→\t// Write non-JSON output\n   551→\trequire.NoError(t, os.WriteFile(filepath.Join(outputDir, \"plain.out\"), []byte(\"not json\"), 0644))\n   552→\n   553→\texecutor := &Executor{\n   554→\t\tProjectDir: tmpDir,\n   555→\t\tOutputDir:  outputDir,\n   556→\t\tWires: []domain.Wire{\n   557→\t\t\t{\n   558→\t\t\t\tFrom:   \"plain\",\n   559→\t\t\t\tResult: \"success\",\n   560→\t\t\t\tTo:     \"consumer\",\n   561→\t\t\t\tOutputMap: []domain.OutputMapping{\n   562→\t\t\t\t\t{\n   563→\t\t\t\t\t\tEnvVar: \"VAL\",\n   564→\t\t\t\t\t\tPath:   domain.OutputPath{Segments: []domain.PathSegment{{Kind: domain.SegmentField, Field: \"key\"}}},\n   565→\t\t\t\t\t},\n   566→\t\t\t\t},\n   567→\t\t\t},\n   568→\t\t},\n   569→\t}\n   570→\n   571→\tstep := &domain.Step{\n   572→\t\tName:    \"consumer\",\n   573→\t\tType:    domain.StepTypeScript,\n   574→\t\tResults: []string{\"success\", \"fail\"},\n   575→\t\tConfig:  map[string]string{\"run\": \"echo hello\"},\n   576→\t}\n   577→\n   578→\t_, err := executor.Execute(context.Background(), step)\n   579→\trequire.Error(t, err)\n   580→\tassert.Contains(t, err.Error(), \"not valid JSON\")\n   581→}\n   582→\n   583→func TestRunner_RunWithID(t *testing.T) {\n   584→\ttmpDir := t.TempDir()\n   585→\n   586→\t// Write a simple host.cloche\n   587→\tclocheDir := filepath.Join(tmpDir, \".cloche\")\n   588→\trequire.NoError(t, os.MkdirAll(clocheDir, 0755))\n   589→\thostCloche := `workflow \"main\" {\n   590→  step greet {\n   591→    run     = \"echo hi\"\n   592→    results = [success, fail]\n   593→  }\n   594→\n   595→  greet:success -> done\n   596→  greet:fail    -> abort\n   597→}`\n   598→\trequire.NoError(t, os.WriteFile(filepath.Join(clocheDir, \"host.cloche\"), []byte(hostCloche), 0644))\n   599→\n   600→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   601→\n   602→\trunner := &Runner{\n   603→\t\tDispatcher: &fakeDispatcher{runID: \"test-run\"},\n   604→\t\tStore:      store,\n   605→\t}\n   606→\n   607→\tcustomID := \"my-custom-run-id\"\n   608→\tresult, err := runner.RunWithID(context.Background(), tmpDir, customID)\n   609→\trequire.NoError(t, err)\n   610→\tassert.Equal(t, domain.RunStateSucceeded, result.State)\n   611→\tassert.Equal(t, customID, result.RunID, \"RunWithID should use the provided ID\")\n   612→\n   613→\t// Verify the run was persisted with the custom ID\n   614→\thostRun, err := store.GetRun(context.Background(), customID)\n   615→\trequire.NoError(t, err)\n   616→\tassert.True(t, hostRun.IsHost)\n   617→\tassert.Equal(t, domain.RunStateSucceeded, hostRun.State)\n   618→}\n   619→\n   620→func TestRunner_PersistsHostRun(t *testing.T) {\n   621→\ttmpDir := t.TempDir()\n   622→\n   623→\t// Write a simple host.cloche\n   624→\tclocheDir := filepath.Join(tmpDir, \".cloche\")\n   625→\trequire.NoError(t, os.MkdirAll(clocheDir, 0755))\n   626→\thostCloche := `workflow \"main\" {\n   627→  step prepare {\n   628→    run     = \"echo prepared\"\n   629→    results = [success, fail]\n   630→  }\n   631→\n   632→  prepare:success -> done\n   633→  prepare:fail    -> abort\n   634→}`\n   635→\trequire.NoError(t, os.WriteFile(filepath.Join(clocheDir, \"host.cloche\"), []byte(hostCloche), 0644))\n   636→\n   637→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   638→\n   639→\trunner := &Runner{\n   640→\t\tDispatcher: &fakeDispatcher{runID: \"test-run\"},\n   641→\t\tStore:      store,\n   642→\t}\n   643→\n   644→\tresult, err := runner.Run(context.Background(), tmpDir)\n   645→\trequire.NoError(t, err)\n   646→\tassert.Equal(t, domain.RunStateSucceeded, result.State)\n   647→\tassert.NotEmpty(t, result.RunID)\n   648→\n   649→\t// Verify the host run was persisted in the store\n   650→\thostRun, err := store.GetRun(context.Background(), result.RunID)\n   651→\trequire.NoError(t, err)\n   652→\tassert.True(t, hostRun.IsHost, \"host run should have IsHost=true\")\n   653→\tassert.Equal(t, tmpDir, hostRun.ProjectDir)\n   654→\tassert.Equal(t, domain.RunStateSucceeded, hostRun.State)\n   655→\tassert.False(t, hostRun.StartedAt.IsZero())\n   656→\tassert.False(t, hostRun.CompletedAt.IsZero())\n   657→}\n   658→\n   659→func TestRunner_PersistsHostRunOnFailure(t *testing.T) {\n   660→\ttmpDir := t.TempDir()\n   661→\n   662→\t// Write a host.cloche that will fail\n   663→\tclocheDir := filepath.Join(tmpDir, \".cloche\")\n   664→\trequire.NoError(t, os.MkdirAll(clocheDir, 0755))\n   665→\thostCloche := `workflow \"main\" {\n   666→  step bad {\n   667→    run     = \"exit 1\"\n   668→    results = [success, fail]\n   669→  }\n   670→\n   671→  bad:success -> done\n   672→  bad:fail    -> abort\n   673→}`\n   674→\trequire.NoError(t, os.WriteFile(filepath.Join(clocheDir, \"host.cloche\"), []byte(hostCloche), 0644))\n   675→\n   676→\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n   677→\n   678→\trunner := &Runner{\n   679→\t\tDispatcher: &fakeDispatcher{runID: \"test-run\"},\n   680→\t\tStore:      store,\n   681→\t}\n   682→\n   683→\tresult, err := runner.Run(context.Background(), tmpDir)\n   684→\trequire.NoError(t, err)\n   685→\tassert.Equal(t, domain.RunStateFailed, result.State)\n   686→\n   687→\t// Verify the host run was persisted with failed state\n   688→\thostRun, err := store.GetRun(context.Background(), result.RunID)\n   689→\trequire.NoError(t, err)\n   690→\tassert.True(t, hostRun.IsHost)\n   691→\tassert.Equal(t, domain.RunStateFailed, hostRun.State)\n   692→\tassert.False(t, hostRun.CompletedAt.IsZero())\n   693→}\n   694→"}]},"parent_tool_use_id":null,"session_id":"86005800-dc4f-4a50-b6ae-f82ea613cda8","uuid":"0c7d341e-f100-4eae-bfcb-2ea0fc9c397f","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/host/executor_test.go","content":"package host\n\nimport (\n\t\"context\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"testing\"\n\t\"time\"\n\n\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/engine\"\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n)\n\n// fakeDispatcher records dispatch calls and returns a predetermined run ID.\ntype fakeDispatcher struct {\n\tcalls     []*pb.RunWorkflowRequest\n\trunID     string\n\treturnErr error\n}\n\nfunc (f *fakeDispatcher) RunWorkflow(_ context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error) {\n\tf.calls = append(f.calls, req)\n\tif f.returnErr != nil {\n\t\treturn nil, f.returnErr\n\t}\n\treturn &pb.RunWorkflowResponse{RunId: f.runID}, nil\n}\n\n// fakeStore returns a predetermined run on GetRun.\ntype fakeStore struct {\n\truns map[string]*domain.Run\n}\n\nfunc (f *fakeStore) CreateRun(_ context.Context, run *domain.Run) error {\n\tf.runs[run.ID] = run\n\treturn nil\n}\nfunc (f *fakeStore) GetRun(_ context.Context, id string) (*domain.Run, error) {\n\tif r, ok := f.runs[id]; ok {\n\t\treturn r, nil\n\t}\n\treturn nil, os.ErrNotExist\n}\nfunc (f *fakeStore) UpdateRun(_ context.Context, run *domain.Run) error {\n\tf.runs[run.ID] = run\n\treturn nil\n}\nfunc (f *fakeStore) DeleteRun(_ context.Context, id string) error {\n\tdelete(f.runs, id)\n\treturn nil\n}\nfunc (f *fakeStore) ListRuns(_ context.Context, _ time.Time) ([]*domain.Run, error) {\n\treturn nil, nil\n}\nfunc (f *fakeStore) ListRunsByProject(_ context.Context, _ string, _ time.Time) ([]*domain.Run, error) {\n\treturn nil, nil\n}\nfunc (f *fakeStore) ListProjects(_ context.Context) ([]string, error) {\n\treturn nil, nil\n}\nfunc (f *fakeStore) ListChildRuns(_ context.Context, parentRunID string) ([]*domain.Run, error) {\n\tvar children []*domain.Run\n\tfor _, r := range f.runs {\n\t\tif r.ParentRunID == parentRunID {\n\t\t\tchildren = append(children, r)\n\t\t}\n\t}\n\treturn children, nil\n}\n\nfunc TestExecutor_ScriptStep_Success(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tOutputDir:  outputDir,\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"greet\",\n\t\tType:    domain.StepTypeScript,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"run\": \"echo hello\"},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"success\", result)\n\n\t// Check output was written\n\tdata, err := os.ReadFile(filepath.Join(outputDir, \"greet.out\"))\n\trequire.NoError(t, err)\n\tassert.Contains(t, string(data), \"hello\")\n}\n\nfunc TestExecutor_ScriptStep_Failure(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tOutputDir:  outputDir,\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"bad\",\n\t\tType:    domain.StepTypeScript,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"run\": \"exit 1\"},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"fail\", result)\n}\n\nfunc TestExecutor_ScriptStep_ResultMarker(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tOutputDir:  outputDir,\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"marker\",\n\t\tType:    domain.StepTypeScript,\n\t\tResults: []string{\"success\", \"fail\", \"custom\"},\n\t\tConfig:  map[string]string{\"run\": \"echo 'some output'; echo 'CLOCHE_RESULT:custom'\"},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"custom\", result)\n\n\t// Marker line should be stripped from output\n\tdata, err := os.ReadFile(filepath.Join(outputDir, \"marker.out\"))\n\trequire.NoError(t, err)\n\tassert.NotContains(t, string(data), \"CLOCHE_RESULT\")\n\tassert.Contains(t, string(data), \"some output\")\n}\n\nfunc TestExecutor_WorkflowStep_Success(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\t_ = os.MkdirAll(outputDir, 0755)\n\n\tstore := &fakeStore{runs: map[string]*domain.Run{\n\t\t\"develop-test-run\": {\n\t\t\tID:    \"develop-test-run\",\n\t\t\tState: domain.RunStateSucceeded,\n\t\t},\n\t}}\n\n\tdispatcher := &fakeDispatcher{runID: \"develop-test-run\"}\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tDispatcher: dispatcher,\n\t\tStore:      store,\n\t\tOutputDir:  outputDir,\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"develop\",\n\t\tType:    domain.StepTypeWorkflow,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"workflow_name\": \"develop\"},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"success\", result)\n\tassert.Len(t, dispatcher.calls, 1)\n\tassert.Equal(t, \"develop\", dispatcher.calls[0].WorkflowName)\n\tassert.Equal(t, tmpDir, dispatcher.calls[0].ProjectDir)\n}\n\nfunc TestExecutor_WorkflowStep_Failure(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\t_ = os.MkdirAll(outputDir, 0755)\n\n\tstore := &fakeStore{runs: map[string]*domain.Run{\n\t\t\"develop-test-run\": {\n\t\t\tID:    \"develop-test-run\",\n\t\t\tState: domain.RunStateFailed,\n\t\t},\n\t}}\n\n\tdispatcher := &fakeDispatcher{runID: \"develop-test-run\"}\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tDispatcher: dispatcher,\n\t\tStore:      store,\n\t\tOutputDir:  outputDir,\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"develop\",\n\t\tType:    domain.StepTypeWorkflow,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"workflow_name\": \"develop\"},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"fail\", result)\n}\n\nfunc TestExecutor_WorkflowStep_PassesPrompt(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\t_ = os.MkdirAll(outputDir, 0755)\n\n\t// Write a previous step's output\n\t_ = os.WriteFile(filepath.Join(outputDir, \"prepare-prompt.out\"), []byte(\"the task prompt\"), 0644)\n\n\tstore := &fakeStore{runs: map[string]*domain.Run{\n\t\t\"develop-test-run\": {\n\t\t\tID:    \"develop-test-run\",\n\t\t\tState: domain.RunStateSucceeded,\n\t\t},\n\t}}\n\n\tdispatcher := &fakeDispatcher{runID: \"develop-test-run\"}\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tDispatcher: dispatcher,\n\t\tStore:      store,\n\t\tOutputDir:  outputDir,\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"develop\",\n\t\tType:    domain.StepTypeWorkflow,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig: map[string]string{\n\t\t\t\"workflow_name\": \"develop\",\n\t\t\t\"prompt_step\":   \"prepare-prompt\",\n\t\t},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"success\", result)\n\tassert.Equal(t, \"the task prompt\", dispatcher.calls[0].Prompt)\n}\n\nfunc TestEngine_HostWorkflow_Linear(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\n\tstore := &fakeStore{runs: map[string]*domain.Run{\n\t\t\"develop-test-run\": {\n\t\t\tID:    \"develop-test-run\",\n\t\t\tState: domain.RunStateSucceeded,\n\t\t},\n\t}}\n\n\tdispatcher := &fakeDispatcher{runID: \"develop-test-run\"}\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tDispatcher: dispatcher,\n\t\tStore:      store,\n\t\tOutputDir:  outputDir,\n\t}\n\n\twf := &domain.Workflow{\n\t\tName: \"main\",\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"prepare\": {\n\t\t\t\tName:    \"prepare\",\n\t\t\t\tType:    domain.StepTypeScript,\n\t\t\t\tResults: []string{\"success\", \"fail\"},\n\t\t\t\tConfig:  map[string]string{\"run\": \"echo 'prepared'\"},\n\t\t\t},\n\t\t\t\"develop\": {\n\t\t\t\tName:    \"develop\",\n\t\t\t\tType:    domain.StepTypeWorkflow,\n\t\t\t\tResults: []string{\"success\", \"fail\"},\n\t\t\t\tConfig:  map[string]string{\"workflow_name\": \"develop\"},\n\t\t\t},\n\t\t\t\"merge\": {\n\t\t\t\tName:    \"merge\",\n\t\t\t\tType:    domain.StepTypeScript,\n\t\t\t\tResults: []string{\"success\", \"fail\"},\n\t\t\t\tConfig:  map[string]string{\"run\": \"echo 'merged'\"},\n\t\t\t},\n\t\t},\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"prepare\", Result: \"success\", To: \"develop\"},\n\t\t\t{From: \"prepare\", Result: \"fail\", To: domain.StepAbort},\n\t\t\t{From: \"develop\", Result: \"success\", To: \"merge\"},\n\t\t\t{From: \"develop\", Result: \"fail\", To: domain.StepAbort},\n\t\t\t{From: \"merge\", Result: \"success\", To: domain.StepDone},\n\t\t\t{From: \"merge\", Result: \"fail\", To: domain.StepAbort},\n\t\t},\n\t\tEntryStep: \"prepare\",\n\t}\n\n\teng := engine.New(executor)\n\trun, err := eng.Run(context.Background(), wf)\n\trequire.NoError(t, err)\n\tassert.Equal(t, domain.RunStateSucceeded, run.State)\n\tassert.Len(t, dispatcher.calls, 1)\n}\n\nfunc TestEngine_HostWorkflow_AbortOnScriptFail(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tOutputDir:  outputDir,\n\t}\n\n\twf := &domain.Workflow{\n\t\tName: \"main\",\n\t\tSteps: map[string]*domain.Step{\n\t\t\t\"prepare\": {\n\t\t\t\tName:    \"prepare\",\n\t\t\t\tType:    domain.StepTypeScript,\n\t\t\t\tResults: []string{\"success\", \"fail\"},\n\t\t\t\tConfig:  map[string]string{\"run\": \"exit 1\"},\n\t\t\t},\n\t\t\t\"develop\": {\n\t\t\t\tName:    \"develop\",\n\t\t\t\tType:    domain.StepTypeWorkflow,\n\t\t\t\tResults: []string{\"success\", \"fail\"},\n\t\t\t\tConfig:  map[string]string{\"workflow_name\": \"develop\"},\n\t\t\t},\n\t\t},\n\t\tWiring: []domain.Wire{\n\t\t\t{From: \"prepare\", Result: \"success\", To: \"develop\"},\n\t\t\t{From: \"prepare\", Result: \"fail\", To: domain.StepAbort},\n\t\t\t{From: \"develop\", Result: \"success\", To: domain.StepDone},\n\t\t\t{From: \"develop\", Result: \"fail\", To: domain.StepAbort},\n\t\t},\n\t\tEntryStep: \"prepare\",\n\t}\n\n\teng := engine.New(executor)\n\trun, err := eng.Run(context.Background(), wf)\n\trequire.NoError(t, err)\n\tassert.Equal(t, domain.RunStateFailed, run.State)\n}\n\nfunc TestExecutor_ScriptStep_EnvironmentVars(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tOutputDir:  outputDir,\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"env-check\",\n\t\tType:    domain.StepTypeScript,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"run\": \"echo $CLOCHE_PROJECT_DIR\"},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"success\", result)\n\n\tdata, err := os.ReadFile(filepath.Join(outputDir, \"env-check.out\"))\n\trequire.NoError(t, err)\n\tassert.Contains(t, string(data), tmpDir)\n}\n\nfunc TestExecutor_ScriptStep_NoOutputMappings(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tOutputDir:  outputDir,\n\t\tWires: []domain.Wire{\n\t\t\t{From: \"step-a\", Result: \"success\", To: \"step-b\"},\n\t\t},\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"step-b\",\n\t\tType:    domain.StepTypeScript,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"run\": \"echo hello\"},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"success\", result)\n}\n\nfunc TestExecutor_ScriptStep_OutputMappings_JSONFields(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n\n\t// Write source step output as JSON\n\tsourceJSON := `{\"title\": \"Fix bug\", \"priority\": \"high\"}`\n\trequire.NoError(t, os.WriteFile(filepath.Join(outputDir, \"get-tasks.out\"), []byte(sourceJSON), 0644))\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tOutputDir:  outputDir,\n\t\tWires: []domain.Wire{\n\t\t\t{\n\t\t\t\tFrom:   \"get-tasks\",\n\t\t\t\tResult: \"success\",\n\t\t\t\tTo:     \"use-tasks\",\n\t\t\t\tOutputMap: []domain.OutputMapping{\n\t\t\t\t\t{\n\t\t\t\t\t\tEnvVar: \"TASK_TITLE\",\n\t\t\t\t\t\tPath:   domain.OutputPath{Segments: []domain.PathSegment{{Kind: domain.SegmentField, Field: \"title\"}}},\n\t\t\t\t\t},\n\t\t\t\t\t{\n\t\t\t\t\t\tEnvVar: \"TASK_PRIORITY\",\n\t\t\t\t\t\tPath:   domain.OutputPath{Segments: []domain.PathSegment{{Kind: domain.SegmentField, Field: \"priority\"}}},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"use-tasks\",\n\t\tType:    domain.StepTypeScript,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"run\": \"echo $TASK_TITLE $TASK_PRIORITY\"},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"success\", result)\n\n\tdata, err := os.ReadFile(filepath.Join(outputDir, \"use-tasks.out\"))\n\trequire.NoError(t, err)\n\tassert.Contains(t, string(data), \"Fix bug\")\n\tassert.Contains(t, string(data), \"high\")\n}\n\nfunc TestExecutor_ScriptStep_OutputMappings_ArrayIndex(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n\n\t// Write source step output as JSON array\n\tsourceJSON := `[{\"id\": \"task-1\", \"title\": \"First\"}, {\"id\": \"task-2\", \"title\": \"Second\"}]`\n\trequire.NoError(t, os.WriteFile(filepath.Join(outputDir, \"list-tasks.out\"), []byte(sourceJSON), 0644))\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tOutputDir:  outputDir,\n\t\tWires: []domain.Wire{\n\t\t\t{\n\t\t\t\tFrom:   \"list-tasks\",\n\t\t\t\tResult: \"success\",\n\t\t\t\tTo:     \"process\",\n\t\t\t\tOutputMap: []domain.OutputMapping{\n\t\t\t\t\t{\n\t\t\t\t\t\tEnvVar: \"FIRST_ID\",\n\t\t\t\t\t\tPath: domain.OutputPath{Segments: []domain.PathSegment{\n\t\t\t\t\t\t\t{Kind: domain.SegmentIndex, Index: 0},\n\t\t\t\t\t\t\t{Kind: domain.SegmentField, Field: \"id\"},\n\t\t\t\t\t\t}},\n\t\t\t\t\t},\n\t\t\t\t\t{\n\t\t\t\t\t\tEnvVar: \"SECOND_TITLE\",\n\t\t\t\t\t\tPath: domain.OutputPath{Segments: []domain.PathSegment{\n\t\t\t\t\t\t\t{Kind: domain.SegmentIndex, Index: 1},\n\t\t\t\t\t\t\t{Kind: domain.SegmentField, Field: \"title\"},\n\t\t\t\t\t\t}},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"process\",\n\t\tType:    domain.StepTypeScript,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"run\": \"echo $FIRST_ID $SECOND_TITLE\"},\n\t}\n\n\tresult, err := executor.Execute(context.Background(), step)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"success\", result)\n\n\tdata, err := os.ReadFile(filepath.Join(outputDir, \"process.out\"))\n\trequire.NoError(t, err)\n\tassert.Contains(t, string(data), \"task-1\")\n\tassert.Contains(t, string(data), \"Second\")\n}\n\nfunc TestExecutor_ScriptStep_OutputMappings_MissingSourceOutput(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n\n\t// No source output file written\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tOutputDir:  outputDir,\n\t\tWires: []domain.Wire{\n\t\t\t{\n\t\t\t\tFrom:   \"missing-step\",\n\t\t\t\tResult: \"success\",\n\t\t\t\tTo:     \"consumer\",\n\t\t\t\tOutputMap: []domain.OutputMapping{\n\t\t\t\t\t{\n\t\t\t\t\t\tEnvVar: \"VAL\",\n\t\t\t\t\t\tPath:   domain.OutputPath{Segments: []domain.PathSegment{{Kind: domain.SegmentField, Field: \"key\"}}},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"consumer\",\n\t\tType:    domain.StepTypeScript,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"run\": \"echo hello\"},\n\t}\n\n\t_, err := executor.Execute(context.Background(), step)\n\trequire.Error(t, err)\n\tassert.Contains(t, err.Error(), \"reading output of missing-step\")\n}\n\nfunc TestExecutor_ScriptStep_OutputMappings_NotJSON(t *testing.T) {\n\ttmpDir := t.TempDir()\n\toutputDir := filepath.Join(tmpDir, \"output\")\n\trequire.NoError(t, os.MkdirAll(outputDir, 0755))\n\n\t// Write non-JSON output\n\trequire.NoError(t, os.WriteFile(filepath.Join(outputDir, \"plain.out\"), []byte(\"not json\"), 0644))\n\n\texecutor := &Executor{\n\t\tProjectDir: tmpDir,\n\t\tOutputDir:  outputDir,\n\t\tWires: []domain.Wire{\n\t\t\t{\n\t\t\t\tFrom:   \"plain\",\n\t\t\t\tResult: \"success\",\n\t\t\t\tTo:     \"consumer\",\n\t\t\t\tOutputMap: []domain.OutputMapping{\n\t\t\t\t\t{\n\t\t\t\t\t\tEnvVar: \"VAL\",\n\t\t\t\t\t\tPath:   domain.OutputPath{Segments: []domain.PathSegment{{Kind: domain.SegmentField, Field: \"key\"}}},\n\t\t\t\t\t},\n\t\t\t\t},\n\t\t\t},\n\t\t},\n\t}\n\n\tstep := &domain.Step{\n\t\tName:    \"consumer\",\n\t\tType:    domain.StepTypeScript,\n\t\tResults: []string{\"success\", \"fail\"},\n\t\tConfig:  map[string]string{\"run\": \"echo hello\"},\n\t}\n\n\t_, err := executor.Execute(context.Background(), step)\n\trequire.Error(t, err)\n\tassert.Contains(t, err.Error(), \"not valid JSON\")\n}\n\nfunc TestRunner_RunWithID(t *testing.T) {\n\ttmpDir := t.TempDir()\n\n\t// Write a simple host.cloche\n\tclocheDir := filepath.Join(tmpDir, \".cloche\")\n\trequire.NoError(t, os.MkdirAll(clocheDir, 0755))\n\thostCloche := `workflow \"main\" {\n  step greet {\n    run     = \"echo hi\"\n    results = [success, fail]\n  }\n\n  greet:success -> done\n  greet:fail    -> abort\n}`\n\trequire.NoError(t, os.WriteFile(filepath.Join(clocheDir, \"host.cloche\"), []byte(hostCloche), 0644))\n\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\n\trunner := &Runner{\n\t\tDispatcher: &fakeDispatcher{runID: \"test-run\"},\n\t\tStore:      store,\n\t}\n\n\tcustomID := \"my-custom-run-id\"\n\tresult, err := runner.RunWithID(context.Background(), tmpDir, customID)\n\trequire.NoError(t, err)\n\tassert.Equal(t, domain.RunStateSucceeded, result.State)\n\tassert.Equal(t, customID, result.RunID, \"RunWithID should use the provided ID\")\n\n\t// Verify the run was persisted with the custom ID\n\thostRun, err := store.GetRun(context.Background(), customID)\n\trequire.NoError(t, err)\n\tassert.True(t, hostRun.IsHost)\n\tassert.Equal(t, domain.RunStateSucceeded, hostRun.State)\n}\n\nfunc TestRunner_PersistsHostRun(t *testing.T) {\n\ttmpDir := t.TempDir()\n\n\t// Write a simple host.cloche\n\tclocheDir := filepath.Join(tmpDir, \".cloche\")\n\trequire.NoError(t, os.MkdirAll(clocheDir, 0755))\n\thostCloche := `workflow \"main\" {\n  step prepare {\n    run     = \"echo prepared\"\n    results = [success, fail]\n  }\n\n  prepare:success -> done\n  prepare:fail    -> abort\n}`\n\trequire.NoError(t, os.WriteFile(filepath.Join(clocheDir, \"host.cloche\"), []byte(hostCloche), 0644))\n\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\n\trunner := &Runner{\n\t\tDispatcher: &fakeDispatcher{runID: \"test-run\"},\n\t\tStore:      store,\n\t}\n\n\tresult, err := runner.Run(context.Background(), tmpDir)\n\trequire.NoError(t, err)\n\tassert.Equal(t, domain.RunStateSucceeded, result.State)\n\tassert.NotEmpty(t, result.RunID)\n\n\t// Verify the host run was persisted in the store\n\thostRun, err := store.GetRun(context.Background(), result.RunID)\n\trequire.NoError(t, err)\n\tassert.True(t, hostRun.IsHost, \"host run should have IsHost=true\")\n\tassert.Equal(t, tmpDir, hostRun.ProjectDir)\n\tassert.Equal(t, domain.RunStateSucceeded, hostRun.State)\n\tassert.False(t, hostRun.StartedAt.IsZero())\n\tassert.False(t, hostRun.CompletedAt.IsZero())\n}\n\nfunc TestRunner_PersistsHostRunOnFailure(t *testing.T) {\n\ttmpDir := t.TempDir()\n\n\t// Write a host.cloche that will fail\n\tclocheDir := filepath.Join(tmpDir, \".cloche\")\n\trequire.NoError(t, os.MkdirAll(clocheDir, 0755))\n\thostCloche := `workflow \"main\" {\n  step bad {\n    run     = \"exit 1\"\n    results = [success, fail]\n  }\n\n  bad:success -> done\n  bad:fail    -> abort\n}`\n\trequire.NoError(t, os.WriteFile(filepath.Join(clocheDir, \"host.cloche\"), []byte(hostCloche), 0644))\n\n\tstore := &fakeStore{runs: map[string]*domain.Run{}}\n\n\trunner := &Runner{\n\t\tDispatcher: &fakeDispatcher{runID: \"test-run\"},\n\t\tStore:      store,\n\t}\n\n\tresult, err := runner.Run(context.Background(), tmpDir)\n\trequire.NoError(t, err)\n\tassert.Equal(t, domain.RunStateFailed, result.State)\n\n\t// Verify the host run was persisted with failed state\n\thostRun, err := store.GetRun(context.Background(), result.RunID)\n\trequire.NoError(t, err)\n\tassert.True(t, hostRun.IsHost)\n\tassert.Equal(t, domain.RunStateFailed, hostRun.State)\n\tassert.False(t, hostRun.CompletedAt.IsZero())\n}\n","numLines":694,"startLine":1,"totalLines":694}}}
