{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019BbvcNLTmWNUDTW9CG5WyG","type":"tool_result","content":"     1→package host\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"os\"\n     6→\t\"path/filepath\"\n     7→\t\"testing\"\n     8→\t\"time\"\n     9→\n    10→\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    11→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    12→\t\"github.com/cloche-dev/cloche/internal/engine\"\n    13→\t\"github.com/stretchr/testify/assert\"\n    14→\t\"github.com/stretchr/testify/require\"\n    15→)\n    16→\n    17→// fakeDispatcher records dispatch calls and returns a predetermined run ID.\n    18→type fakeDispatcher struct {\n    19→\tcalls     []*pb.RunWorkflowRequest\n    20→\trunID     string\n    21→\treturnErr error\n    22→}\n    23→\n    24→func (f *fakeDispatcher) RunWorkflow(_ context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error) {\n    25→\tf.calls = append(f.calls, req)\n    26→\tif f.returnErr != nil {\n    27→\t\treturn nil, f.returnErr\n    28→\t}\n    29→\treturn &pb.RunWorkflowResponse{RunId: f.runID}, nil\n    30→}\n    31→\n    32→// fakeStore returns a predetermined run on GetRun.\n    33→type fakeStore struct {\n    34→\truns map[string]*domain.Run\n    35→}\n    36→\n    37→func (f *fakeStore) CreateRun(_ context.Context, run *domain.Run) error {\n    38→\tf.runs[run.ID] = run\n    39→\treturn nil\n    40→}\n    41→func (f *fakeStore) GetRun(_ context.Context, id string) (*domain.Run, error) {\n    42→\tif r, ok := f.runs[id]; ok {\n    43→\t\treturn r, nil\n    44→\t}\n    45→\treturn nil, os.ErrNotExist\n    46→}\n    47→func (f *fakeStore) UpdateRun(_ context.Context, run *domain.Run) error {\n    48→\tf.runs[run.ID] = run\n    49→\treturn nil\n    50→}\n    51→func (f *fakeStore) DeleteRun(_ context.Context, id string) error {\n    52→\tdelete(f.runs, id)\n    53→\treturn nil\n    54→}\n    55→func (f *fakeStore) ListRuns(_ context.Context, _ time.Time) ([]*domain.Run, error) {\n    56→\treturn nil, nil\n    57→}\n    58→func (f *fakeStore) ListRunsByProject(_ context.Context, _ string, _ time.Time) ([]*domain.Run, error) {\n    59→\treturn nil, nil\n    60→}\n    61→func (f *fakeStore) ListProjects(_ context.Context) ([]string, error) {\n    62→\treturn nil, nil\n    63→}\n    64→func (f *fakeStore) ListChildRuns(_ context.Context, parentRunID string) ([]*domain.Run, error) {\n    65→\tvar children []*domain.Run\n    66→\tfor _, r := range f.runs {\n    67→\t\tif r.ParentRunID == parentRunID {\n    68→\t\t\tchildren = append(children, r)\n    69→\t\t}\n    70→\t}\n    71→\treturn children, nil\n    72→}\n    73→\n    74→func TestExecutor_ScriptStep_Success(t *testing.T) {\n    75→\ttmpDir := t.TempDir()\n    76→\toutputDir := filepath.Join(tmpDir, \"output\")\n    77→\n    78→\texecutor := &Executor{\n    79→\t\tProjectDir: tmpDir,\n    80→\t\tOutputDir:  outputDir,\n    81→\t}\n    82→\n    83→\tstep := &domain.Step{\n    84→\t\tName:    \"greet\",\n    85→\t\tType:    domain.StepTypeScript,\n    86→\t\tResults: []string{\"success\", \"fail\"},\n    87→\t\tConfig:  map[string]string{\"run\": \"echo hello\"},\n    88→\t}\n    89→\n    90→\tresult, err := executor.Execute(context.Background(), step)\n    91→\trequire.NoError(t, err)\n    92→\tassert.Equal(t, \"success\", result)\n    93→\n    94→\t// Check output was written\n    95→\tdata, err := os.ReadFile(filepath.Join(outputDir, \"greet.out\"))\n    96→\trequire.NoError(t, err)\n    97→\tassert.Contains(t, string(data), \"hello\")\n    98→}\n    99→\n   100→func TestExecutor_ScriptStep_Failure(t *testing.T) {\n   101→\ttmpDir := t.TempDir()\n   102→\toutputDir := filepath.Join(tmpDir, \"output\")\n   103→\n   104→\texecutor := &Executor{\n   105→\t\tProjectDir: tmpDir,\n   106→\t\tOutputDir:  outputDir,\n   107→\t}\n   108→\n   109→\tstep := &domain.Step{\n   110→\t\tName:    \"bad\",\n   111→\t\tType:    domain.StepTypeScript,\n   112→\t\tResults: []string{\"success\", \"fail\"},\n   113→\t\tConfig:  map[string]string{\"run\": \"exit 1\"},\n   114→\t}\n   115→\n   116→\tresult, err := executor.Execute(context.Background(), step)\n   117→\trequire.NoError(t, err)\n   118→\tassert.Equal(t, \"fail\", result)\n   119→}\n   120→\n   121→func TestExecutor_ScriptStep_ResultMarker(t *testing.T) {\n   122→\ttmpDir := t.TempDir()\n   123→\toutputDir := filepath.Join(tmpDir, \"output\")\n   124→\n   125→\texecutor := &Executor{\n   126→\t\tProjectDir: tmpDir,\n   127→\t\tOutputDir:  outputDir,\n   128→\t}\n   129→\n   130→\tstep := &domain.Step{\n   131→\t\tName:    \"marker\",\n   132→\t\tType:    domain.StepTypeScript,\n   133→\t\tResults: []string{\"success\", \"fail\", \"custom\"},\n   134→\t\tConfig:  map[string]string{\"run\": \"echo 'some output'; echo 'CLOCHE_RESULT:custom'\"},\n   135→\t}\n   136→\n   137→\tresult, err := executor.Execute(context.Background(), step)\n   138→\trequire.NoError(t, err)\n   139→\tassert.Equal(t, \"custom\", result)\n   140→\n   141→\t// Marker line should be stripped from output\n   142→\tdata, err := os.ReadFile(filepath.Join(outputDir, \"marker.out\"))\n   143→\trequire.NoError(t, err)\n   144→\tassert.NotContains(t, string(data), \"CLOCHE_RESULT\")\n   145→\tassert.Contains(t, string(data), \"some output\")\n   146→}\n   147→\n   148→func TestExecutor_WorkflowStep_Success(t *testing.T) {\n   149→\ttmpDir := t.TempDir()\n   150→\toutputDir := filepath.Join(tmpDir, \"output\")\n   151→\t_ = os.MkdirAll(outputDir, 0755)\n   152→\n   153→\tstore := &fakeStore{runs: map[string]*domain.Run{\n   154→\t\t\"develop-test-run\": {\n   155→\t\t\tID:    \"develop-test-run\",\n   156→\t\t\tState: domain.RunStateSucceeded,\n   157→\t\t},\n   158→\t}}\n   159→\n   160→\tdispatcher := &fakeDispatcher{runID: \"develop-test-run\"}\n   161→\n   162→\texecutor := &Executor{\n   163→\t\tProjectDir: tmpDir,\n   164→\t\tDispatcher: dispatcher,\n   165→\t\tStore:      store,\n   166→\t\tOutputDir:  ou