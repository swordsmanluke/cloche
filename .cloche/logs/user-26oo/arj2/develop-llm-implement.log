{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TKc6qdUjWVtfmqnfGLQywA","type":"tool_result","content":"     1→package host\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"fmt\"\n     6→\t\"log\"\n     7→\t\"os\"\n     8→\t\"os/exec\"\n     9→\t\"path/filepath\"\n    10→\t\"strings\"\n    11→\t\"time\"\n    12→\n    13→\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    14→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    15→\t\"github.com/cloche-dev/cloche/internal/engine\"\n    16→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    17→\t\"github.com/cloche-dev/cloche/internal/protocol\"\n    18→)\n    19→\n    20→// resolveOutputMappings finds all wires targeting stepName that have output mappings,\n    21→// reads the source step's output, evaluates each mapping path, and returns KEY=value\n    22→// strings suitable for adding to a command's environment.\n    23→func (e *Executor) resolveOutputMappings(stepName string, wires []domain.Wire) ([]string, error) {\n    24→\tvar env []string\n    25→\tfor _, w := range wires {\n    26→\t\tif w.To != stepName || len(w.OutputMap) == 0 {\n    27→\t\t\tcontinue\n    28→\t\t}\n    29→\t\tdata, err := os.ReadFile(e.stepOutputPath(w.From))\n    30→\t\tif err != nil {\n    31→\t\t\treturn nil, fmt.Errorf(\"reading output of %s: %w\", w.From, err)\n    32→\t\t}\n    33→\t\tfor _, m := range w.OutputMap {\n    34→\t\t\tval, err := m.Path.Evaluate(data)\n    35→\t\t\tif err != nil {\n    36→\t\t\t\treturn nil, fmt.Errorf(\"mapping %s for step %s: %w\", m.EnvVar, stepName, err)\n    37→\t\t\t}\n    38→\t\t\tenv = append(env, m.EnvVar+\"=\"+val)\n    39→\t\t}\n    40→\t}\n    41→\treturn env, nil\n    42→}\n    43→\n    44→// RunDispatcher dispatches a container workflow run and returns the run ID.\n    45→type RunDispatcher interface {\n    46→\tRunWorkflow(ctx context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error)\n    47→}\n    48→\n    49→// Executor implements engine.StepExecutor for host workflow steps.\n    50→type Executor struct {\n    51→\tProjectDir string\n    52→\tMainDir    string         // main branch worktree dir; scripts execute from here\n    53→\tDispatcher RunDispatcher\n    54→\tStore      ports.RunStore\n    55→\tOutputDir  string         // directory for step output files\n    56→\tWires      []domain.Wire  // workflow wiring (for output mappings)\n    57→\tHostRunID  string         // ID of the parent host run (set on child runs)\n    58→}\n    59→\n    60→// scriptDir returns the directory from which scripts should execute.\n    61→// Uses MainDir if set, otherwise falls back to ProjectDir.\n    62→func (e *Executor) scriptDir() string {\n    63→\tif e.MainDir != \"\" {\n    64→\t\treturn e.MainDir\n    65→\t}\n    66→\treturn e.ProjectDir\n    67→}\n    68→\n    69→var _ engine.StepExecutor = (*Executor)(nil)\n    70→\n    71→// Execute runs a single host workflow step.\n    72→func (e *Executor) Execute(ctx context.Context, step *domain.Step) (string, error) {\n    73→\tswitch step.Type {\n    74→\tcase domain.StepTypeScript:\n    75→\t\treturn e.executeScript(ctx, step)\n    76→\tcase domain.StepTypeWorkflow:\n    77→\t\treturn e.executeWorkflow(ctx, step)\n    78→\tdefault:\n    79→\t\treturn \"\", fmt.Errorf(\"unsupported step type %q in host workflow\", step.Type)\n    80→\t}\n    81→}\n    82→\n    83→// executeScript runs a shell command on the host.\n    84→func (e *Executor) executeScript(ctx context.Context, step *domain.Step) (string, error) {\n    85→\tcmdStr := step.Config[\"run\"]\n    86→\tcmd := exec.CommandContext(ctx, \"sh\", \"-c\", cmdStr)\n    87→\tcmd.Dir = e.scriptDir()\n    88→\tcmd.Env = append(os.Environ(),\n    89→\t\t\"CLOCHE_PROJECT_DIR=\"+e.ProjectDir,\n    90→\t\t\"CLOCHE_STEP_OUTPUT=\"+e.stepOutputPath(step.Name),\n    91→\t)\n    92→\n    93→\t// Pass previous step output if available\n    94→\tif prevOutput := e.findPrevOutput(step); prevOutput != \"\" {\n    95→\t\tcmd.Env = append(cmd.Env, \"CLOCHE_PREV_OUTPUT=\"+prevOutput)\n    96→\t}\n    97→\n    98→\t// Resolve output mappings from wires and add as env vars\n    99→\tif len(e.Wires) > 0 {\n   100→\t\tmapped, err := e.resolveOutputMappings(step.Name, e.Wires)\n   101→\t\tif err != nil {\n   102→\t\t\treturn \"\", fmt.Errorf(\"resolving output mappings for step %q: %w\", step.Name, err)\n   103→\t\t}\n   104→\t\tcmd.Env = append(cmd.Env, mapped...)\n   105→\t}\n   106→\n   107→\toutput, err := cmd.CombinedOutput()\n   108→\n   109→\t// Extract result marker\n   110→\tmarkerResult, cleanOutput, found := protocol.ExtractResult(output)\n   111→\n   112→\t// Write output to file\n   113→\tif mkErr := os.MkdirAll(e.OutputDir, 0755); mkErr == nil {\n   114→\t\t_ = os.WriteFile(e.stepOutputPath(step.Name), cleanOutput, 0644)\n   115→\t}\n   116→\n   117→\tif err != nil {\n   118→\t\tif _, ok := err.(*exec.ExitError); ok {\n   119→\t\t\tresult := \"fail\"\n   120→\t\t\tif found {\n   121→\t\t\t\tresult = markerResult\n   122→\t\t\t}\n   123→\t\t\treturn result, nil\n   124→\t\t}\n   125→\t\treturn \"\", err\n   126→\t}\n   127→\n   128→\tresult := \"success\"\n   129→\tif found {\n   130→\t\tresult = markerResult\n   131→\t}\n   132→\treturn result, nil\n   133→}\n   134→\n   135→// executeWorkflow dispatches a container workflow run and blocks until it completes.\n   136→func (e *Executor) executeWorkflow(ctx context.Context, step *domain.Step) (string, error) {\n   137→\tworkflowName := step.Config[\"workflow_name\"]\n   138→\tif workflowName == \"\" {\n   139→\t\treturn \"\", fmt.Errorf(\"workflow step %q missing workflow_name\", step.Name)\n   140→\t}\n   141→\n   142→\t// Read prompt from previous step output or prompt_step override\n   143→\tvar promptContent string\n   144→\tpromptSource := step.Config[\"prompt_step\"]\n   145→\tif promptSource != \"\" {\n   146→\t\tdata, err := os.ReadFile(e.stepOutputPath(promptSource))\n   147→\t\tif err == nil {\n   148→\t\t\tpromptContent = string(data)\n   149→\t\t}\n   150→\t} else if prev := e.findPrevOutput(step); prev != \"\" {\n   151→\t\tdata, err := os.ReadFile(prev)\n   152→\t\tif err == nil {\n   153→\t\t\tpromptContent = string(data)\n   154→\t\t}\n   155→\t}\n   156→\n   157→\tresp, err := e.Dispatcher.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n   158→\t\tWorkflowName: workflowName,\n   159→\t\tProjectDir:   e.ProjectDir,\n   160→\t\tPrompt:       promptContent,\n   161→\t})\n   162→\tif err != nil {\n   163→\t\treturn \"\", fmt.Errorf(\"dispatching workflow %q: %w\", workflowName, err)\n   164→\t}\n   165→\n   166→\tlog.Printf(\"host executor: dispatched container workflow %q as run %s\", workflowName, resp.RunId)\n   167→\n   168→\t// Link child run to parent host run\n   169→\tif e.HostRunID != \"\" {\n   170→\t\tif childRun, err := e.Store.GetRun(ctx, resp.RunId); err == nil {\n   171→\t\t\tchildRun.ParentRunID = e.HostRunID\n   172→\t\t\t_ = e.Store.UpdateRun(ctx, childRun)\n   173→\t\t}\n   174→\t}\n   175→\n   176→\t// Write run ID to step output so downstream steps (e.g. merge) can find it\n   177→\tif mkErr := os.MkdirAll(e.OutputDir, 0755); mkErr == nil {\n   178→\t\t_ = os.WriteFile(e.stepOutputPath(step.Name), []byte(resp.RunId), 0644)\n   179→\t}\n   180→\n   181→\t// Poll until the run reaches a terminal state\n   182→\tstate, err := e.waitForRun(ctx, resp.RunId)\n   183→\tif err != nil {\n   184→\t\treturn \"\", fmt.Errorf(\"waiting for workflow %q run %s: %w\", workflowName, resp.RunId, err)\n   185→\t}\n   186→\n   187→\tlog.Printf(\"host executor: workflow %q run %s completed with state %s\", workflowName, resp.RunId, state)\n   188→\n   189→\t// Map run state to step result\n   190→\tif state == domain.RunStateSucceeded {\n   191→\t\treturn \"success\", nil\n   192→\t}\n   193→\treturn \"fail\", nil\n   194→}\n   195→\n   196→// waitForRun polls the store until the run reaches a terminal state.\n   197→func (e *Executor) waitForRun(ctx context.Context, runID string) (domain.RunState, error) {\n   198→\tticker := time.NewTicker(2 * time.Second)\n   199→\tdefer ticker.Stop()\n   200→\n   201→\tfor {\n   202→\t\tselect {\n   203→\t\tcase <-ctx.Done():\n   204→\t\t\treturn \"\", fmt.Errorf(\"context cancelled while waiting for run %s: %w\", runID, ctx.Err())\n   205→\t\tcase <-ticker.C:\n   206→\t\t\trun, err := e.Store.GetRun(ctx, runID)\n   207→\t\t\tif err != nil {\n   208→\t\t\t\tcontinue // transient error, retry\n   209→\t\t\t}\n   210→\t\t\tswitch run.State {\n   211→\t\t\tcase domain.RunStateSucceeded, domain.RunStateFailed, domain.RunStateCancelled:\n   212→\t\t\t\treturn run.State, nil\n   213→\t\t\t}\n   214→\t\t\t// Still pending or running, continue polling\n   215→\t\t}\n   216→\t}\n   217→}\n   218→\n   219→// stepOutputPath returns the path for a step's output file.\n   220→func (e *Executor) stepOutputPath(stepName string) string {\n   221→\treturn filepath.Join(e.OutputDir, stepName+\".out\")\n   222→}\n   223→\n   224→// findPrevOutput finds the output file from the step that wires into this one.\n   225→// It checks prompt_step config first, then walks the wiring graph to find the\n   226→// source step.\n   227→func (e *Executor) findPrevOutput(step *domain.Step) string {\n   228→\t// Explicit prompt_step config takes priority\n   229→\tif ps := step.Config[\"prompt_step\"]; ps != \"\" {\n   230→\t\tpath := e.stepOutputPath(ps)\n   231→\t\tif _, err := os.Stat(path); err == nil {\n   232→\t\t\treturn path\n   233→\t\t}\n   234→\t}\n   235→\n   236→\t// Walk wiring to find the step that feeds into this one\n   237→\tfor _, w := range e.Wires {\n   238→\t\tif w.To == step.Name {\n   239→\t\t\tpath := e.stepOutputPath(w.From)\n   240→\t\t\tif _, err := os.Stat(path); err == nil {\n   241→\t\t\t\treturn path\n   242→\t\t\t}\n   243→\t\t}\n   244→\t}\n   245→\treturn \"\"\n   246→}\n   247→\n   248→// MainWorktreeDir returns the path of the main (non-linked) git worktree for\n   249→// the repository containing projectDir. If projectDir is already the main\n   250→// worktree, it returns projectDir unchanged. Falls back to projectDir on any\n   251→// error (e.g. not a git repo).\n   252→func MainWorktreeDir(projectDir string) string {\n   253→\tcmd := exec.Command(\"git\", \"-C\", projectDir, \"worktree\", \"list\", \"--porcelain\")\n   254→\tout, err := cmd.Output()\n   255→\tif err != nil {\n   256→\t\treturn projectDir\n   257→\t}\n   258→\t// The first \"worktree <path>\" line is always the main worktree.\n   259→\tfor _, line := range strings.Split(string(out), \"\\n\") {\n   260→\t\tif strings.HasPrefix(line, \"worktree \") {\n   261→\t\t\treturn strings.TrimPrefix(line, \"worktree \")\n   262→\t\t}\n   263→\t}\n   264→\treturn projectDir\n   265→}\n   266→"}]},"parent_tool_use_id":null,"session_id":"86005800-dc4f-4a50-b6ae-f82ea613cda8","uuid":"c18c7b10-614b-41cb-a428-b16c81bc816a","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/host/executor.go","content":"package host\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"log\"\n\t\"os\"\n\t\"os/exec\"\n\t\"path/filepath\"\n\t\"strings\"\n\t\"time\"\n\n\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/engine\"\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n\t\"github.com/cloche-dev/cloche/internal/protocol\"\n)\n\n// resolveOutputMappings finds all wires targeting stepName that have output mappings,\n// reads the source step's output, evaluates each mapping path, and returns KEY=value\n// strings suitable for adding to a command's environment.\nfunc (e *Executor) resolveOutputMappings(stepName string, wires []domain.Wire) ([]string, error) {\n\tvar env []string\n\tfor _, w := range wires {\n\t\tif w.To != stepName || len(w.OutputMap) == 0 {\n\t\t\tcontinue\n\t\t}\n\t\tdata, err := os.ReadFile(e.stepOutputPath(w.From))\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"reading output of %s: %w\", w.From, err)\n\t\t}\n\t\tfor _, m := range w.OutputMap {\n\t\t\tval, err := m.Path.Evaluate(data)\n\t\t\tif err != nil {\n\t\t\t\treturn nil, fmt.Errorf(\"mapping %s for step %s: %w\", m.EnvVar, stepName, err)\n\t\t\t}\n\t\t\tenv = append(env, m.EnvVar+\"=\"+val)\n\t\t}\n\t}\n\treturn env, nil\n}\n\n// RunDispatcher dispatches a container workflow run and returns the run ID.\ntype RunDispatcher interface {\n\tRunWorkflow(ctx context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error)\n}\n\n// Executor implements engine.StepExecutor for host workflow steps.\ntype Executor struct {\n\tProjectDir string\n\tMainDir    string         // main branch worktree dir; scripts execute from here\n\tDispatcher RunDispatcher\n\tStore      ports.RunStore\n\tOutputDir  string         // directory for step output files\n\tWires      []domain.Wire  // workflow wiring (for output mappings)\n\tHostRunID  string         // ID of the parent host run (set on child runs)\n}\n\n// scriptDir returns the directory from which scripts should execute.\n// Uses MainDir if set, otherwise falls back to ProjectDir.\nfunc (e *Executor) scriptDir() string {\n\tif e.MainDir != \"\" {\n\t\treturn e.MainDir\n\t}\n\treturn e.ProjectDir\n}\n\nvar _ engine.StepExecutor = (*Executor)(nil)\n\n// Execute runs a single host workflow step.\nfunc (e *Executor) Execute(ctx context.Context, step *domain.Step) (string, error) {\n\tswitch step.Type {\n\tcase domain.StepTypeScript:\n\t\treturn e.executeScript(ctx, step)\n\tcase domain.StepTypeWorkflow:\n\t\treturn e.executeWorkflow(ctx, step)\n\tdefault:\n\t\treturn \"\", fmt.Errorf(\"unsupported step type %q in host workflow\", step.Type)\n\t}\n}\n\n// executeScript runs a shell command on the host.\nfunc (e *Executor) executeScript(ctx context.Context, step *domain.Step) (string, error) {\n\tcmdStr := step.Config[\"run\"]\n\tcmd := exec.CommandContext(ctx, \"sh\", \"-c\", cmdStr)\n\tcmd.Dir = e.scriptDir()\n\tcmd.Env = append(os.Environ(),\n\t\t\"CLOCHE_PROJECT_DIR=\"+e.ProjectDir,\n\t\t\"CLOCHE_STEP_OUTPUT=\"+e.stepOutputPath(step.Name),\n\t)\n\n\t// Pass previous step output if available\n\tif prevOutput := e.findPrevOutput(step); prevOutput != \"\" {\n\t\tcmd.Env = append(cmd.Env, \"CLOCHE_PREV_OUTPUT=\"+prevOutput)\n\t}\n\n\t// Resolve output mappings from wires and add as env vars\n\tif len(e.Wires) > 0 {\n\t\tmapped, err := e.resolveOutputMappings(step.Name, e.Wires)\n\t\tif err != nil {\n\t\t\treturn \"\", fmt.Errorf(\"resolving output mappings for step %q: %w\", step.Name, err)\n\t\t}\n\t\tcmd.Env = append(cmd.Env, mapped...)\n\t}\n\n\toutput, err := cmd.CombinedOutput()\n\n\t// Extract result marker\n\tmarkerResult, cleanOutput, found := protocol.ExtractResult(output)\n\n\t// Write output to file\n\tif mkErr := os.MkdirAll(e.OutputDir, 0755); mkErr == nil {\n\t\t_ = os.WriteFile(e.stepOutputPath(step.Name), cleanOutput, 0644)\n\t}\n\n\tif err != nil {\n\t\tif _, ok := err.(*exec.ExitError); ok {\n\t\t\tresult := \"fail\"\n\t\t\tif found {\n\t\t\t\tresult = markerResult\n\t\t\t}\n\t\t\treturn result, nil\n\t\t}\n\t\treturn \"\", err\n\t}\n\n\tresult := \"success\"\n\tif found {\n\t\tresult = markerResult\n\t}\n\treturn result, nil\n}\n\n// executeWorkflow dispatches a container workflow run and blocks until it completes.\nfunc (e *Executor) executeWorkflow(ctx context.Context, step *domain.Step) (string, error) {\n\tworkflowName := step.Config[\"workflow_name\"]\n\tif workflowName == \"\" {\n\t\treturn \"\", fmt.Errorf(\"workflow step %q missing workflow_name\", step.Name)\n\t}\n\n\t// Read prompt from previous step output or prompt_step override\n\tvar promptContent string\n\tpromptSource := step.Config[\"prompt_step\"]\n\tif promptSource != \"\" {\n\t\tdata, err := os.ReadFile(e.stepOutputPath(promptSource))\n\t\tif err == nil {\n\t\t\tpromptContent = string(data)\n\t\t}\n\t} else if prev := e.findPrevOutput(step); prev != \"\" {\n\t\tdata, err := os.ReadFile(prev)\n\t\tif err == nil {\n\t\t\tpromptContent = string(data)\n\t\t}\n\t}\n\n\tresp, err := e.Dispatcher.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n\t\tWorkflowName: workflowName,\n\t\tProjectDir:   e.ProjectDir,\n\t\tPrompt:       promptContent,\n\t})\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"dispatching workflow %q: %w\", workflowName, err)\n\t}\n\n\tlog.Printf(\"host executor: dispatched container workflow %q as run %s\", workflowName, resp.RunId)\n\n\t// Link child run to parent host run\n\tif e.HostRunID != \"\" {\n\t\tif childRun, err := e.Store.GetRun(ctx, resp.RunId); err == nil {\n\t\t\tchildRun.ParentRunID = e.HostRunID\n\t\t\t_ = e.Store.UpdateRun(ctx, childRun)\n\t\t}\n\t}\n\n\t// Write run ID to step output so downstream steps (e.g. merge) can find it\n\tif mkErr := os.MkdirAll(e.OutputDir, 0755); mkErr == nil {\n\t\t_ = os.WriteFile(e.stepOutputPath(step.Name), []byte(resp.RunId), 0644)\n\t}\n\n\t// Poll until the run reaches a terminal state\n\tstate, err := e.waitForRun(ctx, resp.RunId)\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"waiting for workflow %q run %s: %w\", workflowName, resp.RunId, err)\n\t}\n\n\tlog.Printf(\"host executor: workflow %q run %s completed with state %s\", workflowName, resp.RunId, state)\n\n\t// Map run state to step result\n\tif state == domain.RunStateSucceeded {\n\t\treturn \"success\", nil\n\t}\n\treturn \"fail\", nil\n}\n\n// waitForRun polls the store until the run reaches a terminal state.\nfunc (e *Executor) waitForRun(ctx context.Context, runID string) (domain.RunState, error) {\n\tticker := time.NewTicker(2 * time.Second)\n\tdefer ticker.Stop()\n\n\tfor {\n\t\tselect {\n\t\tcase <-ctx.Done():\n\t\t\treturn \"\", fmt.Errorf(\"context cancelled while waiting for run %s: %w\", runID, ctx.Err())\n\t\tcase <-ticker.C:\n\t\t\trun, err := e.Store.GetRun(ctx, runID)\n\t\t\tif err != nil {\n\t\t\t\tcontinue // transient error, retry\n\t\t\t}\n\t\t\tswitch run.State {\n\t\t\tcase domain.RunStateSucceeded, domain.RunStateFailed, domain.RunStateCancelled:\n\t\t\t\treturn run.State, nil\n\t\t\t}\n\t\t\t// Still pending or running, continue polling\n\t\t}\n\t}\n}\n\n// stepOutputPath returns the path for a step's output file.\nfunc (e *Executor) stepOutputPath(stepName string) string {\n\treturn filepath.Join(e.OutputDir, stepName+\".out\")\n}\n\n// findPrevOutput finds the output file from the step that wires into this one.\n// It checks prompt_step config first, then walks the wiring graph to find the\n// source step.\nfunc (e *Executor) findPrevOutput(step *domain.Step) string {\n\t// Explicit prompt_step config takes priority\n\tif ps := step.Config[\"prompt_step\"]; ps != \"\" {\n\t\tpath := e.stepOutputPath(ps)\n\t\tif _, err := os.Stat(path); err == nil {\n\t\t\treturn path\n\t\t}\n\t}\n\n\t// Walk wiring to find the step that feeds into this one\n\tfor _, w := range e.Wires {\n\t\tif w.To == step.Name {\n\t\t\tpath := e.stepOutputPath(w.From)\n\t\t\tif _, err := os.Stat(path); err == nil {\n\t\t\t\treturn path\n\t\t\t}\n\t\t}\n\t}\n\treturn \"\"\n}\n\n// MainWorktreeDir returns the path of the main (non-linked) git worktree for\n// the repository containing projectDir. If projectDir is already the main\n// worktree, it returns projectDir unchanged. Falls back to projectDir on any\n// error (e.g. not a git repo).\nfunc MainWorktreeDir(projectDir string) string {\n\tcmd := exec.Command(\"git\", \"-C\", projectDir, \"worktree\", \"list\", \"--porcelain\")\n\tout, err := cmd.Output()\n\tif err != nil {\n\t\treturn projectDir\n\t}\n\t// The first \"worktree <path>\" line is always the main worktree.\n\tfor _, line := range strings.Split(string(out), \"\\n\") {\n\t\tif strings.HasPrefix(line, \"worktree \") {\n\t\t\treturn strings.TrimPrefix(line, \"worktree \")\n\t\t}\n\t}\n\treturn projectDir\n}\n","numLines":266,"startLine":1,"totalLines":266}}}
