{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0121TWi3JsNeGjuxcAtpHnAM","type":"tool_result","content":"     1→package host\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"fmt\"\n     6→\t\"log\"\n     7→\t\"os\"\n     8→\t\"os/exec\"\n     9→\t\"path/filepath\"\n    10→\t\"time\"\n    11→\n    12→\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    13→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    14→\t\"github.com/cloche-dev/cloche/internal/engine\"\n    15→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    16→\t\"github.com/cloche-dev/cloche/internal/protocol\"\n    17→)\n    18→\n    19→// resolveOutputMappings finds all wires targeting stepName that have output mappings,\n    20→// reads the source step's output, evaluates each mapping path, and returns KEY=value\n    21→// strings suitable for adding to a command's environment.\n    22→func (e *Executor) resolveOutputMappings(stepName string, wires []domain.Wire) ([]string, error) {\n    23→\tvar env []string\n    24→\tfor _, w := range wires {\n    25→\t\tif w.To != stepName || len(w.OutputMap) == 0 {\n    26→\t\t\tcontinue\n    27→\t\t}\n    28→\t\tdata, err := os.ReadFile(e.stepOutputPath(w.From))\n    29→\t\tif err != nil {\n    30→\t\t\treturn nil, fmt.Errorf(\"reading output of %s: %w\", w.From, err)\n    31→\t\t}\n    32→\t\tfor _, m := range w.OutputMap {\n    33→\t\t\tval, err := m.Path.Evaluate(data)\n    34→\t\t\tif err != nil {\n    35→\t\t\t\treturn nil, fmt.Errorf(\"mapping %s for step %s: %w\", m.EnvVar, stepName, err)\n    36→\t\t\t}\n    37→\t\t\tenv = append(env, m.EnvVar+\"=\"+val)\n    38→\t\t}\n    39→\t}\n    40→\treturn env, nil\n    41→}\n    42→\n    43→// RunDispatcher dispatches a container workflow run and returns the run ID.\n    44→type RunDispatcher interface {\n    45→\tRunWorkflow(ctx context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error)\n    46→}\n    47→\n    48→// Executor implements engine.StepExecutor for host workflow steps.\n    49→type Executor struct {\n    50→\tProjectDir string\n    51→\tDispatcher RunDispatcher\n    52→\tStore      ports.RunStore\n    53→\tOutputDir  string         // directory for step output files\n    54→\tWires      []domain.Wire  // workflow wiring (for output mappings)\n    55→\tHostRunID  string         // ID of the parent host run (set on child runs)\n    56→}\n    57→\n    58→var _ engine.StepExecutor = (*Executor)(nil)\n    59→\n    60→// Execute runs a single host workflow step.\n    61→func (e *Executor) Execute(ctx context.Context, step *domain.Step) (string, error) {\n    62→\tswitch step.Type {\n    63→\tcase domain.StepTypeScript:\n    64→\t\treturn e.executeScript(ctx, step)\n    65→\tcase domain.StepTypeWorkflow:\n    66→\t\treturn e.executeWorkflow(ctx, step)\n    67→\tdefault:\n    68→\t\treturn \"\", fmt.Errorf(\"unsupported step type %q in host workflow\", step.Type)\n    69→\t}\n    70→}\n    71→\n    72→// executeScript runs a shell command on the host.\n    73→func (e *Executor) executeScript(ctx context.Context, step *domain.Step) (string, error) {\n    74→\tcmdStr := step.Config[\"run\"]\n    75→\tcmd := exec.CommandContext(ctx, \"sh\", \"-c\", cmdStr)\n    76→\tcmd.Dir = e.ProjectDir\n    77→\tcmd.Env = append(os.Environ(),\n    78→\t\t\"CLOCHE_PROJECT_DIR=\"+e.ProjectDir,\n    79→\t\t\"CLOCHE_STEP_OUTPUT=\"+e.stepOutputPath(step.Name),\n    80→\t)\n    81→\n    82→\t// Pass previous step output if available\n    83→\tif prevOutput := e.findPrevOutput(step); prevOutput != \"\" {\n    84→\t\tcmd.Env = append(cmd.Env, \"CLOCHE_PREV_OUTPUT=\"+prevOutput)\n    85→\t}\n    86→\n    87→\t// Resolve output mappings from wires and add as env vars\n    88→\tif len(e.Wires) > 0 {\n    89→\t\tmapped, err := e.resolveOutputMappings(step.Name, e.Wires)\n    90→\t\tif err != nil {\n    91→\t\t\treturn \"\", fmt.Errorf(\"resolving output mappings for step %q: %w\", step.Name, err)\n    92→\t\t}\n    93→\t\tcmd.Env = append(cmd.Env, mapped...)\n    94→\t}\n    95→\n    96→\toutput, err := cmd.CombinedOutput()\n    97→\n    98→\t// Extract result marker\n    99→\tmarkerResult, cleanOutput, found := protocol.ExtractResult(output)\n   100→\n   101→\t// Write output to file\n   102→\tif mkErr := os.MkdirAll(e.OutputDir, 0755); mkErr == nil {\n   103→\t\t_ = os.WriteFile(e.stepOutputPath(step.Name), cleanOutput, 0644)\n   104→\t}\n   105→\n   106→\tif err != nil {\n   107→\t\tif _, ok := err.(*exec.ExitError); ok {\n   108→\t\t\tresult := \"fail\"\n   109→\t\t\tif found {\n   110→\t\t\t\tresult = markerResult\n   111→\t\t\t}\n   112→\t\t\treturn result, nil\n   113→\t\t}\n   114→\t\treturn \"\", err\n   115→\t}\n   116→\n   117→\tresult := \"success\"\n   118→\tif found {\n   119→\t\tresult = markerResult\n   120→\t}\n   121→\treturn result, nil\n   122→}\n   123→\n   124→// executeWorkflow dispatches a container workflow run and blocks until it completes.\n   125→func (e *Executor) executeWorkflow(ctx context.Context, step *domain.Step) (string, error) {\n   126→\tworkflowName := step.Config[\"workflow_name\"]\n   127→\tif workflowName == \"\" {\n   128→\t\treturn \"\", fmt.Errorf(\"workflow step %q missing workflow_name\", step.Name)\n   129→\t}\n   130→\n   131→\t// Read prompt from previous step output or prompt_step override\n   132→\tvar promptContent string\n   133→\tpromptSource := step.Config[\"prompt_step\"]\n   134→\tif promptSource != \"\" {\n   135→\t\tdata, err := os.ReadFile(e.stepOutputPath(promptSource))\n   136→\t\tif err == nil {\n   137→\t\t\tpromptContent = string(data)\n   138→\t\t}\n   139→\t} else if prev := e.findPrevOutput(step); prev != \"\" {\n   140→\t\tdata, err := os.ReadFile(prev)\n   141→\t\tif err == nil {\n   142→\t\t\tpromptContent = string(data)\n   143→\t\t}\n   144→\t}\n   145→\n   146→\tresp, err := e.Dispatcher.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n   147→\t\tWorkflowName: workflowName,\n   148→\t\tProjectDir:   e.ProjectDir,\n   149→\t\tPrompt:       promptContent,\n   150→\t})\n   151→\tif err != nil {\n   152→\t\treturn \"\", fmt.Errorf(\"dispatching workflow %q: %w\", workflowName, err)\n   153→\t}\n   154→\n   155→\tlog.Printf(\"host executor: dispatched container workflow %q as run %s\", workflowName, resp.RunId)\n   156→\n   157→\t// Link child run to parent host run\n   158→\tif e.HostRunID != \"\" {\n   159→\t\tif childRun, err := e.Store.GetRun(ctx, resp.RunId); err == nil {\n   160→\t\t\tchildRun.ParentRunID = e.HostRunID\n   161→\t\t\t_ = e.Store.UpdateRun(ctx, childRun)\n   162→\t\t}\n   163→\t}\n   164→\n   165→\t// Write run ID to step output so downstream steps (e.g. merge) can find it\n   166→\tif mkErr := os.MkdirAll(e.OutputDir, 0755); mkErr == nil {\n   167→\t\t_ = os.WriteFile(e.stepOutputPath(step.Name), []byte(resp.RunId), 0644)\n   168→\t}\n   169→\n   170→\t// Poll until the run reaches a terminal state\n   171→\tstate, err := e.waitForRun(ctx, resp.RunId)\n   172→\tif err != nil {\n   173→\t\treturn \"\", fmt.Errorf(\"waiting for workflow %q run %s: %w\", workflowName, resp.RunId, err)\n   174→\t}\n   175→\n   176→\tlog.Printf(\"host executor: workflow %q run %s completed with state %s\", workflowName, resp.RunId, state)\n   177→\n   178→\t// Map run state to step result\n   179→\tif state == domain.RunStateSucceeded {\n   180→\t\treturn \"success\", nil\n   181→\t}\n   182→\treturn \"fail\", nil\n   183→}\n   184→\n   185→// waitForRun polls the store until the run reaches a terminal state.\n   186→func (e *Executor) waitForRun(ctx context.Context, runID string) (domain.RunState, error) {\n   187→\tticker := time.NewTicker(2 * time.Second)\n   188→\tdefer ticker.Stop()\n   189→\n   190→\tfor {\n   191→\t\tselect {\n   192→\t\tcase <-ctx.Done():\n   193→\t\t\treturn \"\", fmt.Errorf(\"context cancelled while waiting for run %s: %w\", runID, ctx.Err())\n   194→\t\tcase <-ticker.C:\n   195→\t\t\trun, err := e.Store.GetRun(ctx, runID)\n   196→\t\t\tif err != nil {\n   197→\t\t\t\tcontinue // transient error, retry\n   198→\t\t\t}\n   199→\t\t\tswitch run.State {\n   200→\t\t\tcase domain.RunStateSucceeded, domain.RunStateFailed, domain.RunStateCancelled:\n   201→\t\t\t\treturn run.State, nil\n   202→\t\t\t}\n   203→\t\t\t// Still pending or running, continue polling\n   204→\t\t}\n   205→\t}\n   206→}\n   207→\n   208→// stepOutputPath returns the path for a step's output file.\n   209→func (e *Executor) stepOutputPath(stepName string) string {\n   210→\treturn filepath.Join(e.OutputDir, stepName+\".out\")\n   211→}\n   212→\n   213→// findPrevOutput finds the output file from the step that wires into this one.\n   214→// It checks prompt_step config first, then walks the wiring graph to find the\n   215→// source step.\n   216→func (e *Executor) findPrevOutput(step *domain.Step) string {\n   217→\t// Explicit prompt_step config takes priority\n   218→\tif ps := step.Config[\"prompt_step\"]; ps != \"\" {\n   219→\t\tpath := e.stepOutputPath(ps)\n   220→\t\tif _, err := os.Stat(path); err == nil {\n   221→\t\t\treturn path\n   222→\t\t}\n   223→\t}\n   224→\n   225→\t// Walk wiring to find the step that feeds into this one\n   226→\tfor _, w := range e.Wires {\n   227→\t\tif w.To == step.Name {\n   228→\t\t\tpath := e.stepOutputPath(w.From)\n   229→\t\t\tif _, err := os.Stat(path); err == nil {\n   230→\t\t\t\treturn path\n   231→\t\t\t}\n   232→\t\t}\n   233→\t}\n   234→\treturn \"\"\n   235→}\n   236→"}]},"parent_tool_use_id":null,"session_id":"86005800-dc4f-4a50-b6ae-f82ea613cda8","uuid":"531ea434-03c1-411f-bb61-0dbaca5b7b4a","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/host/executor.go","content":"package host\n\nimport (\n\t\"context\"\n\t\"fmt\"\n\t\"log\"\n\t\"os\"\n\t\"os/exec\"\n\t\"path/filepath\"\n\t\"time\"\n\n\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/engine\"\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n\t\"github.com/cloche-dev/cloche/internal/protocol\"\n)\n\n// resolveOutputMappings finds all wires targeting stepName that have output mappings,\n// reads the source step's output, evaluates each mapping path, and returns KEY=value\n// strings suitable for adding to a command's environment.\nfunc (e *Executor) resolveOutputMappings(stepName string, wires []domain.Wire) ([]string, error) {\n\tvar env []string\n\tfor _, w := range wires {\n\t\tif w.To != stepName || len(w.OutputMap) == 0 {\n\t\t\tcontinue\n\t\t}\n\t\tdata, err := os.ReadFile(e.stepOutputPath(w.From))\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"reading output of %s: %w\", w.From, err)\n\t\t}\n\t\tfor _, m := range w.OutputMap {\n\t\t\tval, err := m.Path.Evaluate(data)\n\t\t\tif err != nil {\n\t\t\t\treturn nil, fmt.Errorf(\"mapping %s for step %s: %w\", m.EnvVar, stepName, err)\n\t\t\t}\n\t\t\tenv = append(env, m.EnvVar+\"=\"+val)\n\t\t}\n\t}\n\treturn env, nil\n}\n\n// RunDispatcher dispatches a container workflow run and returns the run ID.\ntype RunDispatcher interface {\n\tRunWorkflow(ctx context.Context, req *pb.RunWorkflowRequest) (*pb.RunWorkflowResponse, error)\n}\n\n// Executor implements engine.StepExecutor for host workflow steps.\ntype Executor struct {\n\tProjectDir string\n\tDispatcher RunDispatcher\n\tStore      ports.RunStore\n\tOutputDir  string         // directory for step output files\n\tWires      []domain.Wire  // workflow wiring (for output mappings)\n\tHostRunID  string         // ID of the parent host run (set on child runs)\n}\n\nvar _ engine.StepExecutor = (*Executor)(nil)\n\n// Execute runs a single host workflow step.\nfunc (e *Executor) Execute(ctx context.Context, step *domain.Step) (string, error) {\n\tswitch step.Type {\n\tcase domain.StepTypeScript:\n\t\treturn e.executeScript(ctx, step)\n\tcase domain.StepTypeWorkflow:\n\t\treturn e.executeWorkflow(ctx, step)\n\tdefault:\n\t\treturn \"\", fmt.Errorf(\"unsupported step type %q in host workflow\", step.Type)\n\t}\n}\n\n// executeScript runs a shell command on the host.\nfunc (e *Executor) executeScript(ctx context.Context, step *domain.Step) (string, error) {\n\tcmdStr := step.Config[\"run\"]\n\tcmd := exec.CommandContext(ctx, \"sh\", \"-c\", cmdStr)\n\tcmd.Dir = e.ProjectDir\n\tcmd.Env = append(os.Environ(),\n\t\t\"CLOCHE_PROJECT_DIR=\"+e.ProjectDir,\n\t\t\"CLOCHE_STEP_OUTPUT=\"+e.stepOutputPath(step.Name),\n\t)\n\n\t// Pass previous step output if available\n\tif prevOutput := e.findPrevOutput(step); prevOutput != \"\" {\n\t\tcmd.Env = append(cmd.Env, \"CLOCHE_PREV_OUTPUT=\"+prevOutput)\n\t}\n\n\t// Resolve output mappings from wires and add as env vars\n\tif len(e.Wires) > 0 {\n\t\tmapped, err := e.resolveOutputMappings(step.Name, e.Wires)\n\t\tif err != nil {\n\t\t\treturn \"\", fmt.Errorf(\"resolving output mappings for step %q: %w\", step.Name, err)\n\t\t}\n\t\tcmd.Env = append(cmd.Env, mapped...)\n\t}\n\n\toutput, err := cmd.CombinedOutput()\n\n\t// Extract result marker\n\tmarkerResult, cleanOutput, found := protocol.ExtractResult(output)\n\n\t// Write output to file\n\tif mkErr := os.MkdirAll(e.OutputDir, 0755); mkErr == nil {\n\t\t_ = os.WriteFile(e.stepOutputPath(step.Name), cleanOutput, 0644)\n\t}\n\n\tif err != nil {\n\t\tif _, ok := err.(*exec.ExitError); ok {\n\t\t\tresult := \"fail\"\n\t\t\tif found {\n\t\t\t\tresult = markerResult\n\t\t\t}\n\t\t\treturn result, nil\n\t\t}\n\t\treturn \"\", err\n\t}\n\n\tresult := \"success\"\n\tif found {\n\t\tresult = markerResult\n\t}\n\treturn result, nil\n}\n\n// executeWorkflow dispatches a container workflow run and blocks until it completes.\nfunc (e *Executor) executeWorkflow(ctx context.Context, step *domain.Step) (string, error) {\n\tworkflowName := step.Config[\"workflow_name\"]\n\tif workflowName == \"\" {\n\t\treturn \"\", fmt.Errorf(\"workflow step %q missing workflow_name\", step.Name)\n\t}\n\n\t// Read prompt from previous step output or prompt_step override\n\tvar promptContent string\n\tpromptSource := step.Config[\"prompt_step\"]\n\tif promptSource != \"\" {\n\t\tdata, err := os.ReadFile(e.stepOutputPath(promptSource))\n\t\tif err == nil {\n\t\t\tpromptContent = string(data)\n\t\t}\n\t} else if prev := e.findPrevOutput(step); prev != \"\" {\n\t\tdata, err := os.ReadFile(prev)\n\t\tif err == nil {\n\t\t\tpromptContent = string(data)\n\t\t}\n\t}\n\n\tresp, err := e.Dispatcher.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n\t\tWorkflowName: workflowName,\n\t\tProjectDir:   e.ProjectDir,\n\t\tPrompt:       promptContent,\n\t})\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"dispatching workflow %q: %w\", workflowName, err)\n\t}\n\n\tlog.Printf(\"host executor: dispatched container workflow %q as run %s\", workflowName, resp.RunId)\n\n\t// Link child run to parent host run\n\tif e.HostRunID != \"\" {\n\t\tif childRun, err := e.Store.GetRun(ctx, resp.RunId); err == nil {\n\t\t\tchildRun.ParentRunID = e.HostRunID\n\t\t\t_ = e.Store.UpdateRun(ctx, childRun)\n\t\t}\n\t}\n\n\t// Write run ID to step output so downstream steps (e.g. merge) can find it\n\tif mkErr := os.MkdirAll(e.OutputDir, 0755); mkErr == nil {\n\t\t_ = os.WriteFile(e.stepOutputPath(step.Name), []byte(resp.RunId), 0644)\n\t}\n\n\t// Poll until the run reaches a terminal state\n\tstate, err := e.waitForRun(ctx, resp.RunId)\n\tif err != nil {\n\t\treturn \"\", fmt.Errorf(\"waiting for workflow %q run %s: %w\", workflowName, resp.RunId, err)\n\t}\n\n\tlog.Printf(\"host executor: workflow %q run %s completed with state %s\", workflowName, resp.RunId, state)\n\n\t// Map run state to step result\n\tif state == domain.RunStateSucceeded {\n\t\treturn \"success\", nil\n\t}\n\treturn \"fail\", nil\n}\n\n// waitForRun polls the store until the run reaches a terminal state.\nfunc (e *Executor) waitForRun(ctx context.Context, runID string) (domain.RunState, error) {\n\tticker := time.NewTicker(2 * time.Second)\n\tdefer ticker.Stop()\n\n\tfor {\n\t\tselect {\n\t\tcase <-ctx.Done():\n\t\t\treturn \"\", fmt.Errorf(\"context cancelled while waiting for run %s: %w\", runID, ctx.Err())\n\t\tcase <-ticker.C:\n\t\t\trun, err := e.Store.GetRun(ctx, runID)\n\t\t\tif err != nil {\n\t\t\t\tcontinue // transient error, retry\n\t\t\t}\n\t\t\tswitch run.State {\n\t\t\tcase domain.RunStateSucceeded, domain.RunStateFailed, domain.RunStateCancelled:\n\t\t\t\treturn run.State, nil\n\t\t\t}\n\t\t\t// Still pending or running, continue polling\n\t\t}\n\t}\n}\n\n// stepOutputPath returns the path for a step's output file.\nfunc (e *Executor) stepOutputPath(stepName string) string {\n\treturn filepath.Join(e.OutputDir, stepName+\".out\")\n}\n\n// findPrevOutput finds the output file from the step that wires into this one.\n// It checks prompt_step config first, then walks the wiring graph to find the\n// source step.\nfunc (e *Executor) findPrevOutput(step *domain.Step) string {\n\t// Explicit prompt_step config takes priority\n\tif ps := step.Config[\"prompt_step\"]; ps != \"\" {\n\t\tpath := e.stepOutputPath(ps)\n\t\tif _, err := os.Stat(path); err == nil {\n\t\t\treturn path\n\t\t}\n\t}\n\n\t// Walk wiring to find the step that feeds into this one\n\tfor _, w := range e.Wires {\n\t\tif w.To == step.Name {\n\t\t\tpath := e.stepOutputPath(w.From)\n\t\t\tif _, err := os.Stat(path); err == nil {\n\t\t\t\treturn path\n\t\t\t}\n\t\t}\n\t}\n\treturn \"\"\n}\n","numLines":236,"startLine":1,"totalLines":236}}}
