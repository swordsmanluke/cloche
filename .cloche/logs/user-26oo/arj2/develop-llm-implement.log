{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PrxfezR2QsAoGD4T4yL5vw","type":"tool_result","content":"     1→package main\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"fmt\"\n     6→\t\"net\"\n     7→\t\"net/http\"\n     8→\t\"os\"\n     9→\t\"os/signal\"\n    10→\t\"path/filepath\"\n    11→\t\"syscall\"\n    12→\n    13→\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    14→\t\"github.com/cloche-dev/cloche/internal/adapters/docker\"\n    15→\tadaptgrpc \"github.com/cloche-dev/cloche/internal/adapters/grpc\"\n    16→\t\"github.com/cloche-dev/cloche/internal/adapters/local\"\n    17→\t\"github.com/cloche-dev/cloche/internal/adapters/sqlite\"\n    18→\t\"github.com/cloche-dev/cloche/internal/adapters/web\"\n    19→\t\"github.com/cloche-dev/cloche/internal/config\"\n    20→\t\"github.com/cloche-dev/cloche/internal/evolution\"\n    21→\thostpkg \"github.com/cloche-dev/cloche/internal/host\"\n    22→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    23→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    24→\t\"google.golang.org/grpc\"\n    25→)\n    26→\n    27→func main() {\n    28→\t// Load global config file (~/.config/cloche/config)\n    29→\tglobalCfg, err := config.LoadGlobal()\n    30→\tif err != nil {\n    31→\t\tfmt.Fprintf(os.Stderr, \"warning: failed to load global config: %v\\n\", err)\n    32→\t\tdefaults := config.Config{}\n    33→\t\tglobalCfg = &defaults\n    34→\t}\n    35→\n    36→\tdbPath := envOrConfig(\"CLOCHE_DB\", globalCfg.Daemon.DB, \"cloche.db\")\n    37→\tlistenAddr := envOrConfig(\"CLOCHE_LISTEN\", globalCfg.Daemon.Listen, \"unix:///tmp/cloche.sock\")\n    38→\n    39→\tstore, err := sqlite.NewStore(dbPath)\n    40→\tif err != nil {\n    41→\t\tfmt.Fprintf(os.Stderr, \"failed to open store: %v\\n\", err)\n    42→\t\tos.Exit(1)\n    43→\t}\n    44→\tdefer store.Close()\n    45→\n    46→\t// Sweep stale runs from a previous daemon crash (pending or running with no live goroutine).\n    47→\tif n, err := store.FailStaleRuns(context.Background()); err != nil {\n    48→\t\tfmt.Fprintf(os.Stderr, \"warning: failed to sweep stale runs: %v\\n\", err)\n    49→\t} else if n > 0 {\n    50→\t\tfmt.Fprintf(os.Stderr, \"startup: marked %d stale run(s) as failed\\n\", n)\n    51→\t}\n    52→\n    53→\truntime, err := initRuntime(globalCfg)\n    54→\tif err != nil {\n    55→\t\tfmt.Fprintf(os.Stderr, \"failed to init runtime: %v\\n\", err)\n    56→\t\tos.Exit(1)\n    57→\t}\n    58→\n    59→\tdefaultImage := envOrConfig(\"CLOCHE_IMAGE\", globalCfg.Daemon.Image, \"cloche-agent:latest\")\n    60→\n    61→\tbroadcaster := logstream.NewBroadcaster()\n    62→\n    63→\tsrv := adaptgrpc.NewClocheServerWithCaptures(store, store, runtime, defaultImage)\n    64→\tsrv.SetLogStore(store)\n    65→\tsrv.SetLogBroadcaster(broadcaster)\n    66→\n    67→\t// Set up evolution trigger\n    68→\tevoTrigger := initEvolution(globalCfg, store, store)\n    69→\tif evoTrigger != nil {\n    70→\t\tsrv.SetEvolution(evoTrigger)\n    71→\t}\n    72→\n    73→\tgrpcServer := grpc.NewServer()\n    74→\tpb.RegisterClocheServiceServer(grpcServer, srv)\n    75→\n    76→\tsrv.SetShutdownFunc(func() { grpcServer.GracefulStop() })\n    77→\n    78→\tlis, err := listen(listenAddr)\n    79→\tif err != nil {\n    80→\t\tfmt.Fprintf(os.Stderr, \"failed to listen on %s: %v\\n\", listenAddr, err)\n    81→\t\tos.Exit(1)\n    82→\t}\n    83→\n    84→\tvar httpServer *http.Server\n    85→\tif httpAddr := envOrConfig(\"CLOCHE_HTTP\", globalCfg.Daemon.HTTP, \"\"); httpAddr != \"\" {\n    86→\t\twebOpts := []web.HandlerOption{\n    87→\t\t\tweb.WithContainerLogger(runtime),\n    88→\t\t\tweb.WithLogStore(store),\n    89→\t\t\tweb.WithLogBroadcaster(broadcaster),\n    90→\t\t}\n    91→\t\twebHandler, err := web.NewHandler(store, store, webOpts...)\n    92→\t\tif err != nil {\n    93→\t\t\tfmt.Fprintf(os.Stderr, \"failed to create web handler: %v\\n\", err)\n    94→\t\t\tos.Exit(1)\n    95→\t\t}\n    96→\t\thttpServer = &http.Server{Addr: httpAddr, Handler: webHandler}\n    97→\t\tgo func() {\n    98→\t\t\tfmt.Fprintf(os.Stderr, \"cloched web dashboard on http://%s\\n\", httpAddr)\n    99→\t\t\tif err := httpServer.ListenAndServe(); err != nil && err != http.ErrServerClosed {\n   100→\t\t\t\tfmt.Fprintf(os.Stderr, \"http server error: %v\\n\", err)\n   101→\t\t\t}\n   102→\t\t}()\n   103→\t}\n   104→\n   105→\t// Auto-execute main workflow for active projects\n   106→\tautoRunActiveProjects(store, srv)\n   107→\n   108→\tsigCh := make(chan os.Signal, 1)\n   109→\tsignal.Notify(sigCh, syscall.SIGTERM, syscall.SIGINT)\n   110→\tgo func() {\n   111→\t\t<-sigCh\n   112→\t\tif httpServer != nil {\n   113→\t\t\thttpServer.Close()\n   114→\t\t}\n   115→\t\tgrpcServer.GracefulStop()\n   116→\t}()\n   117→\n   118→\tfmt.Fprintf(os.Stderr, \"cloched listening on %s\\n\", listenAddr)\n   119→\tif err := grpcServer.Serve(lis); err != nil {\n   120→\t\tfmt.Fprintf(os.Stderr, \"server error: %v\\n\", err)\n   121→\t\tos.Exit(1)\n   122→\t}\n   123→}\n   124→\n   125→func initRuntime(cfg *config.Config) (ports.ContainerRuntime, error) {\n   126→\truntimeType := envOrConfig(\"CLOCHE_RUNTIME\", cfg.Daemon.Runtime, \"docker\")\n   127→\n   128→\tswitch runtimeType {\n   129→\tcase \"local\":\n   130→\t\tagentPath := envOrConfig(\"CLOCHE_AGENT_PATH\", cfg.Daemon.AgentPath, \"\")\n   131→\t\tif agentPath == \"\" {\n   132→\t\t\t// Look for cloche-agent next to this binary\n   133→\t\t\texe, err := os.Executable()\n   134→\t\t\tif err == nil {\n   135→\t\t\t\tagentPath = filepath.Join(filepath.Dir(exe), \"cloche-agent\")\n   136→\t\t\t} else {\n   137→\t\t\t\tagentPath = \"cloche-agent\"\n   138→\t\t\t}\n   139→\t\t}\n   140→\t\treturn local.NewRuntime(agentPath), nil\n   141→\tcase \"docker\":\n   142→\t\treturn docker.NewRuntime()\n   143→\tdefault:\n   144→\t\treturn nil, fmt.Errorf(\"unknown runtime: %s\", runtimeType)\n   145→\t}\n   146→}\n   147→\n   148→func initEvolution(globalCfg *config.Config, evoStore ports.EvolutionStore, capStore ports.CaptureStore) *evolution.Trigger {\n   149→\t// Load config from working directory (daemon-level defaults)\n   150→\tcfg, err := config.Load(\".\")\n   151→\tif err != nil || !cfg.Evolution.Enabled {\n   152→\t\treturn nil\n   153→\t}\n   154→\n   155→\tllmCmd := envOrConfig(\"CLOCHE_LLM_COMMAND\", globalCfg.Daemon.LLMCommand, \"\")\n   156→\tif llmCmd == \"\" {\n   157→\t\treturn nil\n   158→\t}\n   159→\n   160→\ttrigger := evolution.NewTrigger(evolution.TriggerConfig{\n   161→\t\tDebounceSeconds: cfg.Evolution.DebounceSeconds,\n   162→\t\tRunFunc: func(projectDir, workflowName, runID string) {\n   163→\t\t\t// Load per-project config for confidence threshold\n   164→\t\t\tprojCfg, err := config.Load(projectDir)\n   165→\t\t\tif err != nil {\n   166→\t\t\t\tprojCfg = cfg // fall back to daemon config\n   167→\t\t\t}\n   168→\n   169→\t\t\tllm := &evolution.CommandLLMClient{Command: llmCmd}\n   170→\t\t\torch := evolution.NewOrchestrator(evolution.OrchestratorConfig{\n   171→\t\t\t\tProjectDir:    projectDir,\n   172→\t\t\t\tWorkflowName:  workflowName,\n   173→\t\t\t\tLLM:           llm,\n   174→\t\t\t\tMinConfidence: projCfg.Evolution.MinConfidence,\n   175→\t\t\t})\n   176→\n   177→\t\t\tctx := context.Background()\n   178→\t\t\tif _, err := orch.Run(ctx, runID, evoStore, capStore); err != nil {\n   179→\t\t\t\tfmt.Fprintf(os.Stderr, \"evolution error for %s/%s: %v\\n\", projectDir, workflowName, err)\n   180→\t\t\t}\n   181→\t\t},\n   182→\t})\n   183→\n   184→\treturn trigger\n   185→}\n   186→\n   187→func listen(addr string) (net.Listener, error) {\n   188→\tif len(addr) > 7 && addr[:7] == \"unix://\" {\n   189→\t\tsockPath := addr[7:]\n   190→\t\tos.Remove(sockPath)\n   191→\t\treturn net.Listen(\"unix\", sockPath)\n   192→\t}\n   193→\treturn net.Listen(\"tcp\", addr)\n   194→}\n   195→\n   196→// autoRunActiveProjects scans known projects for active = true in their config,\n   197→// parses .cloche/host.cloche and executes the full host workflow step by step.\n   198→func autoRunActiveProjects(store ports.RunStore, srv *adaptgrpc.ClocheServer) {\n   199→\tctx := context.Background()\n   200→\tprojects, err := store.ListProjects(ctx)\n   201→\tif err != nil {\n   202→\t\tfmt.Fprintf(os.Stderr, \"startup: failed to list projects: %v\\n\", err)\n   203→\t\treturn\n   204→\t}\n   205→\n   206→\tfor _, projectDir := range projects {\n   207→\t\tcfg, err := config.Load(projectDir)\n   208→\t\tif err != nil || !cfg.Active {\n   209→\t\t\tcontinue\n   210→\t\t}\n   211→\n   212→\t\t// Verify host.cloche exists before launching\n   213→\t\thostPath := filepath.Join(projectDir, \".cloche\", \"host.cloche\")\n   214→\t\tif _, err := os.Stat(hostPath); err != nil {\n   215→\t\t\tfmt.Fprintf(os.Stderr, \"startup: skipping active project %s: %v\\n\", projectDir, err)\n   216→\t\t\tcontinue\n   217→\t\t}\n   218→\n   219→\t\tfmt.Fprintf(os.Stderr, \"startup: auto-running host workflow for active project %s\\n\", projectDir)\n   220→\t\tgo func(projDir string) {\n   221→\t\t\trunner := &hostpkg.Runner{\n   222→\t\t\t\tDispatcher: srv,\n   223→\t\t\t\tStore:      store,\n   224→\t\t\t}\n   225→\t\t\tresult, err := runner.Run(context.Background(), projDir)\n   226→\t\t\tif err != nil {\n   227→\t\t\t\tfmt.Fprintf(os.Stderr, \"startup: host workflow failed for %s: %v\\n\", projDir, err)\n   228→\t\t\t} else {\n   229→\t\t\t\tfmt.Fprintf(os.Stderr, \"startup: host workflow completed for %s: %s (run %s)\\n\", projDir, result.State, result.RunID)\n   230→\t\t\t}\n   231→\t\t}(projectDir)\n   232→\t}\n   233→}\n   234→\n   235→// envOrConfig returns the env var value if set, otherwise the config file\n   236→// value if non-empty, otherwise the fallback default.\n   237→func envOrConfig(envKey, configVal, fallback string) string {\n   238→\tif v := os.Getenv(envKey); v != \"\" {\n   239→\t\treturn v\n   240→\t}\n   241→\tif configVal != \"\" {\n   242→\t\treturn configVal\n   243→\t}\n   244→\treturn fallback\n   245→}\n   246→"}]},"parent_tool_use_id":"toolu_01K1PWN97AwX8v2MajgZU6tK","session_id":"86005800-dc4f-4a50-b6ae-f82ea613cda8","uuid":"e3961c1f-bcde-42f9-99bb-139e4b4c9a41"}
