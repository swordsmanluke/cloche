{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01W5bXA9CH2zWUo68BN9dd65","type":"tool_result","content":"     1→package config\n     2→\n     3→import (\n     4→\t\"os\"\n     5→\t\"path/filepath\"\n     6→\n     7→\t\"github.com/BurntSushi/toml\"\n     8→)\n     9→\n    10→type DaemonConfig struct {\n    11→\tListen     string `toml:\"listen\"`\n    12→\tHTTP       string `toml:\"http\"`\n    13→\tImage      string `toml:\"image\"`\n    14→\tDB         string `toml:\"db\"`\n    15→\tRuntime    string `toml:\"runtime\"`\n    16→\tAgentPath  string `toml:\"agent_path\"`\n    17→\tLLMCommand string `toml:\"llm_command\"`\n    18→}\n    19→\n    20→type EvolutionConfig struct {\n    21→\tEnabled          bool   `toml:\"enabled\"`\n    22→\tDebounceSeconds  int    `toml:\"debounce_seconds\"`\n    23→\tMinConfidence    string `toml:\"min_confidence\"`\n    24→\tMaxPromptBullets int    `toml:\"max_prompt_bullets\"`\n    25→}\n    26→\n    27→type OrchestrationConfig struct {\n    28→\tConcurrency    int     `toml:\"concurrency\"`\n    29→\tStaggerSeconds float64 `toml:\"stagger_seconds\"`\n    30→}\n    31→\n    32→type Config struct {\n    33→\tActive        bool                `toml:\"active\"`\n    34→\tDaemon        DaemonConfig        `toml:\"daemon\"`\n    35→\tEvolution     EvolutionConfig     `toml:\"evolution\"`\n    36→\tOrchestration OrchestrationConfig `toml:\"orchestration\"`\n    37→}\n    38→\n    39→func defaults() Config {\n    40→\treturn Config{\n    41→\t\tEvolution: EvolutionConfig{\n    42→\t\t\tEnabled:          true,\n    43→\t\t\tDebounceSeconds:  30,\n    44→\t\t\tMinConfidence:    \"medium\",\n    45→\t\t\tMaxPromptBullets: 50,\n    46→\t\t},\n    47→\t\tOrchestration: OrchestrationConfig{\n    48→\t\t\tConcurrency:    1,\n    49→\t\t\tStaggerSeconds: 1.0,\n    50→\t\t},\n    51→\t}\n    52→}\n    53→\n    54→// Load reads a per-project config from <projectDir>/.cloche/config.toml.\n    55→func Load(projectDir string) (*Config, error) {\n    56→\tcfg := defaults()\n    57→\tpath := filepath.Join(projectDir, \".cloche\", \"config.toml\")\n    58→\n    59→\tdata, err := os.ReadFile(path)\n    60→\tif os.IsNotExist(err) {\n    61→\t\treturn &cfg, nil\n    62→\t}\n    63→\tif err != nil {\n    64→\t\treturn nil, err\n    65→\t}\n    66→\n    67→\tif _, err := toml.Decode(string(data), &cfg); err != nil {\n    68→\t\treturn nil, err\n    69→\t}\n    70→\treturn &cfg, nil\n    71→}\n    72→\n    73→// LoadGlobal reads the global daemon config from ~/.config/cloche/config.\n    74→// Returns defaults if the file does not exist.\n    75→func LoadGlobal() (*Config, error) {\n    76→\tcfg := defaults()\n    77→\n    78→\thome, err := os.UserHomeDir()\n    79→\tif err != nil {\n    80→\t\treturn &cfg, nil\n    81→\t}\n    82→\n    83→\tpath := filepath.Join(home, \".config\", \"cloche\", \"config\")\n    84→\tdata, err := os.ReadFile(path)\n    85→\tif os.IsNotExist(err) {\n    86→\t\treturn &cfg, nil\n    87→\t}\n    88→\tif err != nil {\n    89→\t\treturn nil, err\n    90→\t}\n    91→\n    92→\tif _, err := toml.Decode(string(data), &cfg); err != nil {\n    93→\t\treturn nil, err\n    94→\t}\n    95→\treturn &cfg, nil\n    96→}\n    97→\n    98→// LoadGlobalFrom reads the global config from a specific path.\n    99→// Useful for testing.\n   100→func LoadGlobalFrom(path string) (*Config, error) {\n   101→\tcfg := defaults()\n   102→\n   103→\tdata, err := os.ReadFile(path)\n   104→\tif os.IsNotExist(err) {\n   105→\t\treturn &cfg, nil\n   106→\t}\n   107→\tif err != nil {\n   108→\t\treturn nil, err\n   109→\t}\n   110→\n   111→\tif _, err := toml.Decode(string(data), &cfg); err != nil {\n   112→\t\treturn nil, err\n   113→\t}\n   114→\treturn &cfg, nil\n   115→}\n   116→"}]},"parent_tool_use_id":"toolu_019ypLfX9L3BfCTvo4W2Nw4T","session_id":"86005800-dc4f-4a50-b6ae-f82ea613cda8","uuid":"3780f79c-30f6-47f5-be7c-e81f739a07f7"}
