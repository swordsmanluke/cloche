[2026-03-07T16:43:42Z] [llm] {"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QPwJuFGANUs4aBYknaS88n","type":"tool_result","content":"     1→package evolution\n     2→\n     3→import (\n     4→\t\"context\"\n     5→\t\"encoding/json\"\n     6→\t\"os\"\n     7→\t\"path/filepath\"\n     8→\t\"strings\"\n     9→\t\"testing\"\n    10→\n    11→\t\"github.com/stretchr/testify/assert\"\n    12→\t\"github.com/stretchr/testify/require\"\n    13→)\n    14→\n    15→// fakeLLM returns a fixed response for testing.\n    16→type fakeLLM struct {\n    17→\tresponse string\n    18→}\n    19→\n    20→func (f *fakeLLM) Complete(ctx context.Context, system, user string) (string, error) {\n    21→\treturn f.response, nil\n    22→}\n    23→\n    24→// --- Collector tests ---\n    25→\n    26→func TestCollectorGathersData(t *testing.T) {\n    27→\tdir := t.TempDir()\n    28→\n    29→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\"), 0755)\n    30→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n    31→\tos.WriteFile(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\", \"develop.md\"),\n    32→\t\t[]byte(\"# Knowledge Base\\n\"), 0644)\n    33→\tos.WriteFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"),\n    34→\t\t[]byte(\"Write good code\"), 0644)\n    35→\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n    36→\t\t[]byte(`workflow \"develop\" {\n    37→  step impl {\n    38→    prompt = file(\".cloche/prompts/implement.md\")\n    39→    results = [success]\n    40→  }\n    41→  impl:success -> done\n    42→}`), 0644)\n    43→\n    44→\tc := &Collector{ProjectDir: dir, WorkflowName: \"develop\"}\n    45→\tdata, err := c.Collect(context.Background(), nil, nil)\n    46→\trequire.NoError(t, err)\n    47→\n    48→\tassert.Equal(t, \"# Knowledge Base\\n\", data.KnowledgeBase)\n    49→\tassert.Contains(t, data.CurrentPrompts, \".cloche/prompts/implement.md\")\n    50→\tassert.Equal(t, \"Write good code\", data.CurrentPrompts[\".cloche/prompts/implement.md\"])\n    51→\tassert.NotEmpty(t, data.CurrentWorkflow)\n    52→\tassert.Equal(t, dir, data.ProjectDir)\n    53→\tassert.Equal(t, \"develop\", data.WorkflowName)\n    54→}\n    55→\n    56→func TestCollectorNoKnowledgeBase(t *testing.T) {\n    57→\tdir := t.TempDir()\n    58→\tos.MkdirAll(filepath.Join(dir, \".cloche\"), 0755)\n    59→\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n    60→\t\t[]byte(`workflow \"develop\" { step s { run = \"echo hi\" results = [success] } s:success -> done }`), 0644)\n    61→\n    62→\tc := &Collector{ProjectDir: dir, WorkflowName: \"develop\"}\n    63→\tdata, err := c.Collect(context.Background(), nil, nil)\n    64→\trequire.NoError(t, err)\n    65→\tassert.Empty(t, data.KnowledgeBase)\n    66→}\n    67→\n    68→func TestExtractPromptFiles(t *testing.T) {\n    69→\tworkflow := `step impl { prompt = file(\".cloche/prompts/implement.md\") }\n    70→step fix { prompt = file(\".cloche/prompts/fix.md\") }\n    71→step test { run = \"make test\" }`\n    72→\n    73→\tfiles := extractPromptFiles(workflow)\n    74→\tassert.Len(t, files, 2)\n    75→\tassert.Contains(t, files, \".cloche/prompts/implement.md\")\n    76→\tassert.Contains(t, files, \".cloche/prompts/fix.md\")\n    77→}\n    78→\n    79→// --- Classifier tests ---\n    80→\n    81→func TestClassifierCategorizesRun(t *testing.T) {\n    82→\ttests := []struct {\n    83→\t\tname     string\n    84→\t\tresponse string\n    85→\t\texpected string\n    86→\t}{\n    87→\t\t{\"bug\", `{\"classification\": \"bug\"}`, \"bug\"},\n    88→\t\t{\"feature\", `{\"classification\": \"feature\"}`, \"feature\"},\n    89→\t\t{\"feedback\", `{\"classification\": \"feedback\"}`, \"feedback\"},\n    90→\t\t{\"enhancement\", `{\"classification\": \"enhancement\"}`, \"enhancement\"},\n    91→\t\t{\"chore\", `{\"classification\": \"chore\"}`, \"chore\"},\n    92→\t\t{\"invalid defaults to feature\", `{\"classification\": \"unknown\"}`, \"feature\"},\n    93→\t\t{\"malformed JSON defaults to feature\", `not json`, \"feature\"},\n    94→\t}\n    95→\n    96→\tfor _, tt := range tests {\n    97→\t\tt.Run(tt.name, func(t *testing.T) {\n    98→\t\t\tllm := &fakeLLM{response: tt.response}\n    99→\t\t\tc := &Classifier{LLM: llm}\n   100→\t\t\tresult, err := c.Classify(context.Background(), \"some prompt\")\n   101→\t\t\trequire.NoError(t, err)\n   102→\t\t\tassert.Equal(t, tt.expected, result)\n   103→\t\t})\n   104→\t}\n   105→}\n   106→\n   107→// --- Reflector tests ---\n   108→\n   109→func TestReflectorExtractsLessons(t *testing.T) {\n   110→\tlessonsJSON, _ := json.Marshal(map[string]any{\n   111→\t\t\"lessons\": []map[string]any{\n   112→\t\t\t{\n   113→\t\t\t\t\"id\":               \"lesson-001\",\n   114→\t\t\t\t\"category\":         \"prompt_improvement\",\n   115→\t\t\t\t\"target\":           \".cloche/prompts/implement.md\",\n   116→\t\t\t\t\"insight\":          \"Agent produces unsanitized HTML\",\n   117→\t\t\t\t\"suggested_action\": \"Add sanitization rule\",\n   118→\t\t\t\t\"evidence\":         []string{\"run-1\", \"run-2\"},\n   119→\t\t\t\t\"confidence\":       \"high\",\n   120→\t\t\t},\n   121→\t\t},\n   122→\t})\n   123→\n   124→\tllm := &fakeLLM{response: string(lessonsJSON)}\n   125→\tr := &Reflector{LLM: llm, MinConfidence: \"medium\"}\n   126→\n   127→\tdata := &CollectedData{WorkflowName: \"develop\", KnowledgeBase: \"# KB\\n\"}\n   128→\tlessons, err := r.Reflect(context.Background(), data, \"bug\")\n   129→\trequire.NoError(t, err)\n   130→\trequire.Len(t, lessons, 1)\n   131→\tassert.Equal(t, \"prompt_improvement\", lessons[0].Category)\n   132→\tassert.Equal(t, \"high\", lessons[0].Confidence)\n   133→}\n   134→\n   135→func TestReflectorFiltersLowConfidence(t *testing.T) {\n   136→\tlessonsJSON, _ := json.Marshal(map[string]any{\n   137→\t\t\"lessons\": []map[string]any{\n   138→\t\t\t{\"id\": \"L1\", \"category\": \"new_step\", \"confidence\": \"low\"},\n   139→\t\t\t{\"id\": \"L2\", \"category\": \"prompt_improvement\", \"confidence\": \"high\"},\n   140→\t\t},\n   141→\t})\n   142→\n   143→\tllm := &fakeLLM{response: string(lessonsJSON)}\n   144→\tr := &Reflector{LLM: llm, MinConfidence: \"medium\"}\n   145→\n   146→\tlessons, err := r.Reflect(context.Background(), &CollectedData{}, \"bug\")\n   147→\trequire.NoError(t, err)\n   148→\tassert.Len(t, lessons, 1)\n   149→\tassert.Equal(t, \"L2\", lessons[0].ID)\n   150→}\n   151→\n   152→func TestConfidenceLevel(t *testing.T) {\n   153→\tassert.Equal(t, 3, confidenceLevel(\"high\"))\n   154→\tassert.Equal(t, 2, confidenceLevel(\"medium\"))\n   155→\tassert.Equal(t, 1, confidenceLevel(\"low\"))\n   156→\tassert.Equal(t, 0, confidenceLevel(\"\"))\n   157→}\n   158→\n   159→// --- Audit Logger tests ---\n   160→\n   161→func TestAuditLoggerAppendsJSONL(t *testing.T) {\n   162→\tdir := t.TempDir()\n   163→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\"), 0755)\n   164→\n   165→\tlogger := &AuditLogger{ProjectDir: dir}\n   166→\n   167→\tresult1 := &EvolutionResult{\n   168→\t\tID:           \"evo-1\",\n   169→\t\tWorkflowName: \"develop\",\n   170→\t\tChanges:      []Change{{Type: \"prompt_update\", File: \".cloche/prompts/impl.md\"}},\n   171→\t}\n   172→\trequire.NoError(t, logger.Log(result1))\n   173→\n   174→\tresult2 := &EvolutionResult{\n   175→\t\tID:           \"evo-2\",\n   176→\t\tWorkflowName: \"develop\",\n   177→\t\tChanges:      []Change{{Type: \"add_step\", File: \".cloche/develop.cloche\"}},\n   178→\t}\n   179→\trequire.NoError(t, logger.Log(result2))\n   180→\n   181→\tcontent, err := os.ReadFile(filepath.Join(dir, \".cloche\", \"evolution\", \"log.jsonl\"))\n   182→\trequire.NoError(t, err)\n   183→\n   184→\tlines := strings.Split(strings.TrimSpace(string(content)), \"\\n\")\n   185→\tassert.Len(t, lines, 2)\n   186→\n   187→\tvar entry1 EvolutionResult\n   188→\trequire.NoError(t, json.Unmarshal([]byte(lines[0]), &entry1))\n   189→\tassert.Equal(t, \"evo-1\", entry1.ID)\n   190→}\n   191→\n   192→func TestAuditLoggerSnapshot(t *testing.T) {\n   193→\tdir := t.TempDir()\n   194→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n   195→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n   196→\tos.WriteFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"), []byte(\"original content\"), 0644)\n   197→\n   198→\tlogger := &AuditLogger{ProjectDir: dir}\n   199→\tsnapName, err := logger.Snapshot(\".cloche/prompts/implement.md\")\n   200→\trequire.NoError(t, err)\n   201→\tassert.NotEmpty(t, snapName)\n   202→\n   203→\tsnapPath := filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\", snapName)\n   204→\tcontent, err := os.ReadFile(snapPath)\n   205→\trequire.NoError(t, err)\n   206→\tassert.Equal(t, \"original content\", string(content))\n   207→}\n   208→\n   209→func TestAuditLoggerUpdatesKnowledge(t *testing.T) {\n   210→\tdir := t.TempDir()\n   211→\tkbDir := filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\")\n   212→\tos.MkdirAll(kbDir, 0755)\n   213→\tos.WriteFile(filepath.Join(kbDir, \"develop.md\"), []byte(\"# Knowledge Base: develop workflow\\n\"), 0644)\n   214→\n   215→\tlogger := &AuditLogger{ProjectDir: dir}\n   216→\tlessons := []Lesson{\n   217→\t\t{\n   218→\t\t\tID:              \"P001\",\n   219→\t\t\tCategory:        \"prompt_improvement\",\n   220→\t\t\tConfidence:      \"high\",\n   221→\t\t\tInsight:         \"Always sanitize HTML inputs\",\n   222→\t\t\tSuggestedAction: \"Add rule to implement prompt\",\n   223→\t\t\tEvidence:        []string{\"run-1\", \"run-2\"},\n   224→\t\t},\n   225→\t}\n   226→\n   227→\trequire.NoError(t, logger.UpdateKnowledge(\"develop\", lessons))\n   228→\n   229→\tcontent, err := os.ReadFile(filepath.Join(kbDir, \"develop.md\"))\n   230→\trequire.NoError(t, err)\n   231→\tassert.Contains(t, string(content), \"[P001]\")\n   232→\tassert.Contains(t, string(content), \"sanitize HTML\")\n   233→\tassert.Contains(t, string(content), \"run-1, run-2\")\n   234→}\n   235→\n   236→// --- LLM Client tests ---\n   237→\n   238→// --- Curator tests ---\n   239→\n   240→func TestCuratorUpdatesPrompt(t *testing.T) {\n   241→\tdir := t.TempDir()\n   242→\tpromptPath := filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\")\n   243→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n   244→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n   245→\tos.WriteFile(promptPath, []byte(\"# Implementation Prompt\\n\\nWrite good code.\\n\"), 0644)\n   246→\n   247→\tupdatedContent := \"# Implementation Prompt\\n\\nWrite good code.\\n\\n## Learned Rules\\n\\n- Always sanitize user inputs\\n\"\n   248→\tllm := &fakeLLM{response: updatedContent}\n   249→\n   250→\taudit := &AuditLogger{ProjectDir: dir}\n   251→\tc := &Curator{LLM: llm, Audit: audit}\n   252→\tlesson := &Lesson{\n   253→\t\tID:              \"lesson-001\",\n   254→\t\tCategory:        \"prompt_improvement\",\n   255→\t\tTarget:          \".cloche/prompts/implement.md\",\n   256→\t\tInsight:         \"XSS vulnerabilities in form handlers\",\n   257→\t\tSuggestedAction: \"Add sanitization rule\",\n   258→\t}\n   259→\n   260→\tchange, err := c.Apply(context.Background(), dir, lesson)\n   261→\trequire.NoError(t, err)\n   262→\tassert.Equal(t, \"prompt_update\", change.Type)\n   263→\tassert.Equal(t, \".cloche/prompts/implement.md\", change.File)\n   264→\tassert.NotEmpty(t, change.Snapshot)\n   265→\n   266→\tcontent, err := os.ReadFile(promptPath)\n   267→\trequire.NoError(t, err)\n   268→\tassert.Contains(t, string(content), \"sanitize user inputs\")\n   269→}\n   270→\n   271→// --- Script Generator tests ---\n   272→\n   273→func TestScriptGeneratorCreatesScript(t *testing.T) {\n   274→\tdir := t.TempDir()\n   275→\n   276→\tllm := &fakeLLM{response: `{\"path\": \"scripts/security-scan.sh\", \"content\": \"#!/bin/bash\\ngosec ./...\"}`}\n   277→\tg := &ScriptGenerator{LLM: llm}\n   278→\n   279→\tlesson := &Lesson{\n   280→\t\tID:              \"lesson-001\",\n   281→\t\tCategory:        \"new_step\",\n   282→\t\tStepType:        \"script\",\n   283→\t\tInsight:         \"No security scanning\",\n   284→\t\tSuggestedAction: \"Add gosec security scan\",\n   285→\t}\n   286→\n   287→\tresult, err := g.Generate(context.Background(), dir, lesson)\n   288→\trequire.NoError(t, err)\n   289→\tassert.Equal(t, \"scripts/security-scan.sh\", result.Path)\n   290→\n   291→\tcontent, err := os.ReadFile(filepath.Join(dir, \"scripts\", \"security-scan.sh\"))\n   292→\trequire.NoError(t, err)\n   293→\tassert.Contains(t, string(content), \"gosec\")\n   294→\n   295→\tinfo, err := os.Stat(filepath.Join(dir, \"scripts\", \"security-scan.sh\"))\n   296→\trequire.NoError(t, err)\n   297→\tassert.NotZero(t, info.Mode()&0111) // executable\n   298→}\n   299→\n   300→// --- LLM Client tests ---\n   301→\n   302→func TestCommandLLMClient(t *testing.T) {\n   303→\tc := &CommandLLMClient{Command: \"cat\", Args: []string{}}\n   304→\tresult, err := c.Complete(context.Background(), \"system\", \"user prompt\")\n   305→\trequire.NoError(t, err)\n   306→\tassert.Contains(t, result, \"user prompt\")\n   307→\tassert.Contains(t, result, \"system\")\n   308→}\n   309→\n   310→// --- Orchestrator tests ---\n   311→\n   312→// scriptedLLM returns responses in order.\n   313→type scriptedLLM struct {\n   314→\tresponses []string\n   315→\tidx       int\n   316→}\n   317→\n   318→func (s *scriptedLLM) Complete(ctx context.Context, system, user string) (string, error) {\n   319→\tresp := s.responses[s.idx]\n   320→\ts.idx++\n   321→\treturn resp, nil\n   322→}\n   323→\n   324→func TestOrchestratorEndToEnd(t *testing.T) {\n   325→\tdir := t.TempDir()\n   326→\n   327→\t// Set up project structure\n   328→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\"), 0755)\n   329→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n   330→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n   331→\tos.WriteFile(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\", \"develop.md\"),\n   332→\t\t[]byte(\"# Knowledge Base: develop\\n\"), 0644)\n   333→\tos.WriteFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"),\n   334→\t\t[]byte(\"Write good code.\\n\"), 0644)\n   335→\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n   336→\t\t[]byte(`workflow \"develop\" {\n   337→  step implement {\n   338→    prompt = file(\".cloche/prompts/implement.md\")\n   339→    results = [success, fail]\n   340→  }\n   341→  step test {\n   342→    run = \"make test\"\n   343→    results = [success, fail]\n   344→  }\n   345→  implement:success -> test\n   346→  test:success -> done\n   347→  test:fail -> abort\n   348→}`), 0644)\n   349→\n   350→\t// Fake LLM that returns appropriate responses per stage\n   351→\tllm := &scriptedLLM{\n   352→\t\tresponses: []string{\n   353→\t\t\t// Classifier\n   354→\t\t\t`{\"classification\": \"bug\"}`,\n   355→\t\t\t// Reflector\n   356→\t\t\t`{\"lessons\": [{\"id\": \"L001\", \"category\": \"prompt_improvement\", \"target\": \".cloche/prompts/implement.md\", \"insight\": \"XSS pattern\", \"suggested_action\": \"Add sanitization rule\", \"evidence\": [\"run-1\"], \"confidence\": \"high\"}]}`,\n   357→\t\t\t// Curator\n   358→\t\t\t\"Write good code.\\n\\n## Learned Rules\\n\\n- Always sanitize user inputs\\n\",\n   359→\t\t},\n   360→\t}\n   361→\n   362→\torch := NewOrchestrator(OrchestratorConfig{\n   363→\t\tProjectDir:    dir,\n   364→\t\tWorkflowName:  \"develop\",\n   365→\t\tLLM:           llm,\n   366→\t\tMinConfidence: \"medium\",\n   367→\t})\n   368→\n   369→\tresult, err := orch.Run(context.Background(), \"run-1\", nil, nil)\n   370→\trequire.NoError(t, err)\n   371→\tassert.Equal(t, \"bug\", result.Classification)\n   372→\trequire.Len(t, result.Changes, 1)\n   373→\tassert.Equal(t, \"prompt_update\", result.Changes[0].Type)\n   374→\n   375→\t// Verify prompt was actually updated\n   376→\tcontent, _ := os.ReadFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"))\n   377→\tassert.Contains(t, string(content), \"sanitize user inputs\")\n   378→\n   379→\t// Verify audit log was written\n   380→\tlogContent, _ := os.ReadFile(filepath.Join(dir, \".cloche\", \"evolution\", \"log.jsonl\"))\n   381→\tassert.Contains(t, string(logContent), \"prompt_update\")\n   382→\tassert.Contains(t, string(logContent), \"XSS pattern\")\n   383→\n   384→\t// Verify knowledge base was updated\n   385→\tkbContent, _ := os.ReadFile(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\", \"develop.md\"))\n   386→\tassert.Contains(t, string(kbContent), \"L001\")\n   387→}\n   388→\n   389→func TestOrchestratorNoLessons(t *testing.T) {\n   390→\tdir := t.TempDir()\n   391→\n   392→\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\"), 0755)\n   393→\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n   394→\t\t[]byte(`workflow \"develop\" {\n   395→  step s {\n   396→    run = \"echo hi\"\n   397→    results = [success]\n   398→  }\n   399→  s:success -> done\n   400→}`), 0644)\n   401→\n   402→\tllm := &scriptedLLM{\n   403→\t\tresponses: []string{\n   404→\t\t\t// Classifier\n   405→\t\t\t`{\"classification\": \"feature\"}`,\n   406→\t\t\t// Reflector — no lessons\n   407→\t\t\t`{\"lessons\": []}`,\n   408→\t\t},\n   409→\t}\n   410→\n   411→\torch := NewOrchestrator(OrchestratorConfig{\n   412→\t\tProjectDir:    dir,\n   413→\t\tWorkflowName:  \"develop\",\n   414→\t\tLLM:           llm,\n   415→\t\tMinConfidence: \"medium\",\n   416→\t})\n   417→\n   418→\tresult, err := orch.Run(context.Background(), \"run-1\", nil, nil)\n   419→\trequire.NoError(t, err)\n   420→\tassert.Equal(t, \"feature\", result.Classification)\n   421→\tassert.Empty(t, result.Changes)\n   422→}\n   423→"}]},"parent_tool_use_id":null,"session_id":"97413514-e330-41c8-96f2-9637de070141","uuid":"0dfbc149-5818-4bb8-9ca9-b4856d8ad6a2","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/evolution/evolution_test.go","content":"package evolution\n\nimport (\n\t\"context\"\n\t\"encoding/json\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"strings\"\n\t\"testing\"\n\n\t\"github.com/stretchr/testify/assert\"\n\t\"github.com/stretchr/testify/require\"\n)\n\n// fakeLLM returns a fixed response for testing.\ntype fakeLLM struct {\n\tresponse string\n}\n\nfunc (f *fakeLLM) Complete(ctx context.Context, system, user string) (string, error) {\n\treturn f.response, nil\n}\n\n// --- Collector tests ---\n\nfunc TestCollectorGathersData(t *testing.T) {\n\tdir := t.TempDir()\n\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\"), 0755)\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\", \"develop.md\"),\n\t\t[]byte(\"# Knowledge Base\\n\"), 0644)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"),\n\t\t[]byte(\"Write good code\"), 0644)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n\t\t[]byte(`workflow \"develop\" {\n  step impl {\n    prompt = file(\".cloche/prompts/implement.md\")\n    results = [success]\n  }\n  impl:success -> done\n}`), 0644)\n\n\tc := &Collector{ProjectDir: dir, WorkflowName: \"develop\"}\n\tdata, err := c.Collect(context.Background(), nil, nil)\n\trequire.NoError(t, err)\n\n\tassert.Equal(t, \"# Knowledge Base\\n\", data.KnowledgeBase)\n\tassert.Contains(t, data.CurrentPrompts, \".cloche/prompts/implement.md\")\n\tassert.Equal(t, \"Write good code\", data.CurrentPrompts[\".cloche/prompts/implement.md\"])\n\tassert.NotEmpty(t, data.CurrentWorkflow)\n\tassert.Equal(t, dir, data.ProjectDir)\n\tassert.Equal(t, \"develop\", data.WorkflowName)\n}\n\nfunc TestCollectorNoKnowledgeBase(t *testing.T) {\n\tdir := t.TempDir()\n\tos.MkdirAll(filepath.Join(dir, \".cloche\"), 0755)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n\t\t[]byte(`workflow \"develop\" { step s { run = \"echo hi\" results = [success] } s:success -> done }`), 0644)\n\n\tc := &Collector{ProjectDir: dir, WorkflowName: \"develop\"}\n\tdata, err := c.Collect(context.Background(), nil, nil)\n\trequire.NoError(t, err)\n\tassert.Empty(t, data.KnowledgeBase)\n}\n\nfunc TestExtractPromptFiles(t *testing.T) {\n\tworkflow := `step impl { prompt = file(\".cloche/prompts/implement.md\") }\nstep fix { prompt = file(\".cloche/prompts/fix.md\") }\nstep test { run = \"make test\" }`\n\n\tfiles := extractPromptFiles(workflow)\n\tassert.Len(t, files, 2)\n\tassert.Contains(t, files, \".cloche/prompts/implement.md\")\n\tassert.Contains(t, files, \".cloche/prompts/fix.md\")\n}\n\n// --- Classifier tests ---\n\nfunc TestClassifierCategorizesRun(t *testing.T) {\n\ttests := []struct {\n\t\tname     string\n\t\tresponse string\n\t\texpected string\n\t}{\n\t\t{\"bug\", `{\"classification\": \"bug\"}`, \"bug\"},\n\t\t{\"feature\", `{\"classification\": \"feature\"}`, \"feature\"},\n\t\t{\"feedback\", `{\"classification\": \"feedback\"}`, \"feedback\"},\n\t\t{\"enhancement\", `{\"classification\": \"enhancement\"}`, \"enhancement\"},\n\t\t{\"chore\", `{\"classification\": \"chore\"}`, \"chore\"},\n\t\t{\"invalid defaults to feature\", `{\"classification\": \"unknown\"}`, \"feature\"},\n\t\t{\"malformed JSON defaults to feature\", `not json`, \"feature\"},\n\t}\n\n\tfor _, tt := range tests {\n\t\tt.Run(tt.name, func(t *testing.T) {\n\t\t\tllm := &fakeLLM{response: tt.response}\n\t\t\tc := &Classifier{LLM: llm}\n\t\t\tresult, err := c.Classify(context.Background(), \"some prompt\")\n\t\t\trequire.NoError(t, err)\n\t\t\tassert.Equal(t, tt.expected, result)\n\t\t})\n\t}\n}\n\n// --- Reflector tests ---\n\nfunc TestReflectorExtractsLessons(t *testing.T) {\n\tlessonsJSON, _ := json.Marshal(map[string]any{\n\t\t\"lessons\": []map[string]any{\n\t\t\t{\n\t\t\t\t\"id\":               \"lesson-001\",\n\t\t\t\t\"category\":         \"prompt_improvement\",\n\t\t\t\t\"target\":           \".cloche/prompts/implement.md\",\n\t\t\t\t\"insight\":          \"Agent produces unsanitized HTML\",\n\t\t\t\t\"suggested_action\": \"Add sanitization rule\",\n\t\t\t\t\"evidence\":         []string{\"run-1\", \"run-2\"},\n\t\t\t\t\"confidence\":       \"high\",\n\t\t\t},\n\t\t},\n\t})\n\n\tllm := &fakeLLM{response: string(lessonsJSON)}\n\tr := &Reflector{LLM: llm, MinConfidence: \"medium\"}\n\n\tdata := &CollectedData{WorkflowName: \"develop\", KnowledgeBase: \"# KB\\n\"}\n\tlessons, err := r.Reflect(context.Background(), data, \"bug\")\n\trequire.NoError(t, err)\n\trequire.Len(t, lessons, 1)\n\tassert.Equal(t, \"prompt_improvement\", lessons[0].Category)\n\tassert.Equal(t, \"high\", lessons[0].Confidence)\n}\n\nfunc TestReflectorFiltersLowConfidence(t *testing.T) {\n\tlessonsJSON, _ := json.Marshal(map[string]any{\n\t\t\"lessons\": []map[string]any{\n\t\t\t{\"id\": \"L1\", \"category\": \"new_step\", \"confidence\": \"low\"},\n\t\t\t{\"id\": \"L2\", \"category\": \"prompt_improvement\", \"confidence\": \"high\"},\n\t\t},\n\t})\n\n\tllm := &fakeLLM{response: string(lessonsJSON)}\n\tr := &Reflector{LLM: llm, MinConfidence: \"medium\"}\n\n\tlessons, err := r.Reflect(context.Background(), &CollectedData{}, \"bug\")\n\trequire.NoError(t, err)\n\tassert.Len(t, lessons, 1)\n\tassert.Equal(t, \"L2\", lessons[0].ID)\n}\n\nfunc TestConfidenceLevel(t *testing.T) {\n\tassert.Equal(t, 3, confidenceLevel(\"high\"))\n\tassert.Equal(t, 2, confidenceLevel(\"medium\"))\n\tassert.Equal(t, 1, confidenceLevel(\"low\"))\n\tassert.Equal(t, 0, confidenceLevel(\"\"))\n}\n\n// --- Audit Logger tests ---\n\nfunc TestAuditLoggerAppendsJSONL(t *testing.T) {\n\tdir := t.TempDir()\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\"), 0755)\n\n\tlogger := &AuditLogger{ProjectDir: dir}\n\n\tresult1 := &EvolutionResult{\n\t\tID:           \"evo-1\",\n\t\tWorkflowName: \"develop\",\n\t\tChanges:      []Change{{Type: \"prompt_update\", File: \".cloche/prompts/impl.md\"}},\n\t}\n\trequire.NoError(t, logger.Log(result1))\n\n\tresult2 := &EvolutionResult{\n\t\tID:           \"evo-2\",\n\t\tWorkflowName: \"develop\",\n\t\tChanges:      []Change{{Type: \"add_step\", File: \".cloche/develop.cloche\"}},\n\t}\n\trequire.NoError(t, logger.Log(result2))\n\n\tcontent, err := os.ReadFile(filepath.Join(dir, \".cloche\", \"evolution\", \"log.jsonl\"))\n\trequire.NoError(t, err)\n\n\tlines := strings.Split(strings.TrimSpace(string(content)), \"\\n\")\n\tassert.Len(t, lines, 2)\n\n\tvar entry1 EvolutionResult\n\trequire.NoError(t, json.Unmarshal([]byte(lines[0]), &entry1))\n\tassert.Equal(t, \"evo-1\", entry1.ID)\n}\n\nfunc TestAuditLoggerSnapshot(t *testing.T) {\n\tdir := t.TempDir()\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"), []byte(\"original content\"), 0644)\n\n\tlogger := &AuditLogger{ProjectDir: dir}\n\tsnapName, err := logger.Snapshot(\".cloche/prompts/implement.md\")\n\trequire.NoError(t, err)\n\tassert.NotEmpty(t, snapName)\n\n\tsnapPath := filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\", snapName)\n\tcontent, err := os.ReadFile(snapPath)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"original content\", string(content))\n}\n\nfunc TestAuditLoggerUpdatesKnowledge(t *testing.T) {\n\tdir := t.TempDir()\n\tkbDir := filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\")\n\tos.MkdirAll(kbDir, 0755)\n\tos.WriteFile(filepath.Join(kbDir, \"develop.md\"), []byte(\"# Knowledge Base: develop workflow\\n\"), 0644)\n\n\tlogger := &AuditLogger{ProjectDir: dir}\n\tlessons := []Lesson{\n\t\t{\n\t\t\tID:              \"P001\",\n\t\t\tCategory:        \"prompt_improvement\",\n\t\t\tConfidence:      \"high\",\n\t\t\tInsight:         \"Always sanitize HTML inputs\",\n\t\t\tSuggestedAction: \"Add rule to implement prompt\",\n\t\t\tEvidence:        []string{\"run-1\", \"run-2\"},\n\t\t},\n\t}\n\n\trequire.NoError(t, logger.UpdateKnowledge(\"develop\", lessons))\n\n\tcontent, err := os.ReadFile(filepath.Join(kbDir, \"develop.md\"))\n\trequire.NoError(t, err)\n\tassert.Contains(t, string(content), \"[P001]\")\n\tassert.Contains(t, string(content), \"sanitize HTML\")\n\tassert.Contains(t, string(content), \"run-1, run-2\")\n}\n\n// --- LLM Client tests ---\n\n// --- Curator tests ---\n\nfunc TestCuratorUpdatesPrompt(t *testing.T) {\n\tdir := t.TempDir()\n\tpromptPath := filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\")\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n\tos.WriteFile(promptPath, []byte(\"# Implementation Prompt\\n\\nWrite good code.\\n\"), 0644)\n\n\tupdatedContent := \"# Implementation Prompt\\n\\nWrite good code.\\n\\n## Learned Rules\\n\\n- Always sanitize user inputs\\n\"\n\tllm := &fakeLLM{response: updatedContent}\n\n\taudit := &AuditLogger{ProjectDir: dir}\n\tc := &Curator{LLM: llm, Audit: audit}\n\tlesson := &Lesson{\n\t\tID:              \"lesson-001\",\n\t\tCategory:        \"prompt_improvement\",\n\t\tTarget:          \".cloche/prompts/implement.md\",\n\t\tInsight:         \"XSS vulnerabilities in form handlers\",\n\t\tSuggestedAction: \"Add sanitization rule\",\n\t}\n\n\tchange, err := c.Apply(context.Background(), dir, lesson)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"prompt_update\", change.Type)\n\tassert.Equal(t, \".cloche/prompts/implement.md\", change.File)\n\tassert.NotEmpty(t, change.Snapshot)\n\n\tcontent, err := os.ReadFile(promptPath)\n\trequire.NoError(t, err)\n\tassert.Contains(t, string(content), \"sanitize user inputs\")\n}\n\n// --- Script Generator tests ---\n\nfunc TestScriptGeneratorCreatesScript(t *testing.T) {\n\tdir := t.TempDir()\n\n\tllm := &fakeLLM{response: `{\"path\": \"scripts/security-scan.sh\", \"content\": \"#!/bin/bash\\ngosec ./...\"}`}\n\tg := &ScriptGenerator{LLM: llm}\n\n\tlesson := &Lesson{\n\t\tID:              \"lesson-001\",\n\t\tCategory:        \"new_step\",\n\t\tStepType:        \"script\",\n\t\tInsight:         \"No security scanning\",\n\t\tSuggestedAction: \"Add gosec security scan\",\n\t}\n\n\tresult, err := g.Generate(context.Background(), dir, lesson)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"scripts/security-scan.sh\", result.Path)\n\n\tcontent, err := os.ReadFile(filepath.Join(dir, \"scripts\", \"security-scan.sh\"))\n\trequire.NoError(t, err)\n\tassert.Contains(t, string(content), \"gosec\")\n\n\tinfo, err := os.Stat(filepath.Join(dir, \"scripts\", \"security-scan.sh\"))\n\trequire.NoError(t, err)\n\tassert.NotZero(t, info.Mode()&0111) // executable\n}\n\n// --- LLM Client tests ---\n\nfunc TestCommandLLMClient(t *testing.T) {\n\tc := &CommandLLMClient{Command: \"cat\", Args: []string{}}\n\tresult, err := c.Complete(context.Background(), \"system\", \"user prompt\")\n\trequire.NoError(t, err)\n\tassert.Contains(t, result, \"user prompt\")\n\tassert.Contains(t, result, \"system\")\n}\n\n// --- Orchestrator tests ---\n\n// scriptedLLM returns responses in order.\ntype scriptedLLM struct {\n\tresponses []string\n\tidx       int\n}\n\nfunc (s *scriptedLLM) Complete(ctx context.Context, system, user string) (string, error) {\n\tresp := s.responses[s.idx]\n\ts.idx++\n\treturn resp, nil\n}\n\nfunc TestOrchestratorEndToEnd(t *testing.T) {\n\tdir := t.TempDir()\n\n\t// Set up project structure\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\"), 0755)\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"snapshots\"), 0755)\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"prompts\"), 0755)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\", \"develop.md\"),\n\t\t[]byte(\"# Knowledge Base: develop\\n\"), 0644)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"),\n\t\t[]byte(\"Write good code.\\n\"), 0644)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n\t\t[]byte(`workflow \"develop\" {\n  step implement {\n    prompt = file(\".cloche/prompts/implement.md\")\n    results = [success, fail]\n  }\n  step test {\n    run = \"make test\"\n    results = [success, fail]\n  }\n  implement:success -> test\n  test:success -> done\n  test:fail -> abort\n}`), 0644)\n\n\t// Fake LLM that returns appropriate responses per stage\n\tllm := &scriptedLLM{\n\t\tresponses: []string{\n\t\t\t// Classifier\n\t\t\t`{\"classification\": \"bug\"}`,\n\t\t\t// Reflector\n\t\t\t`{\"lessons\": [{\"id\": \"L001\", \"category\": \"prompt_improvement\", \"target\": \".cloche/prompts/implement.md\", \"insight\": \"XSS pattern\", \"suggested_action\": \"Add sanitization rule\", \"evidence\": [\"run-1\"], \"confidence\": \"high\"}]}`,\n\t\t\t// Curator\n\t\t\t\"Write good code.\\n\\n## Learned Rules\\n\\n- Always sanitize user inputs\\n\",\n\t\t},\n\t}\n\n\torch := NewOrchestrator(OrchestratorConfig{\n\t\tProjectDir:    dir,\n\t\tWorkflowName:  \"develop\",\n\t\tLLM:           llm,\n\t\tMinConfidence: \"medium\",\n\t})\n\n\tresult, err := orch.Run(context.Background(), \"run-1\", nil, nil)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"bug\", result.Classification)\n\trequire.Len(t, result.Changes, 1)\n\tassert.Equal(t, \"prompt_update\", result.Changes[0].Type)\n\n\t// Verify prompt was actually updated\n\tcontent, _ := os.ReadFile(filepath.Join(dir, \".cloche\", \"prompts\", \"implement.md\"))\n\tassert.Contains(t, string(content), \"sanitize user inputs\")\n\n\t// Verify audit log was written\n\tlogContent, _ := os.ReadFile(filepath.Join(dir, \".cloche\", \"evolution\", \"log.jsonl\"))\n\tassert.Contains(t, string(logContent), \"prompt_update\")\n\tassert.Contains(t, string(logContent), \"XSS pattern\")\n\n\t// Verify knowledge base was updated\n\tkbContent, _ := os.ReadFile(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\", \"develop.md\"))\n\tassert.Contains(t, string(kbContent), \"L001\")\n}\n\nfunc TestOrchestratorNoLessons(t *testing.T) {\n\tdir := t.TempDir()\n\n\tos.MkdirAll(filepath.Join(dir, \".cloche\", \"evolution\", \"knowledge\"), 0755)\n\tos.WriteFile(filepath.Join(dir, \".cloche\", \"develop.cloche\"),\n\t\t[]byte(`workflow \"develop\" {\n  step s {\n    run = \"echo hi\"\n    results = [success]\n  }\n  s:success -> done\n}`), 0644)\n\n\tllm := &scriptedLLM{\n\t\tresponses: []string{\n\t\t\t// Classifier\n\t\t\t`{\"classification\": \"feature\"}`,\n\t\t\t// Reflector — no lessons\n\t\t\t`{\"lessons\": []}`,\n\t\t},\n\t}\n\n\torch := NewOrchestrator(OrchestratorConfig{\n\t\tProjectDir:    dir,\n\t\tWorkflowName:  \"develop\",\n\t\tLLM:           llm,\n\t\tMinConfidence: \"medium\",\n\t})\n\n\tresult, err := orch.Run(context.Background(), \"run-1\", nil, nil)\n\trequire.NoError(t, err)\n\tassert.Equal(t, \"feature\", result.Classification)\n\tassert.Empty(t, result.Changes)\n}\n","numLines":423,"startLine":1,"totalLines":423}}}
