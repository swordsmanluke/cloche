→\n    59→// Load reads a per-project config from <projectDir>/.cloche/config.toml.\n    60→func Load(projectDir string) (*Config, error) {\n    61→\tcfg := defaults()\n    62→\tpath := filepath.Join(projectDir, \".cloche\", \"config.toml\")\n    63→\n    64→\tdata, err := os.ReadFile(path)\n    65→\tif os.IsNotExist(err) {\n    66→\t\treturn &cfg, nil\n    67→\t}\n    68→\tif err != nil {\n    69→\t\treturn nil, err\n    70→\t}\n    71→\n    72→\tif _, err := toml.Decode(string(data), &cfg); err != nil {\n    73→\t\treturn nil, err\n    74→\t}\n    75→\treturn &cfg, nil\n    76→}\n    77→\n    78→// LoadGlobal reads the global daemon config from ~/.config/cloche/config.\n    79→// Returns defaults if the file does not exist.\n    80→func LoadGlobal() (*Config, error) {\n    81→\tcfg := defaults()\n    82→\n    83→\thome, err := os.UserHomeDir()\n    84→\tif err != nil {\n    85→\t\treturn &cfg, nil\n    86→\t}\n    87→\n    88→\tpath := filepath.Join(home, \".config\", \"cloche\", \"config\")\n    89→\tdata, err := os.ReadFile(path)\n    90→\tif os.IsNotExist(err) {\n    91→\t\treturn &cfg, nil\n    92→\t}\n    93→\tif err != nil {\n    94→\t\treturn nil, err\n    95→\t}\n    96→\n    97→\tif _, err := toml.Decode(string(data), &cfg); err != nil {\n    98→\t\treturn nil, err\n    99→\t}\n   100→\treturn &cfg, nil\n   101→}\n   102→\n   103→// LoadGlobalFrom reads the global config from a specific path.\n   104→// Useful for testing.\n   105→func LoadGlobalFrom(path string) (*Config, error) {\n   106→\tcfg := defaults()\n   107→\n   108→\tdata, err := os.ReadFile(path)\n   109→\tif os.IsNotExist(err) {\n   110→\t\treturn &cfg, nil\n   111→\t}\n   112→\tif err != nil {\n   113→\t\treturn nil, err\n   114→\t}\n   115→\n   116→\tif _, err := toml.Decode(string(data), &cfg); err != nil {\n   117→\t\treturn nil, err\n   118→\t}\n   119→\treturn &cfg, nil\n   120→}\n   121→\n   122→// LoadVersion reads the project version from <projectDir>/.cloche/version.\n   123→// Returns 1 if the file does not exist.\n   124→func LoadVersion(projectDir string) (int, error) {\n   125→\tpath := filepath.Join(projectDir, \".cloche\", \"version\")\n   126→\tdata, err := os.ReadFile(path)\n   127→\tif os.IsNotExist(err) {\n   128→\t\treturn 1, nil\n   129→\t}\n   130→\tif err != nil {\n   131→\t\treturn 0, err\n   132→\t}\n   133→\tv, err := strconv.Atoi(strings.TrimSpace(string(data)))\n   134→\tif err != nil {\n   135→\t\treturn 0, fmt.Errorf(\"invalid version file: %w\", err)\n   136→\t}\n   137→\treturn v, nil\n   138→}\n   139→\n   140→// IncrementVersion reads .cloche/version, increments the integer, and writes\n   141→// it back atomically. If the file does not exist, it writes 2 (treating the\n   142→// missing file as implicit version 1).\n   143→func IncrementVersion(projectDir string) error {\n   144→\tv, err := LoadVersion(projectDir)\n   145→\tif err != nil {\n   146→\t\treturn err\n   147→\t}\n   148→\tv++\n   149→\n   150→\tpath := filepath.Join(projectDir, \".cloche\", \"version\")\n   151→\ttmp := path + \".tmp\"\n   152→\tif err := os.WriteFile(tmp, []byte(strconv.Itoa(v)+\"\\n\"), 0644); err != nil {\n   153→\t\treturn err\n   154→\t}\n   155→\treturn os.Rename(tmp, path)\n   156→}\n   157→"}]},"parent_tool_use_id":null,"session_id":"17e028fb-d381-40de-b934-dc63b92e534a","uuid":"cb750ce4-5693-4b5c-b0d6-626b7e948464","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/config/config.go","content":"package config\n\nimport (\n\t\"fmt\"\n\t\"os\"\n\t\"path/filepath\"\n\t\"strconv\"\n\t\"strings\"\n\n\t\"github.com/BurntSushi/toml\"\n)\n\ntype DaemonConfig struct {\n\tListen     string `toml:\"listen\"`\n\tHTTP       string `toml:\"http\"`\n\tImage      string `toml:\"image\"`\n\tDB         string `toml:\"db\"`\n\tRuntime    string `toml:\"runtime\"`\n\tAgentPath  string `toml:\"agent_path\"`\n\tLLMCommand string `toml:\"llm_command\"`\n}\n\ntype EvolutionConfig struct {\n\tEnabled          bool   `toml:\"enabled\"`\n\tDebounceSeconds  int    `toml:\"debounce_seconds\"`\n\tMinConfidence    string `toml:\"min_confidence\"`\n\tMaxPromptBullets int    `toml:\"max_prompt_bullets\"`\n}\n\ntype OrchestrationConfig struct {\n\tEnabled     bool   `toml:\"enabled\"`\n\tTracker     string `toml:\"tracker\"`\n\tConcurrency int    `toml:\"concurrency\"`\n\tWorkflow    string `toml:\"workflow\"`\n}\n\ntype Config struct {\n\tDaemon        DaemonConfig        `toml:\"daemon\"`\n\tEvolution     EvolutionConfig     `toml:\"evolution\"`\n\tOrchestration OrchestrationConfig `toml:\"orchestration\"`\n}\n\nfunc defaults() Config {\n\treturn Config{\n\t\tEvolution: EvolutionConfig{\n\t\t\tEnabled:          true,\n\t\t\tDebounceSeconds:  30,\n\t\t\tMinConfidence:    \"medium\",\n\t\t\tMaxPromptBullets: 50,\n\t\t},\n\t\tOrchestration: OrchestrationConfig{\n\t\t\tTracker:     \"beads\",\n\t\t\tConcurrency: 1,\n\t\t\tWorkflow:     \"develop\",\n\t\t},\n\t}\n}\n\n// Load reads a per-project config from <projectDir>/.cloche/config.toml.\nfunc Load(projectDir string) (*Config, error) {\n\tcfg := defaults()\n\tpath := filepath.Join(projectDir, \".cloche\", \"config.toml\")\n\n\tdata, err := os.ReadFile(path)\n\tif os.IsNotExist(err) {\n\t\treturn &cfg, nil\n\t}\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tif _, err := toml.Decode(string(data), &cfg); err != nil {\n\t\treturn nil, err\n\t}\n\treturn &cfg, nil\n}\n\n// LoadGlobal reads the global daemon config from ~/.config/cloche/config.\n// Returns defaults if the file does not exist.\nfunc LoadGlobal() (*Config, error) {\n\tcfg := defaults()\n\n\thome, err := os.UserHomeDir()\n\tif err != nil {\n\t\treturn &cfg, nil\n\t}\n\n\tpath := filepath.Join(home, \".config\", \"cloche\", \"config\")\n\tdata, err := os.ReadFile(path)\n\tif os.IsNotExist(err) {\n\t\treturn &cfg, nil\n\t}\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tif _, err := toml.Decode(string(data), &cfg); err != nil {\n\t\treturn nil, err\n\t}\n\treturn &cfg, nil\n}\n\n// LoadGlobalFrom reads the global config from a specific path.\n// Useful for testing.\nfunc LoadGlobalFrom(path string) (*Config, error) {\n\tcfg := defaults()\n\n\tdata, err := os.ReadFile(path)\n\tif os.IsNotExist(err) {\n\t\treturn &cfg, nil\n\t}\n\tif err != nil {\n\t\treturn nil, err\n\t}\n\n\tif _, err := toml.Decode(string(data), &cfg); err != nil {\n\t\treturn nil, err\n\t}\n\treturn &cfg, nil\n}\n\n// LoadVersion reads the project version from <projectDir>/.cloche/version.\n// Returns 1 if the file does not exist.\nfunc LoadVersion(projectDir string) (int, error) {\n\tpath := filepath.Join(projectDir, \".cloche\", \"version\")\n\tdata, err := os.ReadFile(path)\n\tif os.IsNotExist(err) {\n\t\treturn 1, nil\n\t}\n\tif err != nil {\n\t\treturn 0, err\n\t}\n\tv, err := strconv.Atoi(strings.TrimSpace(string(data)))\n\tif err != nil {\n\t\treturn 0, fmt.Errorf(\"invalid version file: %w\", err)\n\t}\n\treturn v, nil\n}\n\n// IncrementVersion reads .cloche/version, increments the integer, and writes\n// it back atomically. If the file does not exist, it writes 2 (treating the\n// missing file as implicit version 1).\nfunc IncrementVersion(projectDir string) error {\n\tv, err := LoadVersion(projectDir)\n\tif err != nil {\n\t\treturn err\n\t}\n\tv++\n\n\tpath := filepath.Join(projectDir, \".cloche\", \"version\")\n\ttmp := path + \".tmp\"\n\tif err := os.WriteFile(tmp, []byte(strconv.Itoa(v)+\"\\n\"), 0644); err != nil {\n\t\treturn err\n\t}\n\treturn os.Rename(tmp, path)\n}\n","numLines":157,"startLine":1,"totalLines":157}}}
