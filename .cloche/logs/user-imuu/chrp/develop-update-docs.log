{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01U9Far9VfiQ5KxQiAAVYoxu","type":"tool_result","content":"     1→package web\n     2→\n     3→import (\n     4→\t\"bufio\"\n     5→\t\"context\"\n     6→\t\"embed\"\n     7→\t\"encoding/json\"\n     8→\t\"fmt\"\n     9→\t\"html/template\"\n    10→\t\"io/fs\"\n    11→\t\"net/http\"\n    12→\t\"os\"\n    13→\t\"os/exec\"\n    14→\t\"path/filepath\"\n    15→\t\"regexp\"\n    16→\t\"sort\"\n    17→\t\"strconv\"\n    18→\t\"strings\"\n    19→\t\"time\"\n    20→\n    21→\t\"github.com/cloche-dev/cloche/internal/domain\"\n    22→\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    23→\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    24→\t\"github.com/cloche-dev/cloche/internal/ports\"\n    25→)\n    26→\n    27→// HandlerOption configures optional Handler dependencies.\n    28→type HandlerOption func(*Handler)\n    29→\n    30→// WithContainerLogger sets the container runtime for fetching live logs.\n    31→func WithContainerLogger(c ContainerLogger) HandlerOption {\n    32→\treturn func(h *Handler) { h.container = c }\n    33→}\n    34→\n    35→// WithContainerManager sets a full container manager (logs, inspect, remove).\n    36→func WithContainerManager(c ContainerManager) HandlerOption {\n    37→\treturn func(h *Handler) { h.container = c }\n    38→}\n    39→\n    40→// WithLogBroadcaster sets the log broadcaster for SSE streaming.\n    41→func WithLogBroadcaster(b *logstream.Broadcaster) HandlerOption {\n    42→\treturn func(h *Handler) { h.logBroadcast = b }\n    43→}\n    44→\n    45→// WithLogStore sets the log store for indexed log file lookups.\n    46→func WithLogStore(ls ports.LogStore) HandlerOption {\n    47→\treturn func(h *Handler) { h.logStore = ls }\n    48→}\n    49→\n    50→// WithOrchestrateFunc sets the function called when the orchestrator is triggered.\n    51→func WithOrchestrateFunc(fn func(ctx context.Context, projectDir string) (int, error)) HandlerOption {\n    52→\treturn func(h *Handler) { h.orchestrateFn = fn }\n    53→}\n    54→\n    55→// OrchestratorController provides per-project orchestrator control.\n    56→type OrchestratorController interface {\n    57→\tStatus(dir string) (enabled bool, inFlight int, concurrency int)\n    58→\tSetEnabled(dir string, enabled bool)\n    59→\tSetConcurrency(dir string, concurrency int)\n    60→}\n    61→\n    62→// WithOrchestrator sets the orchestrator controller for project-level control.\n    63→func WithOrchestrator(oc OrchestratorController) HandlerOption {\n    64→\treturn func(h *Handler) { h.orchestrator = oc }\n    65→}\n    66→\n    67→//go:embed templates/*.html static/*\n    68→var content embed.FS\n    69→\n    70→// Handler serves the web dashboard.\n    71→// ContainerLogger can retrieve logs from a container by ID.\n    72→type ContainerLogger interface {\n    73→\tLogs(ctx context.Context, containerID string) (string, error)\n    74→}\n    75→\n    76→// ContainerManager extends ContainerLogger with container lifecycle operations.\n    77→type ContainerManager interface {\n    78→\tContainerLogger\n    79→\tRemove(ctx context.Context, containerID string) error\n    80→\tInspect(ctx context.Context, containerID string) (*ports.ContainerStatus, error)\n    81→}\n    82→\n    83→type Handler struct {\n    84→\tstore         ports.RunStore\n    85→\tcaptures      ports.CaptureStore\n    86→\tlogStore      ports.LogStore\n    87→\tcontainer     ContainerLogger\n    88→\tlogBroadcast  *logstream.Broadcaster\n    89→\torchestrateFn func(ctx context.Context, projectDir string) (int, error)\n    90→\torchestrator  OrchestratorController\n    91→\tpages         map[string]*template.Template\n    92→\tmux           *http.ServeMux\n    93→}\n    94→\n    95→// NewHandler creates a web dashboard handler.\n    96→func NewHandler(store ports.RunStore, captures ports.CaptureStore, opts ...HandlerOption) (*Handler, error) {\n    97→\tfuncMap := template.FuncMap{\n    98→\t\t\"stateColor\":       stateColor,\n    99→\t\t\"healthColor\":      healthColor,\n   100→\t\t\"formatTime\":       formatTime,\n   101→\t\t\"formatDuration\":   formatDuration,\n   102→\t\t\"truncate\":         truncate,\n   103→\t\t\"shortContainerID\": shortContainerID,\n   104→\t}\n   105→\n   106→\tbase, err := template.New(\"\").Funcs(funcMap).ParseFS(content, \"templates/layout.html\")\n   107→\tif err != nil {\n   108→\t\treturn nil, fmt.Errorf(\"parse layout: %w\", err)\n   109→\t}\n   110→\n   111→\tpages := map[string]*template.Template{}\n   112→\tfor _, page := range []string{\"projects\", \"runs\", \"run_detail\", \"project_detail\"} {\n   113→\t\tclone, err := base.Clone()\n   114→\t\tif err != nil {\n   115→\t\t\treturn nil, fmt.Errorf(\"clone layout for %s: %w\", page, err)\n   116→\t\t}\n   117→\t\t_, err = clone.ParseFS(content, \"templates/\"+page+\".html\")\n   118→\t\tif err != nil {\n   119→\t\t\treturn nil, fmt.Errorf(\"parse %s: %w\", page, err)\n   120→\t\t}\n   121→\t\tpages[page] = clone\n   122→\t}\n   123→\n   124→\th := &Handler{\n   125→\t\tstore:    store,\n   126→\t\tcaptures: captures,\n   127→\t\tpages:    pages,\n   128→\t\tmux:      http.NewServeMux(),\n   129→\t}\n   130→\tfor _, opt := range opts {\n   131→\t\topt(h)\n   132→\t}\n   133→\n   134→\tstaticFS, err := fs.Sub(content, \"static\")\n   135→\tif err != nil {\n   136→\t\treturn nil, fmt.Errorf(\"static sub-fs: %w\", err)\n   137→\t}\n   138→\n   139→\th.mux.HandleFunc(\"GET /{$}\", h.handleProjectOverview)\n   140→\th.mux.HandleFunc(\"GET /runs\", h.handleRunsList)\n   141→\th.mux.HandleFunc(\"GET /runs/{id}\", h.handleRunDetail)\n   142→\th.mux.HandleFunc(\"GET /projects/{name}/runs\", h.handleRunsList)\n   143→\th.mux.HandleFunc(\"GET /projects/{name}\", h.handleProjectDetail)\n   144→\th.mux.HandleFunc(\"GET /api/projects\", h.handleAPIProjects)\n   145→\th.mux.HandleFunc(\"GET /api/runs\", h.handleAPIRuns)\n   146→\th.mux.HandleFunc(\"GET /api/runs/{id}\", h.handleAPIRunDetail)\n   147→\th.mux.HandleFunc(\"GET /api/runs/{id}/steps/{step}/output\", h.handleAPIStepOutput)\n   148→\th.mux.HandleFunc(\"DELETE /api/runs/{id}/container\", h.handleAPIDeleteContainer)\n   149→\th.mux.HandleFunc(\"POST /api/projects/{name}/trigger\", h.handleAPITriggerOrchestrator)\n   150→\th.mux.HandleFunc(\"GET /api/projects/{name}/orchestrator\", h.handleAPIOrchestratorStatus)\n   151→\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/start\", h.handleAPIOrchestratorStart)\n   152→\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/stop\", h.handleAPIOrchestratorStop)\n   153→\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/concurrency\", h.handleAPIOrchestratorConcurrency)\n   154→\th.mux.HandleFunc(\"GET /api/projects/{name}/info\", h.handleAPIProjectInfo)\n   155→\th.mux.HandleFunc(\"GET /api/projects/{name}/info/prompt-diff\", h.handleAPIPromptDiff)\n   156→\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows\", h.handleAPIWorkflows)\n   157→\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows/{workflow}/steps/{step}/content\", h.handleAPIStepContent)\n   158→\th.mux.HandleFunc(\"GET /api/runs/{id}/stream\", h.handleAPIStream)\n   159→\th.mux.Handle(\"GET /static/\", http.StripPrefix(\"/static/\", http.FileServerFS(staticFS)))\n   160→\n   161→\treturn h, nil\n   162→}\n   163→\n   164→func (h *Handler) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n   165→\th.mux.ServeHTTP(w, r)\n   166→}\n   167→\n   168→// --- HTML handlers ---\n   169→\n   170→// projectOverviewEntry holds data for a single project card on the landing page.\n   171→type projectOverviewEntry struct {\n   172→\tDir         string\n   173→\tLabel       string\n   174→\tHealth      domain.HealthResult\n   175→\tRecentRuns  []recentRunDot\n   176→\tActiveCount int\n   177→}\n   178→\n   179→// recentRunDot is a minimal representation of a run for the mini history display.\n   180→type recentRunDot struct {\n   181→\tID    string\n   182→\tState string\n   183→}\n   184→\n   185→const healthWindowSize = 10\n   186→\n   187→func (h *Handler) handleProjectOverview(w http.ResponseWriter, r *http.Request) {\n   188→\tprojects, _ := h.store.ListProjects(r.Context())\n   189→\tlabels := projectLabels(projects)\n   190→\n   191→\tvar entries []projectOverviewEntry\n   192→\tfor _, dir := range projects {\n   193→\t\truns, err := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   194→\t\tif err != nil {\n   195→\t\t\tcontinue\n   196→\t\t}\n   197→\n   198→\t\t// Convert []*domain.Run to []domain.Run for CalculateHealth.\n   199→\t\trunValues := make([]domain.Run, len(runs))\n   200→\t\tfor i, rr := range runs {\n   201→\t\t\trunValues[i] = *rr\n   202→\t\t}\n   203→\n   204→\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n   205→\n   206→\t\t// Take the last N runs for the mini history (most recent first).\n   207→\t\tn := healthWindowSize\n   208→\t\tif n > len(runs) {\n   209→\t\t\tn = len(runs)\n   210→\t\t}\n   211→\t\tdots := make([]recentRunDot, n)\n   212→\t\tfor i := 0; i < n; i++ {\n   213→\t\t\tdots[i] = recentRunDot{\n   214→\t\t\t\tID:    runs[i].ID,\n   215→\t\t\t\tState: string(runs[i].State),\n   216→\t\t\t}\n   217→\t\t}\n   218→\n   219→\t\tvar activeCount int\n   220→\t\tfor _, rr := range runs {\n   221→\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n   222→\t\t\t\tactiveCount++\n   223→\t\t\t}\n   224→\t\t}\n   225→\n   226→\t\tentries = append(entries, projectOverviewEntry{\n   227→\t\t\tDir:         dir,\n   228→\t\t\tLabel:       labels[dir],\n   229→\t\t\tHealth:      health,\n   230→\t\t\tRecentRuns:  dots,\n   231→\t\t\tActiveCount: activeCount,\n   232→\t\t})\n   233→\t}\n   234→\n   235→\tsort.Slice(entries, func(i, j int) bool {\n   236→\t\treturn entries[i].Label < entries[j].Label\n   237→\t})\n   238→\n   239→\tdata := map[string]any{\n   240→\t\t\"Title\":    \"Projects\",\n   241→\t\t\"Projects\": entries,\n   242→\t}\n   243→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   244→\tif err := h.pages[\"projects\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   245→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   246→\t}\n   247→}\n   248→\n   249→func (h *Handler) handleRunsList(w http.ResponseWriter, r *http.Request) {\n   250→\tprojects, _ := h.store.ListProjects(r.Context())\n   251→\tlabels := projectLabels(projects)\n   252→\n   253→\tvar projectFilter string // dir\n   254→\tvar projectLabel string\n   255→\n   256→\t// Resolve project from path (/projects/{name}/runs) or query param (?project=dir)\n   257→\tif name := r.PathValue(\"name\"); name != \"\" {\n   258→\t\tfor dir, l := range labels {\n   259→\t\t\tif l == name {\n   260→\t\t\t\tprojectFilter = dir\n   261→\t\t\t\tprojectLabel = l\n   262→\t\t\t\tbreak\n   263→\t\t\t}\n   264→\t\t}\n   265→\t\tif projectFilter == \"\" {\n   266→\t\t\thttp.Error(w, \"project not found\", http.StatusNotFound)\n   267→\t\t\treturn\n   268→\t\t}\n   269→\t} else if qp := r.URL.Query().Get(\"project\"); qp != \"\" {\n   270→\t\tprojectFilter = qp\n   271→\t\tprojectLabel = labels[qp]\n   272→\t\t// Redirect to clean URL if we can resolve the label\n   273→\t\tif projectLabel != \"\" {\n   274→\t\t\thttp.Redirect(w, r, \"/projects/\"+projectLabel+\"/runs\", http.StatusMovedPermanently)\n   275→\t\t\treturn\n   276→\t\t}\n   277→\t}\n   278→\n   279→\tvar runs []*domain.Run\n   280→\tvar err error\n   281→\tif projectFilter != \"\" {\n   282→\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n   283→\t} else {\n   284→\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n   285→\t}\n   286→\tif err != nil {\n   287→\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n   288→\t\treturn\n   289→\t}\n   290→\n   291→\t// Count retained containers per project\n   292→\tcontainerCounts := map[string]int{}\n   293→\tallRuns, _ := h.store.ListRuns(r.Context(), time.Time{})\n   294→\tfor _, run := range allRuns {\n   295→\t\tif run.ContainerKept {\n   296→\t\t\tcontainerCounts[run.ProjectDir]++\n   297→\t\t}\n   298→\t}\n   299→\n   300→\tvar projectList []projectEntry\n   301→\tfor _, dir := range projects {\n   302→\t\tprojectList = append(projectList, projectEntry{Dir: dir, Label: labels[dir], ContainerCount: containerCounts[dir]})\n   303→\t}\n   304→\tsort.Slice(projectList, func(i, j int) bool {\n   305→\t\treturn projectList[i].Label < projectList[j].Label\n   306→\t})\n   307→\n   308→\tdata := map[string]any{\n   309→\t\t\"Title\":         \"Runs\",\n   310→\t\t\"Runs\":          runs,\n   311→\t\t\"Projects\":      projectList,\n   312→\t\t\"ProjectFilter\": projectFilter,\n   313→\t\t\"ProjectLabel\":  projectLabel,\n   314→\t\t\"ProjectLabels\": labels,\n   315→\t}\n   316→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   317→\tif err := h.pages[\"runs\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   318→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   319→\t}\n   320→}\n   321→\n   322→// stepEntry is a merged view of a step execution for the template.\n   323→type stepEntry struct {\n   324→\tIndex     int\n   325→\tStepName  string\n   326→\tResult    string\n   327→\tStartedAt time.Time\n   328→\tDuration  string\n   329→}\n   330→\n   331→// mergeCaptures collapses started/completed capture pairs into single entries.\n   332→func mergeCaptures(caps []*domain.StepExecution) []stepEntry {\n   333→\tvar entries []stepEntry\n   334→\t// Track pending started rows by step name (LIFO for retries)\n   335→\tpending := map[string]*domain.StepExecution{}\n   336→\n   337→\tfor _, c := range caps {\n   338→\t\tif c.Result == \"\" {\n   339→\t\t\t// step_started row\n   340→\t\t\tpending[c.StepName] = c\n   341→\t\t\tcontinue\n   342→\t\t}\n   343→\t\t// step_completed row — merge with pending started if available\n   344→\t\tstartedAt := c.StartedAt\n   345→\t\tif started := pending[c.StepName]; started != nil {\n   346→\t\t\tstartedAt = started.StartedAt\n   347→\t\t\tdelete(pending, c.StepName)\n   348→\t\t}\n   349→\t\tentries = append(entries, stepEntry{\n   350→\t\t\tIndex:     len(entries),\n   351→\t\t\tStepName:  c.StepName,\n   352→\t\t\tResult:    c.Result,\n   353→\t\t\tStartedAt: startedAt,\n   354→\t\t\tDuration:  formatDuration(startedAt, c.CompletedAt),\n   355→\t\t})\n   356→\t}\n   357→\n   358→\t// Append any started-but-not-completed steps (still running)\n   359→\tfor _, c := range caps {\n   360→\t\tif c.Result == \"\" {\n   361→\t\t\tif _, used := pending[c.StepName]; !used {\n   362→\t\t\t\tcontinue\n   363→\t\t\t}\n   364→\t\t\tentries = append(entries, stepEntry{\n   365→\t\t\t\tIndex:     len(entries),\n   366→\t\t\t\tStepName:  c.StepName,\n   367→\t\t\t\tStartedAt: c.StartedAt,\n   368→\t\t\t})\n   369→\t\t\tdelete(pending, c.StepName)\n   370→\t\t}\n   371→\t}\n   372→\n   373→\treturn entries\n   374→}\n   375→\n   376→// containerState inspects the container for a run and returns one of:\n   377→//   - \"running\"   – container exists and is running\n   378→//   - \"stopped\"   – container exists, not running, not kept\n   379→//   - \"available\" – container exists, not running, kept (can be deleted)\n   380→//   - \"removed\"   – no container ID, no manager, or inspect failed\n   381→func (h *Handler) containerState(ctx context.Context, run *domain.Run) string {\n   382→\tif run.ContainerID == \"\" {\n   383→\t\treturn \"removed\"\n   384→\t}\n   385→\tmgr, ok := h.container.(ContainerManager)\n   386→\tif !ok {\n   387→\t\treturn \"removed\"\n   388→\t}\n   389→\tstatus, err := mgr.Inspect(ctx, run.ContainerID)\n   390→\tif err != nil {\n   391→\t\treturn \"removed\"\n   392→\t}\n   393→\tif status.Running {\n   394→\t\treturn \"running\"\n   395→\t}\n   396→\tif run.ContainerKept {\n   397→\t\treturn \"available\"\n   398→\t}\n   399→\treturn \"stopped\"\n   400→}\n   401→\n   402→func (h *Handler) handleRunDetail(w http.ResponseWriter, r *http.Request) {\n   403→\tid := r.PathValue(\"id\")\n   404→\n   405→\trun, err := h.store.GetRun(r.Context(), id)\n   406→\tif err != nil {\n   407→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   408→\t\treturn\n   409→\t}\n   410→\n   411→\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n   412→\tif err != nil {\n   413→\t\tcaps = nil // non-fatal\n   414→\t}\n   415→\n   416→\tsteps := mergeCaptures(caps)\n   417→\n   418→\tdata := map[string]any{\n   419→\t\t\"Title\":          \"Run \" + run.ID,\n   420→\t\t\"Run\":            run,\n   421→\t\t\"Steps\":          steps,\n   422→\t\t\"Page\":           \"detail\",\n   423→\t\t\"ContainerState\": h.containerState(r.Context(), run),\n   424→\t}\n   425→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   426→\tif err := h.pages[\"run_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   427→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   428→\t}\n   429→}\n   430→\n   431→// --- JSON API handlers ---\n   432→\n   433→type apiRun struct {\n   434→\tID           string `json:\"id\"`\n   435→\tWorkflowName string `json:\"workflow_name\"`\n   436→\tProjectDir   string `json:\"project_dir\"`\n   437→\tProjectLabel string `json:\"project_label\"`\n   438→\tState        string `json:\"state\"`\n   439→\tStartedAt    string `json:\"started_at\"`\n   440→\tCompletedAt  string `json:\"completed_at\"`\n   441→\tContainerID  string `json:\"container_id\"`\n   442→\tErrorMessage string `json:\"error_message\"`\n   443→}\n   444→\n   445→type apiStep struct {\n   446→\tStepName    string `json:\"step_name\"`\n   447→\tResult      string `json:\"result\"`\n   448→\tStartedAt   string `json:\"started_at\"`\n   449→\tCompletedAt string `json:\"completed_at\"`\n   450→\tDuration    string `json:\"duration\"`\n   451→}\n   452→\n   453→type apiRunDetail struct {\n   454→\tapiRun\n   455→\tContainerState string    `json:\"container_state\"`\n   456→\tSteps          []apiStep `json:\"steps\"`\n   457→}\n   458→\n   459→func toAPIRun(r *domain.Run, labels map[string]string) apiRun {\n   460→\treturn apiRun{\n   461→\t\tID:           r.ID,\n   462→\t\tWorkflowName: r.WorkflowName,\n   463→\t\tProjectDir:   r.ProjectDir,\n   464→\t\tProjectLabel: labels[r.ProjectDir],\n   465→\t\tState:        string(r.State),\n   466→\t\tStartedAt:    formatTime(r.StartedAt),\n   467→\t\tCompletedAt:  formatTime(r.CompletedAt),\n   468→\t\tContainerID:  r.ContainerID,\n   469→\t\tErrorMessage: r.ErrorMessage,\n   470→\t}\n   471→}\n   472→\n   473→func (h *Handler) handleAPIRuns(w http.ResponseWriter, r *http.Request) {\n   474→\tprojectFilter := r.URL.Query().Get(\"project\")\n   475→\n   476→\tvar runs []*domain.Run\n   477→\tvar err error\n   478→\tif projectFilter != \"\" {\n   479→\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n   480→\t} else {\n   481→\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n   482→\t}\n   483→\tif err != nil {\n   484→\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n   485→\t\treturn\n   486→\t}\n   487→\n   488→\tprojects, _ := h.store.ListProjects(r.Context())\n   489→\tlabels := projectLabels(projects)\n   490→\n   491→\tresult := make([]apiRun, len(runs))\n   492→\tfor i, run := range runs {\n   493→\t\tresult[i] = toAPIRun(run, labels)\n   494→\t}\n   495→\n   496→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   497→\tjson.NewEncoder(w).Encode(result)\n   498→}\n   499→\n   500→func (h *Handler) handleAPIProjects(w http.ResponseWriter, r *http.Request) {\n   501→\tprojects, err := h.store.ListProjects(r.Context())\n   502→\tif err != nil {\n   503→\t\thttp.Error(w, \"failed to list projects\", http.StatusInternalServerError)\n   504→\t\treturn\n   505→\t}\n   506→\tlabels := projectLabels(projects)\n   507→\n   508→\ttype apiHealth struct {\n   509→\t\tStatus string `json:\"status\"`\n   510→\t\tPassed int    `json:\"passed\"`\n   511→\t\tFailed int    `json:\"failed\"`\n   512→\t\tTotal  int    `json:\"total\"`\n   513→\t}\n   514→\ttype apiProject struct {\n   515→\t\tDir         string    `json:\"dir\"`\n   516→\t\tLabel       string    `json:\"label\"`\n   517→\t\tHealth      apiHealth `json:\"health\"`\n   518→\t\tActiveCount int       `json:\"active_count\"`\n   519→\t}\n   520→\tresult := make([]apiProject, len(projects))\n   521→\tfor i, dir := range projects {\n   522→\t\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   523→\t\trunValues := make([]domain.Run, len(runs))\n   524→\t\tfor j, rr := range runs {\n   525→\t\t\trunValues[j] = *rr\n   526→\t\t}\n   527→\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n   528→\t\tvar activeCount int\n   529→\t\tfor _, rr := range runs {\n   530→\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n   531→\t\t\t\tactiveCount++\n   532→\t\t\t}\n   533→\t\t}\n   534→\t\tresult[i] = apiProject{\n   535→\t\t\tDir:   dir,\n   536→\t\t\tLabel: labels[dir],\n   537→\t\t\tHealth: apiHealth{\n   538→\t\t\t\tStatus: string(health.Status),\n   539→\t\t\t\tPassed: health.Passed,\n   540→\t\t\t\tFailed: health.Failed,\n   541→\t\t\t\tTotal:  health.Total,\n   542→\t\t\t},\n   543→\t\t\tActiveCount: activeCount,\n   544→\t\t}\n   545→\t}\n   546→\n   547→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   548→\tjson.NewEncoder(w).Encode(result)\n   549→}\n   550→\n   551→func (h *Handler) handleAPIRunDetail(w http.ResponseWriter, r *http.Request) {\n   552→\tid := r.PathValue(\"id\")\n   553→\n   554→\trun, err := h.store.GetRun(r.Context(), id)\n   555→\tif err != nil {\n   556→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   557→\t\treturn\n   558→\t}\n   559→\n   560→\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n   561→\tif err != nil {\n   562→\t\tcaps = nil\n   563→\t}\n   564→\n   565→\tprojects, _ := h.store.ListProjects(r.Context())\n   566→\tlabels := projectLabels(projects)\n   567→\n   568→\tmerged := mergeCaptures(caps)\n   569→\tsteps := make([]apiStep, len(merged))\n   570→\tfor i, e := range merged {\n   571→\t\tsteps[i] = apiStep{\n   572→\t\t\tStepName:  e.StepName,\n   573→\t\t\tResult:    e.Result,\n   574→\t\t\tStartedAt: formatTime(e.StartedAt),\n   575→\t\t\tDuration:  e.Duration,\n   576→\t\t}\n   577→\t}\n   578→\n   579→\tdetail := apiRunDetail{\n   580→\t\tapiRun:         toAPIRun(run, labels),\n   581→\t\tContainerState: h.containerState(r.Context(), run),\n   582→\t\tSteps:          steps,\n   583→\t}\n   584→\n   585→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   586→\tjson.NewEncoder(w).Encode(detail)\n   587→}\n   588→\n   589→func (h *Handler) handleAPIStepOutput(w http.ResponseWriter, r *http.Request) {\n   590→\tid := r.PathValue(\"id\")\n   591→\tstep := r.PathValue(\"step\")\n   592→\tlogType := r.URL.Query().Get(\"type\") // optional: \"script\", \"llm\"\n   593→\n   594→\trun, err := h.store.GetRun(r.Context(), id)\n   595→\tif err != nil {\n   596→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   597→\t\treturn\n   598→\t}\n   599→\n   600→\t// Try log index first for fast lookup\n   601→\tif h.logStore != nil {\n   602→\t\tlogFiles, err := h.logStore.GetLogFilesByStep(r.Context(), id, step)\n   603→\t\tif err == nil && len(logFiles) > 0 {\n   604→\t\t\t// If type filter specified, narrow results\n   605→\t\t\tfor _, lf := range logFiles {\n   606→\t\t\t\tif logType != \"\" && lf.FileType != logType {\n   607→\t\t\t\t\tcontinue\n   608→\t\t\t\t}\n   609→\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n   610→\t\t\t\tif readErr == nil && len(data) > 0 {\n   611→\t\t\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   612→\t\t\t\t\tw.Write(data)\n   613→\t\t\t\t\treturn\n   614→\t\t\t\t}\n   615→\t\t\t}\n   616→\t\t}\n   617→\t}\n   618→\n   619→\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", id, \"output\")\n   620→\n   621→\t// Fall back to file path conventions\n   622→\t// If type is \"llm\", try llm-<step>.log\n   623→\tif logType == \"llm\" {\n   624→\t\tllmPath := filepath.Join(outputDir, \"llm-\"+step+\".log\")\n   625→\t\tdata, err := os.ReadFile(llmPath)\n   626→\t\tif err == nil && len(data) > 0 {\n   627→\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   628→\t\t\tw.Write(data)\n   629→\t\t\treturn\n   630→\t\t}\n   631→\t}\n   632→\n   633→\t// Try per-step output first, fall back to container.log, then live docker logs\n   634→\toutputPath := filepath.Join(outputDir, step+\".log\")\n   635→\tdata, err := os.ReadFile(outputPath)\n   636→\tif err == nil && len(data) > 0 {\n   637→\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   638→\t\tw.Write(data)\n   639→\t\treturn\n   640→\t}\n   641→\n   642→\tcontainerLog := filepath.Join(outputDir, \"container.log\")\n   643→\tdata, err = os.ReadFile(containerLog)\n   644→\tif err == nil && len(data) > 0 {\n   645→\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   646→\t\tw.Write(data)\n   647→\t\treturn\n   648→\t}\n   649→\n   650→\t// Last resort: try live docker logs from still-existing container\n   651→\tif h.container != nil && run.ContainerID != \"\" {\n   652→\t\tif logs, logErr := h.container.Logs(r.Context(), run.ContainerID); logErr == nil && logs != \"\" {\n   653→\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   654→\t\t\tw.Write([]byte(logs))\n   655→\t\t\treturn\n   656→\t\t}\n   657→\t}\n   658→\n   659→\thttp.Error(w, \"step output not found\", http.StatusNotFound)\n   660→}\n   661→\n   662→func (h *Handler) handleAPIDeleteContainer(w http.ResponseWriter, r *http.Request) {\n   663→\tid := r.PathValue(\"id\")\n   664→\n   665→\trun, err := h.store.GetRun(r.Context(), id)\n   666→\tif err != nil {\n   667→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   668→\t\tw.WriteHeader(http.StatusNotFound)\n   669→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"run not found\"})\n   670→\t\treturn\n   671→\t}\n   672→\n   673→\tmgr, ok := h.container.(ContainerManager)\n   674→\tif !ok || run.ContainerID == \"\" {\n   675→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   676→\t\tw.WriteHeader(http.StatusBadRequest)\n   677→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"container management not available\"})\n   678→\t\treturn\n   679→\t}\n   680→\n   681→\tif err := mgr.Remove(r.Context(), run.ContainerID); err != nil {\n   682→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   683→\t\tw.WriteHeader(http.StatusInternalServerError)\n   684→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to remove container: %v\", err)})\n   685→\t\treturn\n   686→\t}\n   687→\n   688→\trun.ContainerKept = false\n   689→\tif err := h.store.UpdateRun(r.Context(), run); err != nil {\n   690→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   691→\t\tw.WriteHeader(http.StatusInternalServerError)\n   692→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to update run: %v\", err)})\n   693→\t\treturn\n   694→\t}\n   695→\n   696→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   697→\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n   698→}\n   699→\n   700→func (h *Handler) handleAPITriggerOrchestrator(w http.ResponseWriter, r *http.Request) {\n   701→\tlabel := r.PathValue(\"name\")\n   702→\n   703→\t// Resolve label back to project directory via the store.\n   704→\tprojects, _ := h.store.ListProjects(r.Context())\n   705→\tlabels := projectLabels(projects)\n   706→\tvar projectDir string\n   707→\tfor dir, l := range labels {\n   708→\t\tif l == label {\n   709→\t\t\tprojectDir = dir\n   710→\t\t\tbreak\n   711→\t\t}\n   712→\t}\n   713→\tif projectDir == \"\" {\n   714→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   715→\t\tw.WriteHeader(http.StatusNotFound)\n   716→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"project not found\"})\n   717→\t\treturn\n   718→\t}\n   719→\n   720→\tif h.orchestrateFn == nil {\n   721→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   722→\t\tw.WriteHeader(http.StatusNotImplemented)\n   723→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n   724→\t\treturn\n   725→\t}\n   726→\n   727→\tdispatched, err := h.orchestrateFn(r.Context(), projectDir)\n   728→\tif err != nil {\n   729→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   730→\t\tw.WriteHeader(http.StatusInternalServerError)\n   731→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": err.Error()})\n   732→\t\treturn\n   733→\t}\n   734→\n   735→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   736→\tjson.NewEncoder(w).Encode(map[string]any{\"status\": \"ok\", \"project\": label, \"dispatched\": dispatched})\n   737→}\n   738→\n   739→// handleAPIStream serves an SSE stream of log lines for a run.\n   740→// For active runs, it subscribes to the live broadcaster.\n   741→// For completed runs, it serves the archived full.log then closes.\n   742→func (h *Handler) handleAPIStream(w http.ResponseWriter, r *http.Request) {\n   743→\tid := r.PathValue(\"id\")\n   744→\n   745→\trun, err := h.store.GetRun(r.Context(), id)\n   746→\tif err != nil {\n   747→\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   748→\t\treturn\n   749→\t}\n   750→\n   751→\tflusher, ok := w.(http.Flusher)\n   752→\tif !ok {\n   753→\t\thttp.Error(w, \"streaming not supported\", http.StatusInternalServerError)\n   754→\t\treturn\n   755→\t}\n   756→\n   757→\tw.Header().Set(\"Content-Type\", \"text/event-stream\")\n   758→\tw.Header().Set(\"Cache-Control\", \"no-cache\")\n   759→\tw.Header().Set(\"Connection\", \"keep-alive\")\n   760→\tw.Header().Set(\"X-Accel-Buffering\", \"no\")\n   761→\n   762→\tisComplete := run.State == domain.RunStateSucceeded ||\n   763→\t\trun.State == domain.RunStateFailed ||\n   764→\t\trun.State == domain.RunStateCancelled\n   765→\n   766→\tif isComplete {\n   767→\t\t// Serve archived full.log\n   768→\t\th.streamFullLog(w, flusher, run)\n   769→\t\t// Send done event\n   770→\t\tfmt.Fprintf(w, \"event: done\\ndata: %s\\n\\n\", string(run.State))\n   771→\t\tflusher.Flush()\n   772→\t\treturn\n   773→\t}\n   774→\n   775→\t// Active run: subscribe to live broadcaster\n   776→\tif h.logBroadcast == nil {\n   777→\t\thttp.Error(w, \"log streaming not available\", http.StatusServiceUnavailable)\n   778→\t\treturn\n   779→\t}\n   780→\n   781→\tsub := h.logBroadcast.Subscribe(id)\n   782→\tdefer h.logBroadcast.Unsubscribe(id, sub)\n   783→\n   784→\tctx := r.Context()\n   785→\tfor {\n   786→\t\tselect {\n   787→\t\tcase <-ctx.Done():\n   788→\t\t\treturn\n   789→\t\tcase line, ok := <-sub.C:\n   790→\t\t\tif !ok {\n   791→\t\t\t\t// Stream finished (run completed)\n   792→\t\t\t\tfmt.Fprintf(w, \"event: done\\ndata: completed\\n\\n\")\n   793→\t\t\t\tflusher.Flush()\n   794→\t\t\t\treturn\n   795→\t\t\t}\n   796→\t\t\tdata, _ := json.Marshal(line)\n   797→\t\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n   798→\t\t\tflusher.Flush()\n   799→\t\t}\n   800→\t}\n   801→}\n   802→\n   803→// logLineRegex parses \"[timestamp] [type] content\" format from full.log.\n   804→var logLineRegex = regexp.MustCompile(`^\\[([^\\]]+)\\] \\[([^\\]]+)\\] (.*)$`)\n   805→\n   806→// streamFullLog reads the archived full.log file and sends its entries as SSE events.\n   807→func (h *Handler) streamFullLog(w http.ResponseWriter, flusher http.Flusher, run *domain.Run) {\n   808→\tlogPath := filepath.Join(run.ProjectDir, \".cloche\", run.ID, \"output\", \"full.log\")\n   809→\tf, err := os.Open(logPath)\n   810→\tif err != nil {\n   811→\t\treturn\n   812→\t}\n   813→\tdefer f.Close()\n   814→\n   815→\tscanner := bufio.NewScanner(f)\n   816→\tfor scanner.Scan() {\n   817→\t\ttext := scanner.Text()\n   818→\t\tline := parseFullLogLine(text)\n   819→\t\tdata, _ := json.Marshal(line)\n   820→\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n   821→\t\tflusher.Flush()\n   822→\t}\n   823→}\n   824→\n   825→// parseFullLogLine parses a \"[timestamp] [type] content\" line into a LogLine.\n   826→func parseFullLogLine(text string) logstream.LogLine {\n   827→\tm := logLineRegex.FindStringSubmatch(text)\n   828→\tif m == nil {\n   829→\t\treturn logstream.LogLine{\n   830→\t\t\tTimestamp: time.Now().UTC().Format(time.RFC3339),\n   831→\t\t\tType:      \"script\",\n   832→\t\t\tContent:   text,\n   833→\t\t}\n   834→\t}\n   835→\treturn logstream.LogLine{\n   836→\t\tTimestamp: m[1],\n   837→\t\tType:      m[2],\n   838→\t\tContent:   m[3],\n   839→\t}\n   840→}\n   841→\n   842→// --- Project detail handlers ---\n   843→\n   844→// resolveProjectDir resolves a project label from the URL to its directory path.\n   845→// Returns (dir, label, ok). Writes a JSON error response if not found.\n   846→func (h *Handler) resolveProjectDir(w http.ResponseWriter, r *http.Request) (string, string, bool) {\n   847→\tlabel := r.PathValue(\"name\")\n   848→\tprojects, _ := h.store.ListProjects(r.Context())\n   849→\tlabels := projectLabels(projects)\n   850→\tfor dir, l := range labels {\n   851→\t\tif l == label {\n   852→\t\t\treturn dir, label, true\n   853→\t\t}\n   854→\t}\n   855→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   856→\tw.WriteHeader(http.StatusNotFound)\n   857→\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"project not found\"})\n   858→\treturn \"\", \"\", false\n   859→}\n   860→\n   861→func (h *Handler) handleProjectDetail(w http.ResponseWriter, r *http.Request) {\n   862→\tdir, label, ok := h.resolveProjectDir(w, r)\n   863→\tif !ok {\n   864→\t\treturn\n   865→\t}\n   866→\n   867→\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   868→\tn := 10\n   869→\tif n > len(runs) {\n   870→\t\tn = len(runs)\n   871→\t}\n   872→\tdots := make([]recentRunDot, n)\n   873→\tfor i := 0; i < n; i++ {\n   874→\t\tdots[i] = recentRunDot{ID: runs[i].ID, State: string(runs[i].State)}\n   875→\t}\n   876→\n   877→\tdata := map[string]any{\n   878→\t\t\"Title\":      label,\n   879→\t\t\"Label\":      label,\n   880→\t\t\"Dir\":        dir,\n   881→\t\t\"RecentRuns\": dots,\n   882→\t}\n   883→\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   884→\tif err := h.pages[\"project_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   885→\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   886→\t}\n   887→}\n   888→\n   889→func (h *Handler) handleAPIOrchestratorStatus(w http.ResponseWriter, r *http.Request) {\n   890→\tdir, _, ok := h.resolveProjectDir(w, r)\n   891→\tif !ok {\n   892→\t\treturn\n   893→\t}\n   894→\tif h.orchestrator == nil {\n   895→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   896→\t\tjson.NewEncoder(w).Encode(map[string]any{\"enabled\": false, \"in_flight\": 0, \"concurrency\": 0})\n   897→\t\treturn\n   898→\t}\n   899→\tenabled, inFlight, concurrency := h.orchestrator.Status(dir)\n   900→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   901→\tjson.NewEncoder(w).Encode(map[string]any{\n   902→\t\t\"enabled\":     enabled,\n   903→\t\t\"in_flight\":   inFlight,\n   904→\t\t\"concurrency\": concurrency,\n   905→\t})\n   906→}\n   907→\n   908→func (h *Handler) handleAPIOrchestratorStart(w http.ResponseWriter, r *http.Request) {\n   909→\tdir, _, ok := h.resolveProjectDir(w, r)\n   910→\tif !ok {\n   911→\t\treturn\n   912→\t}\n   913→\tif h.orchestrator == nil {\n   914→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   915→\t\tw.WriteHeader(http.StatusNotImplemented)\n   916→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n   917→\t\treturn\n   918→\t}\n   919→\th.orchestrator.SetEnabled(dir, true)\n   920→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   921→\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n   922→}\n   923→\n   924→func (h *Handler) handleAPIOrchestratorStop(w http.ResponseWriter, r *http.Request) {\n   925→\tdir, _, ok := h.resolveProjectDir(w, r)\n   926→\tif !ok {\n   927→\t\treturn\n   928→\t}\n   929→\tif h.orchestrator == nil {\n   930→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   931→\t\tw.WriteHeader(http.StatusNotImplemented)\n   932→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n   933→\t\treturn\n   934→\t}\n   935→\th.orchestrator.SetEnabled(dir, false)\n   936→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   937→\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n   938→}\n   939→\n   940→func (h *Handler) handleAPIOrchestratorConcurrency(w http.ResponseWriter, r *http.Request) {\n   941→\tdir, _, ok := h.resolveProjectDir(w, r)\n   942→\tif !ok {\n   943→\t\treturn\n   944→\t}\n   945→\tif h.orchestrator == nil {\n   946→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   947→\t\tw.WriteHeader(http.StatusNotImplemented)\n   948→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n   949→\t\treturn\n   950→\t}\n   951→\tvar body struct {\n   952→\t\tConcurrency int `json:\"concurrency\"`\n   953→\t}\n   954→\tif err := json.NewDecoder(r.Body).Decode(&body); err != nil || body.Concurrency < 1 {\n   955→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   956→\t\tw.WriteHeader(http.StatusBadRequest)\n   957→\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"concurrency must be a positive integer\"})\n   958→\t\treturn\n   959→\t}\n   960→\th.orchestrator.SetConcurrency(dir, body.Concurrency)\n   961→\tw.Header().Set(\"Content-Type\", \"application/json\")\n   962→\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n   963→}\n   964→\n   965→func (h *Handler) handleAPIProjectInfo(w http.ResponseWriter, r *http.Request) {\n   966→\tdir, _, ok := h.resolveProjectDir(w, r)\n   967→\tif !ok {\n   968→\t\treturn\n   969→\t}\n   970→\n   971→\t// Docker image: read FROM line from Dockerfile\n   972→\tdockerImage := \"\"\n   973→\tdockerfilePath := filepath.Join(dir, \".cloche\", \"Dockerfile\")\n   974→\tif data, err := os.ReadFile(dockerfilePath); err == nil {\n   975→\t\t// Find the last FROM line (final stage)\n   976→\t\tfor _, line := range strings.Split(string(data), \"\\n\") {\n   977→\t\t\ttrimmed := strings.TrimSpace(line)\n   978→\t\t\tif strings.HasPrefix(strings.ToUpper(trimmed), \"FROM \") {\n   979→\t\t\t\tparts := strings.Fields(trimmed)\n   980→\t\t\t\tif len(parts) >= 2 {\n   981→\t\t\t\t\tdockerImage = parts[1]\n   982→\t\t\t\t}\n   983→\t\t\t}\n   984→\t\t}\n   985→\t}\n   986→\n   987→\t// Version\n   988→\tversion := 0\n   989→\tversionPath := filepath.Join(dir, \".cloche\", \"version\")\n   990→\tif data, err := os.ReadFile(versionPath); err == nil {\n   991→\t\tif v, err := strconv.Atoi(strings.TrimSpace(string(data))); err == nil {\n   992→\t\t\tversion = v\n   993→\t\t}\n   994→\t}\n   995→\n   996→\t// Prompt files history\n   997→\ttype commitEntry struct {\n   998→\t\tSHA     string `json:\"sha\"`\n   999→\t\tDate    string `json:\"date\"`\n  1000→\t\tMessage string `json:\"message\"`\n  1001→\t}\n  1002→\ttype promptFile struct {\n  1003→\t\tPath    string        `json:\"path\"`\n  1004→\t\tHistory []commitEntry `json:\"history\"`\n  1005→\t}\n  1006→\n  1007→\tvar promptFiles []promptFile\n  1008→\tpromptsDir := filepath.Join(dir, \".cloche\", \"prompts\")\n  1009→\tif entries, err := os.ReadDir(promptsDir); err == nil {\n  1010→\t\tfor _, e := range entries {\n  1011→\t\t\tif e.IsDir() {\n  1012→\t\t\t\tcontinue\n  1013→\t\t\t}\n  1014→\t\t\trelPath := filepath.Join(\".cloche\", \"prompts\", e.Name())\n  1015→\t\t\tcmd := exec.Command(\"git\", \"log\", \"--follow\", \"--format=%H %aI %s\", \"--\", relPath)\n  1016→\t\t\tcmd.Dir = dir\n  1017→\t\t\tout, err := cmd.Output()\n  1018→\t\t\tif err != nil {\n  1019→\t\t\t\tcontinue\n  1020→\t\t\t}\n  1021→\t\t\tvar history []commitEntry\n  1022→\t\t\tfor _, line := range strings.Split(strings.TrimSpace(string(out)), \"\\n\") {\n  1023→\t\t\t\tif line == \"\" {\n  1024→\t\t\t\t\tcontinue\n  1025→\t\t\t\t}\n  1026→\t\t\t\tparts := strings.SplitN(line, \" \", 3)\n  1027→\t\t\t\tif len(parts) < 3 {\n  1028→\t\t\t\t\tcontinue\n  1029→\t\t\t\t}\n  1030→\t\t\t\t// Parse date to short form\n  1031→\t\t\t\tdateStr := parts[1]\n  1032→\t\t\t\tif t, err := time.Parse(time.RFC3339, dateStr); err == nil {\n  1033→\t\t\t\t\tdateStr = t.Format(\"2006-01-02\")\n  1034→\t\t\t\t}\n  1035→\t\t\t\thistory = append(history, commitEntry{\n  1036→\t\t\t\t\tSHA:     parts[0][:7],\n  1037→\t\t\t\t\tDate:    dateStr,\n  1038→\t\t\t\t\tMessage: parts[2],\n  1039→\t\t\t\t})\n  1040→\t\t\t}\n  1041→\t\t\tpromptFiles = append(promptFiles, promptFile{Path: relPath, History: history})\n  1042→\t\t}\n  1043→\t}\n  1044→\n  1045→\tw.Header().Set(\"Content-Type\", \"application/json\")\n  1046→\tjson.NewEncoder(w).Encode(map[string]any{\n  1047→\t\t\"docker_image\": dockerImage,\n  1048→\t\t\"version\":      version,\n  1049→\t\t\"prompt_files\": promptFiles,\n  1050→\t})\n  1051→}\n  1052→\n  1053→func (h *Handler) handleAPIPromptDiff(w http.ResponseWriter, r *http.Request) {\n  1054→\tdir, _, ok := h.resolveProjectDir(w, r)\n  1055→\tif !ok {\n  1056→\t\treturn\n  1057→\t}\n  1058→\tfile := r.URL.Query().Get(\"file\")\n  1059→\tsha := r.URL.Query().Get(\"sha\")\n  1060→\tif file == \"\" || sha == \"\" {\n  1061→\t\thttp.Error(w, \"file and sha required\", http.StatusBadRequest)\n  1062→\t\treturn\n  1063→\t}\n  1064→\n  1065→\t// Validate sha is alphanumeric to prevent injection\n  1066→\tfor _, c := range sha {\n  1067→\t\tif !((c >= '0' && c <= '9') || (c >= 'a' && c <= 'f') || (c >= 'A' && c <= 'F')) {\n  1068→\t\t\thttp.Error(w, \"invalid sha\", http.StatusBadRequest)\n  1069→\t\t\treturn\n  1070→\t\t}\n  1071→\t}\n  1072→\n  1073→\tcmd := exec.Command(\"git\", \"diff\", sha+\"^..\"+sha, \"--\", file)\n  1074→\tcmd.Dir = dir\n  1075→\tout, err := cmd.Output()\n  1076→\tif err != nil {\n  1077→\t\thttp.Error(w, \"diff not available\", http.StatusNotFound)\n  1078→\t\treturn\n  1079→\t}\n  1080→\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n  1081→\tw.Write(out)\n  1082→}\n  1083→\n  1084→func (h *Handler) handleAPIWorkflows(w http.ResponseWriter, r *http.Request) {\n  1085→\tdir, _, ok := h.resolveProjectDir(w, r)\n  1086→\tif !ok {\n  1087→\t\treturn\n  1088→\t}\n  1089→\n  1090→\tclocheDir := filepath.Join(dir, \".cloche\")\n  1091→\tentries, err := os.ReadDir(clocheDir)\n  1092→\tif err != nil {\n  1093→\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n  1094→\t\tjson.NewEncoder(w).Encode([]any{})\n  1095→\t\treturn\n  1096→\t}\n  1097→\n  1098→\ttype apiWire struct {\n  1099→\t\tFrom   string `json:\"from\"`\n  1100→\t\tResult string `json:\"result\"`\n  1101→\t\tTo     string `json:\"to\"`\n  1102→\t}\n  1103→\ttype apiStepDef struct {\n  1104→\t\tName    string            `json:\"name\"`\n  1105→\t\tType    string            `json:\"type\"`\n  1106→\t\tResults []string          `json:\"results\"`\n  1107→\t\tConfig  map[string]string `json:\"config\"`\n  1108→\t}\n  1109→\ttype apiWorkflow struct {\n  1110→\t\tName      string       `json:\"name\"`\n  1111→\t\tFile      string       `json:\"file\"`\n  1112→\t\tSteps     []apiStepDef `json:\"steps\"`\n  1113→\t\tWires     []apiWire    `json:\"wires\"`\n  1114→\t\tEntryStep string       `json:\"entry_step\"`\n  1115→\t}\n  1116→\n  1117→\tvar workflows []apiWorkflow\n  1118→\tfor _, e := range entries {\n  1119→\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n  1120→\t\t\tcontinue\n  1121→\t\t}\n  1122→\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n  1123→\t\tif err != nil {\n  1124→\t\t\tcontinue\n  1125→\t\t}\n  1126→\t\twf, err := dsl.Parse(string(data))\n  1127→\t\tif err != nil {\n  1128→\t\t\tcontinue\n  1129→\t\t}\n  1130→\t\tvar steps []apiStepDef\n  1131→\t\tfor _, s := range wf.Steps {\n  1132→\t\t\tsteps = append(steps, apiStepDef{\n  1133→\t\t\t\tName:    s.Name,\n  1134→\t\t\t\tType:    string(s.Type),\n  1135→\t\t\t\tResults: s.Results,\n  1136→\t\t\t\tConfig:  s.Config,\n  1137→\t\t\t})\n  1138→\t\t}\n  1139→\t\t// Sort steps by name for consistent ordering\n  1140→\t\tsort.Slice(steps, func(i, j int) bool { return steps[i].Name < steps[j].Name })\n  1141→\n  1142→\t\tvar wires []apiWire\n  1143→\t\tfor _, wire := range wf.Wiring {\n  1144→\t\t\twires = append(wires, apiWire{From: wire.From, Result: wire.Result, To: wire.To})\n  1145→\t\t}\n  1146→\n  1147→\t\tworkflows = append(workflows, apiWorkflow{\n  1148→\t\t\tName:      wf.Name,\n  1149→\t\t\tFile:      filepath.Join(\".cloche\", e.Name()),\n  1150→\t\t\tSteps:     steps,\n  1151→\t\t\tWires:     wires,\n  1152→\t\t\tEntryStep: wf.EntryStep,\n  1153→\t\t})\n  1154→\t}\n  1155→\n  1156→\tw.Header().Set(\"Content-Type\", \"application/json\")\n  1157→\tjson.NewEncoder(w).Encode(workflows)\n  1158→}\n  1159→\n  1160→func (h *Handler) handleAPIStepContent(w http.ResponseWriter, r *http.Request) {\n  1161→\tdir, _, ok := h.resolveProjectDir(w, r)\n  1162→\tif !ok {\n  1163→\t\treturn\n  1164→\t}\n  1165→\tworkflowName := r.PathValue(\"workflow\")\n  1166→\tstepName := r.PathValue(\"step\")\n  1167→\n  1168→\t// Find the workflow file\n  1169→\tclocheDir := filepath.Join(dir, \".cloche\")\n  1170→\tvar wf *domain.Workflow\n  1171→\tentries, _ := os.ReadDir(clocheDir)\n  1172→\tfor _, e := range entries {\n  1173→\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n  1174→\t\t\tcontinue\n  1175→\t\t}\n  1176→\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n  1177→\t\tif err != nil {\n  1178→\t\t\tcontinue\n  1179→\t\t}\n  1180→\t\tparsed, err := dsl.Parse(string(data))\n  1181→\t\tif err != nil {\n  1182→\t\t\tcontinue\n  1183→\t\t}\n  1184→\t\tif parsed.Name == workflowName {\n  1185→\t\t\twf = parsed\n  1186→\t\t\tbreak\n  1187→\t\t}\n  1188→\t}\n  1189→\tif wf == nil {\n  1190→\t\thttp.Error(w, \"workflow not found\", http.StatusNotFound)\n  1191→\t\treturn\n  1192→\t}\n  1193→\n  1194→\tstep, ok := wf.Steps[stepName]\n  1195→\tif !ok {\n  1196→\t\thttp.Error(w, \"step not found\", http.StatusNotFound)\n  1197→\t\treturn\n  1198→\t}\n  1199→\n  1200→\t// Try to read the referenced file from step config\n  1201→\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n  1202→\n  1203→\tif prompt := step.Config[\"prompt\"]; prompt != \"\" {\n  1204→\t\tdata, err := os.ReadFile(filepath.Join(dir, prompt))\n  1205→\t\tif err == nil {\n  1206→\t\t\tw.Write(data)\n  1207→\t\t\treturn\n  1208→\t\t}\n  1209→\t}\n  1210→\tif script := step.Config[\"command\"]; script != \"\" {\n  1211→\t\tw.Write([]byte(script))\n  1212→\t\treturn\n  1213→\t}\n  1214→\tif script := step.Config[\"script\"]; script != \"\" {\n  1215→\t\tdata, err := os.ReadFile(filepath.Join(dir, script))\n  1216→\t\tif err == nil {\n  1217→\t\t\tw.Write(data)\n  1218→\t\t\treturn\n  1219→\t\t}\n  1220→\t\tw.Write([]byte(script))\n  1221→\t\treturn\n  1222→\t}\n  1223→\n  1224→\thttp.Error(w, \"no content available\", http.StatusNotFound)\n  1225→}\n  1226→\n  1227→// --- Template helpers ---\n  1228→\n  1229→func stateColor(state domain.RunState) string {\n  1230→\tswitch state {\n  1231→\tcase domain.RunStatePending:\n  1232→\t\treturn \"pending\"\n  1233→\tcase domain.RunStateRunning:\n  1234→\t\treturn \"running\"\n  1235→\tcase domain.RunStateSucceeded:\n  1236→\t\treturn \"succeeded\"\n  1237→\tcase domain.RunStateFailed:\n  1238→\t\treturn \"failed\"\n  1239→\tcase domain.RunStateCancelled:\n  1240→\t\treturn \"cancelled\"\n  1241→\tdefault:\n  1242→\t\treturn \"pending\"\n  1243→\t}\n  1244→}\n  1245→\n  1246→func healthColor(status domain.HealthStatus) string {\n  1247→\tswitch status {\n  1248→\tcase domain.HealthGreen:\n  1249→\t\treturn \"green\"\n  1250→\tcase domain.HealthYellow:\n  1251→\t\treturn \"yellow\"\n  1252→\tcase domain.HealthRed:\n  1253→\t\treturn \"red\"\n  1254→\tcase domain.HealthBlue:\n  1255→\t\treturn \"blue\"\n  1256→\tdefault:\n  1257→\t\treturn \"grey\"\n  1258→\t}\n  1259→}\n  1260→\n  1261→func formatTime(t time.Time) string {\n  1262→\tif t.IsZero() {\n  1263→\t\treturn \"\"\n  1264→\t}\n  1265→\treturn t.Format(\"2006-01-02 15:04:05\")\n  1266→}\n  1267→\n  1268→func formatDuration(start, end time.Time) string {\n  1269→\tif start.IsZero() || end.IsZero() {\n  1270→\t\treturn \"\"\n  1271→\t}\n  1272→\td := end.Sub(start)\n  1273→\tif d < time.Second {\n  1274→\t\treturn fmt.Sprintf(\"%dms\", d.Milliseconds())\n  1275→\t}\n  1276→\tif d < time.Minute {\n  1277→\t\treturn fmt.Sprintf(\"%.1fs\", d.Seconds())\n  1278→\t}\n  1279→\treturn fmt.Sprintf(\"%dm%ds\", int(d.Minutes()), int(d.Seconds())%60)\n  1280→}\n  1281→\n  1282→func truncate(s string, n int) string {\n  1283→\tif len(s) <= n {\n  1284→\t\treturn s\n  1285→\t}\n  1286→\treturn s[:n] + \"...\"\n  1287→}\n  1288→\n  1289→func shortContainerID(id string) string {\n  1290→\tif len(id) > 12 {\n  1291→\t\treturn id[:12]\n  1292→\t}\n  1293→\treturn id\n  1294→}\n  1295→\n  1296→// projectLabels builds a mapping from full project directory paths to short\n  1297→// display labels. Each label is the final directory component (e.g.\n  1298→// \"myproject\" from \"/home/user/workspace/myproject\"). When two projects share\n  1299→// the same final name, the parent directory is prepended to disambiguate\n  1300→// (e.g. \"foo/bar\" vs \"baz/bar\").\n  1301→func projectLabels(dirs []string) map[string]string {\n  1302→\tlabels := make(map[string]string, len(dirs))\n  1303→\t// Group dirs by their base name to detect conflicts.\n  1304→\tbyBase := map[string][]string{}\n  1305→\tfor _, d := range dirs {\n  1306→\t\tbase := filepath.Base(d)\n  1307→\t\tbyBase[base] = append(byBase[base], d)\n  1308→\t}\n  1309→\tfor base, paths := range byBase {\n  1310→\t\tif len(paths) == 1 {\n  1311→\t\t\tlabels[paths[0]] = base\n  1312→\t\t} else {\n  1313→\t\t\tfor _, p := range paths {\n  1314→\t\t\t\tparent := filepath.Base(filepath.Dir(p))\n  1315→\t\t\t\tlabels[p] = parent + \"/\" + base\n  1316→\t\t\t}\n  1317→\t\t}\n  1318→\t}\n  1319→\treturn labels\n  1320→}\n  1321→\n  1322→type projectEntry struct {\n  1323→\tDir            string\n  1324→\tLabel          string\n  1325→\tContainerCount int\n  1326→}\n  1327→"}]},"parent_tool_use_id":null,"session_id":"a694c1e4-90d4-4886-83d4-c69fb8f4b627","uuid":"5b2ae716-06cb-4886-856a-2d713d6eac63","tool_use_result":{"type":"text","file":{"filePath":"/workspace/internal/adapters/web/handler.go","content":"package web\n\nimport (\n\t\"bufio\"\n\t\"context\"\n\t\"embed\"\n\t\"encoding/json\"\n\t\"fmt\"\n\t\"html/template\"\n\t\"io/fs\"\n\t\"net/http\"\n\t\"os\"\n\t\"os/exec\"\n\t\"path/filepath\"\n\t\"regexp\"\n\t\"sort\"\n\t\"strconv\"\n\t\"strings\"\n\t\"time\"\n\n\t\"github.com/cloche-dev/cloche/internal/domain\"\n\t\"github.com/cloche-dev/cloche/internal/dsl\"\n\t\"github.com/cloche-dev/cloche/internal/logstream\"\n\t\"github.com/cloche-dev/cloche/internal/ports\"\n)\n\n// HandlerOption configures optional Handler dependencies.\ntype HandlerOption func(*Handler)\n\n// WithContainerLogger sets the container runtime for fetching live logs.\nfunc WithContainerLogger(c ContainerLogger) HandlerOption {\n\treturn func(h *Handler) { h.container = c }\n}\n\n// WithContainerManager sets a full container manager (logs, inspect, remove).\nfunc WithContainerManager(c ContainerManager) HandlerOption {\n\treturn func(h *Handler) { h.container = c }\n}\n\n// WithLogBroadcaster sets the log broadcaster for SSE streaming.\nfunc WithLogBroadcaster(b *logstream.Broadcaster) HandlerOption {\n\treturn func(h *Handler) { h.logBroadcast = b }\n}\n\n// WithLogStore sets the log store for indexed log file lookups.\nfunc WithLogStore(ls ports.LogStore) HandlerOption {\n\treturn func(h *Handler) { h.logStore = ls }\n}\n\n// WithOrchestrateFunc sets the function called when the orchestrator is triggered.\nfunc WithOrchestrateFunc(fn func(ctx context.Context, projectDir string) (int, error)) HandlerOption {\n\treturn func(h *Handler) { h.orchestrateFn = fn }\n}\n\n// OrchestratorController provides per-project orchestrator control.\ntype OrchestratorController interface {\n\tStatus(dir string) (enabled bool, inFlight int, concurrency int)\n\tSetEnabled(dir string, enabled bool)\n\tSetConcurrency(dir string, concurrency int)\n}\n\n// WithOrchestrator sets the orchestrator controller for project-level control.\nfunc WithOrchestrator(oc OrchestratorController) HandlerOption {\n\treturn func(h *Handler) { h.orchestrator = oc }\n}\n\n//go:embed templates/*.html static/*\nvar content embed.FS\n\n// Handler serves the web dashboard.\n// ContainerLogger can retrieve logs from a container by ID.\ntype ContainerLogger interface {\n\tLogs(ctx context.Context, containerID string) (string, error)\n}\n\n// ContainerManager extends ContainerLogger with container lifecycle operations.\ntype ContainerManager interface {\n\tContainerLogger\n\tRemove(ctx context.Context, containerID string) error\n\tInspect(ctx context.Context, containerID string) (*ports.ContainerStatus, error)\n}\n\ntype Handler struct {\n\tstore         ports.RunStore\n\tcaptures      ports.CaptureStore\n\tlogStore      ports.LogStore\n\tcontainer     ContainerLogger\n\tlogBroadcast  *logstream.Broadcaster\n\torchestrateFn func(ctx context.Context, projectDir string) (int, error)\n\torchestrator  OrchestratorController\n\tpages         map[string]*template.Template\n\tmux           *http.ServeMux\n}\n\n// NewHandler creates a web dashboard handler.\nfunc NewHandler(store ports.RunStore, captures ports.CaptureStore, opts ...HandlerOption) (*Handler, error) {\n\tfuncMap := template.FuncMap{\n\t\t\"stateColor\":       stateColor,\n\t\t\"healthColor\":      healthColor,\n\t\t\"formatTime\":       formatTime,\n\t\t\"formatDuration\":   formatDuration,\n\t\t\"truncate\":         truncate,\n\t\t\"shortContainerID\": shortContainerID,\n\t}\n\n\tbase, err := template.New(\"\").Funcs(funcMap).ParseFS(content, \"templates/layout.html\")\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"parse layout: %w\", err)\n\t}\n\n\tpages := map[string]*template.Template{}\n\tfor _, page := range []string{\"projects\", \"runs\", \"run_detail\", \"project_detail\"} {\n\t\tclone, err := base.Clone()\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"clone layout for %s: %w\", page, err)\n\t\t}\n\t\t_, err = clone.ParseFS(content, \"templates/\"+page+\".html\")\n\t\tif err != nil {\n\t\t\treturn nil, fmt.Errorf(\"parse %s: %w\", page, err)\n\t\t}\n\t\tpages[page] = clone\n\t}\n\n\th := &Handler{\n\t\tstore:    store,\n\t\tcaptures: captures,\n\t\tpages:    pages,\n\t\tmux:      http.NewServeMux(),\n\t}\n\tfor _, opt := range opts {\n\t\topt(h)\n\t}\n\n\tstaticFS, err := fs.Sub(content, \"static\")\n\tif err != nil {\n\t\treturn nil, fmt.Errorf(\"static sub-fs: %w\", err)\n\t}\n\n\th.mux.HandleFunc(\"GET /{$}\", h.handleProjectOverview)\n\th.mux.HandleFunc(\"GET /runs\", h.handleRunsList)\n\th.mux.HandleFunc(\"GET /runs/{id}\", h.handleRunDetail)\n\th.mux.HandleFunc(\"GET /projects/{name}/runs\", h.handleRunsList)\n\th.mux.HandleFunc(\"GET /projects/{name}\", h.handleProjectDetail)\n\th.mux.HandleFunc(\"GET /api/projects\", h.handleAPIProjects)\n\th.mux.HandleFunc(\"GET /api/runs\", h.handleAPIRuns)\n\th.mux.HandleFunc(\"GET /api/runs/{id}\", h.handleAPIRunDetail)\n\th.mux.HandleFunc(\"GET /api/runs/{id}/steps/{step}/output\", h.handleAPIStepOutput)\n\th.mux.HandleFunc(\"DELETE /api/runs/{id}/container\", h.handleAPIDeleteContainer)\n\th.mux.HandleFunc(\"POST /api/projects/{name}/trigger\", h.handleAPITriggerOrchestrator)\n\th.mux.HandleFunc(\"GET /api/projects/{name}/orchestrator\", h.handleAPIOrchestratorStatus)\n\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/start\", h.handleAPIOrchestratorStart)\n\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/stop\", h.handleAPIOrchestratorStop)\n\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/concurrency\", h.handleAPIOrchestratorConcurrency)\n\th.mux.HandleFunc(\"GET /api/projects/{name}/info\", h.handleAPIProjectInfo)\n\th.mux.HandleFunc(\"GET /api/projects/{name}/info/prompt-diff\", h.handleAPIPromptDiff)\n\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows\", h.handleAPIWorkflows)\n\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows/{workflow}/steps/{step}/content\", h.handleAPIStepContent)\n\th.mux.HandleFunc(\"GET /api/runs/{id}/stream\", h.handleAPIStream)\n\th.mux.Handle(\"GET /static/\", http.StripPrefix(\"/static/\", http.FileServerFS(staticFS)))\n\n\treturn h, nil\n}\n\nfunc (h *Handler) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n\th.mux.ServeHTTP(w, r)\n}\n\n// --- HTML handlers ---\n\n// projectOverviewEntry holds data for a single project card on the landing page.\ntype projectOverviewEntry struct {\n\tDir         string\n\tLabel       string\n\tHealth      domain.HealthResult\n\tRecentRuns  []recentRunDot\n\tActiveCount int\n}\n\n// recentRunDot is a minimal representation of a run for the mini history display.\ntype recentRunDot struct {\n\tID    string\n\tState string\n}\n\nconst healthWindowSize = 10\n\nfunc (h *Handler) handleProjectOverview(w http.ResponseWriter, r *http.Request) {\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\tvar entries []projectOverviewEntry\n\tfor _, dir := range projects {\n\t\truns, err := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\n\t\t// Convert []*domain.Run to []domain.Run for CalculateHealth.\n\t\trunValues := make([]domain.Run, len(runs))\n\t\tfor i, rr := range runs {\n\t\t\trunValues[i] = *rr\n\t\t}\n\n\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n\n\t\t// Take the last N runs for the mini history (most recent first).\n\t\tn := healthWindowSize\n\t\tif n > len(runs) {\n\t\t\tn = len(runs)\n\t\t}\n\t\tdots := make([]recentRunDot, n)\n\t\tfor i := 0; i < n; i++ {\n\t\t\tdots[i] = recentRunDot{\n\t\t\t\tID:    runs[i].ID,\n\t\t\t\tState: string(runs[i].State),\n\t\t\t}\n\t\t}\n\n\t\tvar activeCount int\n\t\tfor _, rr := range runs {\n\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n\t\t\t\tactiveCount++\n\t\t\t}\n\t\t}\n\n\t\tentries = append(entries, projectOverviewEntry{\n\t\t\tDir:         dir,\n\t\t\tLabel:       labels[dir],\n\t\t\tHealth:      health,\n\t\t\tRecentRuns:  dots,\n\t\t\tActiveCount: activeCount,\n\t\t})\n\t}\n\n\tsort.Slice(entries, func(i, j int) bool {\n\t\treturn entries[i].Label < entries[j].Label\n\t})\n\n\tdata := map[string]any{\n\t\t\"Title\":    \"Projects\",\n\t\t\"Projects\": entries,\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n\tif err := h.pages[\"projects\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n\t}\n}\n\nfunc (h *Handler) handleRunsList(w http.ResponseWriter, r *http.Request) {\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\tvar projectFilter string // dir\n\tvar projectLabel string\n\n\t// Resolve project from path (/projects/{name}/runs) or query param (?project=dir)\n\tif name := r.PathValue(\"name\"); name != \"\" {\n\t\tfor dir, l := range labels {\n\t\t\tif l == name {\n\t\t\t\tprojectFilter = dir\n\t\t\t\tprojectLabel = l\n\t\t\t\tbreak\n\t\t\t}\n\t\t}\n\t\tif projectFilter == \"\" {\n\t\t\thttp.Error(w, \"project not found\", http.StatusNotFound)\n\t\t\treturn\n\t\t}\n\t} else if qp := r.URL.Query().Get(\"project\"); qp != \"\" {\n\t\tprojectFilter = qp\n\t\tprojectLabel = labels[qp]\n\t\t// Redirect to clean URL if we can resolve the label\n\t\tif projectLabel != \"\" {\n\t\t\thttp.Redirect(w, r, \"/projects/\"+projectLabel+\"/runs\", http.StatusMovedPermanently)\n\t\t\treturn\n\t\t}\n\t}\n\n\tvar runs []*domain.Run\n\tvar err error\n\tif projectFilter != \"\" {\n\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n\t} else {\n\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n\t}\n\tif err != nil {\n\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\t// Count retained containers per project\n\tcontainerCounts := map[string]int{}\n\tallRuns, _ := h.store.ListRuns(r.Context(), time.Time{})\n\tfor _, run := range allRuns {\n\t\tif run.ContainerKept {\n\t\t\tcontainerCounts[run.ProjectDir]++\n\t\t}\n\t}\n\n\tvar projectList []projectEntry\n\tfor _, dir := range projects {\n\t\tprojectList = append(projectList, projectEntry{Dir: dir, Label: labels[dir], ContainerCount: containerCounts[dir]})\n\t}\n\tsort.Slice(projectList, func(i, j int) bool {\n\t\treturn projectList[i].Label < projectList[j].Label\n\t})\n\n\tdata := map[string]any{\n\t\t\"Title\":         \"Runs\",\n\t\t\"Runs\":          runs,\n\t\t\"Projects\":      projectList,\n\t\t\"ProjectFilter\": projectFilter,\n\t\t\"ProjectLabel\":  projectLabel,\n\t\t\"ProjectLabels\": labels,\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n\tif err := h.pages[\"runs\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n\t}\n}\n\n// stepEntry is a merged view of a step execution for the template.\ntype stepEntry struct {\n\tIndex     int\n\tStepName  string\n\tResult    string\n\tStartedAt time.Time\n\tDuration  string\n}\n\n// mergeCaptures collapses started/completed capture pairs into single entries.\nfunc mergeCaptures(caps []*domain.StepExecution) []stepEntry {\n\tvar entries []stepEntry\n\t// Track pending started rows by step name (LIFO for retries)\n\tpending := map[string]*domain.StepExecution{}\n\n\tfor _, c := range caps {\n\t\tif c.Result == \"\" {\n\t\t\t// step_started row\n\t\t\tpending[c.StepName] = c\n\t\t\tcontinue\n\t\t}\n\t\t// step_completed row — merge with pending started if available\n\t\tstartedAt := c.StartedAt\n\t\tif started := pending[c.StepName]; started != nil {\n\t\t\tstartedAt = started.StartedAt\n\t\t\tdelete(pending, c.StepName)\n\t\t}\n\t\tentries = append(entries, stepEntry{\n\t\t\tIndex:     len(entries),\n\t\t\tStepName:  c.StepName,\n\t\t\tResult:    c.Result,\n\t\t\tStartedAt: startedAt,\n\t\t\tDuration:  formatDuration(startedAt, c.CompletedAt),\n\t\t})\n\t}\n\n\t// Append any started-but-not-completed steps (still running)\n\tfor _, c := range caps {\n\t\tif c.Result == \"\" {\n\t\t\tif _, used := pending[c.StepName]; !used {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tentries = append(entries, stepEntry{\n\t\t\t\tIndex:     len(entries),\n\t\t\t\tStepName:  c.StepName,\n\t\t\t\tStartedAt: c.StartedAt,\n\t\t\t})\n\t\t\tdelete(pending, c.StepName)\n\t\t}\n\t}\n\n\treturn entries\n}\n\n// containerState inspects the container for a run and returns one of:\n//   - \"running\"   – container exists and is running\n//   - \"stopped\"   – container exists, not running, not kept\n//   - \"available\" – container exists, not running, kept (can be deleted)\n//   - \"removed\"   – no container ID, no manager, or inspect failed\nfunc (h *Handler) containerState(ctx context.Context, run *domain.Run) string {\n\tif run.ContainerID == \"\" {\n\t\treturn \"removed\"\n\t}\n\tmgr, ok := h.container.(ContainerManager)\n\tif !ok {\n\t\treturn \"removed\"\n\t}\n\tstatus, err := mgr.Inspect(ctx, run.ContainerID)\n\tif err != nil {\n\t\treturn \"removed\"\n\t}\n\tif status.Running {\n\t\treturn \"running\"\n\t}\n\tif run.ContainerKept {\n\t\treturn \"available\"\n\t}\n\treturn \"stopped\"\n}\n\nfunc (h *Handler) handleRunDetail(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n\tif err != nil {\n\t\tcaps = nil // non-fatal\n\t}\n\n\tsteps := mergeCaptures(caps)\n\n\tdata := map[string]any{\n\t\t\"Title\":          \"Run \" + run.ID,\n\t\t\"Run\":            run,\n\t\t\"Steps\":          steps,\n\t\t\"Page\":           \"detail\",\n\t\t\"ContainerState\": h.containerState(r.Context(), run),\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n\tif err := h.pages[\"run_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n\t}\n}\n\n// --- JSON API handlers ---\n\ntype apiRun struct {\n\tID           string `json:\"id\"`\n\tWorkflowName string `json:\"workflow_name\"`\n\tProjectDir   string `json:\"project_dir\"`\n\tProjectLabel string `json:\"project_label\"`\n\tState        string `json:\"state\"`\n\tStartedAt    string `json:\"started_at\"`\n\tCompletedAt  string `json:\"completed_at\"`\n\tContainerID  string `json:\"container_id\"`\n\tErrorMessage string `json:\"error_message\"`\n}\n\ntype apiStep struct {\n\tStepName    string `json:\"step_name\"`\n\tResult      string `json:\"result\"`\n\tStartedAt   string `json:\"started_at\"`\n\tCompletedAt string `json:\"completed_at\"`\n\tDuration    string `json:\"duration\"`\n}\n\ntype apiRunDetail struct {\n\tapiRun\n\tContainerState string    `json:\"container_state\"`\n\tSteps          []apiStep `json:\"steps\"`\n}\n\nfunc toAPIRun(r *domain.Run, labels map[string]string) apiRun {\n\treturn apiRun{\n\t\tID:           r.ID,\n\t\tWorkflowName: r.WorkflowName,\n\t\tProjectDir:   r.ProjectDir,\n\t\tProjectLabel: labels[r.ProjectDir],\n\t\tState:        string(r.State),\n\t\tStartedAt:    formatTime(r.StartedAt),\n\t\tCompletedAt:  formatTime(r.CompletedAt),\n\t\tContainerID:  r.ContainerID,\n\t\tErrorMessage: r.ErrorMessage,\n\t}\n}\n\nfunc (h *Handler) handleAPIRuns(w http.ResponseWriter, r *http.Request) {\n\tprojectFilter := r.URL.Query().Get(\"project\")\n\n\tvar runs []*domain.Run\n\tvar err error\n\tif projectFilter != \"\" {\n\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n\t} else {\n\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n\t}\n\tif err != nil {\n\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\tresult := make([]apiRun, len(runs))\n\tfor i, run := range runs {\n\t\tresult[i] = toAPIRun(run, labels)\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(result)\n}\n\nfunc (h *Handler) handleAPIProjects(w http.ResponseWriter, r *http.Request) {\n\tprojects, err := h.store.ListProjects(r.Context())\n\tif err != nil {\n\t\thttp.Error(w, \"failed to list projects\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\tlabels := projectLabels(projects)\n\n\ttype apiHealth struct {\n\t\tStatus string `json:\"status\"`\n\t\tPassed int    `json:\"passed\"`\n\t\tFailed int    `json:\"failed\"`\n\t\tTotal  int    `json:\"total\"`\n\t}\n\ttype apiProject struct {\n\t\tDir         string    `json:\"dir\"`\n\t\tLabel       string    `json:\"label\"`\n\t\tHealth      apiHealth `json:\"health\"`\n\t\tActiveCount int       `json:\"active_count\"`\n\t}\n\tresult := make([]apiProject, len(projects))\n\tfor i, dir := range projects {\n\t\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n\t\trunValues := make([]domain.Run, len(runs))\n\t\tfor j, rr := range runs {\n\t\t\trunValues[j] = *rr\n\t\t}\n\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n\t\tvar activeCount int\n\t\tfor _, rr := range runs {\n\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n\t\t\t\tactiveCount++\n\t\t\t}\n\t\t}\n\t\tresult[i] = apiProject{\n\t\t\tDir:   dir,\n\t\t\tLabel: labels[dir],\n\t\t\tHealth: apiHealth{\n\t\t\t\tStatus: string(health.Status),\n\t\t\t\tPassed: health.Passed,\n\t\t\t\tFailed: health.Failed,\n\t\t\t\tTotal:  health.Total,\n\t\t\t},\n\t\t\tActiveCount: activeCount,\n\t\t}\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(result)\n}\n\nfunc (h *Handler) handleAPIRunDetail(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n\tif err != nil {\n\t\tcaps = nil\n\t}\n\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\n\tmerged := mergeCaptures(caps)\n\tsteps := make([]apiStep, len(merged))\n\tfor i, e := range merged {\n\t\tsteps[i] = apiStep{\n\t\t\tStepName:  e.StepName,\n\t\t\tResult:    e.Result,\n\t\t\tStartedAt: formatTime(e.StartedAt),\n\t\t\tDuration:  e.Duration,\n\t\t}\n\t}\n\n\tdetail := apiRunDetail{\n\t\tapiRun:         toAPIRun(run, labels),\n\t\tContainerState: h.containerState(r.Context(), run),\n\t\tSteps:          steps,\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(detail)\n}\n\nfunc (h *Handler) handleAPIStepOutput(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\tstep := r.PathValue(\"step\")\n\tlogType := r.URL.Query().Get(\"type\") // optional: \"script\", \"llm\"\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\t// Try log index first for fast lookup\n\tif h.logStore != nil {\n\t\tlogFiles, err := h.logStore.GetLogFilesByStep(r.Context(), id, step)\n\t\tif err == nil && len(logFiles) > 0 {\n\t\t\t// If type filter specified, narrow results\n\t\t\tfor _, lf := range logFiles {\n\t\t\t\tif logType != \"\" && lf.FileType != logType {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n\t\t\t\tif readErr == nil && len(data) > 0 {\n\t\t\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\t\t\t\t\tw.Write(data)\n\t\t\t\t\treturn\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", id, \"output\")\n\n\t// Fall back to file path conventions\n\t// If type is \"llm\", try llm-<step>.log\n\tif logType == \"llm\" {\n\t\tllmPath := filepath.Join(outputDir, \"llm-\"+step+\".log\")\n\t\tdata, err := os.ReadFile(llmPath)\n\t\tif err == nil && len(data) > 0 {\n\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\t\t\tw.Write(data)\n\t\t\treturn\n\t\t}\n\t}\n\n\t// Try per-step output first, fall back to container.log, then live docker logs\n\toutputPath := filepath.Join(outputDir, step+\".log\")\n\tdata, err := os.ReadFile(outputPath)\n\tif err == nil && len(data) > 0 {\n\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\t\tw.Write(data)\n\t\treturn\n\t}\n\n\tcontainerLog := filepath.Join(outputDir, \"container.log\")\n\tdata, err = os.ReadFile(containerLog)\n\tif err == nil && len(data) > 0 {\n\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\t\tw.Write(data)\n\t\treturn\n\t}\n\n\t// Last resort: try live docker logs from still-existing container\n\tif h.container != nil && run.ContainerID != \"\" {\n\t\tif logs, logErr := h.container.Logs(r.Context(), run.ContainerID); logErr == nil && logs != \"\" {\n\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\t\t\tw.Write([]byte(logs))\n\t\t\treturn\n\t\t}\n\t}\n\n\thttp.Error(w, \"step output not found\", http.StatusNotFound)\n}\n\nfunc (h *Handler) handleAPIDeleteContainer(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusNotFound)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"run not found\"})\n\t\treturn\n\t}\n\n\tmgr, ok := h.container.(ContainerManager)\n\tif !ok || run.ContainerID == \"\" {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusBadRequest)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"container management not available\"})\n\t\treturn\n\t}\n\n\tif err := mgr.Remove(r.Context(), run.ContainerID); err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to remove container: %v\", err)})\n\t\treturn\n\t}\n\n\trun.ContainerKept = false\n\tif err := h.store.UpdateRun(r.Context(), run); err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to update run: %v\", err)})\n\t\treturn\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n}\n\nfunc (h *Handler) handleAPITriggerOrchestrator(w http.ResponseWriter, r *http.Request) {\n\tlabel := r.PathValue(\"name\")\n\n\t// Resolve label back to project directory via the store.\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\tvar projectDir string\n\tfor dir, l := range labels {\n\t\tif l == label {\n\t\t\tprojectDir = dir\n\t\t\tbreak\n\t\t}\n\t}\n\tif projectDir == \"\" {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusNotFound)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"project not found\"})\n\t\treturn\n\t}\n\n\tif h.orchestrateFn == nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusNotImplemented)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n\t\treturn\n\t}\n\n\tdispatched, err := h.orchestrateFn(r.Context(), projectDir)\n\tif err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusInternalServerError)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": err.Error()})\n\t\treturn\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]any{\"status\": \"ok\", \"project\": label, \"dispatched\": dispatched})\n}\n\n// handleAPIStream serves an SSE stream of log lines for a run.\n// For active runs, it subscribes to the live broadcaster.\n// For completed runs, it serves the archived full.log then closes.\nfunc (h *Handler) handleAPIStream(w http.ResponseWriter, r *http.Request) {\n\tid := r.PathValue(\"id\")\n\n\trun, err := h.store.GetRun(r.Context(), id)\n\tif err != nil {\n\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\tflusher, ok := w.(http.Flusher)\n\tif !ok {\n\t\thttp.Error(w, \"streaming not supported\", http.StatusInternalServerError)\n\t\treturn\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"text/event-stream\")\n\tw.Header().Set(\"Cache-Control\", \"no-cache\")\n\tw.Header().Set(\"Connection\", \"keep-alive\")\n\tw.Header().Set(\"X-Accel-Buffering\", \"no\")\n\n\tisComplete := run.State == domain.RunStateSucceeded ||\n\t\trun.State == domain.RunStateFailed ||\n\t\trun.State == domain.RunStateCancelled\n\n\tif isComplete {\n\t\t// Serve archived full.log\n\t\th.streamFullLog(w, flusher, run)\n\t\t// Send done event\n\t\tfmt.Fprintf(w, \"event: done\\ndata: %s\\n\\n\", string(run.State))\n\t\tflusher.Flush()\n\t\treturn\n\t}\n\n\t// Active run: subscribe to live broadcaster\n\tif h.logBroadcast == nil {\n\t\thttp.Error(w, \"log streaming not available\", http.StatusServiceUnavailable)\n\t\treturn\n\t}\n\n\tsub := h.logBroadcast.Subscribe(id)\n\tdefer h.logBroadcast.Unsubscribe(id, sub)\n\n\tctx := r.Context()\n\tfor {\n\t\tselect {\n\t\tcase <-ctx.Done():\n\t\t\treturn\n\t\tcase line, ok := <-sub.C:\n\t\t\tif !ok {\n\t\t\t\t// Stream finished (run completed)\n\t\t\t\tfmt.Fprintf(w, \"event: done\\ndata: completed\\n\\n\")\n\t\t\t\tflusher.Flush()\n\t\t\t\treturn\n\t\t\t}\n\t\t\tdata, _ := json.Marshal(line)\n\t\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n\t\t\tflusher.Flush()\n\t\t}\n\t}\n}\n\n// logLineRegex parses \"[timestamp] [type] content\" format from full.log.\nvar logLineRegex = regexp.MustCompile(`^\\[([^\\]]+)\\] \\[([^\\]]+)\\] (.*)$`)\n\n// streamFullLog reads the archived full.log file and sends its entries as SSE events.\nfunc (h *Handler) streamFullLog(w http.ResponseWriter, flusher http.Flusher, run *domain.Run) {\n\tlogPath := filepath.Join(run.ProjectDir, \".cloche\", run.ID, \"output\", \"full.log\")\n\tf, err := os.Open(logPath)\n\tif err != nil {\n\t\treturn\n\t}\n\tdefer f.Close()\n\n\tscanner := bufio.NewScanner(f)\n\tfor scanner.Scan() {\n\t\ttext := scanner.Text()\n\t\tline := parseFullLogLine(text)\n\t\tdata, _ := json.Marshal(line)\n\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n\t\tflusher.Flush()\n\t}\n}\n\n// parseFullLogLine parses a \"[timestamp] [type] content\" line into a LogLine.\nfunc parseFullLogLine(text string) logstream.LogLine {\n\tm := logLineRegex.FindStringSubmatch(text)\n\tif m == nil {\n\t\treturn logstream.LogLine{\n\t\t\tTimestamp: time.Now().UTC().Format(time.RFC3339),\n\t\t\tType:      \"script\",\n\t\t\tContent:   text,\n\t\t}\n\t}\n\treturn logstream.LogLine{\n\t\tTimestamp: m[1],\n\t\tType:      m[2],\n\t\tContent:   m[3],\n\t}\n}\n\n// --- Project detail handlers ---\n\n// resolveProjectDir resolves a project label from the URL to its directory path.\n// Returns (dir, label, ok). Writes a JSON error response if not found.\nfunc (h *Handler) resolveProjectDir(w http.ResponseWriter, r *http.Request) (string, string, bool) {\n\tlabel := r.PathValue(\"name\")\n\tprojects, _ := h.store.ListProjects(r.Context())\n\tlabels := projectLabels(projects)\n\tfor dir, l := range labels {\n\t\tif l == label {\n\t\t\treturn dir, label, true\n\t\t}\n\t}\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tw.WriteHeader(http.StatusNotFound)\n\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"project not found\"})\n\treturn \"\", \"\", false\n}\n\nfunc (h *Handler) handleProjectDetail(w http.ResponseWriter, r *http.Request) {\n\tdir, label, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\n\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n\tn := 10\n\tif n > len(runs) {\n\t\tn = len(runs)\n\t}\n\tdots := make([]recentRunDot, n)\n\tfor i := 0; i < n; i++ {\n\t\tdots[i] = recentRunDot{ID: runs[i].ID, State: string(runs[i].State)}\n\t}\n\n\tdata := map[string]any{\n\t\t\"Title\":      label,\n\t\t\"Label\":      label,\n\t\t\"Dir\":        dir,\n\t\t\"RecentRuns\": dots,\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n\tif err := h.pages[\"project_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n\t}\n}\n\nfunc (h *Handler) handleAPIOrchestratorStatus(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\tif h.orchestrator == nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tjson.NewEncoder(w).Encode(map[string]any{\"enabled\": false, \"in_flight\": 0, \"concurrency\": 0})\n\t\treturn\n\t}\n\tenabled, inFlight, concurrency := h.orchestrator.Status(dir)\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]any{\n\t\t\"enabled\":     enabled,\n\t\t\"in_flight\":   inFlight,\n\t\t\"concurrency\": concurrency,\n\t})\n}\n\nfunc (h *Handler) handleAPIOrchestratorStart(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\tif h.orchestrator == nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusNotImplemented)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n\t\treturn\n\t}\n\th.orchestrator.SetEnabled(dir, true)\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n}\n\nfunc (h *Handler) handleAPIOrchestratorStop(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\tif h.orchestrator == nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusNotImplemented)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n\t\treturn\n\t}\n\th.orchestrator.SetEnabled(dir, false)\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n}\n\nfunc (h *Handler) handleAPIOrchestratorConcurrency(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\tif h.orchestrator == nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusNotImplemented)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n\t\treturn\n\t}\n\tvar body struct {\n\t\tConcurrency int `json:\"concurrency\"`\n\t}\n\tif err := json.NewDecoder(r.Body).Decode(&body); err != nil || body.Concurrency < 1 {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tw.WriteHeader(http.StatusBadRequest)\n\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"concurrency must be a positive integer\"})\n\t\treturn\n\t}\n\th.orchestrator.SetConcurrency(dir, body.Concurrency)\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n}\n\nfunc (h *Handler) handleAPIProjectInfo(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\n\t// Docker image: read FROM line from Dockerfile\n\tdockerImage := \"\"\n\tdockerfilePath := filepath.Join(dir, \".cloche\", \"Dockerfile\")\n\tif data, err := os.ReadFile(dockerfilePath); err == nil {\n\t\t// Find the last FROM line (final stage)\n\t\tfor _, line := range strings.Split(string(data), \"\\n\") {\n\t\t\ttrimmed := strings.TrimSpace(line)\n\t\t\tif strings.HasPrefix(strings.ToUpper(trimmed), \"FROM \") {\n\t\t\t\tparts := strings.Fields(trimmed)\n\t\t\t\tif len(parts) >= 2 {\n\t\t\t\t\tdockerImage = parts[1]\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\t// Version\n\tversion := 0\n\tversionPath := filepath.Join(dir, \".cloche\", \"version\")\n\tif data, err := os.ReadFile(versionPath); err == nil {\n\t\tif v, err := strconv.Atoi(strings.TrimSpace(string(data))); err == nil {\n\t\t\tversion = v\n\t\t}\n\t}\n\n\t// Prompt files history\n\ttype commitEntry struct {\n\t\tSHA     string `json:\"sha\"`\n\t\tDate    string `json:\"date\"`\n\t\tMessage string `json:\"message\"`\n\t}\n\ttype promptFile struct {\n\t\tPath    string        `json:\"path\"`\n\t\tHistory []commitEntry `json:\"history\"`\n\t}\n\n\tvar promptFiles []promptFile\n\tpromptsDir := filepath.Join(dir, \".cloche\", \"prompts\")\n\tif entries, err := os.ReadDir(promptsDir); err == nil {\n\t\tfor _, e := range entries {\n\t\t\tif e.IsDir() {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\trelPath := filepath.Join(\".cloche\", \"prompts\", e.Name())\n\t\t\tcmd := exec.Command(\"git\", \"log\", \"--follow\", \"--format=%H %aI %s\", \"--\", relPath)\n\t\t\tcmd.Dir = dir\n\t\t\tout, err := cmd.Output()\n\t\t\tif err != nil {\n\t\t\t\tcontinue\n\t\t\t}\n\t\t\tvar history []commitEntry\n\t\t\tfor _, line := range strings.Split(strings.TrimSpace(string(out)), \"\\n\") {\n\t\t\t\tif line == \"\" {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\tparts := strings.SplitN(line, \" \", 3)\n\t\t\t\tif len(parts) < 3 {\n\t\t\t\t\tcontinue\n\t\t\t\t}\n\t\t\t\t// Parse date to short form\n\t\t\t\tdateStr := parts[1]\n\t\t\t\tif t, err := time.Parse(time.RFC3339, dateStr); err == nil {\n\t\t\t\t\tdateStr = t.Format(\"2006-01-02\")\n\t\t\t\t}\n\t\t\t\thistory = append(history, commitEntry{\n\t\t\t\t\tSHA:     parts[0][:7],\n\t\t\t\t\tDate:    dateStr,\n\t\t\t\t\tMessage: parts[2],\n\t\t\t\t})\n\t\t\t}\n\t\t\tpromptFiles = append(promptFiles, promptFile{Path: relPath, History: history})\n\t\t}\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(map[string]any{\n\t\t\"docker_image\": dockerImage,\n\t\t\"version\":      version,\n\t\t\"prompt_files\": promptFiles,\n\t})\n}\n\nfunc (h *Handler) handleAPIPromptDiff(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\tfile := r.URL.Query().Get(\"file\")\n\tsha := r.URL.Query().Get(\"sha\")\n\tif file == \"\" || sha == \"\" {\n\t\thttp.Error(w, \"file and sha required\", http.StatusBadRequest)\n\t\treturn\n\t}\n\n\t// Validate sha is alphanumeric to prevent injection\n\tfor _, c := range sha {\n\t\tif !((c >= '0' && c <= '9') || (c >= 'a' && c <= 'f') || (c >= 'A' && c <= 'F')) {\n\t\t\thttp.Error(w, \"invalid sha\", http.StatusBadRequest)\n\t\t\treturn\n\t\t}\n\t}\n\n\tcmd := exec.Command(\"git\", \"diff\", sha+\"^..\"+sha, \"--\", file)\n\tcmd.Dir = dir\n\tout, err := cmd.Output()\n\tif err != nil {\n\t\thttp.Error(w, \"diff not available\", http.StatusNotFound)\n\t\treturn\n\t}\n\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\tw.Write(out)\n}\n\nfunc (h *Handler) handleAPIWorkflows(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\n\tclocheDir := filepath.Join(dir, \".cloche\")\n\tentries, err := os.ReadDir(clocheDir)\n\tif err != nil {\n\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n\t\tjson.NewEncoder(w).Encode([]any{})\n\t\treturn\n\t}\n\n\ttype apiWire struct {\n\t\tFrom   string `json:\"from\"`\n\t\tResult string `json:\"result\"`\n\t\tTo     string `json:\"to\"`\n\t}\n\ttype apiStepDef struct {\n\t\tName    string            `json:\"name\"`\n\t\tType    string            `json:\"type\"`\n\t\tResults []string          `json:\"results\"`\n\t\tConfig  map[string]string `json:\"config\"`\n\t}\n\ttype apiWorkflow struct {\n\t\tName      string       `json:\"name\"`\n\t\tFile      string       `json:\"file\"`\n\t\tSteps     []apiStepDef `json:\"steps\"`\n\t\tWires     []apiWire    `json:\"wires\"`\n\t\tEntryStep string       `json:\"entry_step\"`\n\t}\n\n\tvar workflows []apiWorkflow\n\tfor _, e := range entries {\n\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n\t\t\tcontinue\n\t\t}\n\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\twf, err := dsl.Parse(string(data))\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tvar steps []apiStepDef\n\t\tfor _, s := range wf.Steps {\n\t\t\tsteps = append(steps, apiStepDef{\n\t\t\t\tName:    s.Name,\n\t\t\t\tType:    string(s.Type),\n\t\t\t\tResults: s.Results,\n\t\t\t\tConfig:  s.Config,\n\t\t\t})\n\t\t}\n\t\t// Sort steps by name for consistent ordering\n\t\tsort.Slice(steps, func(i, j int) bool { return steps[i].Name < steps[j].Name })\n\n\t\tvar wires []apiWire\n\t\tfor _, wire := range wf.Wiring {\n\t\t\twires = append(wires, apiWire{From: wire.From, Result: wire.Result, To: wire.To})\n\t\t}\n\n\t\tworkflows = append(workflows, apiWorkflow{\n\t\t\tName:      wf.Name,\n\t\t\tFile:      filepath.Join(\".cloche\", e.Name()),\n\t\t\tSteps:     steps,\n\t\t\tWires:     wires,\n\t\t\tEntryStep: wf.EntryStep,\n\t\t})\n\t}\n\n\tw.Header().Set(\"Content-Type\", \"application/json\")\n\tjson.NewEncoder(w).Encode(workflows)\n}\n\nfunc (h *Handler) handleAPIStepContent(w http.ResponseWriter, r *http.Request) {\n\tdir, _, ok := h.resolveProjectDir(w, r)\n\tif !ok {\n\t\treturn\n\t}\n\tworkflowName := r.PathValue(\"workflow\")\n\tstepName := r.PathValue(\"step\")\n\n\t// Find the workflow file\n\tclocheDir := filepath.Join(dir, \".cloche\")\n\tvar wf *domain.Workflow\n\tentries, _ := os.ReadDir(clocheDir)\n\tfor _, e := range entries {\n\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n\t\t\tcontinue\n\t\t}\n\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tparsed, err := dsl.Parse(string(data))\n\t\tif err != nil {\n\t\t\tcontinue\n\t\t}\n\t\tif parsed.Name == workflowName {\n\t\t\twf = parsed\n\t\t\tbreak\n\t\t}\n\t}\n\tif wf == nil {\n\t\thttp.Error(w, \"workflow not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\tstep, ok := wf.Steps[stepName]\n\tif !ok {\n\t\thttp.Error(w, \"step not found\", http.StatusNotFound)\n\t\treturn\n\t}\n\n\t// Try to read the referenced file from step config\n\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n\n\tif prompt := step.Config[\"prompt\"]; prompt != \"\" {\n\t\tdata, err := os.ReadFile(filepath.Join(dir, prompt))\n\t\tif err == nil {\n\t\t\tw.Write(data)\n\t\t\treturn\n\t\t}\n\t}\n\tif script := step.Config[\"command\"]; script != \"\" {\n\t\tw.Write([]byte(script))\n\t\treturn\n\t}\n\tif script := step.Config[\"script\"]; script != \"\" {\n\t\tdata, err := os.ReadFile(filepath.Join(dir, script))\n\t\tif err == nil {\n\t\t\tw.Write(data)\n\t\t\treturn\n\t\t}\n\t\tw.Write([]byte(script))\n\t\treturn\n\t}\n\n\thttp.Error(w, \"no content available\", http.StatusNotFound)\n}\n\n// --- Template helpers ---\n\nfunc stateColor(state domain.RunState) string {\n\tswitch state {\n\tcase domain.RunStatePending:\n\t\treturn \"pending\"\n\tcase domain.RunStateRunning:\n\t\treturn \"running\"\n\tcase domain.RunStateSucceeded:\n\t\treturn \"succeeded\"\n\tcase domain.RunStateFailed:\n\t\treturn \"failed\"\n\tcase domain.RunStateCancelled:\n\t\treturn \"cancelled\"\n\tdefault:\n\t\treturn \"pending\"\n\t}\n}\n\nfunc healthColor(status domain.HealthStatus) string {\n\tswitch status {\n\tcase domain.HealthGreen:\n\t\treturn \"green\"\n\tcase domain.HealthYellow:\n\t\treturn \"yellow\"\n\tcase domain.HealthRed:\n\t\treturn \"red\"\n\tcase domain.HealthBlue:\n\t\treturn \"blue\"\n\tdefault:\n\t\treturn \"grey\"\n\t}\n}\n\nfunc formatTime(t time.Time) string {\n\tif t.IsZero() {\n\t\treturn \"\"\n\t}\n\treturn t.Format(\"2006-01-02 15:04:05\")\n}\n\nfunc formatDuration(start, end time.Time) string {\n\tif start.IsZero() || end.IsZero() {\n\t\treturn \"\"\n\t}\n\td := end.Sub(start)\n\tif d < time.Second {\n\t\treturn fmt.Sprintf(\"%dms\", d.Milliseconds())\n\t}\n\tif d < time.Minute {\n\t\treturn fmt.Sprintf(\"%.1fs\", d.Seconds())\n\t}\n\treturn fmt.Sprintf(\"%dm%ds\", int(d.Minutes()), int(d.Seconds())%60)\n}\n\nfunc truncate(s string, n int) string {\n\tif len(s) <= n {\n\t\treturn s\n\t}\n\treturn s[:n] + \"...\"\n}\n\nfunc shortContainerID(id string) string {\n\tif len(id) > 12 {\n\t\treturn id[:12]\n\t}\n\treturn id\n}\n\n// projectLabels builds a mapping from full project directory paths to short\n// display labels. Each label is the final directory component (e.g.\n// \"myproject\" from \"/home/user/workspace/myproject\"). When two projects share\n// the same final name, the parent directory is prepended to disambiguate\n// (e.g. \"foo/bar\" vs \"baz/bar\").\nfunc projectLabels(dirs []string) map[string]string {\n\tlabels := make(map[string]string, len(dirs))\n\t// Group dirs by their base name to detect conflicts.\n\tbyBase := map[string][]string{}\n\tfor _, d := range dirs {\n\t\tbase := filepath.Base(d)\n\t\tbyBase[base] = append(byBase[base], d)\n\t}\n\tfor base, paths := range byBase {\n\t\tif len(paths) == 1 {\n\t\t\tlabels[paths[0]] = base\n\t\t} else {\n\t\t\tfor _, p := range paths {\n\t\t\t\tparent := filepath.Base(filepath.Dir(p))\n\t\t\t\tlabels[p] = parent + \"/\" + base\n\t\t\t}\n\t\t}\n\t}\n\treturn labels\n}\n\ntype projectEntry struct {\n\tDir            string\n\tLabel          string\n\tContainerCount int\n}\n","numLines":1327,"startLine":1,"totalLines":1327}}}
