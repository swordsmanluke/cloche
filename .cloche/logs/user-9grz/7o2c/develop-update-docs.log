{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SXEJuJD9FmboxXgSq4PNEK","type":"tool_result","content":"     1â†’package main\n     2â†’\n     3â†’import (\n     4â†’\t\"bufio\"\n     5â†’\t\"context\"\n     6â†’\t\"encoding/json\"\n     7â†’\t\"errors\"\n     8â†’\t\"fmt\"\n     9â†’\t\"io\"\n    10â†’\t\"net/http\"\n    11â†’\t\"os\"\n    12â†’\t\"path/filepath\"\n    13â†’\t\"strings\"\n    14â†’\t\"time\"\n    15â†’\n    16â†’\tpb \"github.com/cloche-dev/cloche/api/clochepb\"\n    17â†’\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    18â†’\t\"google.golang.org/grpc\"\n    19â†’\t\"google.golang.org/grpc/credentials/insecure\"\n    20â†’)\n    21â†’\n    22â†’func main() {\n    23â†’\tif len(os.Args) < 2 {\n    24â†’\t\tusage()\n    25â†’\t\tos.Exit(1)\n    26â†’\t}\n    27â†’\n    28â†’\t// Commands that don't need a daemon connection\n    29â†’\tswitch os.Args[1] {\n    30â†’\tcase \"init\":\n    31â†’\t\tcmdInit(os.Args[2:])\n    32â†’\t\treturn\n    33â†’\tcase \"health\":\n    34â†’\t\tcmdHealth(os.Args[2:])\n    35â†’\t\treturn\n    36â†’\t}\n    37â†’\n    38â†’\t// Commands that need a daemon connection\n    39â†’\taddr := os.Getenv(\"CLOCHE_ADDR\")\n    40â†’\tif addr == \"\" {\n    41â†’\t\taddr = \"unix:///tmp/cloche.sock\"\n    42â†’\t}\n    43â†’\n    44â†’\tconn, err := grpc.NewClient(addr, grpc.WithTransportCredentials(insecure.NewCredentials()))\n    45â†’\tif err != nil {\n    46â†’\t\tfmt.Fprintf(os.Stderr, \"failed to connect: %v\\n\", err)\n    47â†’\t\tos.Exit(1)\n    48â†’\t}\n    49â†’\tdefer conn.Close()\n    50â†’\n    51â†’\tclient := pb.NewClocheServiceClient(conn)\n    52â†’\tctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)\n    53â†’\tdefer cancel()\n    54â†’\n    55â†’\tswitch os.Args[1] {\n    56â†’\tcase \"run\":\n    57â†’\t\tcmdRun(ctx, client, os.Args[2:])\n    58â†’\tcase \"status\":\n    59â†’\t\tcmdStatus(ctx, client, os.Args[2:])\n    60â†’\tcase \"logs\":\n    61â†’\t\tcmdLogs(client, os.Args[2:])\n    62â†’\tcase \"poll\":\n    63â†’\t\tcmdPoll(client, os.Args[2:])\n    64â†’\tcase \"list\":\n    65â†’\t\tcmdList(ctx, client, os.Args[2:])\n    66â†’\tcase \"stop\":\n    67â†’\t\tcmdStop(ctx, client, os.Args[2:])\n    68â†’\tcase \"delete\":\n    69â†’\t\tcmdDelete(ctx, client, os.Args[2:])\n    70â†’\tcase \"orchestrate\":\n    71â†’\t\tcmdOrchestrate(ctx, client)\n    72â†’\tcase \"shutdown\":\n    73â†’\t\tcmdShutdown(ctx, client)\n    74â†’\tdefault:\n    75â†’\t\tusage()\n    76â†’\t\tos.Exit(1)\n    77â†’\t}\n    78â†’}\n    79â†’\n    80â†’func usage() {\n    81â†’\tfmt.Fprintf(os.Stderr, `usage: cloche <command> [args]\n    82â†’\n    83â†’Commands:\n    84â†’  init [--workflow <name>] [--base-image <image>]\n    85â†’                                             Initialize a Cloche project\n    86â†’  health                                   Show project health summary\n    87â†’  run --workflow <name> [--prompt \"...\"] [--keep-container]\n    88â†’                                             Launch a workflow run\n    89â†’  status <run-id>                            Check run status\n    90â†’  logs <run-id> [--step <name>] [--type <full|script|llm>] [--follow]\n    91â†’                                             Show logs for a run\n    92â†’  poll <run-id>                              Wait for a run to finish\n    93â†’  list [--all]                                List runs (last hour by default)\n    94â†’  stop <run-id>                              Stop a running workflow\n    95â†’  delete <container-or-run-id>               Delete a retained container\n    96â†’  orchestrate                                Dispatch ready workflow runs\n    97â†’  shutdown                                   Shut down the daemon\n    98â†’`)\n    99â†’}\n   100â†’\n   101â†’func cmdRun(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   102â†’\tvar workflow, prompt string\n   103â†’\tvar keepContainer bool\n   104â†’\n   105â†’\tfor i := 0; i < len(args); i++ {\n   106â†’\t\tswitch args[i] {\n   107â†’\t\tcase \"--workflow\":\n   108â†’\t\t\tif i+1 < len(args) {\n   109â†’\t\t\t\ti++\n   110â†’\t\t\t\tworkflow = args[i]\n   111â†’\t\t\t}\n   112â†’\t\tcase \"--prompt\", \"-p\":\n   113â†’\t\t\tif i+1 < len(args) {\n   114â†’\t\t\t\ti++\n   115â†’\t\t\t\tprompt = args[i]\n   116â†’\t\t\t}\n   117â†’\t\tcase \"--keep-container\":\n   118â†’\t\t\tkeepContainer = true\n   119â†’\t\tdefault:\n   120â†’\t\t\t// Support bare positional arg as workflow name for backwards compat\n   121â†’\t\t\tif workflow == \"\" && !strings.HasPrefix(args[i], \"-\") {\n   122â†’\t\t\t\tworkflow = args[i]\n   123â†’\t\t\t}\n   124â†’\t\t}\n   125â†’\t}\n   126â†’\n   127â†’\tif workflow == \"\" {\n   128â†’\t\tfmt.Fprintf(os.Stderr, \"usage: cloche run --workflow <name> [--prompt \\\"...\\\"]\\n\")\n   129â†’\t\tos.Exit(1)\n   130â†’\t}\n   131â†’\n   132â†’\tcwd, _ := os.Getwd()\n   133â†’\n   134â†’\t// Resolve image from workflow file (soft failure â€” fall back to daemon default)\n   135â†’\tvar image string\n   136â†’\twfPath := filepath.Join(cwd, \".cloche\", workflow+\".cloche\")\n   137â†’\tif data, err := os.ReadFile(wfPath); err == nil {\n   138â†’\t\tif wf, err := dsl.Parse(string(data)); err == nil {\n   139â†’\t\t\timage = wf.Config[\"container.image\"]\n   140â†’\t\t}\n   141â†’\t}\n   142â†’\n   143â†’\tresp, err := client.RunWorkflow(ctx, &pb.RunWorkflowRequest{\n   144â†’\t\tWorkflowName:  workflow,\n   145â†’\t\tProjectDir:    cwd,\n   146â†’\t\tImage:         image,\n   147â†’\t\tPrompt:        prompt,\n   148â†’\t\tKeepContainer: keepContainer,\n   149â†’\t})\n   150â†’\tif err != nil {\n   151â†’\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   152â†’\t\tos.Exit(1)\n   153â†’\t}\n   154â†’\tfmt.Printf(\"Started run: %s\\n\", resp.RunId)\n   155â†’}\n   156â†’\n   157â†’func cmdStatus(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   158â†’\tif len(args) < 1 {\n   159â†’\t\tfmt.Fprintf(os.Stderr, \"usage: cloche status <run-id>\\n\")\n   160â†’\t\tos.Exit(1)\n   161â†’\t}\n   162â†’\n   163â†’\tresp, err := client.GetStatus(ctx, &pb.GetStatusRequest{RunId: args[0]})\n   164â†’\tif err != nil {\n   165â†’\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   166â†’\t\tos.Exit(1)\n   167â†’\t}\n   168â†’\n   169â†’\tfmt.Printf(\"Run:       %s\\n\", resp.RunId)\n   170â†’\tfmt.Printf(\"Workflow:  %s\\n\", resp.WorkflowName)\n   171â†’\tfmt.Printf(\"State:     %s\\n\", resp.State)\n   172â†’\tif resp.ContainerId != \"\" {\n   173â†’\t\tcid := resp.ContainerId\n   174â†’\t\tif len(cid) > 12 {\n   175â†’\t\t\tcid = cid[:12]\n   176â†’\t\t}\n   177â†’\t\tfmt.Printf(\"Container: %s\\n\", cid)\n   178â†’\t}\n   179â†’\tif resp.ErrorMessage != \"\" {\n   180â†’\t\tfmt.Printf(\"Error:     %s\\n\", resp.ErrorMessage)\n   181â†’\t}\n   182â†’\tfmt.Printf(\"Active:    %s\\n\", resp.CurrentStep)\n   183â†’\tfor _, exec := range resp.StepExecutions {\n   184â†’\t\tfmt.Printf(\"  %s: %s (%s -> %s)\\n\", exec.StepName, exec.Result, exec.StartedAt, exec.CompletedAt)\n   185â†’\t}\n   186â†’}\n   187â†’\n   188â†’func cmdList(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   189â†’\tvar all bool\n   190â†’\tfor _, arg := range args {\n   191â†’\t\tif arg == \"--all\" {\n   192â†’\t\t\tall = true\n   193â†’\t\t}\n   194â†’\t}\n   195â†’\n   196â†’\tresp, err := client.ListRuns(ctx, &pb.ListRunsRequest{All: all})\n   197â†’\tif err != nil {\n   198â†’\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   199â†’\t\tos.Exit(1)\n   200â†’\t}\n   201â†’\n   202â†’\tif len(resp.Runs) == 0 {\n   203â†’\t\tfmt.Println(\"No runs found.\")\n   204â†’\t\treturn\n   205â†’\t}\n   206â†’\n   207â†’\tfor _, run := range resp.Runs {\n   208â†’\t\tline := fmt.Sprintf(\"%s  %-20s  %-10s\", run.RunId, run.WorkflowName, run.State)\n   209â†’\t\tif run.ContainerId != \"\" {\n   210â†’\t\t\tline += \"  \" + run.ContainerId\n   211â†’\t\t}\n   212â†’\t\tif run.ErrorMessage != \"\" {\n   213â†’\t\t\terrMsg := run.ErrorMessage\n   214â†’\t\t\tif len(errMsg) > 60 {\n   215â†’\t\t\t\terrMsg = errMsg[:57] + \"...\"\n   216â†’\t\t\t}\n   217â†’\t\t\tline += \"  \" + errMsg\n   218â†’\t\t}\n   219â†’\t\tfmt.Println(line)\n   220â†’\t}\n   221â†’}\n   222â†’\n   223â†’func cmdLogs(client pb.ClocheServiceClient, args []string) {\n   224â†’\tif len(args) < 1 {\n   225â†’\t\tfmt.Fprintf(os.Stderr, \"usage: cloche logs <run-id> [--step <name>] [--type <full|script|llm>] [--follow]\\n\")\n   226â†’\t\tos.Exit(1)\n   227â†’\t}\n   228â†’\n   229â†’\tvar stepFilter, typeFilter string\n   230â†’\tvar follow bool\n   231â†’\trunID := args[0]\n   232â†’\n   233â†’\tfor i := 1; i < len(args); i++ {\n   234â†’\t\tswitch args[i] {\n   235â†’\t\tcase \"--step\":\n   236â†’\t\t\tif i+1 < len(args) {\n   237â†’\t\t\t\ti++\n   238â†’\t\t\t\tstepFilter = args[i]\n   239â†’\t\t\t}\n   240â†’\t\tcase \"--type\":\n   241â†’\t\t\tif i+1 < len(args) {\n   242â†’\t\t\t\ti++\n   243â†’\t\t\t\ttypeFilter = args[i]\n   244â†’\t\t\t}\n   245â†’\t\tcase \"--follow\", \"-f\":\n   246â†’\t\t\tfollow = true\n   247â†’\t\t}\n   248â†’\t}\n   249â†’\n   250â†’\tif follow {\n   251â†’\t\tcmdLogsFollow(runID)\n   252â†’\t\treturn\n   253â†’\t}\n   254â†’\n   255â†’\t// Use background context â€” log output can be large\n   256â†’\tstream, err := client.StreamLogs(context.Background(), &pb.StreamLogsRequest{\n   257â†’\t\tRunId:    runID,\n   258â†’\t\tStepName: stepFilter,\n   259â†’\t\tLogType:  typeFilter,\n   260â†’\t})\n   261â†’\tif err != nil {\n   262â†’\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   263â†’\t\tos.Exit(1)\n   264â†’\t}\n   265â†’\n   266â†’\tfor {\n   267â†’\t\tentry, err := stream.Recv()\n   268â†’\t\tif err != nil {\n   269â†’\t\t\tif errors.Is(err, io.EOF) {\n   270â†’\t\t\t\tbreak\n   271â†’\t\t\t}\n   272â†’\t\t\tfmt.Fprintf(os.Stderr, \"error reading logs: %v\\n\", err)\n   273â†’\t\t\tos.Exit(1)\n   274â†’\t\t}\n   275â†’\n   276â†’\t\tswitch entry.Type {\n   277â†’\t\tcase \"step_started\":\n   278â†’\t\t\tfmt.Printf(\"--- %s started ---\\n\", entry.StepName)\n   279â†’\t\t\tif entry.Message != \"\" {\n   280â†’\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n   281â†’\t\t\t}\n   282â†’\t\tcase \"step_completed\":\n   283â†’\t\t\tfmt.Printf(\"--- %s: %s ---\\n\", entry.StepName, entry.Result)\n   284â†’\t\t\tif entry.Message != \"\" {\n   285â†’\t\t\t\tfmt.Printf(\"%s\\n\", entry.Message)\n   286â†’\t\t\t}\n   287â†’\t\tcase \"run_completed\":\n   288â†’\t\t\tfmt.Printf(\"\\nRun result: %s\\n\", entry.Result)\n   289â†’\t\t\tif entry.Message != \"\" {\n   290â†’\t\t\t\tfmt.Printf(\"Error:      %s\\n\", entry.Message)\n   291â†’\t\t\t}\n   292â†’\t\tcase \"full_log\":\n   293â†’\t\t\tfmt.Print(entry.Message)\n   294â†’\t\tdefault:\n   295â†’\t\t\t// Handles filtered log entries like \"script_log\", \"llm_log\", \"step_log\"\n   296â†’\t\t\tif entry.StepName != \"\" {\n   297â†’\t\t\t\tfmt.Printf(\"--- %s ---\\n\", entry.StepName)\n   298â†’\t\t\t}\n   299â†’\t\t\tif entry.Message != \"\" {\n   300â†’\t\t\t\tfmt.Print(entry.Message)\n   301â†’\t\t\t}\n   302â†’\t\t}\n   303â†’\t}\n   304â†’}\n   305â†’\n   306â†’func cmdLogsFollow(runID string) {\n   307â†’\t// Determine HTTP address from env\n   308â†’\thttpAddr := os.Getenv(\"CLOCHE_HTTP\")\n   309â†’\tif httpAddr == \"\" {\n   310â†’\t\thttpAddr = \"localhost:8080\"\n   311â†’\t}\n   312â†’\t// Strip protocol prefix if present\n   313â†’\thttpAddr = strings.TrimPrefix(httpAddr, \"http://\")\n   314â†’\n   315â†’\tsseURL := fmt.Sprintf(\"http://%s/api/runs/%s/stream\", httpAddr, runID)\n   316â†’\treq, err := http.NewRequest(\"GET\", sseURL, nil)\n   317â†’\tif err != nil {\n   318â†’\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   319â†’\t\tos.Exit(1)\n   320â†’\t}\n   321â†’\treq.Header.Set(\"Accept\", \"text/event-stream\")\n   322â†’\n   323â†’\tresp, err := http.DefaultClient.Do(req)\n   324â†’\tif err != nil {\n   325â†’\t\tfmt.Fprintf(os.Stderr, \"error connecting to SSE stream: %v\\n\", err)\n   326â†’\t\tos.Exit(1)\n   327â†’\t}\n   328â†’\tdefer resp.Body.Close()\n   329â†’\n   330â†’\tif resp.StatusCode != 200 {\n   331â†’\t\tbody, _ := io.ReadAll(resp.Body)\n   332â†’\t\tfmt.Fprintf(os.Stderr, \"error: HTTP %d: %s\\n\", resp.StatusCode, strings.TrimSpace(string(body)))\n   333â†’\t\tos.Exit(1)\n   334â†’\t}\n   335â†’\n   336â†’\tscanner := bufio.NewScanner(resp.Body)\n   337â†’\tfor scanner.Scan() {\n   338â†’\t\tline := scanner.Text()\n   339â†’\t\tif strings.HasPrefix(line, \"event: done\") {\n   340â†’\t\t\tbreak\n   341â†’\t\t}\n   342â†’\t\tif !strings.HasPrefix(line, \"data: \") {\n   343â†’\t\t\tcontinue\n   344â†’\t\t}\n   345â†’\t\tdata := strings.TrimPrefix(line, \"data: \")\n   346â†’\n   347â†’\t\tvar entry struct {\n   348â†’\t\t\tTimestamp string `json:\"timestamp\"`\n   349â†’\t\t\tType      string `json:\"type\"`\n   350â†’\t\t\tContent   string `json:\"content\"`\n   351â†’\t\t}\n   352â†’\t\tif err := json.Unmarshal([]byte(data), &entry); err != nil {\n   353â†’\t\t\tcontinue\n   354â†’\t\t}\n   355â†’\n   356â†’\t\t// Color-code by type\n   357â†’\t\tswitch entry.Type {\n   358â†’\t\tcase \"status\":\n   359â†’\t\t\tfmt.Printf(\"\\033[34m[%s] [%s] %s\\033[0m\\n\", entry.Timestamp, entry.Type, entry.Content)\n   360â†’\t\tcase \"llm\":\n   361â†’\t\t\tfmt.Printf(\"\\033[32m[%s] [%s] %s\\033[0m\\n\", entry.Timestamp, entry.Type, entry.Content)\n   362â†’\t\tdefault:\n   363â†’\t\t\tfmt.Printf(\"[%s] [%s] %s\\n\", entry.Timestamp, entry.Type, entry.Content)\n   364â†’\t\t}\n   365â†’\t}\n   366â†’}\n   367â†’\n   368â†’func cmdStop(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   369â†’\tif len(args) < 1 {\n   370â†’\t\tfmt.Fprintf(os.Stderr, \"usage: cloche stop <run-id>\\n\")\n   371â†’\t\tos.Exit(1)\n   372â†’\t}\n   373â†’\n   374â†’\t_, err := client.StopRun(ctx, &pb.StopRunRequest{RunId: args[0]})\n   375â†’\tif err != nil {\n   376â†’\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   377â†’\t\tos.Exit(1)\n   378â†’\t}\n   379â†’\tfmt.Printf(\"Stopped run: %s\\n\", args[0])\n   380â†’}\n   381â†’\n   382â†’func cmdDelete(ctx context.Context, client pb.ClocheServiceClient, args []string) {\n   383â†’\tif len(args) < 1 {\n   384â†’\t\tfmt.Fprintf(os.Stderr, \"usage: cloche delete <container-or-run-id>\\n\")\n   385â†’\t\tos.Exit(1)\n   386â†’\t}\n   387â†’\n   388â†’\t_, err := client.DeleteContainer(ctx, &pb.DeleteContainerRequest{Id: args[0]})\n   389â†’\tif err != nil {\n   390â†’\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   391â†’\t\tos.Exit(1)\n   392â†’\t}\n   393â†’\tfmt.Printf(\"Deleted container: %s\\n\", args[0])\n   394â†’}\n   395â†’\n   396â†’func cmdOrchestrate(ctx context.Context, client pb.ClocheServiceClient) {\n   397â†’\tcwd, _ := os.Getwd()\n   398â†’\tresp, err := client.Orchestrate(ctx, &pb.OrchestrateRequest{ProjectDir: cwd})\n   399â†’\tif err != nil {\n   400â†’\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   401â†’\t\tos.Exit(1)\n   402â†’\t}\n   403â†’\tif resp.Dispatched == 0 {\n   404â†’\t\tfmt.Println(\"No ready work found.\")\n   405â†’\t} else {\n   406â†’\t\tfmt.Printf(\"Dispatched %d run(s).\\n\", resp.Dispatched)\n   407â†’\t}\n   408â†’}\n   409â†’\n   410â†’func cmdShutdown(ctx context.Context, client pb.ClocheServiceClient) {\n   411â†’\t_, err := client.Shutdown(ctx, &pb.ShutdownRequest{})\n   412â†’\tif err != nil {\n   413â†’\t\tfmt.Fprintf(os.Stderr, \"error: %v\\n\", err)\n   414â†’\t\tos.Exit(1)\n   415â†’\t}\n   416â†’\tfmt.Println(\"Daemon shutting down.\")\n   417â†’}\n   418â†’"}]},"parent_tool_use_id":"toolu_01GueLSMW6cczFRCXbWjkJcQ","session_id":"b51150cf-1c39-4197-a920-3b3045b4ca95","uuid":"03b4748f-8cc8-403f-8dd6-0b0109efbb28"}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BD4Y17o944Jx6yiizBfH1b","type":"tool_result","content":"     1â†’package web\n     2â†’\n     3â†’import (\n     4â†’\t\"bufio\"\n     5â†’\t\"context\"\n     6â†’\t\"embed\"\n     7â†’\t\"encoding/json\"\n     8â†’\t\"fmt\"\n     9â†’\t\"html/template\"\n    10â†’\t\"io/fs\"\n    11â†’\t\"net/http\"\n    12â†’\t\"os\"\n    13â†’\t\"os/exec\"\n    14â†’\t\"path/filepath\"\n    15â†’\t\"regexp\"\n    16â†’\t\"sort\"\n    17â†’\t\"strconv\"\n    18â†’\t\"strings\"\n    19â†’\t\"time\"\n    20â†’\n    21â†’\t\"github.com/cloche-dev/cloche/internal/domain\"\n    22â†’\t\"github.com/cloche-dev/cloche/internal/dsl\"\n    23â†’\t\"github.com/cloche-dev/cloche/internal/logstream\"\n    24â†’\t\"github.com/cloche-dev/cloche/internal/ports\"\n    25â†’)\n    26â†’\n    27â†’// HandlerOption configures optional Handler dependencies.\n    28â†’type HandlerOption func(*Handler)\n    29â†’\n    30â†’// WithContainerLogger sets the container runtime for fetching live logs.\n    31â†’func WithContainerLogger(c ContainerLogger) HandlerOption {\n    32â†’\treturn func(h *Handler) { h.container = c }\n    33â†’}\n    34â†’\n    35â†’// WithContainerManager sets a full container manager (logs, inspect, remove).\n    36â†’func WithContainerManager(c ContainerManager) HandlerOption {\n    37â†’\treturn func(h *Handler) { h.container = c }\n    38â†’}\n    39â†’\n    40â†’// WithLogBroadcaster sets the log broadcaster for SSE streaming.\n    41â†’func WithLogBroadcaster(b *logstream.Broadcaster) HandlerOption {\n    42â†’\treturn func(h *Handler) { h.logBroadcast = b }\n    43â†’}\n    44â†’\n    45â†’// WithLogStore sets the log store for indexed log file lookups.\n    46â†’func WithLogStore(ls ports.LogStore) HandlerOption {\n    47â†’\treturn func(h *Handler) { h.logStore = ls }\n    48â†’}\n    49â†’\n    50â†’// WithOrchestrateFunc sets the function called when the orchestrator is triggered.\n    51â†’func WithOrchestrateFunc(fn func(ctx context.Context, projectDir string) (int, error)) HandlerOption {\n    52â†’\treturn func(h *Handler) { h.orchestrateFn = fn }\n    53â†’}\n    54â†’\n    55â†’// OrchestratorController provides per-project orchestrator control.\n    56â†’type OrchestratorController interface {\n    57â†’\tStatus(dir string) (enabled bool, inFlight int, concurrency int)\n    58â†’\tSetEnabled(dir string, enabled bool)\n    59â†’\tSetConcurrency(dir string, concurrency int)\n    60â†’}\n    61â†’\n    62â†’// WithOrchestrator sets the orchestrator controller for project-level control.\n    63â†’func WithOrchestrator(oc OrchestratorController) HandlerOption {\n    64â†’\treturn func(h *Handler) { h.orchestrator = oc }\n    65â†’}\n    66â†’\n    67â†’//go:embed templates/*.html static/*\n    68â†’var content embed.FS\n    69â†’\n    70â†’// Handler serves the web dashboard.\n    71â†’// ContainerLogger can retrieve logs from a container by ID.\n    72â†’type ContainerLogger interface {\n    73â†’\tLogs(ctx context.Context, containerID string) (string, error)\n    74â†’}\n    75â†’\n    76â†’// ContainerManager extends ContainerLogger with container lifecycle operations.\n    77â†’type ContainerManager interface {\n    78â†’\tContainerLogger\n    79â†’\tRemove(ctx context.Context, containerID string) error\n    80â†’\tInspect(ctx context.Context, containerID string) (*ports.ContainerStatus, error)\n    81â†’}\n    82â†’\n    83â†’type Handler struct {\n    84â†’\tstore         ports.RunStore\n    85â†’\tcaptures      ports.CaptureStore\n    86â†’\tlogStore      ports.LogStore\n    87â†’\tcontainer     ContainerLogger\n    88â†’\tlogBroadcast  *logstream.Broadcaster\n    89â†’\torchestrateFn func(ctx context.Context, projectDir string) (int, error)\n    90â†’\torchestrator  OrchestratorController\n    91â†’\tpages         map[string]*template.Template\n    92â†’\tmux           *http.ServeMux\n    93â†’}\n    94â†’\n    95â†’// NewHandler creates a web dashboard handler.\n    96â†’func NewHandler(store ports.RunStore, captures ports.CaptureStore, opts ...HandlerOption) (*Handler, error) {\n    97â†’\tfuncMap := template.FuncMap{\n    98â†’\t\t\"stateColor\":       stateColor,\n    99â†’\t\t\"healthColor\":      healthColor,\n   100â†’\t\t\"formatTime\":       formatTime,\n   101â†’\t\t\"formatDuration\":   formatDuration,\n   102â†’\t\t\"truncate\":         truncate,\n   103â†’\t\t\"shortContainerID\": shortContainerID,\n   104â†’\t}\n   105â†’\n   106â†’\tbase, err := template.New(\"\").Funcs(funcMap).ParseFS(content, \"templates/layout.html\")\n   107â†’\tif err != nil {\n   108â†’\t\treturn nil, fmt.Errorf(\"parse layout: %w\", err)\n   109â†’\t}\n   110â†’\n   111â†’\tpages := map[string]*template.Template{}\n   112â†’\tfor _, page := range []string{\"projects\", \"runs\", \"run_detail\", \"project_detail\"} {\n   113â†’\t\tclone, err := base.Clone()\n   114â†’\t\tif err != nil {\n   115â†’\t\t\treturn nil, fmt.Errorf(\"clone layout for %s: %w\", page, err)\n   116â†’\t\t}\n   117â†’\t\t_, err = clone.ParseFS(content, \"templates/\"+page+\".html\")\n   118â†’\t\tif err != nil {\n   119â†’\t\t\treturn nil, fmt.Errorf(\"parse %s: %w\", page, err)\n   120â†’\t\t}\n   121â†’\t\tpages[page] = clone\n   122â†’\t}\n   123â†’\n   124â†’\th := &Handler{\n   125â†’\t\tstore:    store,\n   126â†’\t\tcaptures: captures,\n   127â†’\t\tpages:    pages,\n   128â†’\t\tmux:      http.NewServeMux(),\n   129â†’\t}\n   130â†’\tfor _, opt := range opts {\n   131â†’\t\topt(h)\n   132â†’\t}\n   133â†’\n   134â†’\tstaticFS, err := fs.Sub(content, \"static\")\n   135â†’\tif err != nil {\n   136â†’\t\treturn nil, fmt.Errorf(\"static sub-fs: %w\", err)\n   137â†’\t}\n   138â†’\n   139â†’\th.mux.HandleFunc(\"GET /{$}\", h.handleProjectOverview)\n   140â†’\th.mux.HandleFunc(\"GET /runs\", h.handleRunsList)\n   141â†’\th.mux.HandleFunc(\"GET /runs/{id}\", h.handleRunDetail)\n   142â†’\th.mux.HandleFunc(\"GET /projects/{name}\", h.handleProjectDetail)\n   143â†’\th.mux.HandleFunc(\"GET /projects/{name}/runs\", h.handleProjectRunsList)\n   144â†’\th.mux.HandleFunc(\"GET /api/projects\", h.handleAPIProjects)\n   145â†’\th.mux.HandleFunc(\"GET /api/projects/{name}/runs\", h.handleAPIProjectRuns)\n   146â†’\th.mux.HandleFunc(\"GET /api/runs\", h.handleAPIRuns)\n   147â†’\th.mux.HandleFunc(\"GET /api/runs/{id}\", h.handleAPIRunDetail)\n   148â†’\th.mux.HandleFunc(\"GET /api/runs/{id}/steps/{step}/output\", h.handleAPIStepOutput)\n   149â†’\th.mux.HandleFunc(\"DELETE /api/runs/{id}/container\", h.handleAPIDeleteContainer)\n   150â†’\th.mux.HandleFunc(\"POST /api/projects/{name}/trigger\", h.handleAPITriggerOrchestrator)\n   151â†’\th.mux.HandleFunc(\"GET /api/projects/{name}/orchestrator\", h.handleAPIOrchestratorStatus)\n   152â†’\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/start\", h.handleAPIOrchestratorStart)\n   153â†’\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/stop\", h.handleAPIOrchestratorStop)\n   154â†’\th.mux.HandleFunc(\"POST /api/projects/{name}/orchestrator/concurrency\", h.handleAPIOrchestratorConcurrency)\n   155â†’\th.mux.HandleFunc(\"GET /api/projects/{name}/info\", h.handleAPIProjectInfo)\n   156â†’\th.mux.HandleFunc(\"GET /api/projects/{name}/info/prompt-diff\", h.handleAPIPromptDiff)\n   157â†’\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows\", h.handleAPIWorkflows)\n   158â†’\th.mux.HandleFunc(\"GET /api/projects/{name}/workflows/{workflow}/steps/{step}/content\", h.handleAPIStepContent)\n   159â†’\th.mux.HandleFunc(\"GET /api/runs/{id}/stream\", h.handleAPIStream)\n   160â†’\th.mux.Handle(\"GET /static/\", http.StripPrefix(\"/static/\", http.FileServerFS(staticFS)))\n   161â†’\n   162â†’\treturn h, nil\n   163â†’}\n   164â†’\n   165â†’func (h *Handler) ServeHTTP(w http.ResponseWriter, r *http.Request) {\n   166â†’\th.mux.ServeHTTP(w, r)\n   167â†’}\n   168â†’\n   169â†’// --- HTML handlers ---\n   170â†’\n   171â†’// projectOverviewEntry holds data for a single project card on the landing page.\n   172â†’type projectOverviewEntry struct {\n   173â†’\tDir         string\n   174â†’\tLabel       string\n   175â†’\tHealth      domain.HealthResult\n   176â†’\tRecentRuns  []recentRunDot\n   177â†’\tActiveCount int\n   178â†’}\n   179â†’\n   180â†’// recentRunDot is a minimal representation of a run for the mini history display.\n   181â†’type recentRunDot struct {\n   182â†’\tID    string\n   183â†’\tState string\n   184â†’}\n   185â†’\n   186â†’const healthWindowSize = 10\n   187â†’\n   188â†’func (h *Handler) handleProjectOverview(w http.ResponseWriter, r *http.Request) {\n   189â†’\tprojects, _ := h.store.ListProjects(r.Context())\n   190â†’\tlabels := projectLabels(projects)\n   191â†’\n   192â†’\tvar entries []projectOverviewEntry\n   193â†’\tfor _, dir := range projects {\n   194â†’\t\truns, err := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   195â†’\t\tif err != nil {\n   196â†’\t\t\tcontinue\n   197â†’\t\t}\n   198â†’\n   199â†’\t\t// Convert []*domain.Run to []domain.Run for CalculateHealth.\n   200â†’\t\trunValues := make([]domain.Run, len(runs))\n   201â†’\t\tfor i, rr := range runs {\n   202â†’\t\t\trunValues[i] = *rr\n   203â†’\t\t}\n   204â†’\n   205â†’\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n   206â†’\n   207â†’\t\t// Take the last N runs for the mini history (most recent first).\n   208â†’\t\tn := healthWindowSize\n   209â†’\t\tif n > len(runs) {\n   210â†’\t\t\tn = len(runs)\n   211â†’\t\t}\n   212â†’\t\tdots := make([]recentRunDot, n)\n   213â†’\t\tfor i := 0; i < n; i++ {\n   214â†’\t\t\tdots[i] = recentRunDot{\n   215â†’\t\t\t\tID:    runs[i].ID,\n   216â†’\t\t\t\tState: string(runs[i].State),\n   217â†’\t\t\t}\n   218â†’\t\t}\n   219â†’\n   220â†’\t\tvar activeCount int\n   221â†’\t\tfor _, rr := range runs {\n   222â†’\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n   223â†’\t\t\t\tactiveCount++\n   224â†’\t\t\t}\n   225â†’\t\t}\n   226â†’\n   227â†’\t\tentries = append(entries, projectOverviewEntry{\n   228â†’\t\t\tDir:         dir,\n   229â†’\t\t\tLabel:       labels[dir],\n   230â†’\t\t\tHealth:      health,\n   231â†’\t\t\tRecentRuns:  dots,\n   232â†’\t\t\tActiveCount: activeCount,\n   233â†’\t\t})\n   234â†’\t}\n   235â†’\n   236â†’\tsort.Slice(entries, func(i, j int) bool {\n   237â†’\t\treturn entries[i].Label < entries[j].Label\n   238â†’\t})\n   239â†’\n   240â†’\tdata := map[string]any{\n   241â†’\t\t\"Title\":    \"Projects\",\n   242â†’\t\t\"Projects\": entries,\n   243â†’\t}\n   244â†’\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   245â†’\tif err := h.pages[\"projects\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   246â†’\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   247â†’\t}\n   248â†’}\n   249â†’\n   250â†’func (h *Handler) handleRunsList(w http.ResponseWriter, r *http.Request) {\n   251â†’\t// Redirect old ?project= URLs to new /projects/<label>/runs path.\n   252â†’\tif projectFilter := r.URL.Query().Get(\"project\"); projectFilter != \"\" {\n   253â†’\t\tprojects, _ := h.store.ListProjects(r.Context())\n   254â†’\t\tlabels := projectLabels(projects)\n   255â†’\t\tif label, ok := labels[projectFilter]; ok {\n   256â†’\t\t\thttp.Redirect(w, r, \"/projects/\"+label+\"/runs\", http.StatusMovedPermanently)\n   257â†’\t\t\treturn\n   258â†’\t\t}\n   259â†’\t}\n   260â†’\n   261â†’\truns, err := h.store.ListRuns(r.Context(), time.Time{})\n   262â†’\tif err != nil {\n   263â†’\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n   264â†’\t\treturn\n   265â†’\t}\n   266â†’\n   267â†’\tprojects, _ := h.store.ListProjects(r.Context())\n   268â†’\tlabels := projectLabels(projects)\n   269â†’\n   270â†’\t// Count retained containers per project\n   271â†’\tcontainerCounts := map[string]int{}\n   272â†’\tfor _, run := range runs {\n   273â†’\t\tif run.ContainerKept {\n   274â†’\t\t\tcontainerCounts[run.ProjectDir]++\n   275â†’\t\t}\n   276â†’\t}\n   277â†’\n   278â†’\tvar projectList []projectEntry\n   279â†’\tfor _, dir := range projects {\n   280â†’\t\tprojectList = append(projectList, projectEntry{Dir: dir, Label: labels[dir], ContainerCount: containerCounts[dir]})\n   281â†’\t}\n   282â†’\tsort.Slice(projectList, func(i, j int) bool {\n   283â†’\t\treturn projectList[i].Label < projectList[j].Label\n   284â†’\t})\n   285â†’\n   286â†’\tdata := map[string]any{\n   287â†’\t\t\"Title\":         \"Runs\",\n   288â†’\t\t\"Runs\":          runs,\n   289â†’\t\t\"Projects\":      projectList,\n   290â†’\t\t\"ProjectFilter\": \"\",\n   291â†’\t\t\"ProjectLabel\":  \"\",\n   292â†’\t\t\"ProjectLabels\": labels,\n   293â†’\t}\n   294â†’\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   295â†’\tif err := h.pages[\"runs\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   296â†’\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   297â†’\t}\n   298â†’}\n   299â†’\n   300â†’func (h *Handler) handleProjectRunsList(w http.ResponseWriter, r *http.Request) {\n   301â†’\tdir, label, ok := h.resolveProjectDir(w, r)\n   302â†’\tif !ok {\n   303â†’\t\treturn\n   304â†’\t}\n   305â†’\n   306â†’\truns, err := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   307â†’\tif err != nil {\n   308â†’\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n   309â†’\t\treturn\n   310â†’\t}\n   311â†’\n   312â†’\tprojects, _ := h.store.ListProjects(r.Context())\n   313â†’\tlabels := projectLabels(projects)\n   314â†’\n   315â†’\t// Count retained containers per project\n   316â†’\tcontainerCounts := map[string]int{}\n   317â†’\tallRuns, _ := h.store.ListRuns(r.Context(), time.Time{})\n   318â†’\tfor _, run := range allRuns {\n   319â†’\t\tif run.ContainerKept {\n   320â†’\t\t\tcontainerCounts[run.ProjectDir]++\n   321â†’\t\t}\n   322â†’\t}\n   323â†’\n   324â†’\tvar projectList []projectEntry\n   325â†’\tfor _, d := range projects {\n   326â†’\t\tprojectList = append(projectList, projectEntry{Dir: d, Label: labels[d], ContainerCount: containerCounts[d]})\n   327â†’\t}\n   328â†’\tsort.Slice(projectList, func(i, j int) bool {\n   329â†’\t\treturn projectList[i].Label < projectList[j].Label\n   330â†’\t})\n   331â†’\n   332â†’\tdata := map[string]any{\n   333â†’\t\t\"Title\":         \"Runs\",\n   334â†’\t\t\"Runs\":          runs,\n   335â†’\t\t\"Projects\":      projectList,\n   336â†’\t\t\"ProjectFilter\": dir,\n   337â†’\t\t\"ProjectLabel\":  label,\n   338â†’\t\t\"ProjectLabels\": labels,\n   339â†’\t}\n   340â†’\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   341â†’\tif err := h.pages[\"runs\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   342â†’\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   343â†’\t}\n   344â†’}\n   345â†’\n   346â†’// stepEntry is a merged view of a step execution for the template.\n   347â†’type stepEntry struct {\n   348â†’\tIndex     int\n   349â†’\tStepName  string\n   350â†’\tResult    string\n   351â†’\tStartedAt time.Time\n   352â†’\tDuration  string\n   353â†’}\n   354â†’\n   355â†’// mergeCaptures collapses started/completed capture pairs into single entries.\n   356â†’func mergeCaptures(caps []*domain.StepExecution) []stepEntry {\n   357â†’\tvar entries []stepEntry\n   358â†’\t// Track pending started rows by step name (LIFO for retries)\n   359â†’\tpending := map[string]*domain.StepExecution{}\n   360â†’\n   361â†’\tfor _, c := range caps {\n   362â†’\t\tif c.Result == \"\" {\n   363â†’\t\t\t// step_started row\n   364â†’\t\t\tpending[c.StepName] = c\n   365â†’\t\t\tcontinue\n   366â†’\t\t}\n   367â†’\t\t// step_completed row â€” merge with pending started if available\n   368â†’\t\tstartedAt := c.StartedAt\n   369â†’\t\tif started := pending[c.StepName]; started != nil {\n   370â†’\t\t\tstartedAt = started.StartedAt\n   371â†’\t\t\tdelete(pending, c.StepName)\n   372â†’\t\t}\n   373â†’\t\tentries = append(entries, stepEntry{\n   374â†’\t\t\tIndex:     len(entries),\n   375â†’\t\t\tStepName:  c.StepName,\n   376â†’\t\t\tResult:    c.Result,\n   377â†’\t\t\tStartedAt: startedAt,\n   378â†’\t\t\tDuration:  formatDuration(startedAt, c.CompletedAt),\n   379â†’\t\t})\n   380â†’\t}\n   381â†’\n   382â†’\t// Append any started-but-not-completed steps (still running)\n   383â†’\tfor _, c := range caps {\n   384â†’\t\tif c.Result == \"\" {\n   385â†’\t\t\tif _, used := pending[c.StepName]; !used {\n   386â†’\t\t\t\tcontinue\n   387â†’\t\t\t}\n   388â†’\t\t\tentries = append(entries, stepEntry{\n   389â†’\t\t\t\tIndex:     len(entries),\n   390â†’\t\t\t\tStepName:  c.StepName,\n   391â†’\t\t\t\tStartedAt: c.StartedAt,\n   392â†’\t\t\t})\n   393â†’\t\t\tdelete(pending, c.StepName)\n   394â†’\t\t}\n   395â†’\t}\n   396â†’\n   397â†’\treturn entries\n   398â†’}\n   399â†’\n   400â†’// containerState inspects the container for a run and returns one of:\n   401â†’//   - \"running\"   â€“ container exists and is running\n   402â†’//   - \"stopped\"   â€“ container exists, not running, not kept\n   403â†’//   - \"available\" â€“ container exists, not running, kept (can be deleted)\n   404â†’//   - \"removed\"   â€“ no container ID, no manager, or inspect failed\n   405â†’func (h *Handler) containerState(ctx context.Context, run *domain.Run) string {\n   406â†’\tif run.ContainerID == \"\" {\n   407â†’\t\treturn \"removed\"\n   408â†’\t}\n   409â†’\tmgr, ok := h.container.(ContainerManager)\n   410â†’\tif !ok {\n   411â†’\t\treturn \"removed\"\n   412â†’\t}\n   413â†’\tstatus, err := mgr.Inspect(ctx, run.ContainerID)\n   414â†’\tif err != nil {\n   415â†’\t\treturn \"removed\"\n   416â†’\t}\n   417â†’\tif status.Running {\n   418â†’\t\treturn \"running\"\n   419â†’\t}\n   420â†’\tif run.ContainerKept {\n   421â†’\t\treturn \"available\"\n   422â†’\t}\n   423â†’\treturn \"stopped\"\n   424â†’}\n   425â†’\n   426â†’func (h *Handler) handleRunDetail(w http.ResponseWriter, r *http.Request) {\n   427â†’\tid := r.PathValue(\"id\")\n   428â†’\n   429â†’\trun, err := h.store.GetRun(r.Context(), id)\n   430â†’\tif err != nil {\n   431â†’\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   432â†’\t\treturn\n   433â†’\t}\n   434â†’\n   435â†’\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n   436â†’\tif err != nil {\n   437â†’\t\tcaps = nil // non-fatal\n   438â†’\t}\n   439â†’\n   440â†’\tsteps := mergeCaptures(caps)\n   441â†’\n   442â†’\tdata := map[string]any{\n   443â†’\t\t\"Title\":          \"Run \" + run.ID,\n   444â†’\t\t\"Run\":            run,\n   445â†’\t\t\"Steps\":          steps,\n   446â†’\t\t\"Page\":           \"detail\",\n   447â†’\t\t\"ContainerState\": h.containerState(r.Context(), run),\n   448â†’\t}\n   449â†’\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   450â†’\tif err := h.pages[\"run_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   451â†’\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   452â†’\t}\n   453â†’}\n   454â†’\n   455â†’// --- JSON API handlers ---\n   456â†’\n   457â†’type apiRun struct {\n   458â†’\tID           string `json:\"id\"`\n   459â†’\tWorkflowName string `json:\"workflow_name\"`\n   460â†’\tProjectDir   string `json:\"project_dir\"`\n   461â†’\tProjectLabel string `json:\"project_label\"`\n   462â†’\tState        string `json:\"state\"`\n   463â†’\tStartedAt    string `json:\"started_at\"`\n   464â†’\tCompletedAt  string `json:\"completed_at\"`\n   465â†’\tContainerID  string `json:\"container_id\"`\n   466â†’\tErrorMessage string `json:\"error_message\"`\n   467â†’}\n   468â†’\n   469â†’type apiStep struct {\n   470â†’\tStepName    string `json:\"step_name\"`\n   471â†’\tResult      string `json:\"result\"`\n   472â†’\tStartedAt   string `json:\"started_at\"`\n   473â†’\tCompletedAt string `json:\"completed_at\"`\n   474â†’\tDuration    string `json:\"duration\"`\n   475â†’}\n   476â†’\n   477â†’type apiRunDetail struct {\n   478â†’\tapiRun\n   479â†’\tContainerState string    `json:\"container_state\"`\n   480â†’\tSteps          []apiStep `json:\"steps\"`\n   481â†’}\n   482â†’\n   483â†’func toAPIRun(r *domain.Run, labels map[string]string) apiRun {\n   484â†’\treturn apiRun{\n   485â†’\t\tID:           r.ID,\n   486â†’\t\tWorkflowName: r.WorkflowName,\n   487â†’\t\tProjectDir:   r.ProjectDir,\n   488â†’\t\tProjectLabel: labels[r.ProjectDir],\n   489â†’\t\tState:        string(r.State),\n   490â†’\t\tStartedAt:    formatTime(r.StartedAt),\n   491â†’\t\tCompletedAt:  formatTime(r.CompletedAt),\n   492â†’\t\tContainerID:  r.ContainerID,\n   493â†’\t\tErrorMessage: r.ErrorMessage,\n   494â†’\t}\n   495â†’}\n   496â†’\n   497â†’func (h *Handler) handleAPIRuns(w http.ResponseWriter, r *http.Request) {\n   498â†’\tprojectFilter := r.URL.Query().Get(\"project\")\n   499â†’\n   500â†’\tvar runs []*domain.Run\n   501â†’\tvar err error\n   502â†’\tif projectFilter != \"\" {\n   503â†’\t\truns, err = h.store.ListRunsByProject(r.Context(), projectFilter, time.Time{})\n   504â†’\t} else {\n   505â†’\t\truns, err = h.store.ListRuns(r.Context(), time.Time{})\n   506â†’\t}\n   507â†’\tif err != nil {\n   508â†’\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n   509â†’\t\treturn\n   510â†’\t}\n   511â†’\n   512â†’\tprojects, _ := h.store.ListProjects(r.Context())\n   513â†’\tlabels := projectLabels(projects)\n   514â†’\n   515â†’\tresult := make([]apiRun, len(runs))\n   516â†’\tfor i, run := range runs {\n   517â†’\t\tresult[i] = toAPIRun(run, labels)\n   518â†’\t}\n   519â†’\n   520â†’\tw.Header().Set(\"Content-Type\", \"application/json\")\n   521â†’\tjson.NewEncoder(w).Encode(result)\n   522â†’}\n   523â†’\n   524â†’func (h *Handler) handleAPIProjectRuns(w http.ResponseWriter, r *http.Request) {\n   525â†’\tdir, _, ok := h.resolveProjectDir(w, r)\n   526â†’\tif !ok {\n   527â†’\t\treturn\n   528â†’\t}\n   529â†’\n   530â†’\truns, err := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   531â†’\tif err != nil {\n   532â†’\t\thttp.Error(w, \"failed to list runs\", http.StatusInternalServerError)\n   533â†’\t\treturn\n   534â†’\t}\n   535â†’\n   536â†’\tprojects, _ := h.store.ListProjects(r.Context())\n   537â†’\tlabels := projectLabels(projects)\n   538â†’\n   539â†’\tresult := make([]apiRun, len(runs))\n   540â†’\tfor i, run := range runs {\n   541â†’\t\tresult[i] = toAPIRun(run, labels)\n   542â†’\t}\n   543â†’\n   544â†’\tw.Header().Set(\"Content-Type\", \"application/json\")\n   545â†’\tjson.NewEncoder(w).Encode(result)\n   546â†’}\n   547â†’\n   548â†’func (h *Handler) handleAPIProjects(w http.ResponseWriter, r *http.Request) {\n   549â†’\tprojects, err := h.store.ListProjects(r.Context())\n   550â†’\tif err != nil {\n   551â†’\t\thttp.Error(w, \"failed to list projects\", http.StatusInternalServerError)\n   552â†’\t\treturn\n   553â†’\t}\n   554â†’\tlabels := projectLabels(projects)\n   555â†’\n   556â†’\ttype apiHealth struct {\n   557â†’\t\tStatus string `json:\"status\"`\n   558â†’\t\tPassed int    `json:\"passed\"`\n   559â†’\t\tFailed int    `json:\"failed\"`\n   560â†’\t\tTotal  int    `json:\"total\"`\n   561â†’\t}\n   562â†’\ttype apiProject struct {\n   563â†’\t\tDir         string    `json:\"dir\"`\n   564â†’\t\tLabel       string    `json:\"label\"`\n   565â†’\t\tHealth      apiHealth `json:\"health\"`\n   566â†’\t\tActiveCount int       `json:\"active_count\"`\n   567â†’\t}\n   568â†’\tresult := make([]apiProject, len(projects))\n   569â†’\tfor i, dir := range projects {\n   570â†’\t\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   571â†’\t\trunValues := make([]domain.Run, len(runs))\n   572â†’\t\tfor j, rr := range runs {\n   573â†’\t\t\trunValues[j] = *rr\n   574â†’\t\t}\n   575â†’\t\thealth := domain.CalculateHealth(runValues, healthWindowSize)\n   576â†’\t\tvar activeCount int\n   577â†’\t\tfor _, rr := range runs {\n   578â†’\t\t\tif rr.State == domain.RunStatePending || rr.State == domain.RunStateRunning {\n   579â†’\t\t\t\tactiveCount++\n   580â†’\t\t\t}\n   581â†’\t\t}\n   582â†’\t\tresult[i] = apiProject{\n   583â†’\t\t\tDir:   dir,\n   584â†’\t\t\tLabel: labels[dir],\n   585â†’\t\t\tHealth: apiHealth{\n   586â†’\t\t\t\tStatus: string(health.Status),\n   587â†’\t\t\t\tPassed: health.Passed,\n   588â†’\t\t\t\tFailed: health.Failed,\n   589â†’\t\t\t\tTotal:  health.Total,\n   590â†’\t\t\t},\n   591â†’\t\t\tActiveCount: activeCount,\n   592â†’\t\t}\n   593â†’\t}\n   594â†’\n   595â†’\tw.Header().Set(\"Content-Type\", \"application/json\")\n   596â†’\tjson.NewEncoder(w).Encode(result)\n   597â†’}\n   598â†’\n   599â†’func (h *Handler) handleAPIRunDetail(w http.ResponseWriter, r *http.Request) {\n   600â†’\tid := r.PathValue(\"id\")\n   601â†’\n   602â†’\trun, err := h.store.GetRun(r.Context(), id)\n   603â†’\tif err != nil {\n   604â†’\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   605â†’\t\treturn\n   606â†’\t}\n   607â†’\n   608â†’\tcaps, err := h.captures.GetCaptures(r.Context(), id)\n   609â†’\tif err != nil {\n   610â†’\t\tcaps = nil\n   611â†’\t}\n   612â†’\n   613â†’\tprojects, _ := h.store.ListProjects(r.Context())\n   614â†’\tlabels := projectLabels(projects)\n   615â†’\n   616â†’\tmerged := mergeCaptures(caps)\n   617â†’\tsteps := make([]apiStep, len(merged))\n   618â†’\tfor i, e := range merged {\n   619â†’\t\tsteps[i] = apiStep{\n   620â†’\t\t\tStepName:  e.StepName,\n   621â†’\t\t\tResult:    e.Result,\n   622â†’\t\t\tStartedAt: formatTime(e.StartedAt),\n   623â†’\t\t\tDuration:  e.Duration,\n   624â†’\t\t}\n   625â†’\t}\n   626â†’\n   627â†’\tdetail := apiRunDetail{\n   628â†’\t\tapiRun:         toAPIRun(run, labels),\n   629â†’\t\tContainerState: h.containerState(r.Context(), run),\n   630â†’\t\tSteps:          steps,\n   631â†’\t}\n   632â†’\n   633â†’\tw.Header().Set(\"Content-Type\", \"application/json\")\n   634â†’\tjson.NewEncoder(w).Encode(detail)\n   635â†’}\n   636â†’\n   637â†’func (h *Handler) handleAPIStepOutput(w http.ResponseWriter, r *http.Request) {\n   638â†’\tid := r.PathValue(\"id\")\n   639â†’\tstep := r.PathValue(\"step\")\n   640â†’\tlogType := r.URL.Query().Get(\"type\") // optional: \"script\", \"llm\"\n   641â†’\n   642â†’\trun, err := h.store.GetRun(r.Context(), id)\n   643â†’\tif err != nil {\n   644â†’\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   645â†’\t\treturn\n   646â†’\t}\n   647â†’\n   648â†’\t// Try log index first for fast lookup\n   649â†’\tif h.logStore != nil {\n   650â†’\t\tlogFiles, err := h.logStore.GetLogFilesByStep(r.Context(), id, step)\n   651â†’\t\tif err == nil && len(logFiles) > 0 {\n   652â†’\t\t\t// If type filter specified, narrow results\n   653â†’\t\t\tfor _, lf := range logFiles {\n   654â†’\t\t\t\tif logType != \"\" && lf.FileType != logType {\n   655â†’\t\t\t\t\tcontinue\n   656â†’\t\t\t\t}\n   657â†’\t\t\t\tdata, readErr := os.ReadFile(lf.FilePath)\n   658â†’\t\t\t\tif readErr == nil && len(data) > 0 {\n   659â†’\t\t\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   660â†’\t\t\t\t\tw.Write(data)\n   661â†’\t\t\t\t\treturn\n   662â†’\t\t\t\t}\n   663â†’\t\t\t}\n   664â†’\t\t}\n   665â†’\t}\n   666â†’\n   667â†’\toutputDir := filepath.Join(run.ProjectDir, \".cloche\", id, \"output\")\n   668â†’\n   669â†’\t// Fall back to file path conventions\n   670â†’\t// If type is \"llm\", try llm-<step>.log\n   671â†’\tif logType == \"llm\" {\n   672â†’\t\tllmPath := filepath.Join(outputDir, \"llm-\"+step+\".log\")\n   673â†’\t\tdata, err := os.ReadFile(llmPath)\n   674â†’\t\tif err == nil && len(data) > 0 {\n   675â†’\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   676â†’\t\t\tw.Write(data)\n   677â†’\t\t\treturn\n   678â†’\t\t}\n   679â†’\t}\n   680â†’\n   681â†’\t// Try per-step output first, fall back to container.log, then live docker logs\n   682â†’\toutputPath := filepath.Join(outputDir, step+\".log\")\n   683â†’\tdata, err := os.ReadFile(outputPath)\n   684â†’\tif err == nil && len(data) > 0 {\n   685â†’\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   686â†’\t\tw.Write(data)\n   687â†’\t\treturn\n   688â†’\t}\n   689â†’\n   690â†’\tcontainerLog := filepath.Join(outputDir, \"container.log\")\n   691â†’\tdata, err = os.ReadFile(containerLog)\n   692â†’\tif err == nil && len(data) > 0 {\n   693â†’\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   694â†’\t\tw.Write(data)\n   695â†’\t\treturn\n   696â†’\t}\n   697â†’\n   698â†’\t// Last resort: try live docker logs from still-existing container\n   699â†’\tif h.container != nil && run.ContainerID != \"\" {\n   700â†’\t\tif logs, logErr := h.container.Logs(r.Context(), run.ContainerID); logErr == nil && logs != \"\" {\n   701â†’\t\t\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n   702â†’\t\t\tw.Write([]byte(logs))\n   703â†’\t\t\treturn\n   704â†’\t\t}\n   705â†’\t}\n   706â†’\n   707â†’\thttp.Error(w, \"step output not found\", http.StatusNotFound)\n   708â†’}\n   709â†’\n   710â†’func (h *Handler) handleAPIDeleteContainer(w http.ResponseWriter, r *http.Request) {\n   711â†’\tid := r.PathValue(\"id\")\n   712â†’\n   713â†’\trun, err := h.store.GetRun(r.Context(), id)\n   714â†’\tif err != nil {\n   715â†’\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   716â†’\t\tw.WriteHeader(http.StatusNotFound)\n   717â†’\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"run not found\"})\n   718â†’\t\treturn\n   719â†’\t}\n   720â†’\n   721â†’\tmgr, ok := h.container.(ContainerManager)\n   722â†’\tif !ok || run.ContainerID == \"\" {\n   723â†’\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   724â†’\t\tw.WriteHeader(http.StatusBadRequest)\n   725â†’\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"container management not available\"})\n   726â†’\t\treturn\n   727â†’\t}\n   728â†’\n   729â†’\tif err := mgr.Remove(r.Context(), run.ContainerID); err != nil {\n   730â†’\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   731â†’\t\tw.WriteHeader(http.StatusInternalServerError)\n   732â†’\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to remove container: %v\", err)})\n   733â†’\t\treturn\n   734â†’\t}\n   735â†’\n   736â†’\trun.ContainerKept = false\n   737â†’\tif err := h.store.UpdateRun(r.Context(), run); err != nil {\n   738â†’\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   739â†’\t\tw.WriteHeader(http.StatusInternalServerError)\n   740â†’\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": fmt.Sprintf(\"failed to update run: %v\", err)})\n   741â†’\t\treturn\n   742â†’\t}\n   743â†’\n   744â†’\tw.Header().Set(\"Content-Type\", \"application/json\")\n   745â†’\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n   746â†’}\n   747â†’\n   748â†’func (h *Handler) handleAPITriggerOrchestrator(w http.ResponseWriter, r *http.Request) {\n   749â†’\tlabel := r.PathValue(\"name\")\n   750â†’\n   751â†’\t// Resolve label back to project directory via the store.\n   752â†’\tprojects, _ := h.store.ListProjects(r.Context())\n   753â†’\tlabels := projectLabels(projects)\n   754â†’\tvar projectDir string\n   755â†’\tfor dir, l := range labels {\n   756â†’\t\tif l == label {\n   757â†’\t\t\tprojectDir = dir\n   758â†’\t\t\tbreak\n   759â†’\t\t}\n   760â†’\t}\n   761â†’\tif projectDir == \"\" {\n   762â†’\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   763â†’\t\tw.WriteHeader(http.StatusNotFound)\n   764â†’\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"project not found\"})\n   765â†’\t\treturn\n   766â†’\t}\n   767â†’\n   768â†’\tif h.orchestrateFn == nil {\n   769â†’\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   770â†’\t\tw.WriteHeader(http.StatusNotImplemented)\n   771â†’\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n   772â†’\t\treturn\n   773â†’\t}\n   774â†’\n   775â†’\tdispatched, err := h.orchestrateFn(r.Context(), projectDir)\n   776â†’\tif err != nil {\n   777â†’\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   778â†’\t\tw.WriteHeader(http.StatusInternalServerError)\n   779â†’\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": err.Error()})\n   780â†’\t\treturn\n   781â†’\t}\n   782â†’\n   783â†’\tw.Header().Set(\"Content-Type\", \"application/json\")\n   784â†’\tjson.NewEncoder(w).Encode(map[string]any{\"status\": \"ok\", \"project\": label, \"dispatched\": dispatched})\n   785â†’}\n   786â†’\n   787â†’// handleAPIStream serves an SSE stream of log lines for a run.\n   788â†’// For active runs, it subscribes to the live broadcaster.\n   789â†’// For completed runs, it serves the archived full.log then closes.\n   790â†’func (h *Handler) handleAPIStream(w http.ResponseWriter, r *http.Request) {\n   791â†’\tid := r.PathValue(\"id\")\n   792â†’\n   793â†’\trun, err := h.store.GetRun(r.Context(), id)\n   794â†’\tif err != nil {\n   795â†’\t\thttp.Error(w, \"run not found\", http.StatusNotFound)\n   796â†’\t\treturn\n   797â†’\t}\n   798â†’\n   799â†’\tflusher, ok := w.(http.Flusher)\n   800â†’\tif !ok {\n   801â†’\t\thttp.Error(w, \"streaming not supported\", http.StatusInternalServerError)\n   802â†’\t\treturn\n   803â†’\t}\n   804â†’\n   805â†’\tw.Header().Set(\"Content-Type\", \"text/event-stream\")\n   806â†’\tw.Header().Set(\"Cache-Control\", \"no-cache\")\n   807â†’\tw.Header().Set(\"Connection\", \"keep-alive\")\n   808â†’\tw.Header().Set(\"X-Accel-Buffering\", \"no\")\n   809â†’\n   810â†’\tisComplete := run.State == domain.RunStateSucceeded ||\n   811â†’\t\trun.State == domain.RunStateFailed ||\n   812â†’\t\trun.State == domain.RunStateCancelled\n   813â†’\n   814â†’\tif isComplete {\n   815â†’\t\t// Serve archived full.log\n   816â†’\t\th.streamFullLog(w, flusher, run)\n   817â†’\t\t// Send done event\n   818â†’\t\tfmt.Fprintf(w, \"event: done\\ndata: %s\\n\\n\", string(run.State))\n   819â†’\t\tflusher.Flush()\n   820â†’\t\treturn\n   821â†’\t}\n   822â†’\n   823â†’\t// Active run: subscribe to live broadcaster\n   824â†’\tif h.logBroadcast == nil {\n   825â†’\t\thttp.Error(w, \"log streaming not available\", http.StatusServiceUnavailable)\n   826â†’\t\treturn\n   827â†’\t}\n   828â†’\n   829â†’\tsub := h.logBroadcast.Subscribe(id)\n   830â†’\tdefer h.logBroadcast.Unsubscribe(id, sub)\n   831â†’\n   832â†’\tctx := r.Context()\n   833â†’\tfor {\n   834â†’\t\tselect {\n   835â†’\t\tcase <-ctx.Done():\n   836â†’\t\t\treturn\n   837â†’\t\tcase line, ok := <-sub.C:\n   838â†’\t\t\tif !ok {\n   839â†’\t\t\t\t// Stream finished (run completed)\n   840â†’\t\t\t\tfmt.Fprintf(w, \"event: done\\ndata: completed\\n\\n\")\n   841â†’\t\t\t\tflusher.Flush()\n   842â†’\t\t\t\treturn\n   843â†’\t\t\t}\n   844â†’\t\t\tdata, _ := json.Marshal(line)\n   845â†’\t\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n   846â†’\t\t\tflusher.Flush()\n   847â†’\t\t}\n   848â†’\t}\n   849â†’}\n   850â†’\n   851â†’// logLineRegex parses \"[timestamp] [type] content\" format from full.log.\n   852â†’var logLineRegex = regexp.MustCompile(`^\\[([^\\]]+)\\] \\[([^\\]]+)\\] (.*)$`)\n   853â†’\n   854â†’// streamFullLog reads the archived full.log file and sends its entries as SSE events.\n   855â†’func (h *Handler) streamFullLog(w http.ResponseWriter, flusher http.Flusher, run *domain.Run) {\n   856â†’\tlogPath := filepath.Join(run.ProjectDir, \".cloche\", run.ID, \"output\", \"full.log\")\n   857â†’\tf, err := os.Open(logPath)\n   858â†’\tif err != nil {\n   859â†’\t\treturn\n   860â†’\t}\n   861â†’\tdefer f.Close()\n   862â†’\n   863â†’\tscanner := bufio.NewScanner(f)\n   864â†’\tfor scanner.Scan() {\n   865â†’\t\ttext := scanner.Text()\n   866â†’\t\tline := parseFullLogLine(text)\n   867â†’\t\tdata, _ := json.Marshal(line)\n   868â†’\t\tfmt.Fprintf(w, \"data: %s\\n\\n\", data)\n   869â†’\t\tflusher.Flush()\n   870â†’\t}\n   871â†’}\n   872â†’\n   873â†’// parseFullLogLine parses a \"[timestamp] [type] content\" line into a LogLine.\n   874â†’func parseFullLogLine(text string) logstream.LogLine {\n   875â†’\tm := logLineRegex.FindStringSubmatch(text)\n   876â†’\tif m == nil {\n   877â†’\t\treturn logstream.LogLine{\n   878â†’\t\t\tTimestamp: time.Now().UTC().Format(time.RFC3339),\n   879â†’\t\t\tType:      \"script\",\n   880â†’\t\t\tContent:   text,\n   881â†’\t\t}\n   882â†’\t}\n   883â†’\treturn logstream.LogLine{\n   884â†’\t\tTimestamp: m[1],\n   885â†’\t\tType:      m[2],\n   886â†’\t\tContent:   m[3],\n   887â†’\t}\n   888â†’}\n   889â†’\n   890â†’// --- Project detail handlers ---\n   891â†’\n   892â†’// resolveProjectDir resolves a project label from the URL to its directory path.\n   893â†’// Returns (dir, label, ok). Writes a JSON error response if not found.\n   894â†’func (h *Handler) resolveProjectDir(w http.ResponseWriter, r *http.Request) (string, string, bool) {\n   895â†’\tlabel := r.PathValue(\"name\")\n   896â†’\tprojects, _ := h.store.ListProjects(r.Context())\n   897â†’\tlabels := projectLabels(projects)\n   898â†’\tfor dir, l := range labels {\n   899â†’\t\tif l == label {\n   900â†’\t\t\treturn dir, label, true\n   901â†’\t\t}\n   902â†’\t}\n   903â†’\tw.Header().Set(\"Content-Type\", \"application/json\")\n   904â†’\tw.WriteHeader(http.StatusNotFound)\n   905â†’\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"project not found\"})\n   906â†’\treturn \"\", \"\", false\n   907â†’}\n   908â†’\n   909â†’func (h *Handler) handleProjectDetail(w http.ResponseWriter, r *http.Request) {\n   910â†’\tdir, label, ok := h.resolveProjectDir(w, r)\n   911â†’\tif !ok {\n   912â†’\t\treturn\n   913â†’\t}\n   914â†’\n   915â†’\truns, _ := h.store.ListRunsByProject(r.Context(), dir, time.Time{})\n   916â†’\tn := 10\n   917â†’\tif n > len(runs) {\n   918â†’\t\tn = len(runs)\n   919â†’\t}\n   920â†’\tdots := make([]recentRunDot, n)\n   921â†’\tfor i := 0; i < n; i++ {\n   922â†’\t\tdots[i] = recentRunDot{ID: runs[i].ID, State: string(runs[i].State)}\n   923â†’\t}\n   924â†’\n   925â†’\tdata := map[string]any{\n   926â†’\t\t\"Title\":      label,\n   927â†’\t\t\"Label\":      label,\n   928â†’\t\t\"Dir\":        dir,\n   929â†’\t\t\"RecentRuns\": dots,\n   930â†’\t}\n   931â†’\tw.Header().Set(\"Content-Type\", \"text/html; charset=utf-8\")\n   932â†’\tif err := h.pages[\"project_detail\"].ExecuteTemplate(w, \"layout\", data); err != nil {\n   933â†’\t\thttp.Error(w, err.Error(), http.StatusInternalServerError)\n   934â†’\t}\n   935â†’}\n   936â†’\n   937â†’func (h *Handler) handleAPIOrchestratorStatus(w http.ResponseWriter, r *http.Request) {\n   938â†’\tdir, _, ok := h.resolveProjectDir(w, r)\n   939â†’\tif !ok {\n   940â†’\t\treturn\n   941â†’\t}\n   942â†’\tif h.orchestrator == nil {\n   943â†’\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   944â†’\t\tjson.NewEncoder(w).Encode(map[string]any{\"enabled\": false, \"in_flight\": 0, \"concurrency\": 0})\n   945â†’\t\treturn\n   946â†’\t}\n   947â†’\tenabled, inFlight, concurrency := h.orchestrator.Status(dir)\n   948â†’\tw.Header().Set(\"Content-Type\", \"application/json\")\n   949â†’\tjson.NewEncoder(w).Encode(map[string]any{\n   950â†’\t\t\"enabled\":     enabled,\n   951â†’\t\t\"in_flight\":   inFlight,\n   952â†’\t\t\"concurrency\": concurrency,\n   953â†’\t})\n   954â†’}\n   955â†’\n   956â†’func (h *Handler) handleAPIOrchestratorStart(w http.ResponseWriter, r *http.Request) {\n   957â†’\tdir, _, ok := h.resolveProjectDir(w, r)\n   958â†’\tif !ok {\n   959â†’\t\treturn\n   960â†’\t}\n   961â†’\tif h.orchestrator == nil {\n   962â†’\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   963â†’\t\tw.WriteHeader(http.StatusNotImplemented)\n   964â†’\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n   965â†’\t\treturn\n   966â†’\t}\n   967â†’\th.orchestrator.SetEnabled(dir, true)\n   968â†’\tw.Header().Set(\"Content-Type\", \"application/json\")\n   969â†’\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n   970â†’}\n   971â†’\n   972â†’func (h *Handler) handleAPIOrchestratorStop(w http.ResponseWriter, r *http.Request) {\n   973â†’\tdir, _, ok := h.resolveProjectDir(w, r)\n   974â†’\tif !ok {\n   975â†’\t\treturn\n   976â†’\t}\n   977â†’\tif h.orchestrator == nil {\n   978â†’\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   979â†’\t\tw.WriteHeader(http.StatusNotImplemented)\n   980â†’\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n   981â†’\t\treturn\n   982â†’\t}\n   983â†’\th.orchestrator.SetEnabled(dir, false)\n   984â†’\tw.Header().Set(\"Content-Type\", \"application/json\")\n   985â†’\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n   986â†’}\n   987â†’\n   988â†’func (h *Handler) handleAPIOrchestratorConcurrency(w http.ResponseWriter, r *http.Request) {\n   989â†’\tdir, _, ok := h.resolveProjectDir(w, r)\n   990â†’\tif !ok {\n   991â†’\t\treturn\n   992â†’\t}\n   993â†’\tif h.orchestrator == nil {\n   994â†’\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n   995â†’\t\tw.WriteHeader(http.StatusNotImplemented)\n   996â†’\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"orchestrator not configured\"})\n   997â†’\t\treturn\n   998â†’\t}\n   999â†’\tvar body struct {\n  1000â†’\t\tConcurrency int `json:\"concurrency\"`\n  1001â†’\t}\n  1002â†’\tif err := json.NewDecoder(r.Body).Decode(&body); err != nil || body.Concurrency < 1 {\n  1003â†’\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n  1004â†’\t\tw.WriteHeader(http.StatusBadRequest)\n  1005â†’\t\tjson.NewEncoder(w).Encode(map[string]string{\"error\": \"concurrency must be a positive integer\"})\n  1006â†’\t\treturn\n  1007â†’\t}\n  1008â†’\th.orchestrator.SetConcurrency(dir, body.Concurrency)\n  1009â†’\tw.Header().Set(\"Content-Type\", \"application/json\")\n  1010â†’\tjson.NewEncoder(w).Encode(map[string]string{\"status\": \"ok\"})\n  1011â†’}\n  1012â†’\n  1013â†’func (h *Handler) handleAPIProjectInfo(w http.ResponseWriter, r *http.Request) {\n  1014â†’\tdir, _, ok := h.resolveProjectDir(w, r)\n  1015â†’\tif !ok {\n  1016â†’\t\treturn\n  1017â†’\t}\n  1018â†’\n  1019â†’\t// Docker image: read FROM line from Dockerfile\n  1020â†’\tdockerImage := \"\"\n  1021â†’\tdockerfilePath := filepath.Join(dir, \".cloche\", \"Dockerfile\")\n  1022â†’\tif data, err := os.ReadFile(dockerfilePath); err == nil {\n  1023â†’\t\t// Find the last FROM line (final stage)\n  1024â†’\t\tfor _, line := range strings.Split(string(data), \"\\n\") {\n  1025â†’\t\t\ttrimmed := strings.TrimSpace(line)\n  1026â†’\t\t\tif strings.HasPrefix(strings.ToUpper(trimmed), \"FROM \") {\n  1027â†’\t\t\t\tparts := strings.Fields(trimmed)\n  1028â†’\t\t\t\tif len(parts) >= 2 {\n  1029â†’\t\t\t\t\tdockerImage = parts[1]\n  1030â†’\t\t\t\t}\n  1031â†’\t\t\t}\n  1032â†’\t\t}\n  1033â†’\t}\n  1034â†’\n  1035â†’\t// Version\n  1036â†’\tversion := 0\n  1037â†’\tversionPath := filepath.Join(dir, \".cloche\", \"version\")\n  1038â†’\tif data, err := os.ReadFile(versionPath); err == nil {\n  1039â†’\t\tif v, err := strconv.Atoi(strings.TrimSpace(string(data))); err == nil {\n  1040â†’\t\t\tversion = v\n  1041â†’\t\t}\n  1042â†’\t}\n  1043â†’\n  1044â†’\t// Prompt files history\n  1045â†’\ttype commitEntry struct {\n  1046â†’\t\tSHA     string `json:\"sha\"`\n  1047â†’\t\tDate    string `json:\"date\"`\n  1048â†’\t\tMessage string `json:\"message\"`\n  1049â†’\t}\n  1050â†’\ttype promptFile struct {\n  1051â†’\t\tPath    string        `json:\"path\"`\n  1052â†’\t\tHistory []commitEntry `json:\"history\"`\n  1053â†’\t}\n  1054â†’\n  1055â†’\tvar promptFiles []promptFile\n  1056â†’\tpromptsDir := filepath.Join(dir, \".cloche\", \"prompts\")\n  1057â†’\tif entries, err := os.ReadDir(promptsDir); err == nil {\n  1058â†’\t\tfor _, e := range entries {\n  1059â†’\t\t\tif e.IsDir() {\n  1060â†’\t\t\t\tcontinue\n  1061â†’\t\t\t}\n  1062â†’\t\t\trelPath := filepath.Join(\".cloche\", \"prompts\", e.Name())\n  1063â†’\t\t\tcmd := exec.Command(\"git\", \"log\", \"--follow\", \"--format=%H %aI %s\", \"--\", relPath)\n  1064â†’\t\t\tcmd.Dir = dir\n  1065â†’\t\t\tout, err := cmd.Output()\n  1066â†’\t\t\tif err != nil {\n  1067â†’\t\t\t\tcontinue\n  1068â†’\t\t\t}\n  1069â†’\t\t\tvar history []commitEntry\n  1070â†’\t\t\tfor _, line := range strings.Split(strings.TrimSpace(string(out)), \"\\n\") {\n  1071â†’\t\t\t\tif line == \"\" {\n  1072â†’\t\t\t\t\tcontinue\n  1073â†’\t\t\t\t}\n  1074â†’\t\t\t\tparts := strings.SplitN(line, \" \", 3)\n  1075â†’\t\t\t\tif len(parts) < 3 {\n  1076â†’\t\t\t\t\tcontinue\n  1077â†’\t\t\t\t}\n  1078â†’\t\t\t\t// Parse date to short form\n  1079â†’\t\t\t\tdateStr := parts[1]\n  1080â†’\t\t\t\tif t, err := time.Parse(time.RFC3339, dateStr); err == nil {\n  1081â†’\t\t\t\t\tdateStr = t.Format(\"2006-01-02\")\n  1082â†’\t\t\t\t}\n  1083â†’\t\t\t\thistory = append(history, commitEntry{\n  1084â†’\t\t\t\t\tSHA:     parts[0][:7],\n  1085â†’\t\t\t\t\tDate:    dateStr,\n  1086â†’\t\t\t\t\tMessage: parts[2],\n  1087â†’\t\t\t\t})\n  1088â†’\t\t\t}\n  1089â†’\t\t\tpromptFiles = append(promptFiles, promptFile{Path: relPath, History: history})\n  1090â†’\t\t}\n  1091â†’\t}\n  1092â†’\n  1093â†’\tw.Header().Set(\"Content-Type\", \"application/json\")\n  1094â†’\tjson.NewEncoder(w).Encode(map[string]any{\n  1095â†’\t\t\"docker_image\": dockerImage,\n  1096â†’\t\t\"version\":      version,\n  1097â†’\t\t\"prompt_files\": promptFiles,\n  1098â†’\t})\n  1099â†’}\n  1100â†’\n  1101â†’func (h *Handler) handleAPIPromptDiff(w http.ResponseWriter, r *http.Request) {\n  1102â†’\tdir, _, ok := h.resolveProjectDir(w, r)\n  1103â†’\tif !ok {\n  1104â†’\t\treturn\n  1105â†’\t}\n  1106â†’\tfile := r.URL.Query().Get(\"file\")\n  1107â†’\tsha := r.URL.Query().Get(\"sha\")\n  1108â†’\tif file == \"\" || sha == \"\" {\n  1109â†’\t\thttp.Error(w, \"file and sha required\", http.StatusBadRequest)\n  1110â†’\t\treturn\n  1111â†’\t}\n  1112â†’\n  1113â†’\t// Validate sha is alphanumeric to prevent injection\n  1114â†’\tfor _, c := range sha {\n  1115â†’\t\tif !((c >= '0' && c <= '9') || (c >= 'a' && c <= 'f') || (c >= 'A' && c <= 'F')) {\n  1116â†’\t\t\thttp.Error(w, \"invalid sha\", http.StatusBadRequest)\n  1117â†’\t\t\treturn\n  1118â†’\t\t}\n  1119â†’\t}\n  1120â†’\n  1121â†’\tcmd := exec.Command(\"git\", \"diff\", sha+\"^..\"+sha, \"--\", file)\n  1122â†’\tcmd.Dir = dir\n  1123â†’\tout, err := cmd.Output()\n  1124â†’\tif err != nil {\n  1125â†’\t\thttp.Error(w, \"diff not available\", http.StatusNotFound)\n  1126â†’\t\treturn\n  1127â†’\t}\n  1128â†’\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n  1129â†’\tw.Write(out)\n  1130â†’}\n  1131â†’\n  1132â†’func (h *Handler) handleAPIWorkflows(w http.ResponseWriter, r *http.Request) {\n  1133â†’\tdir, _, ok := h.resolveProjectDir(w, r)\n  1134â†’\tif !ok {\n  1135â†’\t\treturn\n  1136â†’\t}\n  1137â†’\n  1138â†’\tclocheDir := filepath.Join(dir, \".cloche\")\n  1139â†’\tentries, err := os.ReadDir(clocheDir)\n  1140â†’\tif err != nil {\n  1141â†’\t\tw.Header().Set(\"Content-Type\", \"application/json\")\n  1142â†’\t\tjson.NewEncoder(w).Encode([]any{})\n  1143â†’\t\treturn\n  1144â†’\t}\n  1145â†’\n  1146â†’\ttype apiWire struct {\n  1147â†’\t\tFrom   string `json:\"from\"`\n  1148â†’\t\tResult string `json:\"result\"`\n  1149â†’\t\tTo     string `json:\"to\"`\n  1150â†’\t}\n  1151â†’\ttype apiStepDef struct {\n  1152â†’\t\tName    string            `json:\"name\"`\n  1153â†’\t\tType    string            `json:\"type\"`\n  1154â†’\t\tResults []string          `json:\"results\"`\n  1155â†’\t\tConfig  map[string]string `json:\"config\"`\n  1156â†’\t}\n  1157â†’\ttype apiWorkflow struct {\n  1158â†’\t\tName      string       `json:\"name\"`\n  1159â†’\t\tFile      string       `json:\"file\"`\n  1160â†’\t\tSteps     []apiStepDef `json:\"steps\"`\n  1161â†’\t\tWires     []apiWire    `json:\"wires\"`\n  1162â†’\t\tEntryStep string       `json:\"entry_step\"`\n  1163â†’\t}\n  1164â†’\n  1165â†’\tvar workflows []apiWorkflow\n  1166â†’\tfor _, e := range entries {\n  1167â†’\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n  1168â†’\t\t\tcontinue\n  1169â†’\t\t}\n  1170â†’\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n  1171â†’\t\tif err != nil {\n  1172â†’\t\t\tcontinue\n  1173â†’\t\t}\n  1174â†’\t\twf, err := dsl.Parse(string(data))\n  1175â†’\t\tif err != nil {\n  1176â†’\t\t\tcontinue\n  1177â†’\t\t}\n  1178â†’\t\tvar steps []apiStepDef\n  1179â†’\t\tfor _, s := range wf.Steps {\n  1180â†’\t\t\tsteps = append(steps, apiStepDef{\n  1181â†’\t\t\t\tName:    s.Name,\n  1182â†’\t\t\t\tType:    string(s.Type),\n  1183â†’\t\t\t\tResults: s.Results,\n  1184â†’\t\t\t\tConfig:  s.Config,\n  1185â†’\t\t\t})\n  1186â†’\t\t}\n  1187â†’\t\t// Sort steps by name for consistent ordering\n  1188â†’\t\tsort.Slice(steps, func(i, j int) bool { return steps[i].Name < steps[j].Name })\n  1189â†’\n  1190â†’\t\tvar wires []apiWire\n  1191â†’\t\tfor _, wire := range wf.Wiring {\n  1192â†’\t\t\twires = append(wires, apiWire{From: wire.From, Result: wire.Result, To: wire.To})\n  1193â†’\t\t}\n  1194â†’\n  1195â†’\t\tworkflows = append(workflows, apiWorkflow{\n  1196â†’\t\t\tName:      wf.Name,\n  1197â†’\t\t\tFile:      filepath.Join(\".cloche\", e.Name()),\n  1198â†’\t\t\tSteps:     steps,\n  1199â†’\t\t\tWires:     wires,\n  1200â†’\t\t\tEntryStep: wf.EntryStep,\n  1201â†’\t\t})\n  1202â†’\t}\n  1203â†’\n  1204â†’\tw.Header().Set(\"Content-Type\", \"application/json\")\n  1205â†’\tjson.NewEncoder(w).Encode(workflows)\n  1206â†’}\n  1207â†’\n  1208â†’func (h *Handler) handleAPIStepContent(w http.ResponseWriter, r *http.Request) {\n  1209â†’\tdir, _, ok := h.resolveProjectDir(w, r)\n  1210â†’\tif !ok {\n  1211â†’\t\treturn\n  1212â†’\t}\n  1213â†’\tworkflowName := r.PathValue(\"workflow\")\n  1214â†’\tstepName := r.PathValue(\"step\")\n  1215â†’\n  1216â†’\t// Find the workflow file\n  1217â†’\tclocheDir := filepath.Join(dir, \".cloche\")\n  1218â†’\tvar wf *domain.Workflow\n  1219â†’\tentries, _ := os.ReadDir(clocheDir)\n  1220â†’\tfor _, e := range entries {\n  1221â†’\t\tif e.IsDir() || !strings.HasSuffix(e.Name(), \".cloche\") || e.Name() == \"host.cloche\" {\n  1222â†’\t\t\tcontinue\n  1223â†’\t\t}\n  1224â†’\t\tdata, err := os.ReadFile(filepath.Join(clocheDir, e.Name()))\n  1225â†’\t\tif err != nil {\n  1226â†’\t\t\tcontinue\n  1227â†’\t\t}\n  1228â†’\t\tparsed, err := dsl.Parse(string(data))\n  1229â†’\t\tif err != nil {\n  1230â†’\t\t\tcontinue\n  1231â†’\t\t}\n  1232â†’\t\tif parsed.Name == workflowName {\n  1233â†’\t\t\twf = parsed\n  1234â†’\t\t\tbreak\n  1235â†’\t\t}\n  1236â†’\t}\n  1237â†’\tif wf == nil {\n  1238â†’\t\thttp.Error(w, \"workflow not found\", http.StatusNotFound)\n  1239â†’\t\treturn\n  1240â†’\t}\n  1241â†’\n  1242â†’\tstep, ok := wf.Steps[stepName]\n  1243â†’\tif !ok {\n  1244â†’\t\thttp.Error(w, \"step not found\", http.StatusNotFound)\n  1245â†’\t\treturn\n  1246â†’\t}\n  1247â†’\n  1248â†’\t// Try to read the referenced file from step config\n  1249â†’\tw.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")\n  1250â†’\n  1251â†’\tif prompt := step.Config[\"prompt\"]; prompt != \"\" {\n  1252â†’\t\tdata, err := os.ReadFile(filepath.Join(dir, prompt))\n  1253â†’\t\tif err == nil {\n  1254â†’\t\t\tw.Write(data)\n  1255â†’\t\t\treturn\n  1256â†’\t\t}\n  1257â†’\t}\n  1258â†’\tif script := step.Config[\"command\"]; script != \"\" {\n  1259â†’\t\tw.Write([]byte(script))\n  1260â†’\t\treturn\n  1261â†’\t}\n  1262â†’\tif script := step.Config[\"script\"]; script != \"\" {\n  1263â†’\t\tdata, err := os.ReadFile(filepath.Join(dir, script))\n  1264â†’\t\tif err == nil {\n  1265â†’\t\t\tw.Write(data)\n  1266â†’\t\t\treturn\n  1267â†’\t\t}\n  1268â†’\t\tw.Write([]byte(script))\n  1269â†’\t\treturn\n  1270â†’\t}\n  1271â†’\n  1272â†’\thttp.Error(w, \"no content available\", http.StatusNotFound)\n  1273â†’}\n  1274â†’\n  1275â†’// --- Template helpers ---\n  1276â†’\n  1277â†’func stateColor(state domain.RunState) string {\n  1278â†’\tswitch state {\n  1279â†’\tcase domain.RunStatePending:\n  1280â†’\t\treturn \"pending\"\n  1281â†’\tcase domain.RunStateRunning:\n  1282â†’\t\treturn \"running\"\n  1283â†’\tcase domain.RunStateSucceeded:\n  1284â†’\t\treturn \"succeeded\"\n  1285â†’\tcase domain.RunStateFailed:\n  1286â†’\t\treturn \"failed\"\n  1287â†’\tcase domain.RunStateCancelled:\n  1288â†’\t\treturn \"cancelled\"\n  1289â†’\tdefault:\n  1290â†’\t\treturn \"pending\"\n  1291â†’\t}\n  1292â†’}\n  1293â†’\n  1294â†’func healthColor(status domain.HealthStatus) string {\n  1295â†’\tswitch status {\n  1296â†’\tcase domain.HealthGreen:\n  1297â†’\t\treturn \"green\"\n  1298â†’\tcase domain.HealthYellow:\n  1299â†’\t\treturn \"yellow\"\n  1300â†’\tcase domain.HealthRed:\n  1301â†’\t\treturn \"red\"\n  1302â†’\tcase domain.HealthBlue:\n  1303â†’\t\treturn \"blue\"\n  1304â†’\tdefault:\n  1305â†’\t\treturn \"grey\"\n  1306â†’\t}\n  1307â†’}\n  1308â†’\n  1309â†’func formatTime(t time.Time) string {\n  1310â†’\tif t.IsZero() {\n  1311â†’\t\treturn \"\"\n  1312â†’\t}\n  1313â†’\treturn t.Format(\"2006-01-02 15:04:05\")\n  1314â†’}\n  1315â†’\n  1316â†’func formatDuration(start, end time.Time) string {\n  1317â†’\tif start.IsZero() || end.IsZero() {\n  1318â†’\t\treturn \"\"\n  1319â†’\t}\n  1320â†’\td := end.Sub(start)\n  1321â†’\tif d < time.Second {\n  1322â†’\t\treturn fmt.Sprintf(\"%dms\", d.Milliseconds())\n  1323â†’\t}\n  1324â†’\tif d < time.Minute {\n  1325â†’\t\treturn fmt.Sprintf(\"%.1fs\", d.Seconds())\n  1326â†’\t}\n  1327â†’\treturn fmt.Sprintf(\"%dm%ds\", int(d.Minutes()), int(d.Seconds())%60)\n  1328â†’}\n  1329â†’\n  1330â†’func truncate(s string, n int) string {\n  1331â†’\tif len(s) <= n {\n  1332â†’\t\treturn s\n  1333â†’\t}\n  1334â†’\treturn s[:n] + \"...\"\n  1335â†’}\n  1336â†’\n  1337â†’func shortContainerID(id string) string {\n  1338â†’\tif len(id) > 12 {\n  1339â†’\t\treturn id[:12]\n  1340â†’\t}\n  1341â†’\treturn id\n  1342â†’}\n  1343â†’\n  1344â†’// projectLabels builds a mapping from full project directory paths to short\n  1345â†’// display labels. Each label is the final directory component (e.g.\n  1346â†’// \"myproject\" from \"/home/user/workspace/myproject\"). When two projects share\n  1347â†’// the same final name, the parent directory is prepended to disambiguate\n  1348â†’// (e.g. \"foo/bar\" vs \"baz/bar\").\n  1349â†’func projectLabels(dirs []string) map[string]string {\n  1350â†’\tlabels := make(map[string]string, len(dirs))\n  1351â†’\t// Group dirs by their base name to detect conflicts.\n  1352â†’\tbyBase := map[string][]string{}\n  1353â†’\tfor _, d := range dirs {\n  1354â†’\t\tbase := filepath.Base(d)\n  1355â†’\t\tbyBase[base] = append(byBase[base], d)\n  1356â†’\t}\n  1357â†’\tfor base, paths := range byBase {\n  1358â†’\t\tif len(paths) == 1 {\n  1359â†’\t\t\tlabels[paths[0]] = base\n  1360â†’\t\t} else {\n  1361â†’\t\t\tfor _, p := range paths {\n  1362â†’\t\t\t\tparent := filepath.Base(filepath.Dir(p))\n  1363â†’\t\t\t\tlabels[p] = parent + \"/\" + base\n  1364â†’\t\t\t}\n  1365â†’\t\t}\n  1366â†’\t}\n  1367â†’\treturn labels\n  1368â†’}\n  1369â†’\n  1370â†’type projectEntry struct {\n  1371â†’\tDir            string\n  1372â†’\tLabel          string\n  1373â†’\tContainerCount int\n  1374â†’}\n  1375â†’"}]},"parent_tool_use_id":"toolu_01GueLSMW6cczFRCXbWjkJcQ","session_id":"b51150cf-1c39-4197-a920-3b3045b4ca95","uuid":"fd4704a2-784f-42bc-ac9c-2ca933eeb9b7"}
