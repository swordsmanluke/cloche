workflow "list-tasks" {
  step ready-tasks {
    run     = "bash .cloche/scripts/ready-tasks.sh"
    results = [success, fail]
  }

  ready-tasks:success -> done
  ready-tasks:fail    -> abort
}

workflow "main" {
  host {
    agent_command = "claude"
  }

  step claim-task {
    run     = "bash .cloche/scripts/claim-task.sh"
    results = [success, fail]
  }

  step prepare-prompt {
    run     = "bash .cloche/scripts/prepare-prompt.sh"
    results = [success, fail]
  }

  step develop {
    workflow_name = "develop"
    results       = [success, fail]
  }

  step merge {
    run     = "bash .cloche/scripts/merge-to-main.sh"
    results = [success, fail]
  }

  step cleanup {
    run     = "bash .cloche/scripts/cleanup-run.sh"
    results = [success, fail]
  }

  claim-task:success     -> prepare-prompt
  claim-task:fail        -> abort
  prepare-prompt:success -> develop
  prepare-prompt:fail    -> abort
  develop:success        -> merge
  develop:fail           -> abort
  merge:success          -> cleanup
  merge:fail             -> abort
  cleanup:success        -> done
  cleanup:fail           -> done
}

workflow "release-task" {
  step release-task {
    run     = "bash .cloche/scripts/release-task.sh"
    results = [success, fail]
  }

  release-task:success -> done
  release-task:fail    -> abort
}

workflow "finalize" {
  host {
    agent_command = "claude"
  }

  step bump-version {
    prompt  = file(".cloche/prompts/bump-version.md")
    results = [success, fail]
  }

  step close-task {
    run     = "bash .cloche/scripts/close-task.sh"
    results = [success, fail]
  }

  bump-version:success -> close-task
  bump-version:fail    -> close-task
  close-task:success   -> done
  close-task:fail      -> done
}
