.env
bin/
.serena/

# Claude Code local settings
**/.claude/settings.local.json

# Built binaries
/cloche
/cloched
/cloche-agent

# Beads task tracker (managed by bd, not git)
.beads/

# Local state
*.db
*.db-shm
*.db-wal

# Example build artifacts
examples/**/target/
examples/**/build/
examples/mini-redis/mini-redis
examples/mini-redis/test_runner

# Cloche runtime artifacts (config/workflow/prompt files are tracked)
.cloche/*-*-*/
.cloche/run-*/
.cloche/attempt_count/
.cloche/evolution/
.cloche/history.log
.cloche/prompt.txt
.cloche/output/
.gitworktrees/

# Example projects' runtime state
examples/*/.cloche/
.cloche/logs/
