#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage: bumpver [major|minor] [--version-file|-f <filepath>]

Increments the project's VERSION value according to Semantic Versioning.

  bumpver           Increment build number (patch)
  bumpver minor     Increment minor version, reset build to 0
  bumpver major     Increment major version, reset minor and build to 0

Options:
  -f, --version-file <filepath>   Path to VERSION file (default: internal/version/VERSION)
EOF
  exit 1
}

version_file="internal/version/VERSION"
bump="build"

while [[ $# -gt 0 ]]; do
  case "$1" in
    major|minor)
      bump="$1"
      shift
      ;;
    -f|--version-file)
      [[ $# -lt 2 ]] && { echo "error: $1 requires an argument" >&2; exit 1; }
      version_file="$2"
      shift 2
      ;;
    -h|--help)
      usage
      ;;
    *)
      echo "error: unknown argument: $1" >&2
      usage
      ;;
  esac
done

if [[ ! -f "$version_file" ]]; then
  echo "error: version file not found: $version_file" >&2
  exit 1
fi

content=$(cat "$version_file")
line_count=$(echo "$content" | wc -l)

if [[ -z "$content" ]]; then
  echo "error: version file is empty: $version_file" >&2
  exit 1
fi

if [[ "$line_count" -ne 1 ]]; then
  echo "error: version file must contain exactly one line: $version_file" >&2
  exit 1
fi

if ! echo "$content" | grep -qE '^[0-9]+\.[0-9]+\.[0-9]+$'; then
  echo "error: version does not match expected format (X.Y.Z): $content" >&2
  exit 1
fi

IFS='.' read -r major minor build <<< "$content"

case "$bump" in
  major)
    major=$((major + 1))
    minor=0
    build=0
    ;;
  minor)
    minor=$((minor + 1))
    build=0
    ;;
  build)
    build=$((build + 1))
    ;;
esac

new_version="${major}.${minor}.${build}"
printf '%s\n' "$new_version" > "$version_file"
echo "$new_version"
